// ============================================================================
// Teko SDK - Native Messaging and CQRS Infrastructure (Core Flows)
// Internal Namespace: teko::flows
// ============================================================================

// Dispatches a Command synchronously, awaiting a response intent
pub fn request<T>(command_data: T) : intent<void>
    where T : struct;

// Fires a Notification in an asynchronous model (Fire-and-Forget)
// The VM runtime routes the event to Green Threads managed by the Scheduler
pub fn notify<T>(notification_data: T) : i32
    where T : struct;

// Sends a Query requiring a channel or typed intent with the contract's return
pub fn send<T, R>(query_data: T) : intent<R>
    where T : struct;
