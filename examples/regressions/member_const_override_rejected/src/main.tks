/**
 * Widget — a struct that ILLEGALLY marks a member `const` with `override`. The parser rejects this:
 * `override` is method-only; a member const is statically hidden, never overridden (#594 crumb 7).
 *
 * @field id  the widget's identifier
 */
type Widget = struct {
    /** the widget's identifier */
    id: i64
    /** BAD — a member const bearing `override`: a located parse error. */
    override const BAD: i64 = 1
}

exit(0)
