let step_result = check_value_steps()
if step_result != 0 { exit(step_result) }
let region_result = check_region_values()
if region_result != 0 { exit(region_result) }
let closure_result = check_closure_state()
if closure_result != 0 { exit(closure_result) }
let pipeline_result = check_pipeline()
if pipeline_result != 0 { exit(pipeline_result) }
