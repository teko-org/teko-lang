let a = List<i64>::make()
if !a.is_empty() { exit(1) }
a.push(10)
a.push(20)
a.push(30)
if a.len() != 3 { exit(2) }
if a.get(0) != 10 { exit(3) }
if a.get(2) != 30 { exit(4) }

a.set(1, 99)
if a.get(1) != 99 { exit(5) }

a.pop()
if a.len() != 2 { exit(6) }
if a.get(1) != 99 { exit(7) }

let b = a
b.push(7)
if a.len() != 3 { exit(8) }
if a.get(2) != 7 { exit(9) }

let s = List<str>::make()
s.push("x")
s.push("yy")
if s.len() != 2 { exit(10) }
if s.get(1) != "yy" { exit(11) }

exit(0)
