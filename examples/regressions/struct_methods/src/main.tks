let p1 = Point { x = 3; y = 4 }
let p2 = p1.scaled(2)
let p3 = Point::origin()
let p4 = Point::make(10, 20)

if p1.sum() != 7 { exit(1) }
if p2.x != 6 { exit(2) }
if p2.y != 8 { exit(3) }
if p3.x != 0 { exit(4) }
if p3.y != 0 { exit(5) }
if p4.x != 10 { exit(6) }
if p4.y != 20 { exit(7) }
if p4.sum() != 30 { exit(8) }
