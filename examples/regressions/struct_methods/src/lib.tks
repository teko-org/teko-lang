type Point = struct {
    x: i64
    y: i64
    fn sum(self) -> i64 { self.x + self.y }
    fn scaled(self, factor: i64) -> Point { Point { x = self.x * factor; y = self.y * factor } }
    fn origin() -> Point { Point { x = 0; y = 0 } }
    fn make(x: i64, y: i64) -> Point { Point { x = x; y = y } }
}
