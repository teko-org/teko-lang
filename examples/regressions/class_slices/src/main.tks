// distinct exit codes per failure surface (0 = all pass; the harness diffs VM vs native).
let r1 = check_construct_index_len()
if r1 != 0 { exit(r1) }

let r2 = check_nested()
if r2 != 0 { exit(r2) }

let r3 = check_field()
if r3 != 0 { exit(r3) }

let r4 = check_param_return()
if r4 != 0 { exit(r4) }

let r5 = check_covariant_upcast()
if r5 != 0 { exit(r5) }

exit(0)
