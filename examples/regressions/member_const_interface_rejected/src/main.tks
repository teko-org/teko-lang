/**
 * Contract — an interface that ILLEGALLY declares a `const` member. The parser rejects this: an
 * interface carries no statics, so a member const is only allowed in a struct/class/trait body.
 */
type Contract = interface {
    /**
     * run — an ordinary interface method signature (legal).
     *
     * @return an i64
     */
    fn run(self) -> i64
    /** BAD — a `const` member in an interface body: a located parse error (#594 crumb 7). */
    const BAD: i64 = 1
}

exit(0)
