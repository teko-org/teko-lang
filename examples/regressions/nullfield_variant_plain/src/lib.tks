/**
 * A — one payload-bearing case of `Op`, carrying an `i64` in `x`.
 *
 * @field x  the case's payload, returned by `read` on the `A` arm
 */
type A = struct {
    /** the case's payload, returned by `read` on the `A` arm. */
    x: i64
}

/**
 * B — the other payload-bearing case of `Op`, carrying an `i64` in `y`.
 *
 * @field y  the case's payload, returned by `read` on the `B` arm
 */
type B = struct {
    /** the case's payload, returned by `read` on the `B` arm. */
    y: i64
}

/**
 * Op — a two-case variant whose largest payload is 8 bytes, so `Op | null` takes the INLINE-TAG
 * representation (`{ uint8 tag; union { A; B } }`) embedded BY VALUE in a struct field.
 */
type Op = variant A | B

/**
 * Slot — the struct under test: its `f` field is the inline-tag absence union `Op | null`, the shape
 * whose topological emission ordering the nullfield fix corrected. A second scalar field neighbours it
 * so the field is not the whole struct.
 *
 * @field f    the `Op | null` field — a present `Op` case or `null`
 * @field tag  a neighbouring scalar (proves the field carries a real offset, not the whole struct)
 */
type Slot = struct {
    /** the `Op | null` field — a present `Op` case or `null`. */
    f: Op | null
    /** a neighbouring scalar, so the union field carries a real offset. */
    tag: i64
}

/**
 * with_a — a `Slot` whose union field holds an `A` case carrying `v` (a value written into the field).
 *
 * @param v  the `A` payload
 * @return   a `Slot` with `f = A { x = v }`
 * @since 0.3.0.30
 */
pub fn with_a(v: i64) -> Slot { return Slot { f = A { x = v }; tag = 1 } }

/**
 * with_b — a `Slot` whose union field holds a `B` case carrying `v`.
 *
 * @param v  the `B` payload
 * @return   a `Slot` with `f = B { y = v }`
 * @since 0.3.0.30
 */
pub fn with_b(v: i64) -> Slot { return Slot { f = B { y = v }; tag = 2 } }

/**
 * empty_slot — a `Slot` whose union field holds `null` (a bare `null` written into an inline-tag field).
 *
 * @return a `Slot` with `f = null`
 * @since 0.3.0.30
 */
pub fn empty_slot() -> Slot { return Slot { f = null; tag = 0 } }

/**
 * read — the field's payload: match the outer `Op` case then its inner `A`/`B` case for the payload,
 * or 0 when the field is `null`.
 *
 * @param s  the slot whose `Op | null` field is read
 * @return   the present case's payload, or 0 for `null`
 * @since 0.3.0.30
 */
pub fn read(s: Slot) -> i64 {
    match s.f {
        Op as v => match v { A as a => return a.x; B as b => return b.y }
        null => return 0
    }
}
