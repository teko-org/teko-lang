/**
 * bad — a for-each header `loop mut _ in xs` that binds the write-only discard `_` in declarative
 * position; the parser rejects the `_` target (aliasing/binding a discard is invalid outside a
 * pattern wildcard) before this body is type-checked (owner ruling 2026-07-15).
 *
 * @param xs  the iterated slice
 * @return    never — the parser rejects this source at parse time
 */
pub fn bad(xs: []i64) -> i64 {
    loop mut _ in xs { }
    0
}
