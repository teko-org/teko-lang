/**
 * bad — holds an invalid typed discard target `let _: i64 = 1`; the parser rejects the `_` target
 * (the write-only discard takes no type) before this body is type-checked (owner ruling 2026-07-15).
 *
 * @return  never — the parser rejects this source at parse time
 */
pub fn bad() -> i64 {
    let _: i64 = 1
    0
}
