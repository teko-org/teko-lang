let source_path = "/tmp/teko_io_file_copy_source_184.txt"
let archive_path = "/tmp/teko_io_file_copy_archive_184.tkl"
let out_path = "/tmp/teko_io_file_copy_out_184.txt"

let seed = match write_file_bytes(source_path, bytes_of_str("the quick brown fox\njumps over\n")) {
    error => 20
    null => 0
}
if seed != 0 { exit(seed) }

let result = run_copy_pipeline(source_path, archive_path, out_path)
if result != 0 { exit(result) }
