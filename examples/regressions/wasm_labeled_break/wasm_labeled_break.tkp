# C1-8b own-wasm #520 engine fixture (issue #389, backend-wasm.md §14.1). A labeled
# `break OUTER` from an inner loop resolves to a MULTI-LEVEL `br N` at the correct scope depth
# (the outer loop's wrapping `block`). Exits with the value set just before the labeled break.
# own-wasm (wasmtime) and C-native must agree on exit 7 (scripts/validate_wasm_own.sh).
name = "wasm_labeled_break"
source = "src"

[artifact]
kind = "binary"
