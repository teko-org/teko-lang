// (W10b.IF) conformance is a COMPILE-TIME check — this program only builds because Point and Circle
// each provide every method of Named (transitively including Describable's describe). The runtime
// just confirms the concrete methods dispatch correctly.
let p = Point { x = 5 }
if p.describe() != "point" { exit(1) }
if p.name_of() != "P" { exit(2) }

let c = Circle::make(2)
if c.describe() != "circle" { exit(3) }
if c.name_of() != "C" { exit(4) }
if c.r != 2 { exit(5) }
