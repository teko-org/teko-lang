// (W10b.IF) an interface is a PURE SIGNATURE CONTRACT — bodyless instance-method signatures only.
// A `Describable` describes itself; `Named` extends `Describable` and adds a name. Both a STRUCT
// and a CLASS may conform (a struct implements via `struct I & … { … }`, a class via `class & I`).
type Describable = interface {
    fn describe(self) -> str
}

// multiple inheritance via `&`: a `Named` is a `Describable` that also has a name. A conforming
// type must therefore provide BOTH describe (from Describable, transitively) AND name_of.
type Named = interface Describable {
    fn name_of(self) -> str
}

// a STRUCT conforms — its members are all-public, so a plain `fn` satisfies the interface contract.
type Point = struct Named {
    x: i64
    fn describe(self) -> str { "point" }
    fn name_of(self) -> str { "P" }
}

// a CLASS conforms — a class method must be genuinely `pub` to satisfy the public interface.
type Circle = class & Named {
    pub r: i64
    pub fn make(rr: i64) -> Circle { Circle { r = rr } }
    pub fn describe(self) -> str { "circle" }
    pub fn name_of(self) -> str { "C" }
}
