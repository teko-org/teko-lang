// Virtual main: exit code = m::pick_area(true) = 30 (Circle{r=3} -> 30).
// Also exercises the value-form `match` arm-join site (m::pick_area_match) — both must agree.
// See if_arm_variant_widen.tkp for the full derivation.
use m

let via_if = m::pick_area(true)          // 30
let via_match = m::pick_area_match(0)     // 30
// If either path mis-widened, they would disagree; return via_if (30) only when both agree.
(if via_if == via_match { via_if } else { 1 }) to i32
