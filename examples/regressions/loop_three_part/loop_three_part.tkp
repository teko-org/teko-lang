# Regression (#517): the C-style 3-part loop head `loop mut i = a; <cond>; <step> { B }`. Proves the
# step runs guarded at the TOP (so `continue` still advances), the condition is re-evaluated each
# iteration, and a non-unit step (`i += 2`) works. Self-checks with exit codes; VM == native.
name = "loop_three_part"
