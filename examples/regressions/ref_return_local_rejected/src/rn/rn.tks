/**
 * bad — a `-> ref T` function that returns a reference to a LOCAL (`ref x` of a frame-local): rejected
 * as an escaping reference (only an own `ref` parameter may be returned — the identity pass-down).
 *
 * @return never — an escaping reference is a compile error (EXPECT_COMPILE_FAIL)
 */
fn bad() -> ref i64 {
    mut x: i64 = 5
    ref x
}

/**
 * probe — forwards `bad`; present so the module has a public entry.
 *
 * @return never — see `bad`
 */
pub fn probe() -> i64 { bad() }
