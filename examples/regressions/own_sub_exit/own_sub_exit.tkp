# A4-5 own-backend differential fixture (issue #385, §9.2; reworked issue #22). `n` is a
# `mut` local (`comptime_fold`'s CF3 local-const propagation never records a `mut` binding
# — DECISION_LOG:391 — so its value is FOLD-OPAQUE: a real MUL and SUB are emitted, not a
# pre-computed constant). `exit(n * 20 - 18)` with `n = 3` lands on 42. VM, C-native, and
# own-native must all agree on exit 42 (scripts/diff_c_own.sh).
name = "own_sub_exit"
source = "src"

[artifact]
kind = "binary"
