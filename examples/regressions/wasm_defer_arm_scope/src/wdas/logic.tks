/**
 * maybe_announce — print "A" only when `cond` is true (via a `defer`
 * registered inside the `if`'s THEN arm, firing at that arm's OWN close),
 * then always print "B" afterward. With `cond=false`, the THEN arm never
 * runs at runtime, so "A" must never print — only "B" (issue #389, PR #553
 * review finding: an arm's own `defer` must not leak past the merge).
 *
 * @param bool cond  whether to announce "A" first
 * @return void
 */
pub fn maybe_announce(cond: bool) {
    if cond {
        defer { teko::io::println("A") }
    }
    teko::io::println("B")
}
