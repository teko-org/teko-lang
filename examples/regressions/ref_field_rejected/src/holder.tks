/**
 * A struct that tries to STORE a bare reference — rejected by the R4 escape gate (a reference cannot
 * be stored in a struct/variant/collection). The C3 R2 relaxation admits a `Reference` ONLY in the
 * `Ref<T> | null` absence shape, never as a bare stored field.
 */
type Holder = struct {
    /** An illegal stored reference — the compile must fail here. */
    r: Ref<i32>
}

