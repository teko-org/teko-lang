let rt_argv = teko::env::args()
let rt_op = rt_op_arg(rt_argv, 1)
let rt_a2 = rt_op_arg(rt_argv, 2)
let rt_b2 = rt_op_arg(rt_argv, 3)
let rt_a = rt_op_parse_u64(rt_a2)
let rt_b = rt_op_parse_u64(rt_b2)
print(rt_op_render(rt_op, rt_a2, rt_b2, rt_a, rt_b))
exit(rt_op_status(rt_op, rt_a2, rt_b2, rt_a, rt_b))
