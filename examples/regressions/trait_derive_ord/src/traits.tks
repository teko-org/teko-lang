/**
 * (TR3, #177 crumb 3) A struct deriving the structural trait `Ord`. The compiler synthesizes
 * `pub fn compare(self, other: Version) -> i64` lexicographically over `major` (i64) then `tag`
 * (str) — the second field decides only when the first ties. No method is written by hand.
 */
pub type Version = struct Ord {
    major: i64
    tag: str
}
