let a = Version { major = 1; tag = "a" }
let b = Version { major = 2; tag = "a" }
let c = Version { major = 1; tag = "b" }
let d = Version { major = 1; tag = "a" }

if a.compare(b) >= 0 { exit(1) }
if b.compare(a) <= 0 { exit(2) }
if a.compare(c) >= 0 { exit(3) }
if c.compare(a) <= 0 { exit(4) }
if a.compare(d) != 0 { exit(5) }
if a.compare(a) != 0 { exit(6) }

exit(0)
