# Regression (negative, owner ruling 2026-07-15): `let _ = expr` is INVALID. `_` is the
# write-only discard and cannot carry a declarative keyword. The keyword-less `_ = expr` is
# the only valid discard-assign. Must be REJECTED at parse time.
name = "discard_let_binding"
source = "src"

[artifact]
kind = "binary"
