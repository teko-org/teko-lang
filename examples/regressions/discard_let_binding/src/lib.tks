/**
 * bad — holds an invalid `let _ = expr` discard binding; the parser rejects the `_` target before
 * this body is ever type-checked (owner ruling 2026-07-15).
 *
 * @return  never — the parser rejects this source at parse time
 */
pub fn bad() -> i64 {
    let _ = compute()
    0
}

/**
 * compute — a trivial helper whose result the invalid `let _` binding attempts to discard.
 *
 * @return  the constant 5
 */
pub fn compute() -> i64 { 5 }
