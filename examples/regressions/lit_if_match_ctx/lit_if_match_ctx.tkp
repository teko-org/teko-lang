# Regression (A: context-directed literal typing): a `u32` binding whose value is an `if`/`match`
# whose arms are bare literals type-checks with NO cast on the arms — the branch leaves are born at
# u32. Before (A) the annotated-declaration path (`annotated_literal_ok`) had no `IfExpr`/`MatchExpr`
# case and forced a `to u32` per arm (the G2 gap). Both engines exit 14 = 7 (if) + 7 (match).
name = "lit_if_match_ctx"
source = "src"

[artifact]
kind = "binary"
