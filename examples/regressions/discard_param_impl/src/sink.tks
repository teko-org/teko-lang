/**
 * Sink — a pure interface contract whose absorb method takes three integers; a conforming type may
 * discard the ones it does not use with `_` discard parameters.
 */
type Sink = interface {
    fn absorb(self, a: i64, b: i64, keep: i64) -> i64
}

/**
 * Bin — a struct conforming to Sink whose absorb IGNORES the first two arguments via two adjacent
 * `_` discard parameters, using only its own `tag` and the kept argument.
 */
type Bin = struct Sink {
    tag: i64
    /**
     * absorb — return `tag + keep`, discarding the first two arguments (their types come by
     * position from Sink::absorb). Demonstrates two `_` discard parameters in a row.
     *
     * @param keep  the one argument this implementation keeps
     * @return      the sum of the bin's tag and the kept argument
     */
    fn absorb(self, _, _, keep: i64) -> i64 { self.tag + keep }
}
