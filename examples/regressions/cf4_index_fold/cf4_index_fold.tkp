# Regression: #comptime-fold CF4 (Layer 1c) — TIndex of a const aggregate at a const index.
#
# `const G: []byte = [0x1F to byte, 0x8B to byte]` is indexed at a CONST index `G[0]`. A module
# aggregate const is NOT inlined to its array literal (only scalar consts are); `G` stays a `TVar`
# resolving to one shared rodata entry. So the fold resolves the `G[0]` receiver through the
# module-aggregate map `build_module_agg_map` threads into `fold_program`, evaluates the element
# (`0x1F` = 31), and splices the literal at the `G[0]` site — the runtime index op is GONE. The
# enclosing `(G[0] to u64) to i32` collapses too (`cf_fold_int`'s TIndex arm), so
# `exit((G[0] to u64) to i32)` is a bare literal `31`.
#
# The fold runs in the frontend shared by both backends, so the C-native build and the own-native
# build (own==C differential) must both exit 31 (EXPECT_EXIT).
#   teko build examples/regressions/cf4_index_fold && \
#     ./examples/regressions/cf4_index_fold/cf4_index_fold   # -> exit 31
name = "cf4_index_fold"
source = "src"

[artifact]
kind = "binary"
