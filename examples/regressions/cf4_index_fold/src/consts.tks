/**
 * GZIP_MAGIC — a module-level aggregate `[]byte` const (the gzip magic prefix). On the LIR/VM +
 * native path it is NOT inlined to its array literal; a use of `GZIP_MAGIC[0]` resolves the receiver
 * through the CF4 module-aggregate map and folds to the element byte `0x1F` at comptime.
 */
pub const GZIP_MAGIC: []byte = [0x1F to byte, 0x8B to byte]
