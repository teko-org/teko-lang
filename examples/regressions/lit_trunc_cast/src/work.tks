/**
 * A truncating constant cast — `256 to u8` is out of range for the cast target, so this must fail
 * early (M.1). (A) does not sanction constant truncation.
 *
 * @return would be the truncated value as i64, but the cast never type-checks
 * @throws the M.1 "constant out of range for the cast target" error at the cast
 */
pub fn bad() -> i64 {
    let x = 256 to u8
    x to i64
}
