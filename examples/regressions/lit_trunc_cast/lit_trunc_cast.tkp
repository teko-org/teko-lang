# Regression (A, NEGATIVE — M.1 preserved): a truncating CONSTANT cast is already an M.1 error and
# (A) must NOT relax it. `256 to u8` stays a compile error (constant out of range for the cast
# target) — (A) only removes the need for a REDUNDANT cast, it never sanctions constant truncation.
name = "lit_trunc_cast"
source = "src"

[artifact]
kind = "binary"
