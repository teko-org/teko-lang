use must_free_leak::handle

/**
 * Binds a `#must_free` handle and falls off the end WITHOUT freeing it — the silent-leak
 * dropped-path this dataflow rejects (acceptance criterion 2). Never actually reached: the
 * checker must reject this function at compile time before the program ever runs.
 *
 * @return 1 (unreachable — this function fails to compile)
 */
pub fn leaks_the_handle() -> i64 {
    mut h = handle::FileHandle::open(1)
    1
}
