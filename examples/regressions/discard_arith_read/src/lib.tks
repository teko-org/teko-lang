/**
 * bad — uses the write-only discard `_` as an arithmetic operand (`_ + 1`); the parser rejects the
 * `_` R-value (it carries no value) at parse time (owner ruling 2026-07-15).
 *
 * @return  never — the parser rejects this source at parse time
 */
pub fn bad() -> i64 {
    let z = _ + 1
    z
}
