/**
 * probe — a `mut ref` binding: rejected. A reference binding is spelled `ref x: T` — the `ref` IS the
 * modifier; there is no `mut ref` (a reference is already inherently mutable).
 *
 * @return never — the binding is a compile error (EXPECT_COMPILE_FAIL)
 */
pub fn probe() -> i64 {
    mut x: i64 = 1
    mut ref r: i64 = ref x
    r
}
