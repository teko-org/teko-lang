# Regression: chars(str) -> []char and len_chars(str) -> i64 builtins (ROUND 0 UTF-8).
#
# Uses len_chars("abc") == 3 as the exit code (avoids the VM multibyte limitation).
# Both backends must agree: exit 3.
#
#   teko run   examples/regressions/chars_iter   # VM   → exit 3
#   teko build examples/regressions/chars_iter && ./examples/regressions/chars_iter/chars_iter   # → exit 3
name = "chars_iter"
source = "src"

[artifact]
kind = "binary"
