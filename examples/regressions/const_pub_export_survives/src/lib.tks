/**
 * P — a `pub` module const: reachable across the project's namespaces (#594). It survives inlining
 * with its public visibility intact and is read bare by `main.tks`.
 */
pub const P: i64 = 20

/**
 * Q — an `exp` module const: part of the exported ABI surface (#594), a strictly wider reach than
