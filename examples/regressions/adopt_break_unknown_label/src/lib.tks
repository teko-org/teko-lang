/**
 * bad_label — a labeled loop enclosing an `adopt` whose body breaks to an UNKNOWN label. The
 * checker must reject this: `check_labels` threads the same `scope` through the adopt body
 * unchanged, so the unknown-label check still fires from inside it.
 *
 * @return  never — the checker rejects this function before codegen is reached.
 */
pub fn bad_label() -> i64 {
    loop outer {
        adopt {
            break nosuchlabel
        }
        break outer
    }
    0
}
