let a: u64 = 0xFF
if $"{a:X}" != "FF" { exit(1) }
if $"{a:x}" != "ff" { exit(2) }
if $"{a:b}" != "11111111" { exit(3) }
if $"{a}" != "255" { exit(4) }
if $"0x{a:X} = {a}" != "0xFF = 255" { exit(5) }
let n: i64 = -1234567
if $"{n:n}" != "-1,234,567" { exit(6) }
if $"{n}" != "-1234567" { exit(7) }
let w: i64 = 42
if $"{w:d5}" != "00042" { exit(8) }
exit(0)
