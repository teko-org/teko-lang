# Regression: #comptime-fold CF5 — the canonical Layer-2 mandate `$"{a:X}"` -> "FF".
#
# A LOCAL `let a: u64 = 0xFF` is propagated (CF3) and its interpolation holes fold (CF5) to a single
# rodata `TStrLit` — no runtime tk_str_concat / tk_fmt_x_upper. This fixture pins the EXACT folded bytes
# against a hand-written literal (an ABSOLUTE check, complementing the differential format-oracle
# fixture): hex upper/lower, binary, the natural decimal render, and the signed thousands render each
# equal their known result, so a byte-divergent fold is caught even if it diverged identically on both
# engines. A mismatch exits with the check's ordinal; all-pass exits 0.
#
# Both engines must agree: `teko run` exit == compiled-binary exit == 0.
#   teko run   examples/regressions/comptime_fold_interp_hex   # VM     -> exit 0
#   teko build examples/regressions/comptime_fold_interp_hex && \
#     ./examples/regressions/comptime_fold_interp_hex/comptime_fold_interp_hex   # native -> exit 0
name = "comptime_fold_interp_hex"
source = "src"

[artifact]
kind = "binary"
