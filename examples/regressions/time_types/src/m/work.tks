// src/m/work.tks
// Deterministic date-accessor helpers — no OS clock calls.
// Uses date_from_days with precomputed day counts so tests are reproducible.
//
// The time types and extern fns are re-declared here because this is a standalone
// project (not the teko compiler itself), so teko::time is not in scope. The
// extern symbols are provided by teko_rt.c, which is always linked.

pub type Date = struct { days: i32 }

pub extern fn date_from_days(d: i32) -> Date = "tk_rt_date_from_days" from "teko_rt"
pub extern fn date_year(d: Date)     -> i32  = "tk_rt_date_year"      from "teko_rt"

// epoch_year: days=0 → 1970-01-01 → year 1970.
pub fn epoch_year() -> i32 { date_year(date_from_days(0)) }

// y2021_year: days=18628 → 2021-01-01 → year 2021.
// Verification: 51 years × 365 + 13 leap days (1972,1976,…,2020) = 18615 + 13 = 18628.
pub fn y2021_year() -> i32 { date_year(date_from_days(18628)) }
