// Exit code = y2021_year() - epoch_year() = 2021 - 1970 = 51.
// Build as a native binary (extern fns are VM-unsupported):
//   teko build examples/regressions/time_types -o /tmp/time_bin
//   /tmp/time_bin/time_types; echo "exit: $?"   # → exit: 51
use m

(m::y2021_year() - m::epoch_year()) to i32
