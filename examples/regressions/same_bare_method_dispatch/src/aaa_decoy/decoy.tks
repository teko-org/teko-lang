/**
 * A DECOY same-bare `Svc` in `aaa_decoy`, whose directory sorts BEFORE `left`/`right` so it is
 * collected FIRST. Its `tag_of` returns a poison value (`self.tag * 1000`); if the checker resolved
 * a `left`/`right` instance method to this class by readdir order (the pre-#290 bug) the program's
 * exit would be a large poison sum, never 10. It is never referenced from `main`, so its only role is
 * to make a namespace collision the FIRST candidate a bare last-segment scan would have found.
 */
type Svc = class {
    /** The decoy tag — multiplied by 1000 in `tag_of` to unmistakably poison any mis-resolution. */
    pub tag: i64

    /**
     * Construct a decoy `Svc`. Never called from `main` — present only to occupy the first
     * same-bare `Svc` collect slot.
     *
     * @param x  the raw tag value
     * @return   a decoy `Svc` carrying `tag = x`
     */
    pub fn make(x: i64) -> Svc { Svc { tag = x } }

    /**
     * The decoy method a mis-resolving dispatch would wrongly bind. Returns a POISON value so any
     * wrong resolution is loud in the program's exit code.
     *
     * @param self  the decoy receiver
     * @return      `self.tag * 1000` (a poison marker)
     */
    pub fn tag_of(self) -> i64 { self.tag * 1000 }
}
