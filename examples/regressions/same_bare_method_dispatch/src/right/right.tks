/**
 * A `Svc` class in the `right` namespace — the SAME bare name as `left::Svc` and `aaa_decoy::Svc`.
 * Distinct canonical name (`right::Svc`) keeps its `tag_of` a distinct dispatch target; if it
 * collided with `left::Svc` the injected instance would answer with the wrong class's method
 * (issue #290).
 */
type Svc = class {
    /** The tag this service carries; read back by `tag_of` to observe correct dispatch. */
    pub tag: i64

    /**
     * Construct a `right::Svc` with the given tag.
     *
     * @param x  the tag value
     * @return   a `right::Svc` carrying `tag = x`
     */
    pub fn make(x: i64) -> Svc { Svc { tag = x } }

    /**
     * Read this service's tag — the INSTANCE method whose cross-namespace dispatch #290 fixes.
     *
     * @param self  the `right::Svc` receiver
     * @return      `self.tag`
     */
    pub fn tag_of(self) -> i64 { self.tag }
}
