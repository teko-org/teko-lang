use crypto

let payload = bytes_of_str("The quick brown fox jumps over the lazy dog")

let sha256_ok = crypto::sha256_hex_of(payload) == "d7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592"
let sha512_ok = crypto::sha512_hex_of(payload) == "07e547d9586f6a73f73fbac0435ed76951218fb7d0c8d788a309d785436bbb642e93a252a954f23912547d1e8a3b5ed6e1bfd7097821233fa0538f3db854fee6"

mut score = 0
if sha256_ok { score = score + 1 }
if sha512_ok { score = score + 1 }
score to i32
