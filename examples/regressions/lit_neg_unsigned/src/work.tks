/**
 * A negative literal on an unsigned binding — `-1` cannot be annotated as u8, so this must fail
 * early (M.1).
 *
 * @return would be the value as i64, but the binding never type-checks
 * @throws the M.1 "a negative literal cannot be annotated as an unsigned type" error at the binding
 */
pub fn bad() -> i64 {
    let x: u8 = -1
    x to i64
}
