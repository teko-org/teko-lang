/**
 * Base — an ABSTRACT class (root namespace) declaring a `pub` static member const `OPEN`. `pub`
 * reaches across namespaces (unlike `private`), including through an inheriting subclass's name.
 */
type Base = abstract class {
    /** OPEN — public; reachable from ANY namespace, including through an inheriting subclass. */
    pub const OPEN: i64 = 5
    /**
     * kind — the concrete subclass's identifying value (an abstract requirement).
     *
     * @return the subclass's kind
     */
    pub abstract fn kind(self) -> i64
}
