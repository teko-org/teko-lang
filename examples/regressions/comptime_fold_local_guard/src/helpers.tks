/**
 * opaque — return `v` unchanged. A user function call is OPAQUE to the comptime fold (its body is
 * never evaluated at compile time — that is Layer 3, unbuilt), so a binding initialized from
 * `opaque(...)` holds a value the fold treats as RUNTIME and must never propagate (the CF3 guard).
 *
 * @param v  the value to pass through
 * @return   `v` unchanged, as a runtime-computed value
 */
fn opaque(v: u64) -> u64 { v }
