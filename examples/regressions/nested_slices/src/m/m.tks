// #81 — nested slices ([][]T) must lower natively (tk_slice_slice_<elem>), matching the VM.
// Each block contributes a known amount to the total (see ../../nested_slices.tkp): 16 total.
pub fn nested_total() -> i32 {
    // construction + chained indexing + len at both depths ([][]i64, ragged rows)
    let rows: [][]i64 = [[1], [2, 3]]
    mut total = rows[0][0] + rows[1][1] + (rows.len to i64) + (rows[1].len to i64)   // 1+3+2+2 = 8

    // [][]u8 with a width-sensitive element op: only a genuine 8-bit slot masks the
    // shift count by 7 (9 & 7 == 1 -> 200 << 1 == 400 -> truncates to byte 144).
    let grid: [][]u8 = [[200, 100], [7]]
    mut y: u8 = grid[0][0]
    y <<= 9
    total = total + ((y to i64) - 140)   // +4

    // push a fresh row into a [][]i64
    mut acc: [][]i64 = [[10]]
    acc = teko::list::push(acc, [20, 30])
    total = total + acc[1][1] - 28   // +2

    // spread nested slices into a new [][]i64
    let joined: [][]i64 = [..rows, ..acc]
    total = total + (joined.len to i64) - 3   // +1

    // nested loop iteration summing every element: 1+2+3+10+20+30 = 66
    mut i = 0
    mut sum = 0
    loop {
        if i >= joined.len { break }
        mut j = 0
        loop {
            if j >= joined[i].len { break }
            sum = sum + joined[i][j]
            j++
        }
        i++
    }
    total = total + sum - 65   // +1

    total to i32   // = 16
}
