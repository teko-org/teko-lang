/**
 * A `[]u8` slice literal with a per-element out-of-range value — `300` does not fit u8, so this must
 * fail early (M.1).
 *
 * @return would be xs[1] as i64, but the binding never type-checks
 * @throws the M.1 "literal out of range for the annotated type" error at the offending element
 */
pub fn bad() -> i64 {
    let xs: []u8 = [1, 300, 3]
    xs[1] to i64
}
