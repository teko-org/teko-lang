# Regression (A, NEGATIVE — M.1 preserved): a per-element out-of-range literal in an annotated slice
# still fails early. (A) borns each fitting element at the slice's element width but does NOT relax
# the per-element range check; `let xs: []u8 = [1, 300, 3]` must remain a compile error (300 > u8).
name = "lit_slice_overflow"
