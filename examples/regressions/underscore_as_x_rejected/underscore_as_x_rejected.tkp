# Regression (#517, negative — owner ruling): `_ as x` (a discard bound to a name) is a semantic
# contradiction — `_` says "I don't care about this value", `as x` says "capture it as x". It is a
# hard PARSE ERROR, not a pattern to make sound. `match o { _ as x => x }` over any subject,
# including an optional `T?`, must be rejected before type-checking is even reached. No build.
name = "underscore_as_x_rejected"
source = "src"

[artifact]
kind = "binary"
