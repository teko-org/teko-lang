/**
 * f — `_ as x` is a discard-then-capture; the parser rejects it before this function's body is
 * even type-checked.
 *
 * @param o  an optional integer
 * @return   never — the parser rejects this source before the checker is reached
 */
pub fn f(o: i64?) -> i64 {
    match o {
        _ as x => x
    }
}
