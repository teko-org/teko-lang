/**
 * An out-of-range `u8` binding — `256` does not fit u8, so this must fail early (M.1). (A) does not
 * accept it.
 *
 * @return would be the value as i64, but the binding never type-checks
 * @throws the M.1 "literal out of range for the annotated type" error at the binding
 */
pub fn bad() -> i64 {
    let x: u8 = 256
    x to i64
}
