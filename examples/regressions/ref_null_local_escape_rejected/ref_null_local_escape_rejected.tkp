# NEGATIVE regression: null-union C5 (0.3.0.30) — returning a `Ref<T> | null` is REJECTED.
#
# The C5 local-binding relaxation admits a `Ref<T> | null` LOCAL, but a reference (bare or as the
# never-null half of a ref-null union) is still pass-down ONLY: a function may not RETURN one, or the
# borrowed handle would outlive its caller-stack referent (R3). This fixture has no successful build.
name = "ref_null_local_escape_rejected"
source = "src"

[artifact]
kind = "binary"
