/**
 * Attempt to RETURN a `Ref<i32> | null` built from a caller-owned parameter reference — rejected by
 * the C5 escape gate (references are pass-down only, R3).
 *
 * @param p  a caller-owned reference
 * @return   never — this signature is a compile error
 */
fn leak(p: Ref<i32>) -> Ref<i32> | null {
    p
}

/** Force `leak` to be checked. @return unreachable */
pub fn leak_probe() -> i32 {
    mut x: i32 = 1
    0
}
