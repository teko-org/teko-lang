/**
 * Identity over i128 — receives an argument that must already be born at the i128 width.
 *
 * @param v  the value to return unchanged
 * @return   v
 */
pub fn takes128(v: i128) -> i128 {
    v
}

/**
 * A6 guard: an `if`-expression ARGUMENT whose taken arm is an over-i64 literal (2^63) is born at the
 * parameter's i128 width, so it round-trips through `takes128`. Before (A6) the arg was left i64 and
 * only outer-retyped, dropping the high bit.
 *
 * @return 7 when the argument round-trips (born i128), 9 otherwise
 */
pub fn arg_if_roundtrip() -> i64 {
    let r = takes128(if true { 9223372036854775808 } else { 0 })
    if r == 9223372036854775808 { 7 } else { 9 }
}
