# Regression (A6: context-directed literal typing at CALL ARGS): an `if`-expression argument whose
# taken arm is an over-i64 literal (2^63) is born at the parameter's i128 width, not left i64 and
# merely outer-retyped (the same miscompile class as the assign path, closed for args). The value
# round-trips through the identity fn, so `r == 2^63` holds. Both engines exit 7.
name = "lit_arg_if_over_i64"
source = "src"

[artifact]
kind = "binary"
