/**
 * bad_unused — an `adopt` body declaring a local that is never read. The checker must reject
 * this: `check_locals` descends an adopt body (unlike a defer body, which is exempt).
 *
 * @return  never — the checker rejects this function before codegen is reached.
 */
pub fn bad_unused() -> i64 {
    adopt {
        let unused_x = 5
    }
    0
}
