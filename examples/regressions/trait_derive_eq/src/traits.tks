/**
 * (TR3, #177 crumb 1) A struct deriving the structural trait `Eq`. The compiler synthesizes
 * `pub fn eq(self, other: Point) -> bool` field-wise over `x`/`y`/`label` — no method is written
 * by hand. The `str` field's `==` lowers to `tk_str_eq`; equality is symmetric.
 */
pub type Point = struct Eq {
    x: i64
    y: i64
    label: str
}
