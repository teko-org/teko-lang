/**
 * A doc comment directly above `#test fn …` (issue #285) — the standard Javadoc placement,
 * ABOVE the `#test` attribute. Exercises `total` over both the struct's and the class's
 * Javadoc-commented fields.
 */
#test
fn total_sums_point_and_vector() -> void {
    let p = Point { x = 5; y = 6 }
    let v = Vector::make(7, 8)
    teko::assert::is_true(total(p, v) == 26)
}
