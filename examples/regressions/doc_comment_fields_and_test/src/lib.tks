/**
 * A 2D point (a struct), with a Javadoc directly above each field (issue #285).
 *
 * @param x  the x coordinate
 * @param y  the y coordinate
 */
pub type Point = struct {
    /**
     * The x coordinate.
     */
    x: i64
    /**
     * The y coordinate.
     */
    y: i64
}

/**
 * A 2D vector (a class), with a Javadoc directly above each field (issue #285) — the same
 * placement `parse_class_fields` must accept alongside a struct's `parse_fields`.
 */
pub type Vector = class {
    /**
     * The horizontal component.
     */
    pub dx: i64
    /**
     * The vertical component.
     */
    pub dy: i64

    /**
     * Build a Vector from its two components.
     *
     * @param dx  the horizontal component
     * @param dy  the vertical component
     * @return    the constructed Vector
     */
    pub fn make(dx: i64, dy: i64) -> Vector { Vector { dx = dx; dy = dy } }
}

/**
 * Sum the components of a Point and a Vector — exercises reading both the struct's and the
 * class's Javadoc-commented fields at runtime (parsing success alone would not).
 *
 * @param p  the point
 * @param v  the vector
 * @return   `p.x + p.y + v.dx + v.dy`
 */
pub fn total(p: Point, v: Vector) -> i64 {
    p.x + p.y + v.dx + v.dy
}
