let a: i64? = 42
if unwrap_or_zero(a) != 42 { exit(1) }

let b: i64? = null
if unwrap_or_zero(b) != 0 { exit(2) }

let whole = match 7 {
    _ as x => x
}
if whole != 7 { exit(3) }

let sp: P? = P { v = 9 }
if field_or_neg(sp) != 9 { exit(4) }

let sn: P? = null
if field_or_neg(sn) != -1 { exit(5) }

exit(0)
