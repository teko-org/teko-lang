# Regression (#517): the type-free `_ as x` wildcard-binding pattern. Binds the payload of an
# optional after a `null` arm (`x : T`), the whole value of a plain subject, and the whole present
# value of an optional struct. Self-checks with exit codes; VM == native.
name = "wildcard_bind"
source = "src"

