/**
 * bad_break — a bare `break` inside `adopt { }` with no enclosing loop. The checker must reject
 * this: `check_labels` does not treat `adopt` as a loop, so `in_loop` stays false here.
 *
 * @return  never — the checker rejects this function before codegen is reached.
 */
pub fn bad_break() -> i64 {
    adopt {
        break
    }
    0
}
