let v = Vault::open("savings", 100)
if v.read() != 100 { exit(1) }
if v.label != "savings" { exit(2) }

let piece = v.split(40)
if piece.read() != 40 { exit(3) }
if piece.label != "savings" { exit(4) }

let a = Animal::adopt("Generic")
if a.speak() != "..." { exit(5) }

let d = Dog::adopt_dog("Rex")
if d.speak() != "Woof" { exit(6) }
if d.name != "Rex" { exit(7) }
