# Regression: #comptime-fold CF4c + CF4d — `.len` of a const aggregate/string and a struct
# field of a const struct fold to scalar literals at comptime.
#
# `const NUMS: []i64 = [10, 20, 30]` (a module aggregate const, NOT inlined to its literal — it
# stays a `TVar` resolving through the CF4 module-aggregate map) has `NUMS.len` folded to the
# literal `3` (CF4d, `.len` of a const aggregate). `const GREETING: str = "hello"` has
# `GREETING.len` folded to `5` (CF4d, byte length of a const string). `const POINT: Point =
# Point{x = 30, y = 12}` has `POINT.x`/`POINT.y` folded to `30`/`12` (CF4c, struct field of a
# const struct), so `(POINT.x + POINT.y) to i32` collapses to `42`. The runtime field/length
# reads are GONE — every leaf is a compile-time literal.
#
# exit code = (POINT.x + POINT.y) + NUMS.len + GREETING.len = 42 + 3 + 5 = 50.
#
# The fold runs in the frontend shared by both backends, so the C-native build and the own-native
# build (own==C differential) must both exit 50 (EXPECT_EXIT).
#   teko build examples/regressions/cf4_field_len_fold && \
#     ./examples/regressions/cf4_field_len_fold/cf4_field_len_fold   # -> exit 50
name = "cf4_field_len_fold"
source = "src"

[artifact]
kind = "binary"
