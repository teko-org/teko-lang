/**
 * Point — a two-field integer struct, the CF4c const-struct-field fold receiver. A module const
 * of this type is NOT inlined to its struct literal; a use of `POINT.x` resolves the receiver
 * through the CF4 module-aggregate map and folds to the field's const value at comptime.
 *
 * @field x  the first coordinate
 * @field y  the second coordinate
 */
pub type Point = struct { x: i64; y: i64 }

/**
 * POINT — a module-level const `Point`. `POINT.x`/`POINT.y` fold to `30`/`12` (CF4c struct-field
 * fold), so `(POINT.x + POINT.y) to i32` is the compile-time literal `42`.
 */
pub const POINT: Point = Point { x = 30; y = 12 }

/**
 * NUMS — a module-level aggregate `[]i64` const. `NUMS.len` folds to the element count `3` (CF4d
 * `.len` of a const aggregate) — the runtime length read is gone.
 */
pub const NUMS: []i64 = [10, 20, 30]

/**
 * GREETING — a module-level const `str`. `GREETING.len` folds to the byte count `5` (CF4d `.len`
 * of a const string).
 */
pub const GREETING: str = "hello"
