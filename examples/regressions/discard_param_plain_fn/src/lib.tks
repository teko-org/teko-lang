/**
 * bad — a plain function that tries to declare a `_` discard parameter; the checker rejects it
 * because a plain function's author controls the signature and must name the parameter (owner
 * refinement 2026-07-15).
 *
 * @param x  the kept argument
 * @return   never — the checker rejects this signature
 */
pub fn bad(x: i64, _) -> i64 { x }
