/**
 * bad — contains the invalid two-underscore token `__`; the lexer rejects a pure run of two or more
 * underscores as a letterless non-identifier before parsing begins (owner ruling 2026-07-15).
 *
 * @return  never — the lexer rejects this source before parsing
 */
pub fn bad() -> i64 {
    __ = 1
    0
}
