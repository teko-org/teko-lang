# F2 own-backend differential fixture (issue #389 §6.2). A nested range loop with a labeled
# `break OUTER`/`continue OUTER` and a loop-carried `sum` live across both loop headers — the
# loop-liveness extension's target (a value live at a loop header must survive the whole body
# across the back-edge). exit(n)-scoped so VM, C-native, and own-native must agree on exit 0
# (scripts/diff_c_own.sh).
name = "own_loop_nested_range"
source = "src"

