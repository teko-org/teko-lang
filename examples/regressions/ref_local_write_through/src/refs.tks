/**
 * compute — binds a local `ref` alias to a mutable local (`ref r: i64 = ref x`) and writes 42 THROUGH
 * the alias with no `.value` (transparent write-through, R4). Reads the aliased local back.
 *
 * @return the value written through the local reference (42)
 */
pub fn compute() -> i64 {
    mut x: i64 = 40
    ref r: i64 = ref x
    r = 42
    x
}
