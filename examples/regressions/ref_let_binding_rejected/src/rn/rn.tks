/**
 * probe — a `let ref` binding: rejected by the tripartite law (there is no immutable reference).
 * The `ref` modifier is itself the binder; `let ref`/`mut ref`/`const ref` do not exist.
 *
 * @return never — the binding is a compile error (EXPECT_COMPILE_FAIL)
 */
pub fn probe() -> i64 {
    mut x: i64 = 1
    let ref r: i64 = ref x
    r
}
