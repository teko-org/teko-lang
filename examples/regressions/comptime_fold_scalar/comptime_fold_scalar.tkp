# Regression: #comptime-fold CF2 — the module-const op-tree fold.
#
# Three module consts carry ARITHMETIC/BITWISE op-tree initializers (not bare literals):
#   MASK  = 255 & 63   -> 63   (a bitwise-and fold)
#   SHIFT = 1 << 4     -> 16   (a shift fold, width-masked like the runtime)
#   NEG   = -(37)      -> -37  (a signed-negation fold)
# `inline_consts` substitutes each const's op-tree at the `exit(MASK + SHIFT + NEG)` use site, then
# the composed CF2 fold (`fold_program`) collapses the whole provably-const integer op-tree to the
# literal 42 — the VM loads an immediate instead of re-executing the `& << - +` op-tree, and the AOT
# path emits the same literal. Behavior is preserved: both engines exit 42.
#   63 + 16 + (-37) = 42
#
# Both engines must agree: `teko run` exit == compiled-binary exit == 42.
#   teko run   examples/regressions/comptime_fold_scalar   # VM   -> exit 42
#   teko build examples/regressions/comptime_fold_scalar && \
#     ./examples/regressions/comptime_fold_scalar/comptime_fold_scalar   # native -> exit 42
name = "comptime_fold_scalar"
source = "src"

[artifact]
kind = "binary"
