/**
 * MASK — a module const whose initializer is a bitwise-and op-tree the CF2 fold collapses to the
 * literal 63 (`255 & 63`), so both engines load an immediate at the use site instead of executing
 * the `&` (#comptime-fold).
 */
const MASK: i64 = (255 to i64) & (63 to i64)

/**
 * SHIFT — a module const whose initializer is a shift op-tree the CF2 fold collapses to the literal
 * 16 (`1 << 4`), matching the runtime's width-masked shift (#comptime-fold).
 */
const SHIFT: i64 = (1 to i64) << 4

/**
 * NEG — a module const whose initializer is a negation op-tree the CF2 fold collapses to the literal
 * -37, exercising the signed reconstruction path (#comptime-fold).
 */
const NEG: i64 = -(37 to i64)
