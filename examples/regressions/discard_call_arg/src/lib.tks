/**
 * bad — passes the write-only discard `_` as a call argument (`teko::str::concat("a", _)`); the
 * parser rejects the `_` R-value (a discard carries no value) at parse time (owner ruling
 * 2026-07-15).
 *
 * @return  never — the parser rejects this source at parse time
 */
pub fn bad() -> str {
    teko::str::concat("a", _)
}
