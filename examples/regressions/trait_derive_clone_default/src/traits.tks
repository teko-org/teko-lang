/**
 * (TR3, #177 crumb 4) A struct deriving `Clone`, `Default`, and `Eq` together. The compiler
 * synthesizes `clone` (field-wise deep copy), `default` (static, field-wise zero/empty), and `eq`
 * (so the assertions can compare structurally). `flag` (bool), `count` (i64), `ratio` (f64), and
 * `name` (str) exercise every scalar default.
 */
pub type Config = struct Clone & Default & Eq {
    flag: bool
    count: i64
    ratio: f64
    name: str
}
