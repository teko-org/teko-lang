let a = Config { flag = true; count = 42; ratio = 2.5; name = "prod" }
let cloned = a.clone()

if !a.eq(cloned) { exit(1) }
if cloned.flag != true { exit(2) }
if cloned.count != 42 { exit(3) }
if cloned.ratio != 2.5 { exit(4) }
if cloned.name != "prod" { exit(5) }

let z = Config::default()
if z.flag != false { exit(6) }
if z.count != 0 { exit(7) }
if z.ratio != 0.0 { exit(8) }
if z.name != "" { exit(9) }

if !z.eq(Config::default()) { exit(10) }

exit(0)
