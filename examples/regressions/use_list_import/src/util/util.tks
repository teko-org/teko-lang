/**
 * Adds two integers. One of the two names a grouped `use` in `main.tks` lists (S1, #335).
 *
 * @param a the first addend
 * @param b the second addend
 * @return  their sum
 */
pub fn add(a: i64, b: i64) -> i64 {
    a + b
}

/**
 * Multiplies two integers. The other name a grouped `use` in `main.tks` lists (S1, #335).
 *
 * @param a the first factor
 * @param b the second factor
 * @return  their product
 */
pub fn mul(a: i64, b: i64) -> i64 {
    a * b
}
