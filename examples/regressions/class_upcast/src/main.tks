// (#98) virtual main — drives the Sub->Base upcast checks (types + helpers live in
// checks.tks / animal.tks / subclasses.tks). Distinct exit codes per failure surface;
// 0 = all pass. The differential harness asserts VM == native.

let r1 = check_binding()
if r1 != 0 { exit(r1) }

let r2 = check_param()
if r2 != 0 { exit(r2) }

let r3 = check_return()
if r3 != 0 { exit(r3) }

exit(0)
