// two subclasses of Animal, each overriding the virtual `speak`.

type Dog = class Animal {
    pub fn make(n: str) -> Dog {
        Dog { name = n }
    }

    pub override fn speak(self) -> str {
        "Woof"
    }
}

type Cat = class Animal {
    pub fn make(n: str) -> Cat {
        Cat { name = n }
    }

    pub override fn speak(self) -> str {
        "Meow"
    }
}
