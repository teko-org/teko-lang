// (#98) class Sub->Base upcast — a POLYMORPHIC base `Animal` (`virtual`) plus two subclasses,
// each overriding the virtual `speak`. A base-typed slot lowers to the fat pointer
// `tk_base_Animal` ({ data, vtable }); the (subclass, base) static vtable makes a call through
// the base-typed value dispatch to the subclass override. Types + helpers here; main.tks drives.

type Animal = virtual class {
    pub name: str

    pub fn make(n: str) -> Animal {
        Animal { name = n }
    }

    pub virtual fn speak(self) -> str {
        "..."
    }
}
