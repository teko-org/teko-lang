// A plain top-level helper in a NON-main file (namespace = the project root
// "exit_success_path") — proves the success path did real work before exit(5) runs.
fn sum_to(n: i64) -> i64 {
    mut total: i64 = 0
    mut i: i64 = 1
    loop {
        if i > n { break }
        total = total + i
        i = i + 1
    }
    total
}
