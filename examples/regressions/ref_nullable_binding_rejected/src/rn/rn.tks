/**
 * probe — a `ref` binding cannot hold `null`: a reference always exists once declared (never-null,
 * R3). The `| null` belongs on the referenced VALUE, never on the reference.
 *
 * @return never — the null binding is a compile error (EXPECT_COMPILE_FAIL)
 */
pub fn probe() -> i64 {
    ref r: i64 = null
    r
}
