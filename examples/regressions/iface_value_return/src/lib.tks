/**
 * Named — a one-method contract returned as an interface VALUE. A function may return the contract
 * type and hand back any conforming class; the caller dispatches without knowing the concrete type.
 */
type Named = interface {
    /**
     * tag — the implementer's identifying number.
     *
     * @return  the tag value
     */
    fn tag(self) -> i64
}

/**
 * Alpha — a class conforming to `Named`, tagged 10.
 */
type Alpha = class & Named {
    /**
     * make — construct an `Alpha`.
     *
     * @return  the constructed value
     */
    pub fn make() -> Alpha { Alpha { } }

    /**
     * tag — the `Named` contract for `Alpha`.
     *
     * @return  10
     */
    pub fn tag(self) -> i64 { 10 }
}

/**
 * Beta — a class conforming to `Named`, tagged 20.
 */
type Beta = class & Named {
    /**
     * make — construct a `Beta`.
     *
     * @return  the constructed value
     */
    pub fn make() -> Beta { Beta { } }

    /**
     * tag — the `Named` contract for `Beta`.
     *
     * @return  20
     */
    pub fn tag(self) -> i64 { 20 }
}

/**
 * pick — return one of two conforming classes as the interface type, chosen by `b`.
 *
 * @param b  when true, return an `Alpha`; otherwise a `Beta`
 * @return   the chosen implementer up-cast to the interface value
 */
pub fn pick(b: bool) -> Named {
    if b { return Alpha::make() }
    Beta::make()
}

/**
 * scenario — return both conforming classes through the interface type and dispatch each.
 *
 * @return  0 when both dispatched tags match, else a distinct failure code
 */
pub fn scenario() -> i64 {
    if pick(true).tag() != 10 { return 1 }
    if pick(false).tag() != 20 { return 2 }
    0
}
