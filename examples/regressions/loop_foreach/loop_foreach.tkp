# Regression (#517): the closure-iterator for-each `loop mut x in <it>` where `<it> : () -> T?`.
# Proves iteration by value over a range iterator (sum 0..3 = 3), `continue` re-pulls (advances),
# and the `mut x` binding is a local COPY with no write-back (rebinding x does not disturb the
# iterator). Self-checks with exit codes; VM == native.
name = "loop_foreach"
