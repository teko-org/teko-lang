mut rc = RangeCursor { next = 0; hi = 3 }
let it = range(rc)
mut s = 0
loop mut x in it {
    s = s + x
}
if s != 3 { exit(1) }

mut rc2 = RangeCursor { next = 0; hi = 5 }
let it2 = range(rc2)
mut s2 = 0
loop mut x in it2 {
    if x == 2 { continue }
    s2 = s2 + x
}
if s2 != 8 { exit(2) }

mut rc3 = RangeCursor { next = 0; hi = 3 }
let it3 = range(rc3)
mut count = 0
loop mut x in it3 {
    x = 99
    count = count + 1
}
if count != 3 { exit(3) }

exit(0)
