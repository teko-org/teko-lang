# NEGATIVE regression: null-union C4 (0.3.0.30) — `#inline` is a binding/field attribute, not a
# declaration attribute. `#inline` before a `fn` (or `type`) is a PRECISE placement error, never a
# silent accept: the decl-attribute parser names the two legal positions (a local binding or a struct
# field). This fixture pins that mis-placement rejection.
name = "inline_attr_misplaced"
source = "src"

[artifact]
kind = "binary"
