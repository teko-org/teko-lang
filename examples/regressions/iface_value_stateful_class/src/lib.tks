/**
 * Counter — a stateful contract. Dispatched through as an interface VALUE, the concrete class
 * carries the mutable state across calls (the class arena-mutation rule).
 */
type Counter = interface {
    /**
     * bump — advance the counter one step.
     */
    fn bump(self)

    /**
     * get — the current count.
     *
     * @return  the running count
     */
    fn get(self) -> i64
}

/**
 * Cnt — a class conforming to `Counter`, whose `bump` mutates its own field.
 */
type Cnt = class & Counter {
    /** The running count. */
    pub n: i64

    /**
     * make — a fresh counter positioned at zero.
     *
     * @return  the constructed counter
     */
    pub fn make() -> Cnt { Cnt { n = 0 } }

    /**
     * bump — the `Counter` contract: increment the stored count.
     */
    pub fn bump(self) { self.n = self.n + 1 }

    /**
     * get — the `Counter` contract: read the stored count.
     *
     * @return  the running count
     */
    pub fn get(self) -> i64 { self.n }
}

/**
 * drive — advance a dynamic `Counter` VALUE three times, then read it. State persists across the
 * dispatched calls because the interface value wraps a live class object.
 *
 * @param c  the counter, taken as a dynamic interface value
 * @return   the count after three increments
 */
pub fn drive(c: Counter) -> i64 {
    c.bump()
    c.bump()
    c.bump()
    c.get()
}

/**
 * scenario — build a fresh counter and drive it three times through the interface value.
 *
 * @return  the count after three increments (3)
 */
pub fn scenario() -> i64 { drive(Cnt::make()) }
