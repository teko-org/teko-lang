use unsafe_type_modifier::rawbuf
use unsafe_type_modifier::ops

let buf = rawbuf::make_rawbuf(7)
if ops::rawbuf_len(buf) != 7 { exit(1) }

let h = rawbuf::Handle::make(9)
if h.addr != 9 { exit(2) }

if ops::sentinel() != 42 { exit(3) }

let p = ops::Plain { tag = 5 }
if ops::plain_tag(p) != 5 { exit(4) }

exit(42)
