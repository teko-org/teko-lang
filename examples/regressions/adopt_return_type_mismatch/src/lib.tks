/**
 * bad_return ‚Äî an `adopt` body returning the WRONG type (`str` from an `i64` fn). The checker
 * must reject this: `check_returns` descends into an adopt body exactly like a loop body.
 *
 * @return  never ‚Äî the checker rejects this function before codegen is reached.
 */
pub fn bad_return() -> i64 {
    adopt {
        return "hello"
    }
    0
}
