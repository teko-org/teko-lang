# Regression (#337, negative): `return "hello"` inside `adopt { }` in an `i64`-returning function
# must be REJECTED by check_returns — the checker's per-block return-type walk must descend an
# adopt body exactly as it descends a loop body (adopt allows return, unlike defer).
name = "adopt_return_type_mismatch"
source = "src"

[artifact]
kind = "binary"
