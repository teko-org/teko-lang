/**
 * Reader — a PRIVATE codec struct that COLLIDES by last segment with the `stream::Reader` interface
 * (the #109 same-last-segment cross-namespace hazard). Its `combine` METHOD takes another codec
 * `Reader` by the BARE name — so BOTH modules carry a bare-`Reader` method param that must bind in
 * its OWN owner-module namespace. Whichever module the resolver discovers second is the one a
 * namespace-blind emitter mis-binds, so this pair fails to compile under the bug regardless of the
 * platform's directory-discovery order; the fix binds each in its own module and both compile.
 */
type Reader = struct {
    /** the codec's read cursor. */
    pos: i64

    /**
     * cursor_at — build a codec `Reader` positioned at `p`.
     *
     * @param p  the initial cursor position
     * @return   a codec reader at position `p`
     */
    pub fn cursor_at(p: i64) -> Reader { Reader { pos = p } }

    /**
     * combine — sum this codec reader's cursor with another codec reader's, taken by the BARE
     * struct name `Reader`. A namespace-blind emitter would mis-bind `other` to the `stream::Reader`
     * interface (a fat pointer) and fail to read its `.pos` field.
     *
     * @param other  a second codec reader, taken by the bare struct name
     * @return       the sum of the two cursors
     */
    pub fn combine(self, other: Reader) -> i64 { self.pos + other.pos }
}

/**
 * spread — drive `Reader::combine` over two codec readers so both the struct decl and its bare-param
 * method stay live in the program.
 *
 * @param a  the first cursor position
 * @param b  the second cursor position
 * @return   the combined cursor sum
 */
pub fn spread(a: i64, b: i64) -> i64 { Reader::cursor_at(a).combine(Reader::cursor_at(b)) }
