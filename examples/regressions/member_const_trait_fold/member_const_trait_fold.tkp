# Regression: #594 crumb 7 — a trait's static member const FOLDS into each deriver.
#
# `trait Sized` declares `pub const WIDTH = 8`. A struct that derives `Sized` folds the trait's
# member const in like a field, so `Widget::WIDTH` resolves to 8 on the deriver (the trait itself is
# non-instantiable and never appears in a value position). The program exits 42 (assertion passes):
#   Widget::WIDTH == 8
#
# Both engines must agree: `teko run` exit == compiled-binary exit == 42.
#   teko run   examples/regressions/member_const_trait_fold   # VM     -> exit 42
#   teko build examples/regressions/member_const_trait_fold && \
#     ./examples/regressions/member_const_trait_fold/member_const_trait_fold   # native -> exit 42
name = "member_const_trait_fold"
source = "src"

[artifact]
kind = "binary"
