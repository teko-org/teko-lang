/**
 * Sized — a trait providing a static member const `WIDTH`. A trait is a non-instantiable bundle; its
 * member const folds into each deriver like a field, resolved by `Deriver::WIDTH` (#594 crumb 7).
 */
type Sized = trait {
    /** WIDTH — the trait's static member const, folded into every deriver. */
    pub const WIDTH: i64 = 8
}

/**
 * Widget — a struct deriving `Sized`, so it gains the folded member const `WIDTH` (`Widget::WIDTH`).
 *
 * @field id  the widget's identifier
 */
type Widget = struct Sized {
    /** the widget's identifier */
    id: i64
}
