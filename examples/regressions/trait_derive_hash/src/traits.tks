/**
 * (TR3, #177 crumb 2) A struct deriving the structural trait `Hash`. The compiler synthesizes
 * `pub fn hash(self) -> u64` — an FNV-1a fold of `id` (u64 value cast) and `name` (str, via
 * `teko::runtime::str_hash`). No method is written by hand.
 */
pub type Item = struct Hash {
    id: i64
    name: str
}
