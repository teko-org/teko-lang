let a = Item { id = 7; name = "alpha" }
let b = Item { id = 7; name = "alpha" }
let c = Item { id = 8; name = "alpha" }
let d = Item { id = 7; name = "omega" }

if a.hash() != b.hash() { exit(1) }
if a.hash() == c.hash() { exit(2) }
if a.hash() == d.hash() { exit(3) }
if a.hash() != a.hash() { exit(4) }

exit(0)
