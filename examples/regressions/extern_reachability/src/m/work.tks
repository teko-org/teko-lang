/** c_abs ‚Äî bound to libc's `abs`; main.tks calls it, so `libc` must stay on the cc link line. */
pub extern fn c_abs(x: i32) -> i32 = "abs" from "libc"

/**
 * phantom_fn ‚Äî bound to a nonexistent `phantomlib`; NEVER called anywhere in this program, so
 * C7.20 must drop `phantomlib` from the link line (it would fail the build if kept).
 */
pub extern fn phantom_fn() -> i32 = "phantom_symbol_181" from "phantomlib"
