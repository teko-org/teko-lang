mut s = 0
loop mut i in 0..3 {
    s = s + i
}
if s != 3 { exit(1) }

mut s2 = 0
loop mut i in 0..=3 {
    s2 = s2 + i
}
if s2 != 6 { exit(2) }

mut s3 = 0
loop mut i in 0..5 {
    if i == 2 { continue }
    s3 = s3 + i
}
if s3 != 8 { exit(3) }

mut n = 3
mut cnt = 0
loop mut i in 0..n {
    n = 100
    cnt = cnt + 1
}
if cnt != 3 { exit(4) }

exit(0)
