# Regression: #comptime-fold CF5 — the Layer-2 interpolation + format fold, format-oracle differential.
#
# For every (value, spec) pair the fold folds, this program compares TWO renders of the SAME value:
#   - `$"{v:spec}"`        — a const-known hole, folded at COMPTIME to a rodata TStrLit (no runtime
#                            tk_str_concat / tk_fmt_* — the CF5 mandate, e.g. `$"{a:X}"` -> "FF").
#   - `$"{keep(v):spec}"`  — the SAME value behind an opaque identity call, which the fold cannot see,
#                            so it stays the RUNTIME tk_fmt_* format.
# The comptime fold is honest (M.1/M.3) iff the two are byte-identical; a single mismatch exits 1.
# The families exercised here are the culture-invariant integer/byte forms that propagate as LOCALS:
# `x`/`X` hex, `b` binary, `d` zero-padded decimal, `n` thousands, and the natural (no-spec)
# int/uint/byte render. The bool and str/char natural forms fold too, but only from a module const
# (locals of those types do not const-propagate), so they are pinned in the `comptime_fold_test.tkt`
# unit differential instead. Floats and dynamic specs are NEVER folded (they stay runtime).
#
# Both engines must agree: `teko run` exit == compiled-binary exit == 0.
#   teko run   examples/regressions/comptime_fold_format_oracle   # VM     -> exit 0
#   teko build examples/regressions/comptime_fold_format_oracle && \
#     ./examples/regressions/comptime_fold_format_oracle/comptime_fold_format_oracle   # native -> exit 0
name = "comptime_fold_format_oracle"
source = "src"

[artifact]
kind = "binary"
