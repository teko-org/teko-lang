/**
 * keep — the identity function: returns its argument unchanged. A CALL to `keep` is not a const
 * literal, so a hole `$"{keep(v):spec}"` is left a RUNTIME `tk_fmt_*` format — the differential twin of
 * the const-folded `$"{v:spec}"`. Generic so one opaque barrier serves every value type in the matrix.
 *
 * @param x  the value to pass through untouched
 * @return   `x` unchanged
 */
pub fn keep<T>(x: T) -> T { x }

/**
 * ck — the oracle assertion: the comptime-folded render `folded` MUST equal the runtime render
 * `runtime` byte-for-byte; a mismatch exits 1 (the fixture expects exit 0).
 *
 * @param folded   the const-folded interpolation result
 * @param runtime  the same value rendered through the opaque `keep` barrier (runtime format)
 * @return         void; exits the process on a mismatch
 */
pub fn ck(folded: str, runtime: str) -> void {
    if folded != runtime { exit(1) }
}
