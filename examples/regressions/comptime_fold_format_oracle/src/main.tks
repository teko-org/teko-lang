let u64_zero: u64 = 0
let u64_255: u64 = 255
let u64_dead: u64 = 3735928559
let u64_max: u64 = 18446744073709551615
let u32_max: u32 = 4294967295
let u16_max: u16 = 65535
let u8_max: u8 = 255
let by_200: byte = 200 to byte
let by_0: byte = 0 to byte
let i64_42: i64 = 42
let i64_n1: i64 = -1
let i64_min: i64 = -9223372036854775808
let i64_ncomma: i64 = -1234567
let i32_n5: i32 = -5
let i32_max: i32 = 2147483647
let i16_n1: i16 = -1
let i8_n100: i8 = -100
let i8_n1: i8 = -1

ck($"{u64_zero}", $"{keep(u64_zero)}")
ck($"{u64_zero:X}", $"{keep(u64_zero):X}")
ck($"{u64_zero:b}", $"{keep(u64_zero):b}")

ck($"{u64_255:X}", $"{keep(u64_255):X}")
ck($"{u64_255:x}", $"{keep(u64_255):x}")
ck($"{u64_255:b}", $"{keep(u64_255):b}")
ck($"{u64_255}", $"{keep(u64_255)}")
ck($"{u64_255:d}", $"{keep(u64_255):d}")
ck($"{u64_255:d6}", $"{keep(u64_255):d6}")
ck($"{u64_255:n}", $"{keep(u64_255):n}")
ck($"v={u64_255:X}!", $"v={keep(u64_255):X}!")

ck($"{u64_dead:X}", $"{keep(u64_dead):X}")
ck($"{u64_dead:x}", $"{keep(u64_dead):x}")
ck($"{u64_dead}", $"{keep(u64_dead)}")

ck($"{u64_max:X}", $"{keep(u64_max):X}")
ck($"{u64_max:b}", $"{keep(u64_max):b}")
ck($"{u64_max}", $"{keep(u64_max)}")

ck($"{u32_max:X}", $"{keep(u32_max):X}")
ck($"{u32_max}", $"{keep(u32_max)}")
ck($"{u16_max:X}", $"{keep(u16_max):X}")
ck($"{u16_max}", $"{keep(u16_max)}")
ck($"{u8_max:X}", $"{keep(u8_max):X}")
ck($"{u8_max:b}", $"{keep(u8_max):b}")
ck($"{u8_max}", $"{keep(u8_max)}")

ck($"{by_200}", $"{keep(by_200)}")
ck($"{by_0}", $"{keep(by_0)}")

ck($"{i64_42}", $"{keep(i64_42)}")
ck($"{i64_42:d}", $"{keep(i64_42):d}")
ck($"{i64_42:d4}", $"{keep(i64_42):d4}")
ck($"{i64_42:n}", $"{keep(i64_42):n}")
ck($"{i64_42:X}", $"{keep(i64_42):X}")

ck($"{i64_n1}", $"{keep(i64_n1)}")
ck($"{i64_n1:X}", $"{keep(i64_n1):X}")
ck($"{i64_n1:d5}", $"{keep(i64_n1):d5}")

ck($"{i64_min}", $"{keep(i64_min)}")
ck($"{i64_min:n}", $"{keep(i64_min):n}")

ck($"{i64_ncomma}", $"{keep(i64_ncomma)}")
ck($"{i64_ncomma:n}", $"{keep(i64_ncomma):n}")
ck($"{i64_ncomma:d10}", $"{keep(i64_ncomma):d10}")

ck($"{i32_n5:X}", $"{keep(i32_n5):X}")
ck($"{i32_n5}", $"{keep(i32_n5)}")
ck($"{i32_max}", $"{keep(i32_max)}")
ck($"{i16_n1:X}", $"{keep(i16_n1):X}")
ck($"{i16_n1}", $"{keep(i16_n1)}")
ck($"{i8_n100}", $"{keep(i8_n100)}")
ck($"{i8_n100:X}", $"{keep(i8_n100):X}")
ck($"{i8_n1}", $"{keep(i8_n1)}")
ck($"{i8_n1:X}", $"{keep(i8_n1):X}")

exit(0)
