# C1-8b own-wasm FIX-2 engine fixture (issue #389, backend-wasm.md §14.1). A counting `loop`
# entered UNCONDITIONALLY: the loop's `end` must close after the NATURAL-LOOP BODY, not the
# (larger) dominance subtree; otherwise the exit block is swallowed inside the `loop` and the
# module is mis-scoped. sum(0..4) = 6. own-wasm (wasmtime) and C-native must agree on exit 6
# (scripts/validate_wasm_own.sh).
name = "wasm_loop_count"
source = "src"

[artifact]
kind = "binary"
