# Regression: #comptime-fold CF3 — Layer 1b local-binding const-propagation.
#
# Three LOCAL `let` bindings (no module const in sight) carry provably-const integer
# initializers, threaded through the loose top-level statement stream (the implicit main):
#   let a: u64 = 0xFF        -> recorded const 0xFF
#   let hi     = a >> 4      -> a propagated; folds to 15
#   let masked = a & 0x0F    -> a propagated; folds to 15
# The `exit(hi + masked + 12)` use site propagates `hi`/`masked` and the composed fold
# collapses the whole provably-const op-tree to the literal 42 — the VM loads an immediate
# instead of executing the `>> & +` op-tree, and the AOT path emits the same literal. The
# fold is behavior-preserving: the folded program and its unfolded twin both exit 42.
#   15 + 15 + 12 = 42
#
# Both engines must agree: `teko run` exit == compiled-binary exit == 42.
#   teko run   examples/regressions/comptime_fold_local   # VM   -> exit 42
#   teko build examples/regressions/comptime_fold_local && \
#     ./examples/regressions/comptime_fold_local/comptime_fold_local   # native -> exit 42
name = "comptime_fold_local"
source = "src"

[artifact]
kind = "binary"
