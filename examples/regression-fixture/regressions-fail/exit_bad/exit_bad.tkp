# A deliberately-FAILING regressive: the program exits 3 but the `.tkr` claims exit 99, so
# the runner MUST report a failure. This dir is OUTSIDE the harness's `regressions/` source
# so it never fails `teko test examples/regression-fixture`; it is driven only by the
# runner's unit tests.
name = "exit_bad"
source = "src"

[artifact]
kind = "binary"
