// Phase 15 (15.B) native runner — ABSTRACT/TRAIT dynamic dispatch via a COMPILE-TIME STATIC VTABLE,
// zero runtime reflection. `Shape` is a trait (two bodyless contract methods). `Circle`/`Square`
// implement it. A `Shape`-typed reference `g` is a FAT local (instance handle + the concrete
// type_id, a compile-time constant). The SAME call site `g.area()` / `g.to_string()` dispatches to
// the concrete impl selected by `g`'s runtime type_id: vtable_get(type_id, method_id) -> routine
// slot -> OP_CALL_FUNC. Reassigning `g` to another concrete type re-points the dispatch. `to_string`
// is dispatched through the SAME vtable as any method (the Phase-16 casting/auto-string hook).
// Inside a method, `self.area()` is concrete (static) dispatch.
extern fn emit_int(n: i32) from "teko_rt" as "teko_rt_emit_int";

trait Shape {
  fn area(self): i32;
  fn to_string(self): i32;
}

class Circle : Shape {
  let r;
  fn area(self): i32 { return self.r * self.r * 3; }
  fn to_string(self): i32 { let a = self.area(); return 100 + a; }
}

class Square : Shape {
  let s;
  fn area(self): i32 { return self.s * self.s; }
  fn to_string(self): i32 { let a = self.area(); return 200 + a; }
}

let c = Circle();
c.r = 2;
let sq = Square();
sq.s = 3;

let g: Shape = c;          // fat trait reference -> Circle
let a1 = g.area();         // dynamic -> Circle.area = 2*2*3 = 12
emit_int(a1);
let t1 = g.to_string();    // dynamic -> Circle.to_string = 100 + 12 = 112
emit_int(t1);

g = sq;                    // reassign -> Square (tid updated)
let a2 = g.area();         // dynamic -> Square.area = 3*3 = 9
emit_int(a2);
let t2 = g.to_string();    // dynamic -> Square.to_string = 200 + 9 = 209
emit_int(t2);
