// Phase 13 native runner — uuid.v4 (random) / uuid.v7 (time-ordered) proof.
// uuid.v4()/uuid.v7() lower to OP_CALL_RUNTIME id 42/43 -> teko_rt_uuid_v4/v7, which use the
// C CSPRNG (and, for v7, the host clock) and format a canonical UUID. Non-deterministic, so
// run-native.sh asserts the canonical layout + version/variant nibbles, not an exact value.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

emit(uuid.v4());
emit(uuid.v7());
