// Phase 16 (16.C) native runner — string INTERPOLATION with auto-`to_string`. A `"…{expr}…"`
// literal interpolates: each `{hole}` is evaluated and auto-converted to its culture-invariant
// string form (id 49), then joined with the literal chunks via str_concat (id 52) — the SAME
// machinery as `+` (16.B). `{{` / `}}` are literal braces. Zero runtime reflection.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

let n = 42;
emit("x = {n}");                // x = 42                (single hole)
emit("{n} items, {n} total");   // 42 items, 42 total    (multiple holes)
emit("sum = {n + 8}");          // sum = 50              (an expression inside the hole)

let label = "count";
emit("{label}: {n}");           // count: 42             (a string local + an int, both holes)

emit("braces {{ }} kept");      // braces { } kept       ({{ and }} are literal braces)

let msg = "[{n}]";              // an interpolated let-initializer -> a string-typed local…
emit(msg);                      // [42]                  (…used as a plain argument)
