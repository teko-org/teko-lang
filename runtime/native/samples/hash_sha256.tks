// Phase 13 native runner — hash.sha256 executable proof.
// hash.sha256("abc") lowers to OP_CALL_RUNTIME id 4 -> teko_rt_sha256_hex in libteko_rt.a,
// which calls the portable C SHA-256 runtime (the single source of truth). The FIPS 180-4
// "abc" vector is asserted by run-native.sh.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

emit(hash.sha256("abc"));
