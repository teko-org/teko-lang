// Phase 13 native runner — Ed25519 sign/verify executable proof (RFC 8032 Test 3).
// sign(seedHex, msgHex) -> sigHex (derives the public key internally);
// verify(pubHex, msgHex, sigHex) -> "1" valid / "0" invalid. seed/msg/sig are hex.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

// Deterministic signature must reproduce the RFC 8032 vector exactly.
emit(crypto.ed25519_sign("c5aa8df43f9f837bedb7442f31dcb7b166d38535076f094b85ce3a2e0b4458f7", "af82"));
// Valid signature verifies (-> "1").
emit(crypto.ed25519_verify("fc51cd8e6218a1a38da47ed00230f0580816ed13ba3303ac5deb911548908025", "af82", "6291d657deec24024827e69c3abe01a30ce548a284743a445e3680d7db5ac3ac18ff9b538d16f290ae67f760984dc6594a7c15e9716ed28dc027beceea1ec40a"));
// Tampered signature (last nibble flipped) is rejected (-> "0").
emit(crypto.ed25519_verify("fc51cd8e6218a1a38da47ed00230f0580816ed13ba3303ac5deb911548908025", "af82", "6291d657deec24024827e69c3abe01a30ce548a284743a445e3680d7db5ac3ac18ff9b538d16f290ae67f760984dc6594a7c15e9716ed28dc027beceea1ec40b"));
