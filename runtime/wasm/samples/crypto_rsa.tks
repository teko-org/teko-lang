// Phase 13 Sub-phase C ("big step") — RSA PSS + OAEP on the WASM surface (RFC 8017,
// SHA-256/MGF1). Secure-by-default: PSS uses a random salt and OAEP a random seed (drawn
// from the reactor's env.teko_random host import), so signature/ciphertext are
// non-deterministic — the proof asserts the DETERMINISTIC outcomes: sign->verify (1),
// wrong-message verify (0), encrypt->decrypt recovering the exact plaintext. The crypto
// math is KAT-pinned in the Unity suite; this proves the WASM language-surface wiring
// (ids 37-40) AND exercises the reactor's entropy import end to end. Same 2048-bit key
// as the native rsa.tks proof.
extern fn emit(s) from "env" as "emit";

let n = "";
let e = "010001";
let d = "";

// PSS: sign a digest, verify it (1), then verify the wrong digest against that sig (0).
let m = "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad";
let sig = crypto.rsa_pss_sign(n, d, m);
emit(crypto.rsa_pss_verify(n, e, m, sig));
let wrong = "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ae";
emit(crypto.rsa_pss_verify(n, e, wrong, sig));

// OAEP: encrypt a message and decrypt it back (must recover the exact plaintext hex).
let pt = "48656c6c6f2c2052534121";
let ct = crypto.rsa_oaep_encrypt(n, e, pt);
emit(crypto.rsa_oaep_decrypt(n, d, ct));
