// Phase 16 (16.F) native runner — the FAIL-LOUD path. `convert.parse_int` on a malformed integer
// does NOT silently return 0: the checked runtime aborts the program (native: a stderr diagnostic
// + non-zero exit; wasm: a trap). run-native.sh asserts a non-zero exit and the diagnostic.
extern fn emit(s) from "env" as "emit";

emit("before");                       // printed, then…
emit("x = " + convert.parse_int("not-a-number"));  // …aborts here (never prints "after")
emit("after");
