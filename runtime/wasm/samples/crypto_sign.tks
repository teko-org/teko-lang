// X25519 ECDH (RFC 7748 §5 vectors 1 & 2).
emit(crypto.x25519("a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4", "e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c"));
emit(crypto.x25519("4b66e9d4d1b4673c5ad22691957d6af5c11b6421e0ea01d42ca4169e7918ba0d", "e5210f12786811d3f4b7959d0538ae2c31dbe7106fc03c3efc4cd549c715a493"));

// ECDSA P-256 (RFC 6979 A.2.5, "sample"): deterministic sig, valid (1), tampered (0).
emit(crypto.ecdsa_p256_sign("c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721", "af2bdbe1aa9b6ec1e2ade1d694f41fc71a831d0268e9891562113d8a62add1bf"));
