// Phase 13 Sub-phase C ("big step") — signatures + ECDH on the WASM surface.
// Ed25519 (RFC 8032 Test 3), X25519 (RFC 7748 §5 vectors 1 & 2), ECDSA P-256 (RFC 6979
// A.2.5) and P-384 (A.2.6) — ids 24/25/26/29/30/31/32, all reactor-backed. sign ->
// signature hex; verify -> "1"/"0"; x25519 -> shared-secret hex.
extern fn emit(s) from "env" as "emit";

// Ed25519: deterministic signature, valid verify (1), tampered verify (0).
emit(crypto.ed25519_sign("c5aa8df43f9f837bedb7442f31dcb7b166d38535076f094b85ce3a2e0b4458f7", "af82"));
emit(crypto.ed25519_verify("fc51cd8e6218a1a38da47ed00230f0580816ed13ba3303ac5deb911548908025", "af82", "6291d657deec24024827e69c3abe01a30ce548a284743a445e3680d7db5ac3ac18ff9b538d16f290ae67f760984dc6594a7c15e9716ed28dc027beceea1ec40a"));
