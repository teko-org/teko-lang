// Phase 14 (14.A) — `routines { … }` fires background tasks on the cooperative scheduler.
// Each enclosed call spawns the named `fn` as a green thread (OP_SPAWN_ASYNC enqueues its
// table slot). The runtime drains the run queue before the program exits, so the workers
// run AFTER `$main`'s body completes — proving deferred background execution, not an inline
// call. The host (run-routines.mjs) provides env.log and records the call order.
extern fn log(msg: str) from "env" as "log";

fn worker() { log("worker ran"); }

log("main start");
routines { worker(); worker(); worker(); }
log("main end");
