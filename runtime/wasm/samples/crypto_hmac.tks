// Phase 13 Sub-phase C ("big step") — HMAC on the WASM surface (multi-arg runtime call).
// hmac.sha256/384/512(hexKey, msg) lower to ids 17/18/19; arg0 (hex key) is staged via
// OP_SETARG into $a0, arg1 (message) stays in $w0, and the WASM OP_CALL_RUNTIME marshals
// both into the imported reactor call. RFC 4231 Test Case 2: key "Jefe" = 4a656665.
extern fn emit(s) from "env" as "emit";

emit(hmac.sha256("4a656665", "what do ya want for nothing?"));
emit(hmac.sha384("4a656665", "what do ya want for nothing?"));
emit(hmac.sha512("4a656665", "what do ya want for nothing?"));
