// Phase 13.1 — native SHA-256 from real Teko source. Each call lowers to the in-module
// SHA-256 runtime (no external deps, no host crypto); the result is a NUL-terminated
// lowercase hex digest in teko_alloc'd memory. The host (run-hash.mjs) captures each
// emit and checks the FIPS 180-4 known-answer vectors + a nested hex(sha256(...)) compose.
extern fn emit(s) from "env" as "emit";

emit(hash.sha256("abc"));    // FIPS: ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
emit(hash.sha256(""));       // FIPS: e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
emit(hash.sha256("The quick brown fox jumps over the lazy dog"));
