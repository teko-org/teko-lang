// Phase 19 (HTTP-INT — http.* client surface) WASM proof.
// Calls http.get("http://example.com/hello") which lowers to env.teko_http_get
// (a WASM host-import). The host mock (run-http.mjs) intercepts the call and
// returns a pointer to "hello-http" written into linear memory.
// The emitted string is compared against "hello-http" by the harness.
//
// Lowers to OP_CALL_RUNTIME id 80 -> env.teko_http_get (single i32 arg: url_ptr).
// The host mock: reads the URL from linear memory, writes "hello-http" into a fixed
// offset (RECV_OFFSET), and returns that offset as the body pointer.
// Demonstrates: http.get surface live on WASM; uses_http gating; wasm_emit_http=1;
// env.teko_http_get import emitted; non-http modules stay byte-identical.
//
// SAST (host side): url_ptr is an i32 module pointer (bounded to the module's linear
// memory); the host mock caps reads at MAX_BUF before scanning; no untrusted data
// leaves the memory region; no format-string / path-traversal on the module side.
extern fn emit(s) from "teko_rt" as "teko_rt_emit";

// Perform an HTTP GET. On WASM the host mock returns a body pointer.
let body = http.get("http://example.com/hello");

// Emit the response body. The harness asserts this is "hello-http".
emit(body);
