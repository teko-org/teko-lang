// Phase 16 (16.C) WASM runner — string INTERPOLATION with auto-`to_string`. A `"…{expr}…"` literal
// interpolates each `{hole}` (auto-converted via reactor id 49) joined with str_concat (id 52) —
// the SAME teko_convert.c source of truth as native, sharing one linear memory. `{{`/`}}` are
// literal braces. Byte-identical output to the native proof.
extern fn emit(s) from "env" as "emit";

let n = 42;
emit("x = {n}");                // x = 42
emit("{n} items, {n} total");   // 42 items, 42 total
emit("sum = {n + 8}");          // sum = 50

let label = "count";
emit("{label}: {n}");           // count: 42

emit("braces {{ }} kept");      // braces { } kept

let msg = "[{n}]";
emit(msg);                      // [42]
