// Phase 15 (15.A) WASM — CONCRETE CLASS: fields + methods + STATIC dispatch, zero runtime
// reflection. Instances live in the runtime reactor (OP_OBJ_* import teko_rt_object_* from
// crypto.wasm and share its linear memory — the SAME teko_object C runtime as the native runner).
// Methods are in-module table routines dispatched via call_indirect (OP_CALL_FUNC), `self` passed
// as the first argument; `self.x` reads a field by compile-time index (OP_OBJ_GET). env.log_int
// surfaces the i32 results to the host harness.
extern fn log_int(n: i32) from "env" as "log_int";

class Point {
  let x;
  let y;
  fn sum(self) { return self.x + self.y; }
  fn scale(self, k) { return (self.x + self.y) * k; }
}

let p = Point();
p.x = 3;
p.y = 4;

let s = p.sum();        // 3 + 4 = 7
log_int(s);

let t = p.scale(10);    // (3 + 4) * 10 = 70
log_int(t);
