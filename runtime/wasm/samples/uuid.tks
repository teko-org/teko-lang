// Phase 13 — native name-based UUID from real Teko source. uuid.v5(name)/uuid.v3(name)
// lower to the in-module UUID runtime (SHA-1 / MD5 over the DNS namespace || name, then
// stamp + canonical format) — no host. The host (run-uuid.mjs) checks the RFC 4122 vectors.
extern fn emit(s) from "env" as "emit";

emit(uuid.v5("python.org"));   // RFC: 886313e1-3b8a-5372-9b90-0c9aee199e5d
emit(uuid.v3("python.org"));   // RFC: 6fa459ea-ee8a-3ca4-894e-db77e160355e
