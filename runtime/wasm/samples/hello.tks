// Phase 11 Browser FFI — real Teko source compiled by the `teko` binary to WASM.
// `extern fn … from "ns" as "name"` declares a host import; calling it lowers to
// OP_CALL_IMPORT against the string constant pool. The host (run-source.mjs)
// provides env.log and reads the pooled string back from linear memory.
extern fn log(msg: str) from "env" as "log";

log("hello from teko source");
