// Phase 11 Browser FFI — real Teko source: an event handler registered from source.
// A `fn` handler is lowered to a WASM table routine; `@dom.on(elem, "click", handler)`
// registers it. When the event fires, the host calls back via teko_invoke and the Teko
// handler updates the DOM. Compiled by the `teko` binary; run in headless Chromium.
fn onClick(target) {
  @dom.setText(target, "clicked from teko");
}

@dom.on(@dom.getElementById("count"), "click", onClick);
