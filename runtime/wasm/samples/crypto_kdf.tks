// Phase 13 Sub-phase C ("big step") — KDF on the WASM surface (4-arg, hex + int args).
// kdf.hkdf_sha256(ikm, salt, info, len) = RFC 5869 Test Case 1 (L=42); kdf.pbkdf2_sha256
// (pass, salt, iters, len) = PBKDF2-HMAC-SHA256("passwd","salt",1,64). ids 27/28; the
// integer length/iteration args lower as ICONST immediates marshalled like pointers.
extern fn emit(s) from "env" as "emit";

emit(kdf.hkdf_sha256("0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b", "000102030405060708090a0b0c", "f0f1f2f3f4f5f6f7f8f9", 42));
emit(kdf.pbkdf2_sha256("706173737764", "73616c74", 1, 64));
