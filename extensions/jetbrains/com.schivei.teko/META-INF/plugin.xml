<idea-plugin>
    <id>com.schivei.teko</id>
    <name>Teko Language Support</name>
    <version>0.1.0</version>
    <vendor email="suporte@teko.org" url="https://github.com">Teko Core</vendor>

    <description><![CDATA[
      Official native support for the Teko programming language.<br>
      Includes high-performance Syntax Highlighting for source files (.tks) and project manifests (.tkp).
    ]]></description>

    <!-- Declares explicit compatibility with the IDE and the base platform -->
    <depends>com.intellij.modules.lang</depends>

    <!-- Injects the TextMate module pointing to the correct Bundle directory -->
    <extensions defaultExtensionNs="com.intellij">
        <textmate.bundleProvider dir="textmate"/>
    </extensions>
</idea-plugin>
