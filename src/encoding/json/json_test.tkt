// src/encoding/json/json_test.tkt — tests for teko::encoding::json (S-JSON).
// Covers: all 6 value kinds, escapes (incl. \uXXXX + surrogate pairs), numbers (int/
// float/exponent/negative), malformed-input error cases (M.1 fail-loud via `error`,
// never a panic), deep nesting, round-trip encode(decode(x)), and the TR4-friendly
// object_get/array_get accessors.

// --- helpers ---

// unwrap `JsonValue | error` — a decode failure in a "should succeed" test is itself a
// test failure (mirrors teko::regex::regex_test.tkt's `matched` helper shape).
fn decoded(text: str) -> teko::encoding::json::JsonValue {
    match teko::encoding::json::decode(text) {
        teko::encoding::json::JsonValue as v => v
        error => { teko::assert::is_true(false); teko::encoding::json::JsonNull { } }
    }
}

fn str_equal(a: str, b: str) -> bool {
    if a.len != b.len { return false }
    mut i: u64 = 0
    loop {
        if i >= a.len { break }
        if a[i] != b[i] { return false }
        i++
    }
    true
}

// --- literals: null / true / false ---

#test
fn decodes_null() {
    match decoded("null") {
        teko::encoding::json::JsonNull => teko::assert::is_true(true)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_true() {
    match decoded("true") {
        teko::encoding::json::JsonBool as b => teko::assert::is_true(b.value)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_false() {
    match decoded("false") {
        teko::encoding::json::JsonBool as b => teko::assert::is_false(b.value)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_with_surrounding_whitespace() {
    match decoded("  \n\t true  \r\n") {
        teko::encoding::json::JsonBool as b => teko::assert::is_true(b.value)
        _ => teko::assert::is_true(false)
    }
}

// --- numbers ---

#test
fn decodes_integer() {
    match decoded("42") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 42.0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_negative_integer() {
    match decoded("-17") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == -17.0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_zero() {
    match decoded("0") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 0.0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_fraction() {
    match decoded("3.5") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 3.5)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_negative_fraction() {
    match decoded("-0.25") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == -0.25)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_exponent_form() {
    match decoded("1.5e2") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 150.0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_negative_exponent() {
    match decoded("2e-3") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 0.002)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_uppercase_exponent_with_plus() {
    match decoded("1E+2") {
        teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 100.0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn rejects_leading_zero() {
    match teko::encoding::json::decode("01") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_bare_minus() {
    match teko::encoding::json::decode("-") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_trailing_dot() {
    match teko::encoding::json::decode("1.") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_absurdly_large_exponent() {
    // guards against an O(|exponent|) pow10 loop hanging on adversarial input (M.1
    // fail-loud, not fail-slow) — f64's usable decimal exponent range is roughly ±308,
    // so a 7+ digit exponent is rejected outright rather than spun through.
    match teko::encoding::json::decode("1e999999999") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn accepts_exponent_at_the_digit_count_boundary() {
    // 6 exponent digits is still accepted (the guard rejects >6, not >=6).
    match teko::encoding::json::decode("1e100000") {
        teko::encoding::json::JsonValue => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
}

// --- strings ---

#test
fn decodes_plain_string() {
    match decoded("\"hello\"") {
        teko::encoding::json::JsonString as s => teko::assert::is_true(str_equal(s.value, "hello"))
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_empty_string() {
    match decoded("\"\"") {
        teko::encoding::json::JsonString as s => teko::assert::is_true(str_equal(s.value, ""))
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_standard_escapes() {
    match decoded("\"a\\\"b\\\\c\\/d\\ne\\tf\\rg\"") {
        teko::encoding::json::JsonString as s => teko::assert::is_true(str_equal(s.value, "a\"b\\c/d\ne\tf\rg"))
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_unicode_escape() {
    // café
    match decoded("\"caf\\u00e9\"") {
        teko::encoding::json::JsonString as s => teko::assert::is_true(str_equal(s.value, "café"))
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_surrogate_pair_escape() {
    // U+1F600 (grinning face) as a UTF-16 surrogate pair
    match decoded("\"\\uD83D\\uDE00\"") {
        teko::encoding::json::JsonString as s => teko::assert::is_true(s.value.len == 4)   // one 4-byte UTF-8 codepoint
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_raw_utf8_passthrough() {
    match decoded("\"héllo wörld\"") {
        teko::encoding::json::JsonString as s => teko::assert::is_true(str_equal(s.value, "héllo wörld"))
        _ => teko::assert::is_true(false)
    }
}

#test
fn rejects_unterminated_string() {
    match teko::encoding::json::decode("\"abc") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_raw_control_character_in_string() {
    // a literal newline byte inside a string (not the \n escape) is illegal per RFC 8259 §7.
    match teko::encoding::json::decode("\"a\nb\"") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_unpaired_high_surrogate() {
    match teko::encoding::json::decode("\"\\uD800\"") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_invalid_escape() {
    match teko::encoding::json::decode("\"\\q\"") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

// --- arrays ---

#test
fn decodes_empty_array() {
    match decoded("[]") {
        teko::encoding::json::JsonArray as a => teko::assert::is_true(a.items.len == 0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_array_of_numbers() {
    match decoded("[1, 2, 3]") {
        teko::encoding::json::JsonArray as a => teko::assert::is_true(a.items.len == 3)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_nested_arrays() {
    match decoded("[[1,2],[3,4],[]]") {
        teko::encoding::json::JsonArray as a => teko::assert::is_true(a.items.len == 3)
        _ => teko::assert::is_true(false)
    }
}

#test
fn rejects_trailing_comma_in_array() {
    match teko::encoding::json::decode("[1,2,]") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_unterminated_array() {
    match teko::encoding::json::decode("[1,2") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

// --- objects ---

#test
fn decodes_empty_object() {
    match decoded("{}") {
        teko::encoding::json::JsonObject as o => teko::assert::is_true(o.keys.len == 0)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_object_with_members() {
    match decoded("{\"a\": 1, \"b\": 2}") {
        teko::encoding::json::JsonObject as o => teko::assert::is_true(o.keys.len == 2)
        _ => teko::assert::is_true(false)
    }
}

#test
fn preserves_object_key_order() {
    match decoded("{\"z\": 1, \"a\": 2}") {
        teko::encoding::json::JsonObject as o => {
            teko::assert::is_true(str_equal(o.keys[0], "z"))
            teko::assert::is_true(str_equal(o.keys[1], "a"))
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn rejects_object_missing_colon() {
    match teko::encoding::json::decode("{\"a\" 1}") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_object_non_string_key() {
    match teko::encoding::json::decode("{1: 2}") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_unterminated_object() {
    match teko::encoding::json::decode("{\"a\": 1") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

// --- deep nesting ---

#test
fn decodes_deeply_nested_structure() {
    match decoded("{\"a\":{\"b\":{\"c\":{\"d\":[1,2,{\"e\":true}]}}}}") {
        teko::encoding::json::JsonObject as o => teko::assert::is_true(o.keys.len == 1)
        _ => teko::assert::is_true(false)
    }
}

#test
fn decodes_deeply_nested_arrays() {
    match decoded("[[[[[[[[[[1]]]]]]]]]]") {
        teko::encoding::json::JsonArray as a => teko::assert::is_true(a.items.len == 1)
        _ => teko::assert::is_true(false)
    }
}

// --- malformed top-level input ---

#test
fn rejects_empty_input() {
    match teko::encoding::json::decode("") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_trailing_garbage() {
    match teko::encoding::json::decode("true garbage") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn rejects_bad_literal_keyword() {
    match teko::encoding::json::decode("nul") {
        teko::encoding::json::JsonValue => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

// --- encode ---

#test
fn encodes_null() {
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonNull { }), "null"))
}

#test
fn encodes_bool() {
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonBool { value = true }), "true"))
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonBool { value = false }), "false"))
}

#test
fn encodes_integral_number_without_decimal_point() {
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonNumber { value = 42.0 }), "42"))
}

#test
fn encodes_negative_integral_number() {
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonNumber { value = -7.0 }), "-7"))
}

#test
fn encodes_fractional_number() {
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonNumber { value = 3.5 }), "3.5"))
}

#test
fn encodes_string_with_escapes() {
    let got = teko::encoding::json::encode(teko::encoding::json::JsonString { value = "a\"b\\c\nd" })
    teko::assert::is_true(str_equal(got, "\"a\\\"b\\\\c\\nd\""))
}

#test
fn encodes_empty_array() {
    teko::assert::is_true(str_equal(teko::encoding::json::encode(teko::encoding::json::JsonArray { items = teko::list::empty() }), "[]"))
}

#test
fn encodes_empty_object() {
    let empty_obj = teko::encoding::json::JsonObject { keys = teko::list::empty(); values = teko::list::empty() }
    teko::assert::is_true(str_equal(teko::encoding::json::encode(empty_obj), "{}"))
}

// --- round-trip: encode(decode(x)) reproduces a stable, re-parseable rendering ---

#test
fn round_trips_object_through_decode_and_encode() {
    let original = "{\"name\":\"Ada\",\"age\":36,\"active\":true,\"tags\":[\"a\",\"b\"],\"meta\":null}"
    let value = decoded(original)
    let re_encoded = teko::encoding::json::encode(value)
    let value2 = decoded(re_encoded)
    let re_encoded2 = teko::encoding::json::encode(value2)
    // a second round trip must be byte-identical to the first (fixpoint) — this is the
    // strongest round-trip guarantee expressible without a structural equality helper.
    teko::assert::is_true(str_equal(re_encoded, re_encoded2))
}

#test
fn round_trips_array_of_mixed_values() {
    let original = "[1,\"two\",3.5,true,false,null,[1,2],{\"k\":\"v\"}]"
    let value = decoded(original)
    let re_encoded = teko::encoding::json::encode(value)
    let value2 = decoded(re_encoded)
    let re_encoded2 = teko::encoding::json::encode(value2)
    teko::assert::is_true(str_equal(re_encoded, re_encoded2))
}

#test
fn round_trips_unicode_string() {
    let original = "{\"greeting\":\"héllo wörld caf\\u00e9\"}"
    let value = decoded(original)
    let re_encoded = teko::encoding::json::encode(value)
    let value2 = decoded(re_encoded)
    let re_encoded2 = teko::encoding::json::encode(value2)
    teko::assert::is_true(str_equal(re_encoded, re_encoded2))
}

#test
fn round_trips_negative_and_fractional_numbers() {
    let original = "[-1,-3.5,0,2.25,100]"
    let value = decoded(original)
    let re_encoded = teko::encoding::json::encode(value)
    let value2 = decoded(re_encoded)
    let re_encoded2 = teko::encoding::json::encode(value2)
    teko::assert::is_true(str_equal(re_encoded, re_encoded2))
}

// --- object_get / array_get (TR4-friendly accessors) ---

#test
fn object_get_finds_existing_key() {
    match decoded("{\"a\":1,\"b\":2}") {
        teko::encoding::json::JsonObject as o => {
            match teko::encoding::json::object_get(o, "b") {
                teko::encoding::json::JsonValue as v => match v {
                    teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 2.0)
                    _ => teko::assert::is_true(false)
                }
                null => teko::assert::is_true(false)
            }
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn object_get_returns_null_for_missing_key() {
    match decoded("{\"a\":1}") {
        teko::encoding::json::JsonObject as o => {
            match teko::encoding::json::object_get(o, "missing") {
                teko::encoding::json::JsonValue => teko::assert::is_true(false)
                null => teko::assert::is_true(true)
            }
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn array_get_returns_element_in_bounds() {
    match decoded("[10,20,30]") {
        teko::encoding::json::JsonArray as a => {
            match teko::encoding::json::array_get(a, 1) {
                teko::encoding::json::JsonValue as v => match v {
                    teko::encoding::json::JsonNumber as n => teko::assert::is_true(n.value == 20.0)
                    _ => teko::assert::is_true(false)
                }
                null => teko::assert::is_true(false)
            }
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn array_get_returns_null_out_of_bounds() {
    match decoded("[10,20]") {
        teko::encoding::json::JsonArray as a => {
            match teko::encoding::json::array_get(a, 5) {
                teko::encoding::json::JsonValue => teko::assert::is_true(false)
                null => teko::assert::is_true(true)
            }
        }
        _ => teko::assert::is_true(false)
    }
}
