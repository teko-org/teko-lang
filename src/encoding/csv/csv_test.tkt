/**
 * Tests for `teko::encoding::csv` (issue #189, T1). Covers RFC 4180 known-answer vectors
 * (simple rows, quoted fields containing commas/quotes/newlines, multi-row documents),
 * minimal-quoting on write, liberal line-ending acceptance on parse, round-trips, and a
 * malformed-input error case (M.1 fail-loud via `error`, never a panic). This file lives
 * under `teko::encoding::csv` (namespace = directory), so functions under test are called
 * bare, mirroring `teko::math::checked_test.tkt`'s convention.
 */

/**
 * Builds a `CsvRow` from a fixed 3-field list — the common case this suite exercises
 * repeatedly.
 *
 * @param a  the first field
 * @param b  the second field
 * @param c  the third field
 * @return   a fresh 3-field `CsvRow`
 */
fn csv_row3(a: str, b: str, c: str) -> CsvRow {
    mut fields: []str = teko::list::empty()
    fields = teko::list::push(fields, a)
    fields = teko::list::push(fields, b)
    fields = teko::list::push(fields, c)
    CsvRow { fields = fields }
}

/**
 * Builds a one-row `[]CsvRow` from a fixed 3-field list (the single-row document case).
 *
 * @param a  the first field
 * @param b  the second field
 * @param c  the third field
 * @return   a fresh single-row `[]CsvRow`
 */
fn one_row(a: str, b: str, c: str) -> []CsvRow {
    mut rows: []CsvRow = teko::list::empty()
    teko::list::push(rows, csv_row3(a, b, c))
}

/**
 * Unwraps a `[]CsvRow | error` parse result — a failure in a "should succeed" test is itself a
 * test failure (mirrors `teko::encoding::json::json_test.tkt`'s `decoded` helper shape).
 *
 * @param result  the parse outcome under test
 * @return        the parsed rows on success, or an empty slice (after failing the assertion) on error
 */
fn expect_ok(result: []CsvRow | error) -> []CsvRow {
    match result {
        []CsvRow as rows => rows
        error => { teko::assert::is_true(false); teko::list::empty() }
    }
}

#test
fn write_simple_row() {
    teko::assert::is_true(write_csv(one_row("a", "b", "c")) == "a,b,c\r\n")
}

#test
fn write_multiple_rows() {
    mut rows: []CsvRow = teko::list::empty()
    rows = teko::list::push(rows, csv_row3("1", "2", "3"))
    rows = teko::list::push(rows, csv_row3("4", "5", "6"))
    teko::assert::is_true(write_csv(rows) == "1,2,3\r\n4,5,6\r\n")
}

#test
fn write_quotes_field_containing_comma() {
    teko::assert::is_true(write_csv(one_row("hello, world", "plain", "x")) == "\"hello, world\",plain,x\r\n")
}

#test
fn write_quotes_and_escapes_embedded_quote() {
    teko::assert::is_true(write_csv(one_row("has \"quotes\"", "plain", "x")) == "\"has \"\"quotes\"\"\",plain,x\r\n")
}

#test
fn write_quotes_field_containing_newline() {
    teko::assert::is_true(write_csv(one_row("line\nbreak", "plain", "x")) == "\"line\nbreak\",plain,x\r\n")
}

#test
fn write_does_not_quote_plain_fields() {
    teko::assert::is_true(write_csv(one_row("plain", "fields", "here")) == "plain,fields,here\r\n")
}

#test
fn parse_simple_row() {
    let rows = expect_ok(parse_csv("a,b,c\r\n"))
    teko::assert::is_true(rows.len == 1)
    teko::assert::is_true(rows[0].fields.len == 3)
    teko::assert::is_true(rows[0].fields[0] == "a")
    teko::assert::is_true(rows[0].fields[1] == "b")
    teko::assert::is_true(rows[0].fields[2] == "c")
}

#test
fn parse_multiple_rows() {
    let rows = expect_ok(parse_csv("1,2,3\r\n4,5,6\r\n"))
    teko::assert::is_true(rows.len == 2)
    teko::assert::is_true(rows[0].fields[0] == "1")
    teko::assert::is_true(rows[1].fields[2] == "6")
}

#test
fn parse_accepts_bare_lf_line_endings() {
    let rows = expect_ok(parse_csv("1,2,3\n4,5,6\n"))
    teko::assert::is_true(rows.len == 2)
    teko::assert::is_true(rows[0].fields[1] == "2")
    teko::assert::is_true(rows[1].fields[1] == "5")
}

#test
fn parse_accepts_bare_cr_line_endings() {
    let rows = expect_ok(parse_csv("1,2,3\r4,5,6\r"))
    teko::assert::is_true(rows.len == 2)
}

#test
fn parse_quoted_field_with_comma() {
    let rows = expect_ok(parse_csv("\"hello, world\",plain,x\r\n"))
    teko::assert::is_true(rows[0].fields[0] == "hello, world")
    teko::assert::is_true(rows[0].fields[1] == "plain")
}

#test
fn parse_quoted_field_with_escaped_quote() {
    let rows = expect_ok(parse_csv("\"has \"\"quotes\"\"\",plain,x\r\n"))
    teko::assert::is_true(rows[0].fields[0] == "has \"quotes\"")
}

#test
fn parse_quoted_field_with_embedded_newline() {
    let rows = expect_ok(parse_csv("\"line\nbreak\",plain,x\r\n"))
    teko::assert::is_true(rows.len == 1)
    teko::assert::is_true(rows[0].fields[0] == "line\nbreak")
}

#test
fn parse_handles_empty_fields() {
    let rows = expect_ok(parse_csv(",empty,\r\n"))
    teko::assert::is_true(rows[0].fields.len == 3)
    teko::assert::is_true(rows[0].fields[0] == "")
    teko::assert::is_true(rows[0].fields[1] == "empty")
    teko::assert::is_true(rows[0].fields[2] == "")
}

#test
fn parse_empty_document_yields_no_rows() {
    let rows = expect_ok(parse_csv(""))
    teko::assert::is_true(rows.len == 0)
}

#test
fn parse_without_trailing_newline_still_yields_the_row() {
    let rows = expect_ok(parse_csv("a,b,c"))
    teko::assert::is_true(rows.len == 1)
    teko::assert::is_true(rows[0].fields[2] == "c")
}

#test
fn round_trip_write_then_parse() {
    mut rows: []CsvRow = teko::list::empty()
    rows = teko::list::push(rows, csv_row3("hello, world", "has \"quotes\"", "line\nbreak"))
    rows = teko::list::push(rows, csv_row3("", "empty", ""))
    let written = write_csv(rows)
    let parsed = expect_ok(parse_csv(written))
    teko::assert::is_true(parsed.len == 2)
    teko::assert::is_true(parsed[0].fields[0] == "hello, world")
    teko::assert::is_true(parsed[0].fields[1] == "has \"quotes\"")
    teko::assert::is_true(parsed[0].fields[2] == "line\nbreak")
    teko::assert::is_true(parsed[1].fields[0] == "")
    teko::assert::is_true(parsed[1].fields[1] == "empty")
    teko::assert::is_true(parsed[1].fields[2] == "")
}

#test
fn parse_rejects_unterminated_quoted_field() {
    match parse_csv("\"unterminated") {
        []CsvRow => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}
