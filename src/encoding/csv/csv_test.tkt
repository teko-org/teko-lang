/**
 * Tests for `teko::encoding::csv` (issue #189, T1). Covers RFC 4180 known-answer vectors
 * (simple rows, quoted fields containing commas/quotes/newlines, multi-row documents),
 * minimal-quoting on write, liberal line-ending acceptance on parse, round-trips, and a
 * malformed-input error case (M.1 fail-loud via `error`, never a panic). This file lives
 * under `teko::encoding::csv` (namespace = directory), so functions under test are called
 * bare, mirroring `teko::math::checked_test.tkt`'s convention.
 */

/**
 * Unwraps a `[]CsvRow | error` parse result — a failure in a "should succeed" test is itself a
 * test failure (mirrors `teko::encoding::json::json_test.tkt`'s `decoded` helper shape).
 *
 * @param result  the parse outcome under test
 * @return        the parsed rows on success, or an empty slice (after failing the assertion) on error
 */
fn expect_ok(result: []CsvRow | error) -> []CsvRow {
    match result {
        []CsvRow as rows => rows
        error => { teko::assert::is_true(false); teko::list::empty() }
    }
}

#test
fn parse_empty_document_yields_no_rows() {
    let rows = expect_ok(parse_csv(""))
    teko::assert::is_true(rows.len == 0)
}

#test
fn parse_without_trailing_newline_still_yields_the_row() {
    let rows = expect_ok(parse_csv("a,b,c"))
    teko::assert::is_true(rows.len == 1)
    teko::assert::is_true(rows[0].fields[2] == "c")
}
