/**
 * Tests for `teko::encoding::url` (issue #189, T1). Covers RFC 3986 percent-encoding known-
 * answer vectors, reserved-character escaping, the space-vs-`+` distinction between
 * `percent_encode` and `encode_form_component`, round-trips, form-body parse/encode, and
 * malformed-escape error cases (M.1 fail-loud via `error`, never a panic). This file lives
 * under `teko::encoding::url` (namespace = directory), so functions under test are called
 * bare, mirroring `teko::math::checked_test.tkt`'s convention.
 */

#test
fn percent_encode_known_answer() {
    teko::assert::is_true(percent_encode("hello world!") == "hello%20world%21")
}

#test
fn percent_encode_leaves_unreserved_untouched() {
    teko::assert::is_true(percent_encode("abcXYZ019-_.~") == "abcXYZ019-_.~")
}

#test
fn percent_encode_escapes_reserved_delimiters() {
    teko::assert::is_true(percent_encode("a=b&c=d") == "a%3Db%26c%3Dd")
    teko::assert::is_true(percent_encode("a/b?c#d") == "a%2Fb%3Fc%23d")
}

#test
fn percent_decode_known_answer() {
    match percent_decode("hello%20world%21") {
        str as s => teko::assert::is_true(s == "hello world!")
        error => teko::assert::is_true(false)
    }
}

#test
fn percent_decode_leaves_plus_literal() {
    match percent_decode("a+b") {
        str as s => teko::assert::is_true(s == "a+b")
        error => teko::assert::is_true(false)
    }
}

#test
fn percent_round_trip() {
    let cases = ["", "hello world!", "a=b&c=d", "100% pure", "unicode café", "abcXYZ019-_.~"]
    mut i: u64 = 0
    loop {
        if i >= cases.len { break }
        let encoded = percent_encode(cases[i])
        match percent_decode(encoded) {
            str as s => teko::assert::is_true(s == cases[i])
            error => teko::assert::is_true(false)
        }
        i++
    }
}

#test
fn form_component_encodes_space_as_plus() {
    teko::assert::is_true(encode_form_component("john doe") == "john+doe")
}

#test
fn form_component_still_escapes_plus_and_reserved() {
    teko::assert::is_true(encode_form_component("a+b") == "a%2Bb")
}

#test
fn form_component_decodes_plus_as_space() {
    match decode_form_component("john+doe") {
        str as s => teko::assert::is_true(s == "john doe")
        error => teko::assert::is_true(false)
    }
}

#test
fn form_component_decodes_percent_escapes_too() {
    match decode_form_component("a%2Bb") {
        str as s => teko::assert::is_true(s == "a+b")
        error => teko::assert::is_true(false)
    }
}

#test
fn parse_form_known_answer() {
    match parse_form("name=john+doe&q=a%2Bb") {
        []FormField as fields => {
            teko::assert::is_true(fields.len == 2)
            teko::assert::is_true(fields[0].key == "name")
            teko::assert::is_true(fields[0].value == "john doe")
            teko::assert::is_true(fields[1].key == "q")
            teko::assert::is_true(fields[1].value == "a+b")
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn parse_form_empty_body_yields_no_fields() {
    match parse_form("") {
        []FormField as fields => teko::assert::is_true(fields.len == 0)
        error => teko::assert::is_true(false)
    }
}

#test
fn parse_form_bare_key_has_empty_value() {
    match parse_form("flag") {
        []FormField as fields => {
            teko::assert::is_true(fields.len == 1)
            teko::assert::is_true(fields[0].key == "flag")
            teko::assert::is_true(fields[0].value == "")
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn parse_form_accepts_legacy_semicolon_separator() {
    match parse_form("a=1;b=2") {
        []FormField as fields => {
            teko::assert::is_true(fields.len == 2)
            teko::assert::is_true(fields[0].key == "a")
            teko::assert::is_true(fields[1].key == "b")
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn encode_form_known_answer() {
    mut fields: []FormField = teko::list::empty()
    fields = teko::list::push(fields, FormField { key = "name"; value = "john doe" })
    fields = teko::list::push(fields, FormField { key = "q"; value = "a+b" })
    teko::assert::is_true(encode_form(fields) == "name=john+doe&q=a%2Bb")
}

#test
fn form_round_trip() {
    mut fields: []FormField = teko::list::empty()
    fields = teko::list::push(fields, FormField { key = "greeting"; value = "hello world" })
    fields = teko::list::push(fields, FormField { key = "sum"; value = "1+1=2" })
    let encoded = encode_form(fields)
    match parse_form(encoded) {
        []FormField as parsed => {
            teko::assert::is_true(parsed.len == 2)
            teko::assert::is_true(parsed[0].value == "hello world")
            teko::assert::is_true(parsed[1].value == "1+1=2")
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn decode_rejects_truncated_escape() {
    match percent_decode("abc%2") {
        str => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn decode_rejects_invalid_hex_digit() {
    match percent_decode("abc%zz") {
        str => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}
