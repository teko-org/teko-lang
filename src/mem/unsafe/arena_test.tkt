/**
 * src/mem/unsafe/arena_test.tkt — VM-runnable coverage for `teko::mem::unsafe::Arena` (S3, issue
 * #358). The module and this test both live under `teko::mem::unsafe` (namespace = directory), so
 * `Arena` is named bare, exactly like `rawbuf_test.tkt` names `Owned`.
 *
 * `Arena`'s FULL create -> alloc -> read -> `mem::free` round-trip is the NATIVE-ONLY
 * `examples/regressions/arena_manual_ok` fixture: `teko::mem::region_alloc` reads pointer bytes back
 * through a host-only builtin the VM refuses (C7.19, the same shape as `RawBuf`'s `buf_ptr`), and
 * `teko test` runs `#test` on the VM. This file covers the half the alloc path never touches:
 * opening a region (`Arena::new`) and consuming the `#must_free` handle via `teko::mem::free`. An
 * `unsafe fn` because it binds a local of the `unsafe type Arena` (U2 containment); freeing on the
 * sole path satisfies the `#must_free` dataflow; the test passes by not diverging.
 */
#test
unsafe fn arena_new_is_opened_and_freed() {
    mut a = Arena::new()
    teko::mem::free(a)
    teko::assert::is_true(true)
}
