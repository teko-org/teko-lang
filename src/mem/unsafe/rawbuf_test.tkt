/**
 * src/mem/unsafe/rawbuf_test.tkt — construction/read coverage for `teko::mem::unsafe` (U3,
 * issue #334). Pure Teko, VM-runnable (no extern), so every case gates BOTH engines. The
 * module and this test both live under `teko::mem::unsafe` (namespace = directory), so the
 * declarations under test are called bare, exactly like `checked_test.tkt` calls
 * `checked_add_u8` against `math::checked`.
 *
 * `RawBuf`'s own round-trip (`rawbuf_alloc`/`rawbuf_read`/`rawbuf_len`) is NOT exercised here:
 * `rawbuf_alloc` calls `teko::mem::buf_ptr`, a host-only builtin the VM refuses to run (C7.19 —
 * "the region stays opaque to Teko"), and `teko test` always runs `#test` on the VM. That
 * round-trip is instead the NATIVE-ONLY `examples/regressions/unsafe_rawbuf_roundtrip` fixture
 * (mirroring `buf_ptr_memset_roundtrip`'s same VM-refusal shape). This file covers the half of
 * the module `buf_ptr` never touches: `Owned<T>`'s construction/read, at two independent
 * concrete instantiations.
 *
 * This first test, `owned_i64_make_and_take_round_trip`: `Owned<T>::make`/`.take()` round-trip
 * a wrapped value unchanged, at one concrete instantiation (`Owned<i64>`).
 */
#test
fn owned_i64_make_and_take_round_trip() {
    let handle = Owned<i64>::make(42)
    teko::assert::is_true(handle.take() == 42)
}

/**
 * `Owned<T>` monomorphizes independently per concrete `T` — a second instantiation
 * (`Owned<str>`) round-trips its own value, proving the generic stamps distinctly per width
 * (mirroring the `List<i64>` / `List<str>` two-instantiation gate in `list_test.tkt`).
 */
#test
fn owned_str_make_and_take_round_trip() {
    let handle = Owned<str>::make("held")
    teko::assert::is_true(teko::runtime::str_eq(handle.take(), "held"))
}
