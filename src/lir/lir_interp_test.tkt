#test
fn iwt_missing_entry_is_negative_sentinel() {
    teko::assert::is_true(interp_lmodule(empty_module(), "nope", iwt_no_args()) == iwt_i128(-1))
}

#test
fn iwt_unknown_runtime_call_is_negative_sentinel() {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    f = append_inst(f, 0, void_call_inst("tk_println", teko::list::empty(), false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, 0, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, 0, ret_inst(z.vreg, 0, 0))
    teko::assert::is_true(interp_lmodule(add_func(empty_module(), f), "main", iwt_no_args()) == iwt_i128(-1))
}

/** iwt_if_exit — F6: `exit(if x<y {x} else {y})` — branch to a per-arm block, each jumping
    to a merge block-arg carrying the picked value, exit(the merge value). Proves
    interp_blocks follows an LBranch to its chosen target and binds the winning jump's
    block-arg into the merge block's param. */
fn iwt_if_exit(x: i64, y: i64) -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let vx = alloc_vreg(f)
    f = vx.func
    f = append_inst(f, 0, const_int_inst(vx.vreg, iwt_i128(x), 0, 0))
    let vy = alloc_vreg(f)
    f = vy.func
    f = append_inst(f, 0, const_int_inst(vy.vreg, iwt_i128(y), 0, 0))
    let vc = alloc_vreg(f)
    f = vc.func
    f = append_inst(f, 0, bin_inst(vc.vreg, LBinOp::ICmpLtS, vx.vreg, vy.vreg, 0, 0))
    let thenb = alloc_block(f)
    f = thenb.func
    let elseb = alloc_block(f)
    f = elseb.func
    let mergeb = alloc_block(f)
    f = mergeb.func
    let mp = add_block_param(f, mergeb.block_id)
    f = mp.func
    f = append_inst(f, 0, branch_inst(vc.vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), 0, 0))
    f = append_inst(f, thenb.block_id, jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), vx.vreg), 0, 0))
    f = append_inst(f, elseb.block_id, jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), vy.vreg), 0, 0))
    let eargs = teko::list::push(teko::list::empty(), mp.vreg)
    f = append_inst(f, mergeb.block_id, void_call_inst("tk_exit", eargs, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, mergeb.block_id, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, mergeb.block_id, ret_inst(z.vreg, 0, 0))
    add_func(empty_module(), f)
}

#test
fn iwt_f6_if_expr_picks_the_then_arm() {
    teko::assert::is_true(interp_lmodule(iwt_if_exit(2, 100), "main", iwt_no_args()) == iwt_i128(2))
}

#test
fn iwt_f6_if_expr_picks_the_else_arm() {
    teko::assert::is_true(interp_lmodule(iwt_if_exit(100, 7), "main", iwt_no_args()) == iwt_i128(7))
}

/** iwt_chain_lt_exit — F7: `exit((a<b) && (b<c) ? 1 : 0)`, the branch-merge AND shape
    lower_compare produces for a chained comparison `a<b<c`. Proves interp_blocks follows a
    SEQUENCE of branch/merge transitions (not just one), short-circuiting past the second
    comparison's block through the merge's 0 constant when the first term is already false. */
fn iwt_chain_lt_exit(a: i64, b: i64, c: i64) -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let va = alloc_vreg(f)
    f = va.func
    f = append_inst(f, 0, const_int_inst(va.vreg, iwt_i128(a), 0, 0))
    let vb = alloc_vreg(f)
    f = vb.func
    f = append_inst(f, 0, const_int_inst(vb.vreg, iwt_i128(b), 0, 0))
    let vc = alloc_vreg(f)
    f = vc.func
    f = append_inst(f, 0, const_int_inst(vc.vreg, iwt_i128(c), 0, 0))
    let t1 = alloc_vreg(f)
    f = t1.func
    f = append_inst(f, 0, bin_inst(t1.vreg, LBinOp::ICmpLtS, va.vreg, vb.vreg, 0, 0))
    let t2 = alloc_vreg(f)
    f = t2.func
    f = append_inst(f, 0, bin_inst(t2.vreg, LBinOp::ICmpLtS, vb.vreg, vc.vreg, 0, 0))
    let thenb = alloc_block(f)
    f = thenb.func
    let elseb = alloc_block(f)
    f = elseb.func
    let mergeb = alloc_block(f)
    f = mergeb.func
    let mp = add_block_param(f, mergeb.block_id)
    f = mp.func
    f = append_inst(f, 0, branch_inst(t1.vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), 0, 0))
    f = append_inst(f, thenb.block_id, jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), t2.vreg), 0, 0))
    let zero = alloc_vreg(f)
    f = zero.func
    f = append_inst(f, elseb.block_id, const_int_inst(zero.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, elseb.block_id, jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), zero.vreg), 0, 0))
    let eargs = teko::list::push(teko::list::empty(), mp.vreg)
    f = append_inst(f, mergeb.block_id, void_call_inst("tk_exit", eargs, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, mergeb.block_id, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, mergeb.block_id, ret_inst(z.vreg, 0, 0))
    add_func(empty_module(), f)
}

#test
fn iwt_f7_chain_all_ascending_is_true() {
    teko::assert::is_true(interp_lmodule(iwt_chain_lt_exit(1, 2, 3), "main", iwt_no_args()) == iwt_i128(1))
}

#test
fn iwt_f7_chain_breaks_at_the_second_term_is_false() {
    teko::assert::is_true(interp_lmodule(iwt_chain_lt_exit(1, 5, 3), "main", iwt_no_args()) == iwt_i128(0))
}

#test
fn iwt_f7_chain_fails_at_the_first_term_is_false() {
    teko::assert::is_true(interp_lmodule(iwt_chain_lt_exit(5, 2, 3), "main", iwt_no_args()) == iwt_i128(0))
}

/** iwt_alloc_field — reserve a slot at `base`, store `val` at `offset`, then load it back
    into a fresh VReg — the shared alloca/field_addr/store/load shape every A1-3 memory
    fixture below builds on. */
fn iwt_alloc_field(f0: LFunc, base: u32, offset: u32, val: i64) -> LFunc {
    mut f = f0
    let c = alloc_vreg(f)
    f = c.func
    f = append_inst(f, 0, const_int_inst(c.vreg, iwt_i128(val), 0, 0))
    let a = alloc_vreg(f)
    f = a.func
    f = append_inst(f, 0, field_addr_inst(a.vreg, base, offset, 0, 0))
    append_inst(f, 0, store_inst(a.vreg, c.vreg, LType::I64, 0, 0))
}

/** iwt_load_field — load the value at `base + offset` into a fresh VReg. */
fn iwt_load_field(f0: LFunc, base: u32, offset: u32) -> FreshVReg {
    let a = alloc_vreg(f0)
    let f1 = a.func
    let l = alloc_vreg(f1)
    let f2 = append_inst(l.func, 0, field_addr_inst(a.vreg, base, offset, 0, 0))
    FreshVReg { func = append_inst(f2, 0, load_inst(l.vreg, a.vreg, LType::I64, 0, 0)); vreg = l.vreg }
}

/** iwt_exit_sum — append `exit(a + b)` (a terminal void_call + the ABI's trailing
    `const 0; ret`) to `f0`. */
fn iwt_exit_sum(f0: LFunc, a: u32, b: u32) -> LFunc {
    let s = alloc_vreg(f0)
    mut f = s.func
    f = append_inst(f, 0, bin_inst(s.vreg, LBinOp::IAdd, a, b, 0, 0))
    let args = teko::list::push(teko::list::empty(), s.vreg)
    f = append_inst(f, 0, void_call_inst("tk_exit", args, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, 0, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    append_inst(f, 0, ret_inst(z.vreg, 0, 0))
}

/** iwt_struct_point_exit — F10: `let p = Point{x=3;y=4}; exit(p.x + p.y)` as hand-built
    memory-op LIR: alloca a 16-byte/8-align slot, store both fields, load them back, exit
    their sum (3+4=7). Proves the interp's cell-store model round-trips a struct write/read. */
fn iwt_struct_point_exit() -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let base = alloc_vreg(f)
    f = base.func
    f = append_inst(f, 0, alloca_inst(base.vreg, 16, 8, 0, 0))
    f = iwt_alloc_field(f, base.vreg, 0, 3)
    f = iwt_alloc_field(f, base.vreg, 8, 4)
    let lx = iwt_load_field(f, base.vreg, 0)
    f = lx.func
    let ly = iwt_load_field(f, base.vreg, 8)
    f = ly.func
    add_func(empty_module(), iwt_exit_sum(f, lx.vreg, ly.vreg))
}

#test
fn iwt_f10_struct_field_roundtrip_sums_to_seven() {
    teko::assert::is_true(interp_lmodule(iwt_struct_point_exit(), "main", iwt_no_args()) == iwt_i128(7))
}

/** iwt_array_index_exit — F11: `let a = [10,20,30]; exit(a[1])` as hand-built memory-op
    LIR: alloca a 24-byte/8-align slot, store the three elements at their constant strides,
    load index 1 (byte offset 8), exit it (20). Proves LFieldAddr's constant-folded index
    addressing. */
fn iwt_array_index_exit() -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let base = alloc_vreg(f)
    f = base.func
    f = append_inst(f, 0, alloca_inst(base.vreg, 24, 8, 0, 0))
    f = iwt_alloc_field(f, base.vreg, 0, 10)
    f = iwt_alloc_field(f, base.vreg, 8, 20)
    f = iwt_alloc_field(f, base.vreg, 16, 30)
    let r = iwt_load_field(f, base.vreg, 8)
    f = r.func
    let args = teko::list::push(teko::list::empty(), r.vreg)
    f = append_inst(f, 0, void_call_inst("tk_exit", args, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, 0, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, 0, ret_inst(z.vreg, 0, 0))
    add_func(empty_module(), f)
}

#test
fn iwt_f11_array_index_reads_the_element() {
    teko::assert::is_true(interp_lmodule(iwt_array_index_exit(), "main", iwt_no_args()) == iwt_i128(20))
}

/** iwt_struct_mutate_exit — F12: a field MUTATION via a load/add/store round-trip
    (`p.x = p.x + 10`), then `exit(p.x + p.y)`: `{x=1,y=2}` mutates x to 11, so the sum
    exits 13. Proves a STORE is visible to a LATER load through the same address. */
fn iwt_struct_mutate_exit() -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let base = alloc_vreg(f)
    f = base.func
    f = append_inst(f, 0, alloca_inst(base.vreg, 16, 8, 0, 0))
    f = iwt_alloc_field(f, base.vreg, 0, 1)
    f = iwt_alloc_field(f, base.vreg, 8, 2)
    let curx = iwt_load_field(f, base.vreg, 0)
    f = curx.func
    let ten = alloc_vreg(f)
    f = ten.func
    f = append_inst(f, 0, const_int_inst(ten.vreg, iwt_i128(10), 0, 0))
    let newx = alloc_vreg(f)
    f = newx.func
    f = append_inst(f, 0, bin_inst(newx.vreg, LBinOp::IAdd, curx.vreg, ten.vreg, 0, 0))
    let addr_x = alloc_vreg(f)
    f = addr_x.func
    f = append_inst(f, 0, field_addr_inst(addr_x.vreg, base.vreg, 0, 0, 0))
    f = append_inst(f, 0, store_inst(addr_x.vreg, newx.vreg, LType::I64, 0, 0))
    let rx = iwt_load_field(f, base.vreg, 0)
    f = rx.func
    let ry = iwt_load_field(f, base.vreg, 8)
    f = ry.func
    add_func(empty_module(), iwt_exit_sum(f, rx.vreg, ry.vreg))
}

#test
fn iwt_f12_field_mutation_is_observed_after_store() {
    teko::assert::is_true(interp_lmodule(iwt_struct_mutate_exit(), "main", iwt_no_args()) == iwt_i128(13))
}

/** iwt_bytes_of — a str literal's raw UTF-8 as a `[]byte` (the rodata payload the fixtures
    below hand-build, mirroring `str_to_bytes` — A1-4, #382). */
fn iwt_bytes_of(s: str) -> []byte {
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= s.len { break }
        out = teko::list::push(out, s[i])
        i++
    }
    out
}

/** iwt_one_rodata — a one-entry rodata table (the shape `lower_str_bytes_fat` interns —
    A1-4, #382). */
fn iwt_one_rodata(symbol: str, text: str) -> []LRodata {
    teko::list::push(teko::list::empty(), LRodata { symbol = symbol; bytes = iwt_bytes_of(text) })
}

/** iwt_str_len_exit — F13: `exit("hello".len)` hand-built exactly as `lower_len_field`
    would emit it: a `global_addr` for the (unused, but STILL materialized) pointer half,
    then the compile-time-known length as a plain constant — proves a module WITH rodata
    seeds/runs cleanly even when the entry never reads the rodata's bytes (A1-4, #382). */
fn iwt_str_len_exit() -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let ptr = alloc_vreg(f)
    f = ptr.func
    f = append_inst(f, 0, global_addr_inst(ptr.vreg, ".Lstr0", 0, 0))
    let lenv = alloc_vreg(f)
    f = lenv.func
    f = append_inst(f, 0, const_int_inst(lenv.vreg, iwt_i128(5), 0, 0))
    let args = teko::list::push(teko::list::empty(), lenv.vreg)
    f = append_inst(f, 0, void_call_inst("tk_exit", args, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, 0, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, 0, ret_inst(z.vreg, 0, 0))
    with_rodata(add_func(empty_module(), f), iwt_one_rodata(".Lstr0", "hello"))
}

#test
fn iwt_f13_str_len_reads_the_compile_time_length() {
    teko::assert::is_true(interp_lmodule(iwt_str_len_exit(), "main", iwt_no_args()) == iwt_i128(5))
}

/** iwt_str_index_exit — F14: `exit("abc"[0] to i32)` hand-built exactly as
    `lower_index_str` + `lower_cast` would emit it: `global_addr` -> `field_addr` (the
    constant-folded byte offset) -> `load.i8` -> `zext` (u8->i32 widens) -> exit. Proves
    `LGlobalAddr`/`seed_rodata`/`rodata_base_of` round-trip a REAL byte read off rodata
    (A1-4, #382). */
fn iwt_str_index_exit() -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let ptr = alloc_vreg(f)
    f = ptr.func
    f = append_inst(f, 0, global_addr_inst(ptr.vreg, ".Lstr0", 0, 0))
    let addr = alloc_vreg(f)
    f = addr.func
    f = append_inst(f, 0, field_addr_inst(addr.vreg, ptr.vreg, 0, 0, 0))
    let byte = alloc_vreg(f)
    f = byte.func
    f = append_inst(f, 0, load_inst(byte.vreg, addr.vreg, LType::I8, 0, 0))
    let widened = alloc_vreg(f)
    f = widened.func
    f = append_inst(f, 0, un_inst(widened.vreg, LUnOp::ZExt, byte.vreg, 0, 0))
    let args = teko::list::push(teko::list::empty(), widened.vreg)
    f = append_inst(f, 0, void_call_inst("tk_exit", args, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, 0, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, 0, ret_inst(z.vreg, 0, 0))
    with_rodata(add_func(empty_module(), f), iwt_one_rodata(".Lstr0", "abc"))
}

#test
fn iwt_f14_str_index_reads_the_byte_off_rodata() {
    teko::assert::is_true(interp_lmodule(iwt_str_index_exit(), "main", iwt_no_args()) == iwt_i128(97))
}

/** iwt_coalesce_exit — F15: `exit(x ?? fallback)` hand-built exactly as `lower_coalesce`
    would emit it: `x` (a null sentinel 0 when ABSENT, else `present_val`) branches to a
    merge carrying either `x` itself or the lowered fallback. Proves interp_blocks follows
    the coalesce's branch/merge shape (a THIRD construct built on the same infra as the
    if-expr F6 and the chained-compare F7 — A1-4, #382). */
fn iwt_coalesce_exit(is_present: bool, present_val: i64, fallback: i64) -> LModule {
    mut f = new_func("main", 0, teko::list::empty(), LType::I32)
    let xv = alloc_vreg(f)
    f = xv.func
    let x_value = if is_present { present_val } else { 0 to i64 }
    f = append_inst(f, 0, const_int_inst(xv.vreg, iwt_i128(x_value), 0, 0))
    let thenb = alloc_block(f)
    f = thenb.func
    let elseb = alloc_block(f)
    f = elseb.func
    let mergeb = alloc_block(f)
    f = mergeb.func
    let mp = add_block_param(f, mergeb.block_id)
    f = mp.func
    f = append_inst(f, 0, branch_inst(xv.vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), 0, 0))
    f = append_inst(f, thenb.block_id, jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), xv.vreg), 0, 0))
    let fb = alloc_vreg(f)
    f = fb.func
    f = append_inst(f, elseb.block_id, const_int_inst(fb.vreg, iwt_i128(fallback), 0, 0))
    f = append_inst(f, elseb.block_id, jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), fb.vreg), 0, 0))
    let eargs = teko::list::push(teko::list::empty(), mp.vreg)
    f = append_inst(f, mergeb.block_id, void_call_inst("tk_exit", eargs, false, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, mergeb.block_id, const_int_inst(z.vreg, iwt_i128(0), 0, 0))
    f = append_inst(f, mergeb.block_id, ret_inst(z.vreg, 0, 0))
    add_func(empty_module(), f)
}

#test
fn iwt_f15_coalesce_present_takes_the_left_value() {
    teko::assert::is_true(interp_lmodule(iwt_coalesce_exit(true, 7, 99), "main", iwt_no_args()) == iwt_i128(7))
}

#test
fn iwt_f15_coalesce_absent_takes_the_fallback() {
    teko::assert::is_true(interp_lmodule(iwt_coalesce_exit(false, 7, 99), "main", iwt_no_args()) == iwt_i128(99))
}
