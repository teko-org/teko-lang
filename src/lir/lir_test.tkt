    f = append_inst(f, 0, const_float_inst(c.vreg, teko::f64_bits(0.0), 0, 0))
    f = append_inst(f, 0, ret_inst(c.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%0 = const.f64 0x0")
}

#test
fn prints_unary_and_negative_int() {
    mut f = new_func("neg", 1, teko::list::push(teko::list::empty(), LType::I64), LType::I64)
    let r = alloc_vreg(f)
    f = r.func
    f = append_inst(f, 0, un_inst(r.vreg, LUnOp::INeg, 0, 0, 0))
    f = append_inst(f, 0, ret_inst(r.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%1 = ineg %0")
}

#test
fn prints_negative_int_literal() {
    mut f = new_func("m", 0, teko::list::empty(), LType::I64)
    let c = alloc_vreg(f)
    f = c.func
    f = append_inst(f, 0, const_int_inst(c.vreg, -42 to i128, 0, 0))
    f = append_inst(f, 0, ret_inst(c.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
