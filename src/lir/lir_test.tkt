}

#test
fn prints_param_instruction() {
    mut f = new_func("id", 1, teko::list::push(teko::list::empty(), LType::I32), LType::I32)
    let p = alloc_vreg(f)
    f = p.func
    f = append_inst(f, 0, param_inst(p.vreg, 0, 0, 0))
    f = append_inst(f, 0, ret_inst(p.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%1 = param 0")
}

#test
fn prints_signed_div_and_rem_mnemonics() {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), LType::I64), LType::I64)
    mut f = new_func("dm", 2, ptypes, LType::I64)
    let q = alloc_vreg(f)
    f = q.func
    f = append_inst(f, 0, bin_inst(q.vreg, LBinOp::IDivS, 0, 1, 0, 0))
    let rr = alloc_vreg(f)
    f = rr.func
    f = append_inst(f, 0, bin_inst(rr.vreg, LBinOp::IRemU, 0, 1, 0, 0))
    f = append_inst(f, 0, ret_inst(q.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%2 = idivs %0, %1")
    teko::assert::str_contains(text, "%3 = iremu %0, %1")
}

#test
fn prints_call_with_multiple_args() {
    mut f = new_func("caller", 0, teko::list::empty(), LType::I64)
    let a = alloc_vreg(f)
    f = a.func
    f = append_inst(f, 0, const_int_inst(a.vreg, 40, 0, 0))
    let b = alloc_vreg(f)
    f = b.func
    f = append_inst(f, 0, const_int_inst(b.vreg, 2, 0, 0))
    let args = teko::list::push(teko::list::push(teko::list::empty(), a.vreg), b.vreg)
    let r = alloc_vreg(f)
    f = r.func
    f = append_inst(f, 0, call_inst(r.vreg, "teko__demo__add", args, false, 0, 0))
    f = append_inst(f, 0, ret_inst(r.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%2 = call @teko__demo__add(%0, %1)")
}

#test
fn empty_module_prints_nothing() {
    teko::assert::is_true(print_lmodule(empty_module()) == "")
}

#test
fn prints_call_indirect_with_multiple_args() {
    mut f = new_func("caller", 0, teko::list::empty(), LType::I64)
    let target = alloc_vreg(f)
    f = target.func
    f = append_inst(f, 0, const_int_inst(target.vreg, 0, 0, 0))
    let a = alloc_vreg(f)
    f = a.func
    f = append_inst(f, 0, const_int_inst(a.vreg, 1, 0, 0))
    let b = alloc_vreg(f)
    f = b.func
    f = append_inst(f, 0, const_int_inst(b.vreg, 2, 0, 0))
    let args = teko::list::push(teko::list::push(teko::list::empty(), a.vreg), b.vreg)
    let r = alloc_vreg(f)
    f = r.func
    f = append_inst(f, 0, call_indirect_inst(r.vreg, target.vreg, args, false, 0, 0))
    f = append_inst(f, 0, ret_inst(r.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%3 = call.indirect %0(%1, %2)")
}

#test
fn prints_void_call_indirect_with_no_result_prefix() {
    mut f = new_func("caller", 0, teko::list::empty(), LType::Void)
    let target = alloc_vreg(f)
    f = target.func
    f = append_inst(f, 0, const_int_inst(target.vreg, 0, 0, 0))
    f = append_inst(f, 0, void_call_indirect_inst(target.vreg, teko::list::empty(), false, 0, 0))
    f = append_inst(f, 0, ret_void_inst(0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "    call.indirect %0()")
    teko::assert::is_true(!teko::str::contains(text, "= call.indirect"))
}

/** lirt_two_blocks — a function with a fresh block #B1 reached by an unconditional jump
    carrying one block-arg, the shape A1-1's block allocator/printer must round-trip. */
fn lirt_two_blocks() -> LFunc {
    mut f = new_func("m", 0, teko::list::empty(), LType::I32)
    let blk = alloc_block(f)
    f = blk.func
    let c = alloc_vreg(f)
    f = c.func
    f = append_inst(f, 0, const_int_inst(c.vreg, 7, 0, 0))
    f = append_inst(f, 0, jump_inst(blk.block_id, teko::list::push(teko::list::empty(), c.vreg), 0, 0))
    append_inst(f, blk.block_id, ret_inst(c.vreg, 0, 0))
}

#test
fn alloc_block_ids_are_dense_and_sequential() {
    mut f = new_func("m", 0, teko::list::empty(), LType::I32)
    let b1 = alloc_block(f)
    f = b1.func
    let b2 = alloc_block(f)
    teko::assert::is_true(b1.block_id == 1)
    teko::assert::is_true(b2.block_id == 2)
}

#test
fn prints_jump_with_a_block_arg() {
    let text = print_lmodule(add_func(empty_module(), lirt_two_blocks()))
    teko::assert::str_contains(text, "jump #B1(%0)")
}

#test
fn prints_block_body_after_a_jump_target() {
    let text = print_lmodule(add_func(empty_module(), lirt_two_blocks()))
    teko::assert::str_contains(text, "  #B1:\n    ret %0")
}

#test
fn prints_branch_with_two_targets() {
    mut f = new_func("m", 0, teko::list::empty(), LType::I32)
    let thenb = alloc_block(f)
    f = thenb.func
    let elseb = alloc_block(f)
    f = elseb.func
    let c = alloc_vreg(f)
    f = c.func
    f = append_inst(f, 0, const_int_inst(c.vreg, 1, 0, 0))
    f = append_inst(f, 0, branch_inst(c.vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), 0, 0))
    f = append_inst(f, thenb.block_id, ret_inst(c.vreg, 0, 0))
    f = append_inst(f, elseb.block_id, ret_inst(c.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "branch %0, #B1(), #B2()")
}

#test
fn prints_block_header_with_a_param() {
    mut f = new_func("m", 0, teko::list::empty(), LType::I32)
    let blk = alloc_block(f)
    f = blk.func
    let p = add_block_param(f, blk.block_id)
    f = p.func
    f = append_inst(f, blk.block_id, ret_inst(p.vreg, 0, 0))
    let z = alloc_vreg(f)
    f = z.func
    f = append_inst(f, 0, const_int_inst(z.vreg, 0, 0, 0))
    f = append_inst(f, 0, jump_inst(blk.block_id, teko::list::push(teko::list::empty(), z.vreg), 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, teko::str::concat("#B1(%", teko::u64_to_str(p.vreg to u64), "):"))
}

/** lirt_mixed_width_fields — a struct with fields of every scalar width the layout
    algorithm must pad between: `{ a: u8; b: u32; c: u8; d: i64 }`. */
fn lirt_mixed_width_names() -> []str {
    teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "a"), "b"), "c"), "d")
}

fn lirt_mixed_width_types() -> []LType {
    teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), LType::I8), LType::I32), LType::I8), LType::I64)
}

#test
fn layout_of_pads_each_field_to_its_own_alignment() {
    let l = layout_of("Mixed", lirt_mixed_width_names(), lirt_mixed_width_types())
    teko::assert::is_true(l.field_offsets[0] == 0)
    teko::assert::is_true(l.field_offsets[1] == 4)
    teko::assert::is_true(l.field_offsets[2] == 8)
    teko::assert::is_true(l.field_offsets[3] == 16)
}

#test
fn layout_of_rounds_the_total_size_up_to_the_widest_alignment() {
    let l = layout_of("Mixed", lirt_mixed_width_names(), lirt_mixed_width_types())
    teko::assert::is_true(l.align == 8)
    teko::assert::is_true(l.size == 24)
}

#test
fn layout_of_flat_two_field_struct_matches_the_point_fixture() {
    let names = teko::list::push(teko::list::push(teko::list::empty(), "x"), "y")
    let types = teko::list::push(teko::list::push(teko::list::empty(), LType::I64), LType::I64)
    let l = layout_of("Point", names, types)
    teko::assert::is_true(l.size == 16)
    teko::assert::is_true(l.align == 8)
    teko::assert::is_true(l.field_offsets[0] == 0)
    teko::assert::is_true(l.field_offsets[1] == 8)
}

#test
fn prints_alloca_field_addr_load_and_store() {
    mut f = new_func("m", 0, teko::list::empty(), LType::I32)
    let base = alloc_vreg(f)
    f = base.func
    f = append_inst(f, 0, alloca_inst(base.vreg, 16, 8, 0, 0))
    let c = alloc_vreg(f)
    f = c.func
    f = append_inst(f, 0, const_int_inst(c.vreg, 9, 0, 0))
    let addr = alloc_vreg(f)
    f = addr.func
    f = append_inst(f, 0, field_addr_inst(addr.vreg, base.vreg, 8, 0, 0))
    f = append_inst(f, 0, store_inst(addr.vreg, c.vreg, LType::I64, 0, 0))
    let r = alloc_vreg(f)
    f = r.func
    f = append_inst(f, 0, load_inst(r.vreg, addr.vreg, LType::I64, 0, 0))
    f = append_inst(f, 0, ret_inst(r.vreg, 0, 0))
    let text = print_lmodule(add_func(empty_module(), f))
    teko::assert::str_contains(text, "%0 = alloca 16, align 8")
    teko::assert::str_contains(text, "%2 = field_addr %0, 8")
    teko::assert::str_contains(text, "store.i64 %2, %1")
    teko::assert::str_contains(text, "%3 = load.i64 %2")
}

#test
fn prints_a_registered_struct_layout_header() {
    let names = teko::list::push(teko::list::push(teko::list::empty(), "x"), "y")
    let types = teko::list::push(teko::list::push(teko::list::empty(), LType::I64), LType::I64)
    let m = add_layout(empty_module(), layout_of("Point", names, types))
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "layout Point: size=16 align=8 {x@0, y@8}")
}

#test
fn a_module_with_no_layouts_prints_no_header() {
    let m = add_func(empty_module(), new_func("m", 0, teko::list::empty(), LType::I32))
    teko::assert::is_true(!teko::str::contains(print_lmodule(m), "layout "))
}
