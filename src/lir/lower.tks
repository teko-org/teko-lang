use teko::checker
use teko::lexer
use teko::parser

/** teko::lir (lowering) — TAST -> LIR for the N1 reference subset (issue #221).

    The lowering mirrors the SHAPE of the C backend's expr/stmt walk (emit_expr_ctx /
    emit_stmt): the same recursion, a different result — instead of appending text to a
    buffer, each visit APPENDS LInsts to the current block and RETURNS the VReg that
    carries the value. Everything is functionally threaded (a fresh LFunc per step, no
    mutable module state), exactly like the rest of the compiler.

    Reference subset (N1): integer/float literals, arithmetic/unary, locals, `to`
    casts, direct calls (Teko-Teko + the `exit`/`panic` builtins), `let`, `return`,
    and expression statements. Everything else honest-stops with a NAMED error (M.1/
    M.3) — the scaffolding N2 fills in case-by-case without rewriting the walk.

    LEnv — the local map name -> VReg. The checker already resolved scope; the lowering
    only remembers "the var `x` lives in VReg N". Parallel slices threaded functionally,
    the same shape as the checker's Env. `len_vregs`/`has_len` are a PARALLEL fat-pointer
    side-table (A1-4, #382): a str/slice local additionally records its LENGTH VReg
    (`has_len[i]=true`), so a `.len` read off a bound name (not just a literal receiver)
    resolves with no memory traffic — mirrors §2.3's "no memory traffic for a length read". */
pub type LEnv = struct { names: []str; vregs: []u32; len_vregs: []u32; has_len: []bool }

/** empty_lenv — an LEnv with no bindings (a function body's seed). */
pub fn empty_lenv() -> LEnv {
    LEnv { names = teko::list::empty(); vregs = teko::list::empty(); len_vregs = teko::list::empty(); has_len = teko::list::empty() }
}

/** lenv_bind — extend `env` with (name -> vreg), a SCALAR (non-fat) binding. A later binding
    of the same name shadows the earlier one (lookup scans newest-first). */
pub fn lenv_bind(env: LEnv, name: str, vreg: u32) -> LEnv {
    LEnv {
        names = teko::list::push(env.names, name); vregs = teko::list::push(env.vregs, vreg)
        len_vregs = teko::list::push(env.len_vregs, 0); has_len = teko::list::push(env.has_len, false)
    }
}

/** lenv_bind_fat — extend `env` with (name -> ptr, len), a FAT (str/slice) binding
    (A1-4, #382). The ptr registers under the ordinary scalar lookup too (`lenv_lookup`
    still finds it), so a fat local used in a plain-value position keeps working unchanged. */
pub fn lenv_bind_fat(env: LEnv, name: str, ptr: u32, len: u32) -> LEnv {
    LEnv {
        names = teko::list::push(env.names, name); vregs = teko::list::push(env.vregs, ptr)
        len_vregs = teko::list::push(env.len_vregs, len); has_len = teko::list::push(env.has_len, true)
    }
}

/**
 * lenv_newest_index — the index of the NEWEST binding of `name` in `env`
 * (scanning newest-first, so a shadow's index wins), or `env.names.len` when
 * `name` is unbound. The shared index primitive for reassign-in-place
 * (`lenv_reassign`) and the merge machinery's pre-branch index capture
 * (`merge_scalar_indices`) (#389 F1b item 3).
 *
 * @param LEnv env  the env to scan
 * @param str name  the local name to locate
 * @return u64  the newest matching index, or `env.names.len` when unbound
 */
fn lenv_newest_index(env: LEnv, name: str) -> u64 {
    mut i: u64 = env.names.len
    loop {
        if i == 0 { break }
        i = i - 1
        if env.names[i] == name { return i }
    }
    env.names.len
}

/**
 * list_set_u32 — `xs` with the element at `idx` replaced by `v`, every other
 * element passed through unchanged; `xs` is returned untouched when `idx` is
 * out of range (a caller invariant break the reassign path never hits, since
 * the index comes from `lenv_newest_index`) (#389 F1b item 3).
 *
 * @param []u32 xs  the source list
 * @param u64 idx  the index to overwrite
 * @param u32 v  the replacement value
 * @return []u32  `xs` with position `idx` set to `v`
 */
fn list_set_u32(xs: []u32, idx: u64, v: u32) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= xs.len { break }
        if i == idx { out = teko::list::push(out, v) } else { out = teko::list::push(out, xs[i]) }
        i++
    }
    out
}

/**
 * lenv_reassign — rebind the NEWEST binding of `name` to `vreg`. For a SCALAR
 * (`!has_len`) newest binding this updates IN PLACE (the SSA-lite reassignment
 * update), preserving the slot's POSITION — so the binding keeps its
 * pre-branch INDEX and the merge machinery can read the enclosing scalar's
 * current value at that fixed index regardless of any shadow appended after it
 * (#389 F1b item 3). Behaviour-preserving for every `lenv_lookup`: the newest
 * `name` is still at its original index, now carrying `vreg`, so a name-keyed
 * newest-first read returns the SAME VReg it would after the old append — the
 * only difference is that no DUPLICATE `name` entry is left behind.
 *
 * For a FAT (`has_len`) newest binding, in-place update is WRONG: it would
 * overwrite the ptr VReg while PRESERVING the old `len_vregs`/`has_len` slot,
 * so a later fat use (`s.len`, or passing `s` on) would silently read the
 * STALE pre-reassignment length — a miscompile item-3's index-identity
 * threading never needed in the first place, since `reassigned_scalars`
 * already filters merge candidates to `!has_len` (a fat local is NEVER
 * threaded through a scalar merge, #389 F1b item 3 review). So a fat newest
 * binding instead falls back to the OLD append behavior (`lenv_bind`, a fresh
 * SCALAR entry with `has_len=false`): this restores the EXACT pre-item3
 * posture — `lenv_lookup_fat`'s newest-first scan hits that fresh scalar
 * entry first and reports `has_len=false`, so `lower_var_fat`/`lower_len_field`
 * honest-stop on the reassigned name exactly as they did before item-3,
 * refusing the program instead of silently returning a stale length.
 *
 * Also falls back to `lenv_bind` when `name` is unbound (a checker invariant
 * break — an assign to an undeclared local never reaches lowering).
 *
 * @param LEnv env  the env whose newest `name` binding is updated
 * @param str name  the reassigned local's name
 * @param u32 vreg  the reassignment's fresh result VReg
 * @return LEnv  `env` with the newest `name` slot updated in place (scalar) or
 *              a fresh scalar entry appended (fat or unbound)
 */
pub fn lenv_reassign(env: LEnv, name: str, vreg: u32) -> LEnv {
    let idx = lenv_newest_index(env, name)
    if idx == env.names.len { return lenv_bind(env, name, vreg) }
    if env.has_len[idx] { return lenv_bind(env, name, vreg) }
    LEnv { names = env.names; vregs = list_set_u32(env.vregs, idx, vreg); len_vregs = env.len_vregs; has_len = env.has_len }
}

/** LLookup — the result of an LEnv lookup: whether the name was bound + its VReg. */
pub type LLookup = struct { found: bool; vreg: u32 }

/** lenv_lookup — the VReg a local name binds to, scanning newest-first so a shadow wins. */
pub fn lenv_lookup(env: LEnv, name: str) -> LLookup {
    mut i = env.names.len
    loop {
        if i == 0 { break }
        i = i - 1
        if env.names[i] == name { return LLookup { found = true; vreg = env.vregs[i] } }
    }
    LLookup { found = false; vreg = 0 }
}

/** LFatLookup — the result of a FAT env lookup: whether the name was bound, whether that
    binding carries a length (`lenv_bind_fat` vs the plain `lenv_bind`), + its ptr/len VRegs
    (A1-4, #382). */
pub type LFatLookup = struct { found: bool; has_len: bool; ptr: u32; len: u32 }

/** lenv_lookup_fat — the (ptr, len) pair a local name binds to, scanning newest-first
    (A1-4, #382). `has_len=false` for a name bound via the plain scalar `lenv_bind` (an
    invariant break if a caller then reads it as fat). */
pub fn lenv_lookup_fat(env: LEnv, name: str) -> LFatLookup {
    mut i = env.names.len
    loop {
        if i == 0 { break }
        i = i - 1
        if env.names[i] == name { return LFatLookup { found = true; has_len = env.has_len[i]; ptr = env.vregs[i]; len = env.len_vregs[i] } }
    }
    LFatLookup { found = false; has_len = false; ptr = 0; len = 0 }
}

/** ltype_of — the machine class of a RESOLVED checker::Type: an integer/float by width,
    or Ptr for every other address-shaped type (str/slice/Ref/ptr/Named/Optional/Variant/
    Func/Byte — all EXERCISED from N2; `byte`'s own I8 mapping is deferred past A1-4, a
    seed-VM match quirk on `checker::Byte` misfires when the SUBJECT is a `Slice{element:
    Byte}` — see `prim_kind_of`'s doc for the narrower, SAFE fix this phase actually needs),
    or Void for the return-only marker. This is where the semantic type dies and the machine
    begins. */
pub fn ltype_of(t: checker::Type) -> LType {
    match t {
        checker::Prim as p => ltype_of_prim(p.kind)
        checker::Void => LType::Void
        _ => LType::Ptr
    }
}

/** ltype_of_prim — a PrimKind's machine class. Bool lowers to I8 (a single byte carrier,
    like the C backend's bool). */
fn ltype_of_prim(k: checker::PrimKind) -> LType {
    if k == checker::PrimKind::F16 { return LType::F16 }
    if k == checker::PrimKind::F32 { return LType::F32 }
    if k == checker::PrimKind::F64 { return LType::F64 }
    ltype_of_int_prim(k)
}

/** ltype_of_int_prim — the machine class of an INTEGER/bool PrimKind by width. Uses `==`
    chains, not a `match`: this module's LType shares the F16/F32/F64 member names with
    checker::PrimKind, and the released seed (0.0.1.9, before the #263 fix) mis-resolves a
    qualified enum PATTERN across the two enums — but `==` resolves the qualified constant
    correctly, so the equality form is the seed-safe spelling (issue #221 lowering-oracle
    bug, root-caused to #263 not being in the CI seed). */
fn ltype_of_int_prim(k: checker::PrimKind) -> LType {
    if prim_width_of(k) == 8 { return LType::I8 }
    if prim_width_of(k) == 16 { return LType::I16 }
    if prim_width_of(k) == 32 { return LType::I32 }
    if prim_width_of(k) == 128 { return LType::I128 }
    if k == checker::PrimKind::Bool { return LType::I8 }
    LType::I64
}

/** ltype_of_typeexpr — the machine class of a PARAMETER annotation (a syntactic
    parser::TypeExpr, since a TFunction carries no resolved Func). A single-segment
    primitive name maps by width; every other shape (compound path, slice, optional,
    union, function) collapses to Ptr — the N1 subset only declares scalar params, so
    Ptr never appears yet, but the mapping is total for the design-ahead contract. */
pub fn ltype_of_typeexpr(te: parser::TypeExpr) -> LType {
    match te {
        parser::NamedType as nt => ltype_of_named_path(nt.path)
        _ => LType::Ptr
    }
}

/** ltype_of_named_path — a single-segment primitive name -> its machine class; a
    multi-segment path or a non-primitive name -> Ptr. */
fn ltype_of_named_path(p: parser::Path) -> LType {
    if p.segments.len != 1 { return LType::Ptr }
    ltype_of_prim_name(p.segments[0].name)
}

/** ltype_of_prim_name — a primitive spelling -> its machine class, else Ptr. */
fn ltype_of_prim_name(name: str) -> LType {
    if name == "u8" { return LType::I8 }
    if name == "u16" { return LType::I16 }
    if name == "u32" { return LType::I32 }
    if name == "u64" { return LType::I64 }
    if name == "u128" { return LType::I128 }
    if name == "i8" { return LType::I8 }
    if name == "i16" { return LType::I16 }
    if name == "i32" { return LType::I32 }
    if name == "i64" { return LType::I64 }
    if name == "i128" { return LType::I128 }
    if name == "f16" { return LType::F16 }
    if name == "f32" { return LType::F32 }
    if name == "f64" { return LType::F64 }
    if name == "bool" { return LType::I8 }
    if name == "byte" { return LType::I8 }
    LType::Ptr
}

/** prim_is_signed_int — true for the signed integer prims (I8..I128); false for the
    unsigned ints, floats, and bool. Chooses the S-variant opcode. */
fn prim_is_signed_int(k: checker::PrimKind) -> bool {
    k == checker::PrimKind::I8 || k == checker::PrimKind::I16 || k == checker::PrimKind::I32 ||
    k == checker::PrimKind::I64 || k == checker::PrimKind::I128
}

/** prim_is_float_kind — true for the IEEE float prims (F16/F32/F64). Chooses the F-family
    opcode. Uses `==`, not a `match`: this module's LType enum shares the F16/F32/F64 member
    names with checker::PrimKind, and the released seed (0.0.1.9, before the #263 fix) mis-
    resolves a qualified enum PATTERN across the two same-named enums (matching by ordinal),
    silently classifying integers as floats. `==` resolves the qualified constant correctly,
    so the equality spelling is the seed-safe form (issue #221 lowering oracle). */
fn prim_is_float_kind(k: checker::PrimKind) -> bool {
    k == checker::PrimKind::F16 || k == checker::PrimKind::F32 || k == checker::PrimKind::F64
}

/** lbinop_of — the LBinOp for an arithmetic operator token given the RESULT's PrimKind.
    Float kinds pick the F-family; integers pick S/U by signedness. N1 emits only the
    arithmetic subset; a non-arithmetic operator honest-stops (comparisons/bitwise/shifts
    are declared in the enum for N2 but not lowered yet). */
pub fn lbinop_of(op: lexer::TokenKind, k: checker::PrimKind) -> LBinOp | error {
    if prim_is_float_kind(k) { return lbinop_float(op) }
    lbinop_int(op, prim_is_signed_int(k))
}

/** lbinop_float — the F-family LBinOp for an arithmetic operator token. */
fn lbinop_float(op: lexer::TokenKind) -> LBinOp | error {
    match op {
        lexer::TokenKind::Plus => LBinOp::FAdd
        lexer::TokenKind::Minus => LBinOp::FSub
        lexer::TokenKind::Star => LBinOp::FMul
        lexer::TokenKind::Slash => LBinOp::FDiv
        _ => error { message = "native backend N1: float operator not yet lowered (N2)" }
    }
}

/** lbinop_int — the integer LBinOp for an arithmetic operator token, S/U chosen by
    `signed`. */
fn lbinop_int(op: lexer::TokenKind, signed: bool) -> LBinOp | error {
    match op {
        lexer::TokenKind::Plus => LBinOp::IAdd
        lexer::TokenKind::Minus => LBinOp::ISub
        lexer::TokenKind::Star => LBinOp::IMul
        lexer::TokenKind::Slash => if signed { LBinOp::IDivS } else { LBinOp::IDivU }
        lexer::TokenKind::Percent => if signed { LBinOp::IRemS } else { LBinOp::IRemU }
        _ => error { message = "native backend N1: integer operator not yet lowered (N2)" }
    }
}

/**
 * lunop_of — the LUnOp for an ARITHMETIC prefix operator token given the operand's
 * PrimKind. `-` picks FNeg/INeg by kind. `!` (logical-not) is NOT handled here — it is
 * intercepted in lower_unary and lowered to a logical `operand == 0` (see
 * lower_logical_not), so mapping `!` to the bitwise LUnOp::INot (the F1c miscompile) is
 * gone. N1 does not lower `~`.
 *
 * @param lexer::TokenKind op  the prefix operator token
 * @param checker::PrimKind k  the operand's PrimKind (selects the float/int family for `-`)
 * @return LUnOp  the negation LUnOp for `-`
 * @throws  for any operator other than `-` (`!` is handled by lower_unary; `~` is N2)
 */
pub fn lunop_of(op: lexer::TokenKind, k: checker::PrimKind) -> LUnOp | error {
    match op {
        lexer::TokenKind::Minus => if prim_is_float_kind(k) { LUnOp::FNeg } else { LUnOp::INeg }
        _ => error { message = "native backend N1: unary operator not yet lowered (N2)" }
    }
}

/** cast_unop_of — the conversion LUnOp for a numeric `to` cast from `src` to `dst`
    machine classes. int->float = IToF, float->int = FToI, float->float = FToF, and
    int->int widens (SExt/ZExt by source signedness) or truncates (Trunc). A same-class
    int cast maps to Trunc (a harmless identity width); a same-class float cast to FToF. */
fn cast_unop_of(src: checker::PrimKind, dst: checker::PrimKind) -> LUnOp {
    let src_f = prim_is_float_kind(src)
    let dst_f = prim_is_float_kind(dst)
    if src_f && dst_f { return LUnOp::FToF }
    if src_f { return LUnOp::FToI }
    if dst_f { return LUnOp::IToF }
    cast_int_unop_of(src, dst)
}

/** cast_int_unop_of — the int->int conversion LUnOp: widen with sign/zero extend (by the
    SOURCE's signedness) or truncate to a narrower/equal width. Bool is excluded from casts
    by the checker (cast direction law), so a bool source here would be an invariant break
    — treated as unsigned (ZExt widens). */
fn cast_int_unop_of(src: checker::PrimKind, dst: checker::PrimKind) -> LUnOp {
    let sw = prim_width_of(src)
    let dw = prim_width_of(dst)
    if dw > sw { return if prim_is_signed_int(src) { LUnOp::SExt } else { LUnOp::ZExt } }
    LUnOp::Trunc
}

/** prim_width_of — the bit width of an integer/float PrimKind (bool = 1). Local copy of
    the width table (type.tks's is private to teko::checker). */
fn prim_width_of(k: checker::PrimKind) -> u32 {
    if k == checker::PrimKind::U8 || k == checker::PrimKind::I8 { return 8 }
    if k == checker::PrimKind::U16 || k == checker::PrimKind::I16 { return 16 }
    if k == checker::PrimKind::U32 || k == checker::PrimKind::I32 { return 32 }
    if k == checker::PrimKind::U64 || k == checker::PrimKind::I64 { return 64 }
    if k == checker::PrimKind::U128 || k == checker::PrimKind::I128 { return 128 }
    if k == checker::PrimKind::F16 { return 16 }
    if k == checker::PrimKind::F32 { return 32 }
    if k == checker::PrimKind::F64 { return 64 }
    1
}

/** mangle_fn_symbol — the LIR symbol for a Teko-Teko call target: the namespace with each
    `:` replaced by `_`, then `__`, then the C-keyword-escaped bare name — byte-identical to
    the C backend's cb_fn_name so the native and C paths name the same symbol. An empty
    namespace (a local/builtin) yields the bare (escaped) name. */
pub fn mangle_fn_symbol(ns: str, name: str) -> str {
    mut sym = ""
    if ns.len != 0 { sym = teko::str::concat(mangle_ns(ns), "__") }
    teko::str::concat(sym, escape_c_keyword(name))
}

/** mangle_ns — a namespace with every `:` byte rewritten to `_`. */
fn mangle_ns(ns: str) -> str {
    mut xs: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= ns.len { break }
        let ch = if ns[i] == b':' { b'_' } else { ns[i] }
        xs = teko::list::push(xs, ch)
        i++
    }
    str(xs)
}

/** escape_c_keyword — a bare identifier with a trailing `_` when it collides with a C
    keyword (mirrors codegen's cb_ident / cg_is_c_keyword so the symbol matches the C
    definition). */
fn escape_c_keyword(name: str) -> str {
    if is_c_keyword(name) { return teko::str::concat(name, "_") }
    name
}

/** is_c_keyword — the reserved C identifiers a mangled symbol must escape (the same set
    the C backend's cg_is_c_keyword guards). */
fn is_c_keyword(s: str) -> bool {
    s == "bool" || s == "int" || s == "char" || s == "short" || s == "long" ||
    s == "float" || s == "double" || s == "void" || s == "unsigned" || s == "signed" ||
    s == "const" || s == "volatile" || s == "register" || s == "auto" || s == "static" ||
    s == "struct" || s == "union" || s == "enum" || s == "return" || s == "default" ||
    s == "goto" || s == "break" || s == "continue" || s == "case" || s == "switch" ||
    s == "do" || s == "for" || s == "while" || s == "if" || s == "else" || s == "sizeof" ||
    s == "typedef" || s == "extern" || s == "inline" || s == "restrict"
}

/**
 * LEnumInfo — one declared `enum` type's name + its member spellings, in
 * declared order (the ORDINAL a bare/qualified enum-member match pattern tests
 * against is that member's INDEX in this list — mirrors the checker's own
 * `check_enum_pattern`/`enum_covered` convention, A1-5, #382).
 */
pub type LEnumInfo = struct { name: str; members: []str }

/**
 * LoopTargets — one active `loop`'s break/continue jump targets (A1-2,
 * #382): `head` is the block a `continue` jumps to (the loop body's own
 * entry), `exit` is the block a `break` jumps to (the block immediately
 * after the loop), `defer_base` is `ctx.defers.len` at the loop body's
 * entry (so a break/continue crossing this loop fires exactly the defers
 * registered INSIDE its own body, LIFO), and `names` is the ordered list
 * of SCALAR local names `promote_env` gave a block-arg on both `head` and
 * `exit` — the loop head/exit are both MERGE points (the entry edge and
 * every back/break edge flow into them), so a `break`/`continue` jump must
 * supply, in this SAME order, the CURRENT VReg of each — mirroring the
 * SAME block-arg merge principle an if-expression's result VReg already
 * uses (§2.4).
 */
pub type LoopTargets = struct { label: str; head: u32; exit: u32; defer_base: u64; names: []str }

/**
 * LowerCtx — the lowering state threaded through the expr/stmt walk: the
 * current LFunc being built + the id of the block instructions append to (N1
 * always block 0) + the local env (name -> VReg) so a TVar resolves to its
 * already-lowered value + the struct-layout table (A1-3, #382 — read-only for
 * the whole lowering of a program, so every copy just carries the SAME slice
 * forward) + the WHOLE-PROGRAM interned-rodata table (A1-4, #382 — grows as
 * string literals/interpolation pieces are found, so a fresh entry mid-function
 * is threaded forward like `func`, unlike the read-only `layouts`) + the
 * WHOLE-PROGRAM enum table (A1-5, #382 — read-only, like `layouts`, so a
 * `match` arm's bare enum-member pattern resolves its ordinal) + the
 * WHOLE-PROGRAM lifted-function table (A1-7, #382 — grows like `rodata`:
 * every closure/thunk LFunc a `TLambda`/`TVar.is_func` lowering builds is
 * folded in here first, then into the module's `funcs` ONCE, at the very end
 * of `lower_program` — its length also serves as the monotonic id counter a
 * fresh lifted symbol's name embeds) + the CURRENT FUNCTION'S pending-defer
 * stack (A1-2, #382 — every `defer { … }` reached so far, in program order;
 * append-only, reset per function/lambda body, fired in LIFO slices by
 * `replay_defers` at each scope exit) + the active loop-target stack (A1-2,
 * #382 — innermost loop last, so a `break`/`continue` resolves by scanning
 * from the end; reset per function/lambda body, since neither construct
 * crosses a function boundary).
 */
pub type LowerCtx = struct {
    func: LFunc; block_id: u32; env: LEnv
    layouts: []LStructLayout; rodata: []LRodata; enums: []LEnumInfo; lifted: []LFunc
    defers: []checker::TDeferStmt; loop_targets: []LoopTargets
}

/** Lowered — the result of lowering an expression: the updated context + the VReg the
    value lives in. */
pub type Lowered = struct { ctx: LowerCtx; vreg: u32 }

/** LowerStmtOut — the result of lowering a statement: the updated context (its env may be
    extended by a `let`) + whether the statement TERMINATED the block (a return), so the
    caller stops emitting into a closed block. */
pub type LowerStmtOut = struct { ctx: LowerCtx; terminated: bool }

/**
 * ctx_with — a copy of `ctx` with a new func/block_id/env, carrying its
 * (unchanged) layouts/enums tables + its (unchanged) rodata table forward.
 * Centralizes the fields every LowerCtx rebuild must not forget, so a future
 * field addition touches this ONE function instead of every construction site.
 * Use `ctx_with_rodata` when the rodata table itself grows (a string literal
 * was just interned).
 *
 * @param LowerCtx ctx  the context to rebuild (its layouts/rodata/enums carry
 *                      forward)
 * @param LFunc func  the new current function
 * @param u32 block_id  the new current block id
 * @param LEnv env  the new local env
 * @return LowerCtx  the rebuilt context
 */
fn ctx_with(ctx: LowerCtx, func: LFunc, block_id: u32, env: LEnv) -> LowerCtx {
    LowerCtx {
        func = func; block_id = block_id; env = env
        layouts = ctx.layouts; rodata = ctx.rodata; enums = ctx.enums; lifted = ctx.lifted
        defers = ctx.defers; loop_targets = ctx.loop_targets
    }
}

/**
 * ctx_with_rodata — a copy of `ctx` with its rodata table replaced by `rodata`
 * (everything else unchanged) — the one site a fresh interned entry threads
 * forward (A1-4, #382).
 *
 * @param LowerCtx ctx  the context to rebuild
 * @param []LRodata rodata  the grown rodata table
 * @return LowerCtx  the rebuilt context
 */
fn ctx_with_rodata(ctx: LowerCtx, rodata: []LRodata) -> LowerCtx {
    LowerCtx {
        func = ctx.func; block_id = ctx.block_id; env = ctx.env
        layouts = ctx.layouts; rodata = rodata; enums = ctx.enums; lifted = ctx.lifted
        defers = ctx.defers; loop_targets = ctx.loop_targets
    }
}

/**
 * ctx_with_lifted — a copy of `ctx` with its lifted-function table replaced
 * by `lifted` (everything else unchanged) — the one site a fresh closure/
 * thunk LFunc threads forward (A1-7, #382).
 *
 * @param LowerCtx ctx  the context to rebuild
 * @param []LFunc lifted  the grown lifted-function table
 * @return LowerCtx  the rebuilt context
 */
fn ctx_with_lifted(ctx: LowerCtx, lifted: []LFunc) -> LowerCtx {
    LowerCtx {
        func = ctx.func; block_id = ctx.block_id; env = ctx.env
        layouts = ctx.layouts; rodata = ctx.rodata; enums = ctx.enums; lifted = lifted
        defers = ctx.defers; loop_targets = ctx.loop_targets
    }
}

/**
 * ctx_with_defers — a copy of `ctx` with its pending-defer stack replaced by
 * `defers` (everything else unchanged) — the one site a fresh `TDeferStmt`
 * registration threads forward (A1-2, #382).
 *
 * @param LowerCtx ctx  the context to rebuild
 * @param []checker::TDeferStmt defers  the grown defer stack
 * @return LowerCtx  the rebuilt context
 */
fn ctx_with_defers(ctx: LowerCtx, defers: []checker::TDeferStmt) -> LowerCtx {
    LowerCtx {
        func = ctx.func; block_id = ctx.block_id; env = ctx.env
        layouts = ctx.layouts; rodata = ctx.rodata; enums = ctx.enums; lifted = ctx.lifted
        defers = defers; loop_targets = ctx.loop_targets
    }
}

/**
 * ctx_with_loops — a copy of `ctx` with its active loop-target stack
 * replaced by `loop_targets` (everything else unchanged) — the site a
 * `lower_loop` pushes/restores its own target (A1-2, #382).
 *
 * @param LowerCtx ctx  the context to rebuild
 * @param []LoopTargets loop_targets  the replacement loop-target stack
 * @return LowerCtx  the rebuilt context
 */
fn ctx_with_loops(ctx: LowerCtx, loop_targets: []LoopTargets) -> LowerCtx {
    LowerCtx {
        func = ctx.func; block_id = ctx.block_id; env = ctx.env
        layouts = ctx.layouts; rodata = ctx.rodata; enums = ctx.enums; lifted = ctx.lifted
        defers = ctx.defers; loop_targets = loop_targets
    }
}

/** ctx_alloc — reserve a fresh VReg in the current function, returning it + the advanced
    context. Centralizes the alloc-then-use pattern every value-producing node repeats. */
fn ctx_alloc(ctx: LowerCtx) -> Lowered {
    let fresh = alloc_vreg(ctx.func)
    Lowered { ctx = ctx_with(ctx, fresh.func, ctx.block_id, ctx.env); vreg = fresh.vreg }
}

/** ctx_append — append `inst` to the current block, returning the updated context. */
fn ctx_append(ctx: LowerCtx, inst: LInst) -> LowerCtx {
    ctx_with(ctx, append_inst(ctx.func, ctx.block_id, inst), ctx.block_id, ctx.env)
}

/** ctx_bind — extend the context's local env with (name -> vreg). */
fn ctx_bind(ctx: LowerCtx, name: str, vreg: u32) -> LowerCtx {
    ctx_with(ctx, ctx.func, ctx.block_id, lenv_bind(ctx.env, name, vreg))
}

/** ctx_bind_fat — extend the context's local env with (name -> ptr, len), a FAT (str/slice)
    binding (A1-4, #382). */
fn ctx_bind_fat(ctx: LowerCtx, name: str, ptr: u32, len: u32) -> LowerCtx {
    ctx_with(ctx, ctx.func, ctx.block_id, lenv_bind_fat(ctx.env, name, ptr, len))
}

/**
 * ctx_reassign — the `ctx_bind` mirror for a reassignment: update the newest
 * `name` binding's VReg IN PLACE (`lenv_reassign`) rather than appending a
 * shadow, so the enclosing scalar keeps its pre-branch index for the merge
 * machinery (#389 F1b item 3). The ONLY reassignment carrier — every other
 * bind site is a fresh lexical binding and stays on `ctx_bind`.
 *
 * @param LowerCtx ctx  the context whose local env is updated
 * @param str name  the reassigned local's name
 * @param u32 vreg  the reassignment's fresh result VReg
 * @return LowerCtx  the context with `name`'s newest binding rebound in place
 */
fn ctx_reassign(ctx: LowerCtx, name: str, vreg: u32) -> LowerCtx {
    ctx_with(ctx, ctx.func, ctx.block_id, lenv_reassign(ctx.env, name, vreg))
}

/** lower_expr — lower a typed expression to LIR, returning the VReg carrying its value.
    Mirrors emit_expr_ctx's dispatch over the subset; every out-of-subset node honest-stops
    with a NAMED error. */
pub fn lower_expr(ctx: LowerCtx, e: checker::TExpr) -> Lowered | error {
    match e.kind {
        checker::TNumber as n => lower_number(ctx, e, n)
        checker::TVar as v => lower_var(ctx, e, v)
        checker::TBinary as b => lower_binary(ctx, e, b)
        checker::TUnary as u => lower_unary(ctx, e, u)
        checker::TCast as c => lower_cast(ctx, e, c)
        checker::TCall as cl => lower_call(ctx, e, cl)
        checker::TCompare as cm => lower_compare(ctx, e, cm)
        checker::TIfExpr as f => lower_if_expr(ctx, e, f)
        checker::TStructInit as si => lower_struct_init(ctx, e, si)
        checker::TFieldAccess as fa => lower_field_access(ctx, e, fa)
        checker::TIndex as ix => lower_index(ctx, e, ix)
        checker::TArrayLit as al => lower_array_lit(ctx, e, al)
        checker::TByteLit as b => lower_byte_lit(ctx, e, b)
        checker::TCharLit as c => lower_char_lit(ctx, e, c)
        checker::TBoolLit as b => lower_bool_lit(ctx, e, b)
        checker::TNullLit as n => lower_null_lit(ctx, e, n)
        checker::TPathExpr as p => lower_path_expr(ctx, e, p)
        checker::TStrLit as s => lower_str_lit(ctx, e, s)
        checker::TInterp as ip => lower_interp(ctx, e, ip)
        checker::TInExpr as ine => lower_in_expr(ctx, e, ine)
        checker::TCoalesce as co => lower_coalesce(ctx, e, co)
        checker::TSafeFieldAccess as sfa => lower_safe_field_access(ctx, e, sfa)
        checker::TMatchExpr as mx => lower_match(ctx, e, mx)
        checker::TLambda as lam => lower_lambda(ctx, e, lam)
        _ => error { message = teko::str::concat("native backend N1: ", texpr_kind_name(e), " not yet lowered (N2)") }
    }
}

/** lower_number — an integer literal -> LConstInt, a float literal -> LConstFloat (carried
    as its exact IEEE bits). */
fn lower_number(ctx: LowerCtx, e: checker::TExpr, n: checker::TNumber) -> Lowered | error {
    let r = ctx_alloc(ctx)
    if n.is_float {
        let finst = const_float_inst(r.vreg, teko::f64_bits(n.fval), e.line, e.col)
        return Lowered { ctx = ctx_append(r.ctx, finst); vreg = r.vreg }
    }
    let inst = const_int_inst(r.vreg, n.value, e.line, e.col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/**
 * lower_var — a local variable reference -> the VReg it already lives in (no instruction; an
 * SSA-lite value IS the var). A bare fn-as-value (`is_func`) instead builds a closure literal
 * wrapping the referenced top-level function (A1-7, #382 — `lower_fn_value`). A name that is NOT a
 * local and NOT a function resolves to a module-level AGGREGATE const materialized in rodata
 * (`lower_program` interned its bytes up front, #594 crumb 6): the value is the address of that
 * rodata symbol (`LGlobalAddr`), exactly as a struct/slice value is its base address.
 *
 * @param ctx  the lowering context to append the reference's instructions into
 * @param e    the variable-reference expression (carries its source position)
 * @param v    the typed variable node (name + fn-as-value marker)
 * @return     the appended context plus the VReg the value lives in
 * @throws     when the name is neither a bound local, a fn value, nor an interned aggregate const
 */
fn lower_var(ctx: LowerCtx, e: checker::TExpr, v: checker::TVar) -> Lowered | error {
    if v.is_func { return lower_fn_value(ctx, e, v) }
    let hit = lenv_lookup(ctx.env, v.name)
    if hit.found { return Lowered { ctx = ctx; vreg = hit.vreg } }
    match find_const_rodata(ctx.rodata, v.name) {
        LRodata as r => lower_const_addr(ctx, r.symbol, e.line, e.col)
        null => error { message = teko::str::concat("native backend N1: unbound local `", v.name, "` (internal)") }
    }
}

/**
 * lower_const_addr — the address of a module-level aggregate const's rodata symbol as a Ptr VReg
 * (`%r = global_addr @<symbol>`), the value an aggregate-const reference lowers to (#594 crumb 6). A
 * struct/variant const's "value" is this base address (field access reads through it, exactly like a
 * `TStructInit`); a str/slice const collapses to this ptr in scalar position (its length arrives via
 * the fat path, `lower_const_fat`).
 *
 * @param ctx     the lowering context to append into
 * @param symbol  the const's already-interned rodata symbol
 * @param line    the reference's source line
 * @param col     the reference's source column
 * @return        the appended context plus the base-address VReg
 */
fn lower_const_addr(ctx: LowerCtx, symbol: str, line: u32, col: u32) -> Lowered {
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, global_addr_inst(r.vreg, symbol, line, col)); vreg = r.vreg }
}

/**
 * find_const_rodata — the rodata entry that materializes the module-level aggregate const named
 * `name`, or null when no such const was interned (`lower_program` interns each aggregate const under
 * the deterministic `const_rodata_symbol(name)` symbol, #594 crumb 6). The lookup keys on that
 * symbol, so it never collides with a string-literal `.Lstr<N>` entry.
 *
 * @param rodata  the module's interned-rodata table
 * @param name    the referenced const's name
 * @return        the matching LRodata entry, or null
 */
fn find_const_rodata(rodata: []LRodata, name: str) -> LRodata? {
    let sym = const_rodata_symbol(name)
    mut i: u64 = 0
    loop {
        if i >= rodata.len { break }
        if rodata[i].symbol == sym { return rodata[i] }
        i++
    }
    null
}

/** lower_binary — lower left then right, then emit the LBin chosen by the RESULT's
    PrimKind (S/U/F picked in lbinop_of). Out-of-subset operators honest-stop. */
fn lower_binary(ctx: LowerCtx, e: checker::TExpr, b: checker::TBinary) -> Lowered | error {
    let lo = match lower_expr(ctx, b.left) { Lowered as x => x; error as err => return err }
    let ro = match lower_expr(lo.ctx, b.right) { Lowered as x => x; error as err => return err }
    let k = match prim_kind_of(e.type) { checker::PrimKind as p => p; error as err => return err }
    let op = match lbinop_of(b.op, k) { LBinOp as o => o; error as err => return err }
    let r = ctx_alloc(ro.ctx)
    let inst = bin_inst(r.vreg, op, lo.vreg, ro.vreg, e.line, e.col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/**
 * lower_unary — lower a prefix-unary expression. `!` (logical-not) lowers to a
 * LOGICAL-not (`operand == 0`) via lower_logical_not; every other prefix operator
 * lowers the operand then emits the LUn chosen by the operand's PrimKind.
 *
 * @param LowerCtx ctx  the lowering context to append the expression's instructions into
 * @param checker::TExpr e  the unary expression (carries its source line/col and type)
 * @param checker::TUnary u  the unary node (the operator token and its operand)
 * @return Lowered  the appended context plus the VReg holding the unary's value
 * @throws  when the operand's type is out of the arithmetic subset, or the operator
 *          is a prefix form not yet lowered (N2)
 */
fn lower_unary(ctx: LowerCtx, e: checker::TExpr, u: checker::TUnary) -> Lowered | error {
    let ao = match lower_expr(ctx, u.operand) { Lowered as x => x; error as err => return err }
    if is_logical_not(u.op) { return lower_logical_not(ao, e.line, e.col) }
    let k = match prim_kind_of(u.operand.type) { checker::PrimKind as p => p; error as err => return err }
    let op = match lunop_of(u.op, k) { LUnOp as o => o; error as err => return err }
    let r = ctx_alloc(ao.ctx)
    let inst = un_inst(r.vreg, op, ao.vreg, e.line, e.col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/**
 * is_logical_not — is this prefix operator token the `!` (logical-not) operator?
 *
 * @param lexer::TokenKind op  the prefix operator token
 * @return bool  true only for `!` (Bang)
 */
fn is_logical_not(op: lexer::TokenKind) -> bool {
    match op { lexer::TokenKind::Bang => true; _ => false }
}

/**
 * lower_logical_not — emit a LOGICAL-not of an already-lowered operand: `operand == 0`
 * (a `const 0` plus an `ICmpEq`). `!` is bool-only in Teko (checker-enforced), so the
 * operand is always `0`/`1` and this yields the clean complement (`1==0 → 0`, `0==0 → 1`).
 * This is NOT a bitwise one's-complement (LUnOp::INot): `INot 1 = 0xFFFFFFFE` is still
 * nonzero, so a conditional branch (which tests nonzero) would take the then-arm for BOTH
 * `!true` and `!false` — the F1c miscompile this replaces. For a non-bool truthy int the
 * `==0` semantics remain the correct logical-not.
 *
 * @param Lowered ao  the already-lowered operand (its context and value VReg)
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return Lowered  the appended context plus the VReg holding the logical-not's `0`/`1`
 */
fn lower_logical_not(ao: Lowered, line: u32, col: u32) -> Lowered {
    let z = ctx_alloc(ao.ctx)
    let with_zero = ctx_append(z.ctx, const_int_inst(z.vreg, 0 to i128, line, col))
    let r = ctx_alloc(with_zero)
    let inst = bin_inst(r.vreg, LBinOp::ICmpEq, ao.vreg, z.vreg, line, col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/** lower_cast — a numeric `to` cast: lower the inner value, then emit the conversion LUn
    chosen by the src/dst machine classes. Only numeric casts are in the N1 subset; a cast
    to/from a non-primitive honest-stops. */
fn lower_cast(ctx: LowerCtx, e: checker::TExpr, c: checker::TCast) -> Lowered | error {
    let ao = match lower_expr(ctx, c.expr) { Lowered as x => x; error as err => return err }
    let src = match prim_kind_of(c.expr.type) { checker::PrimKind as p => p; error as err => return err }
    let dst = match prim_kind_of(e.type) { checker::PrimKind as p => p; error as err => return err }
    let r = ctx_alloc(ao.ctx)
    let inst = un_inst(r.vreg, cast_unop_of(src, dst), ao.vreg, e.line, e.col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/** prim_kind_of — the PrimKind of a resolved primitive type; `byte` maps to `U8` (A1-4,
    #382 — "byte AS u8", the same convention the checker's own `cast_kind` uses, so a
    `byte to <numeric>` cast picks the right sign/width family). Any other non-prim
    honest-stops (its node is out of the arithmetic subset). ONLY ever called on an
    operand's OWN type here (a cast/binary/unary/in-expr operand, never a container's
    element type) — safe against a seed-VM match quirk where `checker::Byte` as an arm
    misfires when the SUBJECT is instead `Slice{element: Byte}` (verified: a BARE `Byte`
    subject resolves correctly; do not widen this match's use to a container type). */
fn prim_kind_of(t: checker::Type) -> checker::PrimKind | error {
    match t {
        checker::Prim as p => p.kind
        checker::Byte => checker::PrimKind::U8
        _ => error { message = "native backend N1: non-primitive arithmetic operand not yet lowered (N2)" }
    }
}

/** cmp_lbinop_of — the LBinOp for a comparison token given the LEFT operand's PrimKind:
    float kinds pick the F-family; integers pick S/U by signedness (mirrors lbinop_of's
    family pick, but over the comparison mnemonics). A non-primitive operand (str, a Named
    type, ...) is out of the N1 subset — deferred to the phase that gives it a runtime value
    (fat pointers land in A1-4). */
fn cmp_lbinop_of(op: lexer::TokenKind, k: checker::PrimKind) -> LBinOp | error {
    if prim_is_float_kind(k) { return cmp_lbinop_float(op) }
    cmp_lbinop_int(op, prim_is_signed_int(k))
}

/** cmp_lbinop_float — the F-family LBinOp for a comparison token. */
fn cmp_lbinop_float(op: lexer::TokenKind) -> LBinOp | error {
    match op {
        lexer::TokenKind::EqEq => LBinOp::FCmpEq
        lexer::TokenKind::Ne => LBinOp::FCmpNe
        lexer::TokenKind::Lt => LBinOp::FCmpLt
        lexer::TokenKind::Le => LBinOp::FCmpLe
        lexer::TokenKind::Gt => LBinOp::FCmpGt
        lexer::TokenKind::Ge => LBinOp::FCmpGe
        _ => error { message = "native backend N1: comparison operator not yet lowered (N2)" }
    }
}

/** cmp_lbinop_int — the integer LBinOp for a comparison token; `==`/`!=` have no S/U split,
    the ordered comparisons (`<`/`<=`/`>`/`>=`) pick S/U by `signed`. */
fn cmp_lbinop_int(op: lexer::TokenKind, signed: bool) -> LBinOp | error {
    match op {
        lexer::TokenKind::EqEq => LBinOp::ICmpEq
        lexer::TokenKind::Ne => LBinOp::ICmpNe
        lexer::TokenKind::Lt => if signed { LBinOp::ICmpLtS } else { LBinOp::ICmpLtU }
        lexer::TokenKind::Le => if signed { LBinOp::ICmpLeS } else { LBinOp::ICmpLeU }
        lexer::TokenKind::Gt => if signed { LBinOp::ICmpGtS } else { LBinOp::ICmpGtU }
        lexer::TokenKind::Ge => if signed { LBinOp::ICmpGeS } else { LBinOp::ICmpGeU }
        _ => error { message = "native backend N1: comparison operator not yet lowered (N2)" }
    }
}

/** CmpChain — the outcome of lowering every ADJACENT term of a TCompare: the updated
    context + the bool VReg of each pairwise comparison (first-vs-rest[0], rest[0]-vs-
    rest[1], ...), in order. */
pub type CmpChain = struct { ctx: LowerCtx; bools: []u32 }

/** lower_compare_terms — lower each rest-operand once (never re-lowering a shared node),
    emitting the ICmp/FCmp opcode chosen by the LEFT operand's PrimKind for each adjacent
    pair. */
fn lower_compare_terms(ctx: LowerCtx, e: checker::TExpr, prev_type: checker::Type, prev_vreg: u32, rest: []checker::TCmpTerm) -> CmpChain | error {
    mut cur = ctx
    mut pv = prev_vreg
    mut pt = prev_type
    mut bools: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= rest.len { break }
        let term = rest[i]
        let ro = match lower_expr(cur, term.operand) { Lowered as x => x; error as err => return err }
        let k = match prim_kind_of(pt) { checker::PrimKind as p => p; error as err => return err }
        let op = match cmp_lbinop_of(term.op, k) { LBinOp as o => o; error as err => return err }
        let r = ctx_alloc(ro.ctx)
        cur = ctx_append(r.ctx, bin_inst(r.vreg, op, pv, ro.vreg, e.line, e.col))
        bools = teko::list::push(bools, r.vreg)
        pv = ro.vreg
        pt = term.operand.type
        i++
    }
    CmpChain { ctx = cur; bools = bools }
}

/** lower_bool_and — short-circuit `a && b` over two ALREADY-lowered bool VRegs, via a
    branch + merge block-arg (no bitwise op needed): if `a` is false the merge takes 0
    directly; otherwise it takes `b`'s value. ANDs a TCompare's adjacent-term results
    (`a<b<c` -> `(a<b) && (b<c)`), reusing the same block infra if-expr lowering builds. */
fn lower_bool_and(ctx: LowerCtx, a_vreg: u32, b_vreg: u32, line: u32, col: u32) -> Lowered {
    let thenb = alloc_block(ctx.func)
    let elseb = alloc_block(thenb.func)
    let mergeb = alloc_block(elseb.func)
    let mp = add_block_param(mergeb.func, mergeb.block_id)
    let br = branch_inst(a_vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), line, col)
    let after_br = append_inst(mp.func, ctx.block_id, br)
    let then_args = teko::list::push(teko::list::empty(), b_vreg)
    let after_then = append_inst(after_br, thenb.block_id, jump_inst(mergeb.block_id, then_args, line, col))
    let zc = alloc_vreg(after_then)
    let with_zero = append_inst(zc.func, elseb.block_id, const_int_inst(zc.vreg, 0 to i128, line, col))
    let else_args = teko::list::push(teko::list::empty(), zc.vreg)
    let after_else = append_inst(with_zero, elseb.block_id, jump_inst(mergeb.block_id, else_args, line, col))
    Lowered { ctx = ctx_with(ctx, after_else, mergeb.block_id, ctx.env); vreg = mp.vreg }
}

/** lower_compare — a TCompare (`first` + `rest` chain) -> the chain of ICmp/FCmp opcodes,
    ANDed together. A lone subject (no `rest`) is degenerate: its own value is already the
    bool result (mirrors emit_compare's C twin). */
fn lower_compare(ctx: LowerCtx, e: checker::TExpr, cmp: checker::TCompare) -> Lowered | error {
    let lo = match lower_expr(ctx, cmp.first) { Lowered as x => x; error as err => return err }
    if cmp.rest.len == 0 { return Lowered { ctx = lo.ctx; vreg = lo.vreg } }
    let chain = match lower_compare_terms(lo.ctx, e, cmp.first.type, lo.vreg, cmp.rest) { CmpChain as c => c; error as err => return err }
    mut cur = chain.ctx
    mut acc = chain.bools[0]
    mut i: u64 = 1
    loop {
        if i >= chain.bools.len { break }
        let merged = lower_bool_and(cur, acc, chain.bools[i], e.line, e.col)
        cur = merged.ctx
        acc = merged.vreg
        i++
    }
    Lowered { ctx = cur; vreg = acc }
}

/**
 * lower_call — a direct, interface-dispatch, or closure call. The `exit`/
 * `panic` builtins and the `print`/`println`/`eprint`/`eprintln`/`write`/
 * `ewrite` io builtins map to their runtime symbols (tk_exit / tk_panic_str /
 * tk_print / …), matching the C backend; a Teko-Teko call resolves its
 * symbol through the shared mangler (call_ns::name). A DYNAMIC
 * contract-method call (`is_iface_dispatch`) routes to `lower_iface_call`
 * (A1-6, #382); a call through a local closure VALUE (`is_closure_call`)
 * routes to `lower_closure_call` (A1-7, #382). A resolved symbol taking its
 * lone argument as a runtime `tk_str` (the C1-6 io/panic group,
 * `is_str_arg_builtin`) routes to `lower_str_arg_call`, which lowers that ONE
 * argument through the (ptr, len) FAT pair (`lower_fat_expr`) instead of the
 * generic left-to-right scalar path — every other call lowers its arguments
 * plainly (`lower_args`) and emits through `lower_call_symbol`.
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExpr e  the call expression (for its type + source
 *                          position)
 * @param checker::TCall c  the call node
 * @return Lowered | error  the advanced context + the call's result VReg (0
 *                          for a void call), or a NAMED internal error when
 *                          the node is malformed
 */
fn lower_call(ctx: LowerCtx, e: checker::TExpr, c: checker::TCall) -> Lowered | error {
    if c.is_closure_call { return lower_closure_call(ctx, e, c) }
    if c.is_iface_dispatch { return lower_iface_call(ctx, e, c) }
    let sym = match call_symbol(c) { str as s => s; error as err => return err }
    if is_str_arg_builtin(sym) { return lower_str_arg_call(ctx, e, sym, c) }
    let lo = match lower_args(ctx, c.args) { LoweredArgs as x => x; error as err => return err }
    lower_call_symbol(lo.ctx, e, sym, lo.vregs)
}

/**
 * is_str_arg_builtin — does the resolved runtime symbol `sym` take its LONE
 * argument as a `tk_str` (a 2-eightbyte `{ptr; len}` struct passed BY VALUE,
 * `teko_rt.h:45-48`)? These seven — the io group (`tk_print`/`tk_println`/
 * `tk_eprint`/`tk_eprintln`/`tk_write`/`tk_ewrite`) plus `tk_panic_str` — are
 * every `(tk_str) -> void`/`_Noreturn` runtime entry the N1 builtin table
 * resolves DIRECTLY (`call_symbol`), as opposed to `tk_str_concat`/
 * `tk_i64_to_str`/… which `lower_interp` calls by a hardcoded symbol and
 * which stay on the plain scalar path (their own multi-register/return-value
 * ABI is the SEPARATE, wider N2 gap `lower_fat_expr`'s own doc names —
 * REPORTED up, not this crumb's scope). A lone struct-by-value argument
 * decomposes to EXACTLY two consecutive AAPCS64/SysV general registers, so
 * passing (ptr, len) as two flat `LCall` operands reproduces the true C ABI
 * with NO isel/regalloc/stackify change (`lower_str_arg_call`).
 *
 * @param str sym  the resolved runtime symbol (`call_symbol`'s result)
 * @return bool  true iff `sym` is one of the seven single-`tk_str`-arg
 *               runtime entries
 */
fn is_str_arg_builtin(sym: str) -> bool {
    sym == "tk_print" || sym == "tk_println" || sym == "tk_eprint" || sym == "tk_eprintln" || sym == "tk_write" || sym == "tk_ewrite" || sym == "tk_panic_str"
}

/**
 * lower_str_arg_call — lower a call to a single-`tk_str`-argument runtime
 * builtin (`is_str_arg_builtin`): the ONE argument through `lower_fat_expr`
 * (its (ptr, len) pair, the A1-4 fat-pointer PRODUCER set — a literal, an
 * array literal, or a `let`-bound fat local), emitted as a two-operand void
 * `LCall` (`ptr` then `len`, matching `tk_str`'s field order). A call whose
 * argument is not one of those closed producers (e.g. an interpolation or
 * another call's result) propagates `lower_fat_expr`'s own NAMED N2
 * honest-stop unchanged — never a fabricated/garbage-ABI call.
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExpr e  the call expression (its source position)
 * @param str sym  the resolved runtime symbol (`is_str_arg_builtin` true)
 * @param checker::TCall c  the call node (its single argument)
 * @return Lowered | error  the advanced context + a dummy 0 VReg (every
 *                          `is_str_arg_builtin` target is void/`_Noreturn`),
 *                          or a NAMED internal/N2 honest-stop
 */
fn lower_str_arg_call(ctx: LowerCtx, e: checker::TExpr, sym: str, c: checker::TCall) -> Lowered | error {
    if c.args.len != 1 {
        return error { message = teko::str::concat("native backend N1: `", sym, "` expects exactly one str argument (internal)") }
    }
    let fo = match lower_fat_expr(ctx, c.args[0]) { LoweredFat as x => x; error as err => return err }
    let inst = void_call_inst(sym, two_args(fo.ptr, fo.len), false, e.line, e.col)
    Lowered { ctx = ctx_append(fo.ctx, inst); vreg = 0 }
}

/** LoweredArgs — the context after lowering an argument list + the VRegs, in order. */
pub type LoweredArgs = struct { ctx: LowerCtx; vregs: []u32 }

/**
 * lower_args — lower every argument expression left-to-right, collecting
 * each one's VReg.
 *
 * @param LowerCtx ctx  the lowering context
 * @param []checker::TExpr args  the argument list to lower
 * @return LoweredArgs | error  the advanced context + the lowered VRegs, in
 *                              order
 */
fn lower_args(ctx: LowerCtx, args: []checker::TExpr) -> LoweredArgs | error {
    lower_args_from(ctx, args, 0)
}

/**
 * lower_args_from — lower `args[start..]` left-to-right, collecting each
 * one's VReg (A1-6, #382 — `lower_args` is the `start=0` case; the
 * interface-dispatch path additionally needs the TAIL of an arg list, the
 * receiver at index 0 having already been lowered separately).
 *
 * @param LowerCtx ctx  the lowering context
 * @param []checker::TExpr args  the full argument list
 * @param u64 start  the first index to lower (0 lowers every argument)
 * @return LoweredArgs | error  the advanced context + the lowered VRegs, in
 *                              order
 */
fn lower_args_from(ctx: LowerCtx, args: []checker::TExpr, start: u64) -> LoweredArgs | error {
    mut cur = ctx
    mut vregs: []u32 = teko::list::empty()
    mut i: u64 = start
    loop {
        if i >= args.len { break }
        let ao = match lower_expr(cur, args[i]) { Lowered as x => x; error as err => return err }
        cur = ao.ctx
        vregs = teko::list::push(vregs, ao.vreg)
        i++
    }
    LoweredArgs { ctx = cur; vregs = vregs }
}

/** lower_call_symbol — emit the LCall for an ALREADY-RESOLVED symbol over an
    already-lowered argument list. A void-returning call (a diverging builtin or a void fn)
    emits a valueless instruction and returns a dummy VReg the caller must not read; a value
    call allocates a result VReg. */
fn lower_call_symbol(ctx: LowerCtx, e: checker::TExpr, sym: str, vregs: []u32) -> Lowered | error {
    if type_is_void(e.type) {
        let inst = void_call_inst(sym, vregs, false, e.line, e.col)
        return Lowered { ctx = ctx_append(ctx, inst); vreg = 0 }
    }
    let r = ctx_alloc(ctx)
    let inst = call_inst(r.vreg, sym, vregs, false, e.line, e.col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/** type_is_void — is `t` the Void marker (no value)? Shared by call lowering (a void call
    emits a valueless instruction) and if-expression lowering (a Void-typed `if` is really an
    if-STATEMENT — its merge carries zero block-args). */
fn type_is_void(t: checker::Type) -> bool {
    match t { checker::Void => true; _ => false }
}

/** call_symbol — the LIR symbol a direct call targets: `exit`/`panic` and the io group
    (`print`/`println`/`eprint`/`eprintln`/`write`/`ewrite`) -> their runtime twins, mirroring
    the C backend's own bare-name builtin dispatch (`codegen.tks:2289-2297`); a Teko-Teko call
    -> the mangled call_ns::name. A call the N1 subset does not recognize (a builtin other
    than this set) honest-stops. */
fn call_symbol(c: checker::TCall) -> str | error {
    let segs = c.callee.segments
    if segs.len == 0 { return error { message = "native backend N1: empty call path (internal)" } }
    let last = segs[segs.len - 1].name
    let addressable = (segs.len == 1) || (segs[0].name == "teko")
    if addressable && last == "exit" { return "tk_exit" }
    if addressable && last == "panic" { return "tk_panic_str" }
    if addressable && last == "print" { return "tk_print" }
    if addressable && last == "println" { return "tk_println" }
    if addressable && last == "eprint" { return "tk_eprint" }
    if addressable && last == "eprintln" { return "tk_eprintln" }
    if addressable && last == "write" { return "tk_write" }
    if addressable && last == "ewrite" { return "tk_ewrite" }
    if c.call_ns.len == 0 && segs.len == 1 {
        return error { message = teko::str::concat("native backend N1: builtin `", last, "` not yet lowered (N2)") }
    }
    mangle_fn_symbol(c.call_ns, last)
}

/**
 * IfaceFatPtr — the two loaded halves of an interface receiver's fat
 * pointer (§5.3: `{data@0, vtable@8}`): its object-data VReg (field 0, the
 * value a dispatched method call rides as its own receiver arg) and its
 * vtable-base VReg (field 1, the address `lower_iface_slot` indexes).
 *
 * @since #382 A1-6
 */
pub type IfaceFatPtr = struct { ctx: LowerCtx; data: u32; vtable: u32 }

/**
 * lower_iface_fatptr — load both halves of an interface receiver's fat
 * pointer at address `base`: the object-data pointer (offset 0) and the
 * vtable-base pointer (offset `ptr-size`) — mirrors the C backend's
 * `{ .data = …, .vtable = tk_vt_<Class>_<Iface> }` layout (`codegen.tks:
 * 4088-4116`) (A1-6, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param u32 base  the receiver's fat-pointer address (a Ptr VReg)
 * @param u32 line  the source line (propagated onto the emitted insts)
 * @param u32 col  the source column (propagated onto the emitted insts)
 * @return IfaceFatPtr  the advanced context + the loaded data/vtable VRegs
 */
fn lower_iface_fatptr(ctx: LowerCtx, base: u32, line: u32, col: u32) -> IfaceFatPtr {
    let ptr_size = ltype_size(LType::Ptr)
    let data_addr = ctx_alloc(ctx)
    let with_data_addr = ctx_append(data_addr.ctx, field_addr_inst(data_addr.vreg, base, 0, line, col))
    let data = ctx_alloc(with_data_addr)
    let with_data = ctx_append(data.ctx, load_inst(data.vreg, data_addr.vreg, LType::Ptr, line, col))
    let vt_addr = ctx_alloc(with_data)
    let with_vt_addr = ctx_append(vt_addr.ctx, field_addr_inst(vt_addr.vreg, base, ptr_size, line, col))
    let vt = ctx_alloc(with_vt_addr)
    let with_vt = ctx_append(vt.ctx, load_inst(vt.vreg, vt_addr.vreg, LType::Ptr, line, col))
    IfaceFatPtr { ctx = with_vt; data = data.vreg; vtable = vt.vreg }
}

/**
 * lower_iface_slot — load the target function address out of `vtable`'s
 * slot `slot`: `field_addr` at byte offset `slot * ptr-size`, then `load.ptr`
 * — mirrors the C backend's `value.vtable[slot]` (`codegen.tks:2098-2100`)
 * (A1-6, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param u32 vtable  the vtable-base VReg (`lower_iface_fatptr`'s result)
 * @param u32 slot  the method's vtable slot (`TCall.iface_slot`)
 * @param u32 line  the source line (propagated onto the emitted insts)
 * @param u32 col  the source column (propagated onto the emitted insts)
 * @return Lowered  the advanced context + the loaded target-function VReg
 */
fn lower_iface_slot(ctx: LowerCtx, vtable: u32, slot: u32, line: u32, col: u32) -> Lowered {
    let ptr_size = ltype_size(LType::Ptr)
    let slot_addr = ctx_alloc(ctx)
    let with_slot_addr = ctx_append(slot_addr.ctx, field_addr_inst(slot_addr.vreg, vtable, slot * ptr_size, line, col))
    let target = ctx_alloc(with_slot_addr)
    Lowered { ctx = ctx_append(target.ctx, load_inst(target.vreg, slot_addr.vreg, LType::Ptr, line, col)); vreg = target.vreg }
}

/**
 * iface_call_args — the indirect-call argument list: `data` prepended to
 * `rest`, in order — mirrors the C backend's `value.data, args…`
 * (`codegen.tks:2101-2109`).
 *
 * @param u32 data  the receiver's object-data VReg (goes first)
 * @param []u32 rest  the remaining (already-lowered) argument VRegs
 * @return []u32  `data` followed by `rest`, in order
 *
 * @since #382 A1-6
 */
fn iface_call_args(data: u32, rest: []u32) -> []u32 {
    mut out: []u32 = teko::list::push(teko::list::empty(), data)
    mut i: u64 = 0
    loop {
        if i >= rest.len { break }
        out = teko::list::push(out, rest[i])
        i++
    }
    out
}

/**
 * lower_call_indirect — emit the `LCallIndirect` for a resolved target +
 * argument list. A void-returning call emits a valueless instruction and
 * returns a dummy VReg the caller must not read; a value call allocates a
 * result VReg (mirrors `lower_call_symbol`).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExpr e  the call expression (for its type + source
 *                          position)
 * @param u32 target  the VReg holding the resolved callee's address
 * @param []u32 args  the (already-lowered) argument VRegs, in order
 * @return Lowered | error  the advanced context + the call's result VReg (0
 *                          for a void call)
 *
 * @since #382 A1-6
 */
fn lower_call_indirect(ctx: LowerCtx, e: checker::TExpr, target: u32, args: []u32) -> Lowered | error {
    if type_is_void(e.type) {
        let inst = void_call_indirect_inst(target, args, false, e.line, e.col)
        return Lowered { ctx = ctx_append(ctx, inst); vreg = 0 }
    }
    let r = ctx_alloc(ctx)
    let inst = call_indirect_inst(r.vreg, target, args, false, e.line, e.col)
    Lowered { ctx = ctx_append(r.ctx, inst); vreg = r.vreg }
}

/**
 * lower_iface_call — a DYNAMIC contract-method call
 * (`TCall.is_iface_dispatch`): the receiver (`c.args[0]`) is an interface
 * fat pointer `{data@0, vtable@8}` (§5.3) — load both halves, index the
 * vtable at `c.iface_slot` to fetch the target function address, then call
 * THROUGH it with `data` prepended to the remaining (already-lowered)
 * arguments — mirrors the C backend's `value.vtable[slot](value.data,
 * args…)` (`codegen.tks:2058-2118`).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExpr e  the call expression (for its type + source
 *                          position)
 * @param checker::TCall c  the interface-dispatch call node (`args[0]` is
 *                          the receiver)
 * @return Lowered | error  the advanced context + the call's result VReg (0
 *                          for a void call), or a NAMED internal error when
 *                          the node is malformed
 *
 * @since #382 A1-6
 */
fn lower_iface_call(ctx: LowerCtx, e: checker::TExpr, c: checker::TCall) -> Lowered | error {
    if c.args.len == 0 { return error { message = "native backend N1: malformed interface-dispatch call (internal)" } }
    let ro = match lower_expr(ctx, c.args[0]) { Lowered as x => x; error as err => return err }
    let fp = lower_iface_fatptr(ro.ctx, ro.vreg, e.line, e.col)
    let tgt = lower_iface_slot(fp.ctx, fp.vtable, c.iface_slot, e.line, e.col)
    let rest = match lower_args_from(tgt.ctx, c.args, 1) { LoweredArgs as x => x; error as err => return err }
    lower_call_indirect(rest.ctx, e, tgt.vreg, iface_call_args(fp.data, rest.vregs))
}

/**
 * func_type_of — extract the resolved `Func` signature from a checker type,
 * or a NAMED internal error for any other shape (the checker guarantees a
 * bare `is_func` reference's own type IS its declaring function's `Func`
 * type — a miss here is an invariant break, A1-7 #382).
 *
 * @param checker::Type t  the type to narrow
 * @return checker::Func | error  the resolved signature
 */
fn func_type_of(t: checker::Type) -> checker::Func | error {
    match t {
        checker::Func as f => f
        _ => error { message = "native backend N1: function-value reference is not Func-typed (internal)" }
    }
}

/**
 * types_to_ltypes — the machine class of each resolved checker type, in
 * order (A1-7, #382 — a closure/thunk signature's parameter machine
 * classes).
 *
 * @param []checker::Type ts  the resolved types to map
 * @return []LType  their machine classes, in order
 */
fn types_to_ltypes(ts: []checker::Type) -> []LType {
    mut out: []LType = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= ts.len { break }
        out = teko::list::push(out, ltype_of(ts[i]))
        i++
    }
    out
}

/**
 * ltype_is_void — is `t` the Void machine class (no value)? (A1-7, #382 — a
 * closure/thunk with a void return skips the result-carrying `ret`.)
 *
 * @param LType t  the machine class to test
 * @return bool  true for `LType::Void`
 */
fn ltype_is_void(t: LType) -> bool {
    match t { Void => true; _ => false }
}

/**
 * env_first_param_types — `Ptr` (the closure's env slot) prepended to
 * `rest` — the ENV-FIRST ABI every lifted closure/thunk `LFunc` shares
 * (A1-7, #382): `LCallIndirect` always passes the closure's env as the
 * first argument, so every callable a closure literal's `fn` field may
 * point to must accept it, whether or not it actually captures anything.
 *
 * @param []LType rest  the callable's OWN declared parameter machine
 *                       classes
 * @return []LType  `Ptr` followed by `rest`, in order
 */
fn env_first_param_types(rest: []LType) -> []LType {
    mut out: []LType = teko::list::push(teko::list::empty(), LType::Ptr)
    mut i: u64 = 0
    loop {
        if i >= rest.len { break }
        out = teko::list::push(out, rest[i])
        i++
    }
    out
}

/**
 * lift_thunk_symbol — the deterministic symbol for the Nth fn-as-value
 * thunk — an assembler-local-style name (`.Lclofn<N>`) that never collides
 * with a Teko-visible symbol (mirrors `rodata_symbol`, A1-7 #382).
 *
 * @param u64 id  the thunk's reserved id (`ctx.lifted.len` at the time it
 *                was reserved)
 * @return str  the thunk's symbol
 */
fn lift_thunk_symbol(id: u64) -> str {
    teko::str::concat(".Lclofn", teko::u64_to_str(id))
}

/**
 * lift_lambda_symbol — the deterministic symbol for the Nth lifted lambda
 * body — an assembler-local-style name (`.Lclo<N>`) that never collides
 * with a Teko-visible symbol (mirrors `rodata_symbol`, A1-7 #382).
 *
 * @param u64 id  the lambda's reserved id
 * @return str  the lifted body's symbol
 */
fn lift_lambda_symbol(id: u64) -> str {
    teko::str::concat(".Lclo", teko::u64_to_str(id))
}

/**
 * materialize_thunk_params — append a `param` instruction for every one of
 * `f0`'s already-declared parameters (env at index 0, the wrapped
 * function's own parameters after it), in order (A1-7, #382).
 *
 * @param LFunc f0  the thunk's (still bodyless) function shell
 * @param u32 line  the source line to propagate onto each `param`
 * @param u32 col  the source column to propagate onto each `param`
 * @return LFunc  `f0` with every parameter materialized into its VReg
 */
fn materialize_thunk_params(f0: LFunc, line: u32, col: u32) -> LFunc {
    mut f = f0
    mut i: u64 = 0
    loop {
        if i >= f.n_params to u64 { break }
        f = append_inst(f, 0, param_inst(i to u32, i to u32, line, col))
        i++
    }
    f
}

/**
 * thunk_forward_args — the VRegs `1..n` (skipping VReg 0, the ignored env
 * parameter) — the argument list a thunk forwards to the wrapped function
 * (A1-7, #382).
 *
 * @param u64 n  the wrapped function's own arity
 * @return []u32  the VRegs `1..n`, in order
 */
fn thunk_forward_args(n: u64) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= n { break }
        out = teko::list::push(out, (i + 1) to u32)
        i++
    }
    out
}

/**
 * build_closure_thunk — an ENV-FIRST wrapper `LFunc` around `target_sym`: it
 * accepts the env-first ABI (`env_first_param_types`), ignores the env
 * parameter, and forwards its own remaining parameters straight through to
 * `target_sym` — the bridge a bare top-level function needs to be called
 * uniformly through `LCallIndirect` alongside a genuinely capturing lambda
 * (A1-7, #382).
 *
 * @param str symbol  the thunk's own (lifted) symbol
 * @param str target_sym  the wrapped function's already-mangled symbol
 * @param []LType ptypes  the wrapped function's OWN parameter machine
 *                        classes
 * @param LType ret_ty  the wrapped function's return machine class
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return LFunc  the built thunk
 */
fn build_closure_thunk(symbol: str, target_sym: str, ptypes: []LType, ret_ty: LType, line: u32, col: u32) -> LFunc {
    let all_ptypes = env_first_param_types(ptypes)
    let f0 = new_func(symbol, (ptypes.len + 1) to u32, all_ptypes, ret_ty)
    let f1 = materialize_thunk_params(f0, line, col)
    let args = thunk_forward_args(ptypes.len)
    if ltype_is_void(ret_ty) {
        let f2 = append_inst(f1, 0, void_call_inst(target_sym, args, false, line, col))
        return append_inst(f2, 0, ret_void_inst(line, col))
    }
    let r = alloc_vreg(f1)
    let f2 = append_inst(r.func, 0, call_inst(r.vreg, target_sym, args, false, line, col))
    append_inst(f2, 0, ret_inst(r.vreg, line, col))
}

/**
 * build_closure_literal — a closure VALUE `{fn@0, env@8}` (§5.3): alloca a
 * 16-byte slot, store `fn_symbol`'s `LFuncAddr` VReg at offset 0 and
 * `env_vreg` at offset 8 — the RESULT is the slot's base address (a Ptr
 * VReg), the same memory shape `lower_closure_fatptr` reads back (A1-7,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param str fn_symbol  the callable's (already-mangled or lifted) symbol
 * @param u32 env_vreg  the closure's env VReg (a null-Ptr const when it
 *                       captures nothing)
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return Lowered  the advanced context + the closure struct's base address
 */
fn build_closure_literal(ctx: LowerCtx, fn_symbol: str, env_vreg: u32, line: u32, col: u32) -> Lowered {
    let ptr_size = ltype_size(LType::Ptr)
    let fnaddr = ctx_alloc(ctx)
    let with_fnaddr = ctx_append(fnaddr.ctx, func_addr_inst(fnaddr.vreg, fn_symbol, line, col))
    let base = ctx_alloc(with_fnaddr)
    let with_alloca = ctx_append(base.ctx, alloca_inst(base.vreg, ptr_size * 2, ptr_size, line, col))
    let fslot = ctx_alloc(with_alloca)
    let with_fslot_addr = ctx_append(fslot.ctx, field_addr_inst(fslot.vreg, base.vreg, 0, line, col))
    let with_fn_store = ctx_append(with_fslot_addr, store_inst(fslot.vreg, fnaddr.vreg, LType::Ptr, line, col))
    let eslot = ctx_alloc(with_fn_store)
    let with_eslot_addr = ctx_append(eslot.ctx, field_addr_inst(eslot.vreg, base.vreg, ptr_size, line, col))
    let with_env_store = ctx_append(with_eslot_addr, store_inst(eslot.vreg, env_vreg, LType::Ptr, line, col))
    Lowered { ctx = with_env_store; vreg = base.vreg }
}

/**
 * lower_fn_value — a bare top-level function used as a VALUE
 * (`TVar.is_func`): lift an env-first THUNK wrapping it
 * (`build_closure_thunk`) so it can be called uniformly through
 * `LCallIndirect` alongside a genuinely capturing lambda, then build the
 * closure literal `{fn=thunk, env=null}` — mirrors the C backend's
 * `(tk_closure){ &<fn>, (void*)0 }` (`codegen.tks:5093-5096`), substituting
 * the thunk for the raw function address so the ABI stays uniform (A1-7,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExpr e  the var expression (its type is the referenced
 *                          function's `Func` signature)
 * @param checker::TVar v  the fn-as-value var node
 * @return Lowered | error  the advanced context + the closure literal's base
 *                          address, or a NAMED internal error
 */
fn lower_fn_value(ctx: LowerCtx, e: checker::TExpr, v: checker::TVar) -> Lowered | error {
    let sig = match func_type_of(e.type) { checker::Func as f => f; error as err => return err }
    let target_sym = mangle_fn_symbol(v.func_ns, v.name)
    let ptypes = types_to_ltypes(sig.params)
    let ret_ty = ltype_of(sig.ret)
    let id = ctx.lifted.len
    let thunk_sym = lift_thunk_symbol(id)
    let thunk = build_closure_thunk(thunk_sym, target_sym, ptypes, ret_ty, e.line, e.col)
    let ctx2 = ctx_with_lifted(ctx, teko::list::push(ctx.lifted, thunk))
    let nullo = ctx_alloc(ctx2)
    let with_null = ctx_append(nullo.ctx, const_int_inst(nullo.vreg, 0 to i128, e.line, e.col))
    build_closure_literal(with_null, thunk_sym, nullo.vreg, e.line, e.col)
}

/**
 * ClosureFatPtr — the two loaded halves of a closure value's `{fn@0, env@8}`
 * memory layout (§5.3): the callable's function-address VReg and its
 * captured-environment VReg. Reuses `lower_iface_fatptr`'s load sequence — a
 * closure and an interface receiver share the identical two-Ptr-field shape
 * (its `data`/`vtable` become this type's `target`/`env`).
 *
 * @since #382 A1-7
 */
pub type ClosureFatPtr = struct { ctx: LowerCtx; target: u32; env: u32 }

/**
 * lower_closure_fatptr — load both halves of a closure value's `{fn@0,
 * env@8}` memory layout at address `base`, reusing `lower_iface_fatptr`'s
 * load sequence (A1-7, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param u32 base  the closure's base address (a Ptr VReg)
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return ClosureFatPtr  the advanced context + the loaded target/env VRegs
 */
fn lower_closure_fatptr(ctx: LowerCtx, base: u32, line: u32, col: u32) -> ClosureFatPtr {
    let fp = lower_iface_fatptr(ctx, base, line, col)
    ClosureFatPtr { ctx = fp.ctx; target = fp.data; env = fp.vtable }
}

/**
 * closure_call_args — the indirect-call argument list: `env` prepended to
 * `rest`, in order — mirrors `iface_call_args`'s `data`-first shape, but for
 * a closure's env slot (A1-7, #382).
 *
 * @param u32 env  the closure's env VReg (goes first)
 * @param []u32 rest  the remaining (already-lowered) argument VRegs
 * @return []u32  `env` followed by `rest`, in order
 */
fn closure_call_args(env: u32, rest: []u32) -> []u32 {
    mut out: []u32 = teko::list::push(teko::list::empty(), env)
    mut i: u64 = 0
    loop {
        if i >= rest.len { break }
        out = teko::list::push(out, rest[i])
        i++
    }
    out
}

/**
 * lower_closure_call — a call through a LOCAL closure VALUE
 * (`TCall.is_closure_call`): the callee's last path segment names the local
 * (mirrors the C backend's `emit_closure_call`, which reads the same
 * identifier) — load its `{fn, env}` halves, then `LCallIndirect` through
 * `fn` with `env` prepended to the remaining (already-lowered) arguments
 * (A1-7, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExpr e  the call expression (for its type + source
 *                          position)
 * @param checker::TCall c  the closure-call node (`c.callee`'s last segment
 *                          names the local closure variable)
 * @return Lowered | error  the advanced context + the call's result VReg (0
 *                          for a void call), or a NAMED internal error when
 *                          the node is malformed
 */
fn lower_closure_call(ctx: LowerCtx, e: checker::TExpr, c: checker::TCall) -> Lowered | error {
    if c.callee.segments.len == 0 { return error { message = "native backend N1: empty closure-call path (internal)" } }
    let name = c.callee.segments[c.callee.segments.len - 1].name
    let hit = lenv_lookup(ctx.env, name)
    if !hit.found { return error { message = teko::str::concat("native backend N1: unbound closure local `", name, "` (internal)") } }
    let fp = lower_closure_fatptr(ctx, hit.vreg, e.line, e.col)
    let rest = match lower_args(fp.ctx, c.args) { LoweredArgs as x => x; error as err => return err }
    lower_call_indirect(rest.ctx, e, fp.target, closure_call_args(fp.env, rest.vregs))
}

/**
 * lambda_capture_names — the declared name of each capture, in order (A1-7,
 * #382 — parallels `lambda_capture_types`, the field list `layout_of`
 * needs).
 *
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @return []str  each capture's name, in order
 */
fn lambda_capture_names(captures: []checker::TCapture) -> []str {
    mut out: []str = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= captures.len { break }
        out = teko::list::push(out, captures[i].name)
        i++
    }
    out
}

/**
 * lambda_capture_types — the machine class of each capture, in order
 * (A1-7, #382 — parallels `lambda_capture_names`).
 *
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @return []LType  each capture's machine class, in order
 */
fn lambda_capture_types(captures: []checker::TCapture) -> []LType {
    mut out: []LType = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= captures.len { break }
        out = teko::list::push(out, ltype_of(captures[i].type))
        i++
    }
    out
}

/**
 * lambda_env_layout — the declared-order, natural-alignment layout of a
 * lambda's env aggregate (one field per capture) — reuses `layout_of`, the
 * same algorithm a `struct` declaration's layout gets (A1-7, #382). The
 * layout's own name is a fixed debug label: it is never registered into
 * `ctx.layouts` or looked up by name, only read directly by
 * `build_lambda_env`/`bind_lambda_captures`.
 *
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @return LStructLayout  the env aggregate's resolved layout
 */
fn lambda_env_layout(captures: []checker::TCapture) -> LStructLayout {
    layout_of("<closure-env>", lambda_capture_names(captures), lambda_capture_types(captures))
}

/**
 * store_lambda_captures — store each capture's CURRENT (already-lowered)
 * value into the env aggregate at `base`, at its layout offset — mirrors
 * `store_struct_fields`, but sources each field from the ENCLOSING scope's
 * already-bound local (`lenv_lookup`) rather than re-lowering an expression
 * (A1-7, #382).
 *
 * @param LowerCtx ctx  the lowering context (the ENCLOSING scope — every
 *                      capture must already be bound in `ctx.env`)
 * @param u32 base  the env aggregate's base address (a Ptr VReg)
 * @param LStructLayout layout  the env aggregate's resolved layout
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return Lowered | error  the advanced context + `base` (unchanged by the
 *                          stores), or a NAMED internal error when a capture
 *                          is unbound
 */
fn store_lambda_captures(ctx: LowerCtx, base: u32, layout: LStructLayout, captures: []checker::TCapture, line: u32, col: u32) -> Lowered | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= captures.len { break }
        let hit = lenv_lookup(cur.env, captures[i].name)
        if !hit.found { return error { message = teko::str::concat("native backend N1: unbound capture `", captures[i].name, "` (internal)") } }
        let off = match field_offset_of(layout, captures[i].name) { u32 as o => o; error as err => return err }
        let addr = ctx_alloc(cur)
        let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, base, off, line, col))
        cur = ctx_append(with_addr, store_inst(addr.vreg, hit.vreg, ltype_of(captures[i].type), line, col))
        i++
    }
    Lowered { ctx = cur; vreg = base }
}

/**
 * build_lambda_env — a lambda's env VALUE: a null Ptr const when it captures
 * nothing, else an alloca'd aggregate (`lambda_env_layout`) with every
 * capture's CURRENT value stored in (`store_lambda_captures`) — the address
 * the lifted body's `bind_lambda_captures` reads back from (A1-7, #382).
 *
 * @param LowerCtx ctx  the lowering context (the ENCLOSING scope)
 * @param LStructLayout layout  the env aggregate's resolved layout
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return Lowered | error  the advanced context + the env VReg, or a NAMED
 *                          internal error when a capture is unbound
 */
fn build_lambda_env(ctx: LowerCtx, layout: LStructLayout, captures: []checker::TCapture, line: u32, col: u32) -> Lowered | error {
    if captures.len == 0 {
        let r = ctx_alloc(ctx)
        return Lowered { ctx = ctx_append(r.ctx, const_int_inst(r.vreg, 0 to i128, line, col)); vreg = r.vreg }
    }
    let base = ctx_alloc(ctx)
    let with_alloca = ctx_append(base.ctx, alloca_inst(base.vreg, layout.size, layout.align, line, col))
    store_lambda_captures(with_alloca, base.vreg, layout, captures, line, col)
}

/**
 * lambda_param_ltypes — the machine class of a lambda's OWN declared
 * parameters, in order (A1-7, #382 — parallels `param_ltypes`, but reading
 * a `TLambdaParam`'s resolved type rather than a syntactic annotation).
 *
 * @param []checker::TLambdaParam params  the lambda's declared parameters
 * @return []LType  each parameter's machine class, in order
 */
fn lambda_param_ltypes(params: []checker::TLambdaParam) -> []LType {
    mut out: []LType = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= params.len { break }
        out = teko::list::push(out, ltype_of(params[i].type))
        i++
    }
    out
}

/** ParamSeed — a lifted lambda body's freshly-materialized function shell +
    the local env binding its own declared parameters (name -> VReg, index
    shifted by one past the env slot) (A1-7, #382). */
pub type ParamSeed = struct { func: LFunc; env: LEnv }

/**
 * materialize_lambda_params — append a `param` instruction for the lifted
 * body's env-first parameter list (env at VReg 0, then each declared
 * parameter), binding every declared parameter's name into a fresh local
 * env (A1-7, #382).
 *
 * @param LFunc f0  the lifted body's (still bodyless) function shell
 * @param checker::TLambda lam  the lambda node (its declared parameters)
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return ParamSeed  the advanced function + the local env binding the
 *                     declared parameters
 */
fn materialize_lambda_params(f0: LFunc, lam: checker::TLambda, line: u32, col: u32) -> ParamSeed {
    mut f = append_inst(f0, 0, param_inst(0, 0, line, col))
    mut env = empty_lenv()
    mut i: u64 = 0
    loop {
        if i >= lam.params.len { break }
        let idx = (i + 1) to u32
        f = append_inst(f, 0, param_inst(idx, idx, line, col))
        env = lenv_bind(env, lam.params[i].name, idx)
        i++
    }
    ParamSeed { func = f; env = env }
}

/**
 * bind_lambda_captures — extend `ctx`'s local env with every capture,
 * loading each one's value out of VReg 0 (the lifted body's env parameter)
 * at its layout offset (A1-7, #382).
 *
 * @param LowerCtx ctx  the lifted body's OWN lowering context
 * @param LStructLayout layout  the env aggregate's resolved layout
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @param u32 line  the source line to propagate onto every emitted inst
 * @param u32 col  the source column to propagate onto every emitted inst
 * @return LowerCtx | error  the extended context, or a NAMED internal error
 *                           when the layout is malformed
 */
fn bind_lambda_captures(ctx: LowerCtx, layout: LStructLayout, captures: []checker::TCapture, line: u32, col: u32) -> LowerCtx | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= captures.len { break }
        let off = match field_offset_of(layout, captures[i].name) { u32 as o => o; error as err => return err }
        let ty = match field_type_of(layout, captures[i].name) { LType as t => t; error as err => return err }
        let addr = ctx_alloc(cur)
        let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, 0, off, line, col))
        let val = ctx_alloc(with_addr)
        let with_val = ctx_append(val.ctx, load_inst(val.vreg, addr.vreg, ty, line, col))
        cur = ctx_bind(with_val, captures[i].name, val.vreg)
        i++
    }
    cur
}

/**
 * close_lambda_body — fire any still-pending defer (from index 0, LIFO) and
 * append the implicit void return when the lifted body's current block did
 * not already terminate (mirrors `close_function`). A NON-void lambda's
 * block is already terminated by the time this runs — `lower_fn_body`
 * auto-returns its trailing expression (#421) — so this only ever fires for
 * a `void`-returning lambda's fall-through (A1-7 #382; defer replay A1-2
 * #382).
 *
 * @param LowerCtx ctx  the lifted body's lowering context, after its
 *                      statements have been lowered
 * @param u32 line  the source line to propagate onto a synthesized `ret`
 * @param u32 col  the source column to propagate onto a synthesized `ret`
 * @return LowerCtx | error  the closed context (its `.func` is the closed
 *                           function; its `.rodata`/`.lifted` carry forward
 *                           any growth the fall-through defer replay made),
 *                           or a NAMED internal error when a pending defer
 *                           fails to lower
 */
fn close_lambda_body(ctx: LowerCtx, line: u32, col: u32) -> LowerCtx | error {
    if block_terminated(ctx.func, ctx.block_id) { return ctx }
    let replayed = match replay_defers(ctx, 0) { LowerCtx as c => c; error as err => return err }
    ctx_append(replayed, ret_void_inst(line, col))
}

/** LoweredLambda — a lifted lambda body's (placeholder-symbol) `LFunc` + the
    rodata/lifted tables it (and everything lowered before it) grew (A1-7,
    #382 — mirrors `LoweredFunction`, plus the lifted-function table so a
    NESTED lambda inside this one's own body is not lost). */
pub type LoweredLambda = struct { func: LFunc; rodata: []LRodata; lifted: []LFunc }

/**
 * build_lambda_lfunc — lower a lambda's OWN body into an independent
 * `LFunc`: env-first parameters (`materialize_lambda_params`), each capture
 * bound by loading it off the env parameter (`bind_lambda_captures`), then
 * the body statements (`lower_fn_body` — a NON-void lambda auto-returns its
 * trailing expression, #421), closed like a function (`close_lambda_body`).
 * Built with a PLACEHOLDER symbol — the caller (`lower_lambda`) renames it
 * once its final lifted id is known (A1-7, #382).
 *
 * @param checker::TLambda lam  the lambda node to lower
 * @param LStructLayout env_layout  the env aggregate's resolved layout
 * @param LowerCtx ctx  the ENCLOSING lowering context (its layouts/rodata/
 *                      enums/lifted tables seed the lifted body's own; its
 *                      OWN func/env/block_id are NOT reused)
 * @param u32 line  the source line to propagate onto every synthesized inst
 * @param u32 col  the source column to propagate onto every synthesized
 *                 inst
 * @return LoweredLambda | error  the built (placeholder-named) LFunc + the
 *                                grown rodata/lifted tables, or an error
 *                                when the body fails to lower
 */
fn build_lambda_lfunc(lam: checker::TLambda, env_layout: LStructLayout, ctx: LowerCtx, line: u32, col: u32) -> LoweredLambda | error {
    let ptypes = lambda_param_ltypes(lam.params)
    let all_ptypes = env_first_param_types(ptypes)
    let seed0 = new_func("", (lam.params.len + 1) to u32, all_ptypes, ltype_of(lam.ret))
    let seed = materialize_lambda_params(seed0, lam, line, col)
    let ctx0 = LowerCtx {
        func = seed.func; block_id = 0; env = seed.env
        layouts = ctx.layouts; rodata = ctx.rodata; enums = ctx.enums; lifted = ctx.lifted
        defers = teko::list::empty(); loop_targets = teko::list::empty()
    }
    let with_captures = match bind_lambda_captures(ctx0, env_layout, lam.captures, line, col) { LowerCtx as c => c; error as err => return err }
    let done = match lower_fn_body(with_captures, lam.body, ltype_of(lam.ret), line, col) { LowerCtx as c => c; error as err => return err }
    let closed = match close_lambda_body(done, line, col) { LowerCtx as c => c; error as err => return err }
    LoweredLambda { func = closed.func; rodata = closed.rodata; lifted = closed.lifted }
}

/**
 * lower_lambda — a closure LITERAL (`TLambda`): build the env aggregate
 * from the ENCLOSING scope's captures (`build_lambda_env`), lower the
 * lambda's OWN body into a lifted `LFunc` (`build_lambda_lfunc`) — its FINAL
 * id is `built.lifted.len` (reserved AFTER any nested lambda inside its own
 * body, so ids never collide), so it is renamed (`rename_lfunc`) only now —
 * then build the closure literal `{fn=lifted, env}` — mirrors the C
 * backend's `(tk_closure){ &__tkclo_<id>, env }` (`codegen.tks:5177-5178`)
 * (A1-7, #382).
 *
 * @param LowerCtx ctx  the lowering context (the ENCLOSING scope)
 * @param checker::TExpr e  the lambda expression (for its source position)
 * @param checker::TLambda lam  the lambda node to lower
 * @return Lowered | error  the advanced context + the closure literal's base
 *                          address, or an error when the body fails to
 *                          lower
 */
fn lower_lambda(ctx: LowerCtx, e: checker::TExpr, lam: checker::TLambda) -> Lowered | error {
    let env_layout = lambda_env_layout(lam.captures)
    let envo = match build_lambda_env(ctx, env_layout, lam.captures, e.line, e.col) { Lowered as x => x; error as err => return err }
    let built = match build_lambda_lfunc(lam, env_layout, envo.ctx, e.line, e.col) { LoweredLambda as x => x; error as err => return err }
    let id = built.lifted.len
    let fn_sym = lift_lambda_symbol(id)
    let named = rename_lfunc(built.func, fn_sym)
    let ctx2 = ctx_with_lifted(ctx_with_rodata(envo.ctx, built.rodata), teko::list::push(built.lifted, named))
    build_closure_literal(ctx2, fn_sym, envo.vreg, e.line, e.col)
}

/** lower_stmt — lower one statement, extending the env on a `let` and signaling block
    termination on a `return`. Mirrors emit_stmt over the subset; out-of-subset statements
    honest-stop. */
pub fn lower_stmt(ctx: LowerCtx, s: checker::TStatement) -> LowerStmtOut | error {
    match s {
        checker::TBinding as b => lower_binding(ctx, b)
        checker::TAssign as a => lower_assign(ctx, a)
        checker::TReturn as r => lower_return(ctx, r)
        checker::TExprStmt as es => lower_expr_stmt(ctx, es)
        checker::TLoopStmt as l => lower_loop(ctx, l)
        checker::TBreakStmt as b => lower_break(ctx, b)
        checker::TContinueStmt as c => lower_continue(ctx, c)
        checker::TDeferStmt as d => lower_defer(ctx, d)
        _ => error { message = teko::str::concat("native backend N1: ", tstmt_kind_name(s), " not yet lowered (N2)") }
    }
}

/** lower_binding — `let x = e`: a str/slice-typed binding (A1-4, #382) lowers `e` through
    the FAT path and binds (ptr, len); every other binding lowers `e` to a single VReg and
    binds it plainly. The binding target must be a simple name (a destructuring pattern is
    out of the N1 subset). */
fn lower_binding(ctx: LowerCtx, b: checker::TBinding) -> LowerStmtOut | error {
    let name = match bind_target_name(b.target) { str as s => s; error as err => return err }
    if is_fat_type(b.bound) {
        let fo = match lower_fat_expr(ctx, b.value) { LoweredFat as x => x; error as err => return err }
        return LowerStmtOut { ctx = ctx_bind_fat(fo.ctx, name, fo.ptr, fo.len); terminated = false }
    }
    let lo = match lower_expr(ctx, b.value) { Lowered as x => x; error as err => return err }
    LowerStmtOut { ctx = ctx_bind(lo.ctx, name, lo.vreg); terminated = false }
}

/** bind_target_name — the bound simple name; a destructuring pattern honest-stops. */
fn bind_target_name(t: parser::BindTarget) -> str | error {
    match t {
        parser::SimpleName as sn => sn.name
        _ => error { message = "native backend N1: destructuring binding not yet lowered (N2)" }
    }
}

/**
 * lower_return — `return e` (or bare `return`): a `return` leaves EVERY
 * enclosing scope, so first fire ALL pending defers (from index 0, LIFO —
 * mirrors the C backend's `emit_return`, `codegen.tks:5770-5773`, which
 * fires before its own return-value TEXT so a defer's mutation of a local
 * IS observable through the value `r.value` reads afterward), THEN lower
 * the return value (when present), THEN emit the `LRet` terminator, closing
 * the block (A1-2, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TReturn r  the return node
 * @return LowerStmtOut | error  the advanced (terminated) context, or a
 *                               NAMED internal error when a pending defer
 *                               body fails to lower
 */
fn lower_return(ctx: LowerCtx, r: checker::TReturn) -> LowerStmtOut | error {
    let replayed = match replay_defers(ctx, 0) { LowerCtx as c => c; error as err => return err }
    if !r.has_value {
        let vinst = ret_void_inst(r.value.line, r.value.col)
        return LowerStmtOut { ctx = ctx_append(replayed, vinst); terminated = true }
    }
    let lo = match lower_expr(replayed, r.value) { Lowered as x => x; error as err => return err }
    let inst = ret_inst(lo.vreg, r.value.line, r.value.col)
    LowerStmtOut { ctx = ctx_append(lo.ctx, inst); terminated = true }
}

/** lower_expr_stmt — an expression statement: lower for effect (the call), discard the
    VReg. */
fn lower_expr_stmt(ctx: LowerCtx, es: checker::TExprStmt) -> LowerStmtOut | error {
    let lo = match lower_expr(ctx, es.expr) { Lowered as x => x; error as err => return err }
    LowerStmtOut { ctx = lo.ctx; terminated = false }
}

/**
 * lower_defer — `defer { … }`: register the node onto the pending-defer
 * stack (LIFO order is `replay_defers`'s job, at whichever scope exit fires
 * it) and emit nothing inline — mirrors the C backend's `dctx_register`
 * (`codegen.tks:5273-5277`) (A1-2, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TDeferStmt d  the defer node to register
 * @return LowerStmtOut  the context with `d` appended to `.defers`
 *                        (terminated=false — a `defer` never closes its
 *                        enclosing block)
 */
fn lower_defer(ctx: LowerCtx, d: checker::TDeferStmt) -> LowerStmtOut {
    LowerStmtOut { ctx = ctx_with_defers(ctx, teko::list::push(ctx.defers, d)); terminated = false }
}

/**
 * replay_defers — fire every deferred body registered at index ≥ `base` in
 * `ctx.defers`, LIFO (innermost/most-recent first), by lowering each body's
 * statements straight-line into the CURRENT block — mirrors the C backend's
 * `emit_defers` (`codegen.tks:5247-5271`). A defer body never itself
 * contains a `return`/`break`/`continue`/`defer` (checker-enforced,
 * `typer.tks:3068-3079`), so lowering it plainly via `lower_block` never
 * re-enters this replay (A1-2, #382).
 *
 * @param LowerCtx ctx  the lowering context; its OWN `.defers` stack is READ
 *                      (not shrunk — firing is a symbolic replay over
 *                      already-lowered source structure, not a runtime pop)
 * @param u64 base  the defer-stack index the exiting scope started at;
 *                  every entry at or after this index fires
 * @return LowerCtx | error  the advanced context (its current block grown
 *                           with the replayed instructions), or a NAMED
 *                           internal error when a defer body fails to lower
 */
fn replay_defers(ctx: LowerCtx, base: u64) -> LowerCtx | error {
    mut cur = ctx
    mut i: u64 = ctx.defers.len
    loop {
        if i <= base { break }
        i = i - 1
        cur = match lower_block(cur, ctx.defers[i].body) { LowerCtx as c => c; error as err => return err }
    }
    cur
}

/**
 * PromotedEnv — the result of giving a MERGE block (a loop's head or exit)
 * one block-arg per SCALAR (non-fat) name in an env: the advanced function,
 * the rebuilt env (each such name now bound to its fresh block-arg VReg,
 * every FAT binding passed through unchanged, unpromoted), and the ordered
 * name list a caller matches against `env_scalar_vregs` to build a jump's
 * argument list into this block (A1-2, #382 — a loop head/exit are both
 * MERGE points, mirroring the SAME block-arg principle an if-expression's
 * result VReg already uses, §2.4).
 */
pub type PromotedEnv = struct { func: LFunc; env: LEnv; names: []str }

/**
 * promote_env — allocate one fresh block-arg VReg per SCALAR (non-fat)
 * binding in `env`, in order, on block `block_id`; rebuild the env with
 * those names now bound to their fresh block-arg VReg. A FAT (str/slice)
 * binding is left UNPROMOTED — its ptr/len stay whatever they were for the
 * whole scope; no A1-2 fixture reassigns a fat local inside a loop
 * (A1-2, #382).
 *
 * @param LFunc f  the function whose block gains the params
 * @param u32 block_id  the merge block (already allocated) to add params to
 * @param LEnv env  the env to promote (its SHAPE — names/fat-vs-scalar —
 *                   drives which entries get a param)
 * @return PromotedEnv  the advanced function + the rebuilt env + the ordered
 *                       promoted-name list
 */
fn promote_env(f: LFunc, block_id: u32, env: LEnv) -> PromotedEnv {
    mut cur_f = f
    mut new_env = empty_lenv()
    mut names: []str = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= env.names.len { break }
        if env.has_len[i] {
            new_env = lenv_bind_fat(new_env, env.names[i], env.vregs[i], env.len_vregs[i])
        } else {
            let bp = add_block_param(cur_f, block_id)
            cur_f = bp.func
            new_env = lenv_bind(new_env, env.names[i], bp.vreg)
            names = teko::list::push(names, env.names[i])
        }
        i++
    }
    PromotedEnv { func = cur_f; env = new_env; names = names }
}

/**
 * env_scalar_vregs — the CURRENT VReg of each SCALAR (non-fat) binding in
 * `env`, in order — the argument list a jump/branch into a `promote_env`'d
 * merge block supplies (A1-2, #382).
 *
 * @param LEnv env  the env to read
 * @return []u32  each non-fat binding's current VReg, in order
 */
fn env_scalar_vregs(env: LEnv) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= env.names.len { break }
        if !env.has_len[i] { out = teko::list::push(out, env.vregs[i]) }
        i++
    }
    out
}

/**
 * jump_args_for_names — the CURRENT VReg of each name in `names` (in
 * order), read from `env` — the argument list a `break`/`continue`/loop
 * back-edge jump supplies into a target `promote_env`'d block whose params
 * are exactly `names`, positionally (A1-2, #382).
 *
 * @param LEnv env  the env to read (the jump SITE's own, however deeply
 *                  nested)
 * @param []str names  the target block's promoted-name list (its param
 *                      order)
 * @return []u32  each name's current VReg, in the SAME order as `names`
 */
fn jump_args_for_names(env: LEnv, names: []str) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= names.len { break }
        out = teko::list::push(out, lenv_lookup(env, names[i]).vreg)
        i++
    }
    out
}

/**
 * merge_scalar_indices — the pre-branch INDEX of each threaded name in `env`
 * (its newest occurrence), in `names` order — computed ONCE at a merge site
 * from the PRE-BRANCH env so every arm reads its enclosing scalar's value from
 * the SAME fixed slot, immune to any shadow the arm appends after it (#389 F1b
 * item 3). Each threaded name occurs once in the pre-branch env, so the newest
 * index IS the enclosing binding's index.
 *
 * @param LEnv env  the pre-branch env (each threaded name occurs once)
 * @param []str names  the threaded scalar names, in merge-param order
 * @return []u64  each name's pre-branch index, in the SAME order as `names`
 */
fn merge_scalar_indices(env: LEnv, names: []str) -> []u64 {
    mut out: []u64 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= names.len { break }
        out = teko::list::push(out, lenv_newest_index(env, names[i]))
        i++
    }
    out
}

/**
 * arm_scalar_args — one jump-arg per threaded scalar, read from `arm_env` at the
 * fixed pre-branch `indices` — the ENCLOSING binding's current value at the
 * arm's close (the reassigned VReg if the arm reassigned the enclosing scalar
 * in place, the untouched pre-branch VReg if the arm only shadowed it at a
 * higher index), REPLACING `jump_args_for_names`'s newest-first name lookup for
 * if/match arm merges (#389 F1b item 3). Loops keep `jump_args_for_names` (a
 * back-edge threads ALL promoted scalars by name, with no enclosing-vs-shadow
 * split to make).
 *
 * @param LEnv arm_env  the arm-end env (its indices 0..pre_branch_len keep
 *                      their positions — arms only append or update in place)
 * @param []u64 indices  the threaded scalars' pre-branch indices, in param order
 * @return []u32  each index's current VReg, in the SAME order as `indices`
 */
fn arm_scalar_args(arm_env: LEnv, indices: []u64) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= indices.len { break }
        out = teko::list::push(out, arm_env.vregs[indices[i]])
        i++
    }
    out
}

/**
 * contains_str — is `s` present anywhere in `xs`? A tiny membership test the
 * reassigned-scalar pre-scan uses both to de-duplicate raw hits and to keep
 * the result in `env` order (#389 F1).
 *
 * @param []str xs  the list to search
 * @param str s  the string to look for
 * @return bool  true when some element of `xs` equals `s`
 */
fn contains_str(xs: []str, s: str) -> bool {
    mut i: u64 = 0
    loop {
        if i >= xs.len { break }
        if xs[i] == s { return true }
        i++
    }
    false
}

/**
 * collect_reassigned_stmts — accumulate into `acc` the target of every
 * `TAssign` of `AssignKind::Simple` reachable in `stmts`, DESCENDING into the
 * statement blocks of a nested statement-form `if`/`match`, a `loop`, a
 * `defer` body, AND the value-position `if`/`match` RHS of a `let`/`mut`
 * binding. A reassignment buried one control-flow level down still rebinds the
 * enclosing scalar PAST that inner merge, so the OUTER merge must carry it too
 * — the SAME drop, one level in.
 *
 * A `defer` body IS descended (#389 F1b item 1): a statement-arm's closing
 * jump-args are now re-sampled from the POST-`replay_defers` env
 * (`close_arm_replaying_defers`), so a scalar a defer body reassigns reaches
 * the merge param with its POST-defer value — the descent is a REAL fix, not
 * the stale param F1 removed it to avoid (F1 sampled the args PRE-replay, so a
 * defer descent then would only have minted a param carrying the stale
 * pre-defer VReg).
 *
 * A binding's value-position `if`/`match` RHS IS descended (#389 F1b item 2):
 * `if outer { let y = if inner { x = 5; x } else { 0 } }` reassigns the
 * enclosing `x` inside the INNER value-if, which threads `x` through its OWN
 * merge — but the OUTER statement merge still reads `x` past it, so the outer
 * merge must carry `x` too or the rebind is DROPPED at the outer merge.
 *
 * @param []checker::TStatement stmts  the statement block to scan
 * @param []str acc  the assignment targets gathered so far
 * @return []str  `acc` extended with every simple-assignment target found
 */
fn collect_reassigned_stmts(stmts: []checker::TStatement, acc: []str) -> []str {
    mut out = acc
    mut i: u64 = 0
    loop {
        if i >= stmts.len { break }
        out = collect_reassigned_stmt(stmts[i], out)
        i++
    }
    out
}

/**
 * collect_reassigned_stmt — one statement's contribution to the
 * reassigned-target scan: a `Simple` `TAssign` yields its `name`; a
 * `let`/`mut` `TBinding` descends into its value-position `if`/`match` RHS
 * (#389 F1b item 2); a statement-form `if`/`match` (a `TExprStmt`), a `loop`,
 * and a `defer` body (#389 F1b item 1) recurse into their own statement
 * blocks; every other statement contributes nothing (#389 F1).
 *
 * @param checker::TStatement s  the statement to scan
 * @param []str acc  the assignment targets gathered so far
 * @return []str  `acc` extended with this statement's simple-assignment
 *                targets
 */
fn collect_reassigned_stmt(s: checker::TStatement, acc: []str) -> []str {
    match s {
        checker::TAssign as a => match a.kind { parser::AssignKind::Simple => teko::list::push(acc, a.name); _ => acc }
        checker::TBinding as b => collect_reassigned_value_expr(b.value, acc)
        checker::TExprStmt as es => collect_reassigned_expr_stmt(es.expr, acc)
        checker::TLoopStmt as l => collect_reassigned_stmts(l.body, collect_reassigned_stmts(l.init, acc))
        checker::TDeferStmt as d => collect_reassigned_stmts(d.body, acc)
        _ => acc
    }
}

/**
 * collect_reassigned_expr_stmt — the reassigned-target scan of a statement's
 * expression: only a statement-form `if`/`match` bears further statement
 * blocks to descend into; any other expression kind contributes nothing
 * (#389 F1).
 *
 * @param checker::TExpr e  the expression-statement's expression
 * @param []str acc  the assignment targets gathered so far
 * @return []str  `acc` extended with the nested control-flow's simple
 *                assignments
 */
fn collect_reassigned_expr_stmt(e: checker::TExpr, acc: []str) -> []str {
    match e.kind {
        checker::TIfExpr as f => collect_reassigned_if(f, acc)
        checker::TMatchExpr as m => collect_reassigned_match(m, acc)
        _ => acc
    }
}

/**
 * collect_reassigned_value_expr — the reassigned-target scan of a binding's
 * value-position expression: only a value-form `if`/`match` bears arm blocks
 * whose reassignments escape into the enclosing scope PAST their own merge, so
 * the OUTER statement merge must carry them too; any other expression kind
 * contributes nothing (#389 F1b item 2).
 *
 * @param checker::TExpr e  the binding's initializer expression
 * @param []str acc  the assignment targets gathered so far
 * @return []str  `acc` extended with the value-if/match RHS's simple
 *                assignments
 */
fn collect_reassigned_value_expr(e: checker::TExpr, acc: []str) -> []str {
    match e.kind {
        checker::TIfExpr as f => collect_reassigned_if(f, acc)
        checker::TMatchExpr as m => collect_reassigned_match(m, acc)
        _ => acc
    }
}

/**
 * collect_reassigned_if — descend the reassigned-target scan into both blocks
 * of a nested statement-form `if` (the else block only when present) (#389 F1).
 *
 * @param checker::TIfExpr f  the nested if node
 * @param []str acc  the assignment targets gathered so far
 * @return []str  `acc` extended with both arms' simple assignments
 */
fn collect_reassigned_if(f: checker::TIfExpr, acc: []str) -> []str {
    let after_then = collect_reassigned_stmts(f.then_blk, acc)
    if f.has_else { return collect_reassigned_stmts(f.else_blk, after_then) }
    after_then
}

/**
 * collect_reassigned_match — descend the reassigned-target scan into every
 * arm body of a nested statement-form `match` (#389 F1).
 *
 * @param checker::TMatchExpr m  the nested match node
 * @param []str acc  the assignment targets gathered so far
 * @return []str  `acc` extended with every arm body's simple assignments
 */
fn collect_reassigned_match(m: checker::TMatchExpr, acc: []str) -> []str {
    mut out = acc
    mut i: u64 = 0
    loop {
        if i >= m.arms.len { break }
        out = collect_reassigned_stmts(m.arms[i].body, out)
        i++
    }
    out
}

/**
 * append_all_u32 — append every element of `xs`, in order, to `acc`;
 * `close_arm_replaying_defers` concatenates an arm's PRE-replay value
 * block-args onto its POST-replay scalar merge-args (#389 F1b).
 *
 * @param []u32 acc  the list to extend
 * @param []u32 xs  the elements to append
 * @return []u32  `acc` with every element of `xs` appended, in order
 */
fn append_all_u32(acc: []u32, xs: []u32) -> []u32 {
    mut out = acc
    mut i: u64 = 0
    loop {
        if i >= xs.len { break }
        out = teko::list::push(out, xs[i])
        i++
    }
    out
}

/**
 * reassigned_scalars — the enclosing-scope SCALAR names some arm of this
 * branch re-assigns (`TAssign`, `AssignKind::Simple`), so the merge must
 * carry them as block-params. A static pre-scan of the arm statement blocks
 * against `env` — computed BEFORE lowering, so the merge params can be
 * allocated up front and each arm's closing jump can supply them. An arm
 * with no such assignment contributes nothing, so an `if`/`match` that
 * mutates no enclosing scalar keeps its CURRENT zero-scalar-param merge
 * (no LIR change, no regression risk for the existing acyclic corpus). Only
 * names bound as SCALARS in `env` qualify (a fat `str`/`slice` local stays
 * unpromoted, mirroring `promote_env`), and the result is DISTINCT and in
 * `env` order so the merge params, each arm's jump args, and the rebuilt
 * post-merge env all agree positionally.
 *
 * Every reassigned pre-branch scalar is threaded — the coarse across-all-arms
 * shadow-EXCLUSION F1 needed is gone (#389 F1b item 3). Under the new
 * enclosing-IDENTITY read (`arm_scalar_args` samples each arm's jump-arg at
 * the name's fixed pre-branch INDEX), an arm that only SHADOWS a threaded name
 * (`mut x = 99`, a pattern bind) appends the shadow at a HIGHER index and
 * leaves the enclosing scalar's index untouched, so it threads its pre-branch
 * VReg — a no-op phi, never a miscompile. Over-approximating (thread every
 * reassigned scalar) is therefore provably safe, and the legitimate arm that
 * reassigns the ENCLOSING scalar is no longer collateral-excluded by a shadow
 * in a SIBLING arm (the F1 over-exclusion this fix eliminates).
 *
 * @param []checker::TStatement arms  every arm's statement block, flattened
 * @param LEnv env  the pre-branch scalar environment (the promotable names)
 * @return []str  the distinct enclosing scalar names re-assigned in any arm
 */
fn reassigned_scalars(arms: []checker::TStatement, env: LEnv) -> []str {
    let raw = collect_reassigned_stmts(arms, teko::list::empty())
    mut out: []str = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= env.names.len { break }
        if !env.has_len[i] && contains_str(raw, env.names[i]) && !contains_str(out, env.names[i]) {
            out = teko::list::push(out, env.names[i])
        }
        i++
    }
    out
}

/**
 * reassigned_scalars_for_match — `reassigned_scalars` over a match's arm
 * bodies. No pattern exclusion is needed under enclosing-identity threading
 * (#389 F1b item 3): a pattern binding (`Some(x)`, `A as x`) appends a shadow
 * at a HIGHER index than the enclosing scalar, so `arm_scalar_args` reads the
 * enclosing scalar's pre-branch index untouched — the `Some` arm threads the
 * enclosing `x`'s pre-branch VReg and the `None` arm threads its reassigned
 * VReg, each correct on its own path. The former across-all-arms pattern
 * exclusion (which reverted a legitimately-reassigned name to the dropped
 * merge whenever a SIBLING arm's pattern shadowed it) is gone.
 *
 * @param []checker::TArm arms  the match's arms
 * @param LEnv env  the pre-branch scalar environment (the promotable names)
 * @return []str  the distinct enclosing scalar names re-assigned in any arm
 */
fn reassigned_scalars_for_match(arms: []checker::TArm, env: LEnv) -> []str {
    reassigned_scalars(match_arm_stmts(arms), env)
}

/**
 * merge_param_for — the merge-param VReg reserved for `name`, looked up by
 * position in the parallel `names`/`vregs` lists `add_merge_scalar_params`
 * built; `found=false` when `name` is not a reassigned scalar (#389 F1).
 *
 * @param []str names  the reassigned scalar names, in merge-param order
 * @param []u32 vregs  the reserved merge-param VReg for each name, same order
 * @param str name  the name to resolve
 * @return LLookup  whether `name` was reassigned + its merge-param VReg
 */
fn merge_param_for(names: []str, vregs: []u32, name: str) -> LLookup {
    mut i: u64 = 0
    loop {
        if i >= names.len { break }
        if names[i] == name { return LLookup { found = true; vreg = vregs[i] } }
        i++
    }
    LLookup { found = false; vreg = 0 }
}

/**
 * rebind_scalars — rebuild `env` rebinding each reassigned SCALAR name to its
 * fresh merge-param VReg (from the parallel `names`/`vregs` lists), passing
 * every other binding — untouched scalars AND every fat binding — through
 * unchanged. The reassigned-only mirror of `promote_env`'s env rebuild, so
 * the post-merge env reads a merged name from its merge param and every other
 * name from its unchanged pre-branch VReg (#389 F1).
 *
 * @param LEnv env  the pre-branch env to rebuild
 * @param []str names  the reassigned scalar names, in merge-param order
 * @param []u32 vregs  the reserved merge-param VReg for each name, same order
 * @return LEnv  the post-merge env
 */
fn rebind_scalars(env: LEnv, names: []str, vregs: []u32) -> LEnv {
    mut out = empty_lenv()
    mut i: u64 = 0
    loop {
        if i >= env.names.len { break }
        if env.has_len[i] {
            out = lenv_bind_fat(out, env.names[i], env.vregs[i], env.len_vregs[i])
        } else {
            let p = merge_param_for(names, vregs, env.names[i])
            out = if p.found { lenv_bind(out, env.names[i], p.vreg) } else { lenv_bind(out, env.names[i], env.vregs[i]) }
        }
        i++
    }
    out
}

/**
 * add_merge_scalar_params — reserve one fresh merge block-param per name in
 * `names` (in order) on `block_id`, then rebuild `env` rebinding each of those
 * SCALAR names to its new param VReg. The reassigned-only mirror of
 * `promote_env`, so an `if`/`match` merge threads exactly the scalars an arm
 * re-assigns and nothing else — a mutation-free branch adds ZERO params and
 * stays byte-identical (#389 F1).
 *
 * @param LFunc f  the function whose merge block gains the params
 * @param u32 block_id  the merge block (already allocated) to add params to
 * @param LEnv env  the pre-branch env to rebuild
 * @param []str names  the reassigned scalar names, in `env` order
 * @return PromotedEnv  the advanced function + rebuilt env + `names` echoed
 */
fn add_merge_scalar_params(f: LFunc, block_id: u32, env: LEnv, names: []str) -> PromotedEnv {
    mut cur_f = f
    mut param_vregs: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= names.len { break }
        let bp = add_block_param(cur_f, block_id)
        cur_f = bp.func
        param_vregs = teko::list::push(param_vregs, bp.vreg)
        i++
    }
    PromotedEnv { func = cur_f; env = rebind_scalars(env, names, param_vregs); names = names }
}

/**
 * merge_value_args — a value-producing merge's jump-arg list: the arm's tail
 * VALUE first, then one arg per reassigned scalar (in `names` order), matching
 * the merge block's `value`-param-first, scalar-params-after layout (#389 F1).
 *
 * @param u32 value  the arm's tail-value VReg (the merge's first block-param)
 * @param []u32 scalars  the reassigned-scalar args, in `names` order
 * @return []u32  `[value] ++ scalars`
 */
fn merge_value_args(value: u32, scalars: []u32) -> []u32 {
    mut out = teko::list::push(teko::list::empty(), value)
    mut i: u64 = 0
    loop {
        if i >= scalars.len { break }
        out = teko::list::push(out, scalars[i])
        i++
    }
    out
}

/**
 * if_arm_stmts — both arms of an `if` flattened into one statement block for
 * the reassigned-scalar pre-scan: the then block always, the else block only
 * when the `if` actually HAS one (an else-less `if`'s pass-through arm mutates
 * nothing) (#389 F1).
 *
 * @param checker::TIfExpr f  the if node
 * @return []checker::TStatement  the then block, plus the else block when present
 */
fn if_arm_stmts(f: checker::TIfExpr) -> []checker::TStatement {
    if !f.has_else { return f.then_blk }
    mut out = f.then_blk
    mut i: u64 = 0
    loop {
        if i >= f.else_blk.len { break }
        out = teko::list::push(out, f.else_blk[i])
        i++
    }
    out
}

/**
 * match_arm_stmts — every arm body of a `match` flattened into one statement
 * block for the reassigned-scalar pre-scan (#389 F1).
 *
 * @param []checker::TArm arms  the match's arms
 * @return []checker::TStatement  every arm body's statements, concatenated
 */
fn match_arm_stmts(arms: []checker::TArm) -> []checker::TStatement {
    mut out: []checker::TStatement = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= arms.len { break }
        let body = arms[i].body
        mut j: u64 = 0
        loop {
            if j >= body.len { break }
            out = teko::list::push(out, body[j])
            j++
        }
        i++
    }
    out
}

/**
 * find_loop_target — the loop-target the innermost matching loop resolves
 * to: an empty `label` matches the INNERMOST active loop; a non-empty label
 * scans from the innermost outward for the loop declared with that name —
 * mirrors the C backend's `cg_target_defer_base` scan (`codegen.tks:
 * 5299-5310`) (A1-2, #382).
 *
 * @param []LoopTargets loops  the active loop-target stack, outermost first
 * @param str label  the break/continue's target label ("" = innermost)
 * @return LoopTargets | error  the matching loop's targets, or a NAMED
 *                              internal error when none match (a checker
 *                              invariant break — a break/continue outside a
 *                              loop never reaches lowering)
 */
fn find_loop_target(loops: []LoopTargets, label: str) -> LoopTargets | error {
    mut i: u64 = loops.len
    loop {
        if i == 0 { break }
        i = i - 1
        let lt = loops[i]
        if label.len == 0 || lt.label == label { return lt }
    }
    error { message = "native backend N1: break/continue outside a loop (internal)" }
}

/**
 * lower_break — `break`/`break L`: resolve the target loop, fire every
 * defer registered inside its own body (LIFO, from its `defer_base`), then
 * jump to its exit block carrying the CURRENT VReg of each of its promoted
 * names (A1-2, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TBreakStmt b  the break node
 * @return LowerStmtOut | error  the advanced (terminated) context, or a
 *                               NAMED internal error when the target loop
 *                               is unresolved or a pending defer fails to
 *                               lower
 */
fn lower_break(ctx: LowerCtx, b: checker::TBreakStmt) -> LowerStmtOut | error {
    let target = match find_loop_target(ctx.loop_targets, b.label) { LoopTargets as t => t; error as err => return err }
    let replayed = match replay_defers(ctx, target.defer_base) { LowerCtx as c => c; error as err => return err }
    let args = jump_args_for_names(replayed.env, target.names)
    LowerStmtOut { ctx = ctx_append(replayed, jump_inst(target.exit, args, 0, 0)); terminated = true }
}

/**
 * lower_continue — `continue`/`continue L`: resolve the target loop, fire
 * every defer registered inside its own body (LIFO, from its
 * `defer_base`), then jump BACK to its head block carrying the CURRENT
 * VReg of each of its promoted names (A1-2, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TContinueStmt c  the continue node
 * @return LowerStmtOut | error  the advanced (terminated) context, or a
 *                               NAMED internal error when the target loop
 *                               is unresolved or a pending defer fails to
 *                               lower
 */
fn lower_continue(ctx: LowerCtx, c: checker::TContinueStmt) -> LowerStmtOut | error {
    let target = match find_loop_target(ctx.loop_targets, c.label) { LoopTargets as t => t; error as err => return err }
    let replayed = match replay_defers(ctx, target.defer_base) { LowerCtx as c2 => c2; error as err => return err }
    let args = jump_args_for_names(replayed.env, target.names)
    LowerStmtOut { ctx = ctx_append(replayed, jump_inst(target.head, args, 0, 0)); terminated = true }
}

/**
 * close_loop_body — close a loop's body block: if it already ended in a
 * terminator (an explicit `return`/`break`/`continue`), leave it as-is;
 * otherwise fire the loop's own pending defers (registered since
 * `defer_base`, LIFO) and append an implicit jump BACK to `head` carrying
 * the current VReg of each promoted name — the body fell through, an
 * ordinary `while(1)` iteration end (mirrors the C backend's
 * `emit_loop`'s fall-through edge, `codegen.tks:5845-5850`) (A1-2, #382).
 *
 * @param LowerCtx ctx  the context after lowering the loop's body
 * @param u32 head  the loop head block a fall-through implicitly continues to
 * @param []str names  the loop's promoted-name list (head's param order)
 * @param u64 defer_base  the defer-stack index the loop's body started at
 * @return LowerCtx | error  the context with its body block closed, or a
 *                           NAMED internal error when a pending defer fails
 *                           to lower
 */
fn close_loop_body(ctx: LowerCtx, head: u32, names: []str, defer_base: u64) -> LowerCtx | error {
    if block_terminated(ctx.func, ctx.block_id) { return ctx }
    let replayed = match replay_defers(ctx, defer_base) { LowerCtx as c => c; error as err => return err }
    let args = jump_args_for_names(replayed.env, names)
    ctx_append(replayed, jump_inst(head, args, 0, 0))
}

/**
 * close_loop — the context immediately after a loop statement: positioned
 * in the exit block with `exit_env` (every promoted name now reading the
 * exit block's OWN param — the value whichever `break` was taken carried),
 * the loop's OWN growth (rodata/lifted/enums/layouts, from lowering its
 * body) carried forward, and BOTH its OWN loop-target AND its OWN defer
 * stack restored to what they were BEFORE the loop (A1-2, #382; the C1-6
 * audit's PR #553 review finding extends the loop_targets restore to
 * `defers`, the sibling side-carried field: every defer the body registered
 * ALREADY fired, once per iteration/break/continue, via `close_loop_body`/
 * `lower_break`/`lower_continue`'s own `replay_defers` calls — carrying
 * `body_done.defers` forward instead would leave those SAME entries
 * pending, so a later scope exit's `replay_defers(…, 0)` would fire them a
 * SECOND time).
 *
 * @param LowerCtx outer  the context as it stood BEFORE the loop's BODY
 *                        (after its `init`, so an init-registered defer
 *                        survives too) — its `.loop_targets`/`.defers` are
 *                        what get restored
 * @param LowerCtx body_done  the context after the loop's body (and its
 *                            fall-through close) finished lowering
 * @param u32 exit_block  the loop's exit block id (the new current block)
 * @param LEnv exit_env  the exit block's own promoted env
 * @return LowerCtx  the context positioned after the loop
 */
fn close_loop(outer: LowerCtx, body_done: LowerCtx, exit_block: u32, exit_env: LEnv) -> LowerCtx {
    LowerCtx {
        func = body_done.func; block_id = exit_block; env = exit_env
        layouts = body_done.layouts; rodata = body_done.rodata; enums = body_done.enums; lifted = body_done.lifted
        defers = outer.defers; loop_targets = outer.loop_targets
    }
}

/**
 * lower_loop — a `loop { … }` statement: jump into the body's own block
 * (`#Bhead`), lower the body there, and — when it falls through normally —
 * fire its own pending defers before an implicit jump BACK to `#Bhead`
 * (mirrors the C backend's `while(1){…}`, `codegen.tks:5813-5856`). The
 * loop's exit block (`#Bexit`) follows immediately; `break` targets it,
 * `continue` targets `#Bhead`. Both `#Bhead` and `#Bexit` are MERGE
 * points — the loop head sees the entry edge AND every back edge, the exit
 * sees every `break` edge — so both get one block-arg per SCALAR local live
 * in the enclosing env (`promote_env`), threading a loop-mutated variable
 * (a counter) correctly across iterations, exactly like an if-expression's
 * result VReg merges through its own block-arg (§2.4) (A1-2, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TLoopStmt l  the loop node
 * @return LowerStmtOut | error  the advanced context, positioned in
 *                               `#Bexit` (terminated=false — code AFTER the
 *                               loop is reachable through a `break`), or a
 *                               NAMED internal error when the body fails to
 *                               lower
 */
fn lower_loop(ctx: LowerCtx, l: checker::TLoopStmt) -> LowerStmtOut | error {
    let ictx = match lower_block(ctx, l.init) { LowerCtx as c => c; error as err => return err }
    let headb = alloc_block(ictx.func)
    let exitb = alloc_block(headb.func)
    let head_seed = promote_env(exitb.func, headb.block_id, ictx.env)
    let exit_seed = promote_env(head_seed.func, exitb.block_id, ictx.env)
    let entry_args = env_scalar_vregs(ictx.env)
    let entered = append_inst(exit_seed.func, ictx.block_id, jump_inst(headb.block_id, entry_args, 0, 0))
    let defer_base = ictx.defers.len
    let target = LoopTargets { label = l.label; head = headb.block_id; exit = exitb.block_id; defer_base = defer_base; names = head_seed.names }
    let body_seed = ctx_with_loops(ctx_with(ictx, entered, headb.block_id, head_seed.env), teko::list::push(ictx.loop_targets, target))
    let body_done = match lower_block(body_seed, l.body) { LowerCtx as c => c; error as err => return err }
    let closed = match close_loop_body(body_done, headb.block_id, head_seed.names, defer_base) { LowerCtx as c => c; error as err => return err }
    LowerStmtOut { ctx = close_loop(ictx, closed, exitb.block_id, exit_seed.env); terminated = false }
}

/** ctx_goto — switch the context to emit into `block_id` (already allocated), keeping the
    function/env unchanged — used after a branch/jump splits control into a fresh block. */
fn ctx_goto(ctx: LowerCtx, block_id: u32) -> LowerCtx {
    ctx_with(ctx, ctx.func, block_id, ctx.env)
}

/** close_arm_to — close a lowered if-arm by jumping to `target` carrying `args` as its
    block-args, UNLESS the arm's block already ended in a terminator (an early return, or a
    nested branch/jump) — such an arm's control never reaches this merge. */
fn close_arm_to(ctx: LowerCtx, target: u32, args: []u32, line: u32, col: u32) -> LFunc {
    if block_terminated(ctx.func, ctx.block_id) { return ctx.func }
    append_inst(ctx.func, ctx.block_id, jump_inst(target, args, line, col))
}

/**
 * ClosedArm — the outcome of `close_arm_replaying_defers`: the arm's own
 * closed function (the merge jump appended, or unchanged when the arm
 * already terminated) + the context a caller resumes lowering FROM (its
 * `.defers` reset to the arm's PRE-ENTRY stack — see
 * `close_arm_replaying_defers`'s own doc for why).
 */
pub type ClosedArm = struct { ctx: LowerCtx; func: LFunc }

/**
 * close_arm_replaying_defers — close a lowered if/match arm CORRECTLY
 * scoped for its OWN defers: fire every defer the arm itself registered
 * since entering it (LIFO, from `pre_arm_defers.len`) AFTER the arm's tail
 * value/effects are already captured, mirroring the C backend's
 * `emit_branch_value` (`codegen.tks:3376-3400`, which fires a branch's own
 * defers right after its tail lands in `sink`, never letting them leak past
 * the branch), THEN reset the pending-defer stack back to `pre_arm_defers`
 * before jumping to `target`.
 *
 * Without the reset, `ctx_with`'s field-copy (the SAME mechanism the C1-6
 * audit's rodata fix relies on) would carry the arm's own defer
 * registrations past the merge, where a later function-exit
 * `replay_defers(…, 0)` (`:3659`) would fire them a SECOND time —
 * UNCONDITIONALLY, even for an arm whose branch never ran at runtime (PR
 * #553 review finding: `if cond { defer { print("A") } }; print("B")`
 * called with `cond=false` must print only "B", never "A"). Arrays are
 * value types in Teko, so reusing the untouched `pre_arm_defers` slice is a
 * free truncation — the SAME pattern `close_loop` uses to restore
 * `loop_targets` (and, after this same audit, `defers` too — see
 * `close_loop`'s own doc).
 *
 * The merge jump's block-args are `value_args` (captured PRE-replay, so a
 * value arm's merge VALUE stays the pre-defer tail — the timing the
 * `lwt_defer_inside_*_value_arm` goldens pin) FOLLOWED BY each reassigned
 * enclosing scalar in `names`, each re-sampled from the POST-replay env so a
 * `defer`'s write to one reaches its merge param with the POST-defer value.
 * Before #389 F1b the scalar args were sampled from the arm's PRE-replay env,
 * silently dropping any defer write to an enclosing scalar past the merge (the
 * latent same-class miscompile F1 left as a documented residual).
 *
 * A terminated arm (an early `return`/`break`/`continue` already fired
 * every defer ITS OWN scope owns, from ITS OWN base — `lower_return`/
 * `lower_break`/`lower_continue`) never reaches `target` at all: this
 * function skips the replay for it (mirroring `close_arm_to`'s own
 * terminated-block no-op) but STILL resets `.defers`, since whatever the
 * arm registered before terminating must not leak into a sibling arm or
 * the merge either — that arm's control never reaches them.
 *
 * @param LowerCtx ctx  the context after lowering the arm's own body
 * @param []checker::TDeferStmt pre_arm_defers  the defer stack as it stood
 *                                               BEFORE the arm (its `.len`
 *                                               is the replay base, and the
 *                                               slice itself is what gets
 *                                               restored)
 * @param u32 target  the merge block id
 * @param []u32 value_args  the arm's PRE-replay value block-args (the
 *                          if/match tail-value VReg for a value arm, empty for
 *                          a statement arm) — captured BEFORE the defer replay
 *                          so the merge VALUE stays pre-defer (#389 F1b)
 * @param []u64 indices  the reassigned enclosing scalars' fixed pre-branch
 *                       INDICES the merge threads, in param order; each is read
 *                       from the POST-replay env at that index, so a `defer`'s
 *                       in-place write to one reaches its merge param with the
 *                       post-defer value (#389 F1b item 1) while a shadow the
 *                       arm appended at a higher index is ignored (#389 F1b
 *                       item 3)
 * @param u32 line  the source line to stamp the replayed defers/jump with
 * @param u32 col  the source column to stamp the replayed defers/jump with
 * @return ClosedArm | error  the closed arm + the resume context, or a
 *                             NAMED internal error when a pending defer
 *                             body fails to lower
 */
fn close_arm_replaying_defers(ctx: LowerCtx, pre_arm_defers: []checker::TDeferStmt, target: u32, value_args: []u32, indices: []u64, line: u32, col: u32) -> ClosedArm | error {
    if block_terminated(ctx.func, ctx.block_id) { return ClosedArm { ctx = ctx_with_defers(ctx, pre_arm_defers); func = ctx.func } }
    let replayed = match replay_defers(ctx, pre_arm_defers.len) { LowerCtx as c => c; error as err => return err }
    let reset = ctx_with_defers(replayed, pre_arm_defers)
    let args = append_all_u32(value_args, arm_scalar_args(replayed.env, indices))
    ClosedArm { ctx = reset; func = close_arm_to(reset, target, args, line, col) }
}

/** LowerBlockValue — the outcome of lowering a value-producing if-expression arm's
    statement block: either it fell through with the tail value in `vreg` (terminated=false
    — the LAST statement was an expression-statement whose value IS the arm's result), or an
    inner control-flow op (a `return`, the only one until A1-2's break/continue) already
    closed the block (terminated=true, `vreg` unused). */
pub type LowerBlockValue = struct { ctx: LowerCtx; terminated: bool; vreg: u32 }

/** lower_block_value — lower an if-expression arm's statement block: every statement but
    the last lowers as an ordinary effect-only statement; the last is the arm's TAIL VALUE
    (an expression-statement) unless it already terminated the block on its own. Mirrors
    emit_branch_value's "last statement is the value" shape (codegen.tks). */
fn lower_block_value(ctx: LowerCtx, body: []checker::TStatement) -> LowerBlockValue | error {
    if body.len == 0 { return error { message = "native backend N1: empty if-expression arm (internal)" } }
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i + 1 >= body.len { break }
        let out = match lower_stmt(cur, body[i]) { LowerStmtOut as x => x; error as err => return err }
        cur = out.ctx
        if out.terminated { return LowerBlockValue { ctx = cur; terminated = true; vreg = 0 } }
        i++
    }
    lower_tail_stmt(cur, body[body.len - 1])
}

/** lower_tail_stmt — an if-expression arm's final statement: an expression-statement's
    value IS the arm's tail value; any other statement kind is delegated to
    lower_tail_non_expr. */
fn lower_tail_stmt(ctx: LowerCtx, s: checker::TStatement) -> LowerBlockValue | error {
    match s {
        checker::TExprStmt as es => {
            let lo = match lower_expr(ctx, es.expr) { Lowered as x => x; error as err => return err }
            LowerBlockValue { ctx = lo.ctx; terminated = false; vreg = lo.vreg }
        }
        _ => lower_tail_non_expr(ctx, s)
    }
}

/** lower_tail_non_expr — a non-expression-statement tail: valid only if it terminates the
    arm (a `return`); anything else honest-stops (a checker invariant break — a value-typed
    if-expr arm whose tail neither returns nor yields a value). */
fn lower_tail_non_expr(ctx: LowerCtx, s: checker::TStatement) -> LowerBlockValue | error {
    let out = match lower_stmt(ctx, s) { LowerStmtOut as x => x; error as err => return err }
    if out.terminated { return LowerBlockValue { ctx = out.ctx; terminated = true; vreg = 0 } }
    error { message = "native backend N1: if-expression arm's tail statement does not yield a value (internal)" }
}

/** lower_if_expr — cond ? then : else via LBranch + per-arm blocks merging through a
    block-arg. An if-EXPRESSION (its result type is not Void) merges with the arm's tail
    value as a one-VReg block-arg; an if-STATEMENT (Void) merges with zero block-args.
    Mirrors emit_if_value/emit_if_stmt's shape (codegen.tks), SSA-lite. */
fn lower_if_expr(ctx: LowerCtx, e: checker::TExpr, f: checker::TIfExpr) -> Lowered | error {
    let co = match lower_expr(ctx, f.cond) { Lowered as x => x; error as err => return err }
    if type_is_void(e.type) { return lower_if_stmt(co.ctx, e, f, co.vreg) }
    lower_if_value(co.ctx, e, f, co.vreg)
}

/** lower_if_stmt — the Void (no-value) shape: both arms lower their statement block for
    effect only and merge with zero block-args; a missing `else` is a pass-through arm (jumps
    straight to the merge). The else-arm's own context, and the final merged context, are
    built from `then_done`/`else_done` (the ARM-THREADED context each arm's own lowering
    actually produced), NEVER from the pre-branch `ctx` — `ctx_with` only OVERRIDES `func`/
    `block_id`/`env` and copies every other field (rodata, lifted closures, …) from its FIRST
    argument, so sourcing either point from `ctx` would SILENTLY DROP whatever an arm interned
    (a genuine miscompile: a `global_addr` relocation against a symbol whose definition never
    reached the module — the SAME class of bug `lower_coalesce` had, C1-6 audit). Each arm
    closes via `close_arm_replaying_defers` (not the bare `close_arm_to`), so a `defer` EITHER
    arm registers fires only on ITS OWN branch, never leaking into the other arm or past the
    merge (PR #553 review finding). A scalar an arm RE-ASSIGNS (`reassigned_scalars`) is
    threaded through the merge as a block-param: the merge gains one param per reassigned name,
    each arm's closing jump supplies that name's CURRENT VReg (re-sampled POST-defer-replay in
    `close_arm_replaying_defers`, so a `defer { s = s + 100 }` in the arm reaches the merge with
    its post-defer value, #389 F1b item 1), and the post-merge env rebinds each to its merge
    param — otherwise an arm-local rebind (`if c { x = 5 }`) would be DROPPED at the merge and
    the name would read its stale pre-branch VReg past the `if` (the #389 A3-loop range-`for`
    back-edge root: the per-iteration `if !first { i = i+1 }` step froze the counter). A branch
    that mutates no enclosing scalar adds ZERO params and stays byte-identical (#389 F1). */
fn lower_if_stmt(ctx: LowerCtx, e: checker::TExpr, f: checker::TIfExpr, cond_vreg: u32) -> Lowered | error {
    let names = reassigned_scalars(if_arm_stmts(f), ctx.env)
    let indices = merge_scalar_indices(ctx.env, names)
    let thenb = alloc_block(ctx.func)
    let elseb = alloc_block(thenb.func)
    let mergeblk = alloc_block(elseb.func)
    let merged = add_merge_scalar_params(mergeblk.func, mergeblk.block_id, ctx.env, names)
    let br = branch_inst(cond_vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), e.line, e.col)
    let ctx1 = ctx_append(ctx_with(ctx, merged.func, ctx.block_id, ctx.env), br)
    let then_done = match lower_block(ctx_goto(ctx1, thenb.block_id), f.then_blk) { LowerCtx as c => c; error as err => return err }
    let then_closed = match close_arm_replaying_defers(then_done, ctx1.defers, mergeblk.block_id, teko::list::empty(), indices, e.line, e.col) { ClosedArm as c => c; error as err => return err }
    let else_ctx = ctx_with(then_closed.ctx, then_closed.func, elseb.block_id, ctx.env)
    let else_done = if f.has_else { match lower_block(else_ctx, f.else_blk) { LowerCtx as c => c; error as err => return err } } else { else_ctx }
    let else_closed = match close_arm_replaying_defers(else_done, ctx1.defers, mergeblk.block_id, teko::list::empty(), indices, e.line, e.col) { ClosedArm as c => c; error as err => return err }
    Lowered { ctx = ctx_with(else_closed.ctx, else_closed.func, mergeblk.block_id, merged.env); vreg = 0 }
}

/** lower_if_value — the value-producing shape: both arms' TAIL values become the merge
    block's single block-arg (the if-expression's result VReg). An if-without-else used as a
    value is out of the N1 subset (mirrors emit_if_value's own honest-stop). Mirrors
    `lower_if_stmt`'s own arm-threading discipline: `else_ctx` and the final merged context
    are built from `then_val.ctx`/`else_val.ctx`, never the pre-branch `ctx` (C1-6 audit); each
    arm closes via `close_arm_replaying_defers` so its OWN defers never leak into the other arm
    or past the merge (PR #553 review finding). A scalar an arm RE-ASSIGNS is threaded through
    the merge exactly as in `lower_if_stmt`, EXCEPT the merge's FIRST block-param is the
    if-expression's own result value — the reassigned-scalar params follow it, so each arm's
    jump supplies `[tail_value] ++ scalar_args`: the tail VALUE is captured PRE-defer-replay
    (so the merge value stays pre-defer) while the scalar args are re-sampled POST-replay inside
    `close_arm_replaying_defers`, so a `defer`'s write to a reassigned scalar reaches its merge
    param without disturbing the pre-defer merge value (#389 F1/F1b). */
fn lower_if_value(ctx: LowerCtx, e: checker::TExpr, f: checker::TIfExpr, cond_vreg: u32) -> Lowered | error {
    if !f.has_else { return error { message = "native backend N1: if-without-else used as a value not yet lowered (N2)" } }
    let names = reassigned_scalars(if_arm_stmts(f), ctx.env)
    let indices = merge_scalar_indices(ctx.env, names)
    let thenb = alloc_block(ctx.func)
    let elseb = alloc_block(thenb.func)
    let mergeblk = alloc_block(elseb.func)
    let mp = add_block_param(mergeblk.func, mergeblk.block_id)
    let merged = add_merge_scalar_params(mp.func, mergeblk.block_id, ctx.env, names)
    let br = branch_inst(cond_vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), e.line, e.col)
    let ctx1 = ctx_append(ctx_with(ctx, merged.func, ctx.block_id, ctx.env), br)
    let then_val = match lower_block_value(ctx_goto(ctx1, thenb.block_id), f.then_blk) { LowerBlockValue as x => x; error as err => return err }
    let then_closed = match close_arm_replaying_defers(then_val.ctx, ctx1.defers, mergeblk.block_id, teko::list::push(teko::list::empty(), then_val.vreg), indices, e.line, e.col) { ClosedArm as c => c; error as err => return err }
    let else_ctx = ctx_with(then_closed.ctx, then_closed.func, elseb.block_id, ctx.env)
    let else_val = match lower_block_value(else_ctx, f.else_blk) { LowerBlockValue as x => x; error as err => return err }
    let else_closed = match close_arm_replaying_defers(else_val.ctx, ctx1.defers, mergeblk.block_id, teko::list::push(teko::list::empty(), else_val.vreg), indices, e.line, e.col) { ClosedArm as c => c; error as err => return err }
    Lowered { ctx = ctx_with(else_closed.ctx, else_closed.func, mergeblk.block_id, merged.env); vreg = mp.vreg }
}

/** unwrap_optional — the inner `T` of an `Optional<T>`; any other type is already unwrapped
    (returned as-is) (A1-4, #382). */
fn unwrap_optional(t: checker::Type) -> checker::Type {
    match t {
        checker::Optional as o => o.inner
        _ => t
    }
}

/** lower_coalesce — `a ?? b`: branch on `a`'s ALREADY-LOWERED value (nonzero = present,
    mirroring the null sentinel every Optional shares with its inner type); the present arm
    merges `a` itself (already unwrapped — no re-lowering), the absent arm lowers `b` (which
    may itself diverge, e.g. `a ?? panic(...)` — its dead post-call jump is harmless, mirrors
    `lower_if_value`'s own arm-closing convention) (A1-4, #382). The final merged context is
    built from `ro.ctx` (the RHS's own POST-lowering context), NOT `ctx1` (the pre-RHS one) —
    `ctx_with` only OVERRIDES `func`/`block_id`/`env` and copies every other field (rodata,
    lifted closures, …) from its first argument, so building it from `ctx1` would SILENTLY
    DROP any rodata `co.right` interned (e.g. a string literal fed to `panic`, C1-6 — a
    genuine miscompile: the caller emits a `global_addr` relocation against a symbol whose
    definition never made it into the module). `ctx1.env` is still the right ENV (unchanged
    across both arms — neither introduces a new binding visible past the merge). */
fn lower_coalesce(ctx: LowerCtx, e: checker::TExpr, co: checker::TCoalesce) -> Lowered | error {
    let lo = match lower_expr(ctx, co.left) { Lowered as x => x; error as err => return err }
    let thenb = alloc_block(lo.ctx.func)
    let elseb = alloc_block(thenb.func)
    let mergeb = alloc_block(elseb.func)
    let mp = add_block_param(mergeb.func, mergeb.block_id)
    let br = branch_inst(lo.vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), e.line, e.col)
    let ctx1 = ctx_append(ctx_with(lo.ctx, mp.func, lo.ctx.block_id, lo.ctx.env), br)
    let then_args = teko::list::push(teko::list::empty(), lo.vreg)
    let then_func = append_inst(ctx1.func, thenb.block_id, jump_inst(mergeb.block_id, then_args, e.line, e.col))
    let else_ctx = ctx_with(ctx1, then_func, elseb.block_id, ctx1.env)
    let ro = match lower_expr(else_ctx, co.right) { Lowered as x => x; error as err => return err }
    let else_args = teko::list::push(teko::list::empty(), ro.vreg)
    let else_func = close_arm_to(ro.ctx, mergeb.block_id, else_args, e.line, e.col)
    Lowered { ctx = ctx_with(ro.ctx, else_func, mergeb.block_id, ctx1.env); vreg = mp.vreg }
}

/** lower_safe_field_access — `recv?.field` on an optional STRUCT receiver (the checker
    desugars a CLASS inner elsewhere — a TSafeFieldAccess node is always the struct route):
    branch on the receiver (nonzero = present); the present arm reads the field through its
    registered layout offset (mirrors `lower_field_access`), the absent arm merges a null
    (zero) constant of the field's machine class (A1-4, #382). */
fn lower_safe_field_access(ctx: LowerCtx, e: checker::TExpr, sfa: checker::TSafeFieldAccess) -> Lowered | error {
    let ro = match lower_expr(ctx, sfa.receiver) { Lowered as x => x; error as err => return err }
    let name = match named_type_name(unwrap_optional(sfa.receiver.type)) { str as s => s; error as err => return err }
    let layout = match find_struct_layout(ro.ctx.layouts, name) { LStructLayout as l => l; error as err => return err }
    let off = match field_offset_of(layout, sfa.field) { u32 as o => o; error as err => return err }
    let result_ty = ltype_of(unwrap_optional(e.type))
    let thenb = alloc_block(ro.ctx.func)
    let elseb = alloc_block(thenb.func)
    let mergeb = alloc_block(elseb.func)
    let mp = add_block_param(mergeb.func, mergeb.block_id)
    let br = branch_inst(ro.vreg, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), e.line, e.col)
    let ctx1 = ctx_append(ctx_with(ro.ctx, mp.func, ro.ctx.block_id, ro.ctx.env), br)
    let then_ctx = ctx_with(ctx1, ctx1.func, thenb.block_id, ctx1.env)
    let addr = ctx_alloc(then_ctx)
    let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, ro.vreg, off, e.line, e.col))
    let fld = ctx_alloc(with_addr)
    let with_load = ctx_append(fld.ctx, load_inst(fld.vreg, addr.vreg, result_ty, e.line, e.col))
    let then_args = teko::list::push(teko::list::empty(), fld.vreg)
    let then_func = append_inst(with_load.func, thenb.block_id, jump_inst(mergeb.block_id, then_args, e.line, e.col))
    let nullr_ctx = ctx_with(ctx1, then_func, elseb.block_id, ctx1.env)
    let nullr = ctx_alloc(nullr_ctx)
    let with_null = ctx_append(nullr.ctx, const_int_inst(nullr.vreg, 0 to i128, e.line, e.col))
    let else_args = teko::list::push(teko::list::empty(), nullr.vreg)
    let else_func = append_inst(with_null.func, elseb.block_id, jump_inst(mergeb.block_id, else_args, e.line, e.col))
    Lowered { ctx = ctx_with(ctx1, else_func, mergeb.block_id, ctx1.env); vreg = mp.vreg }
}

/**
 * MatchSubj — a `match`'s already-lowered SUBJECT: its resolved type (drives
 * every arm's pattern-test/bind dispatch), its scalar/base-address VReg, and
 * (for a `str` subject) its length VReg (`is_fat=false` leaves `len` unused)
 * (A1-5, #382).
 */
type MatchSubj = struct { ty: checker::Type; vreg: u32; is_fat: bool; len: u32 }

/**
 * MatchSubjOut — the context after lowering a `match`'s subject exactly ONCE,
 * plus the subject descriptor every arm reads (A1-5, #382).
 */
type MatchSubjOut = struct { ctx: LowerCtx; subj: MatchSubj }

/**
 * lower_match_subject — lower `subject` ONCE: a `str`/`[]T`-typed subject
 * through the FAT path (ptr+len, for a string arm's byte-compare); every other
 * subject through the plain scalar/address path (an enum's ordinal, a variant's
 * base address, a plain integer, ...) (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the subject's
 *                      instructions into
 * @param checker::TExpr subject  the match's typed subject expression
 * @return MatchSubjOut  the advanced context + the subject descriptor every arm
 *                       reads
 * @throws  when the subject expression itself fails to lower (propagated)
 */
fn lower_match_subject(ctx: LowerCtx, subject: checker::TExpr) -> MatchSubjOut | error {
    if is_fat_type(subject.type) {
        let fo = match lower_fat_expr(ctx, subject) { LoweredFat as x => x; error as err => return err }
        return MatchSubjOut { ctx = fo.ctx; subj = MatchSubj { ty = subject.type; vreg = fo.ptr; is_fat = true; len = fo.len } }
    }
    let lo = match lower_expr(ctx, subject) { Lowered as x => x; error as err => return err }
    MatchSubjOut { ctx = lo.ctx; subj = MatchSubj { ty = subject.type; vreg = lo.vreg; is_fat = false; len = 0 } }
}

/**
 * VariantMember — one member of an inline `checker::Variant` subject resolved
 * BY NAME: its declared INDEX (the runtime tag a variant-tag arm compares
 * against) + its own Type (a `match` binding loads the payload at this Type's
 * machine class) (A1-5, #382).
 */
type VariantMember = struct { index: u32; ty: checker::Type }

/**
 * find_variant_member — the NAMED member of `members` whose last path segment
 * is `case_name`, or a NAMED internal error (an out-of-scope non-nominal member
 * — prim/str/ error/... — is not a case A1-5 selects by name; A1-6+ widens
 * this) (A1-5, #382).
 *
 * @param []checker::Type members  the variant subject's declared members, in
 *                                 order
 * @param str case_name  the pattern's case name (a bind/field pattern's last
 *                       path segment)
 * @return VariantMember  the matching member's declared index + its own Type
 * @throws  when no member of `members` is Named `case_name` (an internal
 *          invariant break)
 */
fn find_variant_member(members: []checker::Type, case_name: str) -> VariantMember | error {
    mut i: u64 = 0
    loop {
        if i >= members.len { break }
        match members[i] {
            checker::Named as n => { if n.name == case_name { return VariantMember { index = i to u32; ty = members[i] } } }
            _ => { }
        }
        i++
    }
    error { message = teko::str::concat("native backend N1: unknown variant case `", case_name, "` (internal)") }
}

/**
 * find_enum_info — the LEnumInfo in `enums` named `name`, or `null` (a match
 * subject bound to a plain Named type that is NOT a registered enum — a bare
 * bind pattern over it always matches, A1-5, #382).
 *
 * @param []LEnumInfo enums  the program's whole enum table
 * @param str name  the subject's Named type name to look up
 * @return LEnumInfo?  the matching entry, or `null` when `name` is not a
 *                     registered enum
 */
fn find_enum_info(enums: []LEnumInfo, name: str) -> LEnumInfo? {
    mut i: u64 = 0
    loop {
        if i >= enums.len { break }
        if enums[i].name == name { return enums[i] }
        i++
    }
    null
}

/**
 * enum_member_ordinal — the declared INDEX of `member` within `ei.members` (the
 * ordinal an enum-subject pattern tests against, mirroring the checker's own
 * `check_enum_pattern`), or a NAMED internal error when the name is not a
 * member (A1-5, #382).
 *
 * @param LEnumInfo ei  the enum's declared name + member list
 * @param str member  the pattern's bare/qualified member name
 * @return u32  `member`'s declared index (its ordinal)
 * @throws  when `member` is not one of `ei.members` (an internal invariant
 *          break)
 */
fn enum_member_ordinal(ei: LEnumInfo, member: str) -> u32 | error {
    mut i: u64 = 0
    loop {
        if i >= ei.members.len { break }
        if ei.members[i] == member { return i to u32 }
        i++
    }
    error { message = teko::str::concat("native backend N1: unknown enum member `", member, "` (internal)") }
}

/**
 * bind_pattern_case_name — a BindPattern's case name (its type path's LAST
 * segment) — the name a variant/enum-subject test resolves BY (A1-5, #382).
 *
 * @param parser::BindPattern bp  the pattern to read the case name from
 * @return str  the type path's last segment name
 */
fn bind_pattern_case_name(bp: parser::BindPattern) -> str {
    let segs = bp.type_name.segments
    segs[segs.len - 1].name
}

/**
 * field_pattern_case_name — a FieldPattern's case name (its type path's LAST
 * segment), mirroring `bind_pattern_case_name` (A1-5, #382).
 *
 * @param parser::FieldPattern fp  the pattern to read the case name from
 * @return str  the type path's last segment name
 */
fn field_pattern_case_name(fp: parser::FieldPattern) -> str {
    let segs = fp.type_name.segments
    segs[segs.len - 1].name
}

/**
 * PatternTest — one arm's pattern-test outcome: `always=true` for a test that
 * matches UNCONDITIONALLY (a wildcard, or a bind that names no case) — the
 * caller then emits an unconditional jump instead of a branch (§2.4); otherwise
 * `vreg` is the bool VReg the test computed (A1-5, #382).
 */
type PatternTest = struct { ctx: LowerCtx; always: bool; vreg: u32 }

/**
 * lower_pattern_test — the boolean test `pat` applies to `subj`: a wildcard
 * always matches; a scalar/string literal tests equality; a bind/field pattern
 * tests a variant's tag OR an enum's ordinal (falling back to an unconditional
 * whole-value bind); a range/ alternation/`null` pattern is out of the A1-5
 * subset (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::Pattern pat  the arm's syntactic pattern
 * @param u32 line  the enclosing match expression's source line (patterns carry
 *                  none)
 * @param u32 col  the enclosing match expression's source column
 * @return PatternTest  the test outcome (always-true, or a computed bool VReg)
 * @throws  for a range/alternation/`null`/slice pattern, or an unresolvable
 *          case/enum name
 */
fn lower_pattern_test(ctx: LowerCtx, subj: MatchSubj, pat: parser::Pattern, line: u32, col: u32) -> PatternTest | error {
    match pat {
        parser::WildcardPattern => PatternTest { ctx = ctx; always = true; vreg = 0 }
        parser::LiteralPattern as lp => lower_literal_pattern_test(ctx, subj, lp, line, col)
        parser::BindPattern as bp => lower_bind_pattern_test(ctx, subj, bp, line, col)
        parser::FieldPattern as fp => lower_field_pattern_test(ctx, subj, fp, line, col)
        parser::RangePattern => error { message = "native backend N1: range match pattern not yet lowered (N2)" }
        parser::AltPattern => error { message = "native backend N1: alternation (`|`) match pattern not yet lowered (N2)" }
        parser::NullPattern => error { message = "native backend N1: `null` match pattern not yet lowered (N2)" }
    }
}

/**
 * lower_literal_pattern_test — a scalar-literal pattern's test: a string
 * literal compares bytes; an integer literal compares via `ICmpEq`; a float
 * literal or any other literal shape (the parser only ever emits
 * number/byte/str) is out of the A1-5 subset (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::LiteralPattern lp  the literal pattern to test
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the computed equality test
 * @throws  for a float literal, or a literal shape the parser never emits
 *          (internal)
 */
fn lower_literal_pattern_test(ctx: LowerCtx, subj: MatchSubj, lp: parser::LiteralPattern, line: u32, col: u32) -> PatternTest | error {
    match lp.value.kind {
        parser::StrLit as sl => lower_str_literal_pattern_test(ctx, subj, sl.text, line, col)
        parser::Number as n => lower_number_literal_pattern_test(ctx, subj, n, line, col)
        parser::ByteLit as b => lower_scalar_literal_pattern_test(ctx, subj, b.value to i128, line, col)
        _ => error { message = "native backend N1: unsupported literal match pattern (internal)" }
    }
}

/**
 * lower_number_literal_pattern_test — an integer-literal pattern's `ICmpEq`
 * test; a float literal pattern is out of the A1-5 subset (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::Number n  the syntactic number literal
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the computed equality test
 * @throws  when `n` is a float literal (not yet lowered)
 */
fn lower_number_literal_pattern_test(ctx: LowerCtx, subj: MatchSubj, n: parser::Number, line: u32, col: u32) -> PatternTest | error {
    if n.is_float { return error { message = "native backend N1: float match pattern not yet lowered (N2)" } }
    lower_scalar_literal_pattern_test(ctx, subj, n.value, line, col)
}

/**
 * lower_scalar_literal_pattern_test — `subj == const(value)` via `ICmpEq`
 * (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param i128 value  the constant to compare the subject against
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the computed equality test
 */
fn lower_scalar_literal_pattern_test(ctx: LowerCtx, subj: MatchSubj, value: i128, line: u32, col: u32) -> PatternTest {
    let r = ctx_alloc(ctx)
    let with_const = ctx_append(r.ctx, const_int_inst(r.vreg, value, line, col))
    let cr = ctx_alloc(with_const)
    let with_cmp = ctx_append(cr.ctx, bin_inst(cr.vreg, LBinOp::ICmpEq, subj.vreg, r.vreg, line, col))
    PatternTest { ctx = with_cmp; always = false; vreg = cr.vreg }
}

/**
 * lower_str_literal_pattern_test — a `str` literal pattern's test: the
 * subject's length must equal the literal's, ANDed with an UNROLLED
 * (compile-time-known length) per-byte equality chain over the subject's
 * rodata/fat-pointer content — no runtime string-compare exists at the LIR
 * level, so this is the "byte-wise compare" the plan calls for (A1-5, #382).
 * Requires a FAT subject (a non-string subject reaching here is an invariant
 * break).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered (FAT) subject
 * @param str text  the literal's own text
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the computed length+bytes equality test
 * @throws  when `subj` is not a FAT (str/slice) subject (internal)
 */
fn lower_str_literal_pattern_test(ctx: LowerCtx, subj: MatchSubj, text: str, line: u32, col: u32) -> PatternTest | error {
    if !subj.is_fat { return error { message = "native backend N1: string match pattern over a non-string subject (internal)" } }
    let lenr = ctx_alloc(ctx)
    let with_lenconst = ctx_append(lenr.ctx, const_int_inst(lenr.vreg, text.len to i128, line, col))
    let lcmp = ctx_alloc(with_lenconst)
    let with_lcmp = ctx_append(lcmp.ctx, bin_inst(lcmp.vreg, LBinOp::ICmpEq, subj.len, lenr.vreg, line, col))
    let bytes_test = str_pattern_bytes_test(with_lcmp, subj, text, lcmp.vreg, line, col)
    PatternTest { ctx = bytes_test.ctx; always = false; vreg = bytes_test.vreg }
}

/**
 * str_pattern_bytes_test — AND `acc0` with one equality test per byte of `text`
 * (unrolled at lowering time, since `text.len` is a compile-time constant),
 * reusing `lower_bool_and`'s branch/merge shape for each conjunction (A1-5,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context to append every byte test's
 *                      instructions into
 * @param MatchSubj subj  the match's already-lowered (FAT) subject
 * @param str text  the literal's own text (its bytes are compared one by one)
 * @param u32 acc0  the running conjunction's SEED bool VReg (the length test)
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return Lowered  the advanced context + the final conjunction's bool VReg
 */
fn str_pattern_bytes_test(ctx: LowerCtx, subj: MatchSubj, text: str, acc0: u32, line: u32, col: u32) -> Lowered {
    mut cur = ctx
    mut acc = acc0
    mut i: u64 = 0
    loop {
        if i >= text.len { break }
        let eq = str_pattern_byte_eq(cur, subj, text[i], i to u32, line, col)
        let merged = lower_bool_and(eq.ctx, acc, eq.vreg, line, col)
        cur = merged.ctx
        acc = merged.vreg
        i++
    }
    Lowered { ctx = cur; vreg = acc }
}

/**
 * str_pattern_byte_eq — the subject's byte at the CONSTANT `index` (its fat
 * pointer's base + `index`), compared for equality against the literal's own
 * byte `want` (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the byte test's
 *                      instructions into
 * @param MatchSubj subj  the match's already-lowered (FAT) subject
 * @param byte want  the literal's own byte at `index`
 * @param u32 index  the constant byte offset within the subject's content
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return Lowered  the advanced context + the byte-equality bool VReg
 */
fn str_pattern_byte_eq(ctx: LowerCtx, subj: MatchSubj, want: byte, index: u32, line: u32, col: u32) -> Lowered {
    let addr = ctx_alloc(ctx)
    let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, subj.vreg, index, line, col))
    let bl = ctx_alloc(with_addr)
    let with_load = ctx_append(bl.ctx, load_inst(bl.vreg, addr.vreg, LType::I8, line, col))
    let bc = ctx_alloc(with_load)
    let with_bconst = ctx_append(bc.ctx, const_int_inst(bc.vreg, want to i128, line, col))
    let eqr = ctx_alloc(with_bconst)
    Lowered { ctx = ctx_append(eqr.ctx, bin_inst(eqr.vreg, LBinOp::ICmpEq, bl.vreg, bc.vreg, line, col)); vreg = eqr.vreg }
}

/**
 * lower_bind_pattern_test — a BindPattern's test: over a `Variant` subject it
 * selects a CASE (by tag); over a plain `Named` subject registered as an enum
 * it selects a MEMBER (by ordinal); a slice pattern (`[]T as x`) is out of the
 * A1-5 subset; anything else always matches (binds the whole subject) (A1-5,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::BindPattern bp  the bind pattern to test
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the test outcome (always-true, or a computed bool VReg)
 * @throws  for a slice pattern, or an unresolvable variant case name
 */
fn lower_bind_pattern_test(ctx: LowerCtx, subj: MatchSubj, bp: parser::BindPattern, line: u32, col: u32) -> PatternTest | error {
    if bp.is_slice { return error { message = "native backend N1: slice match pattern not yet lowered (N2)" } }
    match subj.ty {
        checker::Variant as v => lower_variant_case_test(ctx, subj, v.members, bind_pattern_case_name(bp), line, col)
        checker::Named as n => lower_named_bind_pattern_test(ctx, subj, n, bp, line, col)
        _ => PatternTest { ctx = ctx; always = true; vreg = 0 }
    }
}

/**
 * lower_named_bind_pattern_test — a bind pattern over a plain `Named` subject:
 * an enum member's ordinal test when `n.name` is a registered enum, else an
 * unconditional (whole- value bind) match (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param checker::Named n  the subject's resolved Named type
 * @param parser::BindPattern bp  the bind pattern to test
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the test outcome (always-true, or a computed bool VReg)
 * @throws  when `n.name` is a registered enum but the pattern names an unknown
 *          member
 */
fn lower_named_bind_pattern_test(ctx: LowerCtx, subj: MatchSubj, n: checker::Named, bp: parser::BindPattern, line: u32, col: u32) -> PatternTest | error {
    match find_enum_info(ctx.enums, n.name) {
        LEnumInfo as ei => {
            let ord = match enum_member_ordinal(ei, bind_pattern_case_name(bp)) { u32 as o => o; error as err => return err }
            lower_scalar_literal_pattern_test(ctx, subj, ord to i128, line, col)
        }
        null => PatternTest { ctx = ctx; always = true; vreg = 0 }
    }
}

/**
 * lower_variant_case_test — `subj.tag == <case index>`: load the tag (field 0,
 * `I32`) off the subject's base address, then compare against the named case's
 * declared index (the variant runtime image is tag@0 + payload@8, per the
 * plan's §5.3) (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered (base-address) subject
 * @param []checker::Type members  the variant subject's declared members, in
 *                                 order
 * @param str case_name  the pattern's case name
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the computed tag-equality test
 * @throws  when `case_name` names no member of `members`
 */
fn lower_variant_case_test(ctx: LowerCtx, subj: MatchSubj, members: []checker::Type, case_name: str, line: u32, col: u32) -> PatternTest | error {
    let vm = match find_variant_member(members, case_name) { VariantMember as x => x; error as err => return err }
    let addr = ctx_alloc(ctx)
    let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, subj.vreg, 0, line, col))
    let tagr = ctx_alloc(with_addr)
    let with_tag = ctx_append(tagr.ctx, load_inst(tagr.vreg, addr.vreg, LType::I32, line, col))
    let cr = ctx_alloc(with_tag)
    let with_const = ctx_append(cr.ctx, const_int_inst(cr.vreg, vm.index to i128, line, col))
    let eqr = ctx_alloc(with_const)
    PatternTest { ctx = ctx_append(eqr.ctx, bin_inst(eqr.vreg, LBinOp::ICmpEq, tagr.vreg, cr.vreg, line, col)); always = false; vreg = eqr.vreg }
}

/**
 * lower_field_pattern_test — a FieldPattern's test: the same variant-tag test a
 * BindPattern case-select uses (a field-destructure ALSO selects a case); any
 * other subject shape is out of the A1-5 subset (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the test's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::FieldPattern fp  the field pattern to test
 * @param u32 line  the source line to stamp the emitted instructions with
 * @param u32 col  the source column to stamp the emitted instructions with
 * @return PatternTest  the computed tag-equality test
 * @throws  when the subject is not a `Variant` type
 */
fn lower_field_pattern_test(ctx: LowerCtx, subj: MatchSubj, fp: parser::FieldPattern, line: u32, col: u32) -> PatternTest | error {
    match subj.ty {
        checker::Variant as v => lower_variant_case_test(ctx, subj, v.members, field_pattern_case_name(fp), line, col)
        _ => error { message = "native backend N1: field match pattern over a non-variant subject not yet lowered (N2)" }
    }
}

/**
 * lower_pattern_binds — the bindings `pat` introduces into `ctx`'s env: a bind
 * pattern binds a name; a field pattern destructures a variant's payload struct
 * fields; a wildcard/ literal/range/alt pattern binds nothing (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to extend with the pattern's
 *                      bindings
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::Pattern pat  the arm's syntactic pattern
 * @return LowerCtx  the context with every binding `pat` introduces applied
 * @throws  when a bind/field pattern names an unresolvable variant case
 */
fn lower_pattern_binds(ctx: LowerCtx, subj: MatchSubj, pat: parser::Pattern) -> LowerCtx | error {
    match pat {
        parser::BindPattern as bp => lower_bind_pattern_binds(ctx, subj, bp)
        parser::FieldPattern as fp => lower_field_pattern_binds(ctx, subj, fp)
        _ => ctx
    }
}

/**
 * lower_bind_pattern_binds — `Foo as x`: over a `Variant` subject, `x` binds
 * the CASE's payload (loaded at offset 8, per its own machine class); otherwise
 * `x` binds the WHOLE subject VReg (or fat pair). A bindingless bind
 * (`Foo`/`Foo as _`) binds nothing (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to extend with the pattern's
 *                      binding
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::BindPattern bp  the bind pattern to apply
 * @return LowerCtx  the context with `bp`'s binding applied (unchanged when
 *                   bindingless)
 * @throws  when `bp` names an unresolvable variant case
 */
fn lower_bind_pattern_binds(ctx: LowerCtx, subj: MatchSubj, bp: parser::BindPattern) -> LowerCtx | error {
    if !bp.has_binding { return ctx }
    match subj.ty {
        checker::Variant as v => lower_variant_case_bind(ctx, subj, v.members, bind_pattern_case_name(bp), bp.binding)
        _ => bind_whole_subject(ctx, subj, bp.binding)
    }
}

/**
 * bind_whole_subject — bind `name` to the subject's own value: its fat (ptr,
 * len) pair when `subj.is_fat`, else its plain scalar/address VReg (A1-5,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context to extend with the binding
 * @param MatchSubj subj  the match's already-lowered subject
 * @param str name  the name to bind
 * @return LowerCtx  the context with `name` bound to the subject's own value
 */
fn bind_whole_subject(ctx: LowerCtx, subj: MatchSubj, name: str) -> LowerCtx {
    if subj.is_fat { return ctx_bind_fat(ctx, name, subj.vreg, subj.len) }
    ctx_bind(ctx, name, subj.vreg)
}

/**
 * lower_variant_case_bind — `Foo as x` over a variant subject: `x` binds the
 * case's PAYLOAD (a `field_addr` + `load` at offset 8, of the case type's own
 * machine class — a Ptr for a struct case, so the bound name reads through the
 * case's OWN registered layout exactly like an ordinary `TFieldAccess`) (A1-5,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context to append the load's instructions
 *                      into
 * @param MatchSubj subj  the match's already-lowered (base-address) subject
 * @param []checker::Type members  the variant subject's declared members, in
 *                                 order
 * @param str case_name  the pattern's case name
 * @param str binding  the name to bind the case's payload to
 * @return LowerCtx  the context with `binding` bound to the case's loaded
 *                   payload
 * @throws  when `case_name` names no member of `members`
 */
fn lower_variant_case_bind(ctx: LowerCtx, subj: MatchSubj, members: []checker::Type, case_name: str, binding: str) -> LowerCtx | error {
    let vm = match find_variant_member(members, case_name) { VariantMember as x => x; error as err => return err }
    let ty = ltype_of(vm.ty)
    let addr = ctx_alloc(ctx)
    let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, subj.vreg, 8, 0, 0))
    let r = ctx_alloc(with_addr)
    let with_load = ctx_append(r.ctx, load_inst(r.vreg, addr.vreg, ty, 0, 0))
    ctx_bind(with_load, binding, r.vreg)
}

/**
 * lower_field_pattern_binds — `Foo { f; g }` over a variant subject: read the
 * case's payload POINTER (offset 8), then destructure the requested fields off
 * its OWN registered struct layout; any other subject shape is out of the A1-5
 * subset (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the destructure's
 *                      instructions into
 * @param MatchSubj subj  the match's already-lowered subject
 * @param parser::FieldPattern fp  the field pattern to apply
 * @return LowerCtx  the context with every requested field bound
 * @throws  when the subject is not a `Variant` type, or the case is not a
 *          struct
 */
fn lower_field_pattern_binds(ctx: LowerCtx, subj: MatchSubj, fp: parser::FieldPattern) -> LowerCtx | error {
    match subj.ty {
        checker::Variant as v => lower_variant_field_binds(ctx, subj, v.members, fp)
        _ => error { message = "native backend N1: field match pattern over a non-variant subject not yet lowered (N2)" }
    }
}

/**
 * lower_variant_field_binds — resolve the named case's struct layout, load its
 * payload base address (offset 8), then bind each requested field by its OWN
 * registered offset/type (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append the destructure's
 *                      instructions into
 * @param MatchSubj subj  the match's already-lowered (base-address) subject
 * @param []checker::Type members  the variant subject's declared members, in
 *                                 order
 * @param parser::FieldPattern fp  the field pattern naming the case + its
 *                                 requested fields
 * @return LowerCtx  the context with every requested field bound
 * @throws  when the case is unresolvable, not a struct, or a requested field is
 *          unknown
 */
fn lower_variant_field_binds(ctx: LowerCtx, subj: MatchSubj, members: []checker::Type, fp: parser::FieldPattern) -> LowerCtx | error {
    let vm = match find_variant_member(members, field_pattern_case_name(fp)) { VariantMember as x => x; error as err => return err }
    let sname = match vm.ty { checker::Named as n => n.name; _ => return error { message = "native backend N1: field match pattern requires a struct case (internal)" } }
    let layout = match find_struct_layout(ctx.layouts, sname) { LStructLayout as l => l; error as err => return err }
    let paddr = ctx_alloc(ctx)
    let with_paddr = ctx_append(paddr.ctx, field_addr_inst(paddr.vreg, subj.vreg, 8, 0, 0))
    let base = ctx_alloc(with_paddr)
    let with_base = ctx_append(base.ctx, load_inst(base.vreg, paddr.vreg, LType::Ptr, 0, 0))
    bind_variant_fields(with_base, base.vreg, layout, fp.fields)
}

/**
 * bind_variant_fields — bind each of `fields` (in order) to its own load off
 * `base` via the registered `layout`'s offset/machine-class (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to append each field's load into
 * @param u32 base  the case's own payload base address VReg
 * @param LStructLayout layout  the case's registered struct layout
 * @param []str fields  the requested field names, in order
 * @return LowerCtx  the context with every field bound
 * @throws  when a requested field is not registered on `layout`
 */
fn bind_variant_fields(ctx: LowerCtx, base: u32, layout: LStructLayout, fields: []str) -> LowerCtx | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= fields.len { break }
        let off = match field_offset_of(layout, fields[i]) { u32 as o => o; error as err => return err }
        let fty = match field_type_of(layout, fields[i]) { LType as t => t; error as err => return err }
        let addr = ctx_alloc(cur)
        let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, base, off, 0, 0))
        let r = ctx_alloc(with_addr)
        let with_load = ctx_append(r.ctx, load_inst(r.vreg, addr.vreg, fty, 0, 0))
        cur = ctx_bind(with_load, fields[i], r.vreg)
        i++
    }
    cur
}

/**
 * MatchArmEntry — the context positioned at the START of an arm's BODY (its
 * pattern's bindings applied, and — when present — its `when` guard already
 * resolved TRUE) + the id of the NEXT-arm test block (the pattern's or guard's
 * failure target), shared by the value and statement `match` lowerings (A1-5,
 * #382).
 */
type MatchArmEntry = struct { ctx: LowerCtx; next_block: u32 }

/**
 * close_test_to — close the CURRENT test block: an unconditional jump for an
 * `always` test (§2.4's "wildcard/binding arms are an unconditional jump"),
 * else a conditional branch on the test's bool VReg (A1-5, #382).
 *
 * @param LowerCtx ctx  the context whose current block the terminator closes
 * @param PatternTest test  the arm's pattern-test outcome
 * @param u32 arm_block  the block id to enter on a match
 * @param u32 next_block  the block id to fall through to on a non-match
 * @param u32 line  the source line to stamp the terminator with
 * @param u32 col  the source column to stamp the terminator with
 * @return LowerCtx  the context with the current block closed
 */
fn close_test_to(ctx: LowerCtx, test: PatternTest, arm_block: u32, next_block: u32, line: u32, col: u32) -> LowerCtx {
    if test.always { return ctx_append(ctx, jump_inst(arm_block, teko::list::empty(), line, col)) }
    ctx_append(ctx, branch_inst(test.vreg, arm_block, teko::list::empty(), next_block, teko::list::empty(), line, col))
}

/**
 * lower_match_arm_entry — test `arm`'s pattern against `subj`; on success,
 * apply its bindings and (when present) test its `when` guard — a failed
 * pattern OR a failed guard falls through to the SAME next-arm block. Returns
 * the context positioned at the start of the arm's BODY plus the next-arm block
 * id (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned at the arm's test site
 * @param checker::TExpr e  the enclosing match expression (for its source
 *                          position)
 * @param checker::TArm arm  the arm to lower the entry (test/binds/guard) of
 * @param MatchSubj subj  the match's already-lowered subject
 * @return MatchArmEntry  the context at the arm's body start + the next-arm
 *                        block id
 * @throws  when the pattern test, its bindings, or its guard fail to lower
 */
fn lower_match_arm_entry(ctx: LowerCtx, e: checker::TExpr, arm: checker::TArm, subj: MatchSubj) -> MatchArmEntry | error {
    let test = match lower_pattern_test(ctx, subj, arm.pattern, e.line, e.col) { PatternTest as x => x; error as err => return err }
    let armb = alloc_block(test.ctx.func)
    let nextb = alloc_block(armb.func)
    let gated = close_test_to(ctx_with(test.ctx, nextb.func, test.ctx.block_id, test.ctx.env), test, armb.block_id, nextb.block_id, e.line, e.col)
    let arm_ctx = match lower_pattern_binds(ctx_goto(gated, armb.block_id), subj, arm.pattern) { LowerCtx as c => c; error as err => return err }
    if !arm.has_when { return MatchArmEntry { ctx = arm_ctx; next_block = nextb.block_id } }
    lower_match_guard(arm_ctx, arm, nextb.block_id)
}

/**
 * lower_match_guard — a `when` guard: branch on it, taking the guard-true edge
 * into a fresh body block and falling through to `next_block` (the SAME target
 * the pattern-test's own failure edge uses) on a false guard (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned at the arm's guard site
 * @param checker::TArm arm  the guarded arm (`arm.guard` is valid — `has_when`
 *                           is true)
 * @param u32 next_block  the next-arm block id a false guard falls through to
 * @return MatchArmEntry  the context at the guarded body's start + the next-arm
 *                        block id
 * @throws  when the guard expression fails to lower
 */
fn lower_match_guard(ctx: LowerCtx, arm: checker::TArm, next_block: u32) -> MatchArmEntry | error {
    let guardo = match lower_expr(ctx, arm.guard) { Lowered as x => x; error as err => return err }
    let guardb = alloc_block(guardo.ctx.func)
    let guarded = append_inst(guardb.func, guardo.ctx.block_id, branch_inst(guardo.vreg, guardb.block_id, teko::list::empty(), next_block, teko::list::empty(), arm.guard.line, arm.guard.col))
    MatchArmEntry { ctx = ctx_with(guardo.ctx, guarded, guardb.block_id, guardo.ctx.env); next_block = next_block }
}

/**
 * lower_match_arm_value — lower one VALUE-position arm: its entry
 * (test/binds/guard), its BODY as a tail-value block (mirrors an if-expression
 * arm), then a jump to the merge block carrying the tail value; returns the
 * context positioned at the next-arm test block (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned at the arm's test site
 * @param checker::TExpr e  the enclosing match expression
 * @param checker::TArm arm  the arm to lower
 * @param MatchSubj subj  the match's already-lowered subject
 * @param u32 merge_id  the merge block id the arm's tail value jumps to
 * @param []str names  the reassigned scalars the merge threads, in param order
 * @return LowerCtx  the context positioned at the next-arm test block
 * @throws  when the arm's entry or body fails to lower
 *
 * @implNote the returned context is built from `bv.ctx` (the arm's own
 * BODY-threaded context), never the incoming `ctx` — `ctx_with` copies
 * rodata/lifted-closures from its first argument, so sourcing from `ctx`
 * would drop whatever the arm's test/guard/body interned (the SAME class
 * of bug `lower_coalesce`/`lower_if_value` had, C1-6 audit). Closes via
 * `close_arm_replaying_defers` (not the bare `close_arm_to`), so a `defer`
 * this arm registers fires only on ITS OWN match, never leaking into a
 * sibling arm or past the merge (PR #553 review finding). The closing jump
 * supplies `[tail_value] ++ scalar_args`, mirroring `lower_if_value`, so a
 * scalar this arm re-assigns reaches the merge param instead of being
 * dropped (#389 F1) — the tail value is captured PRE-defer-replay while the
 * scalar args are re-sampled POST-replay inside `close_arm_replaying_defers`,
 * so a `defer`'s write to a reassigned scalar propagates without disturbing
 * the pre-defer merge value (#389 F1b item 1).
 */
fn lower_match_arm_value(ctx: LowerCtx, e: checker::TExpr, arm: checker::TArm, subj: MatchSubj, merge_id: u32, names: []str) -> LowerCtx | error {
    let indices = merge_scalar_indices(ctx.env, names)
    let step = match lower_match_arm_entry(ctx, e, arm, subj) { MatchArmEntry as x => x; error as err => return err }
    let bv = match lower_block_value(step.ctx, arm.body) { LowerBlockValue as x => x; error as err => return err }
    let closed = match close_arm_replaying_defers(bv.ctx, ctx.defers, merge_id, teko::list::push(teko::list::empty(), bv.vreg), indices, e.line, e.col) { ClosedArm as c => c; error as err => return err }
    ctx_with(closed.ctx, closed.func, step.next_block, ctx.env)
}

/**
 * lower_match_arms_value — fold `lower_match_arm_value` over every arm, in
 * order, threading the "next test" position from arm to arm; the final context
 * is the DEAD-CODE fallback position past the last arm's test (unreachable when
 * the checker's exhaustiveness holds) (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned at the first arm's test
 *                      site
 * @param checker::TExpr e  the enclosing match expression
 * @param []checker::TArm arms  the match's arms, in order
 * @param MatchSubj subj  the match's already-lowered subject
 * @param u32 merge_id  the merge block id every arm's tail value jumps to
 * @param []str names  the reassigned scalars the merge threads, in param order
 * @return LowerCtx  the context positioned past the last arm's test (the dead
 *                   fallback)
 * @throws  when any arm fails to lower
 */
fn lower_match_arms_value(ctx: LowerCtx, e: checker::TExpr, arms: []checker::TArm, subj: MatchSubj, merge_id: u32, names: []str) -> LowerCtx | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= arms.len { break }
        cur = match lower_match_arm_value(cur, e, arms[i], subj, merge_id, names) { LowerCtx as c => c; error as err => return err }
        i++
    }
    cur
}

/**
 * lower_match_value — a `match` used as a VALUE: a merge block with ONE
 * block-arg (the result), each arm's tail value feeding it; the DEAD-CODE
 * fallback past the last arm merges a defensive zero (the checker's
 * exhaustiveness makes it unreachable, mirroring
 * `emit_match_tail_fallthrough_return`'s own defensive-return spirit) (A1-5,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context positioned right after the subject
 * @param checker::TExpr e  the match expression (its `.type` is the result's
 *                          machine class)
 * @param checker::TMatchExpr m  the typed match (subject already lowered; only
 *                               `.arms` used)
 * @param MatchSubj subj  the match's already-lowered subject
 * @return Lowered  the advanced context (positioned at the merge block) + its
 *                  result VReg
 * @throws  when any arm fails to lower
 *
 * @implNote C1-6 audit: the final context is sourced from `with_zero` (the
 *           fallback-block context, which itself carries every arm's rodata
 *           and lifted-closure growth via `chain`), never the stale
 *           pre-lowering `ctx` — mirrors the `lower_coalesce` fix. A scalar an
 *           arm re-assigns is threaded through the merge as an extra param
 *           after the value param (`add_merge_scalar_params`), mirroring
 *           `lower_if_value`, EXCEPT a name any arm's PATTERN also binds is
 *           excluded (`reassigned_scalars_for_match`, review round 1 Finding
 *           2) (#389 F1).
 */
fn lower_match_value(ctx: LowerCtx, e: checker::TExpr, m: checker::TMatchExpr, subj: MatchSubj) -> Lowered | error {
    let names = reassigned_scalars_for_match(m.arms, ctx.env)
    let indices = merge_scalar_indices(ctx.env, names)
    let mergeb = alloc_block(ctx.func)
    let mp = add_block_param(mergeb.func, mergeb.block_id)
    let merged = add_merge_scalar_params(mp.func, mergeb.block_id, ctx.env, names)
    let base_ctx = ctx_with(ctx, merged.func, ctx.block_id, ctx.env)
    let chain = match lower_match_arms_value(base_ctx, e, m.arms, subj, mergeb.block_id, names) { LowerCtx as c => c; error as err => return err }
    let fb = ctx_alloc(chain)
    let with_zero = ctx_append(fb.ctx, const_int_inst(fb.vreg, 0 to i128, e.line, e.col))
    let fallback_args = merge_value_args(fb.vreg, arm_scalar_args(with_zero.env, indices))
    let closed = append_inst(with_zero.func, with_zero.block_id, jump_inst(mergeb.block_id, fallback_args, e.line, e.col))
    Lowered { ctx = ctx_with(with_zero, closed, mergeb.block_id, merged.env); vreg = mp.vreg }
}

/**
 * lower_match_arm_stmt — lower one STATEMENT-position arm: its entry
 * (test/binds/guard), its BODY for EFFECT ONLY (mirrors an if-statement arm),
 * then a jump to the merge block (no value); returns the context positioned at
 * the next-arm test block (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned at the arm's test site
 * @param checker::TExpr e  the enclosing match expression
 * @param checker::TArm arm  the arm to lower
 * @param MatchSubj subj  the match's already-lowered subject
 * @param u32 merge_id  the merge block id the arm jumps to after its body
 * @param []str names  the reassigned scalars the merge threads, in param order
 * @return LowerCtx  the context positioned at the next-arm test block
 * @throws  when the arm's entry or body fails to lower
 *
 * @implNote C1-6 audit: the returned context is sourced from `done` (the
 *           post-body context, which carries this arm's rodata and
 *           lifted-closure growth), never the stale pre-arm `ctx` — otherwise
 *           `lower_match_arms_stmt`'s fold would drop each arm's growth in
 *           turn, mirroring the `lower_coalesce` fix. Closes via
 *           `close_arm_replaying_defers` (not the bare `close_arm_to`), so a
 *           `defer` this arm registers fires only on ITS OWN match, never
 *           leaking into a sibling arm or past the merge (PR #553 review
 *           finding). The closing jump supplies `names`' current VRegs,
 *           re-sampled POST-defer-replay in `close_arm_replaying_defers`, so a
 *           scalar this arm re-assigns — INCLUDING inside a `defer` body —
 *           reaches the merge param instead of being dropped (#389 F1/F1b
 *           item 1).
 */
fn lower_match_arm_stmt(ctx: LowerCtx, e: checker::TExpr, arm: checker::TArm, subj: MatchSubj, merge_id: u32, names: []str) -> LowerCtx | error {
    let indices = merge_scalar_indices(ctx.env, names)
    let step = match lower_match_arm_entry(ctx, e, arm, subj) { MatchArmEntry as x => x; error as err => return err }
    let done = match lower_block(step.ctx, arm.body) { LowerCtx as c => c; error as err => return err }
    let closed = match close_arm_replaying_defers(done, ctx.defers, merge_id, teko::list::empty(), indices, e.line, e.col) { ClosedArm as c => c; error as err => return err }
    ctx_with(closed.ctx, closed.func, step.next_block, ctx.env)
}

/**
 * lower_match_arms_stmt — fold `lower_match_arm_stmt` over every arm, mirroring
 * `lower_match_arms_value`'s chaining (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned at the first arm's test
 *                      site
 * @param checker::TExpr e  the enclosing match expression
 * @param []checker::TArm arms  the match's arms, in order
 * @param MatchSubj subj  the match's already-lowered subject
 * @param u32 merge_id  the merge block id every arm jumps to after its body
 * @param []str names  the reassigned scalars the merge threads, in param order
 * @return LowerCtx  the context positioned past the last arm's test (the dead
 *                   fallback)
 * @throws  when any arm fails to lower
 */
fn lower_match_arms_stmt(ctx: LowerCtx, e: checker::TExpr, arms: []checker::TArm, subj: MatchSubj, merge_id: u32, names: []str) -> LowerCtx | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= arms.len { break }
        cur = match lower_match_arm_stmt(cur, e, arms[i], subj, merge_id, names) { LowerCtx as c => c; error as err => return err }
        i++
    }
    cur
}

/**
 * lower_match_stmt — a `match` used as a STATEMENT (a Void-typed `TMatchExpr`,
 * embedded via `TExprStmt` — mirrors an if-statement): a merge block with ZERO
 * block-args, each arm jumping to it after running for effect; the dead-code
 * fallback past the last arm also jumps there unconditionally (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context positioned right after the subject
 * @param checker::TExpr e  the match expression (its `.type` is Void)
 * @param checker::TMatchExpr m  the typed match (subject already lowered; only
 *                               `.arms` used)
 * @param MatchSubj subj  the match's already-lowered subject
 * @return Lowered  the advanced context (positioned at the merge block); `vreg`
 *                  unused
 * @throws  when any arm fails to lower
 *
 * @implNote C1-6 audit: the final context is sourced from `chain` (the
 *           fold's result, carrying every arm's rodata and lifted-closure
 *           growth), never the stale pre-lowering `ctx` — mirrors the
 *           `lower_coalesce` fix. A scalar an arm re-assigns is threaded
 *           through the merge as a block-param (`add_merge_scalar_params`),
 *           mirroring `lower_if_stmt`, EXCEPT a name any arm's PATTERN also
 *           binds is excluded (`reassigned_scalars_for_match`, review round
 *           1 Finding 2) (#389 F1).
 */
fn lower_match_stmt(ctx: LowerCtx, e: checker::TExpr, m: checker::TMatchExpr, subj: MatchSubj) -> Lowered | error {
    let names = reassigned_scalars_for_match(m.arms, ctx.env)
    let indices = merge_scalar_indices(ctx.env, names)
    let mergeb = alloc_block(ctx.func)
    let merged = add_merge_scalar_params(mergeb.func, mergeb.block_id, ctx.env, names)
    let base_ctx = ctx_with(ctx, merged.func, ctx.block_id, ctx.env)
    let chain = match lower_match_arms_stmt(base_ctx, e, m.arms, subj, mergeb.block_id, names) { LowerCtx as c => c; error as err => return err }
    let closed = append_inst(chain.func, chain.block_id, jump_inst(mergeb.block_id, arm_scalar_args(chain.env, indices), e.line, e.col))
    Lowered { ctx = ctx_with(chain, closed, mergeb.block_id, merged.env); vreg = 0 }
}

/**
 * lower_match — a `match` used as either a VALUE (`e.type` is not Void) or a
 * STATEMENT (`e.type` is Void). Lowers the subject ONCE, then a linear TEST
 * CHAIN: each arm's pattern test branches into its own body block on success,
 * or falls through to the NEXT arm's test on failure; mirrors `lower_if_expr`'s
 * value/void split (A1-5, #382).
 *
 * @param LowerCtx ctx  the lowering context to lower the whole match into
 * @param checker::TExpr e  the match expression node
 * @param checker::TMatchExpr m  the typed match (subject + arms)
 * @return Lowered  the advanced context + the match's result VReg (unused for a
 *                  statement)
 * @throws  when the subject, any pattern test, or any arm body fails to lower
 */
fn lower_match(ctx: LowerCtx, e: checker::TExpr, m: checker::TMatchExpr) -> Lowered | error {
    let so = match lower_match_subject(ctx, m.subject) { MatchSubjOut as x => x; error as err => return err }
    if type_is_void(e.type) { return lower_match_stmt(so.ctx, e, m, so.subj) }
    lower_match_value(so.ctx, e, m, so.subj)
}

/** is_fat_type — is `t` a fat-pointer-VALUED type (`str` or `[]T`)? Selects the
    ptr+len lowering path (`lower_fat_expr`/`lenv_bind_fat`) over the plain scalar one
    (A1-4, #382). */
fn is_fat_type(t: checker::Type) -> bool {
    match t {
        checker::Str => true
        checker::Slice => true
        _ => false
    }
}

/** LoweredFat — the result of lowering a fat-pointer-VALUED expression: the updated context
    + its ptr VReg + its len VReg (A1-4, #382 — the plan's two-VReg `FatVReg` threading). */
pub type LoweredFat = struct { ctx: LowerCtx; ptr: u32; len: u32 }

/** lower_fat_expr — lower a `str`/`[]T`-typed expression to its (ptr, len) pair. Only the
    CLOSED set of fat-pointer PRODUCERS is recognized: a string literal (fresh rodata), an
    array literal (fresh alloca + a compile-time-known element count), and a local bound via
    `lenv_bind_fat` (a `let` of str/slice type). Any other producer (a call result, a deeper
    field/index chain, …) honest-stops — those arrive with a wider fat-pointer ABI in a later
    phase (A1-4, #382). */
pub fn lower_fat_expr(ctx: LowerCtx, e: checker::TExpr) -> LoweredFat | error {
    match e.kind {
        checker::TStrLit as s => lower_str_lit_fat(ctx, e, s)
        checker::TArrayLit as al => lower_array_lit_fat(ctx, e, al)
        checker::TVar as v => lower_var_fat(ctx, e, v)
        checker::TFieldAccess as fa => lower_fat_field(ctx, fa)
        _ => error { message = teko::str::concat("native backend N1: fat-pointer receiver `", texpr_kind_name(e), "` not yet lowered (N2)") }
    }
}

/**
 * lower_fat_field — the (ptr, len) pair of a `[]T`/`str` field of a struct receiver (#594 T-B6): lower
 * the receiver to its base address, then read ptr = `LLoad(LFieldAddr(base, fieldoff))` (the `Ptr`
 * class; in a rodata const the slot was relocated to the target array by T-B5/the writers) and len =
 * `LLoad(LFieldAddr(base, fieldoff + POINTER_SIZE))` (`I64`, the inline element count). Matches the
 * 16-byte fat-field layout (`layout_of_fields` via `field_layout_size`): ptr@fieldoff, len@fieldoff+8.
 * This is the arm that lets both engines read an ABI-descriptor const's slice field (the C backend
 * uses its own `.ptr`/`.len`).
 *
 * @param ctx  the lowering context
 * @param fa   the field access (a struct receiver + a fat field name)
 * @return     the (ptr, len) fat pair
 * @throws     when the receiver is not a struct with a registered layout, or the field is unknown
 * @since #594 T-B6
 */
fn lower_fat_field(ctx: LowerCtx, fa: checker::TFieldAccess) -> LoweredFat | error {
    let ro = match lower_expr(ctx, fa.receiver) { Lowered as x => x; error as e => return e }
    let name = match named_type_name(fa.receiver.type) { str as s => s; error as e => return e }
    let layout = match find_struct_layout(ro.ctx.layouts, name) { LStructLayout as l => l; error as e => return e }
    let off = match field_offset_of(layout, fa.field) { u32 as o => o; error as e => return e }
    let pa = ctx_alloc(ro.ctx)
    let with_pa = ctx_append(pa.ctx, field_addr_inst(pa.vreg, ro.vreg, off, fa.receiver.line, fa.receiver.col))
    let pr = ctx_alloc(with_pa)
    let with_pr = ctx_append(pr.ctx, load_inst(pr.vreg, pa.vreg, LType::Ptr, fa.receiver.line, fa.receiver.col))
    let la = ctx_alloc(with_pr)
    let with_la = ctx_append(la.ctx, field_addr_inst(la.vreg, ro.vreg, off + ltype_size(LType::Ptr), fa.receiver.line, fa.receiver.col))
    let lr = ctx_alloc(with_la)
    LoweredFat { ctx = ctx_append(lr.ctx, load_inst(lr.vreg, la.vreg, LType::I64, fa.receiver.line, fa.receiver.col)); ptr = pr.vreg; len = lr.vreg }
}

/**
 * lower_var_fat — a str/slice variable reference to its (ptr, len) fat pair (A1-4, #382). A local
 * bound via `lenv_bind_fat` (a `let` of str/slice type) resolves through the FAT env; a name that is
 * NOT a fat local resolves to a module-level str/slice AGGREGATE const materialized in rodata (#594
 * crumb 6), whose ptr is its rodata symbol and whose len is derived from the interned byte count.
 *
 * @param ctx  the lowering context
 * @param e    the fat-valued reference expression (carries its str/slice type + source position)
 * @param v    the typed variable node (the referenced name)
 * @return     the (ptr, len) fat pair
 * @throws     when the name is neither a fat local nor an interned str/slice aggregate const
 */
fn lower_var_fat(ctx: LowerCtx, e: checker::TExpr, v: checker::TVar) -> LoweredFat | error {
    let hit = lenv_lookup_fat(ctx.env, v.name)
    if hit.found && hit.has_len { return LoweredFat { ctx = ctx; ptr = hit.ptr; len = hit.len } }
    match find_const_rodata(ctx.rodata, v.name) {
        LRodata as r => lower_const_fat(ctx, e, r)
        null => error { message = teko::str::concat("native backend N1: `", v.name, "` is not a fat-pointer local (internal)") }
    }
}

/**
 * lower_const_fat — a module-level str/slice aggregate const's (ptr, len) fat pair (#594 crumb 6):
 * the ptr is the address of its interned rodata symbol (`LGlobalAddr`) and the len is its element
 * count, derived from the interned byte count and the value's own type — a `str` counts its raw UTF-8
 * bytes (stride 1), a `[]T` counts elements at the SAME element stride the indexer uses
 * (`ltype_of(element)`), so a `.len` read and a `[i]` read agree.
 *
 * @param ctx  the lowering context to append into
 * @param e    the fat-valued reference expression (its str/slice type + source position)
 * @param r    the const's interned rodata entry (symbol + raw bytes)
 * @return     the (ptr, len) fat pair
 * @throws     when the reference's type is not a str/slice (an interned aggregate never is otherwise)
 */
fn lower_const_fat(ctx: LowerCtx, e: checker::TExpr, r: LRodata) -> LoweredFat | error {
    let n = match const_fat_len(e.type, r.bytes.len to u32) { u32 as x => x; error as err => return err }
    let ptr = ctx_alloc(ctx)
    let with_ptr = ctx_append(ptr.ctx, global_addr_inst(ptr.vreg, r.symbol, e.line, e.col))
    let lenr = ctx_alloc(with_ptr)
    let with_len = ctx_append(lenr.ctx, const_int_inst(lenr.vreg, n to i128, e.line, e.col))
    LoweredFat { ctx = with_len; ptr = ptr.vreg; len = lenr.vreg }
}

/**
 * const_fat_len — the element count of a materialized str/slice aggregate const from its interned
 * byte length and its type (#594 crumb 6): a `str` is `byte_len` raw bytes (stride 1); a `[]T` is
 * `byte_len / stride` where `stride = ltype_size(ltype_of(element))`, the EXACT stride
 * `lower_index_slice` folds an index against — so the length and the indexing agree byte-for-byte on
 * both engines.
 *
 * @param t         the const's resolved value type (`Str` or `Slice`)
 * @param byte_len  the interned rodata blob's byte length
 * @return          the element count the fat pair's len half carries
 * @throws          when `t` is neither a str nor a slice (unreachable for an interned aggregate)
 */
fn const_fat_len(t: checker::Type, byte_len: u32) -> u32 | error {
    match t {
        checker::Str => byte_len
        checker::Slice as s => const_slice_len(s.element, byte_len)
        _ => error { message = "native backend N1: aggregate const fat receiver is not a str/slice (internal)" }
    }
}

/**
 * const_slice_len — a materialized `[]T` const's element count: `byte_len / stride`, with the element
 * stride taken from `ltype_of(element)` so it matches `lower_index_slice` (#594 crumb 6). A
 * zero-stride element (a `void`-classed type) never reaches here — the serializer rejects it — so the
 * division is always exact.
 *
 * @param element   the slice's element type
 * @param byte_len  the interned rodata blob's byte length
 * @return          the element count
 * @throws          when the element's machine stride is zero (unreachable — rejected at serialize)
 */
fn const_slice_len(element: checker::Type, byte_len: u32) -> u32 | error {
    let stride = ltype_size(ltype_of(element))
    if stride == 0 { return error { message = "native backend N1: aggregate const slice has a zero-stride element (internal)" } }
    byte_len / stride
}

/** rodata_symbol — the deterministic symbol for the Nth interned rodata entry — an
    assembler-local-style name (`.Lstr<N>`) that never collides with a Teko-visible symbol
    (A1-4, #382). */
fn rodata_symbol(index: u64) -> str {
    teko::str::concat(".Lstr", teko::u64_to_str(index))
}

/** str_to_bytes — a str's raw UTF-8 content as a `[]byte` (the rodata entry's payload)
    (A1-4, #382). */
fn str_to_bytes(s: str) -> []byte {
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= s.len { break }
        out = teko::list::push(out, s[i])
        i++
    }
    out
}

/** InternedRodata — the updated context (its rodata table grown by one) + the fresh entry's
    symbol (A1-4, #382). */
pub type InternedRodata = struct { ctx: LowerCtx; symbol: str }

/** intern_rodata — append a fresh rodata entry holding `text`'s UTF-8 bytes, returning the
    advanced context + the entry's symbol (A1-4, #382). No deduplication — each call site
    interns its own entry; a future pass may fold identical entries without changing this
    lowering's correctness. */
fn intern_rodata(ctx: LowerCtx, text: str) -> InternedRodata {
    let sym = rodata_symbol(ctx.rodata.len)
    let entry = LRodata { symbol = sym; bytes = str_to_bytes(text); relocs = teko::list::empty() }
    InternedRodata { ctx = ctx_with_rodata(ctx, teko::list::push(ctx.rodata, entry)); symbol = sym }
}

/** lower_str_bytes_fat — materialize a raw str's UTF-8 bytes as a rodata entry + its
    (ptr, len) fat pair — shared by a `TStrLit` and an interpolation piece literal
    (A1-4, #382). */
fn lower_str_bytes_fat(ctx: LowerCtx, text: str, line: u32, col: u32) -> LoweredFat {
    let interned = intern_rodata(ctx, text)
    let ptr = ctx_alloc(interned.ctx)
    let with_ptr = ctx_append(ptr.ctx, global_addr_inst(ptr.vreg, interned.symbol, line, col))
    let lenr = ctx_alloc(with_ptr)
    let with_len = ctx_append(lenr.ctx, const_int_inst(lenr.vreg, text.len to i128, line, col))
    LoweredFat { ctx = with_len; ptr = ptr.vreg; len = lenr.vreg }
}

/** lower_str_lit_fat — a `TStrLit`'s (ptr, len) pair (A1-4, #382). */
fn lower_str_lit_fat(ctx: LowerCtx, e: checker::TExpr, s: checker::TStrLit) -> LoweredFat {
    lower_str_bytes_fat(ctx, s.text, e.line, e.col)
}

/** lower_str_lit — a `TStrLit` in a plain (scalar) VALUE position: its ptr VReg (the len is
    dropped — `str` collapses to the single Ptr machine class, matching `ltype_of`; a
    consumer that needs the length reads it through `lower_fat_expr` instead) (A1-4, #382). */
fn lower_str_lit(ctx: LowerCtx, e: checker::TExpr, s: checker::TStrLit) -> Lowered {
    let f = lower_str_lit_fat(ctx, e, s)
    Lowered { ctx = f.ctx; vreg = f.ptr }
}

/** two_args — a two-element VReg argument list (the shape every `tk_str_concat`/formatter
    call below takes) (A1-4, #382). */
fn two_args(a: u32, b: u32) -> []u32 {
    teko::list::push(teko::list::push(teko::list::empty(), a), b)
}

/** single_arg — a one-element VReg argument list (A1-4, #382). */
fn single_arg(a: u32) -> []u32 {
    teko::list::push(teko::list::empty(), a)
}

/** lower_interp_piece — one interpolation PIECE literal (a raw str span, not a TExpr) as its
    ptr VReg — the same rodata materialization a `TStrLit` gets, the length dropped (A1-4,
    #382). */
fn lower_interp_piece(ctx: LowerCtx, text: str, line: u32, col: u32) -> Lowered {
    let f = lower_str_bytes_fat(ctx, text, line, col)
    Lowered { ctx = f.ctx; vreg = f.ptr }
}

/** lower_interp_hole_prim — a NO-FORMAT-SPEC hole of a resolved primitive type: an integer
    formats through the runtime's `tk_i64_to_str`/`tk_u64_to_str` (by signedness, mirroring
    the C backend's own no-spec builders); a float/bool hole is out of the A1-4 subset (A1-4,
    #382 — TFSpecNone's full family is a later closure). */
fn lower_interp_hole_prim(ctx: LowerCtx, h: checker::TExpr, k: checker::PrimKind) -> Lowered | error {
    if prim_is_float_kind(k) { return error { message = "native backend N1: float interpolation hole not yet lowered (N2)" } }
    if k == checker::PrimKind::Bool { return error { message = "native backend N1: bool interpolation hole not yet lowered (N2)" } }
    let ho = match lower_expr(ctx, h) { Lowered as x => x; error as err => return err }
    let sym = if prim_is_signed_int(k) { "tk_i64_to_str" } else { "tk_u64_to_str" }
    let r = ctx_alloc(ho.ctx)
    Lowered { ctx = ctx_append(r.ctx, call_inst(r.vreg, sym, single_arg(ho.vreg), false, h.line, h.col)); vreg = r.vreg }
}

/** lower_interp_hole_none — a NO-FORMAT-SPEC hole (`TFSpecNone`): a `str` hole passes
    through unchanged; a primitive hole formats via `lower_interp_hole_prim`; any other hole
    type is out of the A1-4 subset (A1-4, #382). */
fn lower_interp_hole_none(ctx: LowerCtx, h: checker::TExpr) -> Lowered | error {
    match h.type {
        checker::Str => lower_expr(ctx, h)
        checker::Prim as p => lower_interp_hole_prim(ctx, h, p.kind)
        _ => error { message = "native backend N1: interpolation hole of this type not yet lowered (N2)" }
    }
}

/** lower_interp_hole — one interpolation hole's str-VALUED VReg, per its format spec
    (A1-4, #382). Only `TFSpecNone` (no `:spec`) is closed; a static (`:F2`) or dynamic
    (`:[…]`) spec is out of the A1-4 subset — a later closure over `emit_interp`'s full
    `tk_fmt_*` family. */
fn lower_interp_hole(ctx: LowerCtx, h: checker::TExpr, spec: checker::TFSpec) -> Lowered | error {
    match spec.kind {
        checker::TFSpecNone => lower_interp_hole_none(ctx, h)
        checker::TFSpecStatic => error { message = "native backend N1: static interpolation format spec not yet lowered (N2)" }
        checker::TFSpecDynamic => error { message = "native backend N1: dynamic interpolation format spec not yet lowered (N2)" }
    }
}

/** lower_interp — `$"…{expr}…"`: nested `tk_str_concat` calls over `pieces[0] ++
    fmt(holes[0]) ++ pieces[1] ++ … ++ pieces[last]`, left-associative (mirrors the C
    backend's own nesting, `codegen.tks`'s `emit_interp`). Not itself run by the interp oracle
    (the concat/format symbols are runtime builtins outside the N1 run subset — honest-stops
    gracefully AT RUNTIME like any other unrecognized call, per the existing convention); this
    closes the LOWERING honest-stop only (A1-4, #382). */
fn lower_interp(ctx: LowerCtx, e: checker::TExpr, ip: checker::TInterp) -> Lowered | error {
    let seg0 = lower_interp_piece(ctx, ip.pieces[0], e.line, e.col)
    mut cur = seg0.ctx
    mut acc = seg0.vreg
    mut i: u64 = 0
    loop {
        if i >= ip.holes.len { break }
        let spec = if i < ip.specs.len { ip.specs[i] } else { checker::TFSpec { kind = checker::TFSpecNone { } } }
        let ho = match lower_interp_hole(cur, ip.holes[i], spec) { Lowered as x => x; error as err => return err }
        let cr = ctx_alloc(ho.ctx)
        let with_concat = ctx_append(cr.ctx, call_inst(cr.vreg, "tk_str_concat", two_args(acc, ho.vreg), false, e.line, e.col))
        let piece = lower_interp_piece(with_concat, ip.pieces[i + 1], e.line, e.col)
        let pr = ctx_alloc(piece.ctx)
        cur = ctx_append(pr.ctx, call_inst(pr.vreg, "tk_str_concat", two_args(cr.vreg, piece.vreg), false, e.line, e.col))
        acc = pr.vreg
        i++
    }
    Lowered { ctx = cur; vreg = acc }
}

/** lower_in_expr — `lhs in [e0, e1, …]`: the lhs lowers ONCE, then each element compares
    equal via `ICmpEq`/`FCmpEq` (by the lhs's PrimKind), ORed together bitwise (`IOr` — the
    comparisons are always 0/1, so a bitwise OR IS a boolean OR; `IOr` is declared but not yet
    RUN by the interp oracle, N2 — this closes the LOWERING honest-stop only, mirroring
    `lower_interp`'s own scope note) (A1-4, #382). A non-primitive lhs/element (e.g. a `str`
    membership test) is out of the A1-4 subset via `prim_kind_of`'s existing honest-stop. */
fn lower_in_expr(ctx: LowerCtx, e: checker::TExpr, ine: checker::TInExpr) -> Lowered | error {
    if ine.elems.len == 0 { return error { message = "native backend N1: empty `in`-expression not yet lowered (N2)" } }
    let lo = match lower_expr(ctx, ine.lhs) { Lowered as x => x; error as err => return err }
    let k = match prim_kind_of(ine.lhs.type) { checker::PrimKind as p => p; error as err => return err }
    let eq = if prim_is_float_kind(k) { LBinOp::FCmpEq } else { LBinOp::ICmpEq }
    mut cur = lo.ctx
    mut acc: u32 = 0
    mut i: u64 = 0
    loop {
        if i >= ine.elems.len { break }
        let eo = match lower_expr(cur, ine.elems[i]) { Lowered as x => x; error as err => return err }
        let cr = ctx_alloc(eo.ctx)
        let with_cmp = ctx_append(cr.ctx, bin_inst(cr.vreg, eq, lo.vreg, eo.vreg, e.line, e.col))
        if i == 0 {
            acc = cr.vreg
            cur = with_cmp
        } else {
            let orr = ctx_alloc(with_cmp)
            cur = ctx_append(orr.ctx, bin_inst(orr.vreg, LBinOp::IOr, acc, cr.vreg, e.line, e.col))
            acc = orr.vreg
        }
        i++
    }
    Lowered { ctx = cur; vreg = acc }
}

/** named_type_name — the canonical name of a `Named` (struct) type, for looking up its
    registered layout; any other type shape (the receiver isn't a struct) is out of the
    A1-3 subset. */
fn named_type_name(t: checker::Type) -> str | error {
    match t {
        checker::Named as n => n.name
        _ => error { message = "native backend N1: field/index access on a non-struct receiver not yet lowered (N2)" }
    }
}

/** find_struct_layout — the registered LStructLayout named `name`, or a NAMED internal
    error (the checker guarantees every Named struct type was declared, so a miss here is
    an invariant break, not a user error). */
fn find_struct_layout(layouts: []LStructLayout, name: str) -> LStructLayout | error {
    mut i: u64 = 0
    loop {
        if i >= layouts.len { break }
        if layouts[i].name == name { return layouts[i] }
        i++
    }
    error { message = teko::str::concat("native backend N1: no layout registered for struct `", name, "` (internal)") }
}

/** field_offset_of — the byte offset of `field` within `layout`, or a NAMED internal error
    (the checker guarantees the field exists on the struct — a miss here is an invariant
    break). */
fn field_offset_of(layout: LStructLayout, field: str) -> u32 | error {
    mut i: u64 = 0
    loop {
        if i >= layout.field_names.len { break }
        if layout.field_names[i] == field { return layout.field_offsets[i] }
        i++
    }
    error { message = teko::str::concat("native backend N1: unknown field `", field, "` on struct `", layout.name, "` (internal)") }
}

/**
 * field_type_of — the machine class of `field` within `layout`, or a NAMED
 * internal error (mirrors `field_offset_of`; a `match` FieldPattern destructure
 * reads a field it did not itself type-check, so it needs the LOAD width
 * straight out of the layout table — A1-5, #382).
 *
 * @param LStructLayout layout  the struct's registered layout
 * @param str field  the field name to look up
 * @return LType  `field`'s registered machine class
 * @throws  when `field` is not registered on `layout` (an internal invariant
 *          break)
 */
fn field_type_of(layout: LStructLayout, field: str) -> LType | error {
    mut i: u64 = 0
    loop {
        if i >= layout.field_names.len { break }
        if layout.field_names[i] == field { return layout.field_types[i] }
        i++
    }
    error { message = teko::str::concat("native backend N1: unknown field `", field, "` on struct `", layout.name, "` (internal)") }
}

/** lower_struct_init — `Name { f = v, … }`: alloca a slot sized/aligned per the struct's
    registered layout, then store each field's lowered value at its offset (declared
    order). The struct's "value" is its alloca'd BASE ADDRESS (a Ptr VReg) — the memory
    model every aggregate in the A1-3 subset shares (§5.1: the interp is an exit-code
    oracle, not a byte-accurate simulator; A2+ isel reads the real byte layout off
    LStructLayout, not off this VReg's class). */
fn lower_struct_init(ctx: LowerCtx, e: checker::TExpr, si: checker::TStructInit) -> Lowered | error {
    let name = match named_type_name(e.type) { str as s => s; error as err => return err }
    let layout = match find_struct_layout(ctx.layouts, name) { LStructLayout as l => l; error as err => return err }
    let base = ctx_alloc(ctx)
    let with_alloca = ctx_append(base.ctx, alloca_inst(base.vreg, layout.size, layout.align, e.line, e.col))
    store_struct_fields(with_alloca, base.vreg, layout, si.field_names, si.field_vals, e.line, e.col)
}

/** store_struct_fields — lower each field value in turn, storing it at its layout offset
    from `base`; the result VReg is `base` itself (the struct's address, unchanged by the
    stores). */
fn store_struct_fields(ctx: LowerCtx, base: u32, layout: LStructLayout, field_names: []str, field_vals: []checker::TExpr, line: u32, col: u32) -> Lowered | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= field_names.len { break }
        let vo = match lower_expr(cur, field_vals[i]) { Lowered as x => x; error as err => return err }
        let off = match field_offset_of(layout, field_names[i]) { u32 as o => o; error as err => return err }
        let addr = ctx_alloc(vo.ctx)
        let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, base, off, line, col))
        cur = ctx_append(with_addr, store_inst(addr.vreg, vo.vreg, ltype_of(field_vals[i].type), line, col))
        i++
    }
    Lowered { ctx = cur; vreg = base }
}

/** lower_field_access — `recv.field` on a struct receiver: lower the receiver to its base
    address, compute the field's address via its registered layout offset, then load its
    value. `.len` on a str/slice receiver (A1-4, #382) reads the receiver's ALREADY-CARRIED
    length VReg instead — no memory traffic. An error's diagnostic fields / `Ref<T>.value`
    remain out of the A1-3/A1-4 subset. */
fn lower_field_access(ctx: LowerCtx, e: checker::TExpr, fa: checker::TFieldAccess) -> Lowered | error {
    if fa.field == "len" && is_fat_type(fa.receiver.type) { return lower_len_field(ctx, fa) }
    let ro = match lower_expr(ctx, fa.receiver) { Lowered as x => x; error as err => return err }
    let name = match named_type_name(fa.receiver.type) { str as s => s; error as err => return err }
    let layout = match find_struct_layout(ro.ctx.layouts, name) { LStructLayout as l => l; error as err => return err }
    let off = match field_offset_of(layout, fa.field) { u32 as o => o; error as err => return err }
    let addr = ctx_alloc(ro.ctx)
    let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, ro.vreg, off, e.line, e.col))
    let r = ctx_alloc(with_addr)
    Lowered { ctx = ctx_append(r.ctx, load_inst(r.vreg, addr.vreg, ltype_of(e.type), e.line, e.col)); vreg = r.vreg }
}

/** lower_len_field — `recv.len` on a str/slice receiver: the length half of the receiver's
    already-lowered fat pair, read directly (no `load` — A1-4, #382, §2.3). */
fn lower_len_field(ctx: LowerCtx, fa: checker::TFieldAccess) -> Lowered | error {
    let fo = match lower_fat_expr(ctx, fa.receiver) { LoweredFat as x => x; error as err => return err }
    Lowered { ctx = fo.ctx; vreg = fo.len }
}

/** slice_element_type — the element type of a `[]T` (Slice) type; any other receiver shape
    (a `str`'s fat pointer arrives with A1-4) is out of the A1-3 subset. */
fn slice_element_type(t: checker::Type) -> checker::Type | error {
    match t {
        checker::Slice as s => s.element
        _ => error { message = "native backend N1: index receiver is not a slice (N2)" }
    }
}

/** const_index_addr — a CONSTANT index folds directly into a static byte offset
    (`index * stride`), a single `field_addr` (no runtime multiply). */
fn const_index_addr(ctx: LowerCtx, base: u32, idx_value: i128, stride: u32, line: u32, col: u32) -> Lowered {
    let offset = (idx_value * (stride to i128)) to u32
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, field_addr_inst(r.vreg, base, offset, line, col)); vreg = r.vreg }
}

/** dynamic_index_addr — a NON-constant index multiplies through an ordinary `IMul` (index
    * stride) then `IAdd`s onto `base` — `LFieldAddr.offset` only ever carries a compile-time
    constant, so a runtime-computed byte offset is plain integer arithmetic on the address
    VReg instead (the plan's §2.1 resolution). */
fn dynamic_index_addr(ctx: LowerCtx, base: u32, index: checker::TExpr, stride: u32, line: u32, col: u32) -> Lowered | error {
    let io = match lower_expr(ctx, index) { Lowered as x => x; error as err => return err }
    let sc = ctx_alloc(io.ctx)
    let with_stride = ctx_append(sc.ctx, const_int_inst(sc.vreg, stride to i128, line, col))
    let mr = ctx_alloc(with_stride)
    let with_mul = ctx_append(mr.ctx, bin_inst(mr.vreg, LBinOp::IMul, io.vreg, sc.vreg, line, col))
    let ar = ctx_alloc(with_mul)
    Lowered { ctx = ctx_append(ar.ctx, bin_inst(ar.vreg, LBinOp::IAdd, base, mr.vreg, line, col)); vreg = ar.vreg }
}

/** index_addr — the element address for `recv[index]`: `const_index_addr` when `index` is
    a literal integer (folds to a single instruction), else `dynamic_index_addr`. */
fn index_addr(ctx: LowerCtx, base: u32, index: checker::TExpr, stride: u32, line: u32, col: u32) -> Lowered | error {
    match index.kind {
        checker::TNumber as n => if n.is_float { dynamic_index_addr(ctx, base, index, stride, line, col) } else { const_index_addr(ctx, base, n.value, stride, line, col) }
        _ => dynamic_index_addr(ctx, base, index, stride, line, col)
    }
}

/** lower_index — `recv[index]`: a `str` receiver (A1-4, #382) indexes its BYTE at the fat
    pointer's ptr half (element class I8, stride 1); a `[]T` receiver indexes its Slice
    element (unchanged from A1-3). Either way the address is folded when `index` is a
    constant, else computed via `index_addr`'s runtime multiply. */
fn lower_index(ctx: LowerCtx, e: checker::TExpr, ix: checker::TIndex) -> Lowered | error {
    match ix.receiver.type {
        checker::Str => lower_index_str(ctx, e, ix)
        _ => lower_index_slice(ctx, e, ix)
    }
}

/** lower_index_str — `recv[index]` on a `str` receiver: the byte at `index` in its rodata/
    fat-pointer content (A1-4, #382). */
fn lower_index_str(ctx: LowerCtx, e: checker::TExpr, ix: checker::TIndex) -> Lowered | error {
    let ro = match lower_fat_expr(ctx, ix.receiver) { LoweredFat as x => x; error as err => return err }
    let elem_ty = LType::I8
    let addr_out = match index_addr(ro.ctx, ro.ptr, ix.index, ltype_size(elem_ty), e.line, e.col) { Lowered as x => x; error as err => return err }
    let r = ctx_alloc(addr_out.ctx)
    Lowered { ctx = ctx_append(r.ctx, load_inst(r.vreg, addr_out.vreg, elem_ty, e.line, e.col)); vreg = r.vreg }
}

/** lower_index_slice — `recv[index]` on a `[]T` receiver (A1-3 behavior, unchanged): lower
    the receiver to its base address, compute the element's address (folded when `index` is
    constant), then load its value. */
fn lower_index_slice(ctx: LowerCtx, e: checker::TExpr, ix: checker::TIndex) -> Lowered | error {
    let ro = match lower_expr(ctx, ix.receiver) { Lowered as x => x; error as err => return err }
    match slice_element_type(ix.receiver.type) { checker::Type => { }; error as err => return err }
    let elem_ty = ltype_of(e.type)
    let addr_out = match index_addr(ro.ctx, ro.vreg, ix.index, ltype_size(elem_ty), e.line, e.col) { Lowered as x => x; error as err => return err }
    let r = ctx_alloc(addr_out.ctx)
    Lowered { ctx = ctx_append(r.ctx, load_inst(r.vreg, addr_out.vreg, elem_ty, e.line, e.col)); vreg = r.vreg }
}

/** lower_array_lit — `[e0, e1, …]`: alloca `elements.len * stride` bytes (the element's
    machine size), then store each element at its constant offset. The literal's "value" is
    its alloca'd base address, exactly like a struct literal — the length/fat-pointer
    wrapping (`.len`, slicing, spreads) is A1-4's concern; a spread element (`..xs`) is out
    of the A1-3 subset (its length isn't known until then). */
fn lower_array_lit(ctx: LowerCtx, e: checker::TExpr, al: checker::TArrayLit) -> Lowered | error {
    let elem_t = match slice_element_type(e.type) { checker::Type as t => t; error as err => return err }
    let elem_ty = ltype_of(elem_t)
    let stride = ltype_size(elem_ty)
    let total = (al.elements.len to u32) * stride
    let base = ctx_alloc(ctx)
    let with_alloca = ctx_append(base.ctx, alloca_inst(base.vreg, total, ltype_align(elem_ty), e.line, e.col))
    store_array_elements(with_alloca, base.vreg, al.elements, stride, e.line, e.col)
}

/** store_array_elements — lower each non-spread element in turn, storing it at its
    constant `index * stride` offset from `base`; the result VReg is `base` itself. */
fn store_array_elements(ctx: LowerCtx, base: u32, elements: []checker::TArrayElem, stride: u32, line: u32, col: u32) -> Lowered | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= elements.len { break }
        let elem = elements[i]
        if elem.is_spread { return error { message = "native backend N1: spread array element not yet lowered (N2)" } }
        let vo = match lower_expr(cur, elem.expr) { Lowered as x => x; error as err => return err }
        let offset = (i to u32) * stride
        let addr = ctx_alloc(vo.ctx)
        let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, base, offset, line, col))
        cur = ctx_append(with_addr, store_inst(addr.vreg, vo.vreg, ltype_of(elem.expr.type), line, col))
        i++
    }
    Lowered { ctx = cur; vreg = base }
}

/** lower_array_lit_fat — an array literal's (ptr, len) pair: the SAME alloca+stores
    `lower_array_lit` builds (unchanged VReg numbering for the plain scalar path — indexing
    never needs the length), plus one more constant for its compile-time-known element count
    (A1-4, #382). */
fn lower_array_lit_fat(ctx: LowerCtx, e: checker::TExpr, al: checker::TArrayLit) -> LoweredFat | error {
    let base = match lower_array_lit(ctx, e, al) { Lowered as x => x; error as err => return err }
    let lenr = ctx_alloc(base.ctx)
    let with_len = ctx_append(lenr.ctx, const_int_inst(lenr.vreg, al.elements.len to i128, e.line, e.col))
    LoweredFat { ctx = with_len; ptr = base.vreg; len = lenr.vreg }
}

/** bool_lit_value — a bool literal's i128 carrier (1 = true, 0 = false — the released seed
    does not implement a `bool to <numeric>` cast, so this picks the constant explicitly,
    mirroring the interp's own bool_to_i128 and lower_bool_and's zero constant). */
fn bool_lit_value(v: bool) -> i128 { if v { 1 to i128 } else { 0 to i128 } }

/** lower_byte_lit — a byte literal -> its value widened to the i128 carrier. */
fn lower_byte_lit(ctx: LowerCtx, e: checker::TExpr, b: checker::TByteLit) -> Lowered {
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, const_int_inst(r.vreg, b.value to i128, e.line, e.col)); vreg = r.vreg }
}

/** lower_bool_lit — a bool literal -> its i128 carrier (bool_lit_value). */
fn lower_bool_lit(ctx: LowerCtx, e: checker::TExpr, b: checker::TBoolLit) -> Lowered {
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, const_int_inst(r.vreg, bool_lit_value(b.value), e.line, e.col)); vreg = r.vreg }
}

/** lower_null_lit — `null` -> a zero (null) Ptr constant. */
fn lower_null_lit(ctx: LowerCtx, e: checker::TExpr, n: checker::TNullLit) -> Lowered {
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, const_int_inst(r.vreg, 0 to i128, e.line, e.col)); vreg = r.vreg }
}

/** lower_path_expr — `Enum::Member` -> its already-RESOLVED member value (the checker's
    `.value`: the ordinal for a plain enum, `1 << ordinal` for a FLAGS enum). */
fn lower_path_expr(ctx: LowerCtx, e: checker::TExpr, p: checker::TPathExpr) -> Lowered {
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, const_int_inst(r.vreg, p.value to i128, e.line, e.col)); vreg = r.vreg }
}

/** utf8_codepoint2 — the codepoint of a validated 2-byte UTF-8 sequence. */
fn utf8_codepoint2(s: str) -> u32 {
    let b0 = s[0] to u32
    let b1 = s[1] to u32
    ((b0 & 0x1F) << 6) | (b1 & 0x3F)
}

/** utf8_codepoint3 — the codepoint of a validated 3-byte UTF-8 sequence. */
fn utf8_codepoint3(s: str) -> u32 {
    let b0 = s[0] to u32
    let b1 = s[1] to u32
    let b2 = s[2] to u32
    ((b0 & 0x0F) << 12) | ((b1 & 0x3F) << 6) | (b2 & 0x3F)
}

/** utf8_codepoint4 — the codepoint of a validated 4-byte UTF-8 sequence. */
fn utf8_codepoint4(s: str) -> u32 {
    let b0 = s[0] to u32
    let b1 = s[1] to u32
    let b2 = s[2] to u32
    let b3 = s[3] to u32
    ((b0 & 0x07) << 18) | ((b1 & 0x3F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
}

/** utf8_codepoint — the single codepoint a TCharLit's raw UTF-8 bytes decode to (the lexer
    already validated `s` is EXACTLY one codepoint, 1-4 bytes). */
fn utf8_codepoint(s: str) -> i128 {
    if s.len == 1 { return (s[0] to u32) to i128 }
    if s.len == 2 { return utf8_codepoint2(s) to i128 }
    if s.len == 3 { return utf8_codepoint3(s) to i128 }
    utf8_codepoint4(s) to i128
}

/** lower_char_lit — a char literal -> its decoded codepoint (the LIR's scalar
    representation of `char` — distinct from the VM/C backend's `{ptr,len}` carrier; the
    interp is an exit-code oracle, not a layout verifier, §5.1). */
fn lower_char_lit(ctx: LowerCtx, e: checker::TExpr, c: checker::TCharLit) -> Lowered {
    let r = ctx_alloc(ctx)
    Lowered { ctx = ctx_append(r.ctx, const_int_inst(r.vreg, utf8_codepoint(c.bytes), e.line, e.col)); vreg = r.vreg }
}

/** plain_op_of_compound — the plain arithmetic token a compound-assignment operator
    applies (`+=` -> `+`, …), so assignment reuses lbinop_of's family/signedness pick. A
    bitwise/shift compound (`&=`, `<<=`, …) is out of the A1-3 subset (lbinop_of does not
    lower them either — N2). */
fn plain_op_of_compound(op: lexer::TokenKind) -> lexer::TokenKind | error {
    match op {
        lexer::TokenKind::PlusEq => lexer::TokenKind::Plus
        lexer::TokenKind::MinusEq => lexer::TokenKind::Minus
        lexer::TokenKind::StarEq => lexer::TokenKind::Star
        lexer::TokenKind::SlashEq => lexer::TokenKind::Slash
        lexer::TokenKind::PercentEq => lexer::TokenKind::Percent
        _ => error { message = "native backend N1: compound assignment operator not yet lowered (N2)" }
    }
}

/** lower_assign — a TAssign: Simple (a local rebind) or Field (a struct-field write via
    memory); a Ref-deref (`.value op= …`) is out of the A1-3 subset (Ref<T> is not yet a
    memory-modeled type here). */
fn lower_assign(ctx: LowerCtx, a: checker::TAssign) -> LowerStmtOut | error {
    match a.kind {
        parser::AssignKind::Simple => lower_assign_simple(ctx, a)
        parser::AssignKind::Field => lower_assign_field(ctx, a)
        parser::AssignKind::RefDeref => error { message = "native backend N1: reference deref-assignment not yet lowered (N2)" }
    }
}

/** lower_assign_simple — `name = e` rebinds the env to the newly-lowered value (an
    SSA-lite shadow, exactly like a `let`); `name op= e` reads the CURRENT vreg, applies the
    arithmetic op, and rebinds to the result. */
fn lower_assign_simple(ctx: LowerCtx, a: checker::TAssign) -> LowerStmtOut | error {
    if a.op == lexer::TokenKind::Assign {
        let vo = match lower_expr(ctx, a.value) { Lowered as x => x; error as err => return err }
        return LowerStmtOut { ctx = ctx_reassign(vo.ctx, a.name, vo.vreg); terminated = false }
    }
    let cur = lenv_lookup(ctx.env, a.name)
    if !cur.found { return error { message = teko::str::concat("native backend N1: unbound local `", a.name, "` (internal)") } }
    let vo = match lower_expr(ctx, a.value) { Lowered as x => x; error as err => return err }
    let k = match prim_kind_of(a.bound) { checker::PrimKind as p => p; error as err => return err }
    let plain = match plain_op_of_compound(a.op) { lexer::TokenKind as t => t; error as err => return err }
    let op = match lbinop_of(plain, k) { LBinOp as o => o; error as err => return err }
    let r = ctx_alloc(vo.ctx)
    let inst = bin_inst(r.vreg, op, cur.vreg, vo.vreg, a.value.line, a.value.col)
    LowerStmtOut { ctx = ctx_reassign(ctx_append(r.ctx, inst), a.name, r.vreg); terminated = false }
}

/** lower_assign_field — `recv.field = e` / `recv.field op= e`: lower the receiver to its
    base address, compute the field's address via its registered layout offset, then store
    (a compound op first loads the current value, applies it, then stores the result). */
fn lower_assign_field(ctx: LowerCtx, a: checker::TAssign) -> LowerStmtOut | error {
    let fa = match a.target.kind { checker::TFieldAccess as f => f; _ => return error { message = "native backend N1: field-assignment target is not a field access (internal)" } }
    let ro = match lower_expr(ctx, fa.receiver) { Lowered as x => x; error as err => return err }
    let name = match named_type_name(fa.receiver.type) { str as s => s; error as err => return err }
    let layout = match find_struct_layout(ro.ctx.layouts, name) { LStructLayout as l => l; error as err => return err }
    let off = match field_offset_of(layout, fa.field) { u32 as o => o; error as err => return err }
    let addr = ctx_alloc(ro.ctx)
    let with_addr = ctx_append(addr.ctx, field_addr_inst(addr.vreg, ro.vreg, off, a.target.line, a.target.col))
    store_assign_value(with_addr, addr.vreg, ltype_of(a.bound), a)
}

/** store_assign_value — the shared tail of a field assignment: a plain `=` stores the
    lowered RHS directly; a compound op loads the CURRENT field value first, applies the
    arithmetic, then stores the result. */
fn store_assign_value(ctx: LowerCtx, addr: u32, field_ty: LType, a: checker::TAssign) -> LowerStmtOut | error {
    if a.op == lexer::TokenKind::Assign {
        let vo = match lower_expr(ctx, a.value) { Lowered as x => x; error as err => return err }
        return LowerStmtOut { ctx = ctx_append(vo.ctx, store_inst(addr, vo.vreg, field_ty, a.value.line, a.value.col)); terminated = false }
    }
    let cr = ctx_alloc(ctx)
    let with_load = ctx_append(cr.ctx, load_inst(cr.vreg, addr, field_ty, a.value.line, a.value.col))
    let vo = match lower_expr(with_load, a.value) { Lowered as x => x; error as err => return err }
    let k = match prim_kind_of(a.bound) { checker::PrimKind as p => p; error as err => return err }
    let plain = match plain_op_of_compound(a.op) { lexer::TokenKind as t => t; error as err => return err }
    let op = match lbinop_of(plain, k) { LBinOp as o => o; error as err => return err }
    let rr = ctx_alloc(vo.ctx)
    let with_bin = ctx_append(rr.ctx, bin_inst(rr.vreg, op, cr.vreg, vo.vreg, a.value.line, a.value.col))
    LowerStmtOut { ctx = ctx_append(with_bin, store_inst(addr, rr.vreg, field_ty, a.value.line, a.value.col)); terminated = false }
}

/** texpr_kind_name — a short spelling of a typed expression's kind for the honest-stop
    message. Takes the whole TExpr (TExprKind is private to teko::checker) and matches its
    `.kind`. */
fn texpr_kind_name(e: checker::TExpr) -> str {
    match e.kind {
        checker::TNumber => "number"
        checker::TVar => "variable"
        checker::TStrLit => "string literal"
        checker::TByteLit => "byte literal"
        checker::TCharLit => "char literal"
        checker::TBoolLit => "bool literal"
        checker::TNullLit => "null literal"
        checker::TBinary => "binary op"
        checker::TUnary => "unary op"
        checker::TCompare => "comparison"
        checker::TCall => "call"
        checker::TIfExpr => "if-expression"
        checker::TMatchExpr => "match-expression"
        checker::TCast => "cast"
        checker::TFieldAccess => "field access"
        checker::TSafeFieldAccess => "safe field access"
        checker::TCoalesce => "?? coalesce"
        checker::TStructInit => "struct literal"
        checker::TIndex => "index"
        checker::TInterp => "string interpolation"
        checker::TInExpr => "in-expression"
        checker::TPathExpr => "enum member"
        checker::TArrayLit => "array literal"
        checker::TLambda => "lambda"
        checker::TBorrow => "borrow"
    }
}

/** tstmt_kind_name — a short spelling of a TStatement for the honest-stop message. */
fn tstmt_kind_name(s: checker::TStatement) -> str {
    match s {
        checker::TBinding => "binding"
        checker::TAssign => "assignment"
        checker::TReturn => "return"
        checker::TLoopStmt => "loop"
        checker::TBreakStmt => "break"
        checker::TContinueStmt => "continue"
        checker::TExprStmt => "expression statement"
        checker::TDeferStmt => "defer"
        checker::TAdoptStmt => "adopt"
    }
}

/** lower_block — lower a statement block into the current function/block, threading the env
    and stopping at the first terminator (a return closes the block; nothing after it is
    reachable in the N1 straight-line subset). */
fn lower_block(ctx: LowerCtx, body: []checker::TStatement) -> LowerCtx | error {
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i >= body.len { break }
        let out = match lower_stmt(cur, body[i]) { LowerStmtOut as x => x; error as err => return err }
        cur = out.ctx
        if out.terminated { return cur }
        i++
    }
    cur
}

/**
 * lower_fn_body — lower a function/lambda body, auto-returning its TRAILING
 * expression as the body's `LRet` value when the body falls through (no
 * explicit `return` on every path) and the function/lambda's return machine
 * class is non-void (#421 — mirrors the C backend's `emit_block_tail` /
 * `emit_exprstmt_tail`: "a block's trailing NORMAL value is the function's
 * value"). A `void`-returning function/lambda, or an empty body, lowers every
 * statement plainly (`lower_block`) and leaves the fall-through case to the
 * caller's own implicit-void-return close (`close_function`/
 * `close_lambda_body`). Reuses `lower_block_value`'s "last statement is the
 * tail value" walk, so a trailing `if`/`match` EXPRESSION in tail position
 * already resolves through the SAME machinery an if-expression arm uses — no
 * duplicated control-flow logic.
 *
 * @param LowerCtx ctx  the lowering context
 * @param []checker::TStatement body  the function/lambda's statement list
 * @param LType ret_ty  the function/lambda's return machine class
 * @param u32 line  the source line to propagate onto a synthesized `ret`
 * @param u32 col  the source column to propagate onto a synthesized `ret`
 * @return LowerCtx | error  the context after lowering every statement, its
 *                           block already closed with the `LRet` when a
 *                           trailing value was auto-returned. When the body
 *                           has a pending defer, it fires (from index 0,
 *                           LIFO) AFTER the trailing value is computed but
 *                           BEFORE the auto-`ret` (A1-2, #382 — mirrors the
 *                           C backend's value-arm ordering: tail into
 *                           `sink` first, then its defers,
 *                           `codegen.tks:4742-4749` — a defer here can still
 *                           observe every body-local, but never affects the
 *                           already-captured trailing value).
 */
fn lower_fn_body(ctx: LowerCtx, body: []checker::TStatement, ret_ty: LType, line: u32, col: u32) -> LowerCtx | error {
    if body.len == 0 || ltype_is_void(ret_ty) { return lower_block(ctx, body) }
    let tail = match lower_block_value(ctx, body) { LowerBlockValue as x => x; error as err => return err }
    if tail.terminated { return tail.ctx }
    let replayed = match replay_defers(tail.ctx, 0) { LowerCtx as c => c; error as err => return err }
    ctx_append(replayed, ret_inst(tail.vreg, line, col))
}

/**
 * lower_function — a TFunction -> an LFunc: materialize each parameter as an
 * LParam into VRegs 0..n_params (bound in the env by name), then lower the
 * body (`lower_fn_body`). A NON-void body that falls off the end auto-returns
 * its trailing expression's value (#421); a `void` body that falls off the
 * end gets an implicit void return (`close_function`) — the checker
 * guarantees a value-returning fn returns on every path, so a fall-through
 * without a trailing value never reaches this function. A generic or extern
 * function is out of the N1 subset.
 *
 * @param checker::TFunction f  the typed function to lower
 * @param []LStructLayout layouts  the program's struct-layout table (A1-3, #382
 *                                 — defaulted empty so an arithmetic-only
 *                                 fixture need not build one)
 * @param []LRodata rodata  the whole-program interned-rodata table SEEDED with
 *                          everything an earlier function already interned
 *                          (A1-4, #382 — the returned `LoweredFunction` carries
 *                          the GROWN table back out, so `lower_program` threads
 *                          it function-to-function)
 * @param []LEnumInfo enums  the program's enum-member table (A1-5, #382 —
 *                           defaulted empty so a non-enum fixture need not
 *                           build one)
 * @param []LFunc lifted  the whole-program lifted closure/thunk-function
 *                        table SEEDED with everything an earlier function
 *                        already lifted (A1-7, #382 — the returned
 *                        `LoweredFunction` carries the GROWN table back out,
 *                        so `lower_program` threads it function-to-function,
 *                        exactly like `rodata`)
 * @return LoweredFunction | error  the built `LFunc` + its grown rodata/
 *                                  lifted tables; the `error` arm for a
 *                                  generic/extern function, or when its body
 *                                  fails to lower
 */
pub fn lower_function(f: checker::TFunction, layouts: []LStructLayout = teko::list::empty(), rodata: []LRodata = teko::list::empty(), enums: []LEnumInfo = teko::list::empty(), lifted: []LFunc = teko::list::empty()) -> LoweredFunction | error {
    if f.type_params.len != 0 { return error { message = "native backend N1: generic function not yet lowered (N2)" } }
    if f.is_extern { return error { message = "native backend N1: extern function has no body to lower" } }
    let ptypes = param_ltypes(f.params)
    mut fn0 = new_func(mangle_fn_symbol(f.namespace, f.name), f.params.len to u32, ptypes, ltype_of(f.return_type))
    mut env = empty_lenv()
    mut i: u64 = 0
    loop {
        if i >= f.params.len { break }
        fn0 = append_inst(fn0, 0, param_inst(i to u32, i to u32, f.line, f.col))
        env = lenv_bind(env, f.params[i].name, i to u32)
        i++
    }
    let ctx0 = LowerCtx {
        func = fn0; block_id = 0; env = env
        layouts = layouts; rodata = rodata; enums = enums; lifted = lifted
        defers = teko::list::empty(); loop_targets = teko::list::empty()
    }
    let done = match lower_fn_body(ctx0, f.body, ltype_of(f.return_type), f.line, f.col) { LowerCtx as c => c; error as err => return err }
    let closed = match close_function(done, f) { LowerCtx as c => c; error as err => return err }
    LoweredFunction { func = closed.func; rodata = closed.rodata; lifted = closed.lifted }
}

/** LoweredFunction — an `LFunc` + the interned-rodata table (A1-4, #382) and
    the lifted closure/thunk-function table (A1-7, #382) it (and everything
    lowered before it) grew — `lower_function`'s return so the whole-program
    symbol numbering stays contiguous. */
pub type LoweredFunction = struct { func: LFunc; rodata: []LRodata; lifted: []LFunc }

/**
 * close_function — fire any still-pending defer (from index 0, LIFO) and
 * append the implicit void return if the body did not terminate the block
 * (a void fn falling off the end, A1-2, #382 — mirrors the C backend's
 * fn-body fall-through defer fire, `codegen.tks:6418-6429`), then return
 * the closed context.
 *
 * @param LowerCtx ctx  the context after lowering the function's body
 * @param checker::TFunction f  the function (its source position stamps the
 *                              synthesized `ret`)
 * @return LowerCtx | error  the closed context (its `.func` is the closed
 *                           function; its `.rodata`/`.lifted` carry forward
 *                           any growth the fall-through defer replay made),
 *                           or a NAMED internal error when a pending defer
 *                           fails to lower
 */
fn close_function(ctx: LowerCtx, f: checker::TFunction) -> LowerCtx | error {
    if block_terminated(ctx.func, ctx.block_id) { return ctx }
    let replayed = match replay_defers(ctx, 0) { LowerCtx as c => c; error as err => return err }
    ctx_append(replayed, ret_void_inst(f.line, f.col))
}

/** block_terminated — does the block whose id is `block_id` end in a terminator (LRet/
    LJump/LBranch)? N1 only produces LRet, so a non-empty last-inst LRet means terminated. */
fn block_terminated(f: LFunc, block_id: u32) -> bool {
    mut i: u64 = 0
    loop {
        if i >= f.blocks.len { break }
        let b = f.blocks[i]
        if b.id == block_id { return block_ends_in_terminator(b) }
        i++
    }
    false
}

/** block_ends_in_terminator — is the block's last instruction a terminator? */
fn block_ends_in_terminator(b: LBlock) -> bool {
    if b.insts.len == 0 { return false }
    inst_is_terminator(b.insts[b.insts.len - 1])
}

/** inst_is_terminator — is this instruction a block terminator (LRet/LJump/LBranch)? */
fn inst_is_terminator(inst: LInst) -> bool {
    match inst.op {
        LRet => true
        LJump => true
        LBranch => true
        _ => false
    }
}

/** param_ltypes — the machine class of each parameter annotation (in order). */
fn param_ltypes(params: []parser::Param) -> []LType {
    mut out: []LType = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= params.len { break }
        out = teko::list::push(out, ltype_of_typeexpr(params[i].type_ann))
        i++
    }
    out
}

/**
 * lower_program — the module entry: register every declared struct's layout
 * (A1-3, #382), collect every declared enum's members (A1-5, #382), intern every
 * Tier-A aggregate const's byte image into rodata (#594 crumb 6), lower every
 * top-level function, and gather the loose top-level statements into a
 * synthesized `main` (the VIRTUAL-MAIN the C backend also builds), returning
 * `int 0` if the statements fall through. Type/use declarations otherwise carry
 * no code. Mirrors the loop of tk_emit_c over prog.items.
 *
 * @param checker::TProgram prog  the whole typed program to lower
 * @return LModule | error  the built module (functions + rodata/globals/
 *                          layouts, every lifted closure/thunk folded in,
 *                          A1-7 #382); the `error` arm when any function or
 *                          the virtual main fails to lower
 */
pub fn lower_program(prog: checker::TProgram) -> LModule | error {
    let layouts = collect_struct_layouts(prog)
    let enums = collect_enums(prog)
    let variants = collect_variants(prog)
    mut m = match intern_aggregate_consts(register_layouts(empty_module(), layouts), prog.items, layouts, variants) { LModule as x => x; error as e => return e }
    mut loose: []checker::TStatement = teko::list::empty()
    mut lifted: []LFunc = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        let step = match lower_item(m, loose, prog.items[i], layouts, enums, lifted) { LowerItemOut as x => x; error as err => return err }
        m = step.module
        loose = step.loose
        lifted = step.lifted
        i++
    }
    let vmain = match lower_virtual_main(loose, layouts, enums, m.rodata, lifted) { LoweredFunction as x => x; error as err => return err }
    fold_lifted_funcs(add_func(with_rodata(m, vmain.rodata), vmain.func), vmain.lifted)
}

/**
 * fold_lifted_funcs — append every lifted closure/thunk `LFunc` (accumulated
 * across the WHOLE program, A1-7, #382) into `m.funcs`, ONCE, after every
 * top-level function AND the virtual main have finished lowering — folding
 * per-function instead would re-add earlier entries on every subsequent
 * function (the table is CUMULATIVE, like `rodata`).
 *
 * @param LModule m  the module accumulated so far (every real top-level
 *                   function + the virtual main already folded in)
 * @param []LFunc lifted  the whole-program lifted closure/thunk-function
 *                        table
 * @return LModule  `m` with every entry of `lifted` appended to its `funcs`
 */
fn fold_lifted_funcs(m: LModule, lifted: []LFunc) -> LModule {
    mut cur = m
    mut i: u64 = 0
    loop {
        if i >= lifted.len { break }
        cur = add_func(cur, lifted[i])
        i++
    }
    cur
}

/** register_layouts — return a copy of `m` with every entry of `layouts` appended to its
    struct-layout table. */
fn register_layouts(m: LModule, layouts: []LStructLayout) -> LModule {
    mut cur = m
    mut i: u64 = 0
    loop {
        if i >= layouts.len { break }
        cur = add_layout(cur, layouts[i])
        i++
    }
    cur
}

/** collect_struct_layouts — the declared-order, natural-alignment layout of every `struct`
    type declaration in `prog` (A1-3, #382). A generic struct's type-parameter field
    annotations collapse to Ptr (ltype_of_typeexpr's total fallback) — harmless, since no
    A1-3 fixture instantiates one; a NON-struct type declaration (enum/class/variant/…)
    contributes no layout entry. */
fn collect_struct_layouts(prog: checker::TProgram) -> []LStructLayout {
    mut out: []LStructLayout = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        out = collect_struct_layout_item(out, prog.items[i])
        i++
    }
    out
}

/** collect_struct_layout_item — accumulate `it`'s layout (a struct TypeDecl) onto `acc`,
    unchanged for every other item kind. */
fn collect_struct_layout_item(acc: []LStructLayout, it: checker::TItem) -> []LStructLayout {
    match it {
        parser::TypeDecl as td => collect_struct_layout_decl(acc, td)
        _ => acc
    }
}

/** collect_struct_layout_decl — accumulate `td`'s layout onto `acc` when its body is a
    `StructBody`; unchanged for any other type-declaration shape (enum/class/variant/…). */
fn collect_struct_layout_decl(acc: []LStructLayout, td: parser::TypeDecl) -> []LStructLayout {
    match td.body {
        parser::StructBody as sb => teko::list::push(acc, layout_of_fields(td.name, sb.fields, acc))
        _ => acc
    }
}

/**
 * layout_of_fields — a struct's LStructLayout from its DECLARED field list: each
 * field's machine class comes from its syntactic annotation (`ltype_of_typeexpr` —
 * the same mapping a parameter list already uses), in the struct's own declared
 * order. A field whose type NAMES an already-registered struct in `known` (an
 * EARLIER-declared struct — layouts are collected in program order) is a
 * struct-BY-VALUE field: its size/align come from that struct's OWN resolved
 * layout (recursively already-computed, since it registered first), not from
 * `ltype_of_typeexpr`'s total `Ptr` fallback (which would under-size it to 8
 * bytes). A forward-referenced or non-struct field falls back to the scalar
 * `ltype_size`/`ltype_align` mapping, unchanged (#414, #382).
 *
 * @param str name  the struct's canonical (declaring) name
 * @param []parser::Field fields  the struct's declared fields, in order
 * @param []LStructLayout known  every struct layout resolved so far (program
 *                               order) — the lookup table a nested-struct
 *                               field's size/align resolves against
 * @return LStructLayout  the resolved size/align/per-field offsets
 */
fn layout_of_fields(name: str, fields: []parser::Field, known: []LStructLayout) -> LStructLayout {
    mut field_names: []str = teko::list::empty()
    mut field_types: []LType = teko::list::empty()
    mut field_sizes: []u32 = teko::list::empty()
    mut field_aligns: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= fields.len { break }
        let te = fields[i].type_ann
        let ft = ltype_of_typeexpr(te)
        let nested = struct_layout_of_field(te, known)
        field_names = teko::list::push(field_names, fields[i].name)
        field_types = teko::list::push(field_types, ft)
        field_sizes = teko::list::push(field_sizes, field_layout_size(te, ft, nested))
        field_aligns = teko::list::push(field_aligns, field_layout_align(te, ft, nested))
        i++
    }
    layout_of_sized(name, field_names, field_types, field_sizes, field_aligns)
}

/**
 * struct_layout_of_field — the ALREADY-KNOWN layout of a field's type, when that
 * type is a single-segment Named type matching a struct in `known` by name; `null`
 * for every other field-type shape (a scalar, a multi-segment path, a slice/
 * optional/union/function annotation, or a forward reference to a not-yet-
 * registered struct) (#414, #382).
 *
 * @param parser::TypeExpr te  the field's syntactic type annotation
 * @param []LStructLayout known  every struct layout resolved so far
 * @return LStructLayout?  the matching nested layout, or `null`
 */
fn struct_layout_of_field(te: parser::TypeExpr, known: []LStructLayout) -> LStructLayout? {
    match named_type_name_of(te) {
        str as name => find_known_struct_layout(known, name)
        null => null
    }
}

/**
 * named_type_name_of — the bare name of a single-segment Named type annotation
 * (`Point`, not `a::Point`); `null` for a multi-segment path or any other
 * TypeExpr shape (#414, #382).
 *
 * @param parser::TypeExpr te  the syntactic type annotation
 * @return str?  the single segment's name, or `null`
 */
fn named_type_name_of(te: parser::TypeExpr) -> str? {
    match te {
        parser::NamedType as nt => single_segment_name(nt.path)
        _ => null
    }
}

/**
 * single_segment_name — `p`'s lone segment name, or `null` when `p` has zero or
 * more than one segment (#414, #382).
 *
 * @param parser::Path p  the path to inspect
 * @return str?  `p`'s single segment's name, or `null`
 */
fn single_segment_name(p: parser::Path) -> str? {
    if p.segments.len != 1 { return null }
    p.segments[0].name
}

/**
 * find_known_struct_layout — the entry of `layouts` named `name`, or `null`
 * when none matches (a NULLABLE sibling of `find_struct_layout`: a
 * forward-referenced or non-struct field type is a routine "not (yet)
 * known" outcome here, not an internal invariant break) (#414, #382).
 *
 * @param []LStructLayout layouts  the struct-layout table to search
 * @param str name  the struct name to look up
 * @return LStructLayout?  the matching entry, or `null`
 */
fn find_known_struct_layout(layouts: []LStructLayout, name: str) -> LStructLayout? {
    mut i: u64 = 0
    loop {
        if i >= layouts.len { break }
        if layouts[i].name == name { return layouts[i] }
        i++
    }
    null
}

/**
 * field_size_of — a field's byte size: `nested`'s own resolved size when
 * present (a struct-by-value field), else `ft`'s scalar `ltype_size` (#414,
 * #382).
 *
 * @param LType ft  the field's machine class (`ltype_of_typeexpr`'s mapping)
 * @param LStructLayout? nested  the field's nested struct layout, when known
 * @return u32  the field's byte size
 */
fn field_size_of(ft: LType, nested: LStructLayout?) -> u32 {
    match nested {
        LStructLayout as l => l.size
        null => ltype_size(ft)
    }
}

/**
 * field_align_of — a field's byte alignment: `nested`'s own resolved alignment
 * when present (a struct-by-value field), else `ft`'s scalar `ltype_align`
 * (#414, #382).
 *
 * @param LType ft  the field's machine class (`ltype_of_typeexpr`'s mapping)
 * @param LStructLayout? nested  the field's nested struct layout, when known
 * @return u32  the field's byte alignment
 */
fn field_align_of(ft: LType, nested: LStructLayout?) -> u32 {
    match nested {
        LStructLayout as l => l.align
        null => ltype_align(ft)
    }
}

/**
 * typeexpr_is_fat — true iff the syntactic annotation `te` is a fat-pointer type (a `[]T` slice or
 * `str`), the field whose layout occupies 16 bytes `{ptr, len}` instead of the scalar fallback's
 * 8-byte `Ptr` (#594 T-B6). A `char`/Named-by-value/`ptr<T>` is NOT fat (it is an 8-byte `Ptr` or a
 * nested struct), so it does not match here.
 *
 * @param te  the field's syntactic type annotation
 * @return    whether the field is a fat pointer (16 bytes {ptr, len})
 * @since #594 T-B6
 */
fn typeexpr_is_fat(te: parser::TypeExpr) -> bool {
    match te {
        parser::SliceType => true
        parser::NamedType as nt => named_single_segment_is(nt.path, "str")
        _ => false
    }
}

/**
 * named_single_segment_is — true iff `p` is a single-segment path whose lone segment name equals
 * `want` (#594 T-B6): the shape a bare `str` type annotation takes (`str`, not `a::str`).
 *
 * @param p     the path to inspect
 * @param want  the segment name to match
 * @return      whether `p` is the single segment `want`
 * @since #594 T-B6
 */
fn named_single_segment_is(p: parser::Path, want: str) -> bool {
    match single_segment_name(p) {
        str as s => s == want
        null => false
    }
}

/**
 * field_layout_size — a field's byte size, widening a fat-pointer field (`[]T`/`str`) to the 16-byte
 * `{ptr, len}` image and otherwise deferring to `field_size_of` (#594 T-B6). The 16-byte width is the
 * layout the aggregate-const serializer writes (`{ptr@off, len@off+8}`) and the reader loads.
 *
 * @param te      the field's syntactic type annotation (the fat-vs-scalar signal)
 * @param ft      the field's machine class (`ltype_of_typeexpr`'s mapping)
 * @param nested  the field's nested struct layout, when known
 * @return        the field's byte size
 * @since #594 T-B6
 */
fn field_layout_size(te: parser::TypeExpr, ft: LType, nested: LStructLayout?) -> u32 {
    if typeexpr_is_fat(te) { return ltype_size(LType::Ptr) * (2 to u32) }
    field_size_of(ft, nested)
}

/**
 * field_layout_align — a field's byte alignment, pinning a fat-pointer field (`[]T`/`str`) to
 * pointer alignment and otherwise deferring to `field_align_of` (#594 T-B6).
 *
 * @param te      the field's syntactic type annotation (the fat-vs-scalar signal)
 * @param ft      the field's machine class (`ltype_of_typeexpr`'s mapping)
 * @param nested  the field's nested struct layout, when known
 * @return        the field's byte alignment
 * @since #594 T-B6
 */
fn field_layout_align(te: parser::TypeExpr, ft: LType, nested: LStructLayout?) -> u32 {
    if typeexpr_is_fat(te) { return ltype_align(LType::Ptr) }
    field_align_of(ft, nested)
}

/**
 * collect_enums — the name + declared member list of every `enum` type
 * declaration in `prog`, in program order (A1-5, #382 — a `match` arm's bare
 * enum-member pattern resolves its ORDINAL through this table). A non-enum type
 * declaration contributes no entry.
 *
 * @param checker::TProgram prog  the whole typed program to scan
 * @return []LEnumInfo  every declared enum's name + member list, in program
 *                      order
 */
fn collect_enums(prog: checker::TProgram) -> []LEnumInfo {
    mut out: []LEnumInfo = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        out = collect_enum_item(out, prog.items[i])
        i++
    }
    out
}

/**
 * collect_enum_item — accumulate `it`'s enum info onto `acc`, unchanged for
 * every other item kind.
 *
 * @param []LEnumInfo acc  the enum table accumulated so far
 * @param checker::TItem it  the program item to fold
 * @return []LEnumInfo  `acc`, with `it`'s enum info appended when applicable
 */
fn collect_enum_item(acc: []LEnumInfo, it: checker::TItem) -> []LEnumInfo {
    match it {
        parser::TypeDecl as td => collect_enum_decl(acc, td)
        _ => acc
    }
}

/**
 * collect_enum_decl — accumulate `td`'s member list onto `acc` when its body is
 * an `EnumBody`; unchanged for any other type-declaration shape
 * (struct/class/variant/…).
 *
 * @param []LEnumInfo acc  the enum table accumulated so far
 * @param parser::TypeDecl td  the type declaration to fold
 * @return []LEnumInfo  `acc`, with `td`'s enum info appended when applicable
 */
fn collect_enum_decl(acc: []LEnumInfo, td: parser::TypeDecl) -> []LEnumInfo {
    match td.body {
        parser::EnumBody as eb => teko::list::push(acc, LEnumInfo { name = td.name; members = eb.members })
        _ => acc
    }
}

/** LowerItemOut — the module + accumulated loose statements + the WHOLE-PROGRAM
    lifted closure/thunk-function table (A1-7, #382) after folding one top-level item. */
pub type LowerItemOut = struct { module: LModule; loose: []checker::TStatement; lifted: []LFunc }

/**
 * lower_item — fold one TItem: a function lowers into the module (given the
 * program's struct-layout/enum tables); a loose statement accumulates for the
 * virtual main; a type/use declaration is skipped.
 *
 * @param LModule m  the module accumulated so far
 * @param []checker::TStatement loose  the loose top-level statements
 *                                     accumulated so far
 * @param checker::TItem it  the program item to fold
 * @param []LStructLayout layouts  the program's struct-layout table
 * @param []LEnumInfo enums  the program's enum table
 * @param []LFunc lifted  the whole-program lifted closure/thunk-function
 *                        table accumulated so far (A1-7, #382)
 * @return LowerItemOut | error  the advanced module + loose-statement/lifted
 *                               lists; the `error` arm when a function item
 *                               fails to lower
 */
fn lower_item(m: LModule, loose: []checker::TStatement, it: checker::TItem, layouts: []LStructLayout, enums: []LEnumInfo, lifted: []LFunc) -> LowerItemOut | error {
    match it {
        checker::TFunction as f => lower_item_function(m, loose, f, layouts, enums, lifted)
        checker::TStatement as s => LowerItemOut { module = m; loose = teko::list::push(loose, s); lifted = lifted }
        checker::TConstDecl as cd => lower_const_item(m, loose, cd, lifted)
        _ => LowerItemOut { module = m; loose = loose; lifted = lifted }
    }
}

/**
 * const_decl_is_scalar — true iff a residual TConstDecl's declared type is SCALAR (a primitive
 * int/float/bool, a `byte`, or a `char`), the family the crumb-5 inliner substitutes at every use
 * site and drops from the program (#594 crumb 5). Mirrors the checker's `is_scalar_const_type`; kept
 * local so the lowering stays self-contained.
 *
 * @param t  the residual const's resolved value type
 * @return   whether `t` is a scalar (inline-at-use) const type
 */
fn const_decl_is_scalar(t: checker::Type) -> bool {
    match t {
        checker::Slice => false
        checker::Str => false
        checker::Optional => false
        checker::Named => false
        checker::Variant => false
        checker::Func => false
        checker::Error => false
        checker::Void => false
        checker::Ptr => false
        checker::Uptr => false
        checker::Reference => false
        checker::Null => false
        checker::Prim => true
        checker::Byte => true
        checker::Char => true
    }
}

/**
 * lower_const_item — fold a residual TConstDecl in the item loop: a NO-OP for BOTH families (#594
 * crumb 6). A SCALAR const was inlined at every use and dropped by `inline_consts` (post-monomorphize)
 * — it emits no `LFunc`, no `LGlobal`. An AGGREGATE (Tier-A) const's byte image was already interned
 * into rodata by `intern_aggregate_consts`, BEFORE any function lowered, and every use resolves to
 * that rodata symbol — so the declaration itself contributes no further code here. `m.globals` stays
 * empty for either family (rodata, never a global), so no globals honest-stop is reachable.
 *
 * @param m       the module accumulated so far
 * @param loose   the loose top-level statements accumulated so far
 * @param cd      the residual typed const declaration (unused — kept for the item-fold shape)
 * @param lifted  the whole-program lifted closure/thunk-function table
 * @return        the module unchanged (const decls emit no per-item code)
 */
fn lower_const_item(m: LModule, loose: []checker::TStatement, cd: checker::TConstDecl, lifted: []LFunc) -> LowerItemOut | error {
    LowerItemOut { module = m; loose = loose; lifted = lifted }
}

/**
 * lower_item_function — lower a top-level function into the module (a `#test`
 * function is skipped — it is not part of the emitted program). Seeds the
 * lowering with the module's CURRENT rodata table and folds the grown table
 * back in (A1-4, #382), so string literals across every function get distinct
 * symbols; the lifted closure/thunk table threads the same way (A1-7, #382).
 *
 * @param LModule m  the module accumulated so far
 * @param []checker::TStatement loose  the loose top-level statements
 *                                     accumulated so far
 * @param checker::TFunction f  the function to lower
 * @param []LStructLayout layouts  the program's struct-layout table
 * @param []LEnumInfo enums  the program's enum table
 * @param []LFunc lifted  the whole-program lifted closure/thunk-function
 *                        table accumulated so far (A1-7, #382)
 * @return LowerItemOut | error  the advanced module (unchanged `loose`) + the
 *                               grown lifted table; the `error` arm when
 *                               `f`'s body fails to lower
 */
fn lower_item_function(m: LModule, loose: []checker::TStatement, f: checker::TFunction, layouts: []LStructLayout, enums: []LEnumInfo, lifted: []LFunc) -> LowerItemOut | error {
    if f.is_test { return LowerItemOut { module = m; loose = loose; lifted = lifted } }
    if f.is_extern { return LowerItemOut { module = m; loose = loose; lifted = lifted } }
    let lf = match lower_function(f, layouts, m.rodata, enums, lifted) { LoweredFunction as x => x; error as err => return err }
    LowerItemOut { module = add_func(with_rodata(m, lf.rodata), lf.func); loose = loose; lifted = lf.lifted }
}

/**
 * lower_virtual_main — the synthesized `int main()` from the loose top-level
 * statements: lower each, treating a trailing loose EXPRESSION statement as
 * the program's exit-code value (mirrors `lower_fn_body`'s trailing-expression
 * auto-return, #421 — `lower_main_tail`), and if control falls through append
 * `%r = const 0; ret %r` when no such trailing value was found (the ABI: main
 * returns int) (#423, #382). An explicit `exit(n)` inside diverges, so the
 * trailing return is dead but harmless.
 *
 * @param []checker::TStatement loose  the program's loose top-level statements,
 *                                     in order
 * @param []LStructLayout layouts  the program's struct-layout table
 * @param []LEnumInfo enums  the program's enum table
 * @param []LRodata rodata  the whole-program interned-rodata table seeded with
 *                          everything the program's functions already interned
 *                          (A1-4, #382)
 * @param []LFunc lifted  the whole-program lifted closure/thunk-function
 *                        table accumulated so far (A1-7, #382)
 * @return LoweredFunction | error  the built virtual-main `LFunc` + its grown
 *                                  rodata/lifted tables; the `error` arm when
 *                                  any loose statement fails to lower
 */
fn lower_virtual_main(loose: []checker::TStatement, layouts: []LStructLayout, enums: []LEnumInfo, rodata: []LRodata, lifted: []LFunc) -> LoweredFunction | error {
    let fn0 = new_func("main", 0, teko::list::empty(), LType::I32)
    let ctx0 = LowerCtx {
        func = fn0; block_id = 0; env = empty_lenv()
        layouts = layouts; rodata = rodata; enums = enums; lifted = lifted
        defers = teko::list::empty(); loop_targets = teko::list::empty()
    }
    let tail = match lower_main_tail(ctx0, loose) { LowerMainTail as x => x; error as err => return err }
    let closed = match close_virtual_main(tail) { LowerCtx as c => c; error as err => return err }
    LoweredFunction { func = closed.func; rodata = closed.rodata; lifted = closed.lifted }
}

/**
 * LowerMainTail — the outcome of lowering the loose top-level statement list:
 * either it fell through with no trailing exit-code value (`has_value=false`
 * — the last statement was not a value-producing expression, or the body was
 * empty/already terminated), or its last statement was a non-void EXPRESSION
 * statement, whose value is the program's exit code (`has_value=true`, `vreg`)
 * (#423, #382).
 */
pub type LowerMainTail = struct { ctx: LowerCtx; has_value: bool; vreg: u32 }

/**
 * lower_main_tail — lower every loose top-level statement but the last
 * plainly (`lower_stmt`, stopping early on an inner terminator — a labeled
 * top-level `return` never occurs, but an early-terminating construct is
 * handled the same as `lower_block`'s), then resolve the LAST statement
 * through `lower_main_tail_stmt` — the only one eligible to supply the
 * program's exit-code value (#423, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param []checker::TStatement body  the program's loose top-level statements
 * @return LowerMainTail | error  the advanced context, plus whether a
 *                                trailing exit-code value was found
 */
fn lower_main_tail(ctx: LowerCtx, body: []checker::TStatement) -> LowerMainTail | error {
    if body.len == 0 { return LowerMainTail { ctx = ctx; has_value = false; vreg = 0 } }
    mut cur = ctx
    mut i: u64 = 0
    loop {
        if i + 1 >= body.len { break }
        let out = match lower_stmt(cur, body[i]) { LowerStmtOut as x => x; error as err => return err }
        cur = out.ctx
        if out.terminated { return LowerMainTail { ctx = cur; has_value = false; vreg = 0 } }
        i++
    }
    lower_main_tail_stmt(cur, body[body.len - 1])
}

/**
 * lower_main_tail_stmt — the loose top-level statement list's LAST statement:
 * a non-void expression-statement's value IS the program's exit code
 * (`lower_main_tail_expr`); every other statement kind lowers plainly, with
 * no exit-code value (`lower_main_tail_other`) (#423, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TStatement s  the last loose top-level statement
 * @return LowerMainTail | error  the advanced context, plus whether `s`
 *                                supplied a trailing exit-code value
 */
fn lower_main_tail_stmt(ctx: LowerCtx, s: checker::TStatement) -> LowerMainTail | error {
    match s {
        checker::TExprStmt as es => lower_main_tail_expr(ctx, es)
        _ => lower_main_tail_other(ctx, s)
    }
}

/**
 * lower_main_tail_expr — the loose top-level statement list's last statement,
 * when it is an expression-statement: a VOID-typed expression (a diverging
 * builtin call, or any other void call) lowers plainly with no exit-code
 * value; a non-void expression's VReg IS the program's exit code (#423,
 * #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TExprStmt es  the trailing expression-statement
 * @return LowerMainTail | error  the advanced context, plus `es`'s VReg when
 *                                its type is non-void
 */
fn lower_main_tail_expr(ctx: LowerCtx, es: checker::TExprStmt) -> LowerMainTail | error {
    if ltype_is_void(ltype_of(es.expr.type)) {
        let out = match lower_expr_stmt(ctx, es) { LowerStmtOut as x => x; error as err => return err }
        return LowerMainTail { ctx = out.ctx; has_value = false; vreg = 0 }
    }
    let lo = match lower_expr(ctx, es.expr) { Lowered as x => x; error as err => return err }
    LowerMainTail { ctx = lo.ctx; has_value = true; vreg = lo.vreg }
}

/**
 * lower_main_tail_other — the loose top-level statement list's last
 * statement, when it is anything but an expression-statement (a binding,
 * loop, defer, …): lowers plainly, with no exit-code value (#423, #382).
 *
 * @param LowerCtx ctx  the lowering context
 * @param checker::TStatement s  the trailing non-expression statement
 * @return LowerMainTail | error  the advanced context; never an exit-code
 *                                value
 */
fn lower_main_tail_other(ctx: LowerCtx, s: checker::TStatement) -> LowerMainTail | error {
    let out = match lower_stmt(ctx, s) { LowerStmtOut as x => x; error as err => return err }
    LowerMainTail { ctx = out.ctx; has_value = false; vreg = 0 }
}

/**
 * close_virtual_main — fire any still-pending top-level defer (from index 0,
 * LIFO, A1-2, #382) and, when the body did not already terminate, append
 * either `ret %v` (`tail.vreg`, when the loose top-level statements' trailing
 * expression supplied one, #423) or `%r = const 0; ret %r` (no trailing
 * value).
 *
 * @param LowerMainTail tail  the lowered loose top-level statements' outcome
 * @return LowerCtx | error  the closed context, or a NAMED internal error
 *                           when a pending defer fails to lower
 */
fn close_virtual_main(tail: LowerMainTail) -> LowerCtx | error {
    if block_terminated(tail.ctx.func, tail.ctx.block_id) { return tail.ctx }
    let replayed = match replay_defers(tail.ctx, 0) { LowerCtx as c => c; error as err => return err }
    if tail.has_value { return ctx_append(replayed, ret_inst(tail.vreg, 0, 0)) }
    let r = ctx_alloc(replayed)
    let c0 = ctx_append(r.ctx, const_int_inst(r.vreg, 0 to i128, 0, 0))
    ctx_append(c0, ret_inst(r.vreg, 0, 0))
}
