/** lwt_strlit — a `TStrLit` node holding `text` (A1-4, #382). */
fn lwt_strlit(text: str) -> checker::TExpr {
    checker::TExpr { kind = checker::TStrLit { text = text }; type = checker::Str { }; line = 0; col = 0 }
}

#test
fn lwt_lowers_str_literal_interns_rodata_and_a_fat_pair() {
    let text = lwt_lower_expr_text(lwt_strlit("hi"))
    teko::assert::str_contains(text, "rodata .Lstr0: [104, 105]")
    teko::assert::str_contains(text, "%0 = global_addr @.Lstr0")
    teko::assert::str_contains(text, "%1 = const 2")
}

/** lwt_len_field — `recv.len`, always `u64`-typed (A1-4, #382). */
fn lwt_len_field(recv: checker::TExpr) -> checker::TExpr {
    checker::TExpr { kind = checker::TFieldAccess { receiver = recv; field = "len" }; type = lwt_prim(checker::PrimKind::U64); line = 0; col = 0 }
}

#test
fn lwt_lowers_str_len_reads_the_fat_length_with_no_memory_traffic() {
    let text = lwt_lower_expr_text(lwt_len_field(lwt_strlit("hello")))
    teko::assert::str_contains(text, "%1 = const 5")
    teko::assert::is_true(!teko::str::contains(text, "load."))
}

/** lwt_index_of — `recv[index]`, resolved element type `et` (A1-4, #382). */
fn lwt_index_of(recv: checker::TExpr, index: checker::TExpr, et: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TIndex { receiver = recv; index = index }; type = et; line = 0; col = 0 }
}

#test
fn lwt_lowers_str_index_loads_the_byte_off_rodata() {
    let ix = lwt_index_of(lwt_strlit("abc"), lwt_num_i64(0 to i128), checker::Byte { })
    let text = lwt_lower_expr_text(lwt_cast(ix, checker::PrimKind::I32))
    teko::assert::str_contains(text, "rodata .Lstr0: [97, 98, 99]")
    teko::assert::str_contains(text, "field_addr %0, 0")
    teko::assert::str_contains(text, "load.i8")
    teko::assert::str_contains(text, "zext")
}

/** lwt_interp — a `$"…{…}…"` node over `pieces`/`holes`, always no-spec (A1-4, #382). */
fn lwt_interp(pieces: []str, holes: []checker::TExpr) -> checker::TExpr {
    mut specs: []checker::TFSpec = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= holes.len { break }
        specs = teko::list::push(specs, checker::TFSpec { kind = checker::TFSpecNone { } })
        i++
    }
    checker::TExpr { kind = checker::TInterp { pieces = pieces; holes = holes; specs = specs }; type = checker::Str { }; line = 0; col = 0 }
}

#test
fn lwt_lowers_interpolation_as_nested_str_concat_calls() {
    let pieces = teko::list::push(teko::list::push(teko::list::empty(), "n="), "")
    let holes = teko::list::push(teko::list::empty(), lwt_num_i64(7 to i128))
    let text = lwt_lower_expr_text(lwt_interp(pieces, holes))
    teko::assert::str_contains(text, "rodata .Lstr0: [110, 61]")
    teko::assert::str_contains(text, "global_addr @.Lstr0")
    teko::assert::str_contains(text, "call @tk_i64_to_str(")
    teko::assert::str_contains(text, "call @tk_str_concat(")
}

/** lwt_in_expr — `lhs in [elems]`, always bool-typed (A1-4, #382). */
fn lwt_in_expr(lhs: checker::TExpr, elems: []checker::TExpr) -> checker::TExpr {
    checker::TExpr { kind = checker::TInExpr { lhs = lhs; elems = elems }; type = lwt_prim(checker::PrimKind::Bool); line = 0; col = 0 }
}

#test
fn lwt_lowers_in_expr_as_an_eq_chain_ored_together() {
    let elems = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(1 to i128)), lwt_num_i64(2 to i128))
    let text = lwt_lower_expr_text(lwt_in_expr(lwt_num_i64(1 to i128), elems))
    teko::assert::str_contains(text, "icmpeq")
    teko::assert::str_contains(text, "ior")
}

/** lwt_optional_var — a `TVar` of `T?` type (A1-4, #382). */
fn lwt_optional_var(name: str, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = false; func_ns = "" }; type = checker::Optional { inner = lwt_prim(k) }; line = 0; col = 0 }
}

/** lwt_coalesce — `left ?? right`, resolved type `ty` (A1-4, #382). */
fn lwt_coalesce(left: checker::TExpr, right: checker::TExpr, ty: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TCoalesce { left = left; right = right }; type = ty; line = 0; col = 0 }
}

#test
fn lwt_lowers_coalesce_via_branch_and_merge() {
    let x = lwt_optional_var("x", checker::PrimKind::I64)
    let co = lwt_coalesce(x, lwt_num_i64(42 to i128), lwt_prim(checker::PrimKind::I64))
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(co))
    let f = lwt_fn("pick_default", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as r => r.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "branch %0, #B1(), #B2()")
    teko::assert::str_contains(text, "  #B1:\n    jump #B3(%0)")
    teko::assert::str_contains(text, "  #B2:\n    %2 = const 42\n    jump #B3(%2)")
    teko::assert::str_contains(text, "  #B3(%1):\n    ret %1")
}

#test
/**
 * lwt_coalesce_rhs_call_keeps_its_own_interned_rodata — `x ?? panic(str)`
 * (C1-6's `wasm_panic_hook` shape): the RHS interns a FRESH rodata entry
 * (`panic`'s string literal argument) that did not exist before the RHS was
 * lowered. Regression for a genuine miscompile: `lower_coalesce`'s final
 * merged context used to be built from the PRE-RHS context (`ctx1`), so
 * `ctx_with`'s field-copy silently DROPPED the RHS's own rodata growth —
 * the caller still emitted a `global_addr` relocation against `.Lstr0`, but
 * its definition never reached the module (an own-native "undefined
 * reference to `.Lstr0`" linker failure / an own-wasm "unresolved data
 * symbol" honest-stop, neither a lowering-time error). Asserts the rodata
 * entry AND the call survive the merge.
 *
 * @return void
 */
fn lwt_coalesce_rhs_call_keeps_its_own_interned_rodata() {
    let x = lwt_optional_var("x", checker::PrimKind::I64)
    let panic_call = lwt_str_call1("panic", "boom")
    let co = lwt_coalesce(x, panic_call, lwt_prim(checker::PrimKind::I64))
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(co))
    let f = lwt_fn("pick_or_panic", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as r => r; error as err => return }
    let text = print_lmodule(with_rodata(add_func(empty_module(), lf.func), lf.rodata))
    teko::assert::str_contains(text, "rodata .Lstr0:")
    teko::assert::str_contains(text, "call @tk_panic_str(")
}

/** lwt_named_opt_var — a `TVar` of `Named?` type — the safe-field-access receiver shape
    (A1-4, #382). */
fn lwt_named_opt_var(name: str, tname: str) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = false; func_ns = "" }; type = checker::Optional { inner = checker::Named { name = tname } }; line = 0; col = 0 }
}

/** lwt_safe_field_access — `recv?.field` of resolved (unwrapped) field type `ft` — its
    `.type` is `ft` widened into `Optional` (A1-4, #382). */
fn lwt_safe_field_access(recv: checker::TExpr, field: str, ft: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TSafeFieldAccess { receiver = recv; field = field }; type = checker::Optional { inner = ft }; line = 0; col = 0 }
}

#test
fn lwt_lowers_safe_field_access_via_branch_and_merge() {
    let p = lwt_named_opt_var("p", "Point")
    let sfa = lwt_safe_field_access(p, "y", lwt_prim(checker::PrimKind::I64))
    let params = teko::list::push(teko::list::empty(), lwt_param("p", "Point"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(sfa))
    let f = lwt_fn("read_y_opt", "teko::demo", params, checker::Optional { inner = checker::Prim { kind = checker::PrimKind::I64 } }, body)
    let lf = match lower_function(f, lwt_one_layout(lwt_point_layout())) { LoweredFunction as r => r.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "branch %0, #B1(), #B2()")
    teko::assert::str_contains(text, "  #B1:\n    %2 = field_addr %0, 8\n    %3 = load.i64 %2\n    jump #B3(%3)")
    teko::assert::str_contains(text, "  #B2:\n    %4 = const 0\n    jump #B3(%4)")
    teko::assert::str_contains(text, "  #B3(%1):\n    ret %1")
}

/**
 * lwt_iface_call — a dynamic contract-method `TCall`
 * (`is_iface_dispatch=true`): `args[0]` is the receiver, `slot` its vtable
 * index.
 *
 * @param str iface  the contract's canonical name (the callee path's first
 *                   segment)
 * @param str method  the dispatched method's name (the callee path's second
 *                     segment)
 * @param u32 slot  the method's vtable slot
 * @param []checker::TExpr args  the call's arguments (`args[0]` is the
 *                                receiver)
 * @param checker::Type ret  the call's resolved return type
 * @return checker::TExpr  the built interface-dispatch call node
 *
 * @since #382 A1-6
 */
fn lwt_iface_call(iface: str, method: str, slot: u32, args: []checker::TExpr, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TCall {
            callee = lwt_path2(iface, method); args = args; call_ns = ""
            is_closure_call = false; callee_type = checker::Void { }; is_iface_dispatch = true; iface_slot = slot
        }
        type = ret; line = 0; col = 0
    }
}

#test
fn lwt_lowers_iface_dispatch_call_via_vtable_load_and_indirect_call() {
    let recv = lwt_num_i64(1000 to i128)
    let extra = lwt_num_i64(7 to i128)
    let args = teko::list::push(teko::list::push(teko::list::empty(), recv), extra)
    let call = lwt_iface_call("Speaker", "speak", 2, args, lwt_prim(checker::PrimKind::I64))
    let text = lwt_lower_expr_text(call)
    teko::assert::str_contains(text, "%0 = const 1000")
    teko::assert::str_contains(text, "%1 = field_addr %0, 0")
    teko::assert::str_contains(text, "%2 = load.ptr %1")
    teko::assert::str_contains(text, "%3 = field_addr %0, 8")
    teko::assert::str_contains(text, "%4 = load.ptr %3")
    teko::assert::str_contains(text, "%5 = field_addr %4, 16")
    teko::assert::str_contains(text, "%6 = load.ptr %5")
    teko::assert::str_contains(text, "%7 = const 7")
    teko::assert::str_contains(text, "%8 = call.indirect %6(%2, %7)")
}

#test
fn lwt_lowers_void_iface_dispatch_call_as_a_valueless_indirect_call() {
    let recv = lwt_num_i64(2000 to i128)
    let args = teko::list::push(teko::list::empty(), recv)
    let call = lwt_iface_call("Speaker", "speak", 0, args, checker::Void { })
    let text = lwt_lower_expr_text(call)
    teko::assert::str_contains(text, "call.indirect %6(%2)")
    teko::assert::is_true(!teko::str::contains(text, "= call.indirect"))
}

/**
 * lwt_func_type — a resolved `Func` signature (A1-7, #382 — the type a
 * closure-typed local/expression carries).
 *
 * @param []checker::Type params  the signature's parameter types, in order
 * @param checker::Type ret  the signature's return type
 * @return checker::Type  the built `Func` type
 */
fn lwt_func_type(params: []checker::Type, ret: checker::Type) -> checker::Type {
    checker::Func { params = params; ret = ret; variadic = false; param_names = teko::list::empty(); n_required = params.len; defaults = teko::list::empty() }
}

/**
 * lwt_bind_typed — a `let` binding of an ARBITRARY resolved type `ty` (A1-7,
 * #382 — `lwt_bind` only covers a primitive-typed binding; a closure literal
 * binds at its own `Func` type).
 *
 * @param str name  the bound name
 * @param checker::TExpr e  the bound value
 * @param checker::Type ty  the binding's resolved type
 * @return checker::TStatement  the built `let` binding
 */
fn lwt_bind_typed(name: str, e: checker::TExpr, ty: checker::Type) -> checker::TStatement {
    checker::TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; bound = ty; value = e }
}

/**
 * lwt_fn_value — a bare top-level function used as a VALUE
 * (`TVar.is_func=true`, A1-7, #382).
 *
 * @param str name  the referenced function's own (unqualified) name
 * @param str ns  the referenced function's declaring namespace
 * @param checker::Type ty  the reference's resolved `Func` type
 * @return checker::TExpr  the built fn-as-value node
 */
fn lwt_fn_value(name: str, ns: str, ty: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = true; func_ns = ns }; type = ty; line = 0; col = 0 }
}

/**
 * lwt_closure_call — a call through a LOCAL closure value
 * (`TCall.is_closure_call=true`, A1-7, #382).
 *
 * @param str name  the local closure variable's name
 * @param []checker::TExpr args  the call's arguments
 * @param checker::Type callee_ty  the closure's own resolved `Func` type
 * @param checker::Type ret  the call's resolved return type
 * @return checker::TExpr  the built closure-call node
 */
fn lwt_closure_call(name: str, args: []checker::TExpr, callee_ty: checker::Type, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TCall {
            callee = lwt_path1(name); args = args; call_ns = ""
            is_closure_call = true; callee_type = callee_ty; is_iface_dispatch = false; iface_slot = 0
        }
        type = ret; line = 0; col = 0
    }
}

#test
fn lwt_lowers_fn_value_and_closure_call_via_a_thunk() {
    let fty = lwt_func_type(teko::list::push(teko::list::push(teko::list::empty(), lwt_prim(checker::PrimKind::I64)), lwt_prim(checker::PrimKind::I64)), lwt_prim(checker::PrimKind::I64))
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lwt_fn_value("add", "teko::demo", fty), fty)))
    let cargs = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(2 to i128)), lwt_num_i64(3 to i128))
    let call = lwt_closure_call("f", cargs, fty, lwt_prim(checker::PrimKind::I64))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), call), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "funcaddr @.Lclofn0")
    teko::assert::str_contains(text, "func @.Lclofn0(%0: ptr, %1: i64, %2: i64) -> i64 {")
    teko::assert::str_contains(text, "call @teko__demo__add(%1, %2)")
    teko::assert::str_contains(text, "call.indirect")
}

/**
 * lwt_lambda_param — one declared lambda parameter (A1-7, #382).
 *
 * @param str name  the parameter's name
 * @param checker::Type ty  the parameter's resolved type
 * @return checker::TLambdaParam  the built parameter node
 */
fn lwt_lambda_param(name: str, ty: checker::Type) -> checker::TLambdaParam {
    checker::TLambdaParam { name = name; type = ty }
}

/**
 * lwt_capture — one captured (free) variable (A1-7, #382 — always by-copy;
 * `by_ref` only ever flips for a `Ref<T>`-typed capture, irrelevant to the
 * lowering's own machine-class mapping).
 *
 * @param str name  the captured variable's name
 * @param checker::Type ty  the captured variable's resolved type
 * @return checker::TCapture  the built capture node
 */
fn lwt_capture(name: str, ty: checker::Type) -> checker::TCapture {
    checker::TCapture { name = name; type = ty; by_ref = false }
}

/**
 * lwt_lambda_types — the resolved type of each declared lambda parameter, in
 * order (A1-7, #382 — feeds `lwt_func_type` so a lambda literal's own `Func`
 * type matches its declared parameters).
 *
 * @param []checker::TLambdaParam params  the lambda's declared parameters
 * @return []checker::Type  each parameter's resolved type, in order
 */
fn lwt_lambda_types(params: []checker::TLambdaParam) -> []checker::Type {
    mut out: []checker::Type = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= params.len { break }
        out = teko::list::push(out, params[i].type)
        i++
    }
    out
}

/**
 * lwt_lambda — a closure LITERAL node (`TLambda`, A1-7, #382).
 *
 * @param []checker::TLambdaParam params  the lambda's declared parameters
 * @param []checker::TStatement body  the lambda's body statements
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @param checker::Type ret  the lambda's resolved return type
 * @return checker::TExpr  the built lambda-literal node
 */
fn lwt_lambda(params: []checker::TLambdaParam, body: []checker::TStatement, captures: []checker::TCapture, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TLambda { params = params; body = body; captures = captures; ret = ret; lift_id = 0 }
        type = lwt_func_type(lwt_lambda_types(params), ret); line = 0; col = 0
    }
}

#test
fn lwt_lowers_capturing_lambda_literal_and_closure_call() {
    let i64ty = lwt_prim(checker::PrimKind::I64)
    let lam_body = teko::list::push(teko::list::empty(), lwt_ret(lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_var("captured", checker::PrimKind::I64), checker::PrimKind::I64)))
    let params = teko::list::push(teko::list::empty(), lwt_lambda_param("x", i64ty))
    let captures = teko::list::push(teko::list::empty(), lwt_capture("captured", i64ty))
    let lam = lwt_lambda(params, lam_body, captures, i64ty)
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind("captured", lwt_num_i64(41 to i128), checker::PrimKind::I64)))
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lam, lam.type)))
    let call = lwt_closure_call("f", teko::list::push(teko::list::empty(), lwt_num_i64(1 to i128)), lam.type, i64ty)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), call), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "funcaddr @.Lclo0")
    teko::assert::str_contains(text, "func @.Lclo0(%0: ptr, %1: i64) -> i64 {")
    teko::assert::str_contains(text, "field_addr %0, 0")
    teko::assert::str_contains(text, "iadd %1,")
    teko::assert::str_contains(text, "call.indirect")
}

/**
 * lwt_lowers_function_trailing_expression_as_implicit_return — #421: a
 * NON-void `TFunction` whose body falls off the end (its last statement is
 * an expression-statement, no explicit `return`) auto-returns that
 * expression's value as its `LRet` — before the fix, `lower_block` discarded
 * the trailing `iadd`'s VReg and the body closed with a bare `ret` (no
 * value); the golden dump now shows `ret %2`.
 */
#test
fn lwt_lowers_function_trailing_expression_as_implicit_return() {
    let params = teko::list::push(teko::list::push(teko::list::empty(), lwt_param("a", "i64")), lwt_param("b", "i64"))
    let tail = lwt_bin(lexer::TokenKind::Plus, lwt_var("a", checker::PrimKind::I64), lwt_var("b", checker::PrimKind::I64), checker::PrimKind::I64)
    let body = teko::list::push(teko::list::empty(), lwt_exprstmt(tail))
    let f = lwt_fn("add_tail", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "func @teko__demo__add_tail(%0: i64, %1: i64) -> i64 {")
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret %2")
}

/**
 * lwt_lowers_lambda_trailing_expression_as_implicit_return — #421: an arrow
 * lambda `(x) => x + 1` (no explicit `return`) auto-returns its trailing
 * expression's value from the lifted body, exactly like a `TFunction` —
 * before the fix the lifted `.Lclo0` body closed with a bare `ret` and the
 * `iadd` result was unreachable.
 */
#test
fn lwt_lowers_lambda_trailing_expression_as_implicit_return() {
    let i64ty = lwt_prim(checker::PrimKind::I64)
    let lam_body = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_num_i64(1 to i128), checker::PrimKind::I64)))
    let params = teko::list::push(teko::list::empty(), lwt_lambda_param("x", i64ty))
    let lam = lwt_lambda(params, lam_body, teko::list::empty(), i64ty)
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lam, lam.type)))
    let call = lwt_closure_call("f", teko::list::push(teko::list::empty(), lwt_num_i64(41 to i128)), lam.type, i64ty)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), call), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "func @.Lclo0(%0: ptr, %1: i64) -> i64 {")
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret %3")
}

/**
 * lwt_lowers_defer_fires_before_a_void_lambdas_fall_through_return —
 * A1-2, #382: a bodyless-return (`void`) lambda literal `() => { let s=1;
 * defer { s = s + 100 } }` closes via `close_lambda_body`'s own
 * fall-through, which must fire the pending defer before its implicit
 * void `ret`, exactly like a `void` function's own fall-through.
 */
#test
fn lwt_lowers_defer_fires_before_a_void_lambdas_fall_through_return() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let lam_body = teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(defer_body))
    let lam = lwt_lambda(teko::list::empty(), lam_body, teko::list::empty(), checker::Void { })
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lam, lam.type)))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "const 100")
    teko::assert::str_contains(text, "iadd")
}

/**
 * lwt_interp_runs_function_trailing_expression_as_return_value — #421, the
 * interp-oracle side: `fn f() -> i32 { 42 }` (no explicit `return`) lowered
 * via `lower_function` and run through `interp_lmodule` yields exit code 42
 * — before the fix the fall-through body closed with a valueless `ret`, so
 * the interp's `is_return` outcome carried 0, not 42.
 */
#test
fn lwt_interp_runs_function_trailing_expression_as_return_value() {
    let body = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num(42 to i128, checker::PrimKind::I32)))
    let f = lwt_fn("f", "", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I32 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let m = add_func(empty_module(), lf)
    teko::assert::is_true(interp_lmodule(m, "f", teko::list::empty()) == (42 to i128))
}

/**
 * lwt_interp_runs_lambda_trailing_expression_via_closure_call — #421, the
 * interp-oracle side: an arrow lambda `(x) => x + 1` (no explicit `return`),
 * called through its closure value with `x = 41`, yields 42 as the process
 * exit code — before the fix the lifted lambda body's fall-through `ret`
 * carried no value, so the closure call always resolved to 0.
 */
#test
fn lwt_interp_runs_lambda_trailing_expression_via_closure_call() {
    let i64ty = lwt_prim(checker::PrimKind::I64)
    let lam_body = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_num_i64(1 to i128), checker::PrimKind::I64)))
    let params = teko::list::push(teko::list::empty(), lwt_lambda_param("x", i64ty))
    let lam = lwt_lambda(params, lam_body, teko::list::empty(), i64ty)
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lam, lam.type)))
    let call = lwt_closure_call("f", teko::list::push(teko::list::empty(), lwt_num_i64(41 to i128)), lam.type, i64ty)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), call), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    teko::assert::is_true(interp_lmodule(m, "main", teko::list::empty()) == (42 to i128))
}

/**
 * lwt_lowers_loop_with_break_threads_the_counter_through_head_and_exit_block_args
 * — A1-2, #382: `mut s=0; loop { s=s+1; if s==5 { break } }; exit(s)`. The
 * loop head (`#B1`) and exit (`#B2`) are both promoted with one block-arg
 * for `s` — the ONLY scalar local live at the loop's entry — mirroring
 * exactly how an if-expression's result VReg merges through its own
 * block-arg (§2.4): the entry jump seeds the head's param with the
 * pre-loop value, the if-statement's `break` arm carries the
 * freshly-incremented value straight into the exit, and the body's OWN
 * fall-through (through the if-statement's own merge block, `#B5`)
 * implicitly jumps BACK to the head carrying that SAME updated value — a
 * loop-mutated counter threads correctly across iterations.
 */
#test
fn lwt_lowers_loop_with_break_threads_the_counter_through_head_and_exit_block_args() {
    let bump = lwt_simple_assign("s", lexer::TokenKind::Assign, lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(1 to i128), checker::PrimKind::I64), checker::PrimKind::I64)
    let cond = lwt_cmp(lwt_var("s", checker::PrimKind::I64), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::EqEq, lwt_num_i64(5 to i128))))
    let ifstmt = lwt_if_stmt(cond, teko::list::push(teko::list::empty(), lwt_break("")), false, teko::list::empty())
    let loop_body = teko::list::push(teko::list::push(teko::list::empty(), bump), lwt_exprstmt(ifstmt))
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind("s", lwt_num_i64(0 to i128), checker::PrimKind::I64)))
    items = teko::list::push(items, lwt_item(lwt_loop("", loop_body)))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), lwt_var("s", checker::PrimKind::I64)), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "  #B0:\n    %0 = const 0\n    jump #B1(%0)")
    teko::assert::str_contains(text, "  #B1(%1):\n    %3 = const 1\n    %4 = iadd %1, %3")
    teko::assert::str_contains(text, "%6 = icmpeq %4, %5")
    teko::assert::str_contains(text, "branch %6, #B3(), #B4()")
    teko::assert::str_contains(text, "  #B2(%2):\n    call @tk_exit(%2)")
    teko::assert::str_contains(text, "  #B3:\n    jump #B2(%4)")
    teko::assert::str_contains(text, "  #B4:\n    jump #B5()")
    teko::assert::str_contains(text, "  #B5:\n    jump #B1(%4)")
}

/**
 * lwt_lowers_bare_break_terminates_the_head_block_with_no_reloop — A1-2,
 * #382: `loop { break }` — the break is the loop body's ONLY (and hence
 * last) statement, so it terminates the head block directly; the loop's
 * own fall-through close (`close_loop_body`) sees the block already
 * terminated and does NOT append a redundant jump back to the head.
 */
#test
fn lwt_lowers_bare_break_terminates_the_head_block_with_no_reloop() {
    let body = teko::list::push(teko::list::empty(), lwt_loop("", teko::list::push(teko::list::empty(), lwt_break(""))))
    let f = lwt_fn("g", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B0:\n    jump #B1()")
    teko::assert::str_contains(text, "  #B1:\n    jump #B2()")
    teko::assert::str_contains(text, "  #B2:\n    ret")
}

/**
 * lwt_lowers_labeled_break_targets_the_outer_loop_past_the_inner_one —
 * A1-2, #382: `OUTER: loop { loop { break OUTER } }` — the INNER
 * (unlabelled) loop's own `break "outer"` must resolve past its own exit
 * block to the OUTER loop's exit (`find_loop_target` scans innermost-first,
 * skipping a non-matching label), proving a labelled break is not confused
 * with the innermost loop.
 */
#test
fn lwt_lowers_labeled_break_targets_the_outer_loop_past_the_inner_one() {
    let inner = lwt_loop("", teko::list::push(teko::list::empty(), lwt_break("OUTER")))
    let outer_body = teko::list::push(teko::list::empty(), inner)
    let body = teko::list::push(teko::list::empty(), lwt_loop("OUTER", outer_body))
    let f = lwt_fn("h", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    jump #B3()")
    teko::assert::str_contains(text, "  #B3:\n    jump #B2()")
    teko::assert::str_contains(text, "  #B2:\n    ret")
}

/**
 * lwt_lowers_continue_jumps_back_to_the_loop_head — A1-2, #382:
 * `loop { continue }` — the continue is the body's only statement,
 * terminating the head block with a self-jump back to itself (`#B1: jump
 * #B1()`), exercising `lower_continue`'s target-head resolution separately
