}

/**
 * lwt_defer_inside_loop_body_fires_each_fallthrough_iteration_never_survives_past_exit
 * — PR #553 follow-up nit: `let s=1; loop { defer { s = s + 100 } };
 * return s` — the loop's body NEVER breaks, so every trip through it closes
 * via `close_loop_body`'s OWN fall-through replay (not `lower_break`'s):
 * the loop head (`#B1`) fires the body's pending defer — LIFO, from the
 * defer-delta base the BODY itself started at — immediately before its
 * implicit back-edge jump to itself, once per (baked-in, static)
 * iteration. `close_loop`'s OWN `.defers` restore (to whatever the defer
 * stack was BEFORE the loop — here, empty) means the exit block (`#B2`,
 * the function's tail here) carries NOTHING but the plain `ret` of its own
 * block-arg: the exact leak `close_loop`'s `defers = outer.defers` fixes
 * (PR #553 review finding) — carrying `body_done.defers` forward instead
 * would leave the ALREADY-fired entry pending, so the tail `return`'s own
 * `replay_defers(ctx, 0)` would fire it a SECOND time there.
 *
 * @return void
 */
#test
fn lwt_defer_inside_loop_body_fires_each_fallthrough_iteration_never_survives_past_exit() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let loop_body = teko::list::push(teko::list::empty(), lwt_defer(defer_body))
    let tail_ret = lwt_ret(lwt_var("s", checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_loop("", loop_body)), tail_ret)
    let f = lwt_fn("loop_iter_scoped", "teko::demo", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1(%1):\n    %3 = const 100\n    %4 = iadd %1, %3\n    jump #B1(%4)")
    teko::assert::str_contains(text, "  #B2(%2):\n    ret %2\n}")
}

/**
 * lwt_defer_inside_loop_body_fires_via_break_and_the_enclosing_defer_still_fires_after_the_loop_exits
 * — PR #553 follow-up nit: `let s=1; defer { s = s + 1 }; loop { defer { s
 * = s + 100 }; break }; return s` — TWO defers, at TWO different scopes:
 * one registered BEFORE the loop (the enclosing FUNCTION scope), one
 * registered INSIDE the loop's own body. The `break` fires ONLY the loop's
 * OWN defer — LIFO, from the loop's `defer_base` (the defer-stack depth the
 * BODY itself started at, which already SITS ABOVE the enclosing defer, so
 * `lower_break`'s `replay_defers(ctx, target.defer_base)` never re-fires
 * it) — immediately before its jump to the exit block (`#B1`, the loop
 * head; `#B2`, the exit). `close_loop`'s OWN `.defers` restore (to what the
 * stack was BEFORE the loop — the enclosing defer ALONE, still pending)
 * means the exit block still carries the OUTER defer, correctly fired
 * ONLY ONCE there by the tail `return`'s own `replay_defers(ctx, 0)` — NOT
 * a second copy of the loop's OWN already-fired defer (the exact leak
 * `close_loop`'s `defers = outer.defers` fixes, PR #553 review finding:
 * carrying `body_done.defers` forward instead would leave the loop's own
 * ALREADY-fired entry pending too, so the tail's replay would fire BOTH a
 * second time).
 *
 * @return void
 */
#test
fn lwt_defer_inside_loop_body_fires_via_break_and_the_enclosing_defer_still_fires_after_the_loop_exits() {
    let s_plus_1 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(1 to i128), checker::PrimKind::I64)
    let outer_defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_1, checker::PrimKind::I64))
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let loop_defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let loop_body = teko::list::push(teko::list::push(teko::list::empty(), lwt_defer(loop_defer_body)), lwt_break(""))
    let tail_ret = lwt_ret(lwt_var("s", checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(outer_defer_body)), lwt_loop("", loop_body)), tail_ret)
    let f = lwt_fn("loop_break_scoped", "teko::demo", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B0:\n    %0 = const 1\n    jump #B1(%0)")
    teko::assert::str_contains(text, "  #B1(%1):\n    %3 = const 100\n    %4 = iadd %1, %3\n    jump #B2(%4)")
    teko::assert::str_contains(text, "  #B2(%2):\n    %5 = const 1\n    %6 = iadd %2, %5\n    ret %6\n}")
}

/**
 * lwt_lowers_defer_fires_before_the_return_value_reads_it — A1-2, #382:
 * `let s=1; defer { s = s + 100 }; return s` registers the defer inline
 * (emitting nothing) and fires it — LIFO, here just the one entry — BEFORE
 * lowering the `return`'s value expression, so `s` resolves to the
 * POST-defer VReg: the return observes the deferred mutation (mirrors the
 * C backend's `emit_return`, which fires defers before its own return-value
 * text, `codegen.tks:5770-5773`).
 */
#test
fn lwt_lowers_defer_fires_before_the_return_value_reads_it() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(defer_body)), lwt_ret(lwt_var("s", checker::PrimKind::I64)))
    let f = lwt_fn("f", "teko::demo", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "%0 = const 1")
    teko::assert::str_contains(text, "const 100")
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret %2")
}

/**
 * lwt_lowers_defer_fires_before_a_trailing_expressions_auto_return —
 * A1-2, #382: `let s=1; defer { s = s + 100 }; s` — the body's trailing
 * EXPRESSION (no explicit `return`) auto-returns via `lower_fn_body`
 * (#421). The trailing value is MATERIALIZED before the pending defer
 * fires (mirroring the C backend's `emit_exprstmt_tail`), so the return
 * observes the PRE-defer `s` (%0) — unlike an explicit `return`, whose
 * `emit_return` fires defers first (see the sibling test).
 */
#test
fn lwt_lowers_defer_fires_before_a_trailing_expressions_auto_return() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(defer_body)), lwt_exprstmt(lwt_var("s", checker::PrimKind::I64)))
    let f = lwt_fn("tail_defer", "teko::demo", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "const 100")
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret %0")
}

/**
 * lwt_lowers_defer_fires_before_a_void_functions_fall_through_return —
 * A1-2, #382: `fn v() { let s=1; defer { s = s + 100 } }` — a VOID body
 * with no explicit `return` closes via `close_function`'s own
 * fall-through, which must fire the pending defer before its implicit
 * void `ret` (mirrors the C backend's fn-body fall-through defer fire,
 * `codegen.tks:6418-6429`).
 */
#test
fn lwt_lowers_defer_fires_before_a_void_functions_fall_through_return() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(defer_body))
    let f = lwt_fn("v", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "const 100")
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret\n}")
}

/**
 * lwt_lowers_a_defer_fires_independently_on_each_of_two_return_paths —
 * A1-2, #382: `let s=1; defer { s = s + 100 }; if x>0 { return s };
 * return s + 1` — the SAME registered defer replays (LIFO, from index 0)
 * independently at EACH reachable `return`: once inside the `if`'s
 * then-arm and once more at the tail `return`, each producing its OWN
 * fresh `iadd …, 100` from the ORIGINAL pre-defer value — proving
 * `replay_defers` is a non-destructive replay (firing once does not
 * consume the entry), so a defer fires at EVERY scope exit, not just the
 * first one reached.
 */
#test
fn lwt_lowers_a_defer_fires_independently_on_each_of_two_return_paths() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let cond = lwt_cmp(lwt_var("x", checker::PrimKind::I64), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Gt, lwt_num_i64(0 to i128))))
    let then_ret = teko::list::push(teko::list::empty(), lwt_ret(lwt_var("s", checker::PrimKind::I64)))
    let ifstmt = lwt_if_stmt(cond, then_ret, false, teko::list::empty())
    let tail_ret = lwt_ret(lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(1 to i128), checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(defer_body)), lwt_exprstmt(ifstmt)), tail_ret)
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let f = lwt_fn("multi", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    %4 = const 100\n    %5 = iadd %1, %4\n    ret %5")
    teko::assert::str_contains(text, "  #B3:\n    %6 = const 100\n    %7 = iadd %1, %6\n    %8 = const 1\n    %9 = iadd %7, %8\n    ret %9")
}

/**
 * lwt_defer_inside_if_arm_fires_only_on_that_arms_own_branch — PR #553
 * review finding, UPDATED for #389 F1b item 1 (defer-write propagation):
 * `let s=1; if x>0 { defer { s = s + 100 } }; return s` — the `defer`
 * registers ONLY inside the THEN arm, never before the `if`. The THEN arm
 * (`#B1`) fires it — LIFO, from the defer-delta base this arm itself started
 * at — as part of ITS OWN close, immediately before its jump to the merge.
 *
 * `s` is now THREADED through the merge as a block-param (`#B3(%4)`): F1b
 * re-adds the `TDeferStmt` descent so the defer's `s = s + 100` is seen, and
 * `close_arm_replaying_defers` re-samples the THEN arm's scalar arg from its
 * POST-replay env, so THEN jumps `#B3(%6)` — its POST-defer `s` (`%6 = iadd
 * %1, %5`). The ELSE arm (`#B2`, the implicit pass-through — no `else` block)
 * never runs the defer, so it jumps its own untouched `s`, `#B3(%1)`, and the
 * tail reads the merge param, `ret %4`. Before F1b the merge carried ZERO
 * params and the tail read the STALE pre-defer `s` (`ret %1`) — the OLD golden
 * shape encoded that same-class silent merge-drop; the arm block still holds
 * the single `iadd` and `#B3` never carries a stray one (the defer is never
 * replayed a second time at the merge, `close_arm_replaying_defers`'s original
 * PR #553 fix, unconditional-fire regardless of branch).
 *
 * @return void
 */
#test
fn lwt_defer_inside_if_arm_fires_only_on_that_arms_own_branch() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let cond = lwt_cmp(lwt_var("x", checker::PrimKind::I64), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Gt, lwt_num_i64(0 to i128))))
    let then_blk = teko::list::push(teko::list::empty(), lwt_defer(defer_body))
    let ifstmt = lwt_if_stmt(cond, then_blk, false, teko::list::empty())
    let tail_ret = lwt_ret(lwt_var("s", checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_exprstmt(ifstmt)), tail_ret)
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let f = lwt_fn("arm_scoped", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    %5 = const 100\n    %6 = iadd %1, %5\n    jump #B3(%6)")
    teko::assert::str_contains(text, "  #B2:\n    jump #B3(%1)")
    teko::assert::str_contains(text, "  #B3(%4):\n    ret %4\n}")
}

/**
 * lwt_defer_inside_else_arm_fires_only_on_that_arms_own_branch — PR #553
 * follow-up nit, UPDATED for #389 F1b item 1: the ELSE-arm mirror of
 * `lwt_defer_inside_if_arm_fires_only_on_that_arms_own_branch`: `let s=1; if
 * x>0 { } else { defer { s = s + 100 } }; return s` — the `defer` registers
 * ONLY inside the ELSE arm, never the empty THEN arm. The THEN arm (`#B1`,
 * empty) jumps its own untouched `s` straight to the merge, `#B3(%1)`; the
 * ELSE arm (`#B2`) fires the defer — LIFO, from the defer-delta base THIS arm
 * itself started at — as part of ITS OWN close, then jumps its POST-defer `s`,
 * `#B3(%6)` (`%6 = iadd %1, %5`), `close_arm_replaying_defers` re-sampling the
 * scalar arg from its post-replay env. `s` is THREADED as the merge param
 * `#B3(%4)` and the tail reads it, `ret %4` — proving the ELSE arm's defer
 * write reaches the merge (F1b's `TDeferStmt` descent scopes EITHER arm
 * identically, not just the THEN side). Before F1b the merge carried ZERO
 * params and the tail read the STALE pre-defer `s` (`ret %1`) — the OLD golden
 * shape encoded that same-class silent merge-drop; the defer is still never
 * replayed a second time at the merge (its original PR #553 scope fix).
 *
 * @return void
 */
#test
fn lwt_defer_inside_else_arm_fires_only_on_that_arms_own_branch() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let cond = lwt_cmp(lwt_var("x", checker::PrimKind::I64), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Gt, lwt_num_i64(0 to i128))))
    let else_blk = teko::list::push(teko::list::empty(), lwt_defer(defer_body))
    let ifstmt = lwt_if_stmt(cond, teko::list::empty(), true, else_blk)
    let tail_ret = lwt_ret(lwt_var("s", checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_exprstmt(ifstmt)), tail_ret)
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let f = lwt_fn("else_arm_scoped", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    jump #B3(%1)")
    teko::assert::str_contains(text, "  #B2:\n    %5 = const 100\n    %6 = iadd %1, %5\n    jump #B3(%6)")
    teko::assert::str_contains(text, "  #B3(%4):\n    ret %4\n}")
}

/**
 * lwt_defer_inside_if_value_then_arm_fires_only_on_that_arms_own_branch —
 * PR #553 follow-up nit, UPDATED for #389 F1b item 1: the VALUE-producing
 * (`lower_if_value`) shape of
 * `lwt_defer_inside_if_arm_fires_only_on_that_arms_own_branch`: `let s=1;
 * return if x>0 { defer { s = s + 100 }; s } else { s }` — the `defer`
 * registers ONLY inside the THEN arm, before its own tail value `s`. The THEN
 * arm (`#B1`) fires it — LIFO, from the defer-delta base THIS arm itself
 * started at — AFTER its tail value is read but BEFORE its jump.
 *
 * The merge now carries TWO params, `#B3(%4, %5)`: the FIRST (`%4`) is the
 * if-expression RESULT value, the SECOND (`%5`) the threaded enclosing scalar
 * `s` (F1b's `TDeferStmt` descent sees the defer's `s = s + 100`). CRITICALLY
 * the VALUE arg stays PRE-defer: the tail `s` (`%1`) is captured before the
 * defer replays, so the THEN arm jumps `#B3(%1, %7)` — value `%1` (pre-defer)
 * THEN scalar `%7` (post-defer `s`, `%7 = iadd %1, %6`); `close_arm_replaying_
 * defers` re-samples only the SCALAR arg from the post-replay env, never the
 * value. The ELSE arm (`#B2`, no defer) jumps `#B3(%1, %1)`; the tail returns
 * the VALUE param, `ret %4`. Before F1b the merge carried only the value param
 * (`#B3(%4)`) and jumped `#B3(%1)` — the OLD golden shape dropped `s` at the
 * merge; the defer is still never replayed a second time there.
 *
 * @return void
 */
#test
fn lwt_defer_inside_if_value_then_arm_fires_only_on_that_arms_own_branch() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let cond = lwt_cmp(lwt_var("x", checker::PrimKind::I64), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Gt, lwt_num_i64(0 to i128))))
    let then_blk = teko::list::push(teko::list::push(teko::list::empty(), lwt_defer(defer_body)), lwt_exprstmt(lwt_var("s", checker::PrimKind::I64)))
    let else_blk = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_var("s", checker::PrimKind::I64)))
    let ifexpr = lwt_if_value(cond, then_blk, else_blk, checker::PrimKind::I64)
    let body = teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_ret(ifexpr))
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let f = lwt_fn("if_value_arm_scoped", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    %6 = const 100\n    %7 = iadd %1, %6\n    jump #B3(%1, %7)")
    teko::assert::str_contains(text, "  #B2:\n    jump #B3(%1, %1)")
    teko::assert::str_contains(text, "  #B3(%4, %5):\n    ret %4\n}")
}

/**
 * lwt_lowers_loop_leaves_a_fat_local_unpromoted — A1-2, #382: `let s = "hi";
 * loop { break }; exit(s.len)` — `s` is the ONLY name live at the loop's
 * entry, but it is a FAT (str) binding, so `promote_env` leaves it
 * UNPROMOTED: both the head and exit blocks stay zero-arg, and `s.len`
 * still resolves with NO memory traffic (the fat length VReg threads
 * through the loop untouched, exactly as it was before it).
 */
#test
fn lwt_lowers_loop_leaves_a_fat_local_unpromoted() {
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("s", lwt_strlit("hi"), checker::Str { })))
    items = teko::list::push(items, lwt_item(lwt_loop("", teko::list::push(teko::list::empty(), lwt_break("")))))
    let len_access = lwt_field_access(lwt_typed_var("s", checker::Str { }), "len", lwt_prim(checker::PrimKind::I64))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), len_access), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "%1 = const 2")
    teko::assert::str_contains(text, "    jump #B1()\n  #B1:\n    jump #B2()\n  #B2:\n    call @tk_exit(%1)")
}

#test
/**
 * lwt_fat_local_reassign_honest_stops_on_later_fat_use — #389 F1b item 3
 * review finding 1: `let s = "hello"; s = "hi"; return s.len` must HONEST-STOP,
 * NOT silently return the STALE pre-reassignment length. `lower_assign_simple`'s
 * `=` path always lowers the RHS through the plain (scalar) `lower_expr`, so a
 * reassignment of a fat-typed name only ever supplies a fresh PTR VReg, never a
 * fresh length — `lenv_reassign` must therefore NEVER update a fat binding's
 * `vregs` slot in place (that would pair the NEW ptr with the OLD `len_vregs`
 * entry, a silent stale-length miscompile); it falls back to the pre-item3
 * append (a fresh SCALAR entry, `has_len=false`), so `lenv_lookup_fat`'s
 * newest-first scan for `s` hits that scalar entry and reports `has_len=false`,
 * and `lower_len_field` -> `lower_fat_expr` -> `lower_var_fat` honest-stops with
 * the SAME NAMED error a fat reassignment produced before item-3 ever touched
 * `lenv_reassign` — refusing the program instead of returning a wrong answer.
 *
 * @return void
 */
fn lwt_fat_local_reassign_honest_stops_on_later_fat_use() {
    let s_bind = lwt_bind_typed("s", lwt_strlit("hello"), checker::Str { })
    let reassign = lwt_simple_assign("s", lexer::TokenKind::Assign, lwt_strlit("hi"), checker::PrimKind::I64)
    let len_access = lwt_field_access(lwt_typed_var("s", checker::Str { }), "len", lwt_prim(checker::PrimKind::U64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), s_bind), reassign), lwt_ret(len_access))
    let f = lwt_fn("fat_reassign_then_len", "teko::demo", teko::list::empty(), lwt_prim(checker::PrimKind::U64), body)
    let out = match lower_function(f) { LoweredFunction => "ok"; error as e => e.message }
    teko::assert::str_contains(out, "`s` is not a fat-pointer local")
}

/**
 * lwt_honest_stop_on_break_outside_a_loop — a bare `break` with no
 * enclosing `loop` on its lowering path is a checker invariant break
 * (M.1) — `find_loop_target` honest-stops by name rather than resolving
 * to a bogus target (A1-2, #382).
 */
#test
fn lwt_honest_stop_on_break_outside_a_loop() {
    let body = teko::list::push(teko::list::empty(), lwt_break(""))
    let f = lwt_fn("stray_break", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let out = match lower_function(f) { LoweredFunction => "ok"; error as e => e.message }
    teko::assert::str_contains(out, "break/continue outside a loop")
}

/**
 * lwt_honest_stop_on_continue_outside_a_loop — the same invariant guard as
 * `lwt_honest_stop_on_break_outside_a_loop`, exercised through
 * `lower_continue`'s own call site (A1-2, #382).
 */
#test
fn lwt_honest_stop_on_continue_outside_a_loop() {
    let body = teko::list::push(teko::list::empty(), lwt_continue(""))
    let f = lwt_fn("stray_continue", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let out = match lower_function(f) { LoweredFunction => "ok"; error as e => e.message }
    teko::assert::str_contains(out, "break/continue outside a loop")
}

/** lwt_field — one `struct` field: `name: <tname>`, an all-public struct field (#414, #382). */
fn lwt_field(name: str, tname: str) -> parser::Field {
    parser::Field { name = name; type_ann = lwt_named_te(tname); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
}

/** lwt_struct_decl — a `struct <name> { <fields> }` TypeDecl, wrapped as a `checker::TItem`
    (#414, #382). */
fn lwt_struct_decl(name: str, fields: []parser::Field) -> checker::TItem {
    parser::TypeDecl {
        name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }
        vis = parser::Visibility::Pub; has_doc = false; doc = ""
        line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""
        is_unsafe = false; must_free = false
    }
}

/**
 * lwt_two_fields — a two-element `[]parser::Field` list, in order (#414, #382).
 *
 * @param parser::Field a  the first field
 * @param parser::Field b  the second field
 * @return []parser::Field  `[a, b]`
 */
fn lwt_two_fields(a: parser::Field, b: parser::Field) -> []parser::Field {
    teko::list::push(teko::list::push(teko::list::empty(), a), b)
}

/**
 * lwt_three_fields — a three-element `[]parser::Field` list, in order (#414, #382).
 *
 * @param parser::Field a  the first field
 * @param parser::Field b  the second field
 * @param parser::Field c  the third field
 * @return []parser::Field  `[a, b, c]`
 */
fn lwt_three_fields(a: parser::Field, b: parser::Field, c: parser::Field) -> []parser::Field {
    teko::list::push(lwt_two_fields(a, b), c)
}

/**
 * lwt_nested_struct_layout_program — `struct Point { x: i64; y: i64 }` (declared
 * first, so its layout is already KNOWN) followed by `struct Line { a: byte; p:
 * Point; c: byte }`, whose middle field is Point BY VALUE (#414, #382).
 *
 * @return checker::TProgram  the two-struct program
 */
fn lwt_nested_struct_layout_program() -> checker::TProgram {
    let point = lwt_struct_decl("Point", lwt_two_fields(lwt_field("x", "i64"), lwt_field("y", "i64")))
    let line = lwt_struct_decl("Line", lwt_three_fields(lwt_field("a", "byte"), lwt_field("p", "Point"), lwt_field("c", "byte")))
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, point)
    items = teko::list::push(items, line)
    checker::TProgram { items = items }
}

/**
 * nested_struct_by_value_field_layout_accounts_for_the_inner_structs_real_width
 * — #414, #382: `Line`'s middle field `p: Point` (a struct BY VALUE, size 16
 * align 8) must widen `Line` to size 32 (`a`@0 padded to 8 for `p`, `p`@8
 * spans its own 16 bytes, `c`@24 padded to the struct's own 8-byte
 * alignment) — the OLD `ltype_of_typeexpr`-only mapping collapsed `p` to a
 * bare `Ptr` (8 bytes), under-sizing `Line` to 24 and misplacing `c`@16.
 */
#test
fn nested_struct_by_value_field_layout_accounts_for_the_inner_structs_real_width() {
    let m = match lower_program(lwt_nested_struct_layout_program()) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "layout Point: size=16 align=8 {x@0, y@8}")
    teko::assert::str_contains(text, "layout Line: size=32 align=8 {a@0, p@8, c@24}")
}

/**
 * lwt_forward_referenced_struct_field_falls_back_to_ptr — #414, #382: a field
 * naming a struct declared LATER in program order (not yet in the
 * accumulated layout table when `Early` itself is resolved) falls back to
 * the scalar `Ptr` mapping, unchanged — `struct_layout_of_field` only
 * widens a field whose named struct is ALREADY known.
 */
#test
fn lwt_forward_referenced_struct_field_falls_back_to_ptr() {
    let early = lwt_struct_decl("Early", teko::list::push(teko::list::empty(), lwt_field("later", "Later")))
    let later = lwt_struct_decl("Later", teko::list::push(teko::list::empty(), lwt_field("v", "i64")))
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, early)
    items = teko::list::push(items, later)
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "layout Early: size=8 align=8 {later@0}")
}

/**
 * lwt_virtual_main_returns_the_trailing_top_level_expressions_value — #423,
 * #382: `let x = 40; x + 2` (no explicit `exit`/`return`) — the loose
 * top-level statement list's TRAILING non-void expression becomes the
 * program's exit code, exactly like a non-void function body's own
 * trailing-expression auto-return (#421). Before the fix, `close_virtual_main`
 * unconditionally emitted `const 0; ret` here, discarding the `42` value.
 */
#test
fn lwt_virtual_main_returns_the_trailing_top_level_expressions_value() {
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind("x", lwt_num_i64(40 to i128), checker::PrimKind::I64)))
    let tail = lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_num_i64(2 to i128), checker::PrimKind::I64)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(tail)))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret %2")
    teko::assert::is_true(!teko::str::contains(text, "const 0"))
}

/**
 * lwt_virtual_main_still_falls_through_to_return_zero_after_a_void_tail_call
 * — #423, #382: a VOID-typed trailing expression-statement (a call to a
 * void function/builtin, mirroring the existing `exit`-tail fixtures) is
 * NOT an exit-code value — `close_virtual_main` still falls through to
 * `const 0; ret` exactly as before the fix.
 */
#test
fn lwt_virtual_main_still_falls_through_to_return_zero_after_a_void_tail_call() {
    let void_call = lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), lwt_num_i64(1 to i128)), checker::Void { })
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), lwt_item(lwt_exprstmt(void_call))) }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "func @main() -> i32 {")
    teko::assert::str_contains(text, "const 0")
}
