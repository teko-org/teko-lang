use teko::checker
use teko::lexer
use teko::parser

/** lwt_prim — a resolved primitive Type for a PrimKind (the arithmetic operand type).

    Unit tests for the TAST->LIR lowering (C2-C4, issue #221). They build small typed
    ASTs by hand and assert over the stable printer text (the LIR's diff bar) plus the
    pure mapping tables (ltype_of / lbinop_of / lunop_of) and the honest-stop messages.
    The `lwt_` prefix keeps helper names from colliding with other test modules (the VM
    resolves tests by last path segment). */
fn lwt_prim(k: checker::PrimKind) -> checker::Type { checker::Prim { kind = k } }

fn lwt_num(v: i128, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TNumber { is_float = false; value = v; fval = 0.0 }; type = lwt_prim(k); line = 0; col = 0 }
}

fn lwt_num_i64(v: i128) -> checker::TExpr { lwt_num(v, checker::PrimKind::I64) }

fn lwt_fnum(v: f64) -> checker::TExpr {
    checker::TExpr { kind = checker::TNumber { is_float = true; value = 0 to i128; fval = v }; type = lwt_prim(checker::PrimKind::F64); line = 0; col = 0 }
}

fn lwt_var(name: str, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = false; func_ns = "" }; type = lwt_prim(k); line = 0; col = 0 }
}

fn lwt_bin(op: lexer::TokenKind, l: checker::TExpr, r: checker::TExpr, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TBinary { op = op; left = l; right = r }; type = lwt_prim(k); line = 0; col = 0 }
}

fn lwt_unary(op: lexer::TokenKind, operand: checker::TExpr, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TUnary { op = op; operand = operand }; type = lwt_prim(k); line = 0; col = 0 }
}

fn lwt_cast(inner: checker::TExpr, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TCast { expr = inner }; type = lwt_prim(k); line = 0; col = 0 }
}

/** lwt_cmp_term — one adjacent term of a TCompare chain (`op operand`). */
fn lwt_cmp_term(op: lexer::TokenKind, e: checker::TExpr) -> checker::TCmpTerm { checker::TCmpTerm { op = op; operand = e } }

/** lwt_cmp — a TCompare node (`first` + the adjacent `terms`), always Bool-typed. */
fn lwt_cmp(first: checker::TExpr, terms: []checker::TCmpTerm) -> checker::TExpr {
    checker::TExpr { kind = checker::TCompare { first = first; rest = terms }; type = lwt_prim(checker::PrimKind::Bool); line = 0; col = 0 }
}

/** lwt_if_stmt — a Void (no-value) TIfExpr node, the if-STATEMENT shape. */
fn lwt_if_stmt(cond: checker::TExpr, then_blk: []checker::TStatement, has_else: bool, else_blk: []checker::TStatement) -> checker::TExpr {
    checker::TExpr { kind = checker::TIfExpr { cond = cond; then_blk = then_blk; has_else = has_else; else_blk = else_blk }; type = checker::Void { }; line = 0; col = 0 }
}

/** lwt_if_value — a value-producing TIfExpr node (always has an else), typed `k`. */
fn lwt_if_value(cond: checker::TExpr, then_blk: []checker::TStatement, else_blk: []checker::TStatement, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TIfExpr { cond = cond; then_blk = then_blk; has_else = true; else_blk = else_blk }; type = lwt_prim(k); line = 0; col = 0 }
}

fn lwt_seg(s: str) -> parser::Segment { parser::Segment { name = s } }
fn lwt_path1(s: str) -> parser::Path { parser::Path { segments = teko::list::push(teko::list::empty(), lwt_seg(s)) } }

/**
 * lwt_path2 — a two-segment path `a::b` (the `[<Iface>, <method>]` callee
 * shape a dynamic contract-method dispatch's `TCall.callee` carries).
 *
 * @param str a  the first segment's name
 * @param str b  the second segment's name
 * @return parser::Path  the two-segment path `a::b`
 *
 * @since #382 A1-6
 */
fn lwt_path2(a: str, b: str) -> parser::Path {
    parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), lwt_seg(a)), lwt_seg(b)) }
}

fn lwt_call(path: parser::Path, ns: str, args: []checker::TExpr, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TCall { callee = path; args = args; call_ns = ns; is_closure_call = false; callee_type = checker::Void { }; is_iface_dispatch = false; iface_slot = 0 }
        type = ret; line = 0; col = 0
    }
}

fn lwt_named_te(s: str) -> parser::TypeExpr { parser::NamedType { path = lwt_path1(s); args = teko::list::empty() } }

fn lwt_param(name: str, tname: str) -> parser::Param {
    parser::Param { name = name; has_type = true; type_ann = lwt_named_te(tname); is_params = false; has_default = false; default_expr = parser::no_expr() }
}

fn lwt_ret(e: checker::TExpr) -> checker::TStatement { checker::TReturn { has_value = true; value = e } }
fn lwt_bind(name: str, e: checker::TExpr, k: checker::PrimKind) -> checker::TStatement {
    checker::TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; bound = lwt_prim(k); value = e }
}
fn lwt_exprstmt(e: checker::TExpr) -> checker::TStatement { checker::TExprStmt { expr = e } }

/** lwt_loop — a `TLoopStmt` node with an empty `init` (A1-2, #382 — `label` empty = unlabeled). */
fn lwt_loop(label: str, body: []checker::TStatement) -> checker::TStatement {
    checker::TLoopStmt { label = label; init = teko::list::empty(); body = body }
}

/** lwt_break — a `TBreakStmt` node (A1-2, #382 — `label` empty = innermost loop). */
fn lwt_break(label: str) -> checker::TStatement { checker::TBreakStmt { label = label } }

/** lwt_continue — a `TContinueStmt` node (A1-2, #382 — `label` empty = innermost loop). */
fn lwt_continue(label: str) -> checker::TStatement { checker::TContinueStmt { label = label } }

/** lwt_defer — a `TDeferStmt` node (A1-2, #382). */
fn lwt_defer(body: []checker::TStatement) -> checker::TStatement { checker::TDeferStmt { body = body } }

/** lwt_simple_assign — `name op= value` (or `name = value`), a Simple-kind
    TAssign (A1-2, #382 — the shared shape the loop/break/defer fixtures
    reassign a local through). */
fn lwt_simple_assign(name: str, op: lexer::TokenKind, value: checker::TExpr, k: checker::PrimKind) -> checker::TStatement {
    checker::TAssign { kind = parser::AssignKind::Simple; name = name; op = op; bound = lwt_prim(k); value = value; deref = false; target = checker::no_texpr() }
}

fn lwt_fn(name: str, ns: str, params: []parser::Param, ret: checker::Type, body: []checker::TStatement) -> checker::TFunction {
    checker::TFunction {
        name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        namespace = ns; params = params; return_type = ret; body = body
        vis = parser::Visibility::Private; has_doc = false; doc = ""
        file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""
    }
}

/** lwt_lower_expr_text — lower a single expression (with no registered struct layouts)
    into a fresh i64 fn body and return its printed LIR (for asserting on the emitted
    instructions). */
fn lwt_lower_expr_text(e: checker::TExpr) -> str {
    lwt_lower_expr_text_with(e, teko::list::empty())
}

/** lwt_lower_expr_text_with — lwt_lower_expr_text, but threading a struct-layout table
    (A1-3, #382) so a TStructInit/TFieldAccess/TIndex fixture can resolve its offsets. The
    printed module folds in whatever the expression interned into rodata (A1-4, #382) and
    whatever closure/thunk it lifted (A1-7, #382), so a string-literal or closure fixture's
    golden dump shows its `rodata`/`{ptr,len}`/lifted-function shape too. */
fn lwt_lower_expr_text_with(e: checker::TExpr, layouts: []LStructLayout) -> str {
    let f0 = new_func("t", 0, teko::list::empty(), LType::I64)
    let ctx0 = LowerCtx {
        func = f0; block_id = 0; env = empty_lenv()
        layouts = layouts; rodata = teko::list::empty(); enums = teko::list::empty(); lifted = teko::list::empty()
        defers = teko::list::empty(); loop_targets = teko::list::empty()
    }
    let lo = match lower_expr(ctx0, e) { Lowered as x => x; error as err => return teko::str::concat("ERR: ", err.message) }
    let m0 = with_rodata(add_func(empty_module(), lo.ctx.func), lo.ctx.rodata)
    print_lmodule(lwt_fold_lifted(m0, lo.ctx.lifted))
}

/** lwt_fold_lifted — append every entry of `lifted` into `m.funcs` (mirrors `lower.tks`'s
    own `fold_lifted_funcs`, A1-7 #382 — kept local to the test file since it is the ONLY
    caller here that needs to fold a lifted table outside `lower_program` itself). */
fn lwt_fold_lifted(m: LModule, lifted: []LFunc) -> LModule {
    mut cur = m
    mut i: u64 = 0
    loop {
        if i >= lifted.len { break }
        cur = add_func(cur, lifted[i])
        i++
    }
    cur
}

#test
fn lwt_ltype_of_maps_prims_to_machine_classes() {
    teko::assert::is_true(match ltype_of(lwt_prim(checker::PrimKind::I64)) { I64 => true; _ => false })
    teko::assert::is_true(match ltype_of(lwt_prim(checker::PrimKind::U32)) { I32 => true; _ => false })
    teko::assert::is_true(match ltype_of(lwt_prim(checker::PrimKind::I8)) { I8 => true; _ => false })
    teko::assert::is_true(match ltype_of(lwt_prim(checker::PrimKind::F64)) { F64 => true; _ => false })
    teko::assert::is_true(match ltype_of(lwt_prim(checker::PrimKind::Bool)) { I8 => true; _ => false })
}

/** lwt_binop_is — did lbinop_of return exactly `want` (not an error)? */
fn lwt_binop_is(op: lexer::TokenKind, k: checker::PrimKind, want: LBinOp) -> bool {
    match lbinop_of(op, k) { LBinOp as o => o == want; error => false }
}

/** lwt_unop_is — did lunop_of return exactly `want` (not an error)? */
fn lwt_unop_is(op: lexer::TokenKind, k: checker::PrimKind, want: LUnOp) -> bool {
    match lunop_of(op, k) { LUnOp as o => o == want; error => false }
}

#test
fn lwt_lbinop_of_picks_signedness_and_family() {
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Plus, checker::PrimKind::I64, LBinOp::IAdd))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Slash, checker::PrimKind::I32, LBinOp::IDivS))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Slash, checker::PrimKind::U32, LBinOp::IDivU))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Percent, checker::PrimKind::I64, LBinOp::IRemS))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Plus, checker::PrimKind::F64, LBinOp::FAdd))
}

/**
 * lwt_lbinop_of_maps_bitwise_and_shift — the KP2 bitwise/shift lowering: `& | ^` map to
 * IAnd/IOr/IXor, `<<` to the signedness-agnostic IShl, and `>>` to IShrS on a signed result
 * type or IShrU on an unsigned one (the shift's signedness is the LEFT operand's, carried in
 * the result PrimKind lbinop_of receives).
 */
#test
fn lwt_lbinop_of_maps_bitwise_and_shift() {
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Amp, checker::PrimKind::I64, LBinOp::IAnd))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Pipe, checker::PrimKind::U32, LBinOp::IOr))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Caret, checker::PrimKind::I16, LBinOp::IXor))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Shl, checker::PrimKind::I64, LBinOp::IShl))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Shr, checker::PrimKind::I64, LBinOp::IShrS))
    teko::assert::is_true(lwt_binop_is(lexer::TokenKind::Shr, checker::PrimKind::U64, LBinOp::IShrU))
}

/**
 * lwt_lbinop_of_rejects_out_of_subset — a token with no arithmetic/bitwise/shift LBinOp (a
 * logical `&&`, which lowers via its own short-circuit path, never lbinop_of) still
 * honest-stops, so the defensive `_` arm stays reachable-safe.
 */
#test
fn lwt_lbinop_of_rejects_out_of_subset() {
    teko::assert::is_true(match lbinop_of(lexer::TokenKind::AndAnd, checker::PrimKind::I64) { LBinOp => false; error => true })
}

/**
 * lwt_lunop_of_picks_negation_family — lunop_of maps `-` to INeg/FNeg by family and `~`
 * (bitwise one's-complement, integer-only) to INot. `!` (Bang) is deliberately NOT mapped
 * here: it is intercepted in lower_unary and lowered to a logical `operand == 0` (F1c fix,
 * #389), so lunop_of returns an error for it rather than the old bitwise LUnOp::INot (which
 * miscompiled `!` on the own backend); `~`, a genuine one's-complement, DOES map to INot.
 */
#test
fn lwt_lunop_of_picks_negation_family() {
    teko::assert::is_true(lwt_unop_is(lexer::TokenKind::Minus, checker::PrimKind::I64, LUnOp::INeg))
    teko::assert::is_true(lwt_unop_is(lexer::TokenKind::Minus, checker::PrimKind::F64, LUnOp::FNeg))
    teko::assert::is_true(lwt_unop_is(lexer::TokenKind::Tilde, checker::PrimKind::I64, LUnOp::INot))
    teko::assert::is_true(lwt_unop_is(lexer::TokenKind::Tilde, checker::PrimKind::U8, LUnOp::INot))
    teko::assert::is_true(match lunop_of(lexer::TokenKind::Bang, checker::PrimKind::Bool) { LUnOp => false; error => true })
}

/**
 * lwt_lowers_logical_not_to_icmpeq_zero — `!` lowers to a LOGICAL-not: a `const 0`
 * then an `icmpeq operand, 0` (F1c fix, #389), NOT a bitwise `inot`. The operand here is
 * `1 < 2` (%2 = icmplts %0, %1); the not then emits %3 = const 0 and %4 = icmpeq %2, %3.
 */
#test
fn lwt_lowers_logical_not_to_icmpeq_zero() {
    let cond = lwt_cmp(lwt_num_i64(1 to i128), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Lt, lwt_num_i64(2 to i128))))
    let e = lwt_unary(lexer::TokenKind::Bang, cond, checker::PrimKind::Bool)
    let text = lwt_lower_expr_text(e)
    teko::assert::str_contains(text, "%3 = const 0")
    teko::assert::str_contains(text, "%4 = icmpeq %2, %3")
    teko::assert::is_true(!teko::str::contains(text, "inot"))
}

#test
fn lwt_lowers_unary_neg() {
    let e = lwt_unary(lexer::TokenKind::Minus, lwt_num_i64(42 to i128), checker::PrimKind::I64)
    teko::assert::str_contains(lwt_lower_expr_text(e), "%1 = ineg %0")
}

/**
 * lwt_lowers_unary_bitnot — `~x` lowers to a bitwise `inot` over the operand VReg (NOT the
 * logical `== 0` chain that `!` lowers to): the operand is `%0`, then `%1 = inot %0`.
 */
#test
fn lwt_lowers_unary_bitnot() {
    let e = lwt_unary(lexer::TokenKind::Tilde, lwt_num_i64(5 to i128), checker::PrimKind::I64)
    let text = lwt_lower_expr_text(e)
    teko::assert::str_contains(text, "%1 = inot %0")
    teko::assert::is_true(!teko::str::contains(text, "icmpeq"))
}

/**
 * lwt_lowers_bitwise_ops — `a & b`, `a | b`, `a ^ b` lower to iand/ior/ixor over the two
 * operand VRegs (`%2 = <op> %0, %1`).
 */
#test
fn lwt_lowers_bitwise_ops() {
    let a = lwt_num_i64(6 to i128)
    let b = lwt_num_i64(3 to i128)
    teko::assert::str_contains(lwt_lower_expr_text(lwt_bin(lexer::TokenKind::Amp, a, b, checker::PrimKind::I64)), "%2 = iand %0, %1")
    teko::assert::str_contains(lwt_lower_expr_text(lwt_bin(lexer::TokenKind::Pipe, a, b, checker::PrimKind::I64)), "%2 = ior %0, %1")
    teko::assert::str_contains(lwt_lower_expr_text(lwt_bin(lexer::TokenKind::Caret, a, b, checker::PrimKind::I64)), "%2 = ixor %0, %1")
}

/**
 * lwt_lowers_shift_ops_pick_signedness — `<<` lowers to ishl; `>>` lowers to ishrs on a
 * signed result type and ishru on an unsigned one (the shift's signedness is the LEFT
 * operand's, which the checker makes the result type).
 */
#test
fn lwt_lowers_shift_ops_pick_signedness() {
    let a = lwt_num_i64(8 to i128)
    let amt = lwt_num_i64(2 to i128)
    teko::assert::str_contains(lwt_lower_expr_text(lwt_bin(lexer::TokenKind::Shl, a, amt, checker::PrimKind::I64)), "%2 = ishl %0, %1")
    teko::assert::str_contains(lwt_lower_expr_text(lwt_bin(lexer::TokenKind::Shr, a, amt, checker::PrimKind::I64)), "%2 = ishrs %0, %1")
    let ua = lwt_num(8 to i128, checker::PrimKind::U64)
    let uamt = lwt_num(2 to i128, checker::PrimKind::U64)
    teko::assert::str_contains(lwt_lower_expr_text(lwt_bin(lexer::TokenKind::Shr, ua, uamt, checker::PrimKind::U64)), "%2 = ishru %0, %1")
}

#test
fn lwt_lowers_cast_i64_to_i32_truncates() {
    let e = lwt_cast(lwt_num_i64(42 to i128), checker::PrimKind::I32)
    teko::assert::str_contains(lwt_lower_expr_text(e), "%1 = trunc %0")
}

#test
fn lwt_lowers_cast_i32_to_i64_sign_extends() {
    let inner = lwt_num(5 to i128, checker::PrimKind::I32)
    let e = lwt_cast(inner, checker::PrimKind::I64)
    teko::assert::str_contains(lwt_lower_expr_text(e), "%1 = sext %0")
}

#test
fn lwt_lowers_unsigned_ge_comparison() {
    let e = lwt_cmp(lwt_num(3 to i128, checker::PrimKind::U32), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Ge, lwt_num(5 to i128, checker::PrimKind::U32))))
    teko::assert::str_contains(lwt_lower_expr_text(e), "%2 = icmpgeu %0, %1")
}

#test
fn lwt_lowers_eq_and_ne_comparisons() {
    let eq = lwt_cmp(lwt_num_i64(3 to i128), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::EqEq, lwt_num_i64(3 to i128))))
    teko::assert::str_contains(lwt_lower_expr_text(eq), "icmpeq %0, %1")
    let ne = lwt_cmp(lwt_num_i64(3 to i128), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Ne, lwt_num_i64(3 to i128))))
    teko::assert::str_contains(lwt_lower_expr_text(ne), "icmpne %0, %1")
}

#test
fn lwt_lowers_float_eq_comparison() {
    let e = lwt_cmp(lwt_fnum(1.5), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::EqEq, lwt_fnum(2.5))))
    teko::assert::str_contains(lwt_lower_expr_text(e), "fcmpeq %0, %1")
}

#test
fn lwt_lowers_chain_comparison_ands_adjacent_terms() {
    let a = lwt_num_i64(1 to i128)
    let b = lwt_num_i64(2 to i128)
    let c = lwt_num_i64(3 to i128)
    let terms = teko::list::push(teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Lt, b)), lwt_cmp_term(lexer::TokenKind::Lt, c))
    let text = lwt_lower_expr_text(lwt_cmp(a, terms))
    teko::assert::str_contains(text, "icmplts %0, %1")
    teko::assert::str_contains(text, "icmplts %1, %3")
    teko::assert::str_contains(text, "branch")
    teko::assert::str_contains(text, "jump #B")
}

#test
/**
 * lwt_if_stmt_value_if_rhs_reassign_threads_the_outer_merge — the #389 F1b
 * item 2 proof at the LIR level: a `mut` scalar reassigned INSIDE a
 * value-position `if` that is the RHS of a `let` binding in an OUTER
 * statement-`if` arm must ALSO thread through the OUTER merge, not just the
 * inner value-if's own. `if 1 == 1 { let y = if 1 == 1 { x = 5; x } else { 0
 * } }; return x` — the inner value-if threads `x` through its OWN merge
 * (`#B6(%8, %9)`, value param `%8` + scalar `%9`), so past the binding `x`
 * reads `%9`; the OUTER statement merge must carry `x` too or the read past
 * the outer `if` freezes at the stale pre-branch `x` (`%0`). F1b's
 * `collect_reassigned_stmt` `TBinding` case descends into the binding's
 * value-position `if`/`match` RHS, so the reassigned-scalar scan SEES `x` and
 * the outer merge gains its param (`#B3(%4)`). Asserts the inner arms feed the
 * inner merge (`#B4`/`#B5` → `#B6`), the outer then-arm (which ENDS in the
 * inner merge block `#B6`) closes carrying the POST-inner `x` (`jump
 * #B3(%9)`), the outer else pass-through carries the PRE-branch `x` (`#B2` →
 * `jump #B3(%0)`), and the read past the outer merge sees the merge param
 * (`#B3(%4): ret %4`). Before F1b the outer merge carried ZERO params and
 * `return x` read the stale `%0`.
 *
 * @return void
 */
fn lwt_if_stmt_value_if_rhs_reassign_threads_the_outer_merge() {
    let inner_cond = lwt_cmp(lwt_num_i64(1 to i128), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::EqEq, lwt_num_i64(1 to i128))))
    let inner_then = teko::list::push(teko::list::push(teko::list::empty(), lwt_simple_assign("x", lexer::TokenKind::Assign, lwt_num_i64(5 to i128), checker::PrimKind::I64)), lwt_exprstmt(lwt_var("x", checker::PrimKind::I64)))
    let inner_else = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(0 to i128)))
    let inner_if = lwt_if_value(inner_cond, inner_then, inner_else, checker::PrimKind::I64)
    let outer_then = teko::list::push(teko::list::empty(), lwt_bind("y", inner_if, checker::PrimKind::I64))
    let outer_cond = lwt_cmp(lwt_num_i64(1 to i128), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::EqEq, lwt_num_i64(1 to i128))))
    let ifstmt = lwt_if_stmt(outer_cond, outer_then, false, teko::list::empty())
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("x", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_exprstmt(ifstmt)), lwt_ret(lwt_var("x", checker::PrimKind::I64)))
    let f = lwt_fn("nested_value_if_rhs", "teko::demo", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B4:\n    %10 = const 5\n    jump #B6(%10, %10)")
    teko::assert::str_contains(text, "  #B5:\n    %11 = const 0\n    jump #B6(%11, %0)")
    teko::assert::str_contains(text, "  #B6(%8, %9):\n    jump #B3(%9)")
    teko::assert::str_contains(text, "  #B2:\n    jump #B3(%0)")
    teko::assert::str_contains(text, "  #B3(%4):\n    ret %4")
}

#test
/**
 * lwt_match_stmt_threads_both_the_reassigned_and_the_pattern_shadowed_name —
 * #389 F1b item 3: a match subject `k` whose FIRST arm pattern-binds its own
 * value under `x` (`A as x`, no further statements), and whose SECOND
 * (wildcard) arm reassigns BOTH `x` and `y`. Under enclosing-IDENTITY
 * threading BOTH `x` and `y` are threaded (the former across-all-arms pattern
 * exclusion is gone), so the merge carries TWO scalar params in `env` order
 * (`#B1(%3, %4):`, `x` = `%3`, `y` = `%4`). The pattern arm appends its `A as
 * x` bind at a HIGHER index than the enclosing `x`, so `arm_scalar_args` reads
 * both scalars at their untouched pre-branch indices and its closing jump
 * carries pre-branch `x` and pre-branch `y` (`jump #B1(%1, %2)`); the wildcard
 * arm reassigns both in place, so its closing jump carries the reassigned
 * VRegs (`jump #B1(%5, %6)`). The read past the merge sums the two params
 * (`ret %7`). This UPDATE fixes the latent wildcard-path miscompile the old
 * one-param golden enshrined: `x`'s reassignment on the wildcard path was
 * silently dropped when a SIBLING arm's pattern shadowed the name.
 *
 * @return void
 */
fn lwt_match_stmt_threads_both_the_reassigned_and_the_pattern_shadowed_name() {
    let subject = lwt_var("k", checker::PrimKind::I64)
    let arm0 = lwt_arm(lwt_bind_pattern("A", "x"), teko::list::empty())
    let arm1_body = teko::list::push(teko::list::push(teko::list::empty(), lwt_simple_assign("x", lexer::TokenKind::Assign, lwt_num_i64(99 to i128), checker::PrimKind::I64)), lwt_simple_assign("y", lexer::TokenKind::Assign, lwt_num_i64(20 to i128), checker::PrimKind::I64))
    let arm1 = lwt_arm(lwt_wildcard_pattern(), arm1_body)
    let arms = teko::list::push(teko::list::push(teko::list::empty(), arm0), arm1)
    let match_stmt = checker::TExpr { kind = checker::TMatchExpr { subject = subject; arms = arms }; type = checker::Void { }; line = 0; col = 0 }
    let tail = lwt_ret(lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_var("y", checker::PrimKind::I64), checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("x", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_bind("y", lwt_num_i64(10 to i128), checker::PrimKind::I64)), lwt_exprstmt(match_stmt)), tail)
    let params = teko::list::push(teko::list::empty(), lwt_param("k", "i64"))
    let f = lwt_fn("shadow_and_clean_reassign", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "#B1(%3, %4):")
    teko::assert::str_contains(text, "jump #B1(%1, %2)")
    teko::assert::str_contains(text, "jump #B1(%5, %6)")
    teko::assert::str_contains(text, "ret %7")
}

#test
fn lwt_honest_stop_on_if_without_else_as_a_value() {
    let cond = lwt_cmp(lwt_num_i64(1 to i128), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Lt, lwt_num_i64(2 to i128))))
    let then_blk = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(1 to i128)))
    let ifexpr = checker::TExpr { kind = checker::TIfExpr { cond = cond; then_blk = then_blk; has_else = false; else_blk = then_blk }; type = lwt_prim(checker::PrimKind::I64); line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(ifexpr), "if-without-else used as a value not yet lowered")
}

#test
fn lwt_println_arity_mismatch_honest_stops() {
    let args = teko::list::push(teko::list::push(teko::list::empty(), lwt_strlit("a")), lwt_strlit("b"))
    let call = lwt_call(lwt_path1("println"), "", args, checker::Void { })
    teko::assert::str_contains(lwt_lower_expr_text(call), "expects exactly one str argument")
}

#test
fn lwt_println_of_a_non_fat_producer_honest_stops() {
    let inner = lwt_call(lwt_path1("mk_str"), "teko::demo", teko::list::empty(), checker::Str { })
    let call = lwt_call(lwt_path1("println"), "", teko::list::push(teko::list::empty(), inner), checker::Void { })
    teko::assert::str_contains(lwt_lower_expr_text(call), "not yet lowered (N2)")
}

#test
fn lwt_lowers_direct_teko_call_with_mangle() {
    let args = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(40 to i128)), lwt_num_i64(2 to i128))
    let call = lwt_call(lwt_path1("add"), "teko::demo", args, checker::Prim { kind = checker::PrimKind::I64 })
    teko::assert::str_contains(lwt_lower_expr_text(call), "%2 = call @teko__demo__add(%0, %1)")
}

/** lwt_item — a loose top-level statement as a TItem (the virtual-main path). */
fn lwt_item(s: checker::TStatement) -> checker::TItem { s }

/** lwt_const — a private scalar i64 module-level TConstDecl (#594 crumb-5 keystone fixture). */
fn lwt_const(name: str, init: checker::TExpr) -> checker::TItem {
    checker::TConstDecl { name = name; namespace = ""; ty = lwt_prim(checker::PrimKind::I64); init = init; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
}

/**
 * lwt_scalar_const_inlines_and_leaves_no_global — the crumb-5 SCALAR keystone (#594): a
 * `const K: i64 = 41` used as `exit(K + 1)` inlines to the literal 41 through `inline_consts`, and the
 * comptime-fold pass then folds the const-known `41 + 1` to `42`, so the lowered module carries NO
 * reference to `K` and NO `LGlobal` (`m.globals.len == 0`) — proving the globals honest-stop is never
 * reachable for a scalar-only program.
 */
#test
fn lwt_scalar_const_inlines_and_leaves_no_global() {
    let use_expr = lwt_bin(lexer::TokenKind::Plus, lwt_var("K", checker::PrimKind::I64), lwt_num_i64(1 to i128), checker::PrimKind::I64)
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_const("K", lwt_num_i64(41 to i128)))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), use_expr), checker::Void { }))))
    let inlined = match checker::inline_consts(checker::TProgram { items = items }) { checker::TProgram as p => p; error as err => { teko::assert::is_true(false); return } }
    let m = match lower_program(inlined) { LModule as x => x; error as err => { teko::assert::is_true(false); return } }
    teko::assert::is_true(m.globals.len == 0)
    let text = print_lmodule(m)
    teko::assert::is_true(!teko::str::contains(text, "K"))
    teko::assert::str_contains(text, "const 42")
}

/**
 * lwt_agg_slice_const_materializes_one_rodata_entry — the crumb-6 Tier-A aggregate keystone (#594):
 * a `const NUMS: []i64 = [10, 20]` referenced by a RUNTIME index (`NUMS[idx] + NUMS[idx]`, `idx` a
 * mut local) interns EXACTLY ONE rodata entry (`.Lconst_NUMS`, its two i64 elements little-endian at
 * the indexer's stride), every use resolves to that entry's `global_addr`, and `m.globals.len == 0`
 * still holds — the aggregate lives in rodata, never a global, so no globals honest-stop is
 * reachable. T-B1 additionally guarantees that interned rodata never carries a data-reloc today,
 * hence `relocs.len == 0`. The index is deliberately runtime: a CONST index like `NUMS[0]` now folds
 * to its element at comptime (CF4 Layer 1c, see examples/regressions/cf4_index_fold), so this keystone
 * uses a mut-bound index to still exercise the rodata materialization + `global_addr` resolution path.
 *
 * @return void
 */
#test
fn lwt_agg_slice_const_materializes_one_rodata_entry() {
    let elems = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(10 to i128)), lwt_num_i64(20 to i128))
    let slice_ty = checker::Slice { element = lwt_prim(checker::PrimKind::I64) }
    let cd: checker::TItem = checker::TConstDecl { name = "NUMS"; namespace = ""; ty = slice_ty; init = lwt_array_lit(elems, checker::PrimKind::I64); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let i64_ty = lwt_prim(checker::PrimKind::I64)
    let idx_bind: checker::TStatement = checker::TBinding { kind = parser::BindKind::Mut; target = parser::SimpleName { name = "idx" }; bound = i64_ty; value = lwt_num_i64(0 to i128) }
    let use0 = lwt_index(lwt_typed_var("NUMS", slice_ty), lwt_typed_var("idx", i64_ty), i64_ty)
    let use1 = lwt_index(lwt_typed_var("NUMS", slice_ty), lwt_typed_var("idx", i64_ty), i64_ty)
    let sum = lwt_bin(lexer::TokenKind::Plus, use0, use1, checker::PrimKind::I64)
    mut items: []checker::TItem = teko::list::push(teko::list::empty(), cd)
    items = teko::list::push(items, lwt_item(idx_bind))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), sum), checker::Void { }))))
    let inlined = match checker::inline_consts(checker::TProgram { items = items }) { checker::TProgram as p => p; error as err => { teko::assert::is_true(false); return } }
    let m = match lower_program(inlined) { LModule as x => x; error as err => { teko::assert::is_true(false); return } }
    teko::assert::is_true(m.globals.len == 0)
    teko::assert::is_true(m.rodata.len == 1)
    teko::assert::is_true(m.rodata[0].symbol == ".Lconst_NUMS")
    teko::assert::is_true(m.rodata[0].relocs.len == 0)
    teko::assert::is_true(m.rodata[0].bytes.len == 16)
    teko::assert::is_true(m.rodata[0].bytes[0] == (10 to byte))
    teko::assert::is_true(m.rodata[0].bytes[8] == (20 to byte))
    teko::assert::str_contains(print_lmodule(m), "global_addr @.Lconst_NUMS")
}

/**
 * lwt_variant_decl — a `variant <name> = M0 | M1 | …` TypeDecl, wrapped as a `checker::TItem` (#594
 * crumb 9b). The member names become the variant body's union of `NamedType` members, in order, so
 * `collect_variants` recovers the tag ORDER an empty-case aggregate-const serialization needs.
 *
 * @param name     the variant type's name
 * @param members  the member case names, in declared (tag) order
 * @return         the variant type declaration, as a program item
 */
fn lwt_variant_decl(name: str, members: []str) -> checker::TItem {
    mut mtes: []parser::TypeExpr = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= members.len { break }
        mtes = teko::list::push(mtes, lwt_named_te(members[i]))
        i++
    }
    parser::TypeDecl {
        name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        body = parser::VariantBody { type_expr = parser::UnionType { members = mtes } }
        vis = parser::Visibility::Pub; has_doc = false; doc = ""
        line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""
        is_unsafe = false; must_free = false
    }
}

/**
 * lwt_agg_empty_variant_const_interns_its_tag_image — the crumb-9b Tier-A empty-case variant keystone
 * (#594): a `const R: Op = RetC { }` over `variant Op = RetA | RetB | RetC` interns EXACTLY ONE rodata
 * entry (`.Lconst_R`) whose bytes are the constructed member's declared tag — `RetC` is the third
 * member, so the 4-byte little-endian I32 image is `[2, 0, 0, 0]` (the `tag@0` half of the variant
 * runtime image, no payload). `m.globals.len == 0` still holds. Directly validates `serialize_const`'s
 * variant arm (the tag `lower_variant_case_test` later compares against), independent of the own
 * backend's downstream match dispatch.
 *
 * @return void
 */
#test
fn lwt_agg_empty_variant_const_interns_its_tag_image() {
    let members = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RetA"), "RetB"), "RetC")
    mut items: []checker::TItem = teko::list::push(teko::list::empty(), lwt_variant_decl("Op", members))
    let init = lwt_struct_init("RetC", teko::list::empty(), teko::list::empty())
    let cd: checker::TItem = checker::TConstDecl { name = "R"; namespace = ""; ty = checker::Named { name = "Op" }; init = init; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    items = teko::list::push(items, cd)
    let m = match lower_program(checker::TProgram { items = items }) { LModule as x => x; error as err => { teko::assert::is_true(false); return } }
    teko::assert::is_true(m.globals.len == 0)
    teko::assert::is_true(m.rodata.len == 1)
    teko::assert::is_true(m.rodata[0].symbol == ".Lconst_R")
    teko::assert::is_true(m.rodata[0].bytes.len == 4)
    teko::assert::is_true(m.rodata[0].bytes[0] == (2 to byte))
    teko::assert::is_true(m.rodata[0].bytes[1] == (0 to byte))
    teko::assert::is_true(m.rodata[0].bytes[2] == (0 to byte))
    teko::assert::is_true(m.rodata[0].bytes[3] == (0 to byte))
}

/**
 * lwt_slice_field — a struct `parser::Field` whose annotation is a `[]<elem>` slice — the fat-pointer
 * field shape the T-B6 layout widens to 16 bytes and the producer materializes as `{ptr->leaf, len}`
 * (#594 T-B6).
 *
 * @param name        the field's name
 * @param elem_tname  the slice element type's bare name
 * @return            the slice-typed struct field
 */
fn lwt_slice_field(name: str, elem_tname: str) -> parser::Field {
    parser::Field { name = name; type_ann = parser::SliceType { element = lwt_named_te(elem_tname) }; vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
}

/**
 * lwt_tb6_deref_reads_second_element_and_len — the T-B6 sibling reads (#594 §7.3): `K2.xs[1]` derefs
 * the second interned element (exit 20), and `K2.xs.len` reads the inline length half of the fat field
 * through the new `lower_fat_field` reader (exit 2) — the two engines dereference the same target bytes.
 *
 * @return void
 */
#test
fn lwt_tb6_deref_reads_second_element_and_len() {
    teko::assert::is_true(lwt_tb6_deref_exit(lwt_index(lwt_tb6_k2_xs(), lwt_num_i64(1 to i128), lwt_prim(checker::PrimKind::I64))) == (20 to i128))
    teko::assert::is_true(lwt_tb6_deref_exit(lwt_field_access(lwt_tb6_k2_xs(), "len", lwt_prim(checker::PrimKind::I64))) == (2 to i128))
}

/**
 * lwt_tb6_k2_xs — the typed `K2.xs` fat-field access (`[]i64`) the T-B6 deref fixtures read through
 * (#594 §7.3): a field access on the aggregate-const receiver `K2` of type `S2`.
 *
 * @return the typed `K2.xs` field-access expression
 */
fn lwt_tb6_k2_xs() -> checker::TExpr {
    lwt_field_access(lwt_typed_var("K2", checker::Named { name = "S2" }), "xs", checker::Slice { element = lwt_prim(checker::PrimKind::I64) })
}

/**
 * lwt_tb6_deref_exit — lower a program that binds `const K2: S2 = { xs = [10, 20]; n = 2 }` and runs
 * `exit(<use>)` as its virtual main, then interpret it on the VM and return the exit code (#594 §7.3).
 * The struct `S2` is declared first so its 16-byte fat-field layout is registered before the const
 * interns.
 *
 * @param use_expr  the i64-typed expression the virtual main exits with (a `K2.xs[i]` or `K2.xs.len`)
 * @return          the VM exit code of the lowered program
 */
fn lwt_tb6_deref_exit(use_expr: checker::TExpr) -> i128 {
    let decl = lwt_struct_decl("S2", lwt_two_fields(lwt_slice_field("xs", "i64"), lwt_field("n", "i64")))
    let elems = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(10 to i128)), lwt_num_i64(20 to i128))
    let xs_lit = lwt_array_lit(elems, checker::PrimKind::I64)
    let fnames = teko::list::push(teko::list::push(teko::list::empty(), "xs"), "n")
    let fvals = teko::list::push(teko::list::push(teko::list::empty(), xs_lit), lwt_num_i64(2 to i128))
    let si = lwt_struct_init("S2", fnames, fvals)
    let cd: checker::TItem = checker::TConstDecl { name = "K2"; namespace = ""; ty = checker::Named { name = "S2" }; init = si; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let exit_call = lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), use_expr), checker::Void { })
    mut items: []checker::TItem = teko::list::push(teko::list::empty(), decl)
    items = teko::list::push(items, cd)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(exit_call)))
    let m = match lower_program(checker::TProgram { items = items }) { LModule as x => x; error as err => { teko::assert::is_true(false); return (-99 to i128) } }
    let no_args: []i128 = teko::list::empty()
    interp_lmodule(m, "main", no_args)
}

/**
 * lwt_typed_var — a `TVar` of an ARBITRARY resolved type `ty` (A1-5, #382 — a
 * `match` subject is not always a scalar/Named/Optional the other `lwt_*_var`
 * helpers cover; a `Variant`-typed subject needs this general form).
 *
 * @param str name  the variable's name
 * @param checker::Type ty  the variable's resolved type
 * @return checker::TExpr  the typed `TVar` node
 */
fn lwt_typed_var(name: str, ty: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = false; func_ns = "" }; type = ty; line = 0; col = 0 }
}

/**
 * lwt_wildcard_pattern — a bare `_` pattern (A1-5, #382).
 *
 * @return parser::Pattern  the wildcard pattern node
 */
fn lwt_wildcard_pattern() -> parser::Pattern { parser::WildcardPattern { } }

/**
 * lwt_int_pattern — an integer-literal pattern `v` (A1-5, #382).
 *
 * @param i128 v  the literal's integer value
 * @return parser::Pattern  the literal pattern node
 */
fn lwt_int_pattern(v: i128) -> parser::Pattern {
    parser::LiteralPattern { value = parser::Expr { kind = parser::Number { is_float = false; value = v; fval = 0.0 }; line = 0; col = 0 } }
}

/**
 * lwt_str_pattern — a string-literal pattern `text` (A1-5, #382).
 *
 * @param str text  the literal's own text
 * @return parser::Pattern  the literal pattern node
 */
fn lwt_str_pattern(text: str) -> parser::Pattern {
    parser::LiteralPattern { value = parser::Expr { kind = parser::StrLit { text = text }; line = 0; col = 0 } }
}

/**
 * lwt_bind_pattern — `case as binding` (a variant case-select + payload bind),
 * or `case` (no binding) when `binding` is empty (A1-5, #382).
 *
 * @param str case_name  the pattern's case name
 * @param str binding  the name to bind the payload to (empty = no binding)
 * @return parser::Pattern  the bind pattern node
 */
fn lwt_bind_pattern(case_name: str, binding: str) -> parser::Pattern {
    parser::BindPattern { type_name = lwt_path1(case_name); has_binding = binding != ""; binding = binding; is_slice = false; slice_type = null; type_args = teko::list::empty() }
}

/**
 * lwt_arm — an UNGUARDED match arm over `pat`, whose body is `body` (A1-5,
 * #382).
 *
 * @param parser::Pattern pat  the arm's pattern
 * @param []checker::TStatement body  the arm's statement block
 * @return checker::TArm  the typed arm node
 */
fn lwt_arm(pat: parser::Pattern, body: []checker::TStatement) -> checker::TArm {
    checker::TArm { pattern = pat; has_when = false; guard = lwt_num_i64(0 to i128); body = body }
}

/**
 * lwt_guarded_arm — a `when`-guarded match arm over `pat` (A1-5, #382).
 *
 * @param parser::Pattern pat  the arm's pattern
 * @param checker::TExpr guard  the `when` guard condition
 * @param []checker::TStatement body  the arm's statement block
 * @return checker::TArm  the typed arm node
 */
fn lwt_guarded_arm(pat: parser::Pattern, guard: checker::TExpr, body: []checker::TStatement) -> checker::TArm {
    checker::TArm { pattern = pat; has_when = true; guard = guard; body = body }
}

/**
 * lwt_match_value — a VALUE-producing `TMatchExpr` over `subject`/`arms`, typed
 * `k` (A1-5, #382).
 *
 * @param checker::TExpr subject  the match's subject expression
 * @param []checker::TArm arms  the match's arms, in order
 * @param checker::PrimKind k  the match expression's own resolved primitive
 *                             type
 * @return checker::TExpr  the typed `TMatchExpr` node
 */
fn lwt_match_value(subject: checker::TExpr, arms: []checker::TArm, k: checker::PrimKind) -> checker::TExpr {
    checker::TExpr { kind = checker::TMatchExpr { subject = subject; arms = arms }; type = lwt_prim(k); line = 0; col = 0 }
}

/**
 * lwt_variant2 — an inline `checker::Variant` of two NOMINAL (`Named`) cases,
 * in order (A1-5, #382).
 *
 * @param str a  the first case's Named type name
 * @param str b  the second case's Named type name
 * @return checker::Type  the inline `Variant` type
 */
fn lwt_variant2(a: str, b: str) -> checker::Type {
    checker::Variant { members = teko::list::push(teko::list::push(teko::list::empty(), checker::Named { name = a }), checker::Named { name = b }) }
}

/**
 * lwt_circle_layout — `struct Circle { radius: i64 }`'s registered layout
 * (A1-5, #382).
 *
 * @return LStructLayout  Circle's resolved layout
 */
fn lwt_circle_layout() -> LStructLayout {
    layout_of("Circle", teko::list::push(teko::list::empty(), "radius"), teko::list::push(teko::list::empty(), LType::I64))
}

#test
fn lwt_lowers_match_enum_member_pattern_via_registered_ordinal() {
    let subject = lwt_typed_var("c", checker::Named { name = "Color" })
    let arm0 = lwt_arm(lwt_bind_pattern("Red", ""), teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(10 to i128))))
    let arm1 = lwt_arm(lwt_wildcard_pattern(), teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(0 to i128))))
    let arms = teko::list::push(teko::list::push(teko::list::empty(), arm0), arm1)
    let match_expr = lwt_match_value(subject, arms, checker::PrimKind::I64)
    let params = teko::list::push(teko::list::empty(), lwt_param("c", "Color"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(match_expr))
    let f = lwt_fn("pick_color", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let enums = teko::list::push(teko::list::empty(), LEnumInfo { name = "Color"; members = teko::list::push(teko::list::push(teko::list::empty(), "Red"), "Green") })
    let lf = match lower_function(f, teko::list::empty(), teko::list::empty(), enums) { LoweredFunction as r => r.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "%2 = const 0")
    teko::assert::str_contains(text, "%3 = icmpeq %0, %2")
    teko::assert::str_contains(text, "branch %3, #B2(), #B3()")
    teko::assert::str_contains(text, "  #B3:\n    jump #B4()")
}

#test
fn lwt_lowers_match_when_guard_falls_through_to_next_arm() {
    let subject = lwt_var("x", checker::PrimKind::I64)
    let guard = lwt_cmp(subject, teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Gt, lwt_num_i64(0 to i128))))
    let arm0 = lwt_guarded_arm(lwt_int_pattern(1 to i128), guard, teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(100 to i128))))
    let arm1 = lwt_arm(lwt_wildcard_pattern(), teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(0 to i128))))
    let arms = teko::list::push(teko::list::push(teko::list::empty(), arm0), arm1)
    let match_expr = lwt_match_value(subject, arms, checker::PrimKind::I64)
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(match_expr))
    let f = lwt_fn("guarded_pick", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as r => r.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "branch %3, #B2(), #B3()")
    teko::assert::str_contains(text, "branch %5, #B4(), #B3()")
    teko::assert::str_contains(text, "  #B4:\n    %6 = const 100\n    jump #B1(%6)")
    teko::assert::str_contains(text, "  #B3:\n    jump #B5()")
}

#test
fn lwt_lowers_match_variant_case_binds_the_payload() {
    let subject = lwt_typed_var("s", lwt_variant2("Circle", "Square"))
    let payload = lwt_field_access(lwt_typed_var("c", checker::Named { name = "Circle" }), "radius", lwt_prim(checker::PrimKind::I64))
    let arm0 = lwt_arm(lwt_bind_pattern("Circle", "c"), teko::list::push(teko::list::empty(), lwt_exprstmt(payload)))
    let arms = teko::list::push(teko::list::empty(), arm0)
    let match_expr = lwt_match_value(subject, arms, checker::PrimKind::I64)
    let params = teko::list::push(teko::list::empty(), lwt_param("s", "Shape"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(match_expr))
    let f = lwt_fn("read_case", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f, lwt_one_layout(lwt_circle_layout())) { LoweredFunction as r => r.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "%2 = field_addr %0, 0")
    teko::assert::str_contains(text, "%3 = load.i32 %2")
    teko::assert::str_contains(text, "%5 = icmpeq %3, %4")
    teko::assert::str_contains(text, "%6 = field_addr %0, 8")
    teko::assert::str_contains(text, "%7 = load.ptr %6")
    teko::assert::str_contains(text, "%8 = field_addr %7, 0")
    teko::assert::str_contains(text, "%9 = load.i64 %8")
    teko::assert::str_contains(text, "jump #B1(%9)")
    teko::assert::str_contains(text, "  #B1(%1):\n    ret %1")
}

#test
fn lwt_lowers_match_string_arm_via_byte_compare() {
    let subject = lwt_strlit("hi")
    let arm0 = lwt_arm(lwt_str_pattern("hi"), teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(1 to i128))))
    let arm1 = lwt_arm(lwt_wildcard_pattern(), teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num_i64(0 to i128))))
    let arms = teko::list::push(teko::list::push(teko::list::empty(), arm0), arm1)
    let match_expr = lwt_match_value(subject, arms, checker::PrimKind::I64)
    let text = lwt_lower_expr_text(match_expr)
    teko::assert::str_contains(text, "rodata .Lstr0: [104, 105]")
    teko::assert::str_contains(text, "global_addr @.Lstr0")
    teko::assert::str_contains(text, "load.i8")
    teko::assert::is_true(teko::str::contains(text, "icmpeq"))
    teko::assert::str_contains(text, "branch")
}

/**
 * lwt_defer_inside_match_value_arm_fires_only_on_that_arms_own_branch — PR
 * #553 follow-up nit, UPDATED for #389 F1b item 1: the VALUE-producing
 * (`lower_match_arm_value`) mirror of
 * `lwt_defer_inside_match_arm_fires_only_on_that_arms_own_branch`: `let s=1;
 * return match x { 1 => { defer { s = s + 100 }; s } _ => s }` — the `defer`
 * registers ONLY inside arm0's own body, before its own tail value `s`. Arm0's
 * own body block (`#B2`) fires it — LIFO, from the defer-delta base THIS arm
 * itself started at — AFTER its tail value is read but BEFORE its jump.
 *
 * The merge now carries TWO params, `#B1(%2, %3)`: the FIRST (`%2`) is the
 * match RESULT value, the SECOND (`%3`) the threaded enclosing scalar `s`
 * (F1b re-adds the `TDeferStmt` descent, so the defer's `s = s + 100` is seen
 * by the reassigned-scalar scan). CRITICALLY the VALUE arg stays PRE-defer: the
 * tail `s` (`%1`) is captured before the defer replays, so arm0 jumps
 * `#B1(%1, %7)` — value `%1` (pre-defer) THEN scalar `%7` (post-defer `s`,
 * `%7 = iadd %1, %6`); `close_arm_replaying_defers` re-samples only the SCALAR
 * arg from the post-replay env, never the value. The wildcard arm (`#B4`, via
 * its pass-through `#B3`, no defer) jumps `#B1(%1, %1)`; the tail returns the
 * VALUE param, `ret %2`. Before F1b the merge carried only the value param
 * (`#B1(%2)`) and jumped `#B1(%1)` — the OLD golden shape dropped `s` at the
 * merge; the arm block still holds its single `iadd` (defer never replayed
 * twice). `#B1` is allocated BEFORE either arm (mirrors `lower_match_value`'s
 * own `mergeb`-first shape), so it prints immediately followed by `#B2`'s own
 * header, never a trailing `}` (that closes the function after the
 * LAST-allocated block, the dead-code fallback past the last arm).
 *
 * @return void
 */
#test
fn lwt_defer_inside_match_value_arm_fires_only_on_that_arms_own_branch() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let subject = lwt_var("x", checker::PrimKind::I64)
    let arm0_body = teko::list::push(teko::list::push(teko::list::empty(), lwt_defer(defer_body)), lwt_exprstmt(lwt_var("s", checker::PrimKind::I64)))
    let arm0 = lwt_arm(lwt_int_pattern(1 to i128), arm0_body)
    let arm1 = lwt_arm(lwt_wildcard_pattern(), teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_var("s", checker::PrimKind::I64))))
    let arms = teko::list::push(teko::list::push(teko::list::empty(), arm0), arm1)
    let match_expr = lwt_match_value(subject, arms, checker::PrimKind::I64)
    let body = teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_ret(match_expr))
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let f = lwt_fn("match_value_arm_scoped", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B2:\n    %6 = const 100\n    %7 = iadd %1, %6\n    jump #B1(%1, %7)")
    teko::assert::str_contains(text, "  #B3:\n    jump #B4()")
    teko::assert::str_contains(text, "  #B4:\n    jump #B1(%1, %1)")
    teko::assert::str_contains(text, "  #B1(%2, %3):\n    ret %2\n  #B2:")
}

/** lwt_point_layout — the LStructLayout of `struct Point { x: i64; y: i64 }` — a flat,
    two-field, uniform-width aggregate (A1-3, #382 fixtures). */
fn lwt_point_layout() -> LStructLayout {
    let names = teko::list::push(teko::list::push(teko::list::empty(), "x"), "y")
    let types = teko::list::push(teko::list::push(teko::list::empty(), LType::I64), LType::I64)
    layout_of("Point", names, types)
}

/** lwt_one_layout — a one-entry layout table (the common case every fixture below needs). */
fn lwt_one_layout(l: LStructLayout) -> []LStructLayout { teko::list::push(teko::list::empty(), l) }

/** lwt_named_var — a TVar of a NAMED (struct) type — a receiver a field-access/assignment
    fixture reads/writes through. */
fn lwt_named_var(name: str, tname: str) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = false; func_ns = "" }; type = checker::Named { name = tname }; line = 0; col = 0 }
}

/** lwt_struct_init — a `Name { f0 = v0, … }` node, in declared order. */
fn lwt_struct_init(tname: str, field_names: []str, field_vals: []checker::TExpr) -> checker::TExpr {
    checker::TExpr { kind = checker::TStructInit { field_names = field_names; field_vals = field_vals }; type = checker::Named { name = tname }; line = 0; col = 0 }
}

/** lwt_field_access — a `recv.field` node of resolved type `ft`. */
fn lwt_field_access(recv: checker::TExpr, field: str, ft: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TFieldAccess { receiver = recv; field = field }; type = ft; line = 0; col = 0 }
}

#test
fn lwt_lowers_struct_init_via_registered_layout() {
    let names = teko::list::push(teko::list::push(teko::list::empty(), "x"), "y")
    let vals = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(3 to i128)), lwt_num_i64(4 to i128))
    let si = lwt_struct_init("Point", names, vals)
    let text = lwt_lower_expr_text_with(si, lwt_one_layout(lwt_point_layout()))
    teko::assert::str_contains(text, "%0 = alloca 16, align 8")
    teko::assert::str_contains(text, "%2 = field_addr %0, 0")
    teko::assert::str_contains(text, "store.i64 %2, %1")
    teko::assert::str_contains(text, "%4 = field_addr %0, 8")
    teko::assert::str_contains(text, "store.i64 %4, %3")
}

/** lwt_array_elem — a non-spread array element. */
fn lwt_array_elem(e: checker::TExpr) -> checker::TArrayElem { checker::TArrayElem { is_spread = false; expr = e } }

/** lwt_array_lit — `[e0, e1, …]`, each element of PrimKind `k`. */
fn lwt_array_lit(elems: []checker::TExpr, k: checker::PrimKind) -> checker::TExpr {
    mut es: []checker::TArrayElem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= elems.len { break }
        es = teko::list::push(es, lwt_array_elem(elems[i]))
        i++
    }
    checker::TExpr { kind = checker::TArrayLit { elements = es }; type = checker::Slice { element = lwt_prim(k) }; line = 0; col = 0 }
}

/** lwt_index — `recv[index]` of resolved element type `et`. */
fn lwt_index(recv: checker::TExpr, index: checker::TExpr, et: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TIndex { receiver = recv; index = index }; type = et; line = 0; col = 0 }
}

#test
fn lwt_lowers_array_literal_and_constant_index() {
    let elems = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(10 to i128)), lwt_num_i64(20 to i128)), lwt_num_i64(30 to i128))
    let arr = lwt_array_lit(elems, checker::PrimKind::I64)
    let ix = lwt_index(arr, lwt_num_i64(1 to i128), lwt_prim(checker::PrimKind::I64))
    let text = lwt_lower_expr_text(ix)
    teko::assert::str_contains(text, "%0 = alloca 24, align 8")
    teko::assert::str_contains(text, "%4 = field_addr %0, 8")
    teko::assert::str_contains(text, "store.i64 %4, %3")
    teko::assert::str_contains(text, "%7 = field_addr %0, 8")
    teko::assert::str_contains(text, "%8 = load.i64 %7")
}

/** lwt_field_assign — `recv.field op= value`, a Field-kind TAssign whose target is the
    typed field-access LHS (mirrors the checker's typer.tks shape). */
fn lwt_field_assign(recv: checker::TExpr, field: str, op: lexer::TokenKind, value: checker::TExpr, bound: checker::Type) -> checker::TStatement {
    let target = lwt_field_access(recv, field, bound)
    checker::TAssign { kind = parser::AssignKind::Field; name = ""; op = op; bound = bound; value = value; deref = false; target = target }
}

#test
fn lwt_lowers_plain_field_assignment_via_registered_layout() {
    let p = lwt_named_var("p", "Point")
    let assign = lwt_field_assign(p, "x", lexer::TokenKind::Assign, lwt_num_i64(9 to i128), lwt_prim(checker::PrimKind::I64))
    let params = teko::list::push(teko::list::empty(), lwt_param("p", "Point"))
    let body = teko::list::push(teko::list::push(teko::list::empty(), assign), lwt_ret(lwt_num_i64(0 to i128)))
    let f = lwt_fn("write_x", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f, lwt_one_layout(lwt_point_layout())) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "%1 = field_addr %0, 0")
    teko::assert::str_contains(text, "%2 = const 9")
    teko::assert::str_contains(text, "store.i64 %1, %2")
}

#test
fn lwt_lowers_compound_field_assignment_reads_then_writes() {
    let p = lwt_named_var("p", "Point")
    let assign = lwt_field_assign(p, "x", lexer::TokenKind::PlusEq, lwt_num_i64(5 to i128), lwt_prim(checker::PrimKind::I64))
    let params = teko::list::push(teko::list::empty(), lwt_param("p", "Point"))
    let body = teko::list::push(teko::list::push(teko::list::empty(), assign), lwt_ret(lwt_num_i64(0 to i128)))
    let f = lwt_fn("bump_x", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f, lwt_one_layout(lwt_point_layout())) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "%2 = load.i64 %1")
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "store.i64 %1, %4")
}

#test
fn lwt_lowers_compound_simple_assignment_reads_then_rebinds() {
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind("x", lwt_num_i64(4 to i128), checker::PrimKind::I64)))
    let assign = checker::TAssign { kind = parser::AssignKind::Simple; name = "x"; op = lexer::TokenKind::StarEq; bound = lwt_prim(checker::PrimKind::I64); value = lwt_num_i64(3 to i128); deref = false; target = checker::no_texpr() }
    items = teko::list::push(items, lwt_item(assign))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), lwt_var("x", checker::PrimKind::I64)), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "%2 = imul %0, %1")
    teko::assert::str_contains(text, "call @tk_exit(%2)")
}

#test
fn lwt_lowers_byte_literal() {
    let bl = checker::TExpr { kind = checker::TByteLit { value = 200 to byte }; type = checker::Byte { }; line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(bl), "%0 = const 200")
}

#test
fn lwt_lowers_bool_literal_true_and_false() {
    let bt = checker::TExpr { kind = checker::TBoolLit { value = true }; type = lwt_prim(checker::PrimKind::Bool); line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(bt), "%0 = const 1")
    let bf = checker::TExpr { kind = checker::TBoolLit { value = false }; type = lwt_prim(checker::PrimKind::Bool); line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(bf), "%0 = const 0")
}

#test
fn lwt_lowers_null_literal_as_a_zero_ptr_const() {
    let nl = checker::TExpr { kind = checker::TNullLit { }; type = checker::Optional { inner = lwt_prim(checker::PrimKind::I64) }; line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(nl), "%0 = const 0")
}

#test
fn lwt_lowers_path_expr_to_its_resolved_value() {
    let pe = checker::TExpr { kind = checker::TPathExpr { enum_name = "Color"; member = "Green"; ordinal = 1; value = 1 to u128 }; type = checker::Named { name = "Color" }; line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(pe), "%0 = const 1")
}

#test
fn lwt_lowers_char_literal_multibyte_to_its_codepoint() {
    let cl = checker::TExpr { kind = checker::TCharLit { bytes = "é" }; type = checker::Char { }; line = 0; col = 0 }
    teko::assert::str_contains(lwt_lower_expr_text(cl), "%0 = const 233")
}

/** lwt_strlit — a `TStrLit` node holding `text` (A1-4, #382). */
fn lwt_strlit(text: str) -> checker::TExpr {
    checker::TExpr { kind = checker::TStrLit { text = text }; type = checker::Str { }; line = 0; col = 0 }
}

/** lwt_len_field — `recv.len`, always `u64`-typed (A1-4, #382). */
fn lwt_len_field(recv: checker::TExpr) -> checker::TExpr {
    checker::TExpr { kind = checker::TFieldAccess { receiver = recv; field = "len" }; type = lwt_prim(checker::PrimKind::U64); line = 0; col = 0 }
}

#test
fn lwt_lowers_str_len_reads_the_fat_length_with_no_memory_traffic() {
    let text = lwt_lower_expr_text(lwt_len_field(lwt_strlit("hello")))
    teko::assert::str_contains(text, "%1 = const 5")
    teko::assert::is_true(!teko::str::contains(text, "load."))
}

/** lwt_index_of — `recv[index]`, resolved element type `et` (A1-4, #382). */
fn lwt_index_of(recv: checker::TExpr, index: checker::TExpr, et: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TIndex { receiver = recv; index = index }; type = et; line = 0; col = 0 }
}

#test
fn lwt_lowers_str_index_loads_the_byte_off_rodata() {
    let ix = lwt_index_of(lwt_strlit("abc"), lwt_num_i64(0 to i128), checker::Byte { })
    let text = lwt_lower_expr_text(lwt_cast(ix, checker::PrimKind::I32))
    teko::assert::str_contains(text, "rodata .Lstr0: [97, 98, 99]")
    teko::assert::str_contains(text, "field_addr %0, 0")
    teko::assert::str_contains(text, "load.i8")
    teko::assert::str_contains(text, "zext")
}

/** lwt_interp — a `$"…{…}…"` node over `pieces`/`holes`, always no-spec (A1-4, #382). */
fn lwt_interp(pieces: []str, holes: []checker::TExpr) -> checker::TExpr {
    mut specs: []checker::TFSpec = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= holes.len { break }
        specs = teko::list::push(specs, checker::TFSpec { kind = checker::TFSpecNone { } })
        i++
    }
    checker::TExpr { kind = checker::TInterp { pieces = pieces; holes = holes; specs = specs }; type = checker::Str { }; line = 0; col = 0 }
}

#test
fn lwt_lowers_interpolation_as_nested_str_concat_calls() {
    let pieces = teko::list::push(teko::list::push(teko::list::empty(), "n="), "")
    let holes = teko::list::push(teko::list::empty(), lwt_num_i64(7 to i128))
    let text = lwt_lower_expr_text(lwt_interp(pieces, holes))
    teko::assert::str_contains(text, "rodata .Lstr0: [110, 61]")
    teko::assert::str_contains(text, "global_addr @.Lstr0")
    teko::assert::str_contains(text, "call @tk_i64_to_str(")
    teko::assert::str_contains(text, "call @tk_str_concat(")
}

/** lwt_in_expr — `lhs in [elems]`, always bool-typed (A1-4, #382). */
fn lwt_in_expr(lhs: checker::TExpr, elems: []checker::TExpr) -> checker::TExpr {
    checker::TExpr { kind = checker::TInExpr { lhs = lhs; elems = elems }; type = lwt_prim(checker::PrimKind::Bool); line = 0; col = 0 }
}

#test
fn lwt_lowers_in_expr_as_an_eq_chain_ored_together() {
    let elems = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(1 to i128)), lwt_num_i64(2 to i128))
    let text = lwt_lower_expr_text(lwt_in_expr(lwt_num_i64(1 to i128), elems))
    teko::assert::str_contains(text, "icmpeq")
    teko::assert::str_contains(text, "ior")
}

/** lwt_named_opt_var — a `TVar` of `Named?` type — the safe-field-access receiver shape
    (A1-4, #382). */
fn lwt_named_opt_var(name: str, tname: str) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = false; func_ns = "" }; type = checker::Optional { inner = checker::Named { name = tname } }; line = 0; col = 0 }
}

/** lwt_safe_field_access — `recv?.field` of resolved (unwrapped) field type `ft` — its
    `.type` is `ft` widened into `Optional` (A1-4, #382). */
fn lwt_safe_field_access(recv: checker::TExpr, field: str, ft: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TSafeFieldAccess { receiver = recv; field = field }; type = checker::Optional { inner = ft }; line = 0; col = 0 }
}

#test
fn lwt_lowers_safe_field_access_via_branch_and_merge() {
    let p = lwt_named_opt_var("p", "Point")
    let sfa = lwt_safe_field_access(p, "y", lwt_prim(checker::PrimKind::I64))
    let params = teko::list::push(teko::list::empty(), lwt_param("p", "Point"))
    let body = teko::list::push(teko::list::empty(), lwt_ret(sfa))
    let f = lwt_fn("read_y_opt", "teko::demo", params, checker::Optional { inner = checker::Prim { kind = checker::PrimKind::I64 } }, body)
    let lf = match lower_function(f, lwt_one_layout(lwt_point_layout())) { LoweredFunction as r => r.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "branch %0, #B1(), #B2()")
    teko::assert::str_contains(text, "  #B1:\n    %2 = field_addr %0, 8\n    %3 = load.i64 %2\n    jump #B3(%3)")
    teko::assert::str_contains(text, "  #B2:\n    %4 = const 0\n    jump #B3(%4)")
    teko::assert::str_contains(text, "  #B3(%1):\n    ret %1")
}

/**
 * lwt_iface_call — a dynamic contract-method `TCall`
 * (`is_iface_dispatch=true`): `args[0]` is the receiver, `slot` its vtable
 * index.
 *
 * @param str iface  the contract's canonical name (the callee path's first
 *                   segment)
 * @param str method  the dispatched method's name (the callee path's second
 *                     segment)
 * @param u32 slot  the method's vtable slot
 * @param []checker::TExpr args  the call's arguments (`args[0]` is the
 *                                receiver)
 * @param checker::Type ret  the call's resolved return type
 * @return checker::TExpr  the built interface-dispatch call node
 *
 * @since #382 A1-6
 */
fn lwt_iface_call(iface: str, method: str, slot: u32, args: []checker::TExpr, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TCall {
            callee = lwt_path2(iface, method); args = args; call_ns = ""
            is_closure_call = false; callee_type = checker::Void { }; is_iface_dispatch = true; iface_slot = slot
        }
        type = ret; line = 0; col = 0
    }
}

#test
fn lwt_lowers_iface_dispatch_call_via_vtable_load_and_indirect_call() {
    let recv = lwt_num_i64(1000 to i128)
    let extra = lwt_num_i64(7 to i128)
    let args = teko::list::push(teko::list::push(teko::list::empty(), recv), extra)
    let call = lwt_iface_call("Speaker", "speak", 2, args, lwt_prim(checker::PrimKind::I64))
    let text = lwt_lower_expr_text(call)
    teko::assert::str_contains(text, "%0 = const 1000")
    teko::assert::str_contains(text, "%1 = field_addr %0, 0")
    teko::assert::str_contains(text, "%2 = load.ptr %1")
    teko::assert::str_contains(text, "%3 = field_addr %0, 8")
    teko::assert::str_contains(text, "%4 = load.ptr %3")
    teko::assert::str_contains(text, "%5 = field_addr %4, 16")
    teko::assert::str_contains(text, "%6 = load.ptr %5")
    teko::assert::str_contains(text, "%7 = const 7")
    teko::assert::str_contains(text, "%8 = call.indirect %6(%2, %7)")
}

#test
fn lwt_lowers_void_iface_dispatch_call_as_a_valueless_indirect_call() {
    let recv = lwt_num_i64(2000 to i128)
    let args = teko::list::push(teko::list::empty(), recv)
    let call = lwt_iface_call("Speaker", "speak", 0, args, checker::Void { })
    let text = lwt_lower_expr_text(call)
    teko::assert::str_contains(text, "call.indirect %6(%2)")
    teko::assert::is_true(!teko::str::contains(text, "= call.indirect"))
}

/**
 * lwt_func_type — a resolved `Func` signature (A1-7, #382 — the type a
 * closure-typed local/expression carries).
 *
 * @param []checker::Type params  the signature's parameter types, in order
 * @param checker::Type ret  the signature's return type
 * @return checker::Type  the built `Func` type
 */
fn lwt_func_type(params: []checker::Type, ret: checker::Type) -> checker::Type {
    checker::Func { params = params; ret = ret; variadic = false; param_names = teko::list::empty(); n_required = params.len; defaults = teko::list::empty() }
}

/**
 * lwt_bind_typed — a `let` binding of an ARBITRARY resolved type `ty` (A1-7,
 * #382 — `lwt_bind` only covers a primitive-typed binding; a closure literal
 * binds at its own `Func` type).
 *
 * @param str name  the bound name
 * @param checker::TExpr e  the bound value
 * @param checker::Type ty  the binding's resolved type
 * @return checker::TStatement  the built `let` binding
 */
fn lwt_bind_typed(name: str, e: checker::TExpr, ty: checker::Type) -> checker::TStatement {
    checker::TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; bound = ty; value = e }
}

/**
 * lwt_fn_value — a bare top-level function used as a VALUE
 * (`TVar.is_func=true`, A1-7, #382).
 *
 * @param str name  the referenced function's own (unqualified) name
 * @param str ns  the referenced function's declaring namespace
 * @param checker::Type ty  the reference's resolved `Func` type
 * @return checker::TExpr  the built fn-as-value node
 */
fn lwt_fn_value(name: str, ns: str, ty: checker::Type) -> checker::TExpr {
    checker::TExpr { kind = checker::TVar { name = name; is_func = true; func_ns = ns }; type = ty; line = 0; col = 0 }
}

/**
 * lwt_closure_call — a call through a LOCAL closure value
 * (`TCall.is_closure_call=true`, A1-7, #382).
 *
 * @param str name  the local closure variable's name
 * @param []checker::TExpr args  the call's arguments
 * @param checker::Type callee_ty  the closure's own resolved `Func` type
 * @param checker::Type ret  the call's resolved return type
 * @return checker::TExpr  the built closure-call node
 */
fn lwt_closure_call(name: str, args: []checker::TExpr, callee_ty: checker::Type, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TCall {
            callee = lwt_path1(name); args = args; call_ns = ""
            is_closure_call = true; callee_type = callee_ty; is_iface_dispatch = false; iface_slot = 0
        }
        type = ret; line = 0; col = 0
    }
}

#test
fn lwt_lowers_fn_value_and_closure_call_via_a_thunk() {
    let fty = lwt_func_type(teko::list::push(teko::list::push(teko::list::empty(), lwt_prim(checker::PrimKind::I64)), lwt_prim(checker::PrimKind::I64)), lwt_prim(checker::PrimKind::I64))
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lwt_fn_value("add", "teko::demo", fty), fty)))
    let cargs = teko::list::push(teko::list::push(teko::list::empty(), lwt_num_i64(2 to i128)), lwt_num_i64(3 to i128))
    let call = lwt_closure_call("f", cargs, fty, lwt_prim(checker::PrimKind::I64))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), call), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "funcaddr @.Lclofn0")
    teko::assert::str_contains(text, "func @.Lclofn0(%0: ptr, %1: i64, %2: i64) -> i64 {")
    teko::assert::str_contains(text, "call @teko__demo__add(%1, %2)")
    teko::assert::str_contains(text, "call.indirect")
}

/**
 * lwt_lambda_param — one declared lambda parameter (A1-7, #382).
 *
 * @param str name  the parameter's name
 * @param checker::Type ty  the parameter's resolved type
 * @return checker::TLambdaParam  the built parameter node
 */
fn lwt_lambda_param(name: str, ty: checker::Type) -> checker::TLambdaParam {
    checker::TLambdaParam { name = name; type = ty }
}

/**
 * lwt_capture — one captured (free) variable (A1-7, #382 — always by-copy;
 * `by_ref` only ever flips for a `Ref<T>`-typed capture, irrelevant to the
 * lowering's own machine-class mapping).
 *
 * @param str name  the captured variable's name
 * @param checker::Type ty  the captured variable's resolved type
 * @return checker::TCapture  the built capture node
 */
fn lwt_capture(name: str, ty: checker::Type) -> checker::TCapture {
    checker::TCapture { name = name; type = ty; by_ref = false }
}

/**
 * lwt_lambda_types — the resolved type of each declared lambda parameter, in
 * order (A1-7, #382 — feeds `lwt_func_type` so a lambda literal's own `Func`
 * type matches its declared parameters).
 *
 * @param []checker::TLambdaParam params  the lambda's declared parameters
 * @return []checker::Type  each parameter's resolved type, in order
 */
fn lwt_lambda_types(params: []checker::TLambdaParam) -> []checker::Type {
    mut out: []checker::Type = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= params.len { break }
        out = teko::list::push(out, params[i].type)
        i++
    }
    out
}

/**
 * lwt_lambda — a closure LITERAL node (`TLambda`, A1-7, #382).
 *
 * @param []checker::TLambdaParam params  the lambda's declared parameters
 * @param []checker::TStatement body  the lambda's body statements
 * @param []checker::TCapture captures  the lambda's captured-variable list
 * @param checker::Type ret  the lambda's resolved return type
 * @return checker::TExpr  the built lambda-literal node
 */
fn lwt_lambda(params: []checker::TLambdaParam, body: []checker::TStatement, captures: []checker::TCapture, ret: checker::Type) -> checker::TExpr {
    checker::TExpr {
        kind = checker::TLambda { params = params; body = body; captures = captures; ret = ret; lift_id = 0 }
        type = lwt_func_type(lwt_lambda_types(params), ret); line = 0; col = 0
    }
}

#test
fn lwt_lowers_capturing_lambda_literal_and_closure_call() {
    let i64ty = lwt_prim(checker::PrimKind::I64)
    let lam_body = teko::list::push(teko::list::empty(), lwt_ret(lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_var("captured", checker::PrimKind::I64), checker::PrimKind::I64)))
    let params = teko::list::push(teko::list::empty(), lwt_lambda_param("x", i64ty))
    let captures = teko::list::push(teko::list::empty(), lwt_capture("captured", i64ty))
    let lam = lwt_lambda(params, lam_body, captures, i64ty)
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind("captured", lwt_num_i64(41 to i128), checker::PrimKind::I64)))
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lam, lam.type)))
    let call = lwt_closure_call("f", teko::list::push(teko::list::empty(), lwt_num_i64(1 to i128)), lam.type, i64ty)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), call), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "funcaddr @.Lclo0")
    teko::assert::str_contains(text, "func @.Lclo0(%0: ptr, %1: i64) -> i64 {")
    teko::assert::str_contains(text, "field_addr %0, 0")
    teko::assert::str_contains(text, "iadd %1,")
    teko::assert::str_contains(text, "call.indirect")
}

/**
 * lwt_lowers_defer_fires_before_a_void_lambdas_fall_through_return —
 * A1-2, #382: a bodyless-return (`void`) lambda literal `() => { let s=1;
 * defer { s = s + 100 } }` closes via `close_lambda_body`'s own
 * fall-through, which must fire the pending defer before its implicit
 * void `ret`, exactly like a `void` function's own fall-through.
 */
#test
fn lwt_lowers_defer_fires_before_a_void_lambdas_fall_through_return() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let lam_body = teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_defer(defer_body))
    let lam = lwt_lambda(teko::list::empty(), lam_body, teko::list::empty(), checker::Void { })
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("f", lam, lam.type)))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "const 100")
    teko::assert::str_contains(text, "iadd")
}

/**
 * lwt_interp_runs_function_trailing_expression_as_return_value — #421, the
 * interp-oracle side: `fn f() -> i32 { 42 }` (no explicit `return`) lowered
 * via `lower_function` and run through `interp_lmodule` yields exit code 42
 * — before the fix the fall-through body closed with a valueless `ret`, so
 * the interp's `is_return` outcome carried 0, not 42.
 */
#test
fn lwt_interp_runs_function_trailing_expression_as_return_value() {
    let body = teko::list::push(teko::list::empty(), lwt_exprstmt(lwt_num(42 to i128, checker::PrimKind::I32)))
    let f = lwt_fn("f", "", teko::list::empty(), checker::Prim { kind = checker::PrimKind::I32 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let m = add_func(empty_module(), lf)
    teko::assert::is_true(interp_lmodule(m, "f", teko::list::empty()) == (42 to i128))
}

/**
 * lwt_lowers_continue_jumps_back_to_the_loop_head — A1-2, #382:
 * `loop { continue }` — the continue is the body's only statement,
 * terminating the head block with a self-jump back to itself (`#B1: jump
 * #B1()`), exercising `lower_continue`'s target-head resolution separately
 * from `lower_break`'s target-exit one.
 */
#test
fn lwt_lowers_continue_jumps_back_to_the_loop_head() {
    let body = teko::list::push(teko::list::empty(), lwt_loop("", teko::list::push(teko::list::empty(), lwt_continue(""))))
    let f = lwt_fn("k", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    jump #B1()")
}

/**
 * lwt_defer_inside_else_arm_fires_only_on_that_arms_own_branch — PR #553
 * follow-up nit, UPDATED for #389 F1b item 1: the ELSE-arm mirror of
 * `lwt_defer_inside_if_arm_fires_only_on_that_arms_own_branch`: `let s=1; if
 * x>0 { } else { defer { s = s + 100 } }; return s` — the `defer` registers
 * ONLY inside the ELSE arm, never the empty THEN arm. The THEN arm (`#B1`,
 * empty) jumps its own untouched `s` straight to the merge, `#B3(%1)`; the
 * ELSE arm (`#B2`) fires the defer — LIFO, from the defer-delta base THIS arm
 * itself started at — as part of ITS OWN close, then jumps its POST-defer `s`,
 * `#B3(%6)` (`%6 = iadd %1, %5`), `close_arm_replaying_defers` re-sampling the
 * scalar arg from its post-replay env. `s` is THREADED as the merge param
 * `#B3(%4)` and the tail reads it, `ret %4` — proving the ELSE arm's defer
 * write reaches the merge (F1b's `TDeferStmt` descent scopes EITHER arm
 * identically, not just the THEN side). Before F1b the merge carried ZERO
 * params and the tail read the STALE pre-defer `s` (`ret %1`) — the OLD golden
 * shape encoded that same-class silent merge-drop; the defer is still never
 * replayed a second time at the merge (its original PR #553 scope fix).
 *
 * @return void
 */
#test
fn lwt_defer_inside_else_arm_fires_only_on_that_arms_own_branch() {
    let s_plus_100 = lwt_bin(lexer::TokenKind::Plus, lwt_var("s", checker::PrimKind::I64), lwt_num_i64(100 to i128), checker::PrimKind::I64)
    let defer_body = teko::list::push(teko::list::empty(), lwt_simple_assign("s", lexer::TokenKind::Assign, s_plus_100, checker::PrimKind::I64))
    let cond = lwt_cmp(lwt_var("x", checker::PrimKind::I64), teko::list::push(teko::list::empty(), lwt_cmp_term(lexer::TokenKind::Gt, lwt_num_i64(0 to i128))))
    let else_blk = teko::list::push(teko::list::empty(), lwt_defer(defer_body))
    let ifstmt = lwt_if_stmt(cond, teko::list::empty(), true, else_blk)
    let tail_ret = lwt_ret(lwt_var("s", checker::PrimKind::I64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lwt_bind("s", lwt_num_i64(1 to i128), checker::PrimKind::I64)), lwt_exprstmt(ifstmt)), tail_ret)
    let params = teko::list::push(teko::list::empty(), lwt_param("x", "i64"))
    let f = lwt_fn("else_arm_scoped", "teko::demo", params, checker::Prim { kind = checker::PrimKind::I64 }, body)
    let lf = match lower_function(f) { LoweredFunction as x => x.func; error as err => return }
    let text = print_lmodule(add_func(empty_module(), lf))
    teko::assert::str_contains(text, "  #B1:\n    jump #B3(%1)")
    teko::assert::str_contains(text, "  #B2:\n    %5 = const 100\n    %6 = iadd %1, %5\n    jump #B3(%6)")
    teko::assert::str_contains(text, "  #B3(%4):\n    ret %4\n}")
}

/**
 * lwt_lowers_loop_leaves_a_fat_local_unpromoted — A1-2, #382: `let s = "hi";
 * loop { break }; exit(s.len)` — `s` is the ONLY name live at the loop's
 * entry, but it is a FAT (str) binding, so `promote_env` leaves it
 * UNPROMOTED: both the head and exit blocks stay zero-arg, and `s.len`
 * still resolves with NO memory traffic (the fat length VReg threads
 * through the loop untouched, exactly as it was before it).
 */
#test
fn lwt_lowers_loop_leaves_a_fat_local_unpromoted() {
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind_typed("s", lwt_strlit("hi"), checker::Str { })))
    items = teko::list::push(items, lwt_item(lwt_loop("", teko::list::push(teko::list::empty(), lwt_break("")))))
    let len_access = lwt_field_access(lwt_typed_var("s", checker::Str { }), "len", lwt_prim(checker::PrimKind::I64))
    items = teko::list::push(items, lwt_item(lwt_exprstmt(lwt_call(lwt_path1("exit"), "", teko::list::push(teko::list::empty(), len_access), checker::Void { }))))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "%1 = const 2")
    teko::assert::str_contains(text, "    jump #B1()\n  #B1:\n    jump #B2()\n  #B2:\n    call @tk_exit(%1)")
}

#test
/**
 * lwt_fat_local_reassign_honest_stops_on_later_fat_use — #389 F1b item 3
 * review finding 1: `let s = "hello"; s = "hi"; return s.len` must HONEST-STOP,
 * NOT silently return the STALE pre-reassignment length. `lower_assign_simple`'s
 * `=` path always lowers the RHS through the plain (scalar) `lower_expr`, so a
 * reassignment of a fat-typed name only ever supplies a fresh PTR VReg, never a
 * fresh length — `lenv_reassign` must therefore NEVER update a fat binding's
 * `vregs` slot in place (that would pair the NEW ptr with the OLD `len_vregs`
 * entry, a silent stale-length miscompile); it falls back to the pre-item3
 * append (a fresh SCALAR entry, `has_len=false`), so `lenv_lookup_fat`'s
 * newest-first scan for `s` hits that scalar entry and reports `has_len=false`,
 * and `lower_len_field` -> `lower_fat_expr` -> `lower_var_fat` honest-stops with
 * the SAME NAMED error a fat reassignment produced before item-3 ever touched
 * `lenv_reassign` — refusing the program instead of returning a wrong answer.
 *
 * @return void
 */
fn lwt_fat_local_reassign_honest_stops_on_later_fat_use() {
    let s_bind = lwt_bind_typed("s", lwt_strlit("hello"), checker::Str { })
    let reassign = lwt_simple_assign("s", lexer::TokenKind::Assign, lwt_strlit("hi"), checker::PrimKind::I64)
    let len_access = lwt_field_access(lwt_typed_var("s", checker::Str { }), "len", lwt_prim(checker::PrimKind::U64))
    let body = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), s_bind), reassign), lwt_ret(len_access))
    let f = lwt_fn("fat_reassign_then_len", "teko::demo", teko::list::empty(), lwt_prim(checker::PrimKind::U64), body)
    let out = match lower_function(f) { LoweredFunction => "ok"; error as e => e.message }
    teko::assert::str_contains(out, "`s` is not a fat-pointer local")
}

/**
 * lwt_honest_stop_on_break_outside_a_loop — a bare `break` with no
 * enclosing `loop` on its lowering path is a checker invariant break
 * (M.1) — `find_loop_target` honest-stops by name rather than resolving
 * to a bogus target (A1-2, #382).
 */
#test
fn lwt_honest_stop_on_break_outside_a_loop() {
    let body = teko::list::push(teko::list::empty(), lwt_break(""))
    let f = lwt_fn("stray_break", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let out = match lower_function(f) { LoweredFunction => "ok"; error as e => e.message }
    teko::assert::str_contains(out, "break/continue outside a loop")
}

/**
 * lwt_honest_stop_on_continue_outside_a_loop — the same invariant guard as
 * `lwt_honest_stop_on_break_outside_a_loop`, exercised through
 * `lower_continue`'s own call site (A1-2, #382).
 */
#test
fn lwt_honest_stop_on_continue_outside_a_loop() {
    let body = teko::list::push(teko::list::empty(), lwt_continue(""))
    let f = lwt_fn("stray_continue", "teko::demo", teko::list::empty(), checker::Void { }, body)
    let out = match lower_function(f) { LoweredFunction => "ok"; error as e => e.message }
    teko::assert::str_contains(out, "break/continue outside a loop")
}

/** lwt_field — one `struct` field: `name: <tname>`, an all-public struct field (#414, #382). */
fn lwt_field(name: str, tname: str) -> parser::Field {
    parser::Field { name = name; type_ann = lwt_named_te(tname); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
}

/** lwt_struct_decl — a `struct <name> { <fields> }` TypeDecl, wrapped as a `checker::TItem`
    (#414, #382). */
fn lwt_struct_decl(name: str, fields: []parser::Field) -> checker::TItem {
    parser::TypeDecl {
        name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }
        vis = parser::Visibility::Pub; has_doc = false; doc = ""
        line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""
        is_unsafe = false; must_free = false
    }
}

/**
 * lwt_two_fields — a two-element `[]parser::Field` list, in order (#414, #382).
 *
 * @param parser::Field a  the first field
 * @param parser::Field b  the second field
 * @return []parser::Field  `[a, b]`
 */
fn lwt_two_fields(a: parser::Field, b: parser::Field) -> []parser::Field {
    teko::list::push(teko::list::push(teko::list::empty(), a), b)
}

/**
 * lwt_three_fields — a three-element `[]parser::Field` list, in order (#414, #382).
 *
 * @param parser::Field a  the first field
 * @param parser::Field b  the second field
 * @param parser::Field c  the third field
 * @return []parser::Field  `[a, b, c]`
 */
fn lwt_three_fields(a: parser::Field, b: parser::Field, c: parser::Field) -> []parser::Field {
    teko::list::push(lwt_two_fields(a, b), c)
}

/**
 * lwt_nested_struct_layout_program — `struct Point { x: i64; y: i64 }` (declared
 * first, so its layout is already KNOWN) followed by `struct Line { a: byte; p:
 * Point; c: byte }`, whose middle field is Point BY VALUE (#414, #382).
 *
 * @return checker::TProgram  the two-struct program
 */
fn lwt_nested_struct_layout_program() -> checker::TProgram {
    let point = lwt_struct_decl("Point", lwt_two_fields(lwt_field("x", "i64"), lwt_field("y", "i64")))
    let line = lwt_struct_decl("Line", lwt_three_fields(lwt_field("a", "byte"), lwt_field("p", "Point"), lwt_field("c", "byte")))
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, point)
    items = teko::list::push(items, line)
    checker::TProgram { items = items }
}

/**
 * nested_struct_by_value_field_layout_accounts_for_the_inner_structs_real_width
 * — #414, #382: `Line`'s middle field `p: Point` (a struct BY VALUE, size 16
 * align 8) must widen `Line` to size 32 (`a`@0 padded to 8 for `p`, `p`@8
 * spans its own 16 bytes, `c`@24 padded to the struct's own 8-byte
 * alignment) — the OLD `ltype_of_typeexpr`-only mapping collapsed `p` to a
 * bare `Ptr` (8 bytes), under-sizing `Line` to 24 and misplacing `c`@16.
 */
#test
fn nested_struct_by_value_field_layout_accounts_for_the_inner_structs_real_width() {
    let m = match lower_program(lwt_nested_struct_layout_program()) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "layout Point: size=16 align=8 {x@0, y@8}")
    teko::assert::str_contains(text, "layout Line: size=32 align=8 {a@0, p@8, c@24}")
}

/**
 * lwt_virtual_main_returns_the_trailing_top_level_expressions_value — #423,
 * #382: `let x = 40; x + 2` (no explicit `exit`/`return`) — the loose
 * top-level statement list's TRAILING non-void expression becomes the
 * program's exit code, exactly like a non-void function body's own
 * trailing-expression auto-return (#421). Before the fix, `close_virtual_main`
 * unconditionally emitted `const 0; ret` here, discarding the `42` value.
 */
#test
fn lwt_virtual_main_returns_the_trailing_top_level_expressions_value() {
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, lwt_item(lwt_bind("x", lwt_num_i64(40 to i128), checker::PrimKind::I64)))
    let tail = lwt_bin(lexer::TokenKind::Plus, lwt_var("x", checker::PrimKind::I64), lwt_num_i64(2 to i128), checker::PrimKind::I64)
    items = teko::list::push(items, lwt_item(lwt_exprstmt(tail)))
    let prog = checker::TProgram { items = items }
    let m = match lower_program(prog) { LModule as x => x; error as err => return }
    let text = print_lmodule(m)
    teko::assert::str_contains(text, "iadd ")
    teko::assert::str_contains(text, "ret %2")
    teko::assert::is_true(!teko::str::contains(text, "const 0"))
}
