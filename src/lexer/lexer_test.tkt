// src/lexer/lexer_test.tkt — tests for teko::lexer. NO `main`: tests are PUBLIC
// `#test` functions the compiler collects and runs (a runner — ALPHA). The C
// mirror uses a `main` harness (the runner does not exist in the bootstrap).

// helpers (not tests):
// the kinds of the tokens of `source` (already validated), or error if it fails.
fn kinds_of(source: str) -> []TokenKind | error {
    let toks = match tokenize(source) {
        []Token as ts => ts
        error => return error { message = "lex failed" }
    }
    mut ks: []TokenKind = teko::list::empty()
    mut i = 0
    loop {
        if i >= toks.len { break }
        ks = teko::list::push(ks, toks[i].kind)
        i++
    }
    ks
}

// do the kinds of `source` equal `want`, in order?
fn kinds_eq(source: str, want: []TokenKind) -> bool {
    let got = match kinds_of(source) {
        []TokenKind as ks => ks
        error => return false
    }
    if got.len != want.len { return false }
    mut i = 0
    loop {
        if i >= got.len { break }
        if got[i] != want[i] { return false }
        i++
    }
    true
}

// does lexing `source` fail with an error?
fn is_error(source: str) -> bool {
    match tokenize(source) {
        []Token => false
        error => true
    }
}

#test
fn rejects_unexpected_byte() {
    teko::assert::is_true(is_error("1 @ 2"))   // unexpected byte
}

// --- raw / verbatim strings `@"…"` and multi-line strings `"""…"""` ---
// Both forms produce a plain TokenKind::Str carrying the DECODED bytes (the lexer
// already decodes — read_str stores final bytes, not a source view).

// the text (decoded bytes) of the single token of `source`, or "" on failure.
fn one_str_text(source: str) -> str {
    let toks = match tokenize(source) {
        []Token as ts => ts
        error => return ""
    }
    if toks.len != 1 { return "" }
    toks[0].text
}

#test
fn lexes_multiline_string_literal() {
    // a multi-line string is a single Str token; it spans ≥2 lines (literal newline).
    teko::assert::is_true(kinds_eq("\"\"\"a\nb\"\"\"", [TokenKind::Str]))
    teko::assert::is_true(one_str_text("\"\"\"a\nb\"\"\"") == "a\nb")
    // a lone `"` inside is LITERAL (only `"""` closes).
    teko::assert::is_true(one_str_text("\"\"\"a\"b\"\"\"") == "a\"b")
    // escapes are processed normally: `\t` → a tab byte.
    teko::assert::is_true(one_str_text("\"\"\"a\\tb\"\"\"") == "a\tb")
    // empty multi-line string `""""""` (six quotes).
    teko::assert::is_true(one_str_text("\"\"\"\"\"\"") == "")
}

// ---- orthogonal prefix modifiers ($ × @) × delimiters (single/multi) ----

// the InterpRaw token's text is the FRESH inner bytes the lexer already resolved:
// single-line verbatim has the `""`→`"` collapse applied; multi-line is as-is.
#test
fn interp_raw_token_text_is_resolved() {
    // `$@"a""b{1}c"` → inner text `a"b{1}c` (collapse applied; hole span intact, backslash N/A).
    teko::assert::is_true(one_str_text("$@\"a\"\"b{1}c\"") == "a\"b{1}c")
    // backslash literal in verbatim interp: `$@"x{1}\ny"` → inner `x{1}\ny`.
    teko::assert::is_true(one_str_text("$@\"x{1}\\ny\"") == "x{1}\\ny")
    // multi-line verbatim: lone `"` literal — `$@"""a"b{1}c"""` → inner `a"b{1}c`.
    teko::assert::is_true(one_str_text("$@\"\"\"a\"b{1}c\"\"\"") == "a\"b{1}c")
}

// `{{`/`}}` doubling: the LEXER finds the closing quote correctly even with unbalanced literal
// braces at depth 0. Plain Interp keeps the raw VIEW (parser collapses `{{`→`{`); verbatim
// InterpRaw PRESERVES `{{`/`}}` as two bytes AS-IS (parser still does the collapse).
#test
fn lexes_brace_doubling_close_finding() {
    // plain interp: `$"a{{b}}c"` is ONE Interp token (close found; braces balanced literal).
    teko::assert::is_true(kinds_eq("$\"a{{b}}c\"", [TokenKind::Interp]))
    // plain interp UNBALANCED literal brace before the close: `$"a{{"` — close still found.
    teko::assert::is_true(kinds_eq("$\"a{{\"", [TokenKind::Interp]))
    // plain interp token text is the raw VIEW (parser decodes): `$"a{{b}}c"` → `a{{b}}c`.
    teko::assert::is_true(one_str_text("$\"a{{b}}c\"") == "a{{b}}c")
    // plain interp ending in a literal brace: `$"a{{"` → view `a{{`.
    teko::assert::is_true(one_str_text("$\"a{{\"") == "a{{")
    // verbatim interp PRESERVES `{{`/`}}` as two bytes: `$@"{{x}}"` → inner `{{x}}`.
    teko::assert::is_true(one_str_text("$@\"{{x}}\"") == "{{x}}")
    // order-free verbatim: `@$"{{x}}"` → inner `{{x}}` (preserved for the parser to collapse).
    teko::assert::is_true(one_str_text("@$\"{{x}}\"") == "{{x}}")
}
