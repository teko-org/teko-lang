/**
 * sv_gpr — a physical GPR register operand with the given SysV encoding id (a
 * descriptor-test shorthand).
 *
 * @param u32 id  the physical register id (RAX=0..R15=15)
 * @return MReg  the physical GPR register
 */
fn sv_gpr(id: u32) -> MReg {
    preg(id, MRegClass::GPR)
}

/**
 * sv_fpr — a physical FPR (XMM) register operand with the given id.
 *
 * @param u32 id  the physical register id (XMM0=0..XMM15=15)
 * @return MReg  the physical FPR register
 */
fn sv_fpr(id: u32) -> MReg {
    preg(id, MRegClass::FPR)
}

/**
 * sv_iv — a virtual GPR live interval (a neutrality-proof scan-test shorthand,
 * driving the SHARED linear scan under the SysV register file).
 *
 * @param u32 reg_id  the virtual register id
 * @param u32 start  the start program point
 * @param u32 end  the last-use program point
 * @param bool crosses  whether the value is live across a call
 * @return LiveInterval  the virtual interval
 */
fn sv_iv(reg_id: u32, start: u32, end: u32, crosses: bool) -> LiveInterval {
    LiveInterval { reg_id = reg_id; reg_class = MRegClass::GPR; start = start; end = end; is_fixed = false; crosses_call = crosses }
}

/**
 * sv_fixed — a fixed GPR pin interval on physical register `reg_id` (the shape
 * isel plants for an argument-register pin), for the fixed-pin-avoidance proof.
 *
 * @param u32 reg_id  the pinned physical register id
 * @param u32 start  the start program point
 * @param u32 end  the last-use program point
 * @return LiveInterval  the fixed pin interval
 */
fn sv_fixed(reg_id: u32, start: u32, end: u32) -> LiveInterval {
    LiveInterval { reg_id = reg_id; reg_class = MRegClass::GPR; start = start; end = end; is_fixed = true; crosses_call = false }
}

/**
 * sv_set — an `IntervalSet` from virtual + fixed intervals with no call points
 * (`crosses_call` on a virtual interval alone drives the call-clobber filter).
 *
 * @param []LiveInterval virt  the virtual intervals to color
 * @param []LiveInterval fixed  the fixed pin intervals to block
 * @return IntervalSet  the interval set
 */
fn sv_set(virt: []LiveInterval, fixed: []LiveInterval) -> IntervalSet {
    IntervalSet { virt = virt; fixed = fixed; call_points = teko::list::empty() }
}

/**
 * sv_phys — the physical register `vreg_id` was assigned by the scan, or the
 * sentinel 100000 if it was spilled or absent.
 *
 * @param ScanResult scan  the linear-scan result
 * @param u32 vreg_id  the virtual register to resolve
 * @return u32  its assigned physreg id, or 100000
 */
fn sv_phys(scan: ScanResult, vreg_id: u32) -> u32 {
    mut i: u64 = 0
    loop {
        if i >= scan.assignments.len { break }
        let got = match scan.assignments[i] {
            InReg as r => if r.vreg_id == vreg_id { r.phys } else { 100000 to u32 }
            Spilled => 100000 to u32
        }
        if got != 100000 to u32 { return got }
        i++
    }
    100000 to u32
}

/**
 * sv_spilled — whether `vreg_id` was spilled to a frame slot by the scan.
 *
 * @param ScanResult scan  the linear-scan result
 * @param u32 vreg_id  the virtual register to query
 * @return bool  true iff spilled
 */
fn sv_spilled(scan: ScanResult, vreg_id: u32) -> bool {
    mut i: u64 = 0
    loop {
        if i >= scan.assignments.len { break }
        let sp = match scan.assignments[i] {
            Spilled as s => s.vreg_id == vreg_id
            InReg => false
        }
        if sp { return true }
        i++
    }
    false
}

/**
 * sv_tiny_abi — a two-register SysV-flavored GPR descriptor whose only
 * allocatable registers are the callee-saved pair RBX(3)/R12(12), forcing a
 * spill under three-value pressure. Caller-saved is empty so `crosses_call`
 * filtering never interferes with the pressure proof; the spill scratch is the
 * real SysV R10/R11.
 *
 * @return AbiDescriptor  the tiny SysV register file
 */
fn sv_tiny_abi() -> AbiDescriptor {
    mut alloc: []u32 = teko::list::empty()
    alloc = teko::list::push(alloc, 3)
    alloc = teko::list::push(alloc, 12)
    AbiDescriptor {
        gpr_arg = alloc
        fpr_arg = teko::list::empty()
        gpr_allocatable = alloc
        fpr_allocatable = teko::list::empty()
        gpr_caller_saved = teko::list::empty()
        fpr_caller_saved = teko::list::empty()
        gpr_spill_scratch = push_range(teko::list::empty(), 10, 11)
        fpr_spill_scratch = teko::list::empty()
        spill_slot_bytes = 8
        spill_slot_align = 8
        shadow_space = 0 to u32
    }
}

#test
fn sv_arg_reg_fills_argument_registers_then_overflows() {
    let abi = sysv64()
    let a0 = arg_reg(abi, MRegClass::GPR, 0)
    teko::assert::is_true(a0.ok)
    teko::assert::is_true(a0.reg.id == 7)
    teko::assert::is_true(a0.reg.is_phys)
    teko::assert::is_true(a0.reg.reg_class == MRegClass::GPR)
    teko::assert::is_true(arg_reg(abi, MRegClass::GPR, 1).reg.id == 6)
    teko::assert::is_true(arg_reg(abi, MRegClass::GPR, 2).reg.id == 2)
    teko::assert::is_true(arg_reg(abi, MRegClass::GPR, 3).reg.id == 1)
    teko::assert::is_true(arg_reg(abi, MRegClass::GPR, 4).reg.id == 8)
    let a5 = arg_reg(abi, MRegClass::GPR, 5)
    teko::assert::is_true(a5.ok)
    teko::assert::is_true(a5.reg.id == 9)
    teko::assert::is_true(!arg_reg(abi, MRegClass::GPR, 6).ok)
    let f0 = arg_reg(abi, MRegClass::FPR, 0)
    teko::assert::is_true(f0.ok)
    teko::assert::is_true(f0.reg.id == 0)
    teko::assert::is_true(f0.reg.reg_class == MRegClass::FPR)
    teko::assert::is_true(arg_reg(abi, MRegClass::FPR, 7).reg.id == 7)
    teko::assert::is_true(!arg_reg(abi, MRegClass::FPR, 8).ok)
}

#test
fn sv_allocatable_pool_caller_saved_first_excludes_frame_and_scratch() {
    let abi = sysv64()
    let gpr = allocatable_pool(abi, MRegClass::GPR)
    teko::assert::is_true(gpr[0] == 0)
    teko::assert::is_true(is_caller_saved(abi, sv_gpr(gpr[0])))
    teko::assert::is_true(contains_u32(gpr, 1))
    teko::assert::is_true(contains_u32(gpr, 2))
    teko::assert::is_true(contains_u32(gpr, 6))
    teko::assert::is_true(contains_u32(gpr, 7))
    teko::assert::is_true(contains_u32(gpr, 9))
    teko::assert::is_true(!contains_u32(gpr, 4))
    teko::assert::is_true(!contains_u32(gpr, 5))
    teko::assert::is_true(!contains_u32(gpr, 10))
    teko::assert::is_true(!contains_u32(gpr, 11))
    teko::assert::is_true(contains_u32(gpr, 3))
    teko::assert::is_true(contains_u32(gpr, 12))
    teko::assert::is_true(contains_u32(gpr, 15))
    let fpr = allocatable_pool(abi, MRegClass::FPR)
    teko::assert::is_true(fpr[0] == 0)
    teko::assert::is_true(contains_u32(fpr, 13))
    teko::assert::is_true(!contains_u32(fpr, 14))
    teko::assert::is_true(!contains_u32(fpr, 15))
}

#test
fn sv_caller_and_callee_saved_partition() {
    let abi = sysv64()
    teko::assert::is_true(is_caller_saved(abi, sv_gpr(0)))
    teko::assert::is_true(is_caller_saved(abi, sv_gpr(11)))
    teko::assert::is_true(!is_caller_saved(abi, sv_gpr(3)))
    teko::assert::is_true(is_callee_saved(abi, sv_gpr(3)))
    teko::assert::is_true(is_callee_saved(abi, sv_gpr(12)))
    teko::assert::is_true(!is_callee_saved(abi, sv_gpr(0)))
    teko::assert::is_true(!is_callee_saved(abi, sv_gpr(5)))
    teko::assert::is_true(is_caller_saved(abi, sv_fpr(0)))
    teko::assert::is_true(is_caller_saved(abi, sv_fpr(7)))
    teko::assert::is_true(!is_callee_saved(abi, sv_fpr(0)))
}

#test
fn sv_spill_scratch_reserved_registers() {
    let abi = sysv64()
    teko::assert::is_true(spill_scratch(abi, MRegClass::GPR, 0).id == 10)
    teko::assert::is_true(spill_scratch(abi, MRegClass::GPR, 1).id == 11)
    teko::assert::is_true(spill_scratch(abi, MRegClass::GPR, 0).is_phys)
    teko::assert::is_true(spill_scratch(abi, MRegClass::FPR, 0).id == 14)
    teko::assert::is_true(spill_scratch(abi, MRegClass::FPR, 1).id == 15)
    teko::assert::is_true(spill_scratch(abi, MRegClass::FPR, 0).reg_class == MRegClass::FPR)
}

#test
fn sv_disjoint_intervals_reuse_a_register() {
    let virt = teko::list::push(teko::list::push(teko::list::empty(), sv_iv(0, 0, 2, false)), sv_iv(1, 3, 5, false))
    let scan = linear_scan(sysv64(), sv_set(virt, teko::list::empty()))
    teko::assert::is_true(sv_phys(scan, 0) == sv_phys(scan, 1))
    teko::assert::is_true(sv_phys(scan, 0) != 100000 to u32)
}

#test
fn sv_overlapping_intervals_get_distinct_registers() {
    let virt = teko::list::push(teko::list::push(teko::list::empty(), sv_iv(0, 0, 5, false)), sv_iv(1, 2, 7, false))
    let scan = linear_scan(sysv64(), sv_set(virt, teko::list::empty()))
    teko::assert::is_true(sv_phys(scan, 0) != sv_phys(scan, 1))
    teko::assert::is_true(sv_phys(scan, 0) != 100000 to u32)
    teko::assert::is_true(sv_phys(scan, 1) != 100000 to u32)
}

#test
fn sv_crosses_call_gets_a_callee_saved_register() {
    let abi = sysv64()
    let virt = teko::list::push(teko::list::empty(), sv_iv(0, 0, 5, true))
    let scan = linear_scan(abi, sv_set(virt, teko::list::empty()))
    let p = sv_phys(scan, 0)
    teko::assert::is_true(p != 100000 to u32)
    teko::assert::is_true(p == 3)
    teko::assert::is_true(is_callee_saved(abi, sv_gpr(p)))
    teko::assert::is_true(!is_caller_saved(abi, sv_gpr(p)))
}

#test
fn sv_fixed_pin_on_rdi_arg_reg_is_avoided() {
    let virt = teko::list::push(teko::list::empty(), sv_iv(0, 0, 5, false))
    mut fixed: []LiveInterval = teko::list::empty()
    fixed = teko::list::push(fixed, sv_fixed(0, 0, 5))
    fixed = teko::list::push(fixed, sv_fixed(1, 0, 5))
    fixed = teko::list::push(fixed, sv_fixed(2, 0, 5))
    fixed = teko::list::push(fixed, sv_fixed(6, 0, 5))
    fixed = teko::list::push(fixed, sv_fixed(7, 0, 5))
    let scan = linear_scan(sysv64(), sv_set(virt, fixed))
    teko::assert::is_true(sv_phys(scan, 0) != 7 to u32)
    teko::assert::is_true(sv_phys(scan, 0) == 8 to u32)
}

#test
fn sv_pressure_spills_furthest_next_use() {
    let virt = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(),
        sv_iv(0, 0, 9, false)), sv_iv(1, 1, 5, false)), sv_iv(2, 2, 3, false))
    let scan = linear_scan(sv_tiny_abi(), sv_set(virt, teko::list::empty()))
    teko::assert::is_true(sv_spilled(scan, 0))
    teko::assert::is_true(!sv_spilled(scan, 2))
    teko::assert::is_true(sv_phys(scan, 2) != 100000 to u32)
    teko::assert::is_true(sv_phys(scan, 999) == 100000 to u32)
}
