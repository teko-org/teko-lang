use teko::lir

/**
 * iat_i128 — the i128 carrier for a small integer literal in the isel
 * fixtures (mirrors `lir_interp_test.tkt`'s `iwt_i128`).
 *
 * @param i64 v  the literal value
 * @return i128  its i128 carrier
 */
fn iat_i128(v: i64) -> i128 {
    v to i128
}

/**
 * iat_bin — append `%r = op a, b` to `f0`, returning the advanced function
 * plus the fresh result VReg (a fixture-building shorthand shared by every
 * test below).
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LBinOp op  the binary op
 * @param u32 a  the first operand VReg
 * @param u32 b  the second operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn iat_bin(f0: lir::LFunc, op: lir::LBinOp, a: u32, b: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, op, a, b, 0, 0)); vreg = r.vreg }
}

/**
 * iat_un — append `%r = op a` to `f0`, returning the advanced function plus
 * the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LUnOp op  the unary op
 * @param u32 a  the operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn iat_un(f0: lir::LFunc, op: lir::LUnOp, a: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::un_inst(r.vreg, op, a, 0, 0)); vreg = r.vreg }
}

/**
 * iat_const — append `%r = const val` to `f0`, returning the advanced
 * function plus the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param i64 val  the literal value
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn iat_const(f0: lir::LFunc, val: i64) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::const_int_inst(r.vreg, iat_i128(val), 0, 0)); vreg = r.vreg }
}

/**
 * iat_const_float — append `%r = const.float bits` to `f0`, returning the
 * advanced function plus the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param u64 bits  the IEEE bit pattern
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn iat_const_float(f0: lir::LFunc, bits: u64) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::const_float_inst(r.vreg, bits, 0, 0)); vreg = r.vreg }
}

/**
 * iat_ret — append `ret value` to `f0`.
 *
 * @param lir::LFunc f0  the function to extend
 * @param u32 value  the returned VReg
 * @return lir::LFunc  the advanced function
 */
fn iat_ret(f0: lir::LFunc, value: u32) -> lir::LFunc {
    lir::append_inst(f0, 0, lir::ret_inst(value, 0, 0))
}

/**
 * iat_two_i64_params — a fresh 2-param (I64, I64) -> I64 function named
 * `sym`, its entry block already carrying both `LParam` instructions.
 *
 * @param str sym  the function's symbol
 * @return lir::LFunc  the seeded function
 */
fn iat_two_i64_params(sym: str) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I64), lir::LType::I64)
    mut f = lir::new_func(sym, 2, ptypes, lir::LType::I64)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
}
/**
 * iat_main_ret — a zero-param `main` returning a fully-built expression
 * (the "straight-line, no calls" analog of `lir_interp_test.tkt`'s F1-F5:
 * A2-2 does not yet select `LCall`, so the equivalence fixtures below use a
 * plain `ret` in place of a `tk_exit`).
 *
 * @return lir::LFunc  the seeded, empty-bodied function
 */
fn iat_main_ret() -> lir::LFunc {
    lir::new_func("main", 0, teko::list::empty(), lir::LType::I32)
}

#test
fn iat_const_minus_one_is_a_single_movn_with_zero_imm() {
    let c = iat_const(iat_main_ret(), -1)
    let f = iat_ret(c.func, c.vreg)
    let mf = match select_lfunc(f) { MFunc as x => x; error => return }
    let text = minst_print(add_mfunc(empty_mmodule(), mf))
    teko::assert::str_contains(text, "movn.x %0, #0, lsl #0")
}

#test
fn iat_materialize_bits_narrow_form_direct() {
    let ctx0 = SelCtx { func = new_mfunc("main"); vinfo = vinfo_empty(); next_scratch = 0; cur_block = 0; next_block = 1 }
    let ctx1 = materialize_bits(ctx0, vreg(0, MRegClass::GPR), 42 to u64, false)
    let text = minst_print(add_mfunc(empty_mmodule(), ctx1.func))
    teko::assert::str_contains(text, "movz.w %0, #42, lsl #0")
}

/**
 * iat_kitchen_sink — a two-param (I64,I64) function exercising every
 * `LBinOp` arithmetic/bitwise/shift/compare case plus every `LUnOp` case
 * (the coverage sweep for `select_bin`/`select_un`'s full dispatch),
 * ending `ret`. Assertions below are ROBUST — they check the opcode
 * mnemonic appears, not exact register numbers (ids shift as the fixture
 * grows).
 *
 * @return lir::LFunc  the built function
 */
fn iat_kitchen_sink() -> lir::LFunc {
    mut f = iat_two_i64_params("teko__demo__kitchen_sink")
    f = iat_bin(f, lir::LBinOp::IAdd, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ISub, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IMul, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IDivS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IDivU, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IRemS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IRemU, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IAnd, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IOr, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IXor, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IShl, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IShrS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::IShrU, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpEq, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpNe, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpLtS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpLtU, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpLeS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpLeU, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpGtS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpGtU, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpGeS, 0, 1).func
    f = iat_bin(f, lir::LBinOp::ICmpGeU, 0, 1).func
    f = iat_un(f, lir::LUnOp::INeg, 0).func
    f = iat_un(f, lir::LUnOp::INot, 0).func
    f = iat_un(f, lir::LUnOp::Trunc, 0).func
    f = iat_un(f, lir::LUnOp::ZExt, 0).func
    let last = iat_un(f, lir::LUnOp::SExt, 0)
    f = last.func
    iat_ret(f, last.vreg)
}

#test
fn iat_kitchen_sink_covers_every_int_bin_and_un_op() {
    let mf = match select_lfunc(iat_kitchen_sink()) { MFunc as x => x; error => return }
    let text = minst_print(add_mfunc(empty_mmodule(), mf))
    teko::assert::str_contains(text, "add.x ")
    teko::assert::str_contains(text, "sub.x ")
    teko::assert::str_contains(text, "mul.x ")
    teko::assert::str_contains(text, "sdiv.x ")
    teko::assert::str_contains(text, "udiv.x ")
    teko::assert::str_contains(text, "msub.x ")
    teko::assert::str_contains(text, "and.x ")
    teko::assert::str_contains(text, "orr.x ")
    teko::assert::str_contains(text, "eor.x ")
    teko::assert::str_contains(text, "lsl.x ")
    teko::assert::str_contains(text, "asr.x ")
    teko::assert::str_contains(text, "lsr.x ")
    teko::assert::str_contains(text, "cset.w ")
    teko::assert::str_contains(text, "eq")
    teko::assert::str_contains(text, "ne")
    teko::assert::str_contains(text, "lt")
    teko::assert::str_contains(text, "lo")
    teko::assert::str_contains(text, "le")
    teko::assert::str_contains(text, "ls")
    teko::assert::str_contains(text, "gt")
    teko::assert::str_contains(text, "hi")
    teko::assert::str_contains(text, "ge")
    teko::assert::str_contains(text, "hs")
    teko::assert::str_contains(text, "neg.x ")
    teko::assert::str_contains(text, "mvn.x ")
    teko::assert::str_contains(text, "mov.w ")
}

/**
 * iat_float_kitchen_sink — a two-float-const function exercising every
 * `LBinOp` float case plus `FNeg`/`IToF`/`FToI`/`FToF` (the coverage sweep
 * for the float side of `select_bin`/`select_un`).
 *
 * @return lir::LFunc  the built function
 */
fn iat_float_kitchen_sink() -> lir::LFunc {
    mut f = iat_two_i64_params("teko__demo__float_kitchen_sink")
    let a = iat_const_float(f, 4607182418800017408 to u64)
    f = a.func
    let b = iat_const_float(f, 4611686018427387904 to u64)
    f = b.func
    f = iat_bin(f, lir::LBinOp::FAdd, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FSub, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FMul, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FDiv, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FCmpEq, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FCmpNe, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FCmpLt, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FCmpLe, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FCmpGt, a.vreg, b.vreg).func
    f = iat_bin(f, lir::LBinOp::FCmpGe, a.vreg, b.vreg).func
    f = iat_un(f, lir::LUnOp::FNeg, a.vreg).func
    f = iat_un(f, lir::LUnOp::IToF, 0).func
    f = iat_un(f, lir::LUnOp::FToI, a.vreg).func
    let last = iat_un(f, lir::LUnOp::FToF, a.vreg)
    f = last.func
    iat_ret(f, last.vreg)
}

#test
fn iat_float_kitchen_sink_covers_every_float_op() {
    let mf = match select_lfunc(iat_float_kitchen_sink()) { MFunc as x => x; error => return }
    let text = minst_print(add_mfunc(empty_mmodule(), mf))
    teko::assert::str_contains(text, "fadd.d ")
    teko::assert::str_contains(text, "fsub.d ")
    teko::assert::str_contains(text, "fmul.d ")
    teko::assert::str_contains(text, "fdiv.d ")
    teko::assert::str_contains(text, "fcmp.d ")
    teko::assert::str_contains(text, "fneg.d ")
    teko::assert::str_contains(text, "scvtf ")
    teko::assert::str_contains(text, "fcvtzs ")
    teko::assert::str_contains(text, "fcvt ")
}

#test
fn iat_void_ret_selects_bare_ret() {
    let f = lir::append_inst(iat_main_ret(), 0, lir::ret_void_inst(0, 0))
    let mf = match select_lfunc(f) { MFunc as x => x; error => return }
    let text = minst_print(add_mfunc(empty_mmodule(), mf))
    teko::assert::str_contains(text, "ret")
}

/**
 * iat_one_param_func — a single-parameter function of machine class `ty`
 * (its own return type too, so a scalar `ret` is well-formed), its param
 * already read via `LParam` and returned directly — the coverage sweep for
 * `mregclass_of_ltype`/`ltype_is_wide`'s full per-`LType` dispatch (every
 * case but `I128`, which errors — tested separately).
 *
 * @param lir::LType ty  the parameter's (and return's) machine class
 * @return lir::LFunc  the built function
 */
fn iat_one_param_func(ty: lir::LType) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::empty(), ty)
    mut f = lir::new_func("teko__demo__one_param", 1, ptypes, ty)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    iat_ret(f, 0)
}

/**
 * iat_select_succeeds — whether `select_lfunc(f)` selects without error.
 *
 * @param lir::LFunc f  the function to select
 * @return bool  whether selection succeeded
 */
fn iat_select_succeeds(f: lir::LFunc) -> bool {
    match select_lfunc(f) { MFunc => true; error => false }
}

#test
fn iat_select_param_covers_every_scalar_machine_class() {
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::I8)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::I16)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::I32)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::I64)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::Ptr)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::Void)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::F16)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::F32)))
    teko::assert::is_true(iat_select_succeeds(iat_one_param_func(lir::LType::F64)))
    teko::assert::is_true(!iat_select_succeeds(iat_one_param_func(lir::LType::I128)))
}

/**
 * iat_mregclass_and_wide_cover_i128_directly — `mregclass_of_ltype`/
 * `ltype_is_wide`'s own `I128` arms are otherwise UNREACHABLE through
 * `select_param` (its `ltype_is_i128` guard already honest-stops before
 * either helper is consulted for the CURRENTLY-selected parameter) — a
 * direct unit call proves the two total, declared mappings anyway.
 */
#test
fn iat_mregclass_and_wide_cover_i128_directly() {
    teko::assert::is_true(mregclass_of_ltype(lir::LType::I128) == MRegClass::GPR)
    teko::assert::is_true(ltype_is_wide(lir::LType::I128) == true)
}

/**
 * iat_mixed_gpr_fpr_params — a 3-param function `(F64, I64, F64)`: proves
 * the AAPCS64 classifier counts EACH register file independently
 * (`gpr_index_before`/`fpr_index_before`, §3.5) — param 1 (I64) walks ONE
 * earlier FPR entry (the classifier's GPR-count "no match" branch); param
 * 2 (F64) walks a MIXED earlier pair, one FPR match and one GPR non-match
 * (both branches of the FPR-count loop in a single call).
 *
 * @return lir::LFunc  the built function
 */
fn iat_mixed_gpr_fpr_params() -> lir::LFunc {
    let t1 = teko::list::push(teko::list::empty(), lir::LType::F64)
    let t2 = teko::list::push(t1, lir::LType::I64)
    let ptypes = teko::list::push(t2, lir::LType::F64)
    mut f = lir::new_func("teko__demo__mixed_params", 3, ptypes, lir::LType::I64)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(2, 2, 0, 0))
    iat_ret(f, 1)
}

#test
fn iat_mixed_gpr_fpr_params_assigns_independent_class_slots() {
    let mf = match select_lfunc(iat_mixed_gpr_fpr_params()) { MFunc as x => x; error => return }
    let text = minst_print(add_mfunc(empty_mmodule(), mf))
    teko::assert::str_contains(text, "fmov.d %0, %p0")
    teko::assert::str_contains(text, "mov.x %1, %p0")
    teko::assert::str_contains(text, "fmov.d %2, %p1")
}

/**
 * iat_dump — select `f` and render the machine module as text (the A2-3
 * golden-dump fixtures assert against key lines of this).
 *
 * @param lir::LFunc f  the function to select and print
 * @return str  the rendered machine text ("" on a selection error)
 */
fn iat_dump(f: lir::LFunc) -> str {
    let mf = match select_lfunc(f) { MFunc as x => x; error => return "" }
    minst_print(add_mfunc(empty_mmodule(), mf))
}

#test
fn iat_a24_global_addr_is_adrp_add_data_reloc() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let v = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(v.func, 0, lir::global_addr_inst(v.vreg, ".Lstr0", 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(v.vreg, 0, 0))
    let text = iat_dump(s1)
    teko::assert::str_contains(text, "adrp.page_hi %0, @.Lstr0")
    teko::assert::str_contains(text, "add_lo.page_lo %0, %0, @.Lstr0")
}

#test
fn iat_a25_call_indirect_is_blr_through_target() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let t = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(t.func, 0, lir::alloca_inst(t.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::void_call_indirect_inst(t.vreg, teko::list::empty(), false, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(t.vreg, 0, 0))
    teko::assert::str_contains(iat_dump(s2), "call.indirect %0()")
}

#test
fn iat_a24_func_addr_is_adrp_add_text_reloc() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let v = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(v.func, 0, lir::func_addr_inst(v.vreg, "teko__demo__f", 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(v.vreg, 0, 0))
    let text = iat_dump(s1)
    teko::assert::str_contains(text, "adrp.call %0, @teko__demo__f")
    teko::assert::str_contains(text, "add_lo.call %0, %0, @teko__demo__f")
}

#test
fn iat_a25_call_with_result_moves_x0_out() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let r = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(r.func, 0, lir::call_inst(r.vreg, "teko__demo__f", teko::list::empty(), false, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(r.vreg, 0, 0))
    let text = iat_dump(s1)
    teko::assert::str_contains(text, "call @teko__demo__f() -> %p0")
    teko::assert::str_contains(text, "mov.x %0, %p0")
}
