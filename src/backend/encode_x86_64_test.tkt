use teko::lir

/**
 * ex_p — a physical GPR operand with the given ISA id (a golden-vector fixture
 * shorthand; B1 runs post-regalloc, so every operand is physical). The x86
 * instruction-encoding numbering: RAX=0,RCX=1,RDX=2,RBX=3,RSP=4,RBP=5,RSI=6,
 * RDI=7,R8..R15=8..15.
 *
 * @param u32 id  the x86 ISA register number
 * @return MReg  the physical GPR operand
 */
fn ex_p(id: u32) -> MReg {
    preg(id, MRegClass::GPR)
}

/**
 * ex_fpr — a physical FPR (XMM) operand with the given ISA id, the fixture
 * shorthand for the SSE `B1-fp` honest-stop paths.
 *
 * @param u32 id  the XMM register number
 * @return MReg  the physical FPR operand
 */
fn ex_fpr(id: u32) -> MReg {
    preg(id, MRegClass::FPR)
}

/**
 * ex_mem — a base-plus-displacement memory operand (the load/store fixture
 * shorthand).
 *
 * @param MReg base  the base register
 * @param i32 off  the byte displacement
 * @return MMem  the memory operand
 */
fn ex_mem(base: MReg, off: i32) -> MMem {
    MMem { base = base; offset = off }
}

/**
 * ex_layout — a `FrameLayoutX86` fixture whose two frame slots sit at RSP+16 and
 * RSP+24, letting the `MFrameAddrX86` golden pin the resolved `lea dst,
 * [rsp+off]` (with its forced SIB byte) without routing through the B1-6
 * `compute_frame_layout_x86`.
 *
 * @return FrameLayoutX86  the two-slot fixture frame
 */
fn ex_layout() -> FrameLayoutX86 {
    let slots = teko::list::push(teko::list::push(teko::list::empty(), 16 to u32), 24 to u32)
    FrameLayoutX86 { size = 32 to u32; saved_gpr = teko::list::empty(); saved_fpr = teko::list::empty(); slot_offsets = slots }
}

/**
 * ex_bad — the sentinel `EncInstX86` returned when a golden fixture that must
 * encode unexpectedly honest-stops: its single `0xFF` byte never matches a real
 * expected encoding, so a hex assertion fails loudly rather than aborting.
 *
 * @return EncInstX86  the impossible-encoding sentinel
 */
fn ex_bad() -> EncInstX86 {
    EncInstX86 {
        bytes = teko::list::push(teko::list::empty(), 0xFF to byte)
        has_branch = false
        branch_field_off = 0 to u32
        target = 0 to u32
        has_reloc = false
        reloc_field_off = 0 to u32
        reloc_sym = "<error>"
        reloc_kind = RelocKindX86::Plt32
    }
}

/**
 * ex_enc — encode `inst` under the fixture `ex_layout`, unwrapping the success
 * case and falling back to the `ex_bad` sentinel on an unexpected honest-stop.
 *
 * @param MInstX86 inst  the instruction to encode
 * @return EncInstX86  the encoded instruction, or the sentinel on error
 */
fn ex_enc(inst: MInstX86) -> EncInstX86 {
    match encode_inst_x86(ex_layout(), inst) {
        EncInstX86 as x => x
        error as e => ex_bad()
    }
}

/**
 * ex_hex — the lowercase hex string of `inst`'s encoded bytes (two hex digits
 * per byte, in emission order), the readable golden-vector representation.
 *
 * @param MInstX86 inst  the instruction to encode
 * @return str  the encoded bytes as a hex string
 */
fn ex_hex(inst: MInstX86) -> str {
    teko::crypto::to_hex(ex_enc(inst).bytes)
}

/**
 * ex_stop — the honest-stop message `inst` produces, or `<ok>` when it encodes
 * successfully. Lets an honest-stop test assert the named stop is raised.
 *
 * @param MInstX86 inst  the instruction to encode
 * @return str  the error message, or `<ok>` when it encodes
 */
fn ex_stop(inst: MInstX86) -> str {
    match encode_inst_x86(ex_layout(), inst) {
        EncInstX86 as x => "<ok>"
        error as e => e.message
    }
}

/**
 * ex_assert_hex — assert that `inst` encodes to the exact byte string `hex`
 * (the assembler-cross-checked golden-vector check).
 *
 * @param MInstX86 inst  the instruction to encode
 * @param str hex  the known-good x86-64 encoding as a hex string
 * @return void
 */
fn ex_assert_hex(inst: MInstX86, hex: str) {
    teko::assert::is_true(ex_hex(inst) == hex)
}

/**
 * ex_assert_stop — assert that `inst` honest-stops with a message containing the
 * named token.
 *
 * @param MInstX86 inst  the instruction to encode
 * @param str name  the named-stop token expected in the message
 * @return void
 */
fn ex_assert_stop(inst: MInstX86, name: str) {
    teko::assert::str_contains(ex_stop(inst), name)
}

/**
 * ex_assert_reloc_is_plt32 — assert a relocation kind is `Plt32` (the
 * `RelocKindX86` cannot ride `==`, so it is matched to a name).
 *
 * @param RelocKindX86 kind  the relocation kind to check
 * @return void
 */
fn ex_assert_reloc_is_plt32(kind: RelocKindX86) {
    let name = match kind { Plt32 => "plt32"; Pc32 => "pc32"; Abs64 => "abs64" }
    teko::assert::is_true(name == "plt32")
}

/**
 * ex_assert_reloc_is_pc32 — assert a relocation kind is `Pc32`.
 *
 * @param RelocKindX86 kind  the relocation kind to check
 * @return void
 */
fn ex_assert_reloc_is_pc32(kind: RelocKindX86) {
    let name = match kind { Plt32 => "plt32"; Pc32 => "pc32"; Abs64 => "abs64" }
    teko::assert::is_true(name == "pc32")
}

#test
/**
 * ex_encodes_the_immediate_move_forms — `mov r32, imm32`, the sign-extended
 * `mov r64, imm32`, `movabs r64, imm64`, and the REX.B high-register variants.
 *
 * @return void
 */
fn ex_encodes_the_immediate_move_forms() {
    ex_assert_hex(movimm_x86(ex_p(0), 42 to i64, false), "b82a000000")
    ex_assert_hex(movimm_x86(ex_p(0), 42 to i64, true), "48c7c02a000000")
    ex_assert_hex(movimm_x86(ex_p(3), 0x1122334455667788 to i64, true), "48bb8877665544332211")
    ex_assert_hex(movimm_x86(ex_p(8), 5 to i64, false), "41b805000000")
    ex_assert_hex(movimm_x86(ex_p(8), 5 to i64, true), "49c7c005000000")
}

#test
/**
 * ex_encodes_a_negative_immediate_two_s_complement — a negative `imm32` /
 * `imm64` narrows via masking, never a panicking signed cast (the VM
 * byte-width rule for negative-to-unsigned).
 *
 * @return void
 */
fn ex_encodes_a_negative_immediate_two_s_complement() {
    ex_assert_hex(movimm_x86(ex_p(0), (0 to i64) - (1 to i64), true), "48c7c0ffffffff")
    ex_assert_hex(movimm_x86(ex_p(0), (0 to i64) - (4294967297 to i64), true), "48b8fffffffffeffffff")
}

#test
/**
 * ex_encodes_the_register_move — a GPR-GPR `mov` across widths and high
 * registers (the reg-into-rm `89 /r` direction).
 *
 * @return void
 */
fn ex_encodes_the_register_move() {
    ex_assert_hex(mov_x86(ex_p(0), ex_p(3), true), "4889d8")
    ex_assert_hex(mov_x86(ex_p(1), ex_p(2), false), "89d1")
    ex_assert_hex(mov_x86(ex_p(8), ex_p(9), true), "4d89c8")
}

#test
/**
 * ex_encodes_every_two_address_alu_op — ADD/SUB/AND/OR/XOR `r/m64, r64` over
 * `dst=rax, src=rbx`, plus the 32-bit ADD form, covering `alu_opcode_x86`.
 *
 * @return void
 */
fn ex_encodes_every_two_address_alu_op() {
    ex_assert_hex(alu_rm_x86(MAluOpX86::Add, ex_p(0), ex_p(3), true), "4801d8")
    ex_assert_hex(alu_rm_x86(MAluOpX86::Sub, ex_p(0), ex_p(3), true), "4829d8")
    ex_assert_hex(alu_rm_x86(MAluOpX86::And, ex_p(0), ex_p(3), true), "4821d8")
    ex_assert_hex(alu_rm_x86(MAluOpX86::Or, ex_p(0), ex_p(3), true), "4809d8")
    ex_assert_hex(alu_rm_x86(MAluOpX86::Xor, ex_p(0), ex_p(3), true), "4831d8")
    ex_assert_hex(alu_rm_x86(MAluOpX86::Add, ex_p(0), ex_p(3), false), "01d8")
}

#test
/**
 * ex_encodes_the_two_address_add_pair — the `r = a + b` lowering: a `mov dst, a`
 * copy followed by the read-modify-write `add dst, b` (§4.2), each a valid
 * standalone x86 encoding.
 *
 * @return void
 */
fn ex_encodes_the_two_address_add_pair() {
    ex_assert_hex(mov_x86(ex_p(0), ex_p(6), true), "4889f0")
    ex_assert_hex(alu_rm_x86(MAluOpX86::Add, ex_p(0), ex_p(7), true), "4801f8")
}

#test
/**
 * ex_encodes_the_two_operand_multiply — `imul r64, r/m64` (`0F AF`, dst in the
 * reg field) across widths and a high register.
 *
 * @return void
 */
fn ex_encodes_the_two_operand_multiply() {
    ex_assert_hex(imul_x86(ex_p(0), ex_p(3), true), "480fafc3")
    ex_assert_hex(imul_x86(ex_p(0), ex_p(3), false), "0fafc3")
    ex_assert_hex(imul_x86(ex_p(8), ex_p(9), true), "4d0fafc1")
}

#test
/**
 * ex_encodes_the_signed_division_sequence — `mov rax, a ; cqo ; idiv b ;
 * mov dst, rax` (64-bit) and its 32-bit `cdq`/`idiv r32` form.
 *
 * @return void
 */
fn ex_encodes_the_signed_division_sequence() {
    ex_assert_hex(divseq_x86(ex_p(1), ex_p(3), ex_p(3), true, false, true), "4889d8489948f7fb4889c1")
    ex_assert_hex(divseq_x86(ex_p(0), ex_p(0), ex_p(3), true, false, false), "89c099f7fb89c0")
}

#test
/**
 * ex_encodes_the_unsigned_remainder_sequence — `mov rax, a ; xor edx, edx ;
 * div b ; mov dst, rdx`, the unsigned remainder path (result read from RDX).
 *
 * @return void
 */
fn ex_encodes_the_unsigned_remainder_sequence() {
    ex_assert_hex(divseq_x86(ex_p(6), ex_p(0), ex_p(1), false, true, true), "4889c031d248f7f14889d6")
}

#test
/**
 * ex_encodes_every_shift_by_cl — SHL/SHR/SAR `r/m64, cl` (`D3 /4, /5, /7`) plus
 * the 32-bit form, covering `shift_ext_x86`.
 *
 * @return void
 */
fn ex_encodes_every_shift_by_cl() {
    ex_assert_hex(shift_x86(MShiftOpX86::Shl, ex_p(0), true), "48d3e0")
    ex_assert_hex(shift_x86(MShiftOpX86::Shr, ex_p(0), true), "48d3e8")
    ex_assert_hex(shift_x86(MShiftOpX86::Sar, ex_p(0), true), "48d3f8")
    ex_assert_hex(shift_x86(MShiftOpX86::Shl, ex_p(0), false), "d3e0")
}

#test
/**
 * ex_encodes_the_compare — `cmp r/m64, r64` (`39 /r`, `a - b`) across widths.
 *
 * @return void
 */
fn ex_encodes_the_compare() {
    ex_assert_hex(cmp_x86(ex_p(0), ex_p(3), true), "4839d8")
    ex_assert_hex(cmp_x86(ex_p(0), ex_p(3), false), "39d8")
}

#test
/**
 * ex_encodes_setcc_with_zero_extend — `setcc dst8 ; movzx dst32, dst8` for a
 * low register (AL, no REX), a byte-addressable-only register (SIL, forced
 * `0x40`), and a high register (R8B, REX extension).
 *
 * @return void
 */
fn ex_encodes_setcc_with_zero_extend() {
    ex_assert_hex(setcc_x86(ex_p(0), MCond::LT), "0f9cc00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(6), MCond::EQ), "400f94c6400fb6f6")
    ex_assert_hex(setcc_x86(ex_p(8), MCond::GT), "410f9fc0450fb6c0")
}

#test
/**
 * ex_encodes_every_condition_code — each `MCond` maps to its `setcc` opcode
 * (`0F 90+cc`): E/NE, the signed L/LE/G/GE, and the unsigned B/BE/A/AE lanes.
 *
 * @return void
 */
fn ex_encodes_every_condition_code() {
    ex_assert_hex(setcc_x86(ex_p(0), MCond::EQ), "0f94c00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::NE), "0f95c00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::LT), "0f9cc00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::LE), "0f9ec00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::GT), "0f9fc00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::GE), "0f9dc00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::LO), "0f92c00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::LS), "0f96c00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::HI), "0f97c00fb6c0")
    ex_assert_hex(setcc_x86(ex_p(0), MCond::HS), "0f93c00fb6c0")
}

#test
/**
 * ex_encodes_the_unary_ops — `neg r/m64` (`F7 /3`) and `not r/m64` (`F7 /2`),
 * plus the 32-bit `neg` form.
 *
 * @return void
 */
fn ex_encodes_the_unary_ops() {
    ex_assert_hex(neg_x86(ex_p(0), true), "48f7d8")
    ex_assert_hex(not_x86(ex_p(0), true), "48f7d0")
    ex_assert_hex(neg_x86(ex_p(0), false), "f7d8")
}

#test
/**
 * ex_encodes_every_load_addressing_form — the SIB-forcing RSP base, a zero
 * displacement, disp8/disp32 (positive and negative), a plain base, the
 * disp-forcing RBP base, and the REX.B R12/R13 bases.
 *
 * @return void
 */
fn ex_encodes_every_load_addressing_form() {
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "488b442408")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(4), 0 to i32)), "488b0424")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(4), 512 to i32)), "488b842400020000")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(4), (0 to i32) - (8 to i32))), "488b4424f8")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(3), 0 to i32)), "488b03")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(5), 0 to i32)), "488b4500")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(12), 0 to i32)), "498b0424")
    ex_assert_hex(load_x86(MMemSizeX86::Q, false, ex_p(0), ex_mem(ex_p(13), 0 to i32)), "498b4500")
}

#test
/**
 * ex_encodes_every_load_width_and_sign — Q/D/W/B loads in their zero-extending
 * size ladder (byte `movzx 0F B6`, word `movzx 0F B7`, dword `mov 8B`, qword
 * `REX.W 8B`) and their sign-extending `movsxd`(D) / `movsx`(W/B) forms,
 * covering `load_memop_x86` — the isel's `sign=false` zero-extend contract.
 *
 * @return void
 */
fn ex_encodes_every_load_width_and_sign() {
    ex_assert_hex(load_x86(MMemSizeX86::D, false, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "8b442408")
    ex_assert_hex(load_x86(MMemSizeX86::D, true, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "4863442408")
    ex_assert_hex(load_x86(MMemSizeX86::W, false, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "0fb7442408")
    ex_assert_hex(load_x86(MMemSizeX86::W, true, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "480fbf442408")
    ex_assert_hex(load_x86(MMemSizeX86::B, false, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "0fb6442408")
    ex_assert_hex(load_x86(MMemSizeX86::B, true, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "480fbe442408")
}

#test
/**
 * ex_zero_extending_byte_load_needs_no_byte_register_rex — a `movzx` byte load
 * reads the byte from MEMORY into a 32-bit register, so (unlike a byte STORE)
 * it never touches an 8-bit register and forces no bare `0x40` REX: `movzx esi,
 * byte [rbx]` is `0F B6 33` with no REX, while a high destination sets REX.R
 * (`movzx r9d, byte [rbx]` = `44 0F B6 0B`).
 *
 * @return void
 */
fn ex_zero_extending_byte_load_needs_no_byte_register_rex() {
    ex_assert_hex(load_x86(MMemSizeX86::B, false, ex_p(6), ex_mem(ex_p(3), 0 to i32)), "0fb633")
    ex_assert_hex(load_x86(MMemSizeX86::B, false, ex_p(9), ex_mem(ex_p(3), 0 to i32)), "440fb60b")
}

#test
/**
 * ex_encodes_every_store_width — Q/D/W (the `0x66`-prefixed word) and the byte
 * store (a low `al` source, then a forced-REX `sil` source), covering
 * `store_memop_x86` and the byte-register REX trap.
 *
 * @return void
 */
fn ex_encodes_every_store_width() {
    ex_assert_hex(store_x86(MMemSizeX86::Q, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "4889442408")
    ex_assert_hex(store_x86(MMemSizeX86::D, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "89442408")
    ex_assert_hex(store_x86(MMemSizeX86::W, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "6689442408")
    ex_assert_hex(store_x86(MMemSizeX86::B, ex_p(0), ex_mem(ex_p(4), 8 to i32)), "88442408")
    ex_assert_hex(store_x86(MMemSizeX86::B, ex_p(6), ex_mem(ex_p(4), 8 to i32)), "4088742408")
}

#test
/**
 * ex_encodes_the_frame_slot_lea — `MFrameAddrX86` resolves through the fixture
 * `FrameLayoutX86` to `lea dst, [rsp+off]` with the forced SIB byte `0x24` (the
 * RSP-base trap): slot 0 at RSP+16, slot 1 at RSP+24.
 *
 * @return void
 */
fn ex_encodes_the_frame_slot_lea() {
    ex_assert_hex(frame_addr_x86(ex_p(0), 0 to u32), "488d442410")
    ex_assert_hex(frame_addr_x86(ex_p(0), 1 to u32), "488d442418")
}

#test
/**
 * ex_encodes_indirect_calls_and_return — `call r/m64` (`FF /2`) across a low
 * and a high register, and the bare `ret`.
 *
 * @return void
 */
fn ex_encodes_indirect_calls_and_return() {
    ex_assert_hex(call_ind_x86(ex_p(0), teko::list::empty(), ex_p(0), false), "ffd0")
    ex_assert_hex(call_ind_x86(ex_p(11), teko::list::empty(), ex_p(0), false), "41ffd3")
    ex_assert_hex(ret_x86(), "c3")
}

#test
/**
 * ex_encodes_the_unconditional_branch — `jmp rel32` (`E9`) is a zeroed
 * placeholder flagged for the B1-6 patch pass with its rel32 field offset and
 * target block id.
 *
 * @return void
 */
fn ex_encodes_the_unconditional_branch() {
    let enc = ex_enc(jmp_x86(3 to u32))
    teko::assert::is_true(teko::crypto::to_hex(enc.bytes) == "e900000000")
    teko::assert::is_true(enc.has_branch)
    teko::assert::is_true(enc.branch_field_off == (1 to u32))
    teko::assert::is_true(enc.target == (3 to u32))
    teko::assert::is_false(enc.has_reloc)
}

#test
/**
 * ex_encodes_the_conditional_branch — `jcc rel32` (`0F 80+cc`) is a zeroed
 * placeholder flagged for patching, with a rel32 offset of 2; the condition
 * byte rides `cond_cc_x86`.
 *
 * @return void
 */
fn ex_encodes_the_conditional_branch() {
    let enc = ex_enc(jcc_x86(MCond::EQ, 5 to u32))
    teko::assert::is_true(teko::crypto::to_hex(enc.bytes) == "0f8400000000")
    teko::assert::is_true(enc.has_branch)
    teko::assert::is_true(enc.branch_field_off == (2 to u32))
    teko::assert::is_true(enc.target == (5 to u32))
    ex_assert_hex(jcc_x86(MCond::LT, 5 to u32), "0f8c00000000")
}

#test
/**
 * ex_encodes_the_direct_call_reloc — `call rel32` (`E8`) is a zeroed
 * placeholder carrying a `Plt32` relocation on the callee symbol at rel32
 * offset 1.
 *
 * @return void
 */
fn ex_encodes_the_direct_call_reloc() {
    let enc = ex_enc(call_x86("tk_exit", teko::list::empty(), ex_p(0), false, false))
    teko::assert::is_true(teko::crypto::to_hex(enc.bytes) == "e800000000")
    teko::assert::is_true(enc.has_reloc)
    teko::assert::is_true(enc.reloc_field_off == (1 to u32))
    teko::assert::is_true(enc.reloc_sym == "tk_exit")
    ex_assert_reloc_is_plt32(enc.reloc_kind)
    teko::assert::is_false(enc.has_branch)
}

#test
/**
 * ex_encodes_the_rip_relative_lea_reloc — `lea dst, [rip+disp32]` (`REX.W 8D`,
 * `mod=00 rm=101`) is a zeroed-disp placeholder carrying the instruction's
 * relocation kind at disp32 offset 3; a high register sets REX.R.
 *
 * @return void
 */
fn ex_encodes_the_rip_relative_lea_reloc() {
    let enc = ex_enc(lea_rip_x86(ex_p(0), "g", RelocKindX86::Pc32))
    teko::assert::is_true(teko::crypto::to_hex(enc.bytes) == "488d0500000000")
    teko::assert::is_true(enc.has_reloc)
    teko::assert::is_true(enc.reloc_field_off == (3 to u32))
    teko::assert::is_true(enc.reloc_sym == "g")
    ex_assert_reloc_is_pc32(enc.reloc_kind)
    ex_assert_hex(lea_rip_x86(ex_p(10), "g", RelocKindX86::Pc32), "4c8d1500000000")
}

#test
/**
 * ex_fpr_load_store_raise_the_b1_fp_stop — an `MLoadX86`/`MStoreX86` whose
 * register operand is FPR-class is an SSE memory move deferred to 0.3.1, so the
 * B1-5 core raises the named `B1-fp` honest-stop.
 *
 * @return void
 */
fn ex_fpr_load_store_raise_the_b1_fp_stop() {
    ex_assert_stop(load_x86(MMemSizeX86::Q, false, ex_fpr(0), ex_mem(ex_p(4), 0 to i32)), "B1-fp")
    ex_assert_stop(store_x86(MMemSizeX86::Q, ex_fpr(0), ex_mem(ex_p(4), 0 to i32)), "B1-fp")
}

#test
/**
 * ex_rex_prefix_packs_every_bit — `rex_x86` packs W/R/X/B into the `0x40` base:
 * the all-clear prefix, each bit alone, and the all-set prefix. The REX.X
 * (SIB-index, bit `0x2`) path is unreachable through any B1-5 instruction (every
 * memory operand is base-plus-displacement — the `B1-memindex` deferral), so it
 * is pinned directly here so the helper stays fully exercised and forward-ready.
 *
 * @return void
 */
fn ex_rex_prefix_packs_every_bit() {
    teko::assert::is_true(rex_x86(false, false, false, false) == (0x40 to u32))
    teko::assert::is_true(rex_x86(true, false, false, false) == (0x48 to u32))
    teko::assert::is_true(rex_x86(false, true, false, false) == (0x44 to u32))
    teko::assert::is_true(rex_x86(false, false, true, false) == (0x42 to u32))
    teko::assert::is_true(rex_x86(false, false, false, true) == (0x41 to u32))
    teko::assert::is_true(rex_x86(true, true, true, true) == (0x4F to u32))
}

/**
 * fx_u1 — a one-element `[]u32` (the callee-saved / slot-offset fixture builder).
 *
 * @param u32 a  the sole element
 * @return []u32  the singleton list
 */
fn fx_u1(a: u32) -> []u32 {
    teko::list::push(teko::list::empty(), a)
}

/**
 * fx_u2 — a two-element `[]u32`.
 *
 * @param u32 a  the first element
 * @param u32 b  the second element
 * @return []u32  the two-element list
 */
fn fx_u2(a: u32, b: u32) -> []u32 {
    teko::list::push(fx_u1(a), b)
}

/**
 * fx_u3 — a three-element `[]u32`.
 *
 * @param u32 a  the first element
 * @param u32 b  the second element
 * @param u32 c  the third element
 * @return []u32  the three-element list
 */
fn fx_u3(a: u32, b: u32, c: u32) -> []u32 {
    teko::list::push(fx_u2(a, b), c)
}

/**
 * fx_none_u32 — the empty `[]u32` (the no-callee-saved / no-slots fixture).
 *
 * @return []u32  the empty list
 */
fn fx_none_u32() -> []u32 {
    teko::list::empty()
}

/**
 * fx_frame — a `FrameLayoutX86` built directly from a `sub rsp` size, a
 * callee-saved GPR list, and the RSP-relative slot offsets (SysV has no
 * callee-saved FPRs, so `saved_fpr` is always empty). Pins the prologue/epilogue
 * byte goldens without routing through `compute_frame_layout_x86`.
 *
 * @param u32 size  the `sub rsp` amount
 * @param []u32 saved  the callee-saved GPR ids to push (ascending)
 * @param []u32 slots  the RSP-relative slot offsets
 * @return FrameLayoutX86  the fixture frame
 */
fn fx_frame(size: u32, saved: []u32, slots: []u32) -> FrameLayoutX86 {
    FrameLayoutX86 { size = size; saved_gpr = saved; saved_fpr = teko::list::empty(); slot_offsets = slots }
}

/**
 * fx_prologue_hex — the hex of `layout`'s emitted prologue bytes, or `<err>` on
 * an unexpected honest-stop (the prologue golden reader).
 *
 * @param FrameLayoutX86 layout  the frame to emit the prologue for
 * @return str  the prologue bytes as hex, or `<err>`
 */
fn fx_prologue_hex(layout: FrameLayoutX86) -> str {
    match emit_prologue_x86(layout) {
        []byte as b => teko::crypto::to_hex(b)
        error as e => "<err>"
    }
}

/**
 * fx_prologue_stop — the honest-stop message `layout`'s prologue raises, or
 * `<ok>` when it emits (the bigframe-stop reader).
 *
 * @param FrameLayoutX86 layout  the frame to emit the prologue for
 * @return str  the error message, or `<ok>`
 */
fn fx_prologue_stop(layout: FrameLayoutX86) -> str {
    match emit_prologue_x86(layout) {
        []byte as b => "<ok>"
        error as e => e.message
    }
}

/**
 * fx_epilogue_hex — the hex of `layout`'s emitted epilogue bytes (never
 * honest-stops: `leave` handles every frame size).
 *
 * @param FrameLayoutX86 layout  the frame to emit the epilogue for
 * @return str  the epilogue bytes as hex
 */
fn fx_epilogue_hex(layout: FrameLayoutX86) -> str {
    teko::crypto::to_hex(emit_epilogue_x86(layout))
}

#test
/**
 * ex_frameless_prologue_and_epilogue_are_empty — a frameless function (no slots,
 * no callee-saved) emits no prologue and no epilogue bytes.
 *
 * @return void
 */
fn ex_frameless_prologue_and_epilogue_are_empty() {
    let fl = fx_frame(0 to u32, fx_none_u32(), fx_none_u32())
    teko::assert::is_true(fx_prologue_hex(fl) == "")
    teko::assert::is_true(fx_epilogue_hex(fl) == "")
}

#test
/**
 * ex_slots_only_frame_prologue_epilogue — a slot-region frame with no
 * callee-saved registers: `push rbp ; mov rbp,rsp ; sub rsp,16` and the `leave`
 * epilogue (the doc §11.1 spill-fixture golden).
 *
 * @return void
 */
fn ex_slots_only_frame_prologue_epilogue() {
    let fl = fx_frame(16 to u32, fx_none_u32(), fx_u1(0 to u32))
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54883ec10")
    teko::assert::is_true(fx_epilogue_hex(fl) == "c9")
}

#test
/**
 * ex_one_callee_saved_frame — one callee-saved GPR (RBX) with an 8-byte
 * realignment sub: `push rbp ; mov rbp,rsp ; sub rsp,8 ; push rbx`, and the LIFO
 * `pop rbx ; leave` epilogue.
 *
 * @return void
 */
fn ex_one_callee_saved_frame() {
    let fl = fx_frame(8 to u32, fx_u1(3 to u32), fx_none_u32())
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54883ec0853")
    teko::assert::is_true(fx_epilogue_hex(fl) == "5bc9")
}

#test
/**
 * ex_multi_callee_saved_frame — three callee-saved GPRs (RBX, R12, R13, the
 * latter two REX.B-prefixed) with an 8-byte sub: pushed ascending, popped in
 * reverse before `leave`.
 *
 * @return void
 */
fn ex_multi_callee_saved_frame() {
    let fl = fx_frame(8 to u32, fx_u3(3 to u32, 12 to u32, 13 to u32), fx_none_u32())
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54883ec085341544155")
    teko::assert::is_true(fx_epilogue_hex(fl) == "415d415c5bc9")
}

#test
/**
 * ex_even_callee_saved_needs_no_sub — an EVEN callee-saved count (RBX, R12) with
 * no slots keeps RSP aligned via the pushes alone, so the `sub rsp` is elided:
 * `push rbp ; mov rbp,rsp ; push rbx ; push r12`, and `pop r12 ; pop rbx ;
 * leave`. Still a framed function despite the zero sub.
 *
 * @return void
 */
fn ex_even_callee_saved_needs_no_sub() {
    let fl = fx_frame(0 to u32, fx_u2(3 to u32, 12 to u32), fx_none_u32())
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e5534154")
    teko::assert::is_true(fx_epilogue_hex(fl) == "415c5bc9")
}

#test
/**
 * ex_large_frame_uses_imm32_sub — a frame past the imm8 field takes the wide
 * `sub rsp, imm32` form (`48 81 EC id`, little-endian 512), still torn down by a
 * bare `leave`.
 *
 * @return void
 */
fn ex_large_frame_uses_imm32_sub() {
    let fl = fx_frame(512 to u32, fx_none_u32(), fx_u1(0 to u32))
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54881ec00020000")
    teko::assert::is_true(fx_epilogue_hex(fl) == "c9")
}

#test
/**
 * ex_oversized_frame_honest_stops — a frame beyond the signed imm32 `sub rsp`
 * field (2^31 bytes) raises the named `B1-bigframe` honest-stop (near-N/A, pinned
 * by a directly-constructed layout).
 *
 * @return void
 */
fn ex_oversized_frame_honest_stops() {
    let fl = fx_frame(2147483648 to u32, fx_none_u32(), fx_none_u32())
    teko::assert::str_contains(fx_prologue_stop(fl), "B1-bigframe")
}

/**
 * fx_i1 — a one-element `[]MInstX86` (the machine-block stream builder).
 *
 * @param MInstX86 a  the sole instruction
 * @return []MInstX86  the singleton stream
 */
fn fx_i1(a: MInstX86) -> []MInstX86 {
    teko::list::push(teko::list::empty(), a)
}

/**
 * fx_i2 — a two-element `[]MInstX86`.
 *
 * @param MInstX86 a  the first instruction
 * @param MInstX86 b  the second instruction
 * @return []MInstX86  the two-instruction stream
 */
fn fx_i2(a: MInstX86, b: MInstX86) -> []MInstX86 {
    teko::list::push(fx_i1(a), b)
}

/**
 * fx_i3 — a three-element `[]MInstX86`.
 *
 * @param MInstX86 a  the first instruction
 * @param MInstX86 b  the second instruction
 * @param MInstX86 c  the third instruction
 * @return []MInstX86  the three-instruction stream
 */
fn fx_i3(a: MInstX86, b: MInstX86, c: MInstX86) -> []MInstX86 {
    teko::list::push(fx_i2(a, b), c)
}

/**
 * fx_block — a machine block with the given id and instruction stream (empty
 * params — the tests exercise flat straight-line and branch CFGs).
 *
 * @param u32 id  the block id
 * @param []MInstX86 insts  the block's instructions
 * @return MBlockX86  the built block
 */
fn fx_block(id: u32, insts: []MInstX86) -> MBlockX86 {
    MBlockX86 { id = id; params = teko::list::empty(); insts = insts }
}

/**
 * fx_no_frame — the empty `[]lir::LAlloca` (a function with no frame slots).
 *
 * @return []lir::LAlloca  the empty frame table
 */
fn fx_no_frame() -> []lir::LAlloca {
    teko::list::empty()
}

/**
 * fx_alloca_frame — a one-slot `[]lir::LAlloca` frame table.
 *
 * @param u32 bytes  the slot's byte size
 * @param u32 align  the slot's alignment
 * @return []lir::LAlloca  the single-slot frame table
 */
fn fx_alloca_frame(bytes: u32, align: u32) -> []lir::LAlloca {
    teko::list::push(teko::list::empty(), lir::LAlloca { bytes = bytes; align = align })
}

/**
 * fx_1block_func — a single-block `MFuncX86` with the given symbol, stream, and
 * frame table.
 *
 * @param str sym  the function symbol
 * @param []MInstX86 insts  the block's instructions
 * @param []lir::LAlloca frame  the frame-slot table
 * @return MFuncX86  the built function
 */
fn fx_1block_func(sym: str, insts: []MInstX86, frame: []lir::LAlloca) -> MFuncX86 {
    MFuncX86 { symbol = sym; blocks = teko::list::push(teko::list::empty(), fx_block(0 to u32, insts)); frame = frame }
}

/**
 * fx_layout_of — `compute_frame_layout_x86` under `SYSV64` for a function
 * built from a frame table and a single-block stream (the frame-computation
 * logic-test shorthand).
 *
 * @param []lir::LAlloca frame  the frame-slot table
 * @param []MInstX86 insts  the block's instructions (scanned for callee-saved)
 * @return FrameLayoutX86  the resolved frame layout
 */
fn fx_layout_of(frame: []lir::LAlloca, insts: []MInstX86) -> FrameLayoutX86 {
    compute_frame_layout_x86(SYSV64, fx_1block_func("main", insts, frame))
}

#test
/**
 * ex_frameless_layout_from_scan — a leaf (a caller-saved move then `ret`, no
 * slots) resolves to a frameless layout: `size=0`, no callee-saved, no slots.
 *
 * @return void
 */
fn ex_frameless_layout_from_scan() {
    let fl = fx_layout_of(fx_no_frame(), fx_i2(mov_x86(ex_p(0), ex_p(1), true), ret_x86()))
    teko::assert::is_true(fl.size == (0 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
    teko::assert::is_true(fl.saved_fpr.len == 0)
    teko::assert::is_true(fl.slot_offsets.len == 0)
}

#test
/**
 * ex_slots_only_layout — a single 8-byte alloca (no callee-saved) lays the slot
 * at RSP+0 and sizes the sub to the 16-rounded slot region.
 *
 * @return void
 */
fn ex_slots_only_layout() {
    let fl = fx_layout_of(fx_alloca_frame(8 to u32, 8 to u32), fx_i1(ret_x86()))
    teko::assert::is_true(fl.size == (16 to u32))
    teko::assert::is_true(fl.slot_offsets.len == 1)
    teko::assert::is_true(fl.slot_offsets[0] == (0 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
}

#test
/**
 * ex_callee_saved_only_layout — a move DEFINING the callee-saved RBX (no slots)
 * re-derives `saved_gpr=[3]` and an 8-byte realignment sub.
 *
 * @return void
 */
fn ex_callee_saved_only_layout() {
    let fl = fx_layout_of(fx_no_frame(), fx_i2(mov_x86(ex_p(3), ex_p(0), true), ret_x86()))
    teko::assert::is_true(fl.saved_gpr.len == 1)
    teko::assert::is_true(fl.saved_gpr[0] == (3 to u32))
    teko::assert::is_true(fl.size == (8 to u32))
    teko::assert::is_true(fl.slot_offsets.len == 0)
}

#test
/**
 * ex_callee_saved_and_slots_layout — one callee-saved GPR plus an 8-byte slot:
 * the slot offset shifts up by the 8-byte push region (RSP+8), and the sub is
 * sized (24) so `push rbp` + `push rbx` + `sub rsp,24` keeps RSP 16-aligned.
 *
 * @return void
 */
fn ex_callee_saved_and_slots_layout() {
    let fl = fx_layout_of(fx_alloca_frame(8 to u32, 8 to u32), fx_i2(mov_x86(ex_p(3), ex_p(0), true), ret_x86()))
    teko::assert::is_true(fl.saved_gpr.len == 1)
    teko::assert::is_true(fl.saved_gpr[0] == (3 to u32))
    teko::assert::is_true(fl.slot_offsets[0] == (8 to u32))
    teko::assert::is_true(fl.size == (24 to u32))
}

#test
/**
 * ex_multi_callee_saved_ordered_layout — moves defining R13, RBX, R12 out of
 * order re-derive the ascending, duplicate-free `saved_gpr=[3,12,13]` (the
 * front-insert / mid-insert paths of the ordered save-set insert).
 *
 * @return void
 */
fn ex_multi_callee_saved_ordered_layout() {
    let insts = fx_i3(mov_x86(ex_p(13), ex_p(0), true), mov_x86(ex_p(3), ex_p(1), true), mov_x86(ex_p(12), ex_p(2), true))
    let fl = fx_layout_of(fx_no_frame(), insts)
    teko::assert::is_true(fl.saved_gpr.len == 3)
    teko::assert::is_true(fl.saved_gpr[0] == (3 to u32))
    teko::assert::is_true(fl.saved_gpr[1] == (12 to u32))
    teko::assert::is_true(fl.saved_gpr[2] == (13 to u32))
}

#test
/**
 * ex_even_callee_saved_zero_sub_layout — two callee-saved GPRs and no slots size
 * the sub to 0 (the pushes alone realign), yet the layout stays framed
 * (`saved_gpr=[3,12]`).
 *
 * @return void
 */
fn ex_even_callee_saved_zero_sub_layout() {
    let insts = fx_i2(mov_x86(ex_p(3), ex_p(0), true), mov_x86(ex_p(12), ex_p(1), true))
    let fl = fx_layout_of(fx_no_frame(), insts)
    teko::assert::is_true(fl.saved_gpr.len == 2)
    teko::assert::is_true(fl.size == (0 to u32))
}

/**
 * fx_exit_call — a direct `call tk_exit` machine instruction (no result, no
 * pinned arg uses), the Win64/SysV keystone-exit fixture used to exercise the
 * shadow-space frame delta and the `func_makes_call_x86` gate.
 *
 * @return MInstX86  the direct-call instruction
 */
fn fx_exit_call() -> MInstX86 {
    call_x86("tk_exit", teko::list::empty(), ex_p(0), false, false)
}

/**
 * fx_win_layout_of — `compute_frame_layout_x86` under `WIN64` for a function
 * built from a frame table and a single-block stream (the Win64 frame-delta
 * logic-test shorthand — the sibling of `fx_layout_of`, which uses `SYSV64`).
 *
 * @param []lir::LAlloca frame  the frame-slot table
 * @param []MInstX86 insts  the block's instructions (scanned for calls + callee-saved)
 * @return FrameLayoutX86  the resolved Win64 frame layout
 */
fn fx_win_layout_of(frame: []lir::LAlloca, insts: []MInstX86) -> FrameLayoutX86 {
    compute_frame_layout_x86(WIN64, fx_1block_func("main", insts, frame))
}

#test
/**
 * ex_win64_call_frame_reserves_shadow — a Win64 `main` making a `call tk_exit`
 * (no slots, no callee-saved) is FRAMED: the 32-byte shadow space folds into the
 * `sub rsp` region (`size==32`), so the prologue is `push rbp` + `mov rbp,rsp` +
 * `sub rsp,0x20`. The Win64-vs-SysV frame difference the shadow field introduces
 * (§4.2/§4.3).
 *
 * @return void
 */
fn ex_win64_call_frame_reserves_shadow() {
    let fl = fx_win_layout_of(fx_no_frame(), fx_i1(fx_exit_call()))
    teko::assert::is_true(fl.size == (32 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
    teko::assert::is_true(fl.saved_fpr.len == 0)
    teko::assert::is_true(fl.slot_offsets.len == 0)
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54883ec20")
}

#test
/**
 * ex_sysv_call_frame_byte_identical — THE GUARDRAIL: the SAME calling `main`
 * under `SYSV64` (`shadow_space == 0`) reserves NO shadow space and stays
 * frameless (`size==0`, empty prologue) — byte-identical to the pre-shadow-field
 * SysV frame (the `ex_func_frameless_call_reloc` `e800000000` shape). A 0 shadow
 * space adds zero bytes and shifts no offset (§2.2/§3.1 FIXPOINT guardrail).
 *
 * @return void
 */
fn ex_sysv_call_frame_byte_identical() {
    let fl = fx_layout_of(fx_no_frame(), fx_i1(fx_exit_call()))
    teko::assert::is_true(fl.size == (0 to u32))
    teko::assert::is_true(fl.slot_offsets.len == 0)
    teko::assert::is_true(fx_prologue_hex(fl) == "")
}

#test
/**
 * ex_sysv_framed_prologue_byte_identical — THE GUARDRAIL (framed case): a `sysv64`
 * function with one callee-saved GPR (RBX) plus an 8-byte slot routes through
 * `compute_frame_layout_x86` and emits the UNCHANGED prologue `push rbp` +
 * `mov rbp,rsp` + `sub rsp,0x18` (=24) + `push rbx`, with the slot shifted up only
 * by the 8-byte push region (RSP+8) — no shadow bytes, proving the field addition
 * is behavior-preserving for a real framed SysV function.
 *
 * @return void
 */
fn ex_sysv_framed_prologue_byte_identical() {
    let insts = fx_i2(mov_x86(ex_p(3), ex_p(0), true), ret_x86())
    let fl = fx_layout_of(fx_alloca_frame(8 to u32, 8 to u32), insts)
    teko::assert::is_true(fl.size == (24 to u32))
    teko::assert::is_true(fl.slot_offsets[0] == (8 to u32))
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54883ec1853")
}

#test
/**
 * ex_win64_leaf_no_shadow — a Win64 LEAF (a caller-saved move then `ret`, no call,
 * no slots) reserves NO shadow space and stays frameless (`size==0`), proving the
 * `func_makes_call_x86` gate: a leaf function owes the callee no shadow region
 * (§4.2).
 *
 * @return void
 */
fn ex_win64_leaf_no_shadow() {
    let fl = fx_win_layout_of(fx_no_frame(), fx_i2(mov_x86(ex_p(0), ex_p(1), true), ret_x86()))
    teko::assert::is_true(fl.size == (0 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
    teko::assert::is_true(fl.slot_offsets.len == 0)
    teko::assert::is_true(fx_prologue_hex(fl) == "")
}

#test
/**
 * ex_win64_slot_shifted_above_shadow — a Win64 function with an 8-byte slot AND a
 * call: the slot region (16, the 16-rounded one-slot size) plus the 32-byte
 * shadow region size the `sub rsp` to 48, and the slot offset shifts UP by the
 * shadow bytes to RSP+32 (the slot lives ABOVE the [rsp+0..32] shadow region,
 * §4.2).
 *
 * @return void
 */
fn ex_win64_slot_shifted_above_shadow() {
    let insts = fx_i2(frame_addr_x86(ex_p(0), 0 to u32), fx_exit_call())
    let fl = fx_win_layout_of(fx_alloca_frame(8 to u32, 8 to u32), insts)
    teko::assert::is_true(fl.size == (48 to u32))
    teko::assert::is_true(fl.slot_offsets.len == 1)
    teko::assert::is_true(fl.slot_offsets[0] == (32 to u32))
    teko::assert::is_true(fx_prologue_hex(fl) == "554889e54883ec30")
}

#test
/**
 * ex_func_makes_call_x86_detects_direct — `func_makes_call_x86` is true for a
 * function containing a direct `call` (the `MCallX86` shadow-space trigger).
 *
 * @return void
 */
fn ex_func_makes_call_x86_detects_direct() {
    let f = fx_1block_func("main", fx_i1(fx_exit_call()), fx_no_frame())
    teko::assert::is_true(func_makes_call_x86(f))
}

#test
/**
 * ex_func_makes_call_x86_detects_indirect — `func_makes_call_x86` is true for a
 * function containing an indirect `call r/m64` (the `MCallIndX86` arm of the
 * per-instruction call predicate).
 *
 * @return void
 */
fn ex_func_makes_call_x86_detects_indirect() {
    let ind = call_ind_x86(ex_p(0), teko::list::empty(), ex_p(0), false)
    let f = fx_1block_func("main", fx_i1(ind), fx_no_frame())
    teko::assert::is_true(func_makes_call_x86(f))
}

#test
/**
 * ex_func_makes_call_x86_leaf_false — `func_makes_call_x86` is false for a leaf
 * function whose only instructions are a move and a `ret` (no call), so a Win64
 * leaf reserves no shadow space.
 *
 * @return void
 */
fn ex_func_makes_call_x86_leaf_false() {
    let f = fx_1block_func("main", fx_i2(mov_x86(ex_p(0), ex_p(1), true), ret_x86()), fx_no_frame())
    teko::assert::is_true(!func_makes_call_x86(f))
}

#test
/**
 * ex_win64_callee_saved_xmm_honest_stops — a frame carrying a callee-saved XMM in
 * `saved_fpr` (Win64 preserves XMM6-15) raises the named `B3-xmm-callee-saved`
 * honest-stop at prologue emission rather than mis-emitting a GPR `push` for an
 * XMM (the `movaps` spill path is unimplemented; the integer corpus allocates no
 * XMM, §2.2/§7).
 *
 * @return void
 */
fn ex_win64_callee_saved_xmm_honest_stops() {
    let fl = FrameLayoutX86 { size = 16 to u32; saved_gpr = fx_none_u32(); saved_fpr = fx_u1(6 to u32); slot_offsets = fx_none_u32() }
    teko::assert::str_contains(fx_prologue_stop(fl), "B3-xmm-callee-saved")
}

/**
 * fx_func_hex — the hex of `f`'s `encode_func_x86` byte image under `SYSV64`,
 * or `<err>` on an unexpected honest-stop.
 *
 * @param MFuncX86 f  the function to encode
 * @return str  the encoded bytes as hex, or `<err>`
 */
fn fx_func_hex(f: MFuncX86) -> str {
    match encode_func_x86(SYSV64, f) {
        EncodedFuncX86 as ef => teko::crypto::to_hex(ef.bytes)
        error as e => "<err>"
    }
}

/**
 * fx_func_stop — the honest-stop message `f`'s `encode_func_x86` raises, or
 * `<ok>` when it encodes.
 *
 * @param MFuncX86 f  the function to encode
 * @return str  the error message, or `<ok>`
 */
fn fx_func_stop(f: MFuncX86) -> str {
    match encode_func_x86(SYSV64, f) {
        EncodedFuncX86 as ef => "<ok>"
        error as e => e.message
    }
}

/**
 * fx_encode_func — `encode_func_x86` under `SYSV64`, unwrapped to a sentinel
 * empty function on an unexpected honest-stop so a reloc assertion fails loudly
 * rather than aborting.
 *
 * @param MFuncX86 f  the function to encode
 * @return EncodedFuncX86  the encoded function, or the sentinel
 */
fn fx_encode_func(f: MFuncX86) -> EncodedFuncX86 {
    match encode_func_x86(SYSV64, f) {
        EncodedFuncX86 as ef => ef
        error as e => EncodedFuncX86 { symbol = "<error>"; bytes = teko::list::empty(); relocs = teko::list::empty() }
    }
}

/**
 * fx_reloc_kind_name — a `RelocKindX86`'s lowercase name (the kind cannot ride
 * `==`, so it is matched to a name for assertions).
 *
 * @param RelocKindX86 kind  the relocation kind
 * @return str  its lowercase name
 */
fn fx_reloc_kind_name(kind: RelocKindX86) -> str {
    match kind { Plt32 => "plt32"; Pc32 => "pc32"; Abs64 => "abs64" }
}

#test
/**
 * ex_func_frameless_call_reloc — a frameless `main` making a single `call
 * tk_exit` (a call, no return) encodes to `E8 00 00 00 00` with one `Plt32`
 * relocation at rel32 offset 1, addend −4 (the keystone exit path's own-native
 * shape).
 *
 * @return void
 */
fn ex_func_frameless_call_reloc() {
    let f = fx_1block_func("main", fx_i1(call_x86("tk_exit", teko::list::empty(), ex_p(0), false, false)), fx_no_frame())
    let ef = fx_encode_func(f)
    teko::assert::is_true(teko::crypto::to_hex(ef.bytes) == "e800000000")
    teko::assert::is_true(ef.relocs.len == 1)
    teko::assert::is_true(ef.relocs[0].offset == (1 to u32))
    teko::assert::is_true(ef.relocs[0].sym == "tk_exit")
    teko::assert::is_true(fx_reloc_kind_name(ef.relocs[0].kind) == "plt32")
    teko::assert::is_true(ef.relocs[0].addend == ((0 to i64) - (4 to i64)))
}

#test
/**
 * ex_func_forward_and_backward_branches — a three-block CFG (`cmp ; jcc M2 ; jmp
 * M1` / `xor ; jmp M0` / `ret`) resolves a FORWARD `jcc` displacement (+12), a
 * zero `jmp` displacement, and a BACKWARD `jmp` displacement (−21, the
 * two's-complement sign case `EB FF FF FF`), each rel32 patched from the recorded
 * block byte offsets.
 *
 * @return void
 */
fn ex_func_forward_and_backward_branches() {
    let b0 = fx_block(0 to u32, fx_i3(cmp_x86(ex_p(0), ex_p(1), true), jcc_x86(MCond::EQ, 2 to u32), jmp_x86(1 to u32)))
    let b1 = fx_block(1 to u32, fx_i2(alu_rm_x86(MAluOpX86::Xor, ex_p(0), ex_p(0), false), jmp_x86(0 to u32)))
    let b2 = fx_block(2 to u32, fx_i1(ret_x86()))
    let blocks = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), b0), b1), b2)
    let f = MFuncX86 { symbol = "g"; blocks = blocks; frame = teko::list::empty() }
    teko::assert::is_true(fx_func_hex(f) == "4839c80f840c000000e90000000031c0e9ebffffffc3")
}

#test
/**
 * ex_func_framed_branch_shifts_block_offsets — a framed function (one slot) puts
 * its prologue ahead of block 0, so the `jmp` displacement is measured from the
 * post-prologue block offsets; the `MFrameAddrX86` resolves to `lea rax,[rsp+0]`
 * (SIB `0x24`) and `MRetX86` expands to `leave ; ret`.
 *
 * @return void
 */
fn ex_func_framed_branch_shifts_block_offsets() {
    let b0 = fx_block(0 to u32, fx_i2(frame_addr_x86(ex_p(0), 0 to u32), jmp_x86(1 to u32)))
    let b1 = fx_block(1 to u32, fx_i1(ret_x86()))
    let blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b1)
    let f = MFuncX86 { symbol = "g"; blocks = blocks; frame = fx_alloca_frame(8 to u32, 8 to u32) }
    teko::assert::is_true(fx_func_hex(f) == "554889e54883ec10488d0424e900000000c9c3")
}

#test
/**
 * ex_func_rip_lea_reloc — a `lea rax,[rip+gv]` then `ret` encodes to the
 * zeroed-disp `lea` (`48 8D 05 00000000`) plus the bare `ret`, carrying one
 * `Pc32` relocation at disp32 offset 3, addend −4.
 *
 * @return void
 */
fn ex_func_rip_lea_reloc() {
    let f = fx_1block_func("main", fx_i2(lea_rip_x86(ex_p(0), "gv", RelocKindX86::Pc32), ret_x86()), fx_no_frame())
    let ef = fx_encode_func(f)
    teko::assert::is_true(teko::crypto::to_hex(ef.bytes) == "488d0500000000c3")
    teko::assert::is_true(ef.relocs.len == 1)
    teko::assert::is_true(ef.relocs[0].offset == (3 to u32))
    teko::assert::is_true(ef.relocs[0].sym == "gv")
    teko::assert::is_true(fx_reloc_kind_name(ef.relocs[0].kind) == "pc32")
    teko::assert::is_true(ef.relocs[0].addend == ((0 to i64) - (4 to i64)))
}

#test
/**
 * ex_func_branch_to_missing_block_honest_stops — a `jmp` to a block id absent
 * from the function raises the `B1-badblock` internal-invariant honest-stop
 * during the patch pass.
 *
 * @return void
 */
fn ex_func_branch_to_missing_block_honest_stops() {
    let f = fx_1block_func("g", fx_i1(jmp_x86(99 to u32)), fx_no_frame())
    teko::assert::str_contains(fx_func_stop(f), "B1-badblock")
}

#test
/**
 * ex_func_propagates_encode_honest_stop — a function whose body reaches the
 * `B1-fp` encoder stop (an FPR load) propagates that named stop out of
 * `encode_func_x86` unchanged.
 *
 * @return void
 */
fn ex_func_propagates_encode_honest_stop() {
    let ld = load_x86(MMemSizeX86::Q, false, ex_fpr(0), ex_mem(ex_p(4), 0 to i32))
    let f = fx_1block_func("g", fx_i1(ld), fx_no_frame())
    teko::assert::str_contains(fx_func_stop(f), "B1-fp")
}

#test
/**
 * ex_func_bigframe_propagates — a function whose alloca forces a frame past the
 * imm32 `sub rsp` field propagates the `B1-bigframe` stop from `emit_prologue_x86`
 * out of `encode_func_x86`.
 *
 * @return void
 */
fn ex_func_bigframe_propagates() {
    let f = fx_1block_func("g", fx_i1(ret_x86()), fx_alloca_frame(2147483648 to u32, 8 to u32))
    teko::assert::str_contains(fx_func_stop(f), "B1-bigframe")
}

/**
 * fx_patch_stop — the honest-stop message `patch_branches_x86` raises for a
 * crafted fixup/offset pair, or `<ok>` when it patches (the direct rel32-range
 * probe).
 *
 * @param []byte raw  the byte image to patch
 * @param []BranchFixupX86 fixups  the pending fixups
 * @param []BlockOffsetX86 offsets  the block byte offsets
 * @return str  the error message, or `<ok>`
 */
fn fx_patch_stop(raw: []byte, fixups: []BranchFixupX86, offsets: []BlockOffsetX86) -> str {
    match patch_branches_x86(raw, fixups, offsets) {
        []byte as b => "<ok>"
        error as e => e.message
    }
}

#test
/**
 * ex_patch_far_displacement_honest_stops — a crafted branch whose target byte
 * offset lands the rel32 displacement just past the signed 32-bit boundary
 * (2^31) raises the `B1-farbranch` internal-invariant stop, the boundary case a
 * real (tiny) function never reaches.
 *
 * @return void
 */
fn ex_patch_far_displacement_honest_stops() {
    let raw = teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), 0 to byte), 0 to byte), 0 to byte), 0 to byte)
    let fixups = teko::list::push(teko::list::empty(), BranchFixupX86 { field_off = 0 to u32; target = 0 to u32 })
    let offsets = teko::list::push(teko::list::empty(), BlockOffsetX86 { id = 0 to u32; byte = 2147483652 to u32 })
    teko::assert::str_contains(fx_patch_stop(raw, fixups, offsets), "B1-farbranch")
}

#test
/**
 * ex_reloc_addend_convention — the pinned `r_addend` per kind: `Plt32`/`Pc32`
 * carry −4 (the rel32-is-from-field-end correction the assembler oracle
 * confirmed) and `Abs64` carries 0 (the deferred `B1-globals` data case,
 * exercised directly since no B1-6 instruction emits it).
 *
 * @return void
 */
fn ex_reloc_addend_convention() {
    teko::assert::is_true(reloc_addend_x86(RelocKindX86::Plt32) == ((0 to i64) - (4 to i64)))
    teko::assert::is_true(reloc_addend_x86(RelocKindX86::Pc32) == ((0 to i64) - (4 to i64)))
    teko::assert::is_true(reloc_addend_x86(RelocKindX86::Abs64) == (0 to i64))
}

/**
 * fx_module_of1 — a single-function `MModuleX86` (empty rodata/globals/layouts).
 *
 * @param MFuncX86 f  the function
 * @return MModuleX86  the wrapping module
 */
fn fx_module_of1(f: MFuncX86) -> MModuleX86 {
    MModuleX86 { funcs = teko::list::push(teko::list::empty(), f); rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
}

/**
 * fx_module_of2 — a two-function `MModuleX86` in declaration order (empty
 * rodata/globals/layouts).
 *
 * @param MFuncX86 a  the first function
 * @param MFuncX86 b  the second function
 * @return MModuleX86  the wrapping module
 */
fn fx_module_of2(a: MFuncX86, b: MFuncX86) -> MModuleX86 {
    MModuleX86 { funcs = teko::list::push(teko::list::push(teko::list::empty(), a), b); rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
}

/**
 * fx_encode_module — `encode_module_x86` under `SYSV64`, unwrapped to a
 * sentinel empty module on an unexpected honest-stop.
 *
 * @param MModuleX86 m  the module to encode
 * @return EncodedModuleX86  the encoded module, or the sentinel
 */
fn fx_encode_module(m: MModuleX86) -> EncodedModuleX86 {
    match encode_module_x86(SYSV64, m) {
        EncodedModuleX86 as e => e
        error as er => EncodedModuleX86 { text = teko::list::empty(); rodata = teko::list::empty(); symbols = teko::list::empty(); relocs = teko::list::empty() }
    }
}

/**
 * fx_module_stop — the honest-stop message `m`'s `encode_module_x86` raises, or
 * `<ok>` when it encodes.
 *
 * @param MModuleX86 m  the module to encode
 * @return str  the error message, or `<ok>`
 */
fn fx_module_stop(m: MModuleX86) -> str {
    match encode_module_x86(SYSV64, m) {
        EncodedModuleX86 as e => "<ok>"
        error as er => er.message
    }
}

#test
/**
 * ex_module_single_func_call — a one-function module (`main` calling `tk_exit`)
 * assembles the `.text` image, a global defined `main` symbol at offset 0, an
 * undefined `tk_exit`, and one module-rebased `Plt32` relocation at offset 1.
 *
 * @return void
 */
fn ex_module_single_func_call() {
    let f = fx_1block_func("main", fx_i1(call_x86("tk_exit", teko::list::empty(), ex_p(0), false, false)), fx_no_frame())
    let e = fx_encode_module(fx_module_of1(f))
    teko::assert::is_true(teko::crypto::to_hex(e.text) == "e800000000")
    teko::assert::is_true(e.symbols.len == 2)
    teko::assert::is_true(e.symbols[0].name == "main")
    teko::assert::is_true(e.symbols[0].defined)
    teko::assert::is_false(e.symbols[0].local)
    teko::assert::is_true(e.symbols[0].sect == (1 to u8))
    teko::assert::is_true(e.symbols[0].offset == (0 to u32))
    teko::assert::is_true(e.symbols[1].name == "tk_exit")
    teko::assert::is_false(e.symbols[1].defined)
    teko::assert::is_true(e.relocs.len == 1)
    teko::assert::is_true(e.relocs[0].offset == (1 to u32))
    teko::assert::is_true(e.relocs[0].sym == "tk_exit")
}

#test
/**
 * ex_module_cumulative_reloc_rebase — a second function's `.text` base shifts
 * its symbol offset AND its relocation offset: `f1` (a 4-byte frameless
 * `mov ; ret`), `f2` (a 5-byte `call tk_exit`) lands `f2` at offset 4 and its
 * `Plt32` reloc at 5 (base 4 + the field offset 1), not just 1.
 *
 * @return void
 */
fn ex_module_cumulative_reloc_rebase() {
    let f1 = fx_1block_func("main", fx_i2(mov_x86(ex_p(0), ex_p(1), true), ret_x86()), fx_no_frame())
    let f2 = fx_1block_func("g", fx_i1(call_x86("tk_exit", teko::list::empty(), ex_p(0), false, false)), fx_no_frame())
    let e = fx_encode_module(fx_module_of2(f1, f2))
    teko::assert::is_true(teko::crypto::to_hex(e.text) == "4889c8c3e800000000")
    teko::assert::is_true(e.symbols[0].offset == (0 to u32))
    teko::assert::is_true(e.symbols[1].name == "g")
    teko::assert::is_true(e.symbols[1].offset == (4 to u32))
    teko::assert::is_true(e.relocs.len == 1)
    teko::assert::is_true(e.relocs[0].offset == (5 to u32))
}

#test
/**
 * ex_module_dedups_undefined — two calls to the SAME external symbol collapse to
 * one undefined entry (both relocations still reference it by name).
 *
 * @return void
 */
fn ex_module_dedups_undefined() {
    let call = call_x86("tk_exit", teko::list::empty(), ex_p(0), false, false)
    let f = fx_1block_func("main", fx_i2(call, call), fx_no_frame())
    let e = fx_encode_module(fx_module_of1(f))
    teko::assert::is_true(e.relocs.len == 2)
    teko::assert::is_true(e.symbols.len == 2)
    teko::assert::is_true(e.symbols[1].name == "tk_exit")
    teko::assert::is_false(e.symbols[1].defined)
}

#test
/**
 * ex_module_intra_call_stays_defined — a call to another in-module function
 * references a DEFINED symbol, so `collect_undefined_x86` skips it (no undefined
 * entry): the two functions are the only symbols and the reloc names the callee.
 *
 * @return void
 */
fn ex_module_intra_call_stays_defined() {
    let f1 = fx_1block_func("f1", fx_i1(ret_x86()), fx_no_frame())
    let f2 = fx_1block_func("f2", fx_i1(call_x86("f1", teko::list::empty(), ex_p(0), false, false)), fx_no_frame())
    let e = fx_encode_module(fx_module_of2(f1, f2))
    teko::assert::is_true(e.symbols.len == 2)
    teko::assert::is_true(e.symbols[0].name == "f1")
    teko::assert::is_true(e.symbols[0].defined)
    teko::assert::is_true(e.symbols[1].name == "f2")
    teko::assert::is_true(e.relocs.len == 1)
    teko::assert::is_true(e.relocs[0].sym == "f1")
}

#test
/**
 * ex_empty_module_encodes_to_empty — a module with no functions/rodata/globals
 * encodes to an empty `.text`/`.rodata`, an empty symbol table, and no
 * relocations (the degenerate base case exercised end to end).
 *
 * @return void
 */
fn ex_empty_module_encodes_to_empty() {
    let m = MModuleX86 { funcs = teko::list::empty(); rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let e = fx_encode_module(m)
    teko::assert::is_true(e.text.len == 0)
    teko::assert::is_true(e.rodata.len == 0)
    teko::assert::is_true(e.symbols.len == 0)
    teko::assert::is_true(e.relocs.len == 0)
}

#test
/**
 * ex_module_interns_rodata — a rodata entry becomes `.rodata` bytes plus a
 * defined, FILE-LOCAL section-2 symbol at its offset, sorted BEFORE the global
 * function symbol (the local-then-global order the symbol table needs).
 *
 * @return void
 */
fn ex_module_interns_rodata() {
    let rbytes = teko::list::push(teko::list::push(teko::list::empty(), 0x41 to byte), 0 to byte)
    let rodata = teko::list::push(teko::list::empty(), lir::LRodata { symbol = "s0"; bytes = rbytes; relocs = teko::list::empty() })
    let f = fx_1block_func("main", fx_i1(ret_x86()), fx_no_frame())
    let m = MModuleX86 { funcs = teko::list::push(teko::list::empty(), f); rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    let e = fx_encode_module(m)
    teko::assert::is_true(e.rodata.len == (2 to u64))
    teko::assert::is_true(e.symbols.len == 2)
    teko::assert::is_true(e.symbols[0].name == "s0")
    teko::assert::is_true(e.symbols[0].local)
    teko::assert::is_true(e.symbols[0].sect == (2 to u8))
    teko::assert::is_true(e.symbols[1].name == "main")
    teko::assert::is_false(e.symbols[1].local)
}

#test
/**
 * ex_module_globals_honest_stops — a module carrying a top-level data global
 * raises the `B1-globals` named honest-stop (the `.data` section is deferred; the
 * N2 subset lowers none).
 *
 * @return void
 */
fn ex_module_globals_honest_stops() {
    let f = fx_1block_func("main", fx_i1(ret_x86()), fx_no_frame())
    let globals = teko::list::push(teko::list::empty(), lir::LGlobal { symbol = "gv"; ty = lir::LType::I32; bytes = teko::list::empty() })
    let m = MModuleX86 { funcs = teko::list::push(teko::list::empty(), f); rodata = teko::list::empty(); globals = globals; layouts = teko::list::empty() }
    teko::assert::str_contains(fx_module_stop(m), "B1-globals")
}

#test
/**
 * ex_module_propagates_function_stop — a function reaching the `B1-fp` encoder
 * stop propagates it out of `encode_module_x86` unchanged.
 *
 * @return void
 */
fn ex_module_propagates_function_stop() {
    let ld = load_x86(MMemSizeX86::Q, false, ex_fpr(0), ex_mem(ex_p(4), 0 to i32))
    let f = fx_1block_func("main", fx_i1(ld), fx_no_frame())
    teko::assert::str_contains(fx_module_stop(fx_module_of1(f)), "B1-fp")
}

/**
 * T-B5 (inverte a fixture T-B1): o encoder x86 agora PRODUZ a relocation
 * `Abs64`/`Rodata` re-baseada para um ponteiro rodata-interno (gate consumidor
 * aberto; o produtor `serialize_const` segue sendo o único gate até T-B6).
 */
#test
fn tb1_x86_data_reloc_now_produces() {
    let rod = teko::list::push(teko::list::empty(), lir::LRodata { symbol = "k"; bytes = teko::list::push(teko::list::empty(), 0 to byte); relocs = teko::list::push(teko::list::empty(), lir::data_reloc(0 to u32, "k")) })
    let f = fx_1block_func("main", fx_i1(ret_x86()), fx_no_frame())
    let m = MModuleX86 { funcs = teko::list::push(teko::list::empty(), f); rodata = rod; globals = teko::list::empty(); layouts = teko::list::empty() }
    match encode_module_x86(SYSV64, m) {
        EncodedModuleX86 as em => {
            mut found = false
            mut i: u64 = 0
            loop {
                if i >= em.relocs.len { break }
                if em.relocs[i].sect == RelocSect::Rodata { found = true; teko::assert::is_true(em.relocs[i].sym == "k") }
                i++
            }
            teko::assert::is_true(found)
        }
        error => teko::assert::is_true(false)
    }
}
