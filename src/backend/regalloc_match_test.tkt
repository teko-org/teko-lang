use teko::checker
use teko::lexer
use teko::parser
use teko::lir

/**
 * rmt_prim — a resolved primitive Type for a PrimKind (the arithmetic operand
 * type the match arms and result carry).
 *
 * @param checker::PrimKind k  the primitive kind
 * @return checker::Type  the resolved `Prim` type
 */
fn rmt_prim(k: checker::PrimKind) -> checker::Type { checker::Prim { kind = k } }

/**
 * rmt_num — an i64-typed integer-literal `TExpr` (a match subject or arm body).
 *
 * @param i128 v  the literal's integer value
 * @return checker::TExpr  the typed number node
 */
fn rmt_num(v: i128) -> checker::TExpr {
    checker::TExpr { kind = checker::TNumber { is_float = false; value = v; fval = 0.0 }; type = rmt_prim(checker::PrimKind::I64); line = 0; col = 0 }
}

/**
 * rmt_int_pattern — an integer-literal pattern `v` (a refutable arm test).
 *
 * @param i128 v  the literal's integer value
 * @return parser::Pattern  the literal pattern node
 */
fn rmt_int_pattern(v: i128) -> parser::Pattern {
    parser::LiteralPattern { value = parser::Expr { kind = parser::Number { is_float = false; value = v; fval = 0.0 }; line = 0; col = 0 } }
}

/**
 * rmt_wild_pattern — a bare `_` wildcard pattern: the IRREFUTABLE final arm
 * whose unconditional match leaves the defensive fallback block dead (the A4-6
 * crux, #385).
 *
 * @return parser::Pattern  the wildcard pattern node
 */
fn rmt_wild_pattern() -> parser::Pattern { parser::WildcardPattern { } }

/**
 * rmt_arm — an UNGUARDED match arm over `pat` whose body is the single value
 * `val` (an expression-statement tail feeding the merge block).
 *
 * @param parser::Pattern pat  the arm's pattern
 * @param i128 val  the arm's tail value
 * @return checker::TArm  the typed arm node
 */
fn rmt_arm(pat: parser::Pattern, val: i128) -> checker::TArm {
    let body = teko::list::push(teko::list::empty(), checker::TExprStmt { expr = rmt_num(val) })
    checker::TArm { pattern = pat; has_when = false; guard = rmt_num(0 to i128); body = body }
}

/**
 * rmt_match_module — the selected module for `fn pick(): i64 { return match 5 {
 * 1 => 40, 2 => 41, _ => 42 } }`, driven through the REAL pipeline (checker
 * TAST → `lir::lower_function` → `select_module` isel). Its irrefutable final
 * arm leaves the defensive fallback block UNREACHABLE — the exact shape that
 * false-tripped the regalloc back-edge honest-stop before A4-6 (#385). The
 * subject is a CONSTANT so `minst_interp` needs no entry-parameter binding.
 *
 * @return MModule | error  the selected module, or a propagated lower/isel error
 */
fn rmt_match_module() -> MModule | error {
    let subject = rmt_num(5 to i128)
    let arm0 = rmt_arm(rmt_int_pattern(1 to i128), 40 to i128)
    let arm1 = rmt_arm(rmt_int_pattern(2 to i128), 41 to i128)
    let arm2 = rmt_arm(rmt_wild_pattern(), 42 to i128)
    let arms = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), arm0), arm1), arm2)
    let match_expr = checker::TExpr { kind = checker::TMatchExpr { subject = subject; arms = arms }; type = rmt_prim(checker::PrimKind::I64); line = 0; col = 0 }
    let no_params: []parser::Param = teko::list::empty()
    let body = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = match_expr })
    let f = checker::TFunction {
        name = "pick"; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        namespace = "teko::demo"; params = no_params; return_type = rmt_prim(checker::PrimKind::I64); body = body
        vis = parser::Visibility::Private; has_doc = false; doc = ""
        file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""
    }
    let lf = match lir::lower_function(f) { lir::LoweredFunction as r => r.func; error as e => return e }
    select_module(lir::add_func(lir::empty_module(), lf))
}

/**
 * rmt_noargs — the empty argument list for `minst_interp` (the match fixture
 * takes no parameters — its subject is a constant).
 *
 * @return []i128  the empty argument list
 */
fn rmt_noargs() -> []i128 { teko::list::empty() }

/**
 * rmt_dead_block — the id of the single block of `f` NOT reachable from entry
 * (the match's defensive fallback), or `f`'s entry id when every block is
 * reachable (the defensive default, never taken by the match fixture).
 *
 * @param MFunc f  the selected function
 * @param []u32 reachable  the entry-reachable block ids
 * @return u32  the unreachable block id, or the entry id if none
 */
fn rmt_dead_block(f: MFunc, reachable: []u32) -> u32 {
    mut i: u64 = 0
    loop {
        if i >= f.blocks.len { break }
        let bid = f.blocks[i].id
        if !u32_in(reachable, bid) { return bid }
        i++
    }
    f.blocks[0].id
}

/**
 * rmt_has_raw_retreat — the PRE-A4-6 back-edge predicate: a retreating edge by
 * RPO position ALONE, ignoring source reachability. On the match CFG it is
 * true — the dead fallback's forward jump to the merge, the false-positive
 * A4-6 removes — so this documents the bug `natural_loops`'s reachability
 * filter now suppresses (#385).
 *
 * @param []NumberedInst stream  the RPO-numbered stream
 * @param []u32 order  the RPO block-id order
 * @return bool  true iff any terminator retreats in RPO, dead sources included
 */
fn rmt_has_raw_retreat(stream: []NumberedInst, order: []u32) -> bool {
    mut i: u64 = 0
    loop {
        if i >= stream.len { break }
        let ni = stream[i]
        let t = terminator_target(ni.inst)
        if t.has {
            if block_pos(order, t.target) <= block_pos(order, ni.block_id) { return true }
        }
        i++
    }
    false
}

/**
 * rmt_match_wildcard_fallback_is_reachability_excluded — the forensic root-cause
 * assert (#385, A4-6): the real match isel output has 8 blocks, one of which
 * (the defensive fallback past the irrefutable `_` arm) is UNREACHABLE. RPO
 * numbers it LAST via `append_unvisited`, so its forward jump to the merge
 * RETREATS by position (`pos(merge) <= pos(fallback)`) — the raw retreat the
 * pre-A4-6 predicate tripped on. `natural_loops` now excludes that dead source,
 * so the acyclic DAG correctly reports NO natural loop.
 */
#test
fn rmt_match_wildcard_fallback_is_reachability_excluded() {
    let mm = match rmt_match_module() { MModule as x => x; error => return }
    let f = mm.funcs[0]
    teko::assert::is_true(f.blocks.len == (8 to u64))
    let order = rpo_block_order(f)
    let reachable = reachable_blocks(f)
    teko::assert::is_true(reachable.len == (7 to u64))
    let dead = rmt_dead_block(f, reachable)
    teko::assert::is_true(!u32_in(reachable, dead))
    teko::assert::is_true(block_pos(order, dead) == ((order.len - 1) to u32))
    let succs = block_successors(f, dead)
    teko::assert::is_true(succs.len == (1 to u64))
    let merge = succs[0]
    teko::assert::is_true(block_pos(order, merge) < block_pos(order, dead))
    let stream = number_insts(f, order)
    teko::assert::is_true(rmt_has_raw_retreat(stream, order))
    teko::assert::is_true(natural_loops(stream, order, reachable).len == (0 to u64))
}

/**
 * rmt_regalloc_match_allocates_and_preserves — the end-to-end interp-equivalence
 * assert (#385, A4-6): the match module (which previously KNOWN_STOPped at
 * `regalloc_func` with the loop back-edge error) now allocates — every register
 * is physical afterward — and `minst_interp` yields the same result before and
 * after allocation (42, the wildcard arm for subject 5), proving the fix
 * preserves semantics.
 */
#test
fn rmt_regalloc_match_allocates_and_preserves() {
    let mm = match rmt_match_module() { MModule as x => x; error => return }
    let f = mm.funcs[0]
    let pre = minst_interp(mm, f.symbol, rmt_noargs())
    teko::assert::is_true(pre == (42 to i128))
    let is_err = match regalloc_func(aapcs64(), f) { MFunc => false; error => true }
    teko::assert::is_true(!is_err)
    let colored = match regalloc_module(aapcs64(), mm) { MModule as x => x; error => return }
    teko::assert::is_true(all_physical(colored.funcs[0]))
    teko::assert::is_true(minst_interp(colored, f.symbol, rmt_noargs()) == pre)
}

/**
 * rmt_reachable_blocks_empty_function — `reachable_blocks` returns the empty set
 * for a function with no blocks (the defensive guard shared with
 * `rpo_block_order`), covering the empty-CFG branch of the new helper (#385).
 */
#test
fn rmt_reachable_blocks_empty_function() {
    let empty_f = MFunc { symbol = "main"; blocks = teko::list::empty(); frame = teko::list::empty() }
    teko::assert::is_true(reachable_blocks(empty_f).len == (0 to u64))
}
