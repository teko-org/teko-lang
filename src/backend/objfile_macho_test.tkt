use teko::lir

/**
 * mo_gpr — a physical GPR operand with the given ISA id (the object-writer
 * fixture shorthand; A4 runs post-regalloc, every operand physical).
 *
 * @param u32 id  the ISA register number
 * @return MReg  the physical GPR operand
 */
fn mo_gpr(id: u32) -> MReg {
    preg(id, MRegClass::GPR)
}

/**
 * mo_block — a machine block (no params) with the given id and instructions.
 *
 * @param u32 id  the block id
 * @param []MInst insts  the block's instructions
 * @return MBlock  the assembled block
 */
fn mo_block(id: u32, insts: []MInst) -> MBlock {
    MBlock { id = id; params = teko::list::empty(); insts = insts }
}

/**
 * mo_func — a single-block `MFunc` with an empty frame.
 *
 * @param str sym  the function's symbol
 * @param []MInst insts  the block's instructions
 * @return MFunc  the assembled function
 */
fn mo_func(sym: str, insts: []MInst) -> MFunc {
    MFunc { symbol = sym; blocks = teko::list::push(teko::list::empty(), mo_block(0 to u32, insts)); frame = teko::list::empty() }
}

/**
 * mo_no_uses — the empty `[]MReg` list, typed for the call fixtures.
 *
 * @return []MReg  an empty register list
 */
fn mo_no_uses() -> []MReg {
    teko::list::empty()
}

/**
 * mo_object_of — encode `m` and assemble its Mach-O object, or an empty buffer
 * on an unexpected honest-stop (so a golden length/byte assertion fails loudly).
 *
 * @param MModule m  the module to encode + emit
 * @return []byte  the Mach-O object bytes, or empty on error
 */
fn mo_object_of(m: MModule) -> []byte {
    match encode_module(AAPCS64, m) {
        EncodedModule as x => emit_macho(x)
        error as e => teko::list::empty()
    }
}

/**
 * mo_u32_at — the little-endian u32 read from `bytes` at byte index `i` (the
 * golden-object field reader).
 *
 * @param []byte bytes  the object bytes
 * @param u64 i  the field's byte offset
 * @return u32  the little-endian u32 at `i`
 */
fn mo_u32_at(bytes: []byte, i: u64) -> u32 {
    (bytes[i] to u32) | ((bytes[i + (1 to u64)] to u32) << (8 to u32)) | ((bytes[i + (2 to u64)] to u32) << (16 to u32)) | ((bytes[i + (3 to u64)] to u32) << (24 to u32))
}

/**
 * mo_rodata_module — a frameless `ret`-only `main` plus one rodata entry
 * (`"hi\0"`), for the `__const`-section (nsects=2, no-reloc) golden path.
 *
 * @return MModule  the one-function, one-rodata module
 */
fn mo_rodata_module() -> MModule {
    let bytes = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), 0x68 to byte), 0x69 to byte), 0 to byte)
    let rodata = teko::list::push(teko::list::empty(), lir::LRodata { symbol = "s0"; bytes = bytes; relocs = teko::list::empty() })
    let funcs = teko::list::push(teko::list::empty(), mo_func("main", teko::list::push(teko::list::empty(), RET_INST)))
    MModule { funcs = funcs; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
}

#test
/**
 * rodata_module_emits_const_section — a module with rodata emits a two-section
 * segment: `__text` (4 bytes, no relocations) plus `__const` (3 bytes at file
 * offset 396), the 3 rodata bytes are `hi\0`, the seg-data-to-symtab gap is
 * zero-padded (offset 399 → 400). The symbol table is LOCAL-then-GLOBAL: `s0`
 * (rodata) is `N_SECT` only (0x0E, no `N_EXT`) with `n_value = text_size + 0 =
 * 4` (the F1 fix — an ABSOLUTE address, not a bare section-relative offset);
 * `main` is `N_SECT | N_EXT` (0x0F) with `n_value = 0`. `LC_DYSYMTAB` reports
 * `nlocalsym=1`/`iextdefsym=1`/`nextdefsym=1`/`nundefsym=0`. The string table
 * lists `_s0` before `_main` (locals first). The whole object is 443 bytes.
 *
 * @return void
 */
fn rodata_module_emits_const_section() {
    let obj = mo_object_of(mo_rodata_module())
    teko::assert::is_true(obj.len == (443 to u64))
    teko::assert::is_true(mo_u32_at(obj, 96 to u64) == (2 to u32))
    teko::assert::is_true(mo_u32_at(obj, 160 to u64) == (0 to u32))
    teko::assert::is_true(mo_u32_at(obj, 164 to u64) == (0 to u32))
    teko::assert::is_true(obj[184] == (0x5F to byte))
    teko::assert::is_true(obj[186] == (0x63 to byte))
    teko::assert::is_true(obj[190] == (0x74 to byte))
    teko::assert::is_true(mo_u32_at(obj, 216 to u64) == (4 to u32))
    teko::assert::is_true(mo_u32_at(obj, 224 to u64) == (3 to u32))
    teko::assert::is_true(mo_u32_at(obj, 232 to u64) == (396 to u32))
    teko::assert::is_true(mo_u32_at(obj, 392 to u64) == (0xD65F03C0 to u32))
    teko::assert::is_true(obj[396] == (0x68 to byte))
    teko::assert::is_true(obj[397] == (0x69 to byte))
    teko::assert::is_true(obj[398] == (0 to byte))
    teko::assert::is_true(obj[399] == (0 to byte))
    teko::assert::is_true(mo_u32_at(obj, 324 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 328 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 332 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 340 to u64) == (0 to u32))
    teko::assert::is_true(obj[404] == (0x0E to byte))
    teko::assert::is_true(obj[405] == (2 to byte))
    teko::assert::is_true(mo_u32_at(obj, 408 to u64) == (4 to u32))
    teko::assert::is_true(mo_u32_at(obj, 412 to u64) == (0 to u32))
    teko::assert::is_true(obj[420] == (0x0F to byte))
    teko::assert::is_true(obj[421] == (1 to byte))
    teko::assert::is_true(mo_u32_at(obj, 424 to u64) == (0 to u32))
    teko::assert::is_true(obj[433] == (0x5F to byte))
    teko::assert::is_true(obj[434] == (0x73 to byte))
    teko::assert::is_true(obj[435] == (0x30 to byte))
    teko::assert::is_true(obj[436] == (0 to byte))
    teko::assert::is_true(obj[437] == (0x5F to byte))
    teko::assert::is_true(obj[438] == (0x6D to byte))
}

/**
 * mo_two_syms — a two-entry defined, global symbol list, for the `sym_index`
 * fixtures.
 *
 * @return []Symbol  `[a, b]`, both defined and global
 */
fn mo_two_syms() -> []Symbol {
    let a = Symbol { name = "a"; defined = true; sect = 1 to u8; offset = 0 to u32; local = false }
    let b = Symbol { name = "b"; defined = true; sect = 1 to u8; offset = 0 to u32; local = false }
    teko::list::push(teko::list::push(teko::list::empty(), a), b)
}

#test
/**
 * sym_index_finds_and_sentinels — `sym_index` returns a present symbol's index
 * and, for an absent name, the one-past-end sentinel (`symbols.len`), covering
 * both arms of the lookup the relocation table relies on.
 *
 * @return void
 */
fn sym_index_finds_and_sentinels() {
    let syms = mo_two_syms()
    teko::assert::is_true(sym_index(syms, "a") == (0 to u32))
    teko::assert::is_true(sym_index(syms, "b") == (1 to u32))
    teko::assert::is_true(sym_index(syms, "z") == (2 to u32))
}

/**
 * mo_rodata_reloc_module — a frameless `main` of `adrp x0,"s0"; add-lo
 * x0,x0,"s0"; bl tk_exit` (no `ret`, so it stays frameless) plus one rodata
 * entry `s0 = "A\0"`. Exercises all three ARM64 relocation kinds against both
 * a DEFINED (`s0`, local `__const`) and an UNDEFINED (`tk_exit`) target in one
 * object — the F2(a) round-trip fixture.
 *
 * @return MModule  the one-function, one-rodata, three-reloc module
 */
fn mo_rodata_reloc_module() -> MModule {
    let insts = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), adrp_inst(mo_gpr(0), "s0", MRelocKind::PageHi)), add_lo_inst(mo_gpr(0), mo_gpr(0), "s0", MRelocKind::PageLo)), call_inst("tk_exit", mo_no_uses(), mo_gpr(0), false, false))
    let bytes = teko::list::push(teko::list::push(teko::list::empty(), 0x41 to byte), 0 to byte)
    let rodata = teko::list::push(teko::list::empty(), lir::LRodata { symbol = "s0"; bytes = bytes; relocs = teko::list::empty() })
    let funcs = teko::list::push(teko::list::empty(), mo_func("main", insts))
    MModule { funcs = funcs; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
}

#test
/**
 * rodata_reloc_module_pins_symtab_and_page_relocs — the F1/F2/F3 round-trip
 * pin: `s0` (local, `__const`) carries `n_value = text_size(12) + 0 = 12` (the
 * F1 fix — the ABSOLUTE address, not the bare offset 0 the pre-fix writer
 * emitted) and `N_SECT`-only type `0x0E` (the F3 local-symbol fix); `main`
 * (global, `__text`) stays `N_SECT | N_EXT` (0x0F) at `n_value = 0`. The three
 * `relocation_info` words are byte-pinned: `PAGE21`→s0 (`0x3D000000`,
 * pc-relative, symbol index 0), `PAGEOFF12`→s0 (`0x4C000000`, absolute, same
 * index), `BRANCH26`→tk_exit (`0x2D000002`, pc-relative, symbol index 2 — the
 * undefined entry sorts after the two defined ones). `LC_DYSYMTAB` reports
 * `nlocalsym=1`/`nextdefsym=1`/`nundefsym=1`. The whole object is 500 bytes.
 *
 * @return void
 */
fn rodata_reloc_module_pins_symtab_and_page_relocs() {
    let enc = match encode_module(AAPCS64, mo_rodata_reloc_module()) {
        EncodedModule as x => x
        error as e => bad_enc()
    }
    teko::assert::is_true(enc.relocs.len == 3)
    teko::assert::is_true(enc.symbols.len == 3)
    let obj = emit_macho(enc)
    teko::assert::is_true(obj.len == (500 to u64))
    teko::assert::is_true(mo_u32_at(obj, 324 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 328 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 332 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 336 to u64) == (2 to u32))
    teko::assert::is_true(mo_u32_at(obj, 340 to u64) == (1 to u32))
    teko::assert::is_true(mo_u32_at(obj, 408 to u64) == (0 to u32))
    teko::assert::is_true(mo_u32_at(obj, 412 to u64) == (0x3D000000 to u32))
    teko::assert::is_true(mo_u32_at(obj, 416 to u64) == (4 to u32))
    teko::assert::is_true(mo_u32_at(obj, 420 to u64) == (0x4C000000 to u32))
    teko::assert::is_true(mo_u32_at(obj, 424 to u64) == (8 to u32))
    teko::assert::is_true(mo_u32_at(obj, 428 to u64) == (0x2D000002 to u32))
    teko::assert::is_true(obj[436] == (0x0E to byte))
    teko::assert::is_true(obj[437] == (2 to byte))
    teko::assert::is_true(mo_u32_at(obj, 440 to u64) == (12 to u32))
    teko::assert::is_true(mo_u32_at(obj, 444 to u64) == (0 to u32))
    teko::assert::is_true(obj[452] == (0x0F to byte))
    teko::assert::is_true(obj[453] == (1 to byte))
    teko::assert::is_true(mo_u32_at(obj, 456 to u64) == (0 to u32))
    teko::assert::is_true(obj[468] == (0x01 to byte))
    teko::assert::is_true(obj[469] == (0 to byte))
}

/**
 * bad_enc — the sentinel `EncodedModule` for a fixture that must encode but
 * unexpectedly honest-stops (so the following assertion fails loudly).
 *
 * @return EncodedModule  the empty sentinel module
 */
fn bad_enc() -> EncodedModule {
    EncodedModule { text = teko::list::empty(); rodata = teko::list::empty(); symbols = teko::list::empty(); relocs = teko::list::empty() }
}

/**
 * mo_rodata_ptr_enc — a hand-built `EncodedModule` with no functions and a 16-byte
 * `__const` = an 8-byte pointer slot (offset 0) then the target datum `0x41` (offset
 * 8), plus a single `Abs64`/`Rodata` relocation at `__const` offset 0 targeting the
 * `target` local. Feeds `emit_macho` directly (`encode_module` honest-stops a
 * rodata-internal pointer), pinning the `__const` relocation the T-B3 writer emits.
 *
 * @return EncodedModule  the hand-built rodata-internal-pointer module
 */
fn mo_rodata_ptr_enc() -> EncodedModule {
    let rodata = [0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0x41 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte]
    let ptr = Symbol { name = "ptr"; defined = true; sect = 2 to u8; offset = 0 to u32; local = true }
    let target = Symbol { name = "target"; defined = true; sect = 2 to u8; offset = 8 to u32; local = true }
    let rr = Reloc { offset = 0 to u32; sym = "target"; kind = MRelocKind::Abs64; sect = RelocSect::Rodata }
    EncodedModule { text = teko::list::empty(); rodata = rodata; symbols = [ptr, target]; relocs = [rr] }
}

/**
 * T-B3: com um data→data reloc presente, o `__const` section_64 aponta a sua própria
 * relocation table (reloff/nreloc) e a entrada UNSIGNED (r_length=3, extern, symnum
 * do datum-alvo) sai contígua após a tabela (vazia) do `__text`; o slot in-place
 * permanece 0 (o addend da UNSIGNED externa é 0).
 */
#test
fn tb3_macho_const_reloc_emitted() {
    let obj = emit_macho(mo_rodata_ptr_enc())
    teko::assert::is_true(obj.len == 462)
    teko::assert::is_true(mo_u32_at(obj, 96) == 2)
    teko::assert::is_true(mo_u32_at(obj, 240) == 408)
    teko::assert::is_true(mo_u32_at(obj, 244) == 1)
    teko::assert::is_true(mo_u32_at(obj, 408) == 0)
    teko::assert::is_true(mo_u32_at(obj, 412) == 0x0E000001)
    teko::assert::is_true(obj[392] == (0 to byte))
    teko::assert::is_true(obj[400] == (0x41 to byte))
}
