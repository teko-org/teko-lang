/**
 * WASM_OP_I64_GE_U — the wasm `i64.ge_u` opcode.
 */
const WASM_OP_I64_GE_U: byte = 0x5A to byte

/**
 * WASM_OP_F32_EQ — the wasm `f32.eq` opcode.
 */
