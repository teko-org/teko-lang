/**
 * WASM_OP_I32_GE_U — the wasm `i32.ge_u` opcode.
 */
const WASM_OP_I32_GE_U: byte = 0x4F to byte

/**
 * WASM_OP_I64_EQ — the wasm `i64.eq` opcode.
 */
const WASM_OP_I64_EQ: byte = 0x51 to byte

/**
 * WASM_OP_I64_NE — the wasm `i64.ne` opcode.
