use teko::lir

/**
 * WasmVType — the four wasm value types `stackify` ever produces: `I32`
 * (the valtype every sub-32 integer width — `I8`/`I16`/`I32` — and `Ptr`
 * collapse to in wasm32, `backend-c1-wasm.md` §1.1), `I64`, `F32`, `F64`.
 * The declaration ordinal (0,1,2,3) does NOT match the wasm binary format's
 * own value-type bytes (`0x7F`/`0x7E`/`0x7D`/`0x7C`), so every internal
 * comparison/dispatch uses this enum directly — `wasm_vtype_wire` is the
 * single translation point that produces the raw wire byte.
 */
pub type WasmVType = enum { I32; I64; F32; F64 }

/**
 * wasm_vtype_wire — the wasm binary value-type byte (`backend-c1-wasm.md`
 * §1.1) a `WasmVType` tag encodes to: `I32` → `0x7F`, `I64` → `0x7E`, `F32`
 * → `0x7D`, `F64` → `0x7C`. The single wire-mapping function for this
 * family (§594 crumb 10's `_wire` convention) — every other site in this
 * file operates on the `WasmVType` tag, or on the already-produced wire
 * byte threaded through `WasmVTypeTable`/`WasmMemOp`/`WasmLocalGroup`.
 *
 * @param v  the value-type tag
 * @return   the wasm value-type byte
 */
fn wasm_vtype_wire(v: WasmVType) -> u8 {
    match v {
        I32 => 0x7F to u8
        I64 => 0x7E to u8
        F32 => 0x7D to u8
        F64 => 0x7C to u8
    }
}

/**
 * wasm_valtype — the wasm value-type byte an `LType` machine class maps to
 * under target pointer width `ptr64` (`backend-c1-wasm.md` §1.1/§6, the
 * wasm32/wasm64 switch, #389 C1-7): the sub-32 integer widths collapse to
 * `i32`, `I64` maps to `i64`, `F32`/`F64` map directly, and `Ptr` follows
 * `ptr64` — `i32` on wasm32 (`ptr64 = false`, the default — every memory
 * access takes a native i32 address, §6's checked narrow applies at every
 * `Ptr`-typed memory op) or `i64` on wasm64 (`ptr64 = true` — the uniform
 * 64-bit `ptr<>` model needs no narrowing at all, `ltype_size(Ptr) = 8`
 * already matches). `I128` and `F16` have no wasm value type at all — the
 * two NAMED honest-stops `C1-i128` (shared with A2's own i128 route) and
 * `C1-f16` (matching the register targets' own f16 gap). `Void` is a
 * valueless machine class (never a real operand), so it also has no valtype
 * byte — an internal-error arm, distinct from the two design-named stops,
 * exercised directly by a unit test rather than reachable through valid
 * lowering.
 *
 * @param LType t  the machine class to map
 * @param bool ptr64  the target pointer width (`false` = wasm32, the
 *                    default; `true` = wasm64)
 * @return u8 | error  the wasm valtype byte, or a named honest-stop
 * @since #389 C1-7 (the `ptr64` parameter; the mapping itself is C1-1)
 */
pub fn wasm_valtype(t: lir::LType, ptr64: bool) -> u8 | error {
    match t {
        lir::LType::I8 => wasm_vtype_wire(WasmVType::I32)
        lir::LType::I16 => wasm_vtype_wire(WasmVType::I32)
        lir::LType::I32 => wasm_vtype_wire(WasmVType::I32)
        lir::LType::I64 => wasm_vtype_wire(WasmVType::I64)
        lir::LType::I128 => error { message = "stackify: C1-i128 — wasm has no native i128 valtype, deferred (shared with A2's i128 route, backend-a4-encoder.md §6.3)" }
        lir::LType::F16 => error { message = "stackify: C1-f16 — wasm has no native f16 valtype, deferred (matches the register targets' f16 gap)" }
        lir::LType::F32 => wasm_vtype_wire(WasmVType::F32)
        lir::LType::F64 => wasm_vtype_wire(WasmVType::F64)
        lir::LType::Ptr => if ptr64 { wasm_vtype_wire(WasmVType::I64) } else { wasm_vtype_wire(WasmVType::I32) }
        lir::LType::Void => error { message = "stackify: wasm_valtype — a Void machine class has no wasm value type (internal)" }
    }
}

/**
 * WasmVTypeTable — the stackifier's per-VReg side-table: each VReg's already
 * resolved wasm valtype byte, densely indexed (VReg ids are assigned in
 * strictly increasing order by the LIR's own SSA allocator, so a growable
 * positional array suffices — mirrors `isel_arm64.tks`'s `VInfoTable`
 * `class_of` mechanism, but keyed by the concrete valtype byte rather than a
 * register-class/width pair, since a wasm local's type cannot be
 * reinterpreted the way a physical register's view can). Every VReg that
 * defines a value records its valtype here before any later instruction
 * reads it (the LIR's def-before-use SSA property).
 */
type WasmVTypeTable = struct {
    /**
     * vtypes — each recorded VReg's wasm valtype byte, positionally indexed
     * by VReg id.
     */
    vtypes: []u8
}

/**
 * wvt_empty — a side-table with no VRegs recorded yet (a function's
 * lowering seed).
 *
 * @return WasmVTypeTable  the empty table
 */
fn wvt_empty() -> WasmVTypeTable {
    WasmVTypeTable { vtypes = teko::list::empty() }
}

/**
 * wvt_grow — pad `t` with placeholder `i32` entries until it holds at least
 * `n` positions, so a subsequent positional write never runs past the end
 * of the array.
 *
 * @param WasmVTypeTable t  the table to pad
 * @param u64 n  the minimum length the padded table must reach
 * @return WasmVTypeTable  the padded table
 */
fn wvt_grow(t: WasmVTypeTable, n: u64) -> WasmVTypeTable {
    mut vts = t.vtypes
    loop {
        if vts.len >= n { break }
        vts = teko::list::push(vts, wasm_vtype_wire(WasmVType::I32))
    }
    WasmVTypeTable { vtypes = vts }
}

/**
 * wvt_set — record `vt` as the wasm valtype of VReg `id`, growing the table
 * first when `id` is past its current length (a fresh rebuild of the
 * positional array with the one entry rewritten, mirroring the isel
 * side-table's `vinfo_set`).
 *
 * @param WasmVTypeTable t0  the table to update
 * @param u32 id  the VReg id being recorded
 * @param u8 vt  its wasm valtype byte
 * @return WasmVTypeTable  the updated table
 */
fn wvt_set(t0: WasmVTypeTable, id: u32, vt: u8) -> WasmVTypeTable {
    let grown = wvt_grow(t0, (id to u64) + 1)
    mut out: []u8 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= grown.vtypes.len { break }
        out = teko::list::push(out, if (i to u32) == id { vt } else { grown.vtypes[i] })
        i++
    }
    WasmVTypeTable { vtypes = out }
}

/**
 * wvt_get — the recorded wasm valtype of VReg `id`, or the `i32` default
 * when `id` was never recorded (defensive only — the LIR's SSA property
 * guarantees every operand is recorded before it is read).
 *
 * @param WasmVTypeTable t  the table to read
 * @param u32 id  the VReg id to look up
 * @return u8  its recorded (or default) wasm valtype byte
 */
fn wvt_get(t: WasmVTypeTable, id: u32) -> u8 {
    let i = id to u64
    if i >= t.vtypes.len { return wasm_vtype_wire(WasmVType::I32) }
    t.vtypes[i]
}

/**
 * WasmScope — one open structured-control scope during CFGStackify
 * placement: its kind (`block`/`loop`/`if`) and, for a `block`/`loop`, the
 * LIR block whose boundary the scope's label targets (a `br` to that block
 * resolves to this scope's relative depth). The pass keeps a stack of
 * these; `br` depth is the distance from the branch site down to the
 * matching scope (`backend-c1-wasm.md` §3.5).
 *
 * @since #389 C1-3
 */
pub type WasmScope = struct {
    /**
     * kind — `Block` (label at its `end`, a forward exit), `Loop` (label at
     * its start, a back-edge/continue), or `If` (a structural diamond,
     * never a `br` target — it only occupies a depth slot).
     */
    kind: WasmScopeKind
    /**
     * label_block — the LIR block id this scope's label targets
     * (meaningful for `block`/`loop`; unused, always `0`, for `if`).
     */
    label_block: u32
}

/**
 * WasmScopeKind — the tag `WasmScope.kind` carries: `Block` (an `if`-free
 * forward label scope — a wrapped loop exit, or a `br` skip-ahead target),
 * `Loop` (a loop scope; a `br` to it is the back-edge/continue), or `If` (an
 * `if`/`else` structural diamond — it occupies a depth slot but is never a
 * `br` target, its own fallthrough IS the merge). Purely an internal
 * control-flow tag — never serialized to wasm bytes — so no wire mapping is
 * needed.
 */
pub type WasmScopeKind = enum { Block; Loop; If }

/**
 * wasm_scope_stack_push — open a new scope on top of `scopes`.
 *
 * @param []WasmScope scopes  the scope stack to extend
 * @param WasmScopeKind kind  the new scope's kind
 * @param u32 label_block  the new scope's label target (unused for `if`)
 * @return []WasmScope  the extended stack, the new scope innermost
 */
fn wasm_scope_stack_push(scopes: []WasmScope, kind: WasmScopeKind, label_block: u32) -> []WasmScope {
    teko::list::push(scopes, WasmScope { kind = kind; label_block = label_block })
}

/**
 * wasm_scope_stack_pop — close the innermost open scope of `scopes`.
 *
 * @param []WasmScope scopes  the scope stack to shrink
 * @return []WasmScope  `scopes` with its last entry removed (unchanged if
 *                       already empty)
 */
fn wasm_scope_stack_pop(scopes: []WasmScope) -> []WasmScope {
    let keep = if scopes.len == 0 { 0 to u64 } else { scopes.len - 1 }
    mut out: []WasmScope = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= keep { break }
        out = teko::list::push(out, scopes[i])
        i++
    }
    out
}

/**
 * ScopeDepthResult — the outcome of searching the scope stack for a
 * `block`/`loop` labelled by a specific LIR block id.
 */
type ScopeDepthResult = struct {
    /**
     * found — whether a matching `block`/`loop` scope is currently open.
     */
    found: bool
    /**
     * depth — its relative `br` depth (innermost open scope = `0`);
     * meaningless when `found` is `false`.
     */
    depth: u32
}

/**
 * wasm_scope_stack_depth_of — search `scopes` for an open `block`/`loop`
 * labelled `label_block`, and its relative `br` depth (§3.3's "the distance
 * from the branch site down to the matching scope" — the innermost open
 * scope is depth `0`; an `if` scope on the stack still consumes one depth
 * slot even though it can never itself be the match).
 *
 * @param []WasmScope scopes  the currently open scope stack
 * @param u32 label_block  the LIR block id a `br` is targeting
 * @return ScopeDepthResult  whether it is open, and at what depth
 */
fn wasm_scope_stack_depth_of(scopes: []WasmScope, label_block: u32) -> ScopeDepthResult {
    mut i: u64 = 0
    loop {
        if i >= scopes.len { break }
        let s = scopes[i]
        let is_label = s.kind == WasmScopeKind::Block || s.kind == WasmScopeKind::Loop
        if is_label && s.label_block == label_block {
            return ScopeDepthResult { found = true; depth = ((scopes.len - 1) - i) to u32 }
        }
        i++
    }
    ScopeDepthResult { found = false; depth = 0 to u32 }
}

/**
 * WasmSlotTable — the stackifier's per-VReg shadow-stack-slot side-table:
 * each `LAlloca` result VReg's frame-base-relative byte offset (§6.1),
 * densely indexed by VReg id exactly like `WasmVTypeTable` (the LIR's own
 * strictly-increasing VReg id allocation makes a positional array
 * sufficient). Built ONCE, ahead of lowering, from the function's whole
 * static frame layout (`compute_wasm_frame_layout`) — every Teko `LAlloca`
 * carries a compile-time-constant `bytes`/`align` (no VLA), so the whole
 * function's frame can be laid out up front, exactly like a native frame
 * (mirrors `encode_arm64.tks`'s `MFunc.frame` + `SlotLayout`, PARALLELED
 * rather than reused, `backend-c1-wasm.md` §1.3) — this is what keeps an
 * `LAlloca` SITE inside a `loop` body correct: it resolves to the SAME
 * fixed slot every iteration instead of bumping `SP` again each pass.
 *
 * @since #389 C1-4
 */
type WasmSlotTable = struct {
    /**
     * offsets — each recorded alloca VReg's frame-base-relative byte
     * offset, positionally indexed by VReg id (`0` for an unrecorded VReg —
     * never read for one, since every `LAlloca` is pre-scanned before
     * lowering begins).
     */
    offsets: []u32
}

/**
 * wst_empty — a slot table with no `LAlloca` VRegs recorded yet.
 *
 * @return WasmSlotTable  the empty table
 */
fn wst_empty() -> WasmSlotTable {
    WasmSlotTable { offsets = teko::list::empty() }
}

/**
 * wst_grow — pad `t` with placeholder `0` entries until it holds at least
 * `n` positions (mirrors `wvt_grow`).
 *
 * @param WasmSlotTable t  the table to pad
 * @param u64 n  the minimum length the padded table must reach
 * @return WasmSlotTable  the padded table
 */
fn wst_grow(t: WasmSlotTable, n: u64) -> WasmSlotTable {
    mut os = t.offsets
    loop {
        if os.len >= n { break }
        os = teko::list::push(os, 0 to u32)
    }
    WasmSlotTable { offsets = os }
}

/**
 * wst_set — record `off` as the frame-base-relative offset of VReg `id`,
 * growing the table first when needed (mirrors `wvt_set`).
 *
 * @param WasmSlotTable t0  the table to update
 * @param u32 id  the `LAlloca` result VReg being recorded
 * @param u32 off  its frame-base-relative byte offset
 * @return WasmSlotTable  the updated table
 */
fn wst_set(t0: WasmSlotTable, id: u32, off: u32) -> WasmSlotTable {
    let grown = wst_grow(t0, (id to u64) + 1)
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= grown.offsets.len { break }
        out = teko::list::push(out, if (i to u32) == id { off } else { grown.offsets[i] })
        i++
    }
    WasmSlotTable { offsets = out }
}

/**
 * wst_get — the recorded frame-base-relative offset of VReg `id`, or `0`
 * when `id` was never recorded (defensive only — every `LAlloca` site is
 * pre-scanned into the table before its own lowering is ever reached).
 *
 * @param WasmSlotTable t  the table to read
 * @param u32 id  the VReg id to look up
 * @return u32  its recorded (or default) offset
 */
fn wst_get(t: WasmSlotTable, id: u32) -> u32 {
    let i = id to u64
    if i >= t.offsets.len { return 0 to u32 }
    t.offsets[i]
}

/**
 * StackifyCtx — the stackifier's threaded state while lowering one
 * function's whole instruction stream: the already-emitted code-entry body
 * bytes, the `WasmVTypeTable` recording every VReg lowered so far, the
 * CFGStackify scope stack currently open (`WasmScope`, §3), the next free
 * scratch-local id (`next_scratch`, §4.3's parallel-copy staging), and the
 * function's shadow-stack frame (`has_frame`/`frame_base`/`slots`, C1-4's
 * `LAlloca` support — §6.1). Mirrors `isel_arm64.tks`'s `SelCtx`, but with
 * no register file — wasm's per-value state is its valtype plus (during
 * control-flow lowering) the structured-control scope stack a `br`'s label
 * depth resolves against.
 */
type StackifyCtx = struct {
    /**
     * body — the function body bytes emitted so far (the code-entry
     * instruction stream, not yet terminated by the closing `end`).
     */
    body: []byte
    /**
     * vtypes — the per-VReg wasm valtype side-table recorded so far
     * (indexed by VReg id for every real LIR value, and by scratch id —
     * `next_scratch` and up — for every parallel-copy staging temp).
     */
    vtypes: WasmVTypeTable
    /**
     * scopes — the CFGStackify structured-control scope stack currently
     * open, outermost first (§3.3): a `block`/`loop` entry's `label_block`
     * is the LIR block id a `br` reaching it resolves to; an `if` entry
     * only occupies a depth slot (never a `br` target).
     */
    scopes: []WasmScope
    /**
     * next_scratch — the next unused local id available for parallel-copy
     * staging (§4.3): seeded from the function's `next_vreg` (one past
     * every real LIR VReg) and incremented per allocation, so a scratch
     * local never collides with a VReg-backed one.
     */
    next_scratch: u32
    /**
     * has_frame — whether this function reserves a shadow-stack frame (it
     * contains at least one `LAlloca`): when `false`, `frame_base`/`slots`
     * are unused and `LRet`'s epilogue restores nothing.
     */
    has_frame: bool
    /**
     * frame_base — the scratch local holding this call's own frame base
     * (the `SP` value right after the prologue's ONE bump, §6.1): every
     * `LAlloca` site computes `frame_base + its own slot offset`, and every
     * `LRet` epilogue restores `SP` from it. Meaningless when `has_frame`
     * is `false`.
     */
    frame_base: u32
    /**
     * slots — the function's whole `LAlloca` frame layout (`WasmSlotTable`,
     * built once by `compute_wasm_frame_layout` ahead of lowering).
     * Meaningless when `has_frame` is `false`.
     */
    slots: WasmSlotTable
    /**
     * elide — the whole-function value-stack peephole decision table (§5,
     * `compute_func_elide`), built ONCE ahead of lowering and read-only
     * thereafter: each VReg's final `ElideKind` tag. Defaults to an empty
     * table (every VReg reads as `ElideKind::Normal`) for every caller
     * that never populates it — the ALL-LOCALS baseline every fine-grained
     * per-instruction test in `stackify_test.tkt` still exercises directly.
     *
     * @since #389 C1-5
     */
    elide: ElideTable
    /**
     * pending — the live, order-preserving mirror of the values CURRENTLY
     * riding the real wasm operand stack, unmaterialized (§5): a VReg lands
     * here the moment `sc_def_result` decides `Drop`/`Tee`, and leaves the
     * moment `sc_use_operand` finds it at the top — the reactive replay of
     * `compute_func_elide`'s own static decision, walking the SAME
     * instruction stream in the SAME order so the two always agree.
     *
     * @since #389 C1-5
     */
    pending: []u32
}

/**
 * WASM_OP_UNREACHABLE — the wasm `unreachable` opcode: traps the instance
 * immediately (§8's "observe, then trap" shape, M.1). The first of this
 * file's whole §7.3 W15 sweep (crumb S1) of named opcode/format-byte
 * constants below: each is named `WASM_OP_<mnemonic>` (an instruction) or
 * `WASM_<FORMAT>_<name>` (a structural byte that is not itself an
 * instruction — a blocktype or an export-kind tag), and its value is EXACTLY
 * the wasm binary-format byte the wasm core spec (or, for the two export
 * kinds, the object-format `WasmExport.kind` convention already documented
 * in `objfile_wasm.tks`) assigns it — only the SOURCE SPELLING changes;
 * every emitted byte stays identical (fixpoint + the golden-byte tests below
 * prove it).
 */
const WASM_OP_UNREACHABLE: byte = 0x00 to byte

/**
 * WASM_OP_BLOCK — the wasm `block` opcode (a forward-exit structured-control
 * scope, §3.3).
 */
const WASM_OP_BLOCK: byte = 0x02 to byte

/**
 * WASM_OP_LOOP — the wasm `loop` opcode (a back-edge/continue structured-
 * control scope, §3.3).
 */
const WASM_OP_LOOP: byte = 0x03 to byte

/**
 * WASM_OP_IF — the wasm `if` opcode (a structural diamond scope, §3.3).
 */
const WASM_OP_IF: byte = 0x04 to byte

/**
 * WASM_OP_ELSE — the wasm `else` opcode separating an `if`'s then-arm from
 * its else-arm.
 */
const WASM_OP_ELSE: byte = 0x05 to byte

/**
 * WASM_OP_END — the wasm `end` opcode: closes the innermost open `block`/
 * `loop`/`if` scope, or terminates a function's own code-entry body.
 */
const WASM_OP_END: byte = 0x0B to byte

/**
 * WASM_OP_BR — the wasm unconditional `br` opcode (a relative scope-depth
 * branch, §3.3).
 */
const WASM_OP_BR: byte = 0x0C to byte

/**
 * WASM_OP_RETURN — the wasm `return` opcode: exits the current function,
 * carrying its own result (if any) already on the operand stack.
 */
const WASM_OP_RETURN: byte = 0x0F to byte

/**
 * WASM_OP_CALL — the wasm `call` opcode (a direct call by function index).
 */
const WASM_OP_CALL: byte = 0x10 to byte

/**
 * WASM_OP_DROP — the wasm `drop` opcode: discards the top operand-stack
 * value without binding it anywhere.
 */
const WASM_OP_DROP: byte = 0x1A to byte

/**
 * WASM_OP_LOCAL_GET — the wasm `local.get` opcode.
 */
const WASM_OP_LOCAL_GET: byte = 0x20 to byte

/**
 * WASM_OP_LOCAL_SET — the wasm `local.set` opcode.
 */
const WASM_OP_LOCAL_SET: byte = 0x21 to byte

/**
 * WASM_OP_LOCAL_TEE — the wasm `local.tee` opcode: sets the local like
 * `local.set`, but leaves the value on the operand stack too.
 */
const WASM_OP_LOCAL_TEE: byte = 0x22 to byte

/**
 * WASM_OP_GLOBAL_GET — the wasm `global.get` opcode.
 */
const WASM_OP_GLOBAL_GET: byte = 0x23 to byte

/**
 * WASM_OP_GLOBAL_SET — the wasm `global.set` opcode.
 */
const WASM_OP_GLOBAL_SET: byte = 0x24 to byte

/**
 * WASM_OP_I32_LOAD — the wasm `i32.load` opcode (natural 4-byte alignment).
 */
const WASM_OP_I32_LOAD: byte = 0x28 to byte

/**
 * WASM_OP_I64_LOAD — the wasm `i64.load` opcode (natural 8-byte alignment).
 */
const WASM_OP_I64_LOAD: byte = 0x29 to byte

/**
 * WASM_OP_F32_LOAD — the wasm `f32.load` opcode.
 */
const WASM_OP_F32_LOAD: byte = 0x2A to byte

/**
 * WASM_OP_F64_LOAD — the wasm `f64.load` opcode.
 */
const WASM_OP_F64_LOAD: byte = 0x2B to byte

/**
 * WASM_OP_I32_LOAD8_S — the wasm `i32.load8_s` opcode: a byte-width load,
 * zero-extended into the shared `i32` family (`wasm_mem_op`'s own
 * "load zero-extending" convention — never a real sign-extend here).
 */
const WASM_OP_I32_LOAD8_S: byte = 0x2D to byte

/**
 * WASM_OP_I32_LOAD16_S — the wasm `i32.load16_s` opcode: a halfword-width
 * load, zero-extended into the shared `i32` family (mirrors
 * `WASM_OP_I32_LOAD8_S`'s own convention).
 */
const WASM_OP_I32_LOAD16_S: byte = 0x2F to byte

/**
 * WASM_OP_I32_STORE — the wasm `i32.store` opcode.
 */
const WASM_OP_I32_STORE: byte = 0x36 to byte

/**
 * WASM_OP_I64_STORE — the wasm `i64.store` opcode.
 */
const WASM_OP_I64_STORE: byte = 0x37 to byte

/**
 * WASM_OP_F32_STORE — the wasm `f32.store` opcode.
 */
const WASM_OP_F32_STORE: byte = 0x38 to byte

/**
 * WASM_OP_F64_STORE — the wasm `f64.store` opcode.
 */
const WASM_OP_F64_STORE: byte = 0x39 to byte

/**
 * WASM_OP_I32_STORE8 — the wasm `i32.store8` opcode (a byte-width store).
 */
const WASM_OP_I32_STORE8: byte = 0x3A to byte

/**
 * WASM_OP_I32_STORE16 — the wasm `i32.store16` opcode (a halfword-width
 * store).
 */
const WASM_OP_I32_STORE16: byte = 0x3B to byte

/**
 * WASM_OP_I32_CONST — the wasm `i32.const` opcode (followed by a SLEB128
 * immediate).
 */
const WASM_OP_I32_CONST: byte = 0x41 to byte

/**
 * WASM_OP_I64_CONST — the wasm `i64.const` opcode (followed by a SLEB128
 * immediate).
 */
const WASM_OP_I64_CONST: byte = 0x42 to byte

/**
 * WASM_OP_F64_CONST — the wasm `f64.const` opcode (followed by the raw
 * 8-byte little-endian IEEE754 binary64 pattern, NOT LEB128-encoded).
 */
const WASM_OP_F64_CONST: byte = 0x44 to byte

/**
 * WASM_OP_I32_EQ — the wasm `i32.eq` opcode.
