/**
 * WASM_OP_F64_GT — the wasm `f64.gt` opcode.
 */
const WASM_OP_F64_GT: byte = 0x64 to byte

/**
 * WASM_OP_F64_LE — the wasm `f64.le` opcode.
 */
const WASM_OP_F64_LE: byte = 0x65 to byte

/**
 * WASM_OP_F64_GE — the wasm `f64.ge` opcode.
 */
const WASM_OP_F64_GE: byte = 0x66 to byte

/**
 * WASM_OP_I32_ADD — the wasm `i32.add` opcode.
 */
const WASM_OP_I32_ADD: byte = 0x6A to byte

/**
 * WASM_OP_I32_SUB — the wasm `i32.sub` opcode.
 */
const WASM_OP_I32_SUB: byte = 0x6B to byte

/**
 * WASM_OP_I32_MUL — the wasm `i32.mul` opcode.
 */
const WASM_OP_I32_MUL: byte = 0x6C to byte

/**
 * WASM_OP_I32_DIV_S — the wasm `i32.div_s` opcode.
 */
const WASM_OP_I32_DIV_S: byte = 0x6D to byte

/**
 * WASM_OP_I32_DIV_U — the wasm `i32.div_u` opcode.
 */
const WASM_OP_I32_DIV_U: byte = 0x6E to byte

/**
 * WASM_OP_I32_REM_S — the wasm `i32.rem_s` opcode.
 */
const WASM_OP_I32_REM_S: byte = 0x6F to byte

/**
 * WASM_OP_I32_REM_U — the wasm `i32.rem_u` opcode.
 */
const WASM_OP_I32_REM_U: byte = 0x70 to byte

/**
 * WASM_OP_I32_AND — the wasm `i32.and` opcode.
 */
const WASM_OP_I32_AND: byte = 0x71 to byte

/**
 * WASM_OP_I32_OR — the wasm `i32.or` opcode.
 */
const WASM_OP_I32_OR: byte = 0x72 to byte

/**
 * WASM_OP_I32_XOR — the wasm `i32.xor` opcode.
