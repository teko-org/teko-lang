/**
 * WASM_OP_I32_SHR_S — the wasm `i32.shr_s` opcode.
 */
const WASM_OP_I32_SHR_S: byte = 0x75 to byte

/**
 * WASM_OP_I32_SHR_U — the wasm `i32.shr_u` opcode.
 */
const WASM_OP_I32_SHR_U: byte = 0x76 to byte

/**
 * WASM_OP_I64_ADD — the wasm `i64.add` opcode.
 */
const WASM_OP_I64_ADD: byte = 0x7C to byte

/**
 * WASM_OP_I64_SUB — the wasm `i64.sub` opcode.
 */
const WASM_OP_I64_SUB: byte = 0x7D to byte

/**
 * WASM_OP_I64_MUL — the wasm `i64.mul` opcode.
 */
const WASM_OP_I64_MUL: byte = 0x7E to byte

/**
 * WASM_OP_I64_DIV_S — the wasm `i64.div_s` opcode.
 */
const WASM_OP_I64_DIV_S: byte = 0x7F to byte

/**
 * WASM_OP_I64_DIV_U — the wasm `i64.div_u` opcode.
 */
const WASM_OP_I64_DIV_U: byte = 0x80 to byte

/**
 * WASM_OP_I64_REM_S — the wasm `i64.rem_s` opcode.
 */
const WASM_OP_I64_REM_S: byte = 0x81 to byte

/**
 * WASM_OP_I64_REM_U — the wasm `i64.rem_u` opcode.
 */
const WASM_OP_I64_REM_U: byte = 0x82 to byte

/**
 * WASM_OP_I64_AND — the wasm `i64.and` opcode.
 */
const WASM_OP_I64_AND: byte = 0x83 to byte

/**
 * WASM_OP_I64_OR — the wasm `i64.or` opcode.
 */
const WASM_OP_I64_OR: byte = 0x84 to byte

/**
 * WASM_OP_I64_XOR — the wasm `i64.xor` opcode.
 */
const WASM_OP_I64_XOR: byte = 0x85 to byte

/**
 * WASM_OP_I64_SHL — the wasm `i64.shl` opcode.
 */
const WASM_OP_I64_SHL: byte = 0x86 to byte

/**
 * WASM_OP_I64_SHR_S — the wasm `i64.shr_s` opcode.
 */
const WASM_OP_I64_SHR_S: byte = 0x87 to byte

/**
 * WASM_OP_I64_SHR_U — the wasm `i64.shr_u` opcode.
 */
const WASM_OP_I64_SHR_U: byte = 0x88 to byte

/**
 * WASM_OP_F32_NEG — the wasm `f32.neg` opcode.
 */
const WASM_OP_F32_NEG: byte = 0x8C to byte

/**
 * WASM_OP_F32_ADD — the wasm `f32.add` opcode.
 */
const WASM_OP_F32_ADD: byte = 0x92 to byte

/**
 * WASM_OP_F32_SUB — the wasm `f32.sub` opcode.
 */
const WASM_OP_F32_SUB: byte = 0x93 to byte

/**
 * WASM_OP_F32_MUL — the wasm `f32.mul` opcode.
 */
const WASM_OP_F32_MUL: byte = 0x94 to byte

/**
 * WASM_OP_F32_DIV — the wasm `f32.div` opcode.
 */
const WASM_OP_F32_DIV: byte = 0x95 to byte

/**
 * WASM_OP_F64_NEG — the wasm `f64.neg` opcode.
 */
const WASM_OP_F64_NEG: byte = 0x9A to byte

/**
 * WASM_OP_F64_ADD — the wasm `f64.add` opcode.
 */
const WASM_OP_F64_ADD: byte = 0xA0 to byte

/**
 * WASM_OP_F64_SUB — the wasm `f64.sub` opcode.
 */
const WASM_OP_F64_SUB: byte = 0xA1 to byte

/**
 * WASM_OP_F64_MUL — the wasm `f64.mul` opcode.
 */
const WASM_OP_F64_MUL: byte = 0xA2 to byte

/**
 * WASM_OP_F64_DIV — the wasm `f64.div` opcode.
 */
const WASM_OP_F64_DIV: byte = 0xA3 to byte

/**
 * WASM_OP_I32_WRAP_I64 — the wasm `i32.wrap_i64` opcode: narrows an `i64`
 * to `i32` by truncating its high bits (the wasm32 checked-narrow's own
 * final step, once the value is already known in-range).
 */
const WASM_OP_I32_WRAP_I64: byte = 0xA7 to byte

/**
 * WASM_OP_I32_TRUNC_F32_S — the wasm `i32.trunc_f32_s` opcode.
 */
const WASM_OP_I32_TRUNC_F32_S: byte = 0xA8 to byte

/**
 * WASM_OP_I32_TRUNC_F64_S — the wasm `i32.trunc_f64_s` opcode.
 */
const WASM_OP_I32_TRUNC_F64_S: byte = 0xAA to byte

/**
 * WASM_OP_I64_EXTEND_I32_U — the wasm `i64.extend_i32_u` opcode: widens an
 * `i32` register-space `Ptr` value up to the uniform 8-byte on-disk `i64`
 * shape (always lossless — an in-range wasm32 address is never negative).
 */
const WASM_OP_I64_EXTEND_I32_U: byte = 0xAD to byte

/**
 * WASM_OP_F32_DEMOTE_F64 — the wasm `f32.demote_f64` opcode.
 */
const WASM_OP_F32_DEMOTE_F64: byte = 0xB6 to byte

/**
 * WASM_OP_F64_CONVERT_I32_S — the wasm `f64.convert_i32_s` opcode.
 */
const WASM_OP_F64_CONVERT_I32_S: byte = 0xB7 to byte

/**
 * WASM_OP_F64_CONVERT_I64_S — the wasm `f64.convert_i64_s` opcode.
 */
const WASM_OP_F64_CONVERT_I64_S: byte = 0xB9 to byte

/**
 * WASM_OP_F64_PROMOTE_F32 — the wasm `f64.promote_f32` opcode.
 */
const WASM_OP_F64_PROMOTE_F32: byte = 0xBB to byte

/**
 * WASM_BLOCKTYPE_VOID — the wasm `[] -> []` blocktype byte every `block`/
 * `loop`/`if` in the MVP carries (no construct ever needs a value-type or
 * type-index blocktype, §3).
 */
const WASM_BLOCKTYPE_VOID: byte = 0x40 to byte

/**
 * WASM_EXPORT_KIND_FUNC — the wasm export-section `kind` byte naming a
 * function-index-space export (`objfile_wasm.tks`'s own `WasmExport.kind`
 * convention).
 */
const WASM_EXPORT_KIND_FUNC: byte = 0x00 to byte

/**
 * WASM_EXPORT_KIND_MEMORY — the wasm export-section `kind` byte naming a
 * memory-index-space export (the module's own `"memory"` export,
 * `wasm_memory_export`).
 */
const WASM_EXPORT_KIND_MEMORY: byte = 0x02 to byte

/**
 * WASM_U64_LOW32_MASK — the low-32-bits mask an `f64.const`'s raw IEEE754
 * bit pattern is split against before each 32-bit little-endian half is
 * emitted (`sc_f64_bits`): `bits & WASM_U64_LOW32_MASK` isolates the low
 * word, `bits >> 32` (untouched — a shift by exactly half of 64 needs no
 * separate name) the high one.
 */
const WASM_U64_LOW32_MASK: u64 = 0xFFFFFFFF to u64

/**
 * sc_byte — append one raw byte (an opcode, or a section/kind tag) to the
 * context's body.
 *
 * @param StackifyCtx ctx  the context to extend
 * @param byte b  the byte to append
 * @return StackifyCtx  the advanced context
 */
fn sc_byte(ctx: StackifyCtx, b: byte) -> StackifyCtx {
    StackifyCtx { body = teko::list::push(ctx.body, b); vtypes = ctx.vtypes; scopes = ctx.scopes; next_scratch = ctx.next_scratch; has_frame = ctx.has_frame; frame_base = ctx.frame_base; slots = ctx.slots; elide = ctx.elide; pending = ctx.pending }
}

/**
 * sc_uleb — append `v` to the context's body as unsigned LEB128 (a local
 * index, a memarg field, a funcidx).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u64 v  the value to encode
 * @return StackifyCtx  the advanced context
 */
fn sc_uleb(ctx: StackifyCtx, v: u64) -> StackifyCtx {
    StackifyCtx { body = emit_uleb128(ctx.body, v); vtypes = ctx.vtypes; scopes = ctx.scopes; next_scratch = ctx.next_scratch; has_frame = ctx.has_frame; frame_base = ctx.frame_base; slots = ctx.slots; elide = ctx.elide; pending = ctx.pending }
}

/**
 * sc_sleb — append `v` to the context's body as signed LEB128 (an
 * `i32.const`/`i64.const` immediate).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param i64 v  the signed value to encode
 * @return StackifyCtx  the advanced context
 */
fn sc_sleb(ctx: StackifyCtx, v: i64) -> StackifyCtx {
    StackifyCtx { body = emit_sleb128(ctx.body, v); vtypes = ctx.vtypes; scopes = ctx.scopes; next_scratch = ctx.next_scratch; has_frame = ctx.has_frame; frame_base = ctx.frame_base; slots = ctx.slots; elide = ctx.elide; pending = ctx.pending }
}

/**
 * sc_f64_bits — append `bits` to the context's body as the raw 8-byte
 * little-endian IEEE754 binary64 pattern (an `f64.const` immediate, which is
 * NOT LEB128-encoded).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u64 bits  the IEEE bit pattern to append
 * @return StackifyCtx  the advanced context
 */
fn sc_f64_bits(ctx: StackifyCtx, bits: u64) -> StackifyCtx {
    let lo = (bits & WASM_U64_LOW32_MASK) to u32
    let hi = (bits >> (32 to u64)) to u32
    StackifyCtx { body = emit_u32_le(emit_u32_le(ctx.body, lo), hi); vtypes = ctx.vtypes; scopes = ctx.scopes; next_scratch = ctx.next_scratch; has_frame = ctx.has_frame; frame_base = ctx.frame_base; slots = ctx.slots; elide = ctx.elide; pending = ctx.pending }
}

/**
 * sc_local_get — emit `local.get $vreg` (`0x20`): the VReg's own id IS its
 * local index (the "one wasm local per VReg" model, `backend-c1-wasm.md`
 * §4.1 — no separate VReg-to-local remap table is needed, since wasm's own
 * "params are the leading locals" convention already matches the LIR's own
 * "params are VRegs 0..n_params-1" convention).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 vreg  the VReg (and local index) to read
 * @return StackifyCtx  the advanced context
 */
fn sc_local_get(ctx: StackifyCtx, vreg: u32) -> StackifyCtx {
    sc_uleb(sc_byte(ctx, WASM_OP_LOCAL_GET), vreg to u64)
}

/**
 * sc_local_set — emit `local.set $vreg` (`0x21`).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 vreg  the VReg (and local index) to write
 * @return StackifyCtx  the advanced context
 */
fn sc_local_set(ctx: StackifyCtx, vreg: u32) -> StackifyCtx {
    sc_uleb(sc_byte(ctx, WASM_OP_LOCAL_SET), vreg to u64)
}

/**
 * sc_local_tee — emit `local.tee $vreg` (`0x22`): sets the local like
 * `local.set` but leaves the value on the operand stack too — the shadow-
 * stack prologue's own "compute the new `SP`, capture it into `frame_base`,
 * AND still have it on the stack to feed `global.set`" step (§6.1).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 vreg  the VReg (and local index) to write-and-keep
 * @return StackifyCtx  the advanced context
 */
fn sc_local_tee(ctx: StackifyCtx, vreg: u32) -> StackifyCtx {
    sc_uleb(sc_byte(ctx, WASM_OP_LOCAL_TEE), vreg to u64)
}

/**
 * ElideKind — the value-stack peephole's own `ElideTable` tag: `Normal` (the
 * ALL-LOCALS baseline, §5 — `local.set` at def, `local.get` at every use,
 * unchanged from the pre-C1-5 shape; the DEFAULT tag every unset
 * `ElideTable` position reads as), `Drop` (a value fully riding the operand
 * stack — §5's SINGLE-USE + SAME-BLOCK + LIFO + NO-BARRIER case — NEITHER
 * `local.set` at def NOR `local.get` at its one confirmed use), or `Tee` (a
 * value that rides the operand stack into its one confirmed in-block
 * computational use WHILE ALSO persisting to a local for a separate
 * edge-copy use — §5's "`local.tee` where the value must ALSO persist to a
 * local" case). Purely an internal decision tag — never serialized to wasm
 * bytes — so no wire mapping is needed.
 *
 * @since #389 C1-5
 */
pub type ElideKind = enum { Normal; Drop; Tee }

/**
 * ElideTable — the whole-function value-stack peephole decision table (§5):
 * each VReg's final `ElideKind` tag, densely indexed by VReg id exactly
 * like `WasmVTypeTable`/`WasmSlotTable` (PARALLELED rather than reused,
 * §1.3's own discipline — a decision tag is not a valtype byte or a frame
 * offset). Built ONCE, ahead of lowering, by `compute_func_elide`; every
 * unset position defaults to `ElideKind::Normal`, so a caller that never
 * builds one (every fine-grained per-instruction unit test in
 * `stackify_test.tkt`) transparently keeps exercising the ALL-LOCALS
 * baseline.
 *
 * @since #389 C1-5
 */
type ElideTable = struct {
    /**
     * kinds — each recorded VReg's final `ElideKind` tag, positionally
     * indexed by VReg id.
     */
    kinds: []ElideKind
}

/**
 * et_empty — a decision table with no VRegs recorded yet (every position
 * defaults to `ElideKind::Normal`).
 *
 * @return ElideTable  the empty table
 * @since #389 C1-5
 */
fn et_empty() -> ElideTable {
    ElideTable { kinds = teko::list::empty() }
}

/**
 * et_grow — pad `t` with placeholder `ElideKind::Normal` entries until it
 * holds at least `n` positions (mirrors `wvt_grow`).
 *
 * @param ElideTable t  the table to pad
 * @param u64 n  the minimum length the padded table must reach
 * @return ElideTable  the padded table
 * @since #389 C1-5
 */
fn et_grow(t: ElideTable, n: u64) -> ElideTable {
    mut ks = t.kinds
    loop {
        if ks.len >= n { break }
        ks = teko::list::push(ks, ElideKind::Normal)
    }
    ElideTable { kinds = ks }
}

/**
 * et_set — record `kind` as the final decision for VReg `id`, growing the
 * table first when needed (mirrors `wvt_set`).
 *
 * @param ElideTable t0  the table to update
 * @param u32 id  the VReg id being recorded
 * @param ElideKind kind  its final decision tag
 * @return ElideTable  the updated table
 * @since #389 C1-5
 */
fn et_set(t0: ElideTable, id: u32, kind: ElideKind) -> ElideTable {
    let grown = et_grow(t0, (id to u64) + 1)
    mut out: []ElideKind = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= grown.kinds.len { break }
        out = teko::list::push(out, if (i to u32) == id { kind } else { grown.kinds[i] })
        i++
    }
    ElideTable { kinds = out }
}

/**
 * et_get — the recorded decision for VReg `id`, or `ElideKind::Normal` when
 * `id` was never recorded (mirrors `wvt_get`).
 *
 * @param ElideTable t  the table to read
 * @param u32 id  the VReg id to look up
 * @return ElideKind  its recorded (or default) decision tag
 * @since #389 C1-5
 */
fn et_get(t: ElideTable, id: u32) -> ElideKind {
    let i = id to u64
    if i >= t.kinds.len { return ElideKind::Normal }
    t.kinds[i]
}

/**
 * u32_stack_top — the last element of `xs` (§5's own live `ctx.pending`
 * mirror, LIFO top), or `u32_unset()` when `xs` is empty (mirrors `u32_pos`'
 * own defensive sentinel default — no real VReg id collides with it in any
 * function small enough to compile).
 *
 * @param []u32 xs  the stack to read
 * @return u32  its top element, or the sentinel
 * @since #389 C1-5
 */
fn u32_stack_top(xs: []u32) -> u32 {
    if xs.len == 0 { return u32_unset() }
    xs[xs.len - 1]
}

/**
 * u32_stack_pop — `xs` with its own top element removed (a no-op when
 * already empty).
 *
 * @param []u32 xs  the stack to shrink
 * @return []u32  `xs` minus its last element
 * @since #389 C1-5
 */
fn u32_stack_pop(xs: []u32) -> []u32 {
    let keep = if xs.len == 0 { 0 to u64 } else { xs.len - 1 }
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= keep { break }
        out = teko::list::push(out, xs[i])
        i++
    }
    out
}

/**
 * u32_stack_pop_n — `xs` with its own LAST `n` elements removed (a no-op
 * past-the-end `n` clamps to emptying `xs`).
 *
 * @param []u32 xs  the stack to shrink
 * @param u64 n  how many trailing elements to remove
 * @return []u32  `xs` minus its last `n` elements
 * @since #389 C1-5
 */
fn u32_stack_pop_n(xs: []u32, n: u64) -> []u32 {
    let keep = if xs.len <= n { 0 to u64 } else { xs.len - n }
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= keep { break }
        out = teko::list::push(out, xs[i])
        i++
    }
    out
}

/**
 * pending_match_run — how many LEADING entries of `reversed_reads` (an
 * instruction's own operand VRegs, in REVERSE push order) match `pending`'s
 * own top, consecutively, popping virtually as it goes (mirrors the static
 * analysis's own `resolve_inst_operands`, §5 condition 3 — the "reverse
 * scan, stop at the first mismatch" contiguous-suffix rule). The caller
 * (`sc_use_operands`) uses this count to split the operand list into the
 * trailing run that rides the stack for free and the leading run that does
 * not.
 *
 * @param []u32 pending  the live pending mirror (`ctx.pending`)
 * @param []u32 reversed_reads  the operand VRegs, in REVERSE push order
 * @return u64  how many trailing (in push order) operands matched
 * @since #389 C1-5
 */
fn pending_match_run(pending0: []u32, reversed_reads: []u32) -> u64 {
    mut pending = pending0
    mut i: u64 = 0
    loop {
        if i >= reversed_reads.len { break }
        if u32_stack_top(pending) != reversed_reads[i] { break }
        pending = u32_stack_pop(pending)
        i++
    }
    i
}

/**
 * sc_use_operands — the value-stack peephole's own OPERAND-READ entry point
 * (§5): resolve `vregs` (one instruction's own operand VRegs, in push
 * order) against `ctx0.pending` as ONE unit, mirroring `compute_block_
 * elide`'s own static `resolve_inst_operands` exactly — an ALL-OR-NOTHING
 * match: only when EVERY one of `vregs` matches `pending`'s own top `len
 * (vregs)` entries, in order, do they ALL ride the stack (popped, no bytes
 * emitted for any of them). Any partial match is treated as NO match at
 * all — every operand is fetched fresh, `sc_local_get`, in push order —
 * because a partial ride would leave the FRESH operands' own `local.get`
 * pushed ON TOP of the still-riding one, inverting the two relative to each
 * other on the real wasm stack (§5's own miscompile finding: a partial
 * match on a non-commutative op like `ISub` silently swaps the operand
 * order). A single independent top-of-`pending` check per operand (`a`
 * then `b`) is ALSO unsound for the identical reason, which is why every
 * multi-operand call site (`LBin`/`LStore`/`LCall`) routes through this
 * batched, all-or-nothing form rather than one `sc_use_operands([v])` per
 * operand.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param []u32 vregs  the operand VRegs, in push order
 * @return StackifyCtx  the advanced context
 * @since #389 C1-5
 */
fn sc_use_operands(ctx0: StackifyCtx, vregs: []u32) -> StackifyCtx {
    let run = pending_match_run(ctx0.pending, u32_list_reverse(vregs))
    let k = if run == vregs.len { run } else { 0 to u64 }
    let consumed = StackifyCtx { body = ctx0.body; vtypes = ctx0.vtypes; scopes = ctx0.scopes; next_scratch = ctx0.next_scratch; has_frame = ctx0.has_frame; frame_base = ctx0.frame_base; slots = ctx0.slots; elide = ctx0.elide; pending = u32_stack_pop_n(ctx0.pending, k) }
    let fresh_count = vregs.len - k
    mut ctx = consumed
    mut i: u64 = 0
    loop {
        if i >= fresh_count { break }
        ctx = sc_local_get(ctx, vregs[i])
        i++
    }
    ctx
}

/**
 * sc_use_operand — the value-stack peephole's own SINGLE-OPERAND read entry
 * point (§5): `sc_use_operands` specialized to one operand — safe on its
 * own for a one-operand instruction (`LUn`/`LFieldAddr`/`LLoad`'s `addr`/
 * `LRet`'s `value`/`LBranch`'s `cond`), where there is no "later operand"
 * ordering hazard to account for.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param u32 vreg  the VReg operand to read
 * @return StackifyCtx  the advanced context
 * @since #389 C1-5
 */
fn sc_use_operand(ctx0: StackifyCtx, vreg: u32) -> StackifyCtx {
    sc_use_operands(ctx0, [vreg])
}

/**
 * sc_def_result — the value-stack peephole's own RESULT-DEFINITION entry
 * point (§5): consult `ctx0.elide` for `vreg`'s FINAL decision
 * (`compute_func_elide`) — `Drop` emits NEITHER `local.set` NOR anything
 * else (the value stays raw on the operand stack; `ctx.pending` grows so
 * its one confirmed use finds it via `sc_use_operand`); `Tee` emits
 * `local.tee` (writes the local AND leaves the value on the stack for its
 * own confirmed in-block use, while still persisting it for the SEPARATE
 * edge-copy use `emit_edge_copies` reads back out of the local); `Normal`
 * emits the ALL-LOCALS baseline's plain `local.set`. Every case records
 * `vt` in the valtype side-table regardless (`sc_set_vtype` — even an
 * elided value's own class must still be resolvable, e.g. `stackify_bin`'s
 * own `wvt_get` reads of an already-lowered operand).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param u32 vreg  the VReg being defined
 * @param u8 vt  its wasm valtype byte
 * @return StackifyCtx  the advanced context
 * @since #389 C1-5
 */
fn sc_def_result(ctx0: StackifyCtx, vreg: u32, vt: u8) -> StackifyCtx {
    let kind = et_get(ctx0.elide, vreg)
    let typed = sc_set_vtype(ctx0, vreg, vt)
    if kind == ElideKind::Drop {
        return StackifyCtx { body = typed.body; vtypes = typed.vtypes; scopes = typed.scopes; next_scratch = typed.next_scratch; has_frame = typed.has_frame; frame_base = typed.frame_base; slots = typed.slots; elide = typed.elide; pending = teko::list::push(typed.pending, vreg) }
    }
    if kind == ElideKind::Tee {
        let teed = sc_local_tee(typed, vreg)
        return StackifyCtx { body = teed.body; vtypes = teed.vtypes; scopes = teed.scopes; next_scratch = teed.next_scratch; has_frame = teed.has_frame; frame_base = teed.frame_base; slots = teed.slots; elide = teed.elide; pending = teko::list::push(teed.pending, vreg) }
    }
    sc_local_set(typed, vreg)
}

/**
 * wasm_sp_global_index — the shadow-stack `SP` global's module-wide index.
 * The MVP declares no other backend-internal global and no LIR-level
 * `LGlobal` ever lowers to a wasm global (`wasm_honest_globals`, C1-4), so
 * `SP` is always the FIRST (and only) entry of a module's global section —
 * a safe compile-time constant for the whole slice.
 *
 * @return u32  the `SP` global's index (`0`)
 */
pub fn wasm_sp_global_index() -> u32 {
    0 to u32
}

/**
 * wasm_sp_global — build the shadow-stack `SP` global's own module-level
 * declaration (`objfile_wasm.tks`'s `WasmGlobal`): a mutable `i32`
 * initialized to `init` (§6.1 — "top of the reserved stack region", a
 * whole-module memory-layout decision left to the caller, C1-5 territory).
 *
 * @param i64 init  the `SP` global's initial value
 * @return WasmGlobal  the `SP` global declaration
 */
pub fn wasm_sp_global(init: i64) -> WasmGlobal {
    WasmGlobal { valtype = wasm_vtype_wire(WasmVType::I32); mutable = true; init = init }
}

/**
 * sc_global_get — emit `global.get $idx` (`0x23`).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 idx  the global index to read
 * @return StackifyCtx  the advanced context
 */
fn sc_global_get(ctx: StackifyCtx, idx: u32) -> StackifyCtx {
    sc_uleb(sc_byte(ctx, WASM_OP_GLOBAL_GET), idx to u64)
}

/**
 * sc_global_set — emit `global.set $idx` (`0x24`).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 idx  the global index to write
 * @return StackifyCtx  the advanced context
 */
fn sc_global_set(ctx: StackifyCtx, idx: u32) -> StackifyCtx {
    sc_uleb(sc_byte(ctx, WASM_OP_GLOBAL_SET), idx to u64)
}

/**
 * sc_set_vtype — record `vt` as VReg `vreg`'s wasm valtype in the context's
 * side-table, without touching the emitted body bytes.
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 vreg  the VReg being recorded
 * @param u8 vt  its wasm valtype byte
 * @return StackifyCtx  the advanced context
 */
fn sc_set_vtype(ctx: StackifyCtx, vreg: u32, vt: u8) -> StackifyCtx {
    StackifyCtx { body = ctx.body; vtypes = wvt_set(ctx.vtypes, vreg, vt); scopes = ctx.scopes; next_scratch = ctx.next_scratch; has_frame = ctx.has_frame; frame_base = ctx.frame_base; slots = ctx.slots; elide = ctx.elide; pending = ctx.pending }
}

/**
 * sc_memarg — append a wasm memory-instruction's trailing `align, offset`
 * pair (both ULEB128), shared by every load/store lowering.
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 align  the alignment hint (log2 of the natural access width)
 * @param u32 offset  the constant byte offset (always `0` in the MVP — any
 *                     static field offset is already folded into the
 *                     address by a preceding `LFieldAddr`)
 * @return StackifyCtx  the advanced context
 */
fn sc_memarg(ctx: StackifyCtx, align: u32, offset: u32) -> StackifyCtx {
    sc_uleb(sc_uleb(ctx, align to u64), offset to u64)
}

/**
 * wasm_blocktype_void — the `0x40` blocktype byte every `block`/`loop`/`if`
 * in the MVP carries: `[] -> []` (no operand-stack value crosses a scope
 * boundary — block-args cross edges as local copies instead, §4.3), so no
 * construct ever needs a value-type or type-index blocktype.
 *
 * @return byte  the void blocktype byte
 */
fn wasm_blocktype_void() -> byte {
    WASM_BLOCKTYPE_VOID
}

/**
 * sc_open_block — emit a `block` opcode (`0x02`) + void blocktype, and open
 * a matching `WasmScope` labelled `label_block` on the context's scope
 * stack (a forward exit target: a `br` reaching it jumps to its `end`).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 label_block  the LIR block id this scope's label targets
 * @return StackifyCtx  the advanced, scope-extended context
 */
fn sc_open_block(ctx: StackifyCtx, label_block: u32) -> StackifyCtx {
    let opened = sc_byte(sc_byte(ctx, WASM_OP_BLOCK), wasm_blocktype_void())
    StackifyCtx { body = opened.body; vtypes = opened.vtypes; scopes = wasm_scope_stack_push(opened.scopes, WasmScopeKind::Block, label_block); next_scratch = opened.next_scratch; has_frame = opened.has_frame; frame_base = opened.frame_base; slots = opened.slots; elide = opened.elide; pending = opened.pending }
}

/**
 * sc_open_loop — emit a `loop` opcode (`0x03`) + void blocktype, and open a
 * matching `WasmScope` labelled `label_block` (a back-edge target: a `br`
 * reaching it jumps to its OWN start, i.e. `continue`).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 label_block  the loop header's own LIR block id
 * @return StackifyCtx  the advanced, scope-extended context
 */
fn sc_open_loop(ctx: StackifyCtx, label_block: u32) -> StackifyCtx {
    let opened = sc_byte(sc_byte(ctx, WASM_OP_LOOP), wasm_blocktype_void())
    StackifyCtx { body = opened.body; vtypes = opened.vtypes; scopes = wasm_scope_stack_push(opened.scopes, WasmScopeKind::Loop, label_block); next_scratch = opened.next_scratch; has_frame = opened.has_frame; frame_base = opened.frame_base; slots = opened.slots; elide = opened.elide; pending = opened.pending }
}

/**
 * sc_open_if — emit an `if` opcode (`0x04`) + void blocktype, and open a
 * matching (unlabelled) `WasmScope` — it only occupies a depth slot; its
 * own natural fallthrough past `else`/`end` IS the merge, so it is never a
 * `br` target.
 *
 * @param StackifyCtx ctx  the context to extend
 * @return StackifyCtx  the advanced, scope-extended context
 */
fn sc_open_if(ctx: StackifyCtx) -> StackifyCtx {
    let opened = sc_byte(sc_byte(ctx, WASM_OP_IF), wasm_blocktype_void())
    StackifyCtx { body = opened.body; vtypes = opened.vtypes; scopes = wasm_scope_stack_push(opened.scopes, WasmScopeKind::If, 0 to u32); next_scratch = opened.next_scratch; has_frame = opened.has_frame; frame_base = opened.frame_base; slots = opened.slots; elide = opened.elide; pending = opened.pending }
}

/**
 * sc_close_scope — emit the closing `end` (`0x0B`) for the innermost open
 * scope, and pop it off the context's scope stack (shared by `block`/
 * `loop`/`if` — they all close the same way).
 *
 * @param StackifyCtx ctx  the context to extend
 * @return StackifyCtx  the advanced, scope-shrunk context
 */
fn sc_close_scope(ctx: StackifyCtx) -> StackifyCtx {
    let closed = sc_byte(ctx, WASM_OP_END)
    StackifyCtx { body = closed.body; vtypes = closed.vtypes; scopes = wasm_scope_stack_pop(closed.scopes); next_scratch = closed.next_scratch; has_frame = closed.has_frame; frame_base = closed.frame_base; slots = closed.slots; elide = closed.elide; pending = closed.pending }
}

/**
 * sc_br — emit an unconditional `br` (`0x0C`) to the scope `depth` levels
 * out (§3.3's label-depth arithmetic).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 depth  the relative scope depth to branch to
 * @return StackifyCtx  the advanced context
 */
fn sc_br(ctx: StackifyCtx, depth: u32) -> StackifyCtx {
    sc_uleb(sc_byte(ctx, WASM_OP_BR), depth to u64)
}

/**
 * ScratchAlloc — a freshly reserved parallel-copy staging local (§4.3): its
 * id and the context advanced past the reservation (its valtype already
 * recorded).
 */
type ScratchAlloc = struct {
    /**
     * ctx — the context with the scratch id's valtype recorded and
     * `next_scratch` advanced past it.
     */
    ctx: StackifyCtx
    /**
     * id — the freshly reserved scratch local id.
     */
    id: u32
}

/**
 * sc_alloc_scratch — reserve one fresh scratch local of valtype `vt`: a
 * local id no real LIR VReg ever uses (`next_scratch` starts at the
 * function's own `next_vreg` and only grows), used to stage a value through
 * a parallel-copy edge without ever aliasing a real destination (§4.3).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param u8 vt  the scratch local's wasm valtype
 * @return ScratchAlloc  the reserved id + the advanced context
 */
fn sc_alloc_scratch(ctx0: StackifyCtx, vt: u8) -> ScratchAlloc {
    let id = ctx0.next_scratch
    let ctx1 = StackifyCtx { body = ctx0.body; vtypes = wvt_set(ctx0.vtypes, id, vt); scopes = ctx0.scopes; next_scratch = id + 1; has_frame = ctx0.has_frame; frame_base = ctx0.frame_base; slots = ctx0.slots; elide = ctx0.elide; pending = ctx0.pending }
    ScratchAlloc { ctx = ctx1; id = id }
}

/**
 * sc_set_frame — record `frame_base`/`slots` as this context's own shadow-
 * stack frame (`has_frame` becomes `true`), without touching the emitted
 * body bytes (the prologue itself already emitted its own bytes via
 * `sc_global_get`/`sc_local_tee`/`sc_global_set` before this call records
 * the frame).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param u32 frame_base  the scratch local holding this call's frame base
 * @param WasmSlotTable slots  the function's whole `LAlloca` frame layout
 * @return StackifyCtx  the frame-recording context
 */
fn sc_set_frame(ctx: StackifyCtx, frame_base: u32, slots: WasmSlotTable) -> StackifyCtx {
    StackifyCtx { body = ctx.body; vtypes = ctx.vtypes; scopes = ctx.scopes; next_scratch = ctx.next_scratch; has_frame = true; frame_base = frame_base; slots = slots; elide = ctx.elide; pending = ctx.pending }
}

/**
 * wasm_align_up — round `x` up to the next multiple of `a` (the shadow-
 * stack frame-slot packing step, mirroring `encode_arm64.tks`'s own
 * `align_up`, PARALLELED rather than reused per the wasm-specific
 * discipline, `backend-c1-wasm.md` §1.3). A no-op when `a` is `0`/`1`.
 *
 * @param u32 x  the value to round
 * @param u32 a  the alignment (a power of two, or 0/1 for none)
 * @return u32  the least multiple of `a` not less than `x`
 */
fn wasm_align_up(x: u32, a: u32) -> u32 {
    if a <= 1 { return x }
    (((x + a) - (1 to u32)) / a) * a
}

/**
 * wasm_align_down_i32 — append the `i32.and`-with-a-negative-power-of-two-
 * mask idiom that rounds the `i32` value currently on the operand stack DOWN
 * to a multiple of `align` (`x & -align` — the two's-complement identity `-a
 * == ~(a-1)` for a power-of-two `a`, §6.1's "`align_down(SP - bytes,
 * align)`"). A no-op when `align` is `0`/`1` (mirrors `wasm_align_up`'s own
 * guard).
 *
 * @param StackifyCtx ctx0  the context to extend (a value already on the
 *                          operand stack)
 * @param u32 align  the alignment to round down to
 * @return StackifyCtx  the advanced context
 */
fn wasm_align_down_i32(ctx0: StackifyCtx, align: u32) -> StackifyCtx {
    if align <= 1 { return ctx0 }
    let ctx1 = sc_sleb(sc_byte(ctx0, WASM_OP_I32_CONST), -(align to i64))
    sc_byte(ctx1, WASM_OP_I32_AND)
}

/**
 * inst_is_alloca — whether `inst` is an `LAlloca` (the frame-layout
 * pre-scan's own per-instruction test, mirrors `encode_arm64.tks`'s
 * `inst_is_call`/`inst_is_ret`).
 *
 * @param LInst inst  the instruction to test
 * @return bool  true iff `inst.op` is `LAlloca`
 */
fn inst_is_alloca(inst: lir::LInst) -> bool {
    match inst.op {
        lir::LAlloca => true
        _ => false
    }
}

/**
 * alloca_of — `inst`'s own `LAlloca` payload (a well-formed-caller
 * precondition: only ever called on an instruction `inst_is_alloca` already
 * confirmed); an all-zero placeholder on any other case, so the function
 * stays total without a caller-facing error.
 *
 * @param LInst inst  the instruction (assumed `LAlloca`)
 * @return LAlloca  its payload, or an all-zero placeholder
 */
fn alloca_of(inst: lir::LInst) -> lir::LAlloca {
    match inst.op {
        lir::LAlloca as a => a
        _ => lir::LAlloca { bytes = 0 to u32; align = 1 to u32 }
    }
}

/**
 * collect_alloca_insts — every `LAlloca` instruction in `f`, in block-array/
 * instruction order (a deterministic, if not necessarily CFG-traversal-
 * order, scan — sufficient because each slot is keyed by its own VReg id,
 * §the `WasmSlotTable` doc, not by scan position).
 *
 * @param LFunc f  the function to scan
 * @return []LInst  every `LAlloca` instruction found, in scan order
 */
fn collect_alloca_insts(f: lir::LFunc) -> []lir::LInst {
    mut out: []lir::LInst = teko::list::empty()
    mut bi: u64 = 0
    loop {
        if bi >= f.blocks.len { break }
        let insts = f.blocks[bi].insts
        mut ii: u64 = 0
        loop {
            if ii >= insts.len { break }
            if inst_is_alloca(insts[ii]) { out = teko::list::push(out, insts[ii]) }
            ii++
        }
        bi++
    }
    out
}

/**
 * WasmFrameLayout — one function's whole static shadow-stack frame
 * (`compute_wasm_frame_layout`): every `LAlloca` site's own frame-base-
 * relative offset (`WasmSlotTable`), the total frame size the ONE prologue
 * bump reserves, and the frame's own alignment (the largest `align` among
 * its slots — the standard "align the whole frame to its most-aligned
 * member" packing rule).
 */
type WasmFrameLayout = struct {
    /**
     * slots — every `LAlloca` VReg's own frame-base-relative offset.
     */
    slots: WasmSlotTable
    /**
     * frame_size — the total frame byte size (the prologue's `SP -=
     * frame_size`), rounded up to `frame_align`.
     */
    frame_size: u32
    /**
     * frame_align — the largest `align` among the function's own `LAlloca`
     * sites (`1` when the list is empty — never read in that case, since
     * `stackify_control` skips the whole prologue).
     */
    frame_align: u32
}

/**
 * compute_wasm_frame_layout — lay out `allocas` bottom-up (`wasm_align_up`
 * between consecutive slots, exactly mirroring `encode_arm64.tks`'s own
 * `compute_slot_offsets`): every Teko `LAlloca` carries a compile-time-
 * constant `bytes`/`align` (no VLA), so the WHOLE function's frame can be
 * sized and packed ONCE, ahead of lowering — the design that keeps a loop-
 * body `LAlloca` correct (its slot is FIXED across iterations, never a
 * fresh runtime bump per pass, the `WasmSlotTable` doc's own rationale).
 *
 * @param []LInst allocas  every `LAlloca` instruction in the function
 *                         (`collect_alloca_insts`)
 * @return WasmFrameLayout  the packed per-slot offsets + the frame's own
 *                           total size/alignment
 */
fn compute_wasm_frame_layout(allocas: []lir::LInst) -> WasmFrameLayout {
    mut t = wst_empty()
    mut running: u32 = 0
    mut max_align: u32 = 1
    mut i: u64 = 0
    loop {
        if i >= allocas.len { break }
        let a = alloca_of(allocas[i])
        let at = wasm_align_up(running, a.align)
        t = wst_set(t, allocas[i].result, at)
        running = at + a.bytes
        if a.align > max_align { max_align = a.align }
        i++
    }
    WasmFrameLayout { slots = t; frame_size = wasm_align_up(running, max_align); frame_align = max_align }
}

/**
 * emit_frame_prologue — reserve a fresh scratch local (`frame_base`) and
 * emit the shadow-stack prologue that fills it: `global.get $SP; i32.const
 * frame_size; i32.sub; [align_down]; local.tee $frame_base; global.set $SP`
 * (`backend-c1-wasm.md` §6.1's shadow-stack bump, realized ONCE per call
 * rather than once per `LAlloca` site — the task's own "prólogo/epílogo de
 * função ajustam o SP" shape). Every individual `LAlloca` site
 * (`stackify_alloca`) then just adds its own precomputed offset to
 * `frame_base` — pure compile-time-constant arithmetic, no further `SP`
 * mutation.
 *
 * @param StackifyCtx ctx0  the context to extend (BEFORE any body lowering)
 * @param WasmFrameLayout layout  the function's whole frame layout
 * @return StackifyCtx  the advanced, frame-recording context
 */
fn emit_frame_prologue(ctx0: StackifyCtx, layout: WasmFrameLayout) -> StackifyCtx {
    let reserved = sc_alloc_scratch(ctx0, wasm_vtype_wire(WasmVType::I32))
    let ctx1 = sc_global_get(reserved.ctx, wasm_sp_global_index())
    let ctx2 = sc_sleb(sc_byte(ctx1, WASM_OP_I32_CONST), layout.frame_size to i64)
    let ctx3 = sc_byte(ctx2, WASM_OP_I32_SUB)
    let ctx4 = wasm_align_down_i32(ctx3, layout.frame_align)
    let ctx5 = sc_local_tee(ctx4, reserved.id)
    let ctx6 = sc_global_set(ctx5, wasm_sp_global_index())
    sc_set_frame(ctx6, reserved.id, layout.slots)
}

/**
 * emit_frame_epilogue — restore `SP` from `frame_base` (`local.get
 * $frame_base; global.set $SP`) before every `LRet` — a no-op when the
 * function reserves no frame (`!ctx0.has_frame`). Required regardless of
 * loops: without it, every REPEATED CALL to the same function would bump
 * `SP` again without ever giving the space back, eventually exhausting the
 * shadow-stack region.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @return StackifyCtx  the advanced context (unchanged when frameless)
 */
fn emit_frame_epilogue(ctx0: StackifyCtx) -> StackifyCtx {
    if !ctx0.has_frame { return ctx0 }
    let ctx1 = sc_local_get(ctx0, ctx0.frame_base)
    sc_global_set(ctx1, wasm_sp_global_index())
}

/**
 * emit_single_copy — the one-param edge-copy fast path: `local.get $arg;
 * local.set $param` (no interference is possible with a single pair, so no
 * staging is needed).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param u32 param  the destination block-param VReg
 * @param u32 arg  the source VReg
 * @return StackifyCtx  the advanced context
 */
fn emit_single_copy(ctx0: StackifyCtx, param: u32, arg: u32) -> StackifyCtx {
    let vt = wvt_get(ctx0.vtypes, arg)
    let moved = sc_local_set(sc_local_get(ctx0, arg), param)
    sc_set_vtype(moved, param, vt)
}

/**
 * StagedSources — the phase-1 outcome of a multi-param edge copy: the
 * context advanced past every source materialization, plus the ordered
 * list of fresh scratch ids each source now lives in.
 */
type StagedSources = struct {
    /**
     * ctx — the context after every source has been copied into its own
     * scratch local.
     */
    ctx: StackifyCtx
    /**
     * scratches — each source's scratch local id, parallel to the original
     * `args` list.
     */
    scratches: []u32
}

/**
 * stage_sources — phase 1 of a parallel-copy-safe multi-param edge copy:
 * materialize every source VReg into its OWN fresh scratch local, in order
 * (`sc_alloc_scratch`), before any destination param is written — this is
 * what makes the SECOND phase (`commit_scratches`) safe even when a
 * destination param aliases a LATER source (the classic swap hazard a
 * loop-carried multi-scalar back-edge can produce, `promote_env`,
 * `lower.tks`).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param []u32 args  the source VRegs, in target-param order
 * @return StagedSources  the advanced context + the parallel scratch ids
 */
fn stage_sources(ctx0: StackifyCtx, args: []u32) -> StagedSources {
    mut ctx = ctx0
    mut scratches: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= args.len { break }
        let vt = wvt_get(ctx.vtypes, args[i])
        let got = sc_local_get(ctx, args[i])
        let alloc = sc_alloc_scratch(got, vt)
        ctx = sc_local_set(alloc.ctx, alloc.id)
        scratches = teko::list::push(scratches, alloc.id)
        i++
    }
    StagedSources { ctx = ctx; scratches = scratches }
}

/**
 * commit_scratches — phase 2 of a parallel-copy-safe multi-param edge copy:
 * copy each staged scratch (`stage_sources`) into its real destination
 * param, in order. Every source was ALREADY captured in phase 1, so this
 * phase can freely overwrite a param that some OTHER source also happened
 * to alias, without losing its old value.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param []u32 params  the destination block-param VRegs
 * @param []u32 scratches  each param's staged scratch id (`stage_sources`)
 * @return StackifyCtx  the advanced context
 */
fn commit_scratches(ctx0: StackifyCtx, params: []u32, scratches: []u32) -> StackifyCtx {
    mut ctx = ctx0
    mut i: u64 = 0
    loop {
        if i >= params.len { break }
        let vt = wvt_get(ctx.vtypes, scratches[i])
        let moved = sc_local_set(sc_local_get(ctx, scratches[i]), params[i])
        ctx = sc_set_vtype(moved, params[i], vt)
        i++
    }
    ctx
}

/**
 * emit_staged_copies — the multi-param (`>= 2`) edge-copy path: stage every
 * source into its own scratch (`stage_sources`), then commit every scratch
 * into its real destination (`commit_scratches`) — the always-correct
 * "materialize everything, then assign everything" parallel-copy
 * sequentialization (§4.3), sidestepping any need to detect interference
 * cycles.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param []u32 params  the destination block-param VRegs
 * @param []u32 args  the source VRegs, parallel to `params`
 * @return StackifyCtx  the advanced context
 */
fn emit_staged_copies(ctx0: StackifyCtx, params: []u32, args: []u32) -> StackifyCtx {
    let staged = stage_sources(ctx0, args)
    commit_scratches(staged.ctx, params, staged.scratches)
}

/**
 * emit_edge_copies — cross one `LJump`/`LBranch` edge's block-args into its
 * target's params (§4.3): a plain single copy for the (current, always
 * `<= 1` in a merge's own SSA-lite phi, but a loop's PROMOTED env can carry
 * several, `promote_env`) common single-param case, or the parallel-copy-
 * safe staged form once two or more params are involved.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param []u32 params  the target block's params
 * @param []u32 args  the edge's own argument VRegs, parallel to `params`
 * @return StackifyCtx | error  the advanced context, or a NAMED internal
 *                              error when the two lists' arity disagrees
 */
fn emit_edge_copies(ctx0: StackifyCtx, params: []u32, args: []u32) -> StackifyCtx | error {
    if params.len != args.len {
        return error { message = "stackify: block-arg/param arity mismatch (internal)" }
    }
    if params.len == 0 { return ctx0 }
    if params.len == 1 { return emit_single_copy(ctx0, params[0], args[0]) }
    emit_staged_copies(ctx0, params, args)
}

/**
 * stackify_max_i32 — `i32::MAX` (`2147483647`) as an i128, the upper bound
 * of the "does this constant fit i32" test (`stackify_fits_i32`).
 *
 * @return i128  i32::MAX
 */
fn stackify_max_i32() -> i128 {
    2147483647 to i128
}

/**
 * stackify_min_i32 — `i32::MIN`, computed as `-(i32::MAX) - 1` so no literal
 * names the boundary value directly (mirrors `isel_arm64.tks`'s
 * `min_i64_i128` pattern).
 *
 * @return i128  i32::MIN
 */
fn stackify_min_i32() -> i128 {
    -(stackify_max_i32()) - (1 to i128)
}

/**
 * stackify_fits_i32 — true iff `v` lies within the i32 range: the test that
 * picks a `LConstInt`'s wasm width. A constant with no other type
 * information defaults to the NARROWEST no-information-loss wasm width —
 * `i32` (wasm32's own native word size, matching `Ptr`'s own collapse to
 * `i32`) rather than arm64 isel's "always widest" default, because unlike a
 * physical register a wasm local's declared type cannot be reinterpreted
 * later: choosing `i32` whenever the value fits keeps every ordinary
 * literal (the `exit`/arith corpus) in the natural wasm32 family.
 *
 * @param i128 v  the value to check
 * @return bool  whether `v` fits an i32
 */
fn stackify_fits_i32(v: i128) -> bool {
    v >= stackify_min_i32() && v <= stackify_max_i32()
}

/**
 * WasmMemOp — one `LType`'s resolved memory-access shape: the load opcode
 * (zero-extending for a sub-32 width, per `isel_arm64.tks`'s own
 * `select_load` convention — "a narrow value's own producing Trunc/ZExt/
 * SExt chain already fixed its class, so the load itself does not re-sign"),
 * the (single, sign-agnostic) store opcode, the natural-alignment hint, and
 * the resulting wasm valtype. The single source of truth `stackify_load`/
 * `stackify_store` both key off `LLoad.ty`/`LStore.ty`.
 */
type WasmMemOp = struct {
    /**
     * load_op — the wasm load opcode byte for this machine class.
     */
    load_op: byte
    /**
     * store_op — the wasm store opcode byte for this machine class.
     */
    store_op: byte
    /**
     * align — the memarg alignment hint (log2 of the natural access width).
     */
    align: u32
    /**
     * valtype — the wasm valtype a load of this machine class yields.
     */
    valtype: u8
}

/**
 * wasm_mem_op — the load/store opcode pair + alignment + valtype for one
 * `LType`'s NATURAL, ON-DISK memory access (`backend-c1-wasm.md` §4.4/§6).
 * `I8`/`I16` load zero-extending (`i32.load8_u`/`i32.load16_u`) into the
 * shared `i32` family their valtype already collapses to; `I32` gets its own
 * natural `i32` load/store; `I64`/`F32`/`F64` each get their own natural-
 * width op. **`Ptr` ALWAYS stores/loads as `i64` (8 bytes), matching
 * `ltype_size(Ptr) = 8` (`lir.tks:465`) — REGARDLESS of `ptr64`** (#389
 * C1-7): the on-disk width is the uniform 64-bit `ptr<>` model (§2-C, §6);
 * what differs between wasm32/wasm64 is what happens to the loaded/stored
 * value at the REGISTER boundary (the checked narrow / plain widen
 * `stackify_load`/`stackify_store` apply on wasm32, vs the identity on
 * wasm64) — a target-independent decision this table does not need to make.
 * `I128`/`F16` are the same two named honest-stops `wasm_valtype` names;
 * `Void` is the same internal-error arm.
 *
 * @param LType t  the accessed machine class
 * @return WasmMemOp | error  the resolved memory-access shape, or a named
 *                            honest-stop
 */
fn wasm_mem_op(t: lir::LType) -> WasmMemOp | error {
    match t {
        lir::LType::I8 => WasmMemOp { load_op = WASM_OP_I32_LOAD8_S; store_op = WASM_OP_I32_STORE8; align = 0 to u32; valtype = wasm_vtype_wire(WasmVType::I32) }
        lir::LType::I16 => WasmMemOp { load_op = WASM_OP_I32_LOAD16_S; store_op = WASM_OP_I32_STORE16; align = 1 to u32; valtype = wasm_vtype_wire(WasmVType::I32) }
        lir::LType::I32 => WasmMemOp { load_op = WASM_OP_I32_LOAD; store_op = WASM_OP_I32_STORE; align = 2 to u32; valtype = wasm_vtype_wire(WasmVType::I32) }
        lir::LType::I64 => WasmMemOp { load_op = WASM_OP_I64_LOAD; store_op = WASM_OP_I64_STORE; align = 3 to u32; valtype = wasm_vtype_wire(WasmVType::I64) }
        lir::LType::Ptr => WasmMemOp { load_op = WASM_OP_I64_LOAD; store_op = WASM_OP_I64_STORE; align = 3 to u32; valtype = wasm_vtype_wire(WasmVType::I64) }
        lir::LType::F32 => WasmMemOp { load_op = WASM_OP_F32_LOAD; store_op = WASM_OP_F32_STORE; align = 2 to u32; valtype = wasm_vtype_wire(WasmVType::F32) }
        lir::LType::F64 => WasmMemOp { load_op = WASM_OP_F64_LOAD; store_op = WASM_OP_F64_STORE; align = 3 to u32; valtype = wasm_vtype_wire(WasmVType::F64) }
        lir::LType::I128 => error { message = "stackify: C1-i128 — an i128 memory access has no wasm valtype, deferred (shared with A2's i128 route)" }
        lir::LType::F16 => error { message = "stackify: C1-f16 — an f16 memory access has no wasm valtype, deferred (matches the register targets' f16 gap)" }
        lir::LType::Void => error { message = "stackify: a void-typed memory access is malformed (internal)" }
    }
}

/**
 * wasm_narrow_threshold — the wasm32 checked-narrow's own boundary: `2^32`
 * as a signed `i64` (`backend-wasm.md` §6) — the smallest 64-bit address
 * value a wasm32 linear-memory access can NOT represent as an `i32`. Built
 * from arithmetic (never a huge literal, mirroring `sft_i128_beyond_i64`'s
 * own "never write the giant literal" discipline) so the threshold is
 * self-evidently exact.
 *
 * @return i64  `4294967296` (`2^32`)
 */
fn wasm_narrow_threshold() -> i64 {
    let half = 65536 to i64
    half * half
}

/**
 * stackify_narrow_ptr_load — the wasm32 checked-narrow tail of a `Ptr`-typed
 * `LLoad` (`backend-wasm.md` §6, #389 C1-7): given the just-loaded `i64`
 * address already on the operand stack, `local.tee` it into a fresh scratch
 * (`sc_alloc_scratch` — the value must survive both the comparison AND the
 * eventual wrap), test `addr >= 2^32` (`i64.ge_u`, `wasm_narrow_threshold`);
 * on overflow, `sc_open_if` a VOID-signature `if` (§3.3 — every scope stays
 * empty-stack at its boundary) whose `then` arm calls the `tk_panic_str`
 * host-hook trampoline with the fixed overflow message (`wasm_narrow_msg_
 * addr`/`_len`) then `unreachable` TRAPS the instance (§8's "observe, then
 * trap" shape, M.1 — never a silent `i32.wrap_i64`); otherwise (no `else`)
 * fall straight to `sc_close_scope`'s `end`, `local.get` the scratch back,
 * and `i32.wrap_i64` the in-range value down to the wasm32 register width
 * (`wasm_valtype(Ptr, false) = i32`, §3.2).
 *
 * @param StackifyCtx ctx0  the context to extend (the `i64` address value
 *                          already pushed by the caller's own `i64.load`)
 * @param u32 panic_ix  the `tk_panic_str` trampoline's own funcidx
 * @return StackifyCtx  the advanced context, the narrowed `i32` value left
 *                       on the operand stack
 */
fn stackify_narrow_ptr_load(ctx0: StackifyCtx, panic_ix: u32) -> StackifyCtx {
    let alloc = sc_alloc_scratch(ctx0, wasm_vtype_wire(WasmVType::I64))
    let ctx1 = sc_local_tee(alloc.ctx, alloc.id)
    let ctx2 = sc_sleb(sc_byte(ctx1, WASM_OP_I64_CONST), wasm_narrow_threshold())
    let ctx3 = sc_byte(ctx2, WASM_OP_I64_GE_U)
    let ctx4 = sc_open_if(ctx3)
    let ctx5 = sc_sleb(sc_byte(ctx4, WASM_OP_I32_CONST), wasm_narrow_msg_addr() to i64)
    let ctx6 = sc_sleb(sc_byte(ctx5, WASM_OP_I32_CONST), wasm_narrow_msg_len() to i64)
    let ctx7 = sc_uleb(sc_byte(ctx6, WASM_OP_CALL), panic_ix to u64)
    let ctx8 = sc_byte(ctx7, WASM_OP_UNREACHABLE)
    let ctx9 = sc_close_scope(ctx8)
    let ctx10 = sc_local_get(ctx9, alloc.id)
    sc_byte(ctx10, WASM_OP_I32_WRAP_I64)
}

/**
 * stackify_const_int — the `LConstInt` lowering: `i32.const`/`i64.const`
 * (`stackify_fits_i32` picks the narrowest lossless wasm width, §4.1),
 * `local.set` into the result's own VReg-numbered local. A value beyond the
 * i64 range is the `C1-i128` honest-stop (`fits_i64`, shared with A2's own
 * i128-constant materialization gate).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LConstInt c  the constant op
 * @return StackifyCtx | error  the advanced context, or the `C1-i128` stop
 */
fn stackify_const_int(ctx0: StackifyCtx, inst: lir::LInst, c: lir::LConstInt) -> StackifyCtx | error {
    if !fits_i64(c.val) {
        return error { message = "stackify: C1-i128 — an integer constant beyond 64 bits needs register-pair materialization, deferred (shared with A2's i128 route, backend-a4-encoder.md §6.3)" }
    }
    let narrow = stackify_fits_i32(c.val)
    let op = if narrow { WASM_OP_I32_CONST } else { WASM_OP_I64_CONST }
    let vt = if narrow { wasm_vtype_wire(WasmVType::I32) } else { wasm_vtype_wire(WasmVType::I64) }
    let ctx1 = sc_sleb(sc_byte(ctx0, op), c.val to i64)
    sc_def_result(ctx1, inst.result, vt)
}

/**
 * stackify_const_float — the `LConstFloat` lowering: always the `f64` form
 * (mirroring `isel_arm64.tks`'s `select_const_float`'s own "always the
 * f64/D form" default — the LIR carries no per-value float width for a bare
 * constant), `f64.const` + its raw IEEE bit pattern, `local.set` into the
 * result's own VReg-numbered local.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LConstFloat c  the constant op
 * @return StackifyCtx  the advanced context
 */
fn stackify_const_float(ctx0: StackifyCtx, inst: lir::LInst, c: lir::LConstFloat) -> StackifyCtx {
    let ctx1 = sc_f64_bits(sc_byte(ctx0, WASM_OP_F64_CONST), c.bits)
    sc_def_result(ctx1, inst.result, wasm_vtype_wire(WasmVType::F64))
}

/**
 * WasmBinOpInfo — one `LBinOp` case's resolved wasm shape at a given
 * operand width: the opcode byte, and whether the op is a compare (whose
 * wasm result is ALWAYS `i32`, regardless of the compared operands' own
 * width — mirroring `isel_arm64.tks`'s own `select_icmp`/`select_fcmp`
 * always recording a narrow/GPR result).
 */
type WasmBinOpInfo = struct {
    /**
     * opcode — the wasm instruction byte for this op at this width.
     */
    opcode: byte
    /**
     * is_cmp — true iff this is an integer/float compare (its wasm result
     * is always `i32`, never the compared operands' own width).
     */
    is_cmp: bool
}

/**
 * wasm_binop_info — the total per-`LBinOp` opcode table
 * (`backend-c1-wasm.md` §4.4, cross-checked against the wasm core spec's
 * numeric-instruction opcode listing): `wide=true` selects the `i64`/`f64`
 * family member, `wide=false` the `i32`/`f32` one. Every case shares the
 * SAME instruction shape (`local.get a; local.get b; <opcode>; local.set
 * r`), so — unlike arm64/x86 isel, which need a distinct selection function
 * per instruction SHAPE (`MAlu` vs `MCmp`+`MCSet` vs a two-instruction
 * `IRemS`/`IRemU`) — wasm's native `rem_s`/`rem_u`/compare-to-i32
 * instructions let every `LBinOp` case reduce to one opcode lookup.
 *
 * @param LBinOp op  the binary opcode
 * @param bool wide  true to select the 64-bit-family member
 * @return WasmBinOpInfo  the resolved opcode + compare classification
 */
fn wasm_binop_info(op: lir::LBinOp, wide: bool) -> WasmBinOpInfo {
    match op {
        lir::LBinOp::IAdd => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_ADD } else { WASM_OP_I32_ADD }; is_cmp = false }
        lir::LBinOp::ISub => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_SUB } else { WASM_OP_I32_SUB }; is_cmp = false }
        lir::LBinOp::IMul => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_MUL } else { WASM_OP_I32_MUL }; is_cmp = false }
        lir::LBinOp::IDivS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_DIV_S } else { WASM_OP_I32_DIV_S }; is_cmp = false }
        lir::LBinOp::IDivU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_DIV_U } else { WASM_OP_I32_DIV_U }; is_cmp = false }
        lir::LBinOp::IRemS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_REM_S } else { WASM_OP_I32_REM_S }; is_cmp = false }
        lir::LBinOp::IRemU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_REM_U } else { WASM_OP_I32_REM_U }; is_cmp = false }
        lir::LBinOp::IAnd => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_AND } else { WASM_OP_I32_AND }; is_cmp = false }
        lir::LBinOp::IOr => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_OR } else { WASM_OP_I32_OR }; is_cmp = false }
        lir::LBinOp::IXor => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_XOR } else { WASM_OP_I32_XOR }; is_cmp = false }
        lir::LBinOp::IShl => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_SHL } else { WASM_OP_I32_SHL }; is_cmp = false }
        lir::LBinOp::IShrS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_SHR_S } else { WASM_OP_I32_SHR_S }; is_cmp = false }
        lir::LBinOp::IShrU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_SHR_U } else { WASM_OP_I32_SHR_U }; is_cmp = false }
        lir::LBinOp::ICmpEq => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_EQ } else { WASM_OP_I32_EQ }; is_cmp = true }
        lir::LBinOp::ICmpNe => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_NE } else { WASM_OP_I32_NE }; is_cmp = true }
        lir::LBinOp::ICmpLtS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_LT_S } else { WASM_OP_I32_LT_S }; is_cmp = true }
        lir::LBinOp::ICmpLtU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_LT_U } else { WASM_OP_I32_LT_U }; is_cmp = true }
        lir::LBinOp::ICmpLeS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_LE_S } else { WASM_OP_I32_LE_S }; is_cmp = true }
        lir::LBinOp::ICmpLeU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_LE_U } else { WASM_OP_I32_LE_U }; is_cmp = true }
        lir::LBinOp::ICmpGtS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_GT_S } else { WASM_OP_I32_GT_S }; is_cmp = true }
        lir::LBinOp::ICmpGtU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_GT_U } else { WASM_OP_I32_GT_U }; is_cmp = true }
        lir::LBinOp::ICmpGeS => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_GE_S } else { WASM_OP_I32_GE_S }; is_cmp = true }
        lir::LBinOp::ICmpGeU => WasmBinOpInfo { opcode = if wide { WASM_OP_I64_GE_U } else { WASM_OP_I32_GE_U }; is_cmp = true }
        lir::LBinOp::FAdd => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_ADD } else { WASM_OP_F32_ADD }; is_cmp = false }
        lir::LBinOp::FSub => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_SUB } else { WASM_OP_F32_SUB }; is_cmp = false }
        lir::LBinOp::FMul => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_MUL } else { WASM_OP_F32_MUL }; is_cmp = false }
        lir::LBinOp::FDiv => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_DIV } else { WASM_OP_F32_DIV }; is_cmp = false }
        lir::LBinOp::FCmpEq => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_EQ } else { WASM_OP_F32_EQ }; is_cmp = true }
        lir::LBinOp::FCmpNe => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_NE } else { WASM_OP_F32_NE }; is_cmp = true }
        lir::LBinOp::FCmpLt => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_LT } else { WASM_OP_F32_LT }; is_cmp = true }
        lir::LBinOp::FCmpLe => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_LE } else { WASM_OP_F32_LE }; is_cmp = true }
        lir::LBinOp::FCmpGt => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_GT } else { WASM_OP_F32_GT }; is_cmp = true }
        lir::LBinOp::FCmpGe => WasmBinOpInfo { opcode = if wide { WASM_OP_F64_GE } else { WASM_OP_F32_GE }; is_cmp = true }
    }
}

/**
 * stackify_bin — the `LBin` lowering: `local.get a; local.get b; <opcode>;
 * local.set r` for every case (`wasm_binop_info`). The result's wasm valtype
 * is `i32` for a compare, else inherited from operand `a` (an SSA guarantee:
 * `a` was already lowered, and its valtype recorded, before this use —
 * mirrors `isel_arm64.tks`'s `select_bin` reading `a`'s already-recorded
 * `class_of` entry).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LBin b  the binary op
 * @return StackifyCtx  the advanced context
 */
fn stackify_bin(ctx0: StackifyCtx, inst: lir::LInst, b: lir::LBin) -> StackifyCtx {
    let a_vt = wvt_get(ctx0.vtypes, b.a)
    let wide = a_vt == wasm_vtype_wire(WasmVType::I64) || a_vt == wasm_vtype_wire(WasmVType::F64)
    let info = wasm_binop_info(b.op, wide)
    let ctx2 = sc_use_operands(ctx0, [b.a, b.b])
    let ctx3 = sc_byte(ctx2, info.opcode)
    let dst_vt = if info.is_cmp { wasm_vtype_wire(WasmVType::I32) } else { a_vt }
    sc_def_result(ctx3, inst.result, dst_vt)
}

/**
 * stackify_ineg — the `INeg` lowering: wasm has no native integer negate, so
 * `INeg a` renders as `0 - a` (`<width>.const 0; local.get a; <width>.sub`),
 * matching the design doc's worked example (§4.4). The result stays at
 * operand `a`'s own width (mirroring arm64's own `wide=a_info.wide`
 * propagation).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_ineg(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let wide = a_vt == wasm_vtype_wire(WasmVType::I64)
    let const_op = if wide { WASM_OP_I64_CONST } else { WASM_OP_I32_CONST }
    let sub_op = if wide { WASM_OP_I64_SUB } else { WASM_OP_I32_SUB }
    let ctx1 = sc_sleb(sc_byte(ctx0, const_op), 0 to i64)
    let ctx2 = sc_use_operand(ctx1, a)
    let ctx3 = sc_byte(ctx2, sub_op)
    sc_def_result(ctx3, inst.result, a_vt)
}

/**
 * stackify_inot — the `INot` lowering: wasm has no native bitwise-not, so
 * `INot a` renders as `a XOR -1` (`<width>.const -1; local.get a;
 * <width>.xor`), matching the design doc's worked example (§4.4).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_inot(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let wide = a_vt == wasm_vtype_wire(WasmVType::I64)
    let const_op = if wide { WASM_OP_I64_CONST } else { WASM_OP_I32_CONST }
    let xor_op = if wide { WASM_OP_I64_XOR } else { WASM_OP_I32_XOR }
    let ctx1 = sc_sleb(sc_byte(ctx0, const_op), -1 to i64)
    let ctx2 = sc_use_operand(ctx1, a)
    let ctx3 = sc_byte(ctx2, xor_op)
    sc_def_result(ctx3, inst.result, a_vt)
}

/**
 * stackify_fneg — the `FNeg` lowering: wasm's native `f32.neg`/`f64.neg`,
 * selected by operand `a`'s own recorded float width.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_fneg(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let op = if a_vt == wasm_vtype_wire(WasmVType::F64) { WASM_OP_F64_NEG } else { WASM_OP_F32_NEG }
    let ctx1 = sc_byte(sc_use_operand(ctx0, a), op)
    sc_def_result(ctx1, inst.result, a_vt)
}

/**
 * stackify_trunc — the `Trunc` lowering: always an `i32` result (mirroring
 * arm64's own `select_identity_mov(..., wide=false)` "Trunc always picks the
 * W form"). When the operand is already `i32`-family (its write already
 * narrow), the op is a plain local-to-local copy; when it is `i64`, an
 * explicit `i32.wrap_i64` performs the real narrowing.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_trunc(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let ctx1 = sc_use_operand(ctx0, a)
    let ctx2 = if a_vt == wasm_vtype_wire(WasmVType::I64) { sc_byte(ctx1, WASM_OP_I32_WRAP_I64) } else { ctx1 }
    sc_def_result(ctx2, inst.result, wasm_vtype_wire(WasmVType::I32))
}

/**
 * stackify_identity — the `ZExt`/`SExt` lowering: a plain local-to-local
 * copy at operand `a`'s OWN width (mirroring arm64's own `select_identity_
 * mov(..., wide=a_info.wide)` — "the LIR carries no per-value width for
 * these... a bit-preserving move is the honest match for that same
 * semantics"; a real narrowing/widening extend is selected once a value
 * instead crosses a typed memory boundary, `LLoad`'s own `ty`).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_identity(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let ctx1 = sc_use_operand(ctx0, a)
    sc_def_result(ctx1, inst.result, a_vt)
}

/**
 * stackify_itof — the `IToF` lowering: always an `f64` result (mirroring
 * arm64's own `select_itof`'s always-D-form default), signed source
 * (`LUnOp` declares no unsigned `IToF` variant, the same documented default
 * `select_itof` uses), the source opcode selected by operand `a`'s own
 * recorded integer width.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_itof(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let op = if a_vt == wasm_vtype_wire(WasmVType::I64) { WASM_OP_F64_CONVERT_I64_S } else { WASM_OP_F64_CONVERT_I32_S }
    let ctx1 = sc_byte(sc_use_operand(ctx0, a), op)
    sc_def_result(ctx1, inst.result, wasm_vtype_wire(WasmVType::F64))
}

/**
 * stackify_ftoi — the `FToI` lowering: always an `i32` result, signed
 * destination (mirroring arm64's own `select_ftoi`'s `Fcvtzs`-always
 * default), the source opcode selected by operand `a`'s own recorded float
 * width.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_ftoi(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let op = if a_vt == wasm_vtype_wire(WasmVType::F64) { WASM_OP_I32_TRUNC_F64_S } else { WASM_OP_I32_TRUNC_F32_S }
    let ctx1 = sc_byte(sc_use_operand(ctx0, a), op)
    sc_def_result(ctx1, inst.result, wasm_vtype_wire(WasmVType::I32))
}

/**
 * stackify_ftof — the `FToF` lowering: the ONLY two-float-width family, so
 * (unlike every other `LUn` case) the result width is the OPPOSITE of the
 * operand's — `f64` demotes to `f32`, `f32` promotes to `f64` — the total,
 * symmetric reading of "convert between the two wasm float widths" the LIR
 * gives no further information to refine.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param u32 a  the operand VReg
 * @param u8 a_vt  `a`'s already-recorded wasm valtype
 * @return StackifyCtx  the advanced context
 */
fn stackify_ftof(ctx0: StackifyCtx, inst: lir::LInst, a: u32, a_vt: u8) -> StackifyCtx {
    let demote = a_vt == wasm_vtype_wire(WasmVType::F64)
    let op = if demote { WASM_OP_F32_DEMOTE_F64 } else { WASM_OP_F64_PROMOTE_F32 }
    let dst_vt = if demote { wasm_vtype_wire(WasmVType::F32) } else { wasm_vtype_wire(WasmVType::F64) }
    let ctx1 = sc_byte(sc_use_operand(ctx0, a), op)
    sc_def_result(ctx1, inst.result, dst_vt)
}

/**
 * stackify_un — the `LUn` dispatch: one lowering per `LUnOp` case
 * (`backend-c1-wasm.md` §4.4), operand `a`'s wasm valtype read once and
 * threaded to whichever case handles it.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LUn u  the unary op
 * @return StackifyCtx  the advanced context
 */
fn stackify_un(ctx0: StackifyCtx, inst: lir::LInst, u: lir::LUn) -> StackifyCtx {
    let a_vt = wvt_get(ctx0.vtypes, u.a)
    match u.op {
        lir::LUnOp::INeg => stackify_ineg(ctx0, inst, u.a, a_vt)
        lir::LUnOp::INot => stackify_inot(ctx0, inst, u.a, a_vt)
        lir::LUnOp::FNeg => stackify_fneg(ctx0, inst, u.a, a_vt)
        lir::LUnOp::Trunc => stackify_trunc(ctx0, inst, u.a, a_vt)
        lir::LUnOp::ZExt => stackify_identity(ctx0, inst, u.a, a_vt)
        lir::LUnOp::SExt => stackify_identity(ctx0, inst, u.a, a_vt)
        lir::LUnOp::IToF => stackify_itof(ctx0, inst, u.a, a_vt)
        lir::LUnOp::FToI => stackify_ftoi(ctx0, inst, u.a, a_vt)
        lir::LUnOp::FToF => stackify_ftof(ctx0, inst, u.a, a_vt)
    }
}

/**
 * stackify_param — the `LParam` lowering: `local.get $index; local.set $r`
 * (a plain local-to-local copy). `index` and `r` NAME THE SAME local for
 * every param the LIR lowering ever emits (`LParam{index}` always defines
 * VReg `index`, `lower.tks`'s own `param_inst(i, i, ...)` convention), so
 * this is a redundant-but-always-correct self-copy rather than a trusted
 * alias — the copy form is emitted regardless, so correctness never depends
 * on that unchecked invariant continuing to hold (mirrors §3.2's own
 * "do NOT blind-trust" discipline).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LFunc f  the enclosing function (its `param_types`)
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LParam p  the parameter op
 * @param bool ptr64  the target pointer width (`wasm_valtype`'s own switch,
 *                    #389 C1-7)
 * @return StackifyCtx | error  the advanced context, or a NAMED error when
 *                              `p.index` is out of range (internal), or
 *                              `wasm_valtype`'s propagated honest-stop
 */
fn stackify_param(ctx0: StackifyCtx, f: lir::LFunc, inst: lir::LInst, p: lir::LParam, ptr64: bool) -> StackifyCtx | error {
    if (p.index to u64) >= f.param_types.len {
        return error { message = "stackify: param index out of range (internal)" }
    }
    let vt = match wasm_valtype(f.param_types[p.index to u64], ptr64) { u8 as v => v; error as e => return e }
    let ctx1 = sc_local_get(ctx0, p.index)
    sc_def_result(ctx1, inst.result, vt)
}

/**
 * stackify_ret — the `LRet` lowering: restore `SP` first when the function
 * reserves a shadow-stack frame (`emit_frame_epilogue` — a no-op
 * otherwise), then for a value-carrying return push the returned VReg's
 * local, then `return` (`0x0F`); a void return emits `return` alone.
 * `return` is used unconditionally (rather than relying on the
 * fall-off-the-end-of-the-function form) so the lowering is correct
 * regardless of `LRet`'s position in the instruction stream — and every
 * function-exit path is an `LRet` (`backend-c1-wasm.md` §1), so this is the
 * ONLY site the epilogue needs.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LRet r  the return op
 * @return StackifyCtx  the advanced context
 */
fn stackify_ret(ctx0: StackifyCtx, r: lir::LRet) -> StackifyCtx {
    let restored = emit_frame_epilogue(ctx0)
    let ctx1 = if r.has_value { sc_use_operand(restored, r.value) } else { restored }
    sc_byte(ctx1, WASM_OP_RETURN)
}

/**
 * stackify_field_addr — the `LFieldAddr` lowering: `local.get $base;
 * i32.const offset; i32.add; local.set $r` — pure `i32` (`Ptr`) arithmetic,
 * no linear-memory layout knowledge needed (this op only ever adds a
 * compile-time-constant byte offset onto an already-computed address).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LFieldAddr fa  the field-address op
 * @return StackifyCtx  the advanced context
 */
fn stackify_field_addr(ctx0: StackifyCtx, inst: lir::LInst, fa: lir::LFieldAddr) -> StackifyCtx {
    let ctx1 = sc_use_operand(ctx0, fa.base)
    let ctx2 = sc_sleb(sc_byte(ctx1, WASM_OP_I32_CONST), fa.offset to i64)
    let ctx3 = sc_byte(ctx2, WASM_OP_I32_ADD)
    sc_def_result(ctx3, inst.result, wasm_vtype_wire(WasmVType::I32))
}

/**
 * stackify_alloca — the `LAlloca` lowering: `local.get $frame_base;
 * i32.const offset; i32.add; local.set $r`, where `offset` is this
 * instruction's OWN precomputed frame-base-relative slot (`ctx0.slots`,
 * `compute_wasm_frame_layout`) — pure compile-time-constant arithmetic, the
 * SAME shape as `stackify_field_addr`. The actual `SP` reservation already
 * happened once, in the function's own `emit_frame_prologue`; this site
 * never mutates `SP` itself (§6.1, the `WasmSlotTable` doc's loop-safety
 * rationale).
 *
 * @param StackifyCtx ctx0  the context to extend (`has_frame` already
 *                          established by `stackify_control`)
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @return StackifyCtx  the advanced context
 */
fn stackify_alloca(ctx0: StackifyCtx, inst: lir::LInst) -> StackifyCtx {
    let off = wst_get(ctx0.slots, inst.result)
    let ctx1 = sc_local_get(ctx0, ctx0.frame_base)
    let ctx2 = sc_sleb(sc_byte(ctx1, WASM_OP_I32_CONST), off to i64)
    let ctx3 = sc_byte(ctx2, WASM_OP_I32_ADD)
    sc_def_result(ctx3, inst.result, wasm_vtype_wire(WasmVType::I32))
}

/**
 * stackify_load — the `LLoad` lowering: `local.get $addr; <ty>.load
 * align,0; local.set $r` (`wasm_mem_op` resolves the opcode/alignment/
 * valtype from `l.ty`). The offset is always `0` — any static field offset
 * already rode a preceding `LFieldAddr` into the address. **`Ptr`-typed on
 * wasm32 (`!ptr64`) is the ONE exception (#389 C1-7, `backend-wasm.md`
 * §6):** the on-disk access is still the natural `i64.load` (`wasm_mem_op`'s
 * uniform 8-byte `Ptr` shape), but the loaded value is then CHECKED-narrowed
 * to `i32` (`stackify_narrow_ptr_load`, panicking via the `tk_panic_str`
 * host hook on overflow) before landing in the result's local — matching
 * `wasm_valtype(Ptr, false) = i32`'s own register-space width. On wasm64
 * (`ptr64`) `Ptr` needs no special case at all: `mem.valtype` is already
 * `i64`, identical to any other `i64` load.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LLoad l  the load op
 * @param bool ptr64  the target pointer width (#389 C1-7)
 * @param WasmSymbolTable symbols  the call-target resolver (`tk_panic_str`'s
 *                                 own funcidx, needed only on the wasm32
 *                                 `Ptr` narrow path)
 * @return StackifyCtx | error  the advanced context, or `wasm_mem_op`'s (or
 *                              the panic symbol's) propagated honest-stop
 */
fn stackify_load(ctx0: StackifyCtx, inst: lir::LInst, l: lir::LLoad, ptr64: bool, symbols: WasmSymbolTable) -> StackifyCtx | error {
    let mem = match wasm_mem_op(l.ty) { WasmMemOp as m => m; error as e => return e }
    let ctx1 = sc_use_operand(ctx0, l.addr)
    let ctx2 = sc_byte(ctx1, mem.load_op)
    let ctx3 = sc_memarg(ctx2, mem.align, 0 to u32)
    if l.ty == lir::LType::Ptr && !ptr64 {
        let panic_target = match wasm_resolve_call(symbols, "tk_panic_str") { WasmCallTarget as t => t; error as e => return e }
        let narrowed = stackify_narrow_ptr_load(ctx3, panic_target.func_index)
        return sc_def_result(narrowed, inst.result, wasm_vtype_wire(WasmVType::I32))
    }
    sc_def_result(ctx3, inst.result, mem.valtype)
}

/**
 * stackify_store — the `LStore` lowering: `local.get $addr; local.get
 * $value; <ty>.store align,0` (no result). The `i32`-vs-`i64` store FAMILY
 * is derived from `s.ty` (mirroring arm64's own `select_store`'s "size +
 * register file from the stored ty", reading through to the value operand
 * rather than trusting its own recorded valtype) — a well-formed-LIR
 * precondition: `s.value`'s own actual local already agrees with `s.ty`'s
 * implied width. **`Ptr`-typed on wasm32 (`!ptr64`) is the ONE exception**
 * (#389 C1-7, `backend-wasm.md` §6): the register-space value is `i32`
 * (`wasm_valtype(Ptr, false)`), but the on-disk shape is the uniform 8-byte
 * `Ptr` (`wasm_mem_op`), so the `i32` value is `i64.extend_i32_u`-widened
 * (always lossless — an in-range wasm32 address is never negative) before
 * the `i64.store`. On wasm64 (`ptr64`) the value is already `i64`; no widen
 * is needed.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LStore s  the store op
 * @param bool ptr64  the target pointer width (#389 C1-7)
 * @return StackifyCtx | error  the advanced context, or `wasm_mem_op`'s
 *                              propagated honest-stop
 */
fn stackify_store(ctx0: StackifyCtx, s: lir::LStore, ptr64: bool) -> StackifyCtx | error {
    let mem = match wasm_mem_op(s.ty) { WasmMemOp as m => m; error as e => return e }
    if s.ty == lir::LType::Ptr && !ptr64 {
        let ctx1 = sc_use_operands(ctx0, [s.addr, s.value])
        let ctx2 = sc_byte(ctx1, WASM_OP_I64_EXTEND_I32_U)
        let ctx3 = sc_byte(ctx2, mem.store_op)
        return sc_memarg(ctx3, mem.align, 0 to u32)
    }
    let ctx2 = sc_use_operands(ctx0, [s.addr, s.value])
    let ctx3 = sc_byte(ctx2, mem.store_op)
    sc_memarg(ctx3, mem.align, 0 to u32)
}

/**
 * WasmCallTarget — one already-resolved call target: the callee's wasm
 * function index and its return machine class (`Void` for a callee that
 * returns nothing). `stackify_call` needs both to decide whether a result
 * lands in a local, is dropped, or is absent — a decision that fundamentally
 * needs the CALLEE's own signature, external knowledge `LCall` itself does
 * not carry.
 */
pub type WasmCallTarget = struct {
    /**
     * func_index — the callee's index into the module's function index
     * space (imports first, then defined functions).
     */
    func_index: u32
    /**
     * ret_type — the callee's return machine class (`Void` for no return
     * value).
     */
    ret_type: lir::LType
}

/**
 * WasmSymbolTable — a caller-supplied resolver mapping an already-mangled
 * `LCall.symbol` to its `WasmCallTarget`, AND an already-laid-out
 * `LGlobalAddr.symbol` to its linear-memory offset (C1-4, `wasm_layout_
 * rodata`). Resolving every function/import/rodata symbol in a whole
 * program to its final index/offset is module-level "link/dispatch" work
 * (`backend-c1-wasm.md` C1-5); this slice only needs to TRANSLATE a call or
 * global-address instruction given an already-resolved target, so the
 * table is built and threaded in by the caller rather than derived here.
 */
pub type WasmSymbolTable = struct {
    /**
     * symbols — the registered already-mangled call symbols, parallel to
     * `targets`.
     */
    symbols: []str
    /**
     * targets — each call symbol's resolved call target, parallel to
     * `symbols`.
     */
    targets: []WasmCallTarget
    /**
     * data_symbols — the registered rodata/global symbols, parallel to
     * `data_offsets`.
     */
    data_symbols: []str
    /**
     * data_offsets — each data symbol's resolved linear-memory offset,
     * parallel to `data_symbols`.
     */
    data_offsets: []u32
}

/**
 * wasm_symtab_empty — a resolver table with no symbols registered yet.
 *
 * @return WasmSymbolTable  the empty table
 */
pub fn wasm_symtab_empty() -> WasmSymbolTable {
    WasmSymbolTable { symbols = teko::list::empty(); targets = teko::list::empty(); data_symbols = teko::list::empty(); data_offsets = teko::list::empty() }
}

/**
 * wasm_symtab_add — register `symbol`'s call target, returning the
 * extended table.
 *
 * @param WasmSymbolTable t  the table to extend
 * @param str symbol  the already-mangled symbol to register
 * @param WasmCallTarget target  its resolved call target
 * @return WasmSymbolTable  the extended table
 */
pub fn wasm_symtab_add(t: WasmSymbolTable, symbol: str, target: WasmCallTarget) -> WasmSymbolTable {
    WasmSymbolTable { symbols = teko::list::push(t.symbols, symbol); targets = teko::list::push(t.targets, target); data_symbols = t.data_symbols; data_offsets = t.data_offsets }
}

/**
 * wasm_symtab_add_data — register `symbol`'s linear-memory offset (a
 * `LGlobalAddr` target), returning the extended table.
 *
 * @param WasmSymbolTable t  the table to extend
 * @param str symbol  the rodata/global symbol to register
 * @param u32 offset  its linear-memory offset
 * @return WasmSymbolTable  the extended table
 */
pub fn wasm_symtab_add_data(t: WasmSymbolTable, symbol: str, offset: u32) -> WasmSymbolTable {
    WasmSymbolTable { symbols = t.symbols; targets = t.targets; data_symbols = teko::list::push(t.data_symbols, symbol); data_offsets = teko::list::push(t.data_offsets, offset) }
}

/**
 * wasm_resolve_call — the `WasmCallTarget` registered under `symbol`, or a
 * NAMED error when it was never registered (a genuine "the caller owed us
 * this" boundary — resolving every program symbol is C1-5's link/dispatch
 * job, not this slice's).
 *
 * @param WasmSymbolTable t  the resolver table to search
 * @param str symbol  the already-mangled symbol to resolve
 * @return WasmCallTarget | error  the resolved target, or a NAMED error
 */
fn wasm_resolve_call(t: WasmSymbolTable, symbol: str) -> WasmCallTarget | error {
    mut i: u64 = 0
    loop {
        if i >= t.symbols.len { break }
        if t.symbols[i] == symbol { return t.targets[i] }
        i++
    }
    error { message = $"stackify: unresolved call symbol '{symbol}' — the caller must register it in the WasmSymbolTable first (link/dispatch is C1-5 territory)" }
}

/**
 * wasm_resolve_data — the linear-memory offset registered under `symbol`,
 * or a NAMED error when it was never registered (mirrors `wasm_resolve_
 * call`'s own "the caller owed us this" boundary — laying out every
 * program's rodata is C1-4's `wasm_layout_rodata`/C1-5's module-assembly
 * job, not this per-instruction slice's).
 *
 * @param WasmSymbolTable t  the resolver table to search
 * @param str symbol  the rodata/global symbol to resolve
 * @return u32 | error  the resolved offset, or a NAMED error
 */
fn wasm_resolve_data(t: WasmSymbolTable, symbol: str) -> u32 | error {
    mut i: u64 = 0
    loop {
        if i >= t.data_symbols.len { break }
        if t.data_symbols[i] == symbol { return t.data_offsets[i] }
        i++
    }
    error { message = $"stackify: unresolved data symbol '{symbol}' — the caller must register it in the WasmSymbolTable first (rodata layout is C1-4/C1-5 territory)" }
}

/**
 * stackify_call — the `LCall` lowering: push every argument's local, `call
 * $funcidx` (`wasm_resolve_call` names the target). When the callee returns
 * a value: captured into the result's local when `inst.has_result`, else
 * `drop`ped (`0x1A`) to keep the operand stack balanced for a
 * statement-level call whose result is discarded. A `Void`-returning
 * callee needs neither. The `call`'s funcidx operand is the callee's
 * already-final absolute index (`WasmCallTarget.func_index`), emitted as a
 * minimal-width ULEB128 — the module is self-contained (`backend-wasm.md`
 * §1.2), so every function index is fixed at assembly time and no linker
 * ever repositions it.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param WasmSymbolTable symbols  the call-target resolver
 * @param LInst inst  the enclosing instruction (its result VReg, and
 *                     whether the caller captures the result)
 * @param LCall c  the call op
 * @param bool ptr64  the target pointer width (`wasm_valtype`'s own switch,
 *                    #389 C1-7)
 * @return StackifyCtx | error  the advanced context, or a propagated
 *                              honest-stop (an unresolved symbol, or the
 *                              callee's own `C1-i128`/`C1-f16` return type)
 */
fn stackify_call(ctx0: StackifyCtx, symbols: WasmSymbolTable, inst: lir::LInst, c: lir::LCall, ptr64: bool) -> StackifyCtx | error {
    let target = match wasm_resolve_call(symbols, c.symbol) { WasmCallTarget as t => t; error as e => return e }
    let staged = sc_use_operands(ctx0, c.args)
    let ctx = sc_uleb(sc_byte(staged, WASM_OP_CALL), target.func_index to u64)
    if target.ret_type == lir::LType::Void {
        return ctx
    }
    let vt = match wasm_valtype(target.ret_type, ptr64) { u8 as v => v; error as e => return e }
    if inst.has_result {
        return sc_def_result(ctx, inst.result, vt)
    }
    sc_byte(ctx, WASM_OP_DROP)
}

/**
 * stackify_global_addr — the `LGlobalAddr` lowering: `i32.const offset;
 * local.set $r`, where `offset` is `g.symbol`'s already laid-out linear-
 * memory offset (`wasm_resolve_data`, C1-4's `wasm_layout_rodata`) — the
 * wasm analog of arm64's `ADRP+ADD` symbol-address pair, but a single
 * instruction since a wasm `Ptr` is already the flat linear-memory address
 * (`backend-c1-wasm.md` §6.1 — no page-relative relocation needed).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param WasmSymbolTable symbols  the data-symbol resolver
 * @param LInst inst  the enclosing instruction (its result VReg)
 * @param LGlobalAddr g  the global-address op
 * @return StackifyCtx | error  the advanced context, or `wasm_resolve_
 *                              data`'s propagated unresolved-symbol error
 */
fn stackify_global_addr(ctx0: StackifyCtx, symbols: WasmSymbolTable, inst: lir::LInst, g: lir::LGlobalAddr) -> StackifyCtx | error {
    let off = match wasm_resolve_data(symbols, g.symbol) { u32 as o => o; error as e => return e }
    let ctx1 = sc_sleb(sc_byte(ctx0, WASM_OP_I32_CONST), off to i64)
    sc_def_result(ctx1, inst.result, wasm_vtype_wire(WasmVType::I32))
}

/**
 * stackify_inst — the per-`LOp` dispatch for the STRAIGHT-LINE subset: a
 * total match over the closed 16-case `LOp` alphabet (`backend-c1-wasm.md`
 * §1). `LConstInt`/`LConstFloat`/`LBin`/`LUn`/`LParam`/`LRet`/`LFieldAddr`/
 * `LLoad`/`LStore`/`LCall`/`LAlloca`/`LGlobalAddr` lower to real wasm bytes
 * here; `LCallIndirect`/`LFuncAddr` (the funcref table, C1-4/C1-5) are the
 * remaining NAMED honest-stops. `LRet`/`LJump`/`LBranch` are terminators —
 * CFGStackify (`stackify_control`) dispatches them itself
 * (`render_terminator`/`render_jump_terminator`/`render_branch_
 * terminator`, §3), reading the CFG/scope context this per-instruction
 * dispatcher does not carry, so reaching any of them here is an internal
 * misuse (a caller handing a terminator to the straight-line lowerer
 * instead of splicing it via `render_straight` — `stackify_func`/
 * `stackify_control` never do; `stackify_insts` is only ever called on
 * `all_but_last` a block's own instructions).
 *
 * @param StackifyCtx ctx  the context to extend
 * @param LFunc f  the enclosing function (`LParam` needs its `param_types`)
 * @param WasmSymbolTable symbols  the call-target/data-symbol resolver
 *                                 (`LCall`/`LGlobalAddr`)
 * @param LInst inst  the instruction to lower
 * @param bool ptr64  the target pointer width (`LParam`/`LLoad`/`LStore`/
 *                    `LCall`'s own `Ptr`-typed sites, #389 C1-7)
 * @return StackifyCtx | error  the advanced context, or a propagated/named
 *                              honest-stop
 */
fn stackify_inst(ctx: StackifyCtx, f: lir::LFunc, symbols: WasmSymbolTable, inst: lir::LInst, ptr64: bool) -> StackifyCtx | error {
    match inst.op {
        lir::LConstInt as c => stackify_const_int(ctx, inst, c)
        lir::LConstFloat as c => stackify_const_float(ctx, inst, c)
        lir::LBin as b => stackify_bin(ctx, inst, b)
        lir::LUn as u => stackify_un(ctx, inst, u)
        lir::LParam as p => stackify_param(ctx, f, inst, p, ptr64)
        lir::LRet => error { message = "stackify: a return terminator must be rendered by stackify_control's terminator dispatch (render_terminator), not the per-instruction stackify_inst — internal misuse" }
        lir::LJump => error { message = "stackify: a jump terminator must be rendered by stackify_control's terminator dispatch (render_jump_terminator), not the per-instruction stackify_inst — internal misuse" }
        lir::LBranch => error { message = "stackify: a branch terminator must be rendered by stackify_control's terminator dispatch (render_branch_terminator), not the per-instruction stackify_inst — internal misuse" }
        lir::LAlloca => stackify_alloca(ctx, inst)
        lir::LFieldAddr as fa => stackify_field_addr(ctx, inst, fa)
        lir::LLoad as l => stackify_load(ctx, inst, l, ptr64, symbols)
        lir::LStore as s => stackify_store(ctx, s, ptr64)
        lir::LGlobalAddr as g => stackify_global_addr(ctx, symbols, inst, g)
        lir::LCallIndirect => error { message = "stackify: C1-callindirect — an indirect call needs the wasm funcref table, not yet implemented (C1-4/C1-5)" }
        lir::LFuncAddr => error { message = "stackify: C1-funcaddr — a function-value address needs the wasm funcref table, not yet implemented (C1-4/C1-5)" }
        lir::LCall as c => stackify_call(ctx, symbols, inst, c, ptr64)
    }
}

/**
 * stackify_insts — lower every instruction of `insts`, in order, threading
 * the context forward and short-circuiting on the first error.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param LFunc f  the enclosing function
 * @param WasmSymbolTable symbols  the call-target resolver
 * @param []LInst insts  the instruction stream to lower
 * @param bool ptr64  the target pointer width (#389 C1-7)
 * @return StackifyCtx | error  the fully-advanced context, or the first
 *                              propagated error
 */
fn stackify_insts(ctx0: StackifyCtx, f: lir::LFunc, symbols: WasmSymbolTable, insts: []lir::LInst, ptr64: bool) -> StackifyCtx | error {
    mut ctx = ctx0
    mut i: u64 = 0
    loop {
        if i >= insts.len { break }
        let stepped = match stackify_inst(ctx, f, symbols, insts[i], ptr64) { StackifyCtx as c => c; error as e => return e }
        ctx = stepped
        i++
    }
    ctx
}

/* ==========================================================================
 * C1-3 — CFGStackify: small list/table utilities the CFG analysis shares.
 * ========================================================================== */

/**
 * u32_list_has — whether `xs` contains `x`.
 *
 * @param []u32 xs  the list to search
 * @param u32 x  the value to find
 * @return bool  true iff `x` is present
 */
fn u32_list_has(xs: []u32, x: u32) -> bool {
    mut i: u64 = 0
    loop {
        if i >= xs.len { break }
        if xs[i] == x { return true }
        i++
    }
    false
}

/**
 * u32_list_add_unique — `xs` with `x` appended, unless it is already present
 * (the distinct-successor/distinct-exit-target accumulator).
 *
 * @param []u32 xs  the list to extend
 * @param u32 x  the value to add
 * @return []u32  `xs`, plus `x` if it was not already there
 */
fn u32_list_add_unique(xs: []u32, x: u32) -> []u32 {
    if u32_list_has(xs, x) { return xs }
    teko::list::push(xs, x)
}

/**
 * u32_list_reverse — `xs` reversed (a post-order DFS sequence becomes RPO).
 *
 * @param []u32 xs  the list to reverse
 * @return []u32  the reversed list
 */
fn u32_list_reverse(xs: []u32) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = xs.len
    loop {
        if i == 0 { break }
        i = i - 1
        out = teko::list::push(out, xs[i])
    }
    out
}

/**
 * u32_pos — the 0-based position of `id` in `order`, or `order.len` if
 * absent (a defensive default: an absent target sorts last, never a
 * spurious back-edge).
 *
 * @param []u32 order  the RPO block-id order
 * @param u32 id  the block id to rank
 * @return u32  its position, or `order.len`
 */
fn u32_pos(order: []u32, id: u32) -> u32 {
    mut i: u64 = 0
    loop {
        if i >= order.len { break }
        if order[i] == id { return i to u32 }
        i++
    }
    order.len to u32
}

/**
 * u32_table_get — the value at position `id` of a dense `[]u32` table, or
 * `0` when `id` is out of range (a defensive default; every real caller
 * only ever indexes a block id the table was sized for).
 *
 * @param []u32 t  the positional table
 * @param u32 id  the position to read
 * @return u32  the stored value, or `0`
 */
fn u32_table_get(t: []u32, id: u32) -> u32 {
    let i = id to u64
    if i >= t.len { return 0 to u32 }
    t[i]
}

/**
 * u32_table_set — a copy of `t` with position `id` replaced by `v`
 * (positions past the end are left unchanged; mirrors `minst.tks`'s
 * `mreg_list_set` rebuild idiom).
 *
 * @param []u32 t  the positional table to update
 * @param u32 id  the position to replace
 * @param u32 v  the replacement value
 * @return []u32  the updated table
 */
fn u32_table_set(t: []u32, id: u32, v: u32) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= t.len { break }
        out = teko::list::push(out, if (i to u32) == id { v } else { t[i] })
        i++
    }
    out
}

/**
 * u32_unset — the sentinel `[]u32`-table value meaning "not yet computed"
 * (an idom entry before its first pass, or an RPO position for a block that
 * is not reachable) — larger than any real position/id a small function
 * can have.
 *
 * @return u32  the sentinel value
 */
fn u32_unset() -> u32 {
    4294967295 to u32
}

/* ==========================================================================
 * C1-5 — the value-stack peephole: whole-function use analysis + the
 * per-block LIFO simulation that turns it into a final `ElideTable` (§5,
 * `backend-wasm.md`).
 * ========================================================================== */

/**
 * uit_encode_site — pack one use-site's block id + edge-arg flag into a
 * single `u32` (`UseInfoTable`'s own compact per-site encoding): the block
 * id shifted up one bit, the edge flag in bit 0. Keeps `UseInfoTable` to
 * four parallel arrays instead of six.
 *
 * @param u32 block  the block id the use occurs in
 * @param bool is_edge  whether the use is a cross-block edge-copy argument
 * @return u32  the packed site value
 * @since #389 C1-5
 */
fn uit_encode_site(block: u32, is_edge: bool) -> u32 {
    (block << (1 to u32)) | (if is_edge { 1 to u32 } else { 0 to u32 })
}

/**
 * uit_site_block — the block id packed into a `uit_encode_site` value.
 *
 * @param u32 site  the packed site value
 * @return u32  the block id
 * @since #389 C1-5
 */
fn uit_site_block(site: u32) -> u32 {
    site >> (1 to u32)
}

/**
 * uit_site_is_edge — the edge-arg flag packed into a `uit_encode_site`
 * value.
 *
 * @param u32 site  the packed site value
 * @return bool  whether the use is a cross-block edge-copy argument
 * @since #389 C1-5
 */
fn uit_site_is_edge(site: u32) -> bool {
    (site & (1 to u32)) == (1 to u32)
}

/**
 * UseInfoTable — the whole-function per-VReg use analysis
 * `elide_candidate_kind` reads (§5): each VReg's total use count, its first
 * TWO recorded use sites (enough to classify both the single-use `Drop`
 * case and the two-use `Tee` case — a third use, if any, only needs to be
 * known to exist, not itself recorded), and whether the VReg is some
 * block's own incoming block-param (FORCED-LOCAL regardless of use count,
 * §5's own "block-args / `LBlock.params`" rule). Densely indexed by VReg
 * id, mirroring `WasmVTypeTable`/`WasmSlotTable`/`ElideTable`.
 *
 * @since #389 C1-5
 */
type UseInfoTable = struct {
    /**
     * count — each VReg's total use count anywhere in the function,
     * positionally indexed by VReg id.
     */
    count: []u32
    /**
     * site_a — each VReg's FIRST recorded use site (`uit_encode_site`);
     * meaningless when `count` is `0`.
     */
    site_a: []u32
    /**
     * site_b — each VReg's SECOND recorded use site; meaningless when
     * `count` is less than `2`.
     */
    site_b: []u32
    /**
     * is_param — whether each VReg is some block's own incoming block-arg
     * (`LBlock.params`), positionally indexed by VReg id.
     */
    is_param: []bool
}

/**
 * uit_empty — a use-info table with no VRegs recorded yet.
 *
 * @return UseInfoTable  the empty table
 * @since #389 C1-5
 */
fn uit_empty() -> UseInfoTable {
    UseInfoTable { count = teko::list::empty(); site_a = teko::list::empty(); site_b = teko::list::empty(); is_param = teko::list::empty() }
}

/**
 * uit_grow — pad `t` with placeholder (`0`/`false`) entries until every one
 * of its four parallel arrays holds at least `n` positions (mirrors
 * `wvt_grow`).
 *
 * @param UseInfoTable t  the table to pad
 * @param u64 n  the minimum length the padded table must reach
 * @return UseInfoTable  the padded table
 * @since #389 C1-5
 */
fn uit_grow(t: UseInfoTable, n: u64) -> UseInfoTable {
    mut count = t.count
    mut sa = t.site_a
    mut sb = t.site_b
    mut isp = t.is_param
    loop {
        if count.len >= n { break }
        count = teko::list::push(count, 0 to u32)
        sa = teko::list::push(sa, 0 to u32)
        sb = teko::list::push(sb, 0 to u32)
        isp = teko::list::push(isp, false)
    }
    UseInfoTable { count = count; site_a = sa; site_b = sb; is_param = isp }
}

/**
 * uit_record_use — record one occurrence of VReg `vreg` being used in
 * `block` (a computational operand when `is_edge` is `false`, a cross-block
 * edge-copy argument when `true`): increments its count, and — for the
 * first two occurrences only — records the site (`uit_encode_site`); a
 * third-or-later occurrence only bumps the count (its own site is never
 * read, since `elide_candidate_kind` only ever grants `Drop`/`Tee` to a
 * count of `1`/`2`).
 *
 * @param UseInfoTable t0  the table to update
 * @param u32 vreg  the VReg being used
 * @param u32 block  the block the use occurs in
 * @param bool is_edge  whether the use is a cross-block edge-copy argument
 * @return UseInfoTable  the updated table
 * @since #389 C1-5
 */
fn uit_record_use(t0: UseInfoTable, vreg: u32, block: u32, is_edge: bool) -> UseInfoTable {
    let t = uit_grow(t0, (vreg to u64) + 1)
    let site = uit_encode_site(block, is_edge)
    mut count: []u32 = teko::list::empty()
    mut sa: []u32 = teko::list::empty()
    mut sb: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= t.count.len { break }
        if (i to u32) == vreg {
            let prev = t.count[i]
            count = teko::list::push(count, prev + (1 to u32))
            if prev == (0 to u32) {
                sa = teko::list::push(sa, site)
                sb = teko::list::push(sb, t.site_b[i])
            } else if prev == (1 to u32) {
                sa = teko::list::push(sa, t.site_a[i])
                sb = teko::list::push(sb, site)
            } else {
                sa = teko::list::push(sa, t.site_a[i])
                sb = teko::list::push(sb, t.site_b[i])
            }
        } else {
            count = teko::list::push(count, t.count[i])
            sa = teko::list::push(sa, t.site_a[i])
            sb = teko::list::push(sb, t.site_b[i])
        }
        i++
    }
    UseInfoTable { count = count; site_a = sa; site_b = sb; is_param = t.is_param }
}

/**
 * uit_record_list — `uit_record_use` for every VReg in `vregs`, in order
 * (an `LCall`'s own `args`, or an `LJump`/`LBranch` edge's own block-args).
 *
 * @param UseInfoTable t0  the table to update
 * @param u32 block  the block the uses occur in
 * @param []u32 vregs  the VRegs used
 * @param bool is_edge  whether these are cross-block edge-copy arguments
 * @return UseInfoTable  the updated table
 * @since #389 C1-5
 */
fn uit_record_list(t0: UseInfoTable, block: u32, vregs: []u32, is_edge: bool) -> UseInfoTable {
    mut t = t0
    mut i: u64 = 0
    loop {
        if i >= vregs.len { break }
        t = uit_record_use(t, vregs[i], block, is_edge)
        i++
    }
    t
}

/**
 * uit_mark_param — record VReg `vreg` as some block's own incoming
 * block-param (FORCED-LOCAL, §5), growing the table first when needed.
 *
 * @param UseInfoTable t0  the table to update
 * @param u32 vreg  the block-param VReg
 * @return UseInfoTable  the updated table
 * @since #389 C1-5
 */
fn uit_mark_param(t0: UseInfoTable, vreg: u32) -> UseInfoTable {
    let t = uit_grow(t0, (vreg to u64) + 1)
    mut out: []bool = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= t.is_param.len { break }
        out = teko::list::push(out, if (i to u32) == vreg { true } else { t.is_param[i] })
        i++
    }
    UseInfoTable { count = t.count; site_a = t.site_a; site_b = t.site_b; is_param = out }
}

/**
 * uit_count — VReg `v`'s total recorded use count, or `0` when never used
 * (mirrors `wvt_get`'s own out-of-range default).
 *
 * @param UseInfoTable t  the table to read
 * @param u32 v  the VReg to look up
 * @return u32  its recorded (or default) use count
 * @since #389 C1-5
 */
fn uit_count(t: UseInfoTable, v: u32) -> u32 {
    let i = v to u64
    if i >= t.count.len { return 0 to u32 }
    t.count[i]
}

/**
 * uit_is_param — whether VReg `v` is some block's own incoming block-param.
 *
 * @param UseInfoTable t  the table to read
 * @param u32 v  the VReg to look up
 * @return bool  its recorded (or default `false`) param flag
 * @since #389 C1-5
 */
fn uit_is_param(t: UseInfoTable, v: u32) -> bool {
    let i = v to u64
    if i >= t.is_param.len { return false }
    t.is_param[i]
}

/**
 * uit_site_a — VReg `v`'s first recorded use site, or `0` when never used
 * (meaningless in that case — callers only ever read this after checking
 * `uit_count`).
 *
 * @param UseInfoTable t  the table to read
 * @param u32 v  the VReg to look up
 * @return u32  its first recorded (or default) use site
 * @since #389 C1-5
 */
fn uit_site_a(t: UseInfoTable, v: u32) -> u32 {
    let i = v to u64
    if i >= t.site_a.len { return 0 to u32 }
    t.site_a[i]
}

/**
 * uit_site_b — VReg `v`'s second recorded use site, or `0` when it has
 * fewer than two uses (meaningless in that case, mirrors `uit_site_a`).
 *
 * @param UseInfoTable t  the table to read
 * @param u32 v  the VReg to look up
 * @return u32  its second recorded (or default) use site
 * @since #389 C1-5
 */
fn uit_site_b(t: UseInfoTable, v: u32) -> u32 {
    let i = v to u64
    if i >= t.site_b.len { return 0 to u32 }
    t.site_b[i]
}

/**
 * record_inst_uses — record every VReg `inst` reads, whole-function use
 * analysis's own per-instruction step (`collect_use_info`): `LBin`'s `a`/
 * `b`, `LUn`'s `a`, `LCall`'s `args`, `LStore`'s `addr`/`value`,
 * `LFieldAddr`'s `base`, `LLoad`'s `addr`, `LRet`'s `value` (when present)
 * are all computational (`is_edge=false`); `LJump`'s `args` and `LBranch`'s
 * `cond` (computational) plus `t_args`/`f_args` (edge-copy arguments,
 * `is_edge=true`) round out the two terminator cases that read VRegs.
 * Every other case (`LConstInt`/`LConstFloat`/`LParam`/`LAlloca`/
 * `LGlobalAddr`, plus the not-yet-lowered `LCallIndirect`/`LFuncAddr`) reads
 * none.
 *
 * @param UseInfoTable t0  the table to update
 * @param u32 block  the block `inst` belongs to
 * @param LInst inst  the instruction to scan
 * @return UseInfoTable  the updated table
 * @since #389 C1-5
 */
fn record_inst_uses(t0: UseInfoTable, block: u32, inst: lir::LInst) -> UseInfoTable {
    match inst.op {
        lir::LBin as b => uit_record_use(uit_record_use(t0, b.a, block, false), b.b, block, false)
        lir::LUn as u => uit_record_use(t0, u.a, block, false)
        lir::LCall as c => uit_record_list(t0, block, c.args, false)
        lir::LRet as r => if r.has_value { uit_record_use(t0, r.value, block, false) } else { t0 }
        lir::LJump as j => uit_record_list(t0, block, j.args, true)
        lir::LBranch as br => {
            let t1 = uit_record_use(t0, br.cond, block, false)
            let t2 = uit_record_list(t1, block, br.t_args, true)
            uit_record_list(t2, block, br.f_args, true)
        }
        lir::LFieldAddr as fa => uit_record_use(t0, fa.base, block, false)
        lir::LLoad as l => uit_record_use(t0, l.addr, block, false)
        lir::LStore as s => uit_record_use(uit_record_use(t0, s.addr, block, false), s.value, block, false)
        _ => t0
    }
}

/**
 * collect_use_info — the whole-function use analysis (§5): every block's
 * own params (`uit_mark_param`) and every instruction's own reads
 * (`record_inst_uses`), one pass over the whole function.
 *
 * @param LFunc f  the function to scan
 * @return UseInfoTable  the whole-function use-info table
 * @since #389 C1-5
 */
fn collect_use_info(f: lir::LFunc) -> UseInfoTable {
    mut t = uit_empty()
    mut bi: u64 = 0
    loop {
        if bi >= f.blocks.len { break }
        let blk = f.blocks[bi]
        mut pi: u64 = 0
        loop {
            if pi >= blk.params.len { break }
            t = uit_mark_param(t, blk.params[pi])
            pi++
        }
        mut ii: u64 = 0
        loop {
            if ii >= blk.insts.len { break }
            t = record_inst_uses(t, blk.id, blk.insts[ii])
            ii++
        }
        bi++
    }
    t
}

/**
 * elide_candidate_kind — the TENTATIVE peephole category `use_info` alone
 * assigns a freshly-defined VReg `v` in block `owner_block` (§5): `Drop`
 * when its one and only use anywhere is a same-block computational
 * consumer; `Tee` when it has EXACTLY two uses — one same-block
 * computational consumer plus one same-block edge-copy argument (the
 * "must ALSO persist to a local" case); `Normal` otherwise (dead, a
 * cross-block use, a use as some OTHER block's param source that isn't
 * this one, multi-use beyond that shape, or a block-param itself). The
 * forward simulation (`compute_block_elide`) may still downgrade a
 * tentative `Drop`/`Tee` to `Normal` when the LIFO/no-barrier conditions do
 * not actually hold at emission order.
 *
 * @param UseInfoTable use_info  the whole-function use analysis
 * @param u32 owner_block  the block `v` is defined in
 * @param u32 v  the VReg to classify
 * @return ElideKind  the tentative decision tag
 * @since #389 C1-5
 */
fn elide_candidate_kind(use_info: UseInfoTable, owner_block: u32, v: u32) -> ElideKind {
    if uit_is_param(use_info, v) { return ElideKind::Normal }
    let n = uit_count(use_info, v)
    if n == (1 to u32) {
        let site = uit_site_a(use_info, v)
        if uit_site_block(site) == owner_block && !uit_site_is_edge(site) { return ElideKind::Drop }
        return ElideKind::Normal
    }
    if n == (2 to u32) {
        let sa = uit_site_a(use_info, v)
        let sb = uit_site_b(use_info, v)
        let a_comp = uit_site_block(sa) == owner_block && !uit_site_is_edge(sa)
        let a_edge = uit_site_block(sa) == owner_block && uit_site_is_edge(sa)
        let b_comp = uit_site_block(sb) == owner_block && !uit_site_is_edge(sb)
        let b_edge = uit_site_block(sb) == owner_block && uit_site_is_edge(sb)
        if a_comp && b_edge { return ElideKind::Tee }
        if b_comp && a_edge { return ElideKind::Tee }
        return ElideKind::Normal
    }
    ElideKind::Normal
}

/**
 * inst_is_barrier — whether `inst` is a §5 condition-4 hazard barrier (an
 * opaque `LCall`/`LCallIndirect`, or a possibly-aliasing `LStore`): a
 * pending `LLoad` result may not survive across one.
 *
 * @param LInst inst  the instruction to test
 * @return bool  true iff `inst.op` is `LCall`/`LCallIndirect`/`LStore`
 * @since #389 C1-5
 */
fn inst_is_barrier(inst: lir::LInst) -> bool {
    match inst.op {
        lir::LCall => true
        lir::LCallIndirect => true
        lir::LStore => true
        _ => false
    }
}

/**
 * inst_is_load — whether `inst` is an `LLoad` (§5 condition 4's own hazard
 * scope: ONLY a load result is forced off the stack by an intervening
 * barrier — an ordinary computed value safely survives on the real wasm
 * operand stack across a `call`, since a `call` only ever touches the top
 * of the stack it owns, never anything sitting below its own arguments).
 *
 * @param LInst inst  the instruction to test
 * @return bool  true iff `inst.op` is `LLoad`
 * @since #389 C1-5
 */
fn inst_is_load(inst: lir::LInst) -> bool {
    match inst.op {
        lir::LLoad => true
        _ => false
    }
}

/**
 * inst_operand_reads — the computational operand VRegs `inst` reads, in
 * PUSH order (the order `stackify_bin`/`stackify_un`/etc. actually emit
 * `local.get`s in) — the value-stack peephole's own per-instruction
 * "what would each `sc_use_operand` call see" list. Deliberately excludes
 * `LJump`/`LBranch`'s own edge-copy arguments (`t_args`/`f_args`/`LJump.
 * args`) — those are FORCED-LOCAL (§5) and never interact with `pending`.
 *
 * @param LInst inst  the instruction to inspect
 * @return []u32  its computational operand VRegs, in push order
 * @since #389 C1-5
 */
fn inst_operand_reads(inst: lir::LInst) -> []u32 {
    match inst.op {
        lir::LBin as b => [b.a, b.b]
        lir::LUn as u => [u.a]
        lir::LCall as c => c.args
        lir::LStore as s => [s.addr, s.value]
        lir::LFieldAddr as fa => [fa.base]
        lir::LLoad as l => [l.addr]
        lir::LRet as r => if r.has_value { [r.value] } else { teko::list::empty() }
        lir::LBranch as br => [br.cond]
        _ => teko::list::empty()
    }
}

/**
 * PendingItem — one value-stack peephole candidate `compute_block_elide`'s
 * own forward simulation currently believes is riding the real wasm
 * operand stack: its VReg, and whether its DEFINING instruction was an
 * `LLoad` (the one case `inst_is_barrier`'s own hazard rule forces off the
 * stack across a call/store).
 *
 * @since #389 C1-5
 */
type PendingItem = struct {
    /**
     * vreg — the pending value's own VReg.
     */
    vreg: u32
    /**
     * is_load — whether its defining instruction was an `LLoad`.
     */
    is_load: bool
}

/**
 * pending_top_vreg — the VReg of `pending`'s own top (most-recently-pushed)
 * entry, or `u32_unset()` when empty.
 *
 * @param []PendingItem pending  the simulated pending stack
 * @return u32  its top entry's VReg, or the sentinel
 * @since #389 C1-5
 */
fn pending_top_vreg(pending: []PendingItem) -> u32 {
    if pending.len == 0 { return u32_unset() }
    pending[pending.len - 1].vreg
}

/**
 * pending_pop — `pending` with its own top entry removed (a no-op when
 * already empty).
 *
 * @param []PendingItem pending  the simulated pending stack to shrink
 * @return []PendingItem  `pending` minus its last entry
 * @since #389 C1-5
 */
fn pending_pop(pending: []PendingItem) -> []PendingItem {
    let keep = if pending.len == 0 { 0 to u64 } else { pending.len - 1 }
    mut out: []PendingItem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= keep { break }
        out = teko::list::push(out, pending[i])
        i++
    }
    out
}

/**
 * PendingFlush — the outcome of one pending-stack resolution/cancellation
 * step: the simulated pending stack afterward, plus the (possibly
 * downgraded) decision table.
 *
 * @since #389 C1-5
 */
type PendingFlush = struct {
    /**
     * pending — the simulated pending stack after this step.
     */
    pending: []PendingItem
    /**
     * table — the decision table, with any newly-cancelled entries
     * downgraded to `ElideKind::Normal`.
     */
    table: ElideTable
}

/**
 * pending_matches_all — a NON-DESTRUCTIVE, read-only check: does the WHOLE
 * of `reversed_reads` (an instruction's own operand VRegs, in REVERSE push
 * order) match `pending`'s own top `len(reversed_reads)` entries, in order,
 * all the way through? `resolve_inst_operands` (§5 condition 3, LIFO) needs
 * to know this BEFORE committing to popping anything — see its own doc for
 * why a partial pop-as-you-go is unsound.
 *
 * @param []PendingItem pending0  the simulated pending stack to test
 * @param []u32 reversed_reads  the instruction's own operand VRegs, in
 *                               REVERSE push order
 * @return bool  true iff every one of `reversed_reads` matches, in order
 * @since #389 C1-5
 */
fn pending_matches_all(pending0: []PendingItem, reversed_reads: []u32) -> bool {
    mut pending = pending0
    mut i: u64 = 0
    loop {
        if i >= reversed_reads.len { break }
        if pending_top_vreg(pending) != reversed_reads[i] { return false }
        pending = pending_pop(pending)
        i++
    }
    true
}

/**
 * pending_pop_n — `pending` with its own top `n` entries removed (a no-op
 * past-the-end `n` clamps to emptying `pending`; mirrors `u32_stack_pop_n`).
 *
 * @param []PendingItem pending0  the simulated pending stack to shrink
 * @param u64 n  how many trailing entries to remove
 * @return []PendingItem  `pending0` minus its last `n` entries
 * @since #389 C1-5
 */
fn pending_pop_n(pending0: []PendingItem, n: u64) -> []PendingItem {
    mut pending = pending0
    mut i: u64 = 0
    loop {
        if i >= n { break }
        pending = pending_pop(pending)
        i++
    }
    pending
}

/**
 * resolve_inst_operands — match one instruction's WHOLE operand list against
 * `pending`, as a single contiguous-suffix run (§5 condition 3, LIFO):
 * `reversed_reads` is that instruction's own operand VRegs in REVERSE push
 * order (the last-pushed operand first). This is an ALL-OR-NOTHING test
 * (`pending_matches_all`, checked BEFORE any popping): when EVERY operand
 * matches, in order, pop them all — every one of them rides the stack. On
 * ANY mismatch — including a PARTIAL one, where some PREFIX of the reverse
 * scan already matched — cancel EVERY entry in the ORIGINAL `pending0` in
 * one shot (`cancel_all_pending`), not just what is still left after the
 * partial pops. A partial "pop the matches, cancel only what remains" draft
 * of this pass was UNSOUND: it let the already-matched (now-popped) entries
 * keep riding the stack while the mismatched (and earlier-in-push-order)
 * operands fell back to a fresh `local.get` — and that fresh `local.get`
 * physically pushes ON TOP of the still-riding value, inverting the two
 * operands' relative stack order. For a non-commutative op (`ISub`,
 * `IDivS`/`IDivU`, the shifts, EVERY comparison) this silently computed
 * `b - a` instead of `a - b` — a real, reproduced miscompile this
 * all-or-nothing shape closes (mirrors `sc_use_operands`'s own identical
 * fix on the emission side).
 *
 * @param []PendingItem pending0  the simulated pending stack
 * @param ElideTable table0  the decision table so far
 * @param []u32 reversed_reads  the instruction's own operand VRegs, in
 *                               REVERSE push order
 * @return PendingFlush  the pending stack + table after resolving every
 *                        operand of this instruction
 * @since #389 C1-5
 */
fn resolve_inst_operands(pending0: []PendingItem, table0: ElideTable, reversed_reads: []u32) -> PendingFlush {
    if pending_matches_all(pending0, reversed_reads) {
        return PendingFlush { pending = pending_pop_n(pending0, reversed_reads.len); table = table0 }
    }
    PendingFlush { pending = teko::list::empty(); table = cancel_all_pending(pending0, table0) }
}

/**
 * cancel_pending_loads — the §5 condition-4 barrier step (`inst_is_barrier`):
 * downgrade every `is_load` entry currently in `pending` to
 * `ElideKind::Normal` and drop it, leaving every non-load entry in place
 * (a plain computed value safely survives on the real wasm stack across a
 * call/store — only a load result is hazarded, `inst_is_load`'s own doc).
 *
 * @param []PendingItem pending  the simulated pending stack
 * @param ElideTable table0  the decision table so far
 * @return PendingFlush  the pending stack + table with every load cancelled
 * @since #389 C1-5
 */
fn cancel_pending_loads(pending: []PendingItem, table0: ElideTable) -> PendingFlush {
    mut table = table0
    mut out: []PendingItem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= pending.len { break }
        let item = pending[i]
        if item.is_load {
            table = et_set(table, item.vreg, ElideKind::Normal)
        } else {
            out = teko::list::push(out, item)
        }
        i++
    }
    PendingFlush { pending = out; table = table }
}

/**
 * cancel_all_pending — downgrade every entry still in `pending` to
 * `ElideKind::Normal` (the defensive end-of-block flush, §3.3's own
 * "the operand stack is empty at every label boundary" invariant): should
 * never actually find anything, given a correctly-computed `use_info`
 * (every same-block single/double use is, by construction, reachable
 * within the SAME block's own instruction list before its terminator), but
 * keeps `compute_block_elide` total rather than blind-trusting that
 * invariant (§3.2's own discipline).
 *
 * @param []PendingItem pending  the simulated pending stack
 * @param ElideTable table0  the decision table so far
 * @return ElideTable  the table with every still-pending entry cancelled
 * @since #389 C1-5
 */
fn cancel_all_pending(pending: []PendingItem, table0: ElideTable) -> ElideTable {
    mut table = table0
    mut i: u64 = 0
    loop {
        if i >= pending.len { break }
        table = et_set(table, pending[i].vreg, ElideKind::Normal)
        i++
    }
    table
}

/**
 * compute_block_elide — the value-stack peephole's own per-block forward
 * simulation (§5): walk `block.insts` (straight-line instructions THEN the
 * terminator) in program order, mirroring the exact def/use sequence
 * `stackify_insts`/`render_terminator` will later emit, maintaining a
 * `pending` list of VRegs tentatively believed to be riding the real wasm
 * operand stack. Each instruction's own WHOLE operand list is matched
 * against `pending` as one unit (`resolve_inst_operands`, `inst_operand_
 * reads` reversed — the last-pushed operand checked first, mirroring wasm's
 * own LIFO pop order). A barrier (`inst_is_barrier`) additionally cancels
 * every `is_load` entry STILL pending after its own operands are resolved
 * (`cancel_pending_loads`) — checked AFTER, not before, so a load feeding
 * the barrier instruction's OWN operands (e.g. an `LLoad` immediately
 * passed as a `call`'s own argument) gets a fair shot at riding the stack
 * into that very call, rather than being force-cancelled by the barrier it
 * is itself an operand of. Each instruction's own result, once its operands
 * are resolved, is tentatively classified (`elide_candidate_kind`) and —
 * when the tentative kind is `Drop`/`Tee` — pushed onto `pending`. Any entry
 * still pending once every instruction has been processed is defensively
 * cancelled (`cancel_all_pending`).
 *
 * @param LBlock block  the block to simulate
 * @param UseInfoTable use_info  the whole-function use analysis
 * @param ElideTable table0  the whole-function decision table so far
 * @return ElideTable  `table0`, extended with this block's own final
 *                      decisions
 * @since #389 C1-5
 */
fn compute_block_elide(block: lir::LBlock, use_info: UseInfoTable, table0: ElideTable) -> ElideTable {
    mut table = table0
    mut pending: []PendingItem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= block.insts.len { break }
        let inst = block.insts[i]
        let resolved = resolve_inst_operands(pending, table, u32_list_reverse(inst_operand_reads(inst)))
        pending = resolved.pending
        table = resolved.table
        if inst_is_barrier(inst) {
            let flushed = cancel_pending_loads(pending, table)
            pending = flushed.pending
            table = flushed.table
        }
        if inst.has_result {
            let kind = elide_candidate_kind(use_info, block.id, inst.result)
            table = et_set(table, inst.result, kind)
            if kind != ElideKind::Normal {
                pending = teko::list::push(pending, PendingItem { vreg = inst.result; is_load = inst_is_load(inst) })
            }
        }
        i++
    }
    cancel_all_pending(pending, table)
}

/**
 * compute_func_elide — the value-stack peephole's whole-function entry
 * point (§5): `collect_use_info` once, then `compute_block_elide` over
 * every block in turn, each accumulating into the SAME running
 * `ElideTable` (safe — every VReg is defined in exactly one block, so no
 * two blocks' own decisions ever collide).
 *
 * @param LFunc f  the function to analyze
 * @return ElideTable  the whole-function final decision table
 * @since #389 C1-5
 */
fn compute_func_elide(f: lir::LFunc) -> ElideTable {
    let use_info = collect_use_info(f)
    mut table = et_empty()
    mut bi: u64 = 0
    loop {
        if bi >= f.blocks.len { break }
        table = compute_block_elide(f.blocks[bi], use_info, table)
        bi++
    }
    table
}

/* ==========================================================================
 * C1-3 — CFG analysis: successors, RPO, dominators, natural loops.
 * ========================================================================== */

/**
 * TermTargets — the successor block ids one `LInst` terminator names:
 * `LRet` names none, `LJump` names one, `LBranch` names two (`t_target`
 * then `f_target`); every other `LOp` (a non-terminator, mid-block
 * instruction) also names none.
 */
type TermTargets = struct {
    /**
     * has_a — whether a first successor is present.
     */
    has_a: bool
    /**
     * a — the first successor block id (`LJump.target` or
     * `LBranch.t_target`); meaningless when `has_a` is false.
     */
    a: u32
    /**
     * has_b — whether a second successor is present (`LBranch` only).
     */
    has_b: bool
    /**
     * b — the second successor block id (`LBranch.f_target`); meaningless
     * when `has_b` is false.
     */
    b: u32
}

/**
 * term_targets_of — the successor block ids named by one instruction's op,
 * if it is a terminator (`LJump`/`LBranch`); none for every other case
 * (`LRet` included — a return has no CFG successor).
 *
 * @param LOp op  the instruction's op
 * @return TermTargets  its named successors, if any
 */
fn term_targets_of(op: lir::LOp) -> TermTargets {
    match op {
        lir::LJump as j => TermTargets { has_a = true; a = j.target; has_b = false; b = 0 to u32 }
        lir::LBranch as br => TermTargets { has_a = true; a = br.t_target; has_b = true; b = br.f_target }
        _ => TermTargets { has_a = false; a = 0 to u32; has_b = false; b = 0 to u32 }
    }
}

/**
 * blocks_by_id — `f`'s blocks reindexed so position `id` holds the block
 * whose own id is `id` (a positional table every later CFG-analysis
 * function reads in O(1); built via a safe per-id search rather than
 * blindly trusting `alloc_block`'s own "ids are dense and sequential"
 * contract, mirroring this file's own `stackify_param` "do NOT blind-trust"
 * discipline, §3.2).
 *
 * @param LFunc f  the function whose blocks to reindex
 * @return []LBlock  the positionally-indexed blocks
 */
fn blocks_by_id(f: lir::LFunc) -> []lir::LBlock {
    mut out: []lir::LBlock = teko::list::empty()
    mut id: u32 = 0 to u32
    loop {
        if (id to u64) >= f.blocks.len { break }
        out = teko::list::push(out, lir_block_search(f, id))
        id++
    }
    out
}

/**
 * lir_block_search — a linear search for `f`'s block whose id is `id` (the
 * safe fallback `blocks_by_id` builds its positional table from); defaults
 * to `f.blocks[0]` when absent (defensive only — every id this file queries
 * names a real block).
 *
 * @param LFunc f  the function to search
 * @param u32 id  the block id to find
 * @return LBlock  the matching block, or `f.blocks[0]`
 */
fn lir_block_search(f: lir::LFunc, id: u32) -> lir::LBlock {
    mut i: u64 = 0
    loop {
        if i >= f.blocks.len { break }
        if f.blocks[i].id == id { return f.blocks[i] }
        i++
    }
    f.blocks[0]
}

/**
 * successors_table — every block's `TermTargets`, positionally indexed by
 * block id (`blocks[i]` is block id `i`, `blocks_by_id`'s contract).
 *
 * @param []LBlock blocks  the positionally-indexed blocks
 * @return []TermTargets  each block's terminator targets, same order
 */
fn successors_table(blocks: []lir::LBlock) -> []TermTargets {
    mut out: []TermTargets = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= blocks.len { break }
        let insts = blocks[i].insts
        let tt = if insts.len == 0 { TermTargets { has_a = false; a = 0 to u32; has_b = false; b = 0 to u32 } } else { term_targets_of(insts[insts.len - 1].op) }
        out = teko::list::push(out, tt)
        i++
    }
    out
}

/**
 * successors_of — the distinct CFG successor block ids of block `id`
 * (`t_target`/`f_target` collapse to one entry when they name the same
 * block).
 *
 * @param []TermTargets succs  the module's successors table
 * @param u32 id  the block whose successors to read
 * @return []u32  its distinct successor block ids
 */
fn successors_of(succs: []TermTargets, id: u32) -> []u32 {
    let tt = succs[id to u64]
    mut out: []u32 = teko::list::empty()
    if tt.has_a { out = u32_list_add_unique(out, tt.a) }
    if tt.has_b { out = u32_list_add_unique(out, tt.b) }
    out
}

/**
 * LirRpoState — the post-order DFS fold state (mirrors `regalloc.tks`'s
 * own `RpoState`, recomputed here locally so C1 never depends on #443's
 * register-target RPO — D-W3, `backend-c1-wasm.md` §11).
 */
type LirRpoState = struct {
    /**
     * visited — the block ids the DFS has already entered.
     */
    visited: []u32
    /**
     * post — the post-order sequence so far (reversed to RPO by the
     * driver).
     */
    post: []u32
}

/**
 * lir_rpo_visit — the post-order DFS step: enter `id` (once), recurse into
 * every successor in order, then append `id` to the post-order.
 *
 * @param []TermTargets succs  the module's successors table
 * @param u32 id  the block id to visit
 * @param LirRpoState st  the visited set + post-order so far
 * @return LirRpoState  the updated visited set + post-order
 */
fn lir_rpo_visit(succs: []TermTargets, id: u32, st: LirRpoState) -> LirRpoState {
    if u32_list_has(st.visited, id) { return st }
    let ss = successors_of(succs, id)
    mut cur = LirRpoState { visited = teko::list::push(st.visited, id); post = st.post }
    mut i: u64 = 0
    loop {
        if i >= ss.len { break }
        cur = lir_rpo_visit(succs, ss[i], cur)
        i++
    }
    LirRpoState { visited = cur.visited; post = teko::list::push(cur.post, id) }
}

/**
 * lir_rpo_order — the reverse-post-order block-id sequence reachable from
 * `entry` (an unreachable block — dead code no valid Teko source emits
 * reachable-only-by-construction, but a `match`'s defensive fallback CAN
 * leave one, `regalloc.tks`'s own `reachable_blocks` precedent — is simply
 * never rendered, since nothing ever branches to it).
 *
 * @param []TermTargets succs  the module's successors table
 * @param u32 entry  the function's entry block id
 * @return []u32  the RPO block-id order, entry first
 */
fn lir_rpo_order(succs: []TermTargets, entry: u32) -> []u32 {
    let st = lir_rpo_visit(succs, entry, LirRpoState { visited = teko::list::empty(); post = teko::list::empty() })
    u32_list_reverse(st.post)
}

/**
 * PredEntry — one block's predecessor list (a `preds_table`'s positional
 * entry, indexed by block id).
 */
type PredEntry = struct {
    /**
     * preds — the distinct block ids with an edge into this block.
     */
    preds: []u32
}

/**
 * preds_table_empty — a predecessor table sized for `n` blocks, every entry
 * starting empty.
 *
 * @param u64 n  the block count to size for
 * @return []PredEntry  the empty-per-entry table
 */
fn preds_table_empty(n: u64) -> []PredEntry {
    mut out: []PredEntry = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= n { break }
        out = teko::list::push(out, PredEntry { preds = teko::list::empty() })
        i++
    }
    out
}

/**
 * preds_table_add — a copy of `t` with `source` appended to `target`'s
 * predecessor list (mirrors `minst.tks`'s per-index rebuild idiom).
 *
 * @param []PredEntry t  the predecessor table to update
 * @param u32 target  the block whose predecessor list gains `source`
 * @param u32 source  the predecessor block id to add
 * @return []PredEntry  the updated table
 */
fn preds_table_add(t: []PredEntry, target: u32, source: u32) -> []PredEntry {
    mut out: []PredEntry = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= t.len { break }
        let e = t[i]
        out = teko::list::push(out, if (i to u32) == target { PredEntry { preds = teko::list::push(e.preds, source) } } else { e })
        i++
    }
    out
}

/**
 * preds_table_of — the predecessor table built from every reachable
 * block's own successor edges (an edge `b -> s`, for every `s` of every
 * `b` in `order`, adds `b` to `s`'s predecessor list).
 *
 * @param []TermTargets succs  the module's successors table
 * @param []u32 order  the RPO-reachable block-id order
 * @return []PredEntry  the predecessor table, sized to `succs.len`
 */
fn preds_table_of(succs: []TermTargets, order: []u32) -> []PredEntry {
    mut t = preds_table_empty(succs.len)
    mut i: u64 = 0
    loop {
        if i >= order.len { break }
        let bid = order[i]
        let ss = successors_of(succs, bid)
        mut j: u64 = 0
        loop {
            if j >= ss.len { break }
            t = preds_table_add(t, ss[j], bid)
            j++
        }
        i++
    }
    t
}

/**
 * preds_of — the predecessor block ids recorded for `id`.
 *
 * @param []PredEntry t  the predecessor table
 * @param u32 id  the block whose predecessors to read
 * @return []u32  its predecessor block ids
 */
fn preds_of(t: []PredEntry, id: u32) -> []u32 {
    t[id to u64].preds
}

/**
 * rpo_pos_table — a positional `[]u32` giving each block id's own RPO
 * position (`u32_unset()` for a block absent from `order`, i.e.
 * unreachable) — the fast O(1) lookup `compute_idom`'s intersect loop reads
 * instead of repeatedly re-scanning `order` (`u32_pos`).
 *
 * @param u64 n  the block count to size for
 * @param []u32 order  the RPO block-id order
 * @return []u32  each block id's RPO position, or the sentinel
 */
fn rpo_pos_table(n: u64, order: []u32) -> []u32 {
    mut t: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= n { break }
        t = teko::list::push(t, u32_unset())
        i++
    }
    mut j: u64 = 0
    loop {
        if j >= order.len { break }
        t = u32_table_set(t, order[j], j to u32)
        j++
    }
    t
}

/**
 * idom_table_init — the immediate-dominator table's seed: `entry` dominates
 * itself, every other block starts unset (`compute_idom`'s fixpoint fills
 * them in).
 *
 * @param u64 n  the block count to size for
 * @param u32 entry  the function's entry block id
 * @return []u32  the seeded idom table
 */
fn idom_table_init(n: u64, entry: u32) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= n { break }
        out = teko::list::push(out, if (i to u32) == entry { entry } else { u32_unset() })
        i++
    }
    out
}

/**
 * FoundPred — the outcome of scanning a predecessor list for one already
 * processed by `compute_idom`'s current pass.
 */
type FoundPred = struct {
    /**
     * found — whether such a predecessor exists.
     */
    found: bool
    /**
     * pred — the first one found; meaningless when `found` is `false`.
     */
    pred: u32
}

/**
 * first_processed_pred — the first of `ps` whose `idom` entry is already
 * set (the Cooper-Harvey-Kennedy fixpoint's seed for a block's own
 * intersect chain — a reducible CFG processed in RPO order always has at
 * least one forward predecessor already processed by the time its own
 * successor is visited in the SAME left-to-right pass).
 *
 * @param []u32 ps  the block's predecessor ids
 * @param []u32 idom  the idom table so far this pass
 * @return FoundPred  the first already-processed predecessor, if any
 */
fn first_processed_pred(ps: []u32, idom: []u32) -> FoundPred {
    mut i: u64 = 0
    loop {
        if i >= ps.len { break }
        if u32_table_get(idom, ps[i]) != u32_unset() { return FoundPred { found = true; pred = ps[i] } }
        i++
    }
    FoundPred { found = false; pred = 0 to u32 }
}

/**
 * idom_intersect — the Cooper-Harvey-Kennedy "intersect" step: walk both
 * fingers up their own idom chains (toward `entry`, i.e. toward smaller RPO
 * position) until they meet, using `pos` to decide which finger is
 * currently behind.
 *
 * @param []u32 idom  the idom table so far
 * @param []u32 pos  each block id's RPO position (`rpo_pos_table`)
 * @param u32 a0  the first finger's starting block id
 * @param u32 b0  the second finger's starting block id
 * @return u32  the block id both fingers converge to (their common
 *              dominator)
 */
fn idom_intersect(idom: []u32, pos: []u32, a0: u32, b0: u32) -> u32 {
    mut a = a0
    mut b = b0
    loop {
        if a == b { return a }
        loop {
            if u32_table_get(pos, a) <= u32_table_get(pos, b) { break }
            a = u32_table_get(idom, a)
        }
        loop {
            if u32_table_get(pos, b) <= u32_table_get(pos, a) { break }
            b = u32_table_get(idom, b)
        }
    }
}

/**
 * idom_pass — one Cooper-Harvey-Kennedy fixpoint sweep over `order` (skips
 * `entry`): for each block with at least one already-processed predecessor
 * this sweep, recompute its immediate dominator as the intersection of
 * every already-processed predecessor.
 *
 * @param []u32 order  the RPO block-id order
 * @param []PredEntry preds  the predecessor table
 * @param []u32 pos  each block id's RPO position
 * @param []u32 idom0  the idom table before this sweep
 * @param u32 entry  the function's entry block id
 * @return IdomPassResult  the (possibly) updated idom table, and whether
 *                         any entry changed this sweep
 */
type IdomPassResult = struct {
    /**
     * idom — the idom table after this sweep.
     */
    idom: []u32
    /**
     * changed — whether any entry changed during this sweep.
     */
    changed: bool
}

fn idom_pass(order: []u32, preds: []PredEntry, pos: []u32, idom0: []u32, entry: u32) -> IdomPassResult {
    mut idom = idom0
    mut changed = false
    mut oi: u64 = 0
    loop {
        if oi >= order.len { break }
        let b = order[oi]
        if b != entry {
            let ps = preds_of(preds, b)
            let seed = first_processed_pred(ps, idom)
            if seed.found {
                mut new_idom = seed.pred
                mut pi: u64 = 0
                loop {
                    if pi >= ps.len { break }
                    let p = ps[pi]
                    if p != seed.pred && u32_table_get(idom, p) != u32_unset() {
                        new_idom = idom_intersect(idom, pos, p, new_idom)
                    }
                    pi++
                }
                if u32_table_get(idom, b) != new_idom {
                    idom = u32_table_set(idom, b, new_idom)
                    changed = true
                }
            }
        }
        oi++
    }
    IdomPassResult { idom = idom; changed = changed }
}

/**
 * compute_idom — the immediate-dominator table for every RPO-reachable
 * block: the Cooper-Harvey-Kennedy fixpoint (`idom_pass`), swept until no
 * entry changes.
 *
 * @param []u32 order  the RPO block-id order
 * @param []PredEntry preds  the predecessor table
 * @param u64 n  the block count to size the table for
 * @param u32 entry  the function's entry block id
 * @return []u32  the converged idom table
 */
fn compute_idom(order: []u32, preds: []PredEntry, n: u64, entry: u32) -> []u32 {
    let pos = rpo_pos_table(n, order)
    mut idom = idom_table_init(n, entry)
    loop {
        let pass = idom_pass(order, preds, pos, idom, entry)
        idom = pass.idom
        if !pass.changed { break }
    }
    idom
}

/**
 * CfgInfo — one function's whole reducible-CFG analysis, threaded
 * read-only through every CFGStackify placement function: the RPO order,
 * the successors table, the predecessor table, the immediate-dominator
 * table, and the entry block id.
 *
 * @since #389 C1-3
 */
type CfgInfo = struct {
    /**
     * order — the RPO block-id order, entry first.
     */
    order: []u32
    /**
     * succs — every block's terminator targets, positionally by id.
     */
    succs: []TermTargets
    /**
     * preds — every block's predecessor list, positionally by id.
     */
    preds: []PredEntry
    /**
     * idom — every reachable block's immediate dominator, positionally by
     * id.
     */
    idom: []u32
    /**
     * entry — the function's entry block id.
     */
    entry: u32
}

/**
 * build_cfg_info — compute a function's whole `CfgInfo` from its
 * positionally-indexed blocks: successors, RPO, predecessors, then
 * dominators.
 *
 * @param []LBlock blocks  the positionally-indexed blocks (`blocks_by_id`)
 * @param u32 entry  the function's entry block id
 * @return CfgInfo  the computed analysis
 */
fn build_cfg_info(blocks: []lir::LBlock, entry: u32) -> CfgInfo {
    let succs = successors_table(blocks)
    let order = lir_rpo_order(succs, entry)
    let preds = preds_table_of(succs, order)
    let idom = compute_idom(order, preds, blocks.len, entry)
    CfgInfo { order = order; succs = succs; preds = preds; idom = idom; entry = entry }
}

/**
 * dominates — whether block `a` dominates block `b` (every path from
 * `entry` to `b` passes through `a`), read by walking `b`'s own idom chain.
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @param u32 a  the candidate dominator
 * @param u32 b  the block to test
 * @return bool  whether `a` dominates `b`
 */
fn dominates(cfg: CfgInfo, a: u32, b: u32) -> bool {
    mut x = b
    loop {
        if x == a { return true }
        if x == cfg.entry { return false }
        x = u32_table_get(cfg.idom, x)
    }
}

/**
 * is_cfg_irreducible — the belt-and-suspenders reducibility guard (§3.4):
 * true iff some retreating edge (`pos(target) <= pos(source)` in RPO) has
 * a target that does NOT dominate its source — the Hecht-Ullman
 * characterization of an irreducible (multi-entry) cycle. Grounded
 * unreachable from structured Teko source (§3.1): the frontend's ONLY
 * cyclic construct (`loop`) always emits a single-header natural loop.
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @return bool  whether an irreducible cycle was found
 */
fn is_cfg_irreducible(cfg: CfgInfo) -> bool {
    mut i: u64 = 0
    loop {
        if i >= cfg.order.len { break }
        let b = cfg.order[i]
        let ss = successors_of(cfg.succs, b)
        mut j: u64 = 0
        loop {
            if j >= ss.len { break }
            let s = ss[j]
            if u32_pos(cfg.order, s) <= u32_pos(cfg.order, b) && !dominates(cfg, s, b) {
                return true
            }
            j++
        }
        i++
    }
    false
}

/**
 * is_loop_header — whether `h` is a natural-loop header: some reachable
 * block `x` has an edge `x -> h` that retreats in RPO AND `h` dominates
 * `x` (the Hecht-Ullman back-edge test, safe to apply unconditionally once
 * `is_cfg_irreducible` has already been checked function-wide).
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @param u32 h  the candidate loop-header block id
 * @return bool  whether `h` has a back-edge into it
 */
fn is_loop_header(cfg: CfgInfo, h: u32) -> bool {
    mut i: u64 = 0
    loop {
        if i >= cfg.order.len { break }
        let x = cfg.order[i]
        let ss = successors_of(cfg.succs, x)
        mut j: u64 = 0
        loop {
            if j >= ss.len { break }
            if ss[j] == h && u32_pos(cfg.order, h) <= u32_pos(cfg.order, x) && dominates(cfg, h, x) { return true }
            j++
        }
        i++
    }
    false
}

/**
 * natural_loop_body_from — the natural loop's block set for ONE back-edge
 * `latch -> h`: the standard backward-reachability closure (`h` and
 * `latch` seed the set; each newly added block's own predecessors are
 * added too, until no more are found) — every block that can reach `latch`
 * without leaving through `h` (`h`'s OWN other predecessors, e.g. the
 * pre-loop entry edge, are never explored, since the closure never expands
 * `h` itself).
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @param u32 h  the loop header block id
 * @param u32 latch  one back-edge source reaching `h`
 * @return []u32  the natural loop's block ids (including `h`)
 */
fn natural_loop_body_from(cfg: CfgInfo, h: u32, latch: u32) -> []u32 {
    if h == latch { return teko::list::push(teko::list::empty(), h) }
    mut body = teko::list::push(teko::list::push(teko::list::empty(), h), latch)
    mut wi: u64 = 1
    loop {
        if wi >= body.len { break }
        let m = body[wi]
        let ps = preds_of(cfg.preds, m)
        mut pi: u64 = 0
        loop {
            if pi >= ps.len { break }
            if !u32_list_has(body, ps[pi]) { body = teko::list::push(body, ps[pi]) }
            pi++
        }
        wi++
    }
    body
}

/**
 * loop_body_of — the FULL natural-loop block set for header `h`: the union
 * of `natural_loop_body_from` over every back-edge reaching it (ordinarily
 * exactly one, per the "only loop" law's single-latch construction, §3.1;
 * unioned defensively in case a future lowering ever grows a second
 * latch).
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @param u32 h  the loop header block id
 * @return []u32  the loop's whole block set (including `h`)
 */
fn loop_body_of(cfg: CfgInfo, h: u32) -> []u32 {
    mut body = teko::list::push(teko::list::empty(), h)
    mut i: u64 = 0
    loop {
        if i >= cfg.order.len { break }
        let x = cfg.order[i]
        let ss = successors_of(cfg.succs, x)
        mut j: u64 = 0
        loop {
            if j >= ss.len { break }
            if ss[j] == h && u32_pos(cfg.order, h) <= u32_pos(cfg.order, x) && dominates(cfg, h, x) {
                let contrib = natural_loop_body_from(cfg, h, x)
                mut k: u64 = 0
                loop {
                    if k >= contrib.len { break }
                    body = u32_list_add_unique(body, contrib[k])
                    k++
                }
            }
            j++
        }
        i++
    }
    body
}

/**
 * loop_exit_targets — the distinct successor block ids OUTSIDE `body` that
 * some block IN `body` names (the loop's own `break` targets — the "only
 * loop" law guarantees exactly one, `exitb`, but this is computed
 * generally).
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @param []u32 body  the loop's own block set (`loop_body_of`)
 * @return []u32  the distinct exit target block ids
 */
fn loop_exit_targets(cfg: CfgInfo, body: []u32) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= body.len { break }
        let ss = successors_of(cfg.succs, body[i])
        mut j: u64 = 0
        loop {
            if j >= ss.len { break }
            if !u32_list_has(body, ss[j]) { out = u32_list_add_unique(out, ss[j]) }
            j++
        }
        i++
    }
    out
}

/**
 * MergeResult — the outcome of searching for a branch block's own NEW
 * if/else merge (`merge_target_of`).
 */
type MergeResult = struct {
    /**
     * found — whether a merge was found.
     */
    found: bool
    /**
     * target — the merge block id; meaningless when `found` is `false`.
     */
    target: u32
}

/**
 * merge_target_of — the block `b`'s own NEW if/else merge, if any: a block
 * `m` with `idom(m) == b` (created exactly at `b`'s own branch — a block
 * can branch at most once, so at most one such `m` exists) AND indegree
 * `>= 2` (a genuine join, not a straight continuation) AND NOT already an
 * open scope in `scopes` (the loop-exit exclusion: a loop's OWN exit block
 * can ALSO have `idom == b` for some branch `b` buried deep inside the
 * loop body whenever multiple `break` sites happen to share `b` as their
 * nearest common dominator — that block must stay the enclosing loop's
 * OWN wrapped exit, never an inner branch's inline "new merge", so it is
 * excluded here whenever its wrapping scope is already open, §3.3).
 *
 * @param CfgInfo cfg  the function's CFG analysis
 * @param []WasmScope scopes  the currently open scope stack
 * @param u32 b  the branch block to search from
 * @return MergeResult  the found merge, if any
 */
fn merge_target_of(cfg: CfgInfo, scopes: []WasmScope, b: u32) -> MergeResult {
    mut i: u64 = 0
    loop {
        if i >= cfg.order.len { break }
        let m = cfg.order[i]
        let is_candidate = m != b && u32_table_get(cfg.idom, m) == b && preds_of(cfg.preds, m).len >= 2
        if is_candidate && !wasm_scope_stack_depth_of(scopes, m).found {
            return MergeResult { found = true; target = m }
        }
        i++
    }
    MergeResult { found = false; target = 0 to u32 }
}

/**
 * filter_relevant_exits — a loop's own exit targets (`loop_exit_targets`)
 * narrowed to the ones that genuinely need THIS loop's own wrapping
 * `block`: excludes any target already reachable via an open ANCESTOR
 * scope (a labelled `break OuterLoop` skipping past this loop entirely —
 * its `br` resolves at the ancestor's OWN depth, needing no new wrap here)
 * or already equal to the caller's own `stop` (deferred to that ancestor's
 * post-region continuation). The "only loop" law guarantees at most one
 * entry survives the filter — a genuinely new local exit target.
 *
 * @param []u32 exits  the loop's raw exit targets (`loop_exit_targets`)
 * @param []WasmScope scopes  the currently open scope stack
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @return []u32  the exit targets this loop must wrap itself
 */
fn filter_relevant_exits(exits: []u32, scopes: []WasmScope, stop: EdgeStop) -> []u32 {
    mut out: []u32 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= exits.len { break }
        let e = exits[i]
        let already_open = wasm_scope_stack_depth_of(scopes, e).found
        if !already_open && !edge_stop_matches(stop, e) {
            out = teko::list::push(out, e)
        }
        i++
    }
    out
}

/* ==========================================================================
 * C1-3 — the recursive region renderer.
 * ========================================================================== */

/**
 * EdgeStop — the caller-supplied "natural merge continuation" a region's
 * rendering defers to instead of recursing further: reaching this exact
 * block id ends the CURRENT region without emitting it, trusting the
 * caller (the branch/loop that set it) to render it exactly once, right
 * after its own scope closes.
 */
type EdgeStop = struct {
    /**
     * has — whether a stop target is set (a top-level render has none).
     */
    has: bool
    /**
     * target — the block id to stop at; meaningless when `has` is `false`.
     */
    target: u32
}

/**
 * edge_stop_none — no stop target (the top-level function render, and
 * every loop header's own straight-line body).
 *
 * @return EdgeStop  the empty stop
 */
fn edge_stop_none() -> EdgeStop {
    EdgeStop { has = false; target = 0 to u32 }
}

/**
 * edge_stop_at — a stop target of `b` (an enclosing branch's own
 * newly-found merge, §3.3's `merge_target_of`).
 *
 * @param u32 b  the block id to stop at
 * @return EdgeStop  the set stop
 */
fn edge_stop_at(b: u32) -> EdgeStop {
    EdgeStop { has = true; target = b }
}

/**
 * edge_stop_matches — whether `stop` is set to exactly `b`.
 *
 * @param EdgeStop stop  the stop to test
 * @param u32 b  the block id to compare against
 * @return bool  whether `stop` targets `b`
 */
fn edge_stop_matches(stop: EdgeStop, b: u32) -> bool {
    stop.has && stop.target == b
}

/**
 * RenderEnv — the read-only environment threaded through the whole
 * recursive region renderer: the LIR function (straight-line lowering
 * needs its `param_types`), its positionally-indexed blocks, the call-
 * target resolver, its whole CFG analysis, and the target pointer width.
 */
type RenderEnv = struct {
    /**
     * func — the LIR function being rendered.
     */
    func: lir::LFunc
    /**
     * blocks — `func`'s blocks, positionally indexed by id.
     */
    blocks: []lir::LBlock
    /**
     * symbols — the call-target resolver (`LCall`).
     */
    symbols: WasmSymbolTable
    /**
     * cfg — the function's whole CFG analysis.
     */
    cfg: CfgInfo
    /**
     * ptr64 — the target pointer width (`false` = wasm32, the default;
     * `true` = wasm64) — `LParam`/`LLoad`/`LStore`/`LCall`'s own `Ptr`-typed
     * sites read this (#389 C1-7).
     */
    ptr64: bool
}

/**
 * EdgeResultKind — the three shapes `render_edge` can resolve an edge to:
 * `Stop` (the edge reached the caller's own `stop` target — nothing more to
 * render on this path, the caller renders `target` itself once, after its
 * own scope closes), `Branch` (the edge's target is an open scope — a `br`
 * was emitted, a `continue`, a `break`, or a labelled skip past several
 * enclosing scopes at once), or `More` (the edge's target is neither `stop`
 * nor already open — the caller must keep rendering by recursing into it
 * directly, the straight-line "this is simply the next block" fallthrough
 * case). Named `EdgeResultKind` (not `EdgeResult`) to stay distinct from the
 * `EdgeResult` struct below, whose `kind` field it types. Purely an internal
 * control-flow tag — never serialized — so no wire mapping is needed.
 */
pub type EdgeResultKind = enum { Stop; Branch; More }

/**
 * EdgeResult — one edge's fully-resolved outcome (`render_edge`): the
 * advanced context (its block-arg copies already emitted) and which of the
 * three shapes it took.
 */
type EdgeResult = struct {
    /**
     * ctx — the context advanced past the edge's own block-arg copies (and
     * its `br`, when `kind` is `EdgeResultKind::Branch`).
     */
    ctx: StackifyCtx
    /**
     * kind — the edge's resolved `EdgeResultKind`.
     */
    kind: EdgeResultKind
    /**
     * target — the edge's own target block id.
     */
    target: u32
}

/**
 * render_edge — resolve one `LJump`/`LBranch` edge (§3.3 step 4): copy its
 * block-args into the target's params (`emit_edge_copies`), then classify
 * the target as the caller's own `stop`, an already-open scope (emitting
 * `br`), or neither (the caller must recurse).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param u32 target  the edge's target block id
 * @param []u32 args  the edge's own block-args
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @return EdgeResult | error  the resolved edge, or `emit_edge_copies`'s
 *                             propagated internal error
 */
fn render_edge(ctx0: StackifyCtx, env: RenderEnv, target: u32, args: []u32, stop: EdgeStop) -> EdgeResult | error {
    let params = env.blocks[target to u64].params
    let copied = match emit_edge_copies(ctx0, params, args) { StackifyCtx as c => c; error as e => return e }
    if edge_stop_matches(stop, target) {
        return EdgeResult { ctx = copied; kind = EdgeResultKind::Stop; target = target }
    }
    let sd = wasm_scope_stack_depth_of(copied.scopes, target)
    if sd.found {
        return EdgeResult { ctx = sc_br(copied, sd.depth); kind = EdgeResultKind::Branch; target = target }
    }
    EdgeResult { ctx = copied; kind = EdgeResultKind::More; target = target }
}

/**
 * render_arm — render one `if`/`else` arm (or a plain `LJump`'s single
 * edge): resolve its edge (`render_edge`), recursing into the target only
 * when neither `stop` nor an open scope claimed it.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param u32 target  the arm's target block id
 * @param []u32 args  the arm's own block-args
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @return StackifyCtx | error  the advanced context, or a propagated error
 */
fn render_arm(ctx0: StackifyCtx, env: RenderEnv, target: u32, args: []u32, stop: EdgeStop) -> StackifyCtx | error {
    let er = match render_edge(ctx0, env, target, args, stop) { EdgeResult as r => r; error as e => return e }
    if er.kind == EdgeResultKind::More {
        return render_region(er.ctx, env, stop, er.target)
    }
    er.ctx
}

/**
 * all_but_last — `insts` without its own last element (a block's
 * instructions minus its terminator).
 *
 * @param []LInst insts  the instruction stream
 * @return []LInst  every instruction but the last
 */
fn all_but_last(insts: []lir::LInst) -> []lir::LInst {
    let keep = if insts.len == 0 { 0 to u64 } else { insts.len - 1 }
    mut out: []lir::LInst = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= keep { break }
        out = teko::list::push(out, insts[i])
        i++
    }
    out
}

/**
 * render_jump_terminator — an `LJump` terminator: resolve its one edge
 * (`render_edge`), recursing into its target when neither `stop` nor an
 * open scope claimed it.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @param LJump j  the jump terminator
 * @return StackifyCtx | error  the advanced context, or a propagated error
 */
fn render_jump_terminator(ctx0: StackifyCtx, env: RenderEnv, stop: EdgeStop, j: lir::LJump) -> StackifyCtx | error {
    let er = match render_edge(ctx0, env, j.target, j.args, stop) { EdgeResult as r => r; error as e => return e }
    if er.kind == EdgeResultKind::More {
        return render_region(er.ctx, env, stop, er.target)
    }
    er.ctx
}

/**
 * render_branch_terminator — an `LBranch` terminator: the structured `if`
 * diamond (§3.3 step 4). Finds `b`'s own new merge, if any
 * (`merge_target_of`), renders `local.get cond; if …then-arm… else
 * …else-arm… end` (both arms sharing the SAME inner stop — the found
 * merge, or `stop` passed straight through when there is none), then
 * continues rendering the merge itself (under the OUTER `stop`) once the
 * `if` closes. The `cond` read goes through `sc_use_operand` (§5's own
 * ALWAYS-STACK fused-compare case): a `cond` produced by an in-block
 * compare that feeds ONLY this branch rides the operand stack straight
 * into the `if`, never round-tripping through a local.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @param u32 b  the branch's own block id (`merge_target_of` needs it)
 * @param LBranch br  the branch terminator
 * @return StackifyCtx | error  the advanced context, or a propagated error
 */
fn render_branch_terminator(ctx0: StackifyCtx, env: RenderEnv, stop: EdgeStop, b: u32, br: lir::LBranch) -> StackifyCtx | error {
    let mr = merge_target_of(env.cfg, ctx0.scopes, b)
    let inner_stop = if mr.found { edge_stop_at(mr.target) } else { stop }
    let opened = sc_open_if(sc_use_operand(ctx0, br.cond))
    let then_done = match render_arm(opened, env, br.t_target, br.t_args, inner_stop) { StackifyCtx as c => c; error as e => return e }
    let mid = sc_byte(then_done, WASM_OP_ELSE)
    let else_done = match render_arm(mid, env, br.f_target, br.f_args, inner_stop) { StackifyCtx as c => c; error as e => return e }
    let closed = sc_close_scope(else_done)
    if mr.found {
        return render_region(closed, env, stop, mr.target)
    }
    closed
}

/**
 * render_terminator — dispatch one block's own terminator instruction
 * (`LRet`/`LJump`/`LBranch` — the only three `LOp` cases a well-formed
 * block ever ends in).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @param u32 b  the enclosing block's own id (`LBranch` needs it)
 * @param LInst term  the terminator instruction
 * @return StackifyCtx | error  the advanced context, or a propagated/named
 *                              internal error
 */
fn render_terminator(ctx0: StackifyCtx, env: RenderEnv, stop: EdgeStop, b: u32, term: lir::LInst) -> StackifyCtx | error {
    match term.op {
        lir::LRet as r => stackify_ret(ctx0, r)
        lir::LJump as j => render_jump_terminator(ctx0, env, stop, j)
        lir::LBranch as br => render_branch_terminator(ctx0, env, stop, b, br)
        _ => error { message = "stackify: a block must end in LRet/LJump/LBranch (internal)" }
    }
}

/**
 * render_straight — render block `b`'s own straight-line instructions
 * (`stackify_insts`, every instruction but the terminator) then its
 * terminator (`render_terminator`).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @param u32 b  the block id to render
 * @return StackifyCtx | error  the advanced context, or a propagated/named
 *                              internal error
 */
fn render_straight(ctx0: StackifyCtx, env: RenderEnv, stop: EdgeStop, b: u32) -> StackifyCtx | error {
    let blk = env.blocks[b to u64]
    if blk.insts.len == 0 {
        return error { message = "stackify: a block with no instructions has no terminator (internal)" }
    }
    let stepped = match stackify_insts(ctx0, env.func, env.symbols, all_but_last(blk.insts), env.ptr64) { StackifyCtx as c => c; error as e => return e }
    render_terminator(stepped, env, stop, b, blk.insts[blk.insts.len - 1])
}

/**
 * err_irreducible — the NAMED honest-stop `C1-irreducible` (§3.4): a
 * belt-and-suspenders tripwire for a lowering bug that emitted a CFG shape
 * structured Teko source cannot produce — never expected to fire from
 * valid input.
 *
 * @param str detail  which specific defensive check tripped
 * @return error  the named error
 */
fn err_irreducible(detail: str) -> error {
    error { message = $"stackify: C1-irreducible — irreducible control flow ({detail}) — unreachable from structured Teko source; report to the compiler team" }
}

/**
 * render_loop — a loop header `h` (§3.3 step 3): wraps the header..body
 * span in `loop … end` (a `br` to it is `continue`); when the loop has a
 * genuinely new (not already open, not the caller's own `stop`) exit
 * target (`filter_relevant_exits`), additionally wraps the whole thing in
 * an outer `block … end` (a `br` to it is `break`), then continues
 * rendering the exit target under the OUTER `stop` once both close. More
 * than one such newly-relevant exit target is the NAMED honest-stop
 * `C1-irreducible` — the "only loop" law guarantees a single loop has at
 * most one (every `break`, however deeply nested, targets the SAME
 * `exitb`; a labelled `break` past an ENCLOSING loop always resolves via
 * an already-open ancestor scope, never a second fresh target here, §3.3).
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @param u32 h  the loop header block id
 * @return StackifyCtx | error  the advanced context, or the named
 *                              `C1-irreducible` stop
 */
fn render_loop(ctx0: StackifyCtx, env: RenderEnv, stop: EdgeStop, h: u32) -> StackifyCtx | error {
    let body = loop_body_of(env.cfg, h)
    let exits = loop_exit_targets(env.cfg, body)
    let relevant = filter_relevant_exits(exits, ctx0.scopes, stop)
    if relevant.len > 1 {
        return err_irreducible("a loop with more than one newly-reachable exit target")
    }
    let has_exit = relevant.len == 1
    let exit_target = if has_exit { relevant[0] } else { 0 to u32 }
    let opened = if has_exit { sc_open_block(ctx0, exit_target) } else { ctx0 }
    let loop_opened = sc_open_loop(opened, h)
    let body_done = match render_straight(loop_opened, env, edge_stop_none(), h) { StackifyCtx as c => c; error as e => return e }
    let loop_closed = sc_close_scope(body_done)
    if !has_exit { return loop_closed }
    render_region(sc_close_scope(loop_closed), env, stop, exit_target)
}

/**
 * render_region — render block `b` and everything its own control flow
 * naturally leads into, stopping at `stop` (or at a `br`) rather than
 * recursing forever: a loop header dispatches to `render_loop`; every
 * other block dispatches to `render_straight`.
 *
 * @param StackifyCtx ctx0  the context to extend
 * @param RenderEnv env  the read-only render environment
 * @param EdgeStop stop  the enclosing region's own stop target, if any
 * @param u32 b  the block id to render
 * @return StackifyCtx | error  the advanced context, or a propagated/named
 *                              error
 */
fn render_region(ctx0: StackifyCtx, env: RenderEnv, stop: EdgeStop, b: u32) -> StackifyCtx | error {
    if edge_stop_matches(stop, b) { return ctx0 }
    if is_loop_header(env.cfg, b) { return render_loop(ctx0, env, stop, b) }
    render_straight(ctx0, env, stop, b)
}

/**
 * stackify_control — the CFGStackify entry point (§3): reconstruct one
 * `LFunc`'s reducible CFG into structured control flow, starting from its
 * entry block. Checks reducibility ONCE, function-wide
 * (`is_cfg_irreducible`), before any placement — an irreducible cycle is
 * the NAMED honest-stop `C1-irreducible`. Deliberately fuses the design
 * doc's two-phase shape (an abstract marker stream, then a separate byte
 * emitter) into ONE recursive pass: nothing in this MVP consumes an
 * abstract marker stream besides the byte emitter itself, so a separate
 * `StructuredFunc`/`WasmMarker` representation would be pure ceremony (the
 * M.1 "no unreachable complexity" discipline) — `render_region` emits
 * final wasm bytes directly, threading the SAME scope-stack/valtype state
 * `stackify_func`'s straight-line lowering already threads. When `f`
 * contains at least one `LAlloca`, the shadow-stack prologue
 * (`emit_frame_prologue`) is emitted FIRST, ahead of the entry block's own
 * bytes (C1-4, §6.1) — a frameless function pays nothing.
 *
 * @param LFunc f  the function to lower (its `blocks` a reducible CFG)
 * @param WasmSymbolTable symbols  the call-target/data-symbol resolver
 *                                 (`LCall`/`LGlobalAddr`)
 * @param bool ptr64  the target pointer width (`false` = wasm32, the
 *                    default; #389 C1-7)
 * @return StackifyCtx | error  the fully-rendered context (its `body` NOT
 *                              yet closed by the function's own trailing
 *                              `end`), or a NAMED honest-stop
 *
 * @since #389 C1-3
 */
pub fn stackify_control(f: lir::LFunc, symbols: WasmSymbolTable, ptr64: bool) -> StackifyCtx | error {
    if f.blocks.len == 0 {
        return error { message = "stackify: a function with no blocks has no entry (internal)" }
    }
    let blocks = blocks_by_id(f)
    let entry = f.blocks[0].id
    let cfg = build_cfg_info(blocks, entry)
    if is_cfg_irreducible(cfg) {
        return err_irreducible("a multi-entry loop (a back-edge whose target does not dominate its source)")
    }
    let env = RenderEnv { func = f; blocks = blocks; symbols = symbols; cfg = cfg; ptr64 = ptr64 }
    let seed = StackifyCtx { body = teko::list::empty(); vtypes = wvt_empty(); scopes = teko::list::empty(); next_scratch = f.next_vreg; has_frame = false; frame_base = 0 to u32; slots = wst_empty(); elide = compute_func_elide(f); pending = teko::list::empty() }
    let allocas = collect_alloca_insts(f)
    let ctx0 = if allocas.len == 0 { seed } else { emit_frame_prologue(seed, compute_wasm_frame_layout(allocas)) }
    render_region(ctx0, env, edge_stop_none(), entry)
}

/**
 * wasm_local_groups_of — the non-parameter locals declared after `from`
 * (inclusive) up to `to` (exclusive), read from `vtypes` and run-length
 * compressed into `(count, valtype)` groups (wasm's own local-declaration
 * shape, `objfile_wasm.tks`'s `WasmLocalGroup`).
 *
 * @param WasmVTypeTable vtypes  the fully-populated per-VReg valtype table
 * @param u32 from  the first non-parameter VReg id (== `f.n_params`)
 * @param u32 to  one past the last VReg id (== `f.next_vreg`)
 * @return []WasmLocalGroup  the run-length-compressed local declarations
 */
fn wasm_local_groups_of(vtypes: WasmVTypeTable, from: u32, to: u32) -> []WasmLocalGroup {
    mut groups: []WasmLocalGroup = teko::list::empty()
    mut i: u32 = from
    mut cur_vt: u8 = 0 to u8
    mut cur_count: u32 = 0 to u32
    mut have_cur = false
    loop {
        if i >= to { break }
        let vt = wvt_get(vtypes, i)
        if have_cur && vt == cur_vt {
            cur_count++
        } else {
            if have_cur {
                groups = teko::list::push(groups, WasmLocalGroup { count = cur_count; valtype = cur_vt })
            }
            cur_vt = vt
            cur_count = 1 to u32
            have_cur = true
        }
        i++
    }
    if have_cur {
        groups = teko::list::push(groups, WasmLocalGroup { count = cur_count; valtype = cur_vt })
    }
    groups
}

/**
 * WasmFuncBody — one straight-line `LFunc`'s lowered wasm code-entry
 * payload: its non-parameter local declarations and its instruction body
 * bytes (already terminated by the code-entry `end`, `0x0B`). The caller
 * (a later slice, wiring a whole `WasmModule`) pairs this with a resolved
 * `type_index` to build the `objfile_wasm.tks` `WasmFunc` `emit_wasm`
 * packages into the code section — this slice stops at the per-function
 * payload, since interning a module-wide type table is C1-5 "link/dispatch"
 * territory, not per-function instruction lowering.
 *
 * @since #389 C1-2
 */
pub type WasmFuncBody = struct {
    /**
     * local_groups — the non-parameter locals, as run-length `(count,
     * valtype)` groups in local-index order.
     */
    local_groups: []WasmLocalGroup
    /**
     * body — the function body bytes, ending with the code-entry `end`
     * (`0x0B`).
     */
    body: []byte
}

/**
 * stackify_func — lower one `LFunc` (single-block OR multi-block) to its
 * `WasmFuncBody`: every VReg becomes its own wasm local (`backend-c1-wasm.md`
 * §4.1 — no register allocation, just a total `VReg -> local index` identity
 * map, extended with fresh scratch ids past `next_vreg` for parallel-copy
 * staging, §4.3), the whole CFG renders via `stackify_control` (the
 * CFGStackify pass, §3), and the body is closed with the code-entry `end`.
 * The former `C1-3-required` single-block restriction is GONE — a reducible
 * multi-block CFG is now fully supported; only a genuinely irreducible one
 * (a lowering bug, never valid Teko source) still stops honestly.
 *
 * @param LFunc f  the function to lower
 * @param WasmSymbolTable calls  the call-target resolver (`LCall`)
 * @param bool ptr64  the target pointer width (`false` = wasm32, the
 *                    default; #389 C1-7)
 * @return WasmFuncBody | error  the lowered payload, or a propagated/named
 *                               honest-stop (`C1-irreducible`, an
 *                               instruction's own stop, or an internal error)
 */
pub fn stackify_func(f: lir::LFunc, calls: WasmSymbolTable, ptr64: bool) -> WasmFuncBody | error {
    let done = match stackify_control(f, calls, ptr64) { StackifyCtx as c => c; error as e => return e }
    let body = teko::list::push(done.body, WASM_OP_END)
    let groups = wasm_local_groups_of(done.vtypes, f.n_params, done.next_scratch)
    WasmFuncBody { local_groups = groups; body = body }
}

/**
 * WasmRodataLayout — the module's whole rodata assembly (C1-4, §6.1's
 * "rodata at a fixed low base"): every `LRodata` entry placed back-to-back
 * starting at `base` as ONE concatenated data segment (`objfile_wasm.tks`'s
 * `WasmDataSegment`), plus the per-symbol offset table `LGlobalAddr`
 * resolves against.
 *
 * @since #389 C1-4
 */
pub type WasmRodataLayout = struct {
    /**
     * segment — the concatenated rodata bytes as one active data segment
     * placed at `base`.
     */
    segment: WasmDataSegment
    /**
     * symbols — each interned `LRodata` entry's own symbol, parallel to
     * `offsets`.
     */
    symbols: []str
    /**
     * offsets — each entry's own absolute linear-memory offset, parallel
     * to `symbols`.
     */
    offsets: []u32
    /**
     * end — one past the last rodata byte (`base` plus the total rodata
     * size) — the caller's shadow-stack region starts here (§6.1).
     */
    end: u32
}

/**
 * wasm_layout_rodata — place every `LRodata` entry back-to-back starting at
 * `base`: string bytes carry no alignment requirement beyond `1`, so no
 * padding is needed between entries. Mirrors `encode_arm64.tks`'s
 * `encode_rodata`, PARALLELED rather than reused (§1.3) — wasm needs no
 * per-entry symbol TABLE (no linker to resolve against at this slice), just
 * the offset table this per-instruction `LGlobalAddr` lowering reads.
 *
 * @param []LRodata rodata  the module's interned rodata table
 * @param u32 base  the linear-memory offset the first byte lands at
 * @return WasmRodataLayout  the data segment + the symbol->offset table
 */
pub fn wasm_layout_rodata(rodata: []lir::LRodata, base: u32) -> WasmRodataLayout {
    mut bytes: []byte = teko::list::empty()
    mut symbols: []str = teko::list::empty()
    mut offsets: []u32 = teko::list::empty()
    mut off = base
    mut i: u64 = 0
    loop {
        if i >= rodata.len { break }
        let rd = rodata[i]
        symbols = teko::list::push(symbols, rd.symbol)
        offsets = teko::list::push(offsets, off)
        bytes = append_bytes(bytes, rd.bytes)
        off = off + (rd.bytes.len to u32)
        i++
    }
    WasmRodataLayout { segment = WasmDataSegment { offset = base; bytes = bytes }; symbols = symbols; offsets = offsets; end = off }
}

/**
 * wasm_data_addr_of — o endereço ABSOLUTO de memória linear da entrada rodata cujo
 * símbolo é `target`, buscado nas tabelas paralelas `symbols`/`offsets` de um layout
 * de rodata (#594 T-B4). É a resolução do ALVO de um ponteiro data→data no wasm:
 * como o data segment ativo fica numa base fixa e conhecida na emissão
 * (`wasm_rodata_base`), o offset de cada entrada JÁ é o seu endereço absoluto final,
 * então um ponteiro intra-data é uma constante i32 de compile-time — sem relocation,
 * o endereço é gravado direto no slot. Devolve um erro NOMEADO (não um skip silencioso)
 * quando nenhuma entrada carrega esse símbolo, mantendo o miscompile impossível.
 *
 * @param []str symbols  os símbolos das entradas laid-out, paralelo a `offsets`
 * @param []u32 offsets  o endereço absoluto de memória linear de cada entrada
 * @param str target  o símbolo da entrada referenciada
 * @return u32 | error  o endereço absoluto do alvo, ou um erro nomeado
 */
fn wasm_data_addr_of(symbols: []str, offsets: []u32, target: str) -> u32 | error {
    mut i: u64 = 0
    loop {
        if i >= symbols.len { break }
        if symbols[i] == target { return offsets[i] }
        i++
    }
    error { message = $"stackify: rodata-internal pointer targets unknown rodata symbol '{target}' (#594 T-B4)" }
}

/**
 * wasm_relocate_rodata — resolve as relocations INTERNAS de ponteiro de cada entrada
 * rodata num layout já montado, devolvendo o layout com os bytes do seu data segment
 * patcheados in-place (#594 T-B4). Para cada `LDataReloc { offset; target }` da
 * entrada `i`, o endereço absoluto de `target` (`wasm_data_addr_of`) é escrito no slot
 * de ponteiro no byte segment-relativo `(layout.offsets[i] - base) + offset`. O wasm
 * NÃO tem linker e o data segment ativo fica numa base fixa conhecida na emissão
 * (`wasm_rodata_base`), então um ponteiro intra-data é uma constante i32 de
 * compile-time escrita direto no segment — o análogo wasm das relocations data→data
 * `.rela.rodata`/`__const` dos writers nativos (T-B2/T-B3), emitido SEM registro de
 * relocation. O slot de 8 bytes que o serializer Tier-B reserva é preenchido
 * low-word-first: no wasm32 o endereço i32 ocupa os bytes [p, p+4) e o word alto
 * [p+4, p+8) permanece zero (um endereço linear nunca excede 2^32). Toda entrada
 * rodata que o compilador produz HOJE tem `relocs` VAZIO (o produtor `serialize_const`
 * honest-stopa agregados pointer-bearing até T-B6), então isto devolve o layout
 * byte-idêntico e todo golden wasm fica intacto. O arm wasm64 (i64) NÃO é implementado
 * aqui: um programa wasm64 com rodata é honest-stopado a montante por
 * `wasm_scope_stop_wasm64`, então o único arm alcançável é o write i32 do wasm32.
 *
 * @param WasmRodataLayout layout  o rodata laid-out (`wasm_layout_rodata`)
 * @param []lir::LRodata rodata  as entradas na MESMA ordem (as suas relocs)
 * @return WasmRodataLayout | error  o layout com os slots de ponteiro escritos, ou o
 *                                   erro nomeado de alvo desconhecido propagado
 */
pub fn wasm_relocate_rodata(layout: WasmRodataLayout, rodata: []lir::LRodata) -> WasmRodataLayout | error {
    let base = layout.segment.offset
    mut buf = layout.segment.bytes
    mut i: u64 = 0
    loop {
        if i >= rodata.len { break }
        let entry_start = layout.offsets[i] - base
        mut j: u64 = 0
        loop {
            if j >= rodata[i].relocs.len { break }
            let rel = rodata[i].relocs[j]
            let addr = match wasm_data_addr_of(layout.symbols, layout.offsets, rel.target) { u32 as a => a; error as e => return e }
            buf = write_u32_le_at(buf, entry_start + rel.offset, addr)
            j++
        }
        i++
    }
    WasmRodataLayout { segment = WasmDataSegment { offset = base; bytes = buf }; symbols = layout.symbols; offsets = layout.offsets; end = layout.end }
}

/**
 * wasm_symtab_add_rodata — register every `WasmRodataLayout` entry's own
 * symbol/offset into `t` in one pass (`wasm_symtab_add_data`), so a caller
 * assembling a module registers a whole rodata table's worth of
 * `LGlobalAddr` targets in one call.
 *
 * @param WasmSymbolTable t  the table to extend
 * @param WasmRodataLayout layout  the laid-out rodata (`wasm_layout_rodata`)
 * @return WasmSymbolTable  the extended table
 */
pub fn wasm_symtab_add_rodata(t: WasmSymbolTable, layout: WasmRodataLayout) -> WasmSymbolTable {
    mut out = t
    mut i: u64 = 0
    loop {
        if i >= layout.symbols.len { break }
        out = wasm_symtab_add_data(out, layout.symbols[i], layout.offsets[i])
        i++
    }
    out
}

/**
 * wasm_honest_globals — the module-level `C1-globals` honest-stop (mirrors
 * `encode_arm64.tks`'s `honest_globals`, PARALLELED not reused): top-level
 * `LGlobal` data has no wasm lowering in the MVP (the N2 subset lowers
 * none). A future module assembler (C1-5's `emit_native_wasm`) calls this
 * when `LModule.globals` is non-empty, mirroring A4-4's own `if m.globals.
 * len > 0 { return honest_globals() }` guard.
 *
 * @return error  the named `C1-globals` honest-stop
 */
pub fn wasm_honest_globals() -> error {
    error { message = "stackify: C1-globals — top-level LGlobal data has no wasm lowering yet (the N2 subset lowers none), mirrors A4-globals" }
}

/**
 * wasm_io_iov_base_addr — the fixed linear-memory offset of the synthesized
 * io/panic trampolines' own scratch `__wasi_ciovec_t.buf` field (4 bytes,
 * §6.2/C1-6): every `tk_print`/`tk_println`/`tk_eprint`/`tk_eprintln`/
 * `tk_write`/`tk_ewrite`/`tk_panic_str` call reuses this SAME 16-byte
 * scratch region (never reentrant/nested — one host `fd_write` call always
 * runs to completion before the next begins), so no per-call allocation is
 * needed.
 *
 * @return u32  the scratch iovec `buf` field's own offset
 */
fn wasm_io_iov_base_addr() -> u32 {
    0 to u32
}

/**
 * wasm_io_iov_len_addr — the scratch region's `__wasi_ciovec_t.buf_len`
 * field (4 bytes, right after `wasm_io_iov_base_addr`).
 *
 * @return u32  the scratch iovec `buf_len` field's own offset
 */
fn wasm_io_iov_len_addr() -> u32 {
    4 to u32
}

/**
 * wasm_io_nwritten_addr — the scratch region's `fd_write` OUT parameter
 * (the bytes-written count WASI writes back; the MVP trampolines never
 * read it — `fd_write`'s own `errno` RESULT is dropped too, M.4 — a fully
 * honest MVP write path, not a hidden partial-write retry loop).
 *
 * @return u32  the scratch `nwritten` out-param's own offset
 */
fn wasm_io_nwritten_addr() -> u32 {
    8 to u32
}

/**
 * wasm_io_nl_byte_addr — the scratch region's single-byte trailing-newline
 * buffer (`tk_println`/`tk_eprintln` write `0x0A` here, then point a
 * SECOND one-byte iovec at it — the same scratch iovec fields get reused
 * for this second `fd_write`, §6.2).
 *
 * @return u32  the scratch newline byte's own offset
 */
fn wasm_io_nl_byte_addr() -> u32 {
    12 to u32
}

/**
 * wasm_io_scratch_bytes — the whole io/panic scratch region's own byte
 * size (the iovec's two `u32` fields + the `nwritten` out-param + the
 * one-byte newline buffer, rounded up so the program's rodata — which
 * starts right after it, `wasm_rodata_base` — keeps its own natural
 * 8-byte alignment).
 *
 * @return u32  the scratch region's own byte size
 */
fn wasm_io_scratch_bytes() -> u32 {
    16 to u32
}

/**
 * wasm_narrow_msg_bytes — the fixed, compiler-owned ASCII message
 * `stackify_narrow_ptr_load`'s panic call reports to the host (§6/§8, #389
 * C1-7): the message string's raw UTF-8 bytes (never a `LModule.rodata`
 * entry — the message exists regardless of what the PROGRAM interns, so it
 * is reserved memory exactly like the io scratch region, not user rodata).
 *
 * @return []byte  the overflow message's raw ASCII bytes
 */
fn wasm_narrow_msg_bytes() -> []byte {
    let s = "wasm32: pointer address overflow (>= 2^32)"
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= s.len { break }
        out = teko::list::push(out, s[i])
        i++
    }
    out
}

/**
 * wasm_narrow_msg_addr — the fixed linear-memory offset
 * `wasm_narrow_msg_bytes` is placed at: right after the io/panic
 * trampolines' own scratch region (`wasm_io_scratch_bytes`), mirroring
 * `wasm_rodata_base`'s own "reserved infrastructure region, then the
 * program's own data" placement rule.
 *
 * @return u32  the overflow message's own linear-memory offset
 */
fn wasm_narrow_msg_addr() -> u32 {
    wasm_io_scratch_bytes()
}

/**
 * wasm_narrow_msg_len — `wasm_narrow_msg_bytes`'s own byte length, as the
 * `len` argument `stackify_narrow_ptr_load`'s `tk_panic_str` call pushes.
 *
 * @return u32  the overflow message's own byte length
 */
fn wasm_narrow_msg_len() -> u32 {
    wasm_narrow_msg_bytes().len to u32
}

/**
 * wasm_narrow_msg_segment — the checked-narrow panic message's own active
 * data segment (#389 C1-7 review finding #1, `backend-wasm.md` §6/§8's
 * "observe, then trap" contract): `wasm_narrow_msg_bytes` placed at `wasm_
 * narrow_msg_addr` — the SAME address `stackify_narrow_ptr_load`'s
 * `tk_panic_str` call already hands the host. Without this segment linear
 * memory stays zero-initialized at that address, so the trap's own
 * `fd_write` would report 42 NUL bytes instead of the structured message.
 *
 * @return WasmDataSegment  the reserved overflow-message segment
 */
fn wasm_narrow_msg_segment() -> WasmDataSegment {
    WasmDataSegment { offset = wasm_narrow_msg_addr(); bytes = wasm_narrow_msg_bytes() }
}

/**
 * wasm_rodata_base — the fixed linear-memory offset the program's rodata
 * starts at (§6.1's "rodata at a fixed low base"): right after the
 * io/panic trampolines' own scratch region (`wasm_io_scratch_bytes`) AND
 * the reserved checked-narrow overflow message (`wasm_narrow_msg_bytes`,
 * #389 C1-7), 8-byte aligned so no real datum ever lands at the null
 * address and no rodata byte ever aliases either reserved region.
 *
 * @return u32  the rodata region's own base offset
 */
fn wasm_rodata_base() -> u32 {
    wasm_align_up(wasm_narrow_msg_addr() + wasm_narrow_msg_len(), 8 to u32)
}

/**
 * wasm_stack_region_bytes — the shadow-stack region's own fixed byte size
 * (§6.1): reserved directly above rodata, the `SP` global's initial value
 * is this many bytes above the rodata region's own end, and `LAlloca`
 * bumps `SP` DOWN into it. A flat, generous default (`64` KiB) — right-
 * sizing it is `#453`'s `#arena_size` territory, not this slice's.
 *
 * @return u32  the shadow-stack region's own byte size
 */
fn wasm_stack_region_bytes() -> u32 {
    65536 to u32
}

/**
 * wasm_mem_page_bytes — one wasm linear-memory page's own byte size
 * (`65536`, the wasm core spec's fixed page granularity).
 *
 * @return u32  one page's own byte size
 */
fn wasm_mem_page_bytes() -> u32 {
    65536 to u32
}

/**
 * wasm_mem_pages_for — the minimum page count covering `top` bytes,
 * rounded UP to the next whole page and floored at `1` (a module always
 * declares at least one page, §5.2 — even a program with neither rodata
 * nor a shadow-stack frame still gets a usable linear memory).
 *
 * @param u32 top  the highest byte offset the module's own layout reaches
 * @return u32  the page count `emit_wasm`'s memory section requests
 */
fn wasm_mem_pages_for(top: u32) -> u32 {
    let page = wasm_mem_page_bytes()
    let pages = (top + page - (1 to u32)) / page
    if pages < (1 to u32) {
        return 1 to u32
    }
    pages
}

/**
 * wasm_program_func_index — the absolute wasm function index a DEFINED
 * function at position `pos` (0-based, in `LModule.funcs` order) resolves
 * to: the module's own index space places every import first, then every
 * defined function (§5.2), so `pos` simply shifts by `import_count`.
 *
 * @param u64 import_count  how many host imports the module declares
 * @param u64 pos  the function's own 0-based position in `LModule.funcs`
 * @return u32  the function's absolute wasm function index
 */
fn wasm_program_func_index(import_count: u64, pos: u64) -> u32 {
    (import_count + pos) to u32
}

/**
 * wasm_register_program_symbols — the whole program's `WasmSymbolTable`
 * (C1-5, the "link/dispatch" job C1-2's `wasm_resolve_call` doc deferred
 * here): `"tk_exit"` resolves DIRECTLY to the WASI `proc_exit` import
 * (§6.2 — their signatures match exactly, `(i32) -> ()`, so no separate
 * runtime-provided `tk_exit` symbol is needed for the MVP corpus), and
 * every `LModule.funcs` entry resolves to its own assigned absolute index
 * (`wasm_program_func_index`) — so a future cross-function call (none in
 * the MVP corpus, `backend-c1-wasm.md` §12.2) already resolves correctly.
 *
 * @param WasmWasiImportSet wasi  the WASI import set (`proc_exit`'s index)
 * @param []LFunc funcs  the module's defined functions, in `LModule.funcs`
 *                       order
 * @return WasmSymbolTable  the whole-program call-target resolver
 */
fn wasm_register_program_symbols(wasi: WasmWasiImportSet, funcs: []lir::LFunc) -> WasmSymbolTable {
    mut t = wasm_symtab_empty()
    t = wasm_symtab_add(t, "tk_exit", WasmCallTarget { func_index = wasi.proc_exit_index; ret_type = lir::LType::Void })
    let import_count = wasi.imports.len
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        let idx = wasm_program_func_index(import_count, i)
        t = wasm_symtab_add(t, funcs[i].symbol, WasmCallTarget { func_index = idx; ret_type = funcs[i].ret_type })
        i++
    }
    t
}

/**
 * wasm_func_type_of — the `(params) -> (results)` `WasmFuncType` an
 * `LFunc`'s own signature maps to: every `param_types` entry through
 * `wasm_valtype` (in order), and a single result whenever `ret_type` is not
 * `Void` (the MVP's no-multi-value shape, §4.3). Propagates `wasm_valtype`'s
 * own honest-stops (`C1-i128`/`C1-f16`) on either side.
 *
 * @param LFunc f  the function whose signature to translate
 * @return WasmFuncType | error  the translated signature, or a propagated
 *                               honest-stop
 */
fn wasm_func_type_of(f: lir::LFunc, ptr64: bool) -> WasmFuncType | error {
    mut params: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= f.param_types.len { break }
        let vt = match wasm_valtype(f.param_types[i], ptr64) { u8 as v => v; error as e => return e }
        params = teko::list::push(params, vt to byte)
        i++
    }
    if f.ret_type == lir::LType::Void {
        return WasmFuncType { params = params; results = teko::list::empty() }
    }
    let rvt = match wasm_valtype(f.ret_type, ptr64) { u8 as v => v; error as e => return e }
    WasmFuncType { params = params; results = [rvt to byte] }
}

/**
 * wasm_build_program_types — the module's whole type table, BEFORE the
 * synthesized `_start`'s own trailing entry (`wasm_assemble_program` appends
 * that one itself): the WASI import set's own two types (indices `0`/`1`,
 * §6.2), then one entry per `LModule.funcs` function, in order (so a
 * function at position `i` owns type index `wasi.types.len + i`, matching
 * `wasm_program_func_index`'s own index-space convention).
 *
 * @param WasmWasiImportSet wasi  the WASI import set (its own two types)
 * @param []LFunc funcs  the module's defined functions
 * @param bool ptr64  the target pointer width (#389 C1-7)
 * @return []WasmFuncType | error  the type table, or a propagated
 *                                 `wasm_func_type_of` honest-stop
 */
fn wasm_build_program_types(wasi: WasmWasiImportSet, funcs: []lir::LFunc, ptr64: bool) -> []WasmFuncType | error {
    mut types = wasi.types
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        let t = match wasm_func_type_of(funcs[i], ptr64) { WasmFuncType as x => x; error as e => return e }
        types = teko::list::push(types, t)
        i++
    }
    types
}

/**
 * wasm_build_program_funcs — every `LModule.funcs` entry stackified
 * (`stackify_func`) into its own `WasmFunc`: `type_index` matches `wasm_
 * build_program_types`'s own per-function assignment, and `local_groups`/
 * `body` carry through unchanged from the stackifier's own `WasmFuncBody`.
 * The module is self-contained (`backend-wasm.md` §1.2), so each call-site
 * funcidx operand is already the callee's final absolute index (minimal-
 * width ULEB128) — no relocation table, no operand widening, and no linker
 * pass exists to consume one.
 *
 * @param WasmWasiImportSet wasi  the WASI import set (its own import count)
 * @param []LFunc funcs  the module's defined functions
 * @param WasmSymbolTable symtab  the whole-program call-target resolver
 * @param bool ptr64  the target pointer width (#389 C1-7)
 * @return []WasmFunc | error  the defined-function code entries, or a
 *                             propagated `stackify_func` honest-stop
 */
fn wasm_build_program_funcs(wasi: WasmWasiImportSet, funcs: []lir::LFunc, symtab: WasmSymbolTable, ptr64: bool) -> []WasmFunc | error {
    mut out: []WasmFunc = teko::list::empty()
    let import_count = wasi.imports.len
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        let body = match stackify_func(funcs[i], symtab, ptr64) { WasmFuncBody as x => x; error as e => return e }
        let type_index = (import_count + i) to u32
        out = teko::list::push(out, WasmFunc { type_index = type_index; local_groups = body.local_groups; body = body.body })
        i++
    }
    out
}

/**
 * wasm_find_main_index — the program's own `"main"` `LFunc`'s absolute wasm
 * function index (`wasm_program_func_index`), the callee `_start` invokes
 * (§9's `emit_native_wasm` doc — "the LIR's own `main` LFunc"). A NAMED
 * internal error when no function is named `"main"`: `emit_native_wasm`
 * only ever reaches this for a BINARY artifact, whose front-end always
 * synthesizes one (`lir::lower_virtual_main`), so this is a genuine
 * internal-misuse guard, not a reachable user-facing case.
 *
 * @param WasmWasiImportSet wasi  the WASI import set (its own import count)
 * @param []LFunc funcs  the module's defined functions
 * @return u32 | error  `"main"`'s absolute function index, or a NAMED
 *                       internal error
 */
fn wasm_find_main_index(wasi: WasmWasiImportSet, funcs: []lir::LFunc) -> u32 | error {
    let import_count = wasi.imports.len
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        if funcs[i].symbol == "main" {
            return wasm_program_func_index(import_count, i)
        }
        i++
    }
    error { message = "stackify: wasm_assemble_program — no `main` entry function found in the lowered module (internal)" }
}

/**
 * wasm_find_main_ret — the program's own `"main"` `LFunc`'s return type,
 * the `_start` synthesizer (`wasm_synth_start`) needs to decide whether to
 * push a default `i32.const 0` exit code (a `Void` `main`) or forward
 * `main`'s own `i32` result to `proc_exit`. Shares `wasm_find_main_index`'s
 * NAMED internal-misuse guard: an artifact reaching here always has a `main`
 * (`lir::lower_virtual_main`).
 *
 * @param []LFunc funcs  the module's defined functions
 * @return LType | error  `"main"`'s own return type, or a NAMED internal
 *                        error
 */
fn wasm_find_main_ret(funcs: []lir::LFunc) -> lir::LType | error {
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        if funcs[i].symbol == "main" {
            return funcs[i].ret_type
        }
        i++
    }
    error { message = "stackify: wasm_assemble_program — no `main` entry function found in the lowered module (internal)" }
}

/**
 * wasm_synth_start — the WASI command entry point, `_start` (the owner's
 * own C1-5 invariant: a wasm COMMAND module — the `exit(n)` case this slice
 * targets — MUST export `_start`, the symbol `wasmtime`/every WASI host
 * looks up; the Teko front-end's own "virtual main" tail-exit convention
 * BECOMES this `_start`, §9): `call $main; call $proc_exit; end`. When
 * `main` returns `i32` (LIR's C-style "`main` returns the exit code" ABI,
 * `lir::lower_virtual_main`), its own result lands on the operand stack
 * right where `proc_exit`'s single `i32` parameter needs it, so NO local
 * staging is needed. When `main` returns `Void`, it leaves NOTHING on the
 * stack, so a literal `i32.const 0` is pushed first — the standard WASI
 * `_start` "exit 0 on a clean fall-through" shape — keeping `proc_exit`'s
 * `i32` argument balanced instead of underflowing the operand stack
 * (`backend-wasm.md` finding 4). Both `call` funcidx operands are the final
 * absolute index encoded minimal-width (`emit_uleb128`): the module is
 * self-contained (§1.2), so no relocation is recorded and no linker
 * rewrites them.
 *
 * @param u32 type_index  the module's own `() -> ()` type-table index for
 *                        `_start`'s signature (`wasm_assemble_program`
 *                        appends one past `wasm_build_program_types`'s own
 *                        table)
 * @param u32 main_index  `"main"`'s own absolute function index
 * @param u32 proc_exit_index  the WASI `proc_exit` import's own index
 * @param LType main_ret  `main`'s own return type — `Void` triggers the
 *                        default `i32.const 0` exit-code push
 * @return WasmFunc | error  the `_start` code entry, or the NAMED
 *                           `C1-main-ret` honest-stop when `main_ret` is
 *                           neither `I32` nor `Void`
 */
fn wasm_synth_start(type_index: u32, main_index: u32, proc_exit_index: u32, main_ret: lir::LType) -> WasmFunc | error {
    if main_ret != lir::LType::I32 && main_ret != lir::LType::Void {
        return error { message = "stackify: C1-main-ret — wasm_synth_start only knows the virtual-main ABI's own I32/Void return shapes; a differently-typed `main` would feed proc_exit a type-mismatched operand (internal, unreachable under lir::lower_virtual_main)" }
    }
    mut body: []byte = teko::list::empty()
    body = teko::list::push(body, WASM_OP_CALL)
    body = emit_uleb128(body, main_index to u64)
    if main_ret == lir::LType::Void {
        body = teko::list::push(body, WASM_OP_I32_CONST)
        body = emit_sleb128(body, 0 to i64)
    }
    body = teko::list::push(body, WASM_OP_CALL)
    body = emit_uleb128(body, proc_exit_index to u64)
    body = teko::list::push(body, WASM_OP_END)
    WasmFunc { type_index = type_index; local_groups = teko::list::empty(); body = body }
}

/**
 * wasm_op_i32_const — append `i32.const v` (`0x41` then `v` SLEB128) — the
 * shared opcode-emission primitive every C1-6 io/panic trampoline builds
 * its scratch-address/immediate pushes from.
 *
 * @param []byte buf  the buffer to extend
 * @param i64 v  the constant value
 * @return []byte  `buf` followed by the encoded instruction
 */
fn wasm_op_i32_const(buf: []byte, v: i64) -> []byte {
    emit_sleb128(teko::list::push(buf, WASM_OP_I32_CONST), v)
}

/**
 * wasm_op_local_get — append `local.get idx` (`0x20` then the ULEB128
 * local index).
 *
 * @param []byte buf  the buffer to extend
 * @param u32 idx  the local index
 * @return []byte  `buf` followed by the encoded instruction
 */
fn wasm_op_local_get(buf: []byte, idx: u32) -> []byte {
    emit_uleb128(teko::list::push(buf, WASM_OP_LOCAL_GET), idx to u64)
}

/**
 * wasm_op_store32 — append `i32.store` at natural (4-byte) alignment,
 * offset `0` (`0x36 0x02 0x00`) — every C1-6 trampoline store's memarg (the
 * address is always already computed via a preceding `i32.const`, so the
 * memarg's own offset immediate stays `0`).
 *
 * @param []byte buf  the buffer to extend
 * @return []byte  `buf` followed by the encoded instruction
 */
fn wasm_op_store32(buf: []byte) -> []byte {
    let b = teko::list::push(buf, WASM_OP_I32_STORE)
    let b2 = teko::list::push(b, 0x02 to byte)
    teko::list::push(b2, 0x00 to byte)
}

/**
 * wasm_op_store8 — append `i32.store8` at 1-byte alignment, offset `0`
 * (`0x3A 0x00 0x00`) — the trailing-newline byte store.
 *
 * @param []byte buf  the buffer to extend
 * @return []byte  `buf` followed by the encoded instruction
 */
fn wasm_op_store8(buf: []byte) -> []byte {
    let b = teko::list::push(buf, WASM_OP_I32_STORE8)
    let b2 = teko::list::push(b, 0x00 to byte)
    teko::list::push(b2, 0x00 to byte)
}

/**
 * wasm_op_call — append `call funcidx` (`0x10` then the ULEB128 function
 * index).
 *
 * @param []byte buf  the buffer to extend
 * @param u32 funcidx  the callee's absolute function index
 * @return []byte  `buf` followed by the encoded instruction
 */
fn wasm_op_call(buf: []byte, funcidx: u32) -> []byte {
    emit_uleb128(teko::list::push(buf, WASM_OP_CALL), funcidx to u64)
}

/**
 * wasm_op_drop — append `drop` (`0x1A`).
 *
 * @param []byte buf  the buffer to extend
 * @return []byte  `buf` followed by the encoded instruction
 */
fn wasm_op_drop(buf: []byte) -> []byte {
    teko::list::push(buf, WASM_OP_DROP)
}

/**
 * wasm_emit_fd_write_call — append one `fd_write(fd, iov_base_addr, 1,
 * nwritten_addr)` call + a `drop` of its `errno` result (§6.2/§7, C1-6):
 * the scratch iovec/nwritten fields (`wasm_io_iov_base_addr`/…) are
 * assumed ALREADY populated by the caller.
 *
 * @param []byte buf  the buffer to extend
 * @param u32 fd  the target WASI file descriptor (1 = stdout, 2 = stderr)
 * @param u32 fd_write_index  the WASI `fd_write` import's own function
 *                            index
 * @return []byte  `buf` followed by the call + drop
 */
fn wasm_emit_fd_write_call(buf: []byte, fd: u32, fd_write_index: u32) -> []byte {
    let b0 = wasm_op_i32_const(buf, fd to i64)
    let b1 = wasm_op_i32_const(b0, wasm_io_iov_base_addr() to i64)
    let b2 = wasm_op_i32_const(b1, 1 to i64)
    let b3 = wasm_op_i32_const(b2, wasm_io_nwritten_addr() to i64)
    let b4 = wasm_op_call(b3, fd_write_index)
    wasm_op_drop(b4)
}

/**
 * wasm_io_write_newline — the trailing-newline tail `wasm_synth_io_write`
 * appends for `tk_println`/`tk_eprintln`: stage a single `0x0A` byte at
 * `wasm_io_nl_byte_addr`, point the scratch iovec at it (length `1`), then
 * a second `fd_write` call (§6.2, C1-6).
 *
 * @param []byte buf  the buffer to extend (after the first `fd_write`)
 * @param u32 fd  the target WASI file descriptor
 * @param u32 fd_write_index  the WASI `fd_write` import's own function
 *                            index
 * @return []byte  `buf` followed by the newline write
 */
fn wasm_io_write_newline(buf: []byte, fd: u32, fd_write_index: u32) -> []byte {
    let b0 = wasm_op_i32_const(buf, wasm_io_nl_byte_addr() to i64)
    let b1 = wasm_op_i32_const(b0, 10 to i64)
    let b2 = wasm_op_store8(b1)
    let b3 = wasm_op_i32_const(b2, wasm_io_iov_base_addr() to i64)
    let b4 = wasm_op_i32_const(b3, wasm_io_nl_byte_addr() to i64)
    let b5 = wasm_op_store32(b4)
    let b6 = wasm_op_i32_const(b5, wasm_io_iov_len_addr() to i64)
    let b7 = wasm_op_i32_const(b6, 1 to i64)
    let b8 = wasm_op_store32(b7)
    wasm_emit_fd_write_call(b8, fd, fd_write_index)
}

/**
 * wasm_synth_io_write — the `fd_write`-backed trampoline for one io
 * builtin (`tk_print`/`tk_println`/`tk_eprint`/`tk_eprintln`/`tk_write`/
 * `tk_ewrite`, §7 WASI interop + C1-6 — this is the "runtime rides the
 * WASI `fd_write` import" wiring `backend-wasm.md:775` names, killing the
 * `own_print_exit` println gap): a `(ptr: i32, len: i32) -> ()` function
 * that stores `(ptr, len)` into the scratch iovec, calls `fd_write(fd,
 * …)` once, and — when `newline` — a SECOND `fd_write` of one `0x0A` byte
 * staged at `wasm_io_nl_byte_addr`. `tk_write`/`tk_ewrite` are
 * byte-identical to `tk_print`/`tk_eprint` (`teko_rt.c:1300-1303` — no
 * newline, same fd), so the symbol table points BOTH names at the SAME
 * funcidx rather than duplicating the body (`wasm_register_io_symbols`).
 *
 * @param u32 fd  the target WASI file descriptor (1 = stdout, 2 = stderr)
 * @param bool newline  whether to append a trailing `'\n'` (`println`/
 *                      `eprintln`)
 * @param u32 type_index  the module's own `(i32, i32) -> ()` type-table
 *                        index every io/panic trampoline shares
 * @param u32 fd_write_index  the WASI `fd_write` import's own function
 *                            index
 * @return WasmFunc  the trampoline's code-section entry
 */
fn wasm_synth_io_write(fd: u32, newline: bool, type_index: u32, fd_write_index: u32) -> WasmFunc {
    let b0 = wasm_op_i32_const(teko::list::empty(), wasm_io_iov_base_addr() to i64)
    let b1 = wasm_op_local_get(b0, 0 to u32)
    let b2 = wasm_op_store32(b1)
    let b3 = wasm_op_i32_const(b2, wasm_io_iov_len_addr() to i64)
    let b4 = wasm_op_local_get(b3, 1 to u32)
    let b5 = wasm_op_store32(b4)
    let b6 = wasm_emit_fd_write_call(b5, fd, fd_write_index)
    let body = if newline { wasm_io_write_newline(b6, fd, fd_write_index) } else { b6 }
    WasmFunc { type_index = type_index; local_groups = teko::list::empty(); body = teko::list::push(body, WASM_OP_END) }
}

/**
 * wasm_synth_panic_str — the `tk_panic_str` trampoline (§8, C1-6's panic
 * host-import + trap): a `(ptr: i32, len: i32) -> ()` function that stores
 * `(ptr, len)` into the scratch iovec, `fd_write`s the structured panic
 * message to STDERR (fd `2` — the host OBSERVES it, §8 step 1 realized
 * through the already-imported WASI `fd_write`, `backend-wasm.md:595`'s
 * "the panic import can map to a fd_write of the message"), then
 * `unreachable` (`0x00`) TRAPS the instance (§8 step 2, M.1 — observe +
 * report, never recover). No return is ever reached — code after
 * `unreachable` is unreachable-typed, so sharing the io writers' own
 * `(i32,i32)->()` type never mismatches the operand stack.
 *
 * @param u32 type_index  the shared io/panic `(i32, i32) -> ()` type index
 * @param u32 fd_write_index  the WASI `fd_write` import's own function
 *                            index
 * @return WasmFunc  the trampoline's code-section entry
 */
fn wasm_synth_panic_str(type_index: u32, fd_write_index: u32) -> WasmFunc {
    let b0 = wasm_op_i32_const(teko::list::empty(), wasm_io_iov_base_addr() to i64)
    let b1 = wasm_op_local_get(b0, 0 to u32)
    let b2 = wasm_op_store32(b1)
    let b3 = wasm_op_i32_const(b2, wasm_io_iov_len_addr() to i64)
    let b4 = wasm_op_local_get(b3, 1 to u32)
    let b5 = wasm_op_store32(b4)
    let b6 = wasm_emit_fd_write_call(b5, 2 to u32, fd_write_index)
    let b7 = teko::list::push(b6, WASM_OP_UNREACHABLE)
    WasmFunc { type_index = type_index; local_groups = teko::list::empty(); body = teko::list::push(b7, WASM_OP_END) }
}

/**
 * WasmIoPanicFuncs — the five synthesized io/panic trampolines (C1-6):
 * `tk_print`/`tk_println`/`tk_eprint`/`tk_eprintln`/`tk_panic_str`, in this
 * FIXED order — `wasm_assemble_program` appends them right after the
 * program's own `LModule.funcs`, so each one's funcidx is `import_count +
 * lmod.funcs.len + position` (`wasm_register_io_symbols`).
 *
 * @since #389 C1-6
 */
pub type WasmIoPanicFuncs = struct {
    /**
     * funcs — the five trampoline bodies, in the fixed `print, println,
     * eprint, eprintln, panic_str` order.
     */
    funcs: []WasmFunc
}

/**
 * wasm_synth_io_panic_funcs — build the five io/panic trampolines sharing
 * ONE `(i32, i32) -> ()` type-table entry.
 *
 * @param u32 type_index  the shared io/panic type-table index
 * @param u32 fd_write_index  the WASI `fd_write` import's own function
 *                            index
 * @return WasmIoPanicFuncs  the five trampoline bodies, fixed order
 */
fn wasm_synth_io_panic_funcs(type_index: u32, fd_write_index: u32) -> WasmIoPanicFuncs {
    let stdout_fd = 1 to u32
    let stderr_fd = 2 to u32
    let p = wasm_synth_io_write(stdout_fd, false, type_index, fd_write_index)
    let pln = wasm_synth_io_write(stdout_fd, true, type_index, fd_write_index)
    let ep = wasm_synth_io_write(stderr_fd, false, type_index, fd_write_index)
    let epln = wasm_synth_io_write(stderr_fd, true, type_index, fd_write_index)
    let pan = wasm_synth_panic_str(type_index, fd_write_index)
    WasmIoPanicFuncs { funcs = [p, pln, ep, epln, pan] }
}

/**
 * wasm_register_io_symbols — register the five synthesized trampolines'
 * runtime symbols into `t`: `tk_print`/`tk_write` and `tk_eprint`/
 * `tk_ewrite` share a funcidx pair (`teko_rt.c:1300-1303`'s own identical
 * bodies), `tk_println`/`tk_eprintln` get their own, and `tk_panic_str`
 * closes the set (§8).
 *
 * @param WasmSymbolTable t  the table to extend
 * @param u32 base_index  the first trampoline's own funcidx (`print`'s) —
 *                        the remaining four follow at `base_index+1..+4`,
 *                        matching `wasm_synth_io_panic_funcs`'s fixed order
 * @return WasmSymbolTable  the extended table
 */
fn wasm_register_io_symbols(t: WasmSymbolTable, base_index: u32) -> WasmSymbolTable {
    let print_ix = base_index
    let println_ix = base_index + (1 to u32)
    let eprint_ix = base_index + (2 to u32)
    let eprintln_ix = base_index + (3 to u32)
    let panic_ix = base_index + (4 to u32)
    let vt = lir::LType::Void
    mut out = wasm_symtab_add(t, "tk_print", WasmCallTarget { func_index = print_ix; ret_type = vt })
    out = wasm_symtab_add(out, "tk_write", WasmCallTarget { func_index = print_ix; ret_type = vt })
    out = wasm_symtab_add(out, "tk_println", WasmCallTarget { func_index = println_ix; ret_type = vt })
    out = wasm_symtab_add(out, "tk_eprint", WasmCallTarget { func_index = eprint_ix; ret_type = vt })
    out = wasm_symtab_add(out, "tk_ewrite", WasmCallTarget { func_index = eprint_ix; ret_type = vt })
    out = wasm_symtab_add(out, "tk_eprintln", WasmCallTarget { func_index = eprintln_ix; ret_type = vt })
    wasm_symtab_add(out, "tk_panic_str", WasmCallTarget { func_index = panic_ix; ret_type = vt })
}

/**
 * append_wasm_funcs — append every entry of `src` to `funcs`, in order
 * (`[]WasmFunc` has no built-in concat; mirrors `encode_arm64.tks`'s
 * `append_bytes` shape over a different element type).
 *
 * @param []WasmFunc funcs  the list to extend
 * @param []WasmFunc src  the entries to append
 * @return []WasmFunc  `funcs` followed by `src`
 */
fn append_wasm_funcs(funcs: []WasmFunc, src: []WasmFunc) -> []WasmFunc {
    mut out = funcs
    mut i: u64 = 0
    loop {
        if i >= src.len { break }
        out = teko::list::push(out, src[i])
        i++
    }
    out
}

/**
 * wasm_program_has_any_frame — does ANY function in `funcs` need the
 * shared shadow-stack `SP` global (at least one `LAlloca` site, §6.1)? A
 * module declares the `SP` global (index `0`, `wasm_sp_global_index`) iff
 * this is `true` — a program with no `LAlloca` anywhere needs no shadow
 * stack at all.
 *
 * @param []LFunc funcs  the module's defined functions
 * @return bool  `true` iff some function has at least one `LAlloca`
 */
fn wasm_program_has_any_frame(funcs: []lir::LFunc) -> bool {
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        if collect_alloca_insts(funcs[i]).len > (0 to u64) {
            return true
        }
        i++
    }
    false
}

/**
 * inst_is_ptr_load — whether `inst` is an `LLoad` whose own machine class is
 * `Ptr` (`stackify_load`'s own wasm32 checked-narrow trigger, #389 C1-7
 * review finding #1) — `wasm_program_has_ptr_load`'s own per-instruction
 * predicate, mirroring `inst_is_alloca`'s shape over a different op.
 *
 * @param LInst inst  the instruction to test
 * @return bool  true iff `inst.op` is an `LLoad` of `Ptr`
 */
fn inst_is_ptr_load(inst: lir::LInst) -> bool {
    match inst.op {
        lir::LLoad as l => l.ty == lir::LType::Ptr
        _ => false
    }
}

/**
 * func_has_ptr_load — whether `f` contains at least one `Ptr`-typed `LLoad`
 * anywhere in its own blocks (`inst_is_ptr_load`'s own per-function scan,
 * mirroring `collect_alloca_insts`' block/instruction walk shape).
 *
 * @param LFunc f  the function to scan
 * @return bool  true iff some instruction in `f` is a `Ptr`-typed `LLoad`
 */
fn func_has_ptr_load(f: lir::LFunc) -> bool {
    mut bi: u64 = 0
    loop {
        if bi >= f.blocks.len { break }
        let insts = f.blocks[bi].insts
        mut ii: u64 = 0
        loop {
            if ii >= insts.len { break }
            if inst_is_ptr_load(insts[ii]) { return true }
            ii++
        }
        bi++
    }
    false
}

/**
 * wasm_program_has_ptr_load — does ANY function in `funcs` contain at least
 * one `Ptr`-typed `LLoad` (the wasm32 checked-narrow's own reachability
 * test, #389 C1-7 review finding #1): the checked-narrow panic message's
 * own data segment (`wasm_narrow_msg_segment`) is only ever emitted when
 * this is `true` — a program that never loads a `Ptr` value never
 * stackifies `stackify_narrow_ptr_load` (`stackify_load`'s own guard), so
 * the message would otherwise be a dead data segment.
 *
 * @param []LFunc funcs  the module's defined functions
 * @return bool  true iff some function has at least one `Ptr`-typed `LLoad`
 */
fn wasm_program_has_ptr_load(funcs: []lir::LFunc) -> bool {
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        if func_has_ptr_load(funcs[i]) { return true }
        i++
    }
    false
}

/**
 * func_signature_has_ptr — whether `f`'s own signature (any parameter, or
 * its return) names the `Ptr` machine class.
 *
 * @param LFunc f  the function to inspect
 * @return bool  `true` iff `f` has a `Ptr`-typed parameter or return
 */
fn func_signature_has_ptr(f: lir::LFunc) -> bool {
    if f.ret_type == lir::LType::Ptr {
        return true
    }
    mut i: u64 = 0
    loop {
        if i >= f.param_types.len { break }
        if f.param_types[i] == lir::LType::Ptr { return true }
        i++
    }
    false
}

/**
 * wasm_program_uses_ptr — a best-effort scan for whether ANY function in
 * `funcs` names `Ptr` in its own signature (`func_signature_has_ptr`) — one
 * of the three triggers `wasm_assemble_program`'s wasm64 scope guard tests
 * (#389 C1-7, alongside `wasm_program_has_any_frame`/non-empty rodata). NOT
 * an exhaustive instruction-level scan (it does not walk every `LFieldAddr`/
 * `LGlobalAddr`/`Ptr`-typed `LLoad`/`LStore` site) — a genuinely thorough
 * scan is a wider follow-up; this catches the common case (a `Ptr`-typed
 * parameter or return, e.g. the `sft_rodata_func`-style shape) cheaply.
 *
 * @param []LFunc funcs  the module's defined functions
 * @return bool  `true` iff some function's own signature names `Ptr`
 */
fn wasm_program_uses_ptr(funcs: []lir::LFunc) -> bool {
    mut i: u64 = 0
    loop {
        if i >= funcs.len { break }
        if func_signature_has_ptr(funcs[i]) { return true }
        i++
    }
    false
}

/**
 * WasmMemoryPlan — the module's whole linear-memory layout decision (§6.1):
 * the laid-out rodata (`wasm_layout_rodata`), the module's own globals
 * (the `SP` global, present only when `wasm_program_has_any_frame`), and
 * the initial page count covering both.
 *
 * @since #389 C1-5
 */
pub type WasmMemoryPlan = struct {
    /**
     * rodata — the program's rodata, laid out starting at `wasm_rodata_
     * base` (empty when the program interns none).
     */
    rodata: WasmRodataLayout
    /**
     * globals — the module's own globals: one mutable `i32` `SP` global
     * when any function needs a shadow-stack frame, else empty.
     */
    globals: []WasmGlobal
    /**
     * mem_min_pages — the initial linear-memory size, in 64 KiB pages,
     * covering rodata plus (when present) the whole shadow-stack region.
     */
    mem_min_pages: u32
}

/**
 * wasm_program_memory_plan — decide the whole program's linear-memory
 * globals + sizing from an ALREADY-LAID-OUT rodata (§6.1's low-to-high
 * plan: rodata, then the shadow stack): when at least one function needs a
 * shadow-stack frame (`wasm_program_has_any_frame`), the `SP` global's own
 * initial value is set to the rodata region's own end (8-byte aligned)
 * plus `wasm_stack_region_bytes`, and the memory is sized to cover it;
 * otherwise the memory covers rodata alone (still at least one page,
 * `wasm_mem_pages_for`'s own floor). Takes `rodata` PRE-COMPUTED — `wasm_
 * assemble_program` must lay it out BEFORE stackifying any function (an
 * `LGlobalAddr` site resolves through the SAME `WasmSymbolTable` a rodata
 * symbol registers into, `wasm_symtab_add_rodata`), so this function must
 * not recompute it a second time from `lmod` alone.
 *
 * @param LModule lmod  the whole lowered program (its `funcs`, for `wasm_
 *                      program_has_any_frame`)
 * @param WasmRodataLayout rodata  the already-laid-out rodata (`wasm_
 *                                 layout_rodata`)
 * @return WasmMemoryPlan  the resolved rodata layout + globals + page count
 */
fn wasm_program_memory_plan(lmod: lir::LModule, rodata: WasmRodataLayout) -> WasmMemoryPlan {
    let rodata_top = wasm_align_up(rodata.end, 8 to u32)
    if !wasm_program_has_any_frame(lmod.funcs) {
        return WasmMemoryPlan { rodata = rodata; globals = teko::list::empty(); mem_min_pages = wasm_mem_pages_for(rodata_top) }
    }
    let sp_init = rodata_top + wasm_stack_region_bytes()
    let sp_global = WasmGlobal { valtype = wasm_vtype_wire(WasmVType::I32); mutable = true; init = sp_init to i64 }
    WasmMemoryPlan { rodata = rodata; globals = [sp_global]; mem_min_pages = wasm_mem_pages_for(sp_init) }
}

/**
 * wasm_program_data_segments — the module's own data-section entries: the
 * laid-out rodata's one concatenated segment, but ONLY when it actually
 * carries bytes (a program that interns no rodata gets no data section at
 * all, rather than one framed empty segment).
 *
 * @param WasmRodataLayout rodata  the laid-out rodata (`wasm_program_
 *                                 memory_plan`)
 * @return []WasmDataSegment  zero or one data segment
 */
fn wasm_program_data_segments(rodata: WasmRodataLayout) -> []WasmDataSegment {
    if rodata.segment.bytes.len > (0 to u64) {
        return [rodata.segment]
    }
    teko::list::empty()
}

/**
 * append_wasm_data_segments — every entry of `src` appended onto `segs`, in
 * order (`[]WasmDataSegment` has no built-in concat; mirrors `append_wasm_
 * funcs`'s own shape over a different element type).
 *
 * @param []WasmDataSegment segs  the list to extend
 * @param []WasmDataSegment src  the entries to append
 * @return []WasmDataSegment  `segs` followed by `src`
 */
fn append_wasm_data_segments(segs: []WasmDataSegment, src: []WasmDataSegment) -> []WasmDataSegment {
    mut out = segs
    mut i: u64 = 0
    loop {
        if i >= src.len { break }
        out = teko::list::push(out, src[i])
        i++
    }
    out
}

/**
 * wasm_program_narrow_msg_segments — the checked-narrow panic message's own
 * data segment, gated to the program that can actually reach it (#389 C1-7
 * review finding #1): empty on wasm64 (`ptr64` — the checked narrow is
 * elided entirely, §6) or when no function loads a `Ptr` value (`wasm_
 * program_has_ptr_load`) — never a dead segment in a module whose narrow
 * path can never trap through it.
 *
 * @param []LFunc funcs  the module's defined functions
 * @param bool ptr64  the target pointer width (#389 C1-7)
 * @return []WasmDataSegment  zero or one data segment
 */
fn wasm_program_narrow_msg_segments(funcs: []lir::LFunc, ptr64: bool) -> []WasmDataSegment {
    if ptr64 || !wasm_program_has_ptr_load(funcs) {
        return teko::list::empty()
    }
    [wasm_narrow_msg_segment()]
}

/**
 * wasm_io_base_index — the first io/panic trampoline's own absolute funcidx
 * (`wasm_synth_io_panic_funcs`'s fixed `print, println, eprint, eprintln,
 * panic_str` order starts here): right after every `LModule.funcs` entry,
 * in the shared import-then-defined function index space
 * (`wasm_program_func_index`).
 *
 * @param WasmWasiImportSet wasi  the WASI import set (its own import count)
 * @param LModule lmod  the whole lowered program (its own `funcs` count)
 * @return u32  the first trampoline's own absolute funcidx
 */
fn wasm_io_base_index(wasi: WasmWasiImportSet, lmod: lir::LModule) -> u32 {
    wasm_program_func_index(wasi.imports.len, lmod.funcs.len)
}

/**
 * wasm_memory_export — the module's own `"memory"` export (kind `0x02`,
 * index `0` — the module's ONE linear memory, §5.2, always declared since
 * `mem_min_pages` floors at 1 page): every WASI host (wasmtime included)
 * requires a command module to export its memory so host-implemented WASI
 * imports (`fd_write`, …) can read/write it — omitting it fails
 * instantiation with "missing required memory export" even for a module
 * that never calls `fd_write` itself (the C1-6 wasmtime execution proof
 * surfaced this — every prior C1-1..C1-5 slice only ran `wasm-validate`,
 * a structural check the missing export does not fail).
 *
 * @return WasmExport  the `"memory"` export entry
 */
fn wasm_memory_export() -> WasmExport {
    WasmExport { name = "memory"; kind = WASM_EXPORT_KIND_MEMORY; index = 0 to u32 }
}

/**
 * wasm_scope_stop_wasm64 — the NAMED `C1-wasm64-scope` honest-stop (#389
 * C1-7): today's wasm64 arm only supports the alloca-free, rodata-free,
 * `Ptr`-signature-free program subset — `LFieldAddr`/`LAlloca`/`LGlobalAddr`
 * and the shadow-stack `$sp` global still compute in `i32` unconditionally
 * (§6.1's frame/rodata plumbing is not YET `ptr64`-threaded, a scoped
 * follow-up), which would silently mismatch an `i64`-indexed `memory64`
 * module. Fail loud (M.3) rather than emit an invalid module.
 *
 * @return error  the named `C1-wasm64-scope` honest-stop
 */
fn wasm_scope_stop_wasm64() -> error {
    error { message = "stackify: C1-wasm64-scope — wasm64 today only supports a program with no LAlloca, no rodata, and no Ptr-typed signature (LFieldAddr/LAlloca/LGlobalAddr/$sp still compute in i32; threading ptr64 through them is a scoped follow-up)" }
}

/**
 * wasm_assemble_program — the whole own-backend wasm module assembler
 * (C1-5's "link/dispatch" job every earlier slice deferred here,
 * `backend-c1-wasm.md` §5.2/§9): the program's rodata laid out FIRST and
 * registered into the symbol table (`wasm_symtab_add_rodata`) — an
 * `LGlobalAddr` site resolves through the SAME table `stackify_func`
 * reads, so this must happen BEFORE any function is stackified, not after
 * — the five C1-6 io/panic trampolines' own symbols registered ALONGSIDE
 * the program's own (`wasm_register_io_symbols`, so a Teko function
 * calling `println`/`panic` resolves them too), then every `LModule.funcs`
 * entry stackified in place (`wasm_build_program_funcs`), the WASI import
 * set wired in (`wasm_wasi_import_set`), the trampolines themselves
 * appended (`wasm_synth_io_panic_funcs`, §7/§8), the synthesized `_start`
 * command entry point appended LAST and EXPORTED alongside `"memory"` (the
 * owner's own C1-5 invariant — a wasm command module MUST export
 * `_start`, §9's doc, `wasm_synth_start` — PLUS the C1-6 "memory" export
 * every WASI host needs, `wasm_memory_export`), and the whole program's
 * linear memory sized around the ALREADY-LAID-OUT rodata
 * (`wasm_program_memory_plan`). Returns the NAMED `C1-globals` honest-stop
 * when `lmod.globals` is non-empty (mirrors A4-4's own guard,
 * `wasm_honest_globals`) before touching anything else, and propagates
 * any per-function honest-stop unchanged (`C1-i128`/`C1-f16`/
 * `C1-irreducible`/an unresolved call/data symbol).
 *
 * **The checked-narrow panic message (#389 C1-7 review finding #1,
 * `backend-wasm.md` §6/§8).** The module's own data section is the
 * checked-narrow panic message's own segment (`wasm_program_narrow_msg_
 * segments` — reserved at `wasm_narrow_msg_addr`, gated to a wasm32 program
 * that actually loads a `Ptr` value, `wasm_program_has_ptr_load`) FOLLOWED
 * by the program's own rodata (`wasm_program_data_segments`) — without it,
 * a trap through `stackify_narrow_ptr_load`'s `tk_panic_str` call would
 * report 42 NUL bytes (zero-initialized linear memory) instead of the
 * structured overflow message.
 *
 * **The wasm64 switch (#389 C1-7, §6).** When `ptr64`, the program is first
 * checked against `wasm_scope_stop_wasm64`'s own supported subset (no
 * alloca, no rodata, no `Ptr`-typed signature — `wasm_program_has_any_
 * frame`/`lmod.rodata`/`wasm_program_uses_ptr`); the io/panic trampolines
 * (`fd_write`-based — WASI preview1's own ABI is `i32`-address-only, a
 * genuine ecosystem wall against `memory64`, not a Teko gap) are OMITTED
 * entirely rather than emitted invalid — a wasm64 program calling `print`/
 * `panic` cleanly fails at `wasm_resolve_call`'s existing "unresolved call
 * symbol" error. `proc_exit` (an address-free exit CODE parameter) stays
 * imported either way. The module's own memory section flips to
 * `memory64` (`WasmModule.mem_is64`, `objfile_wasm.tks`).
 *
 * @param LModule lmod  the whole lowered program
 * @param bool ptr64  the target pointer width (`false` = wasm32, the
 *                    default; `true` = wasm64, #389 C1-7)
 * @return WasmModule | error  the assembled module, ready for `emit_wasm`,
 *                             or a propagated/named honest-stop
 */
pub fn wasm_assemble_program(lmod: lir::LModule, ptr64: bool) -> WasmModule | error {
    if lmod.globals.len > (0 to u64) {
        return wasm_honest_globals()
    }
    let has_io = !ptr64
    if ptr64 && (wasm_program_has_any_frame(lmod.funcs) || lmod.rodata.len > (0 to u64) || wasm_program_uses_ptr(lmod.funcs)) {
        return wasm_scope_stop_wasm64()
    }
    let wasi = wasm_wasi_import_set()
    let rodata0 = wasm_layout_rodata(lmod.rodata, wasm_rodata_base())
    let rodata = match wasm_relocate_rodata(rodata0, lmod.rodata) { WasmRodataLayout as x => x; error as e => return e }
    let io_base_index = wasm_io_base_index(wasi, lmod)
    let program_symtab_base = wasm_register_program_symbols(wasi, lmod.funcs)
    let program_symtab = if has_io { wasm_register_io_symbols(program_symtab_base, io_base_index) } else { program_symtab_base }
    let symtab = wasm_symtab_add_rodata(program_symtab, rodata)
    let types = match wasm_build_program_types(wasi, lmod.funcs, ptr64) { []WasmFuncType as t => t; error as e => return e }
    let funcs = match wasm_build_program_funcs(wasi, lmod.funcs, symtab, ptr64) { []WasmFunc as f => f; error as e => return e }
    let io_type_index = types.len to u32
    let i32_valtype = wasm_vtype_wire(WasmVType::I32) to byte
    let io_type = WasmFuncType { params = [i32_valtype, i32_valtype]; results = teko::list::empty() }
    let types_with_io = if has_io { teko::list::push(types, io_type) } else { types }
    let io_panic_funcs: []WasmFunc = if has_io { wasm_synth_io_panic_funcs(io_type_index, wasi.fd_write_index).funcs } else { teko::list::empty() }
    let funcs_with_io = append_wasm_funcs(funcs, io_panic_funcs)
    let main_index = match wasm_find_main_index(wasi, lmod.funcs) { u32 as x => x; error as e => return e }
    let main_ret = match wasm_find_main_ret(lmod.funcs) { lir::LType as x => x; error as e => return e }
    let start_type_index = types_with_io.len to u32
    let start = match wasm_synth_start(start_type_index, main_index, wasi.proc_exit_index, main_ret) { WasmFunc as s => s; error as e => return e }
    let start_index = io_base_index + (io_panic_funcs.len to u32)
    let plan = wasm_program_memory_plan(lmod, rodata)
    WasmModule {
        types = teko::list::push(types_with_io, WasmFuncType { params = teko::list::empty(); results = teko::list::empty() })
        imports = wasi.imports
        funcs = teko::list::push(funcs_with_io, start)
        globals = plan.globals
        data = append_wasm_data_segments(wasm_program_narrow_msg_segments(lmod.funcs, ptr64), wasm_program_data_segments(plan.rodata))
        mem_min_pages = plan.mem_min_pages
        mem_is64 = ptr64
        exports = [WasmExport { name = "_start"; kind = WASM_EXPORT_KIND_FUNC; index = start_index }, wasm_memory_export()]
    }
}
