use teko::lir

/**
 * co_u32_at — the little-endian u32 read from `bytes` at byte index `i` (the
 * golden-object field reader for the 32-bit COFF fields).
 *
 * @param []byte bytes  the object bytes
 * @param u64 i  the field's byte offset
 * @return u32  the little-endian u32 at `i`
 */
fn co_u32_at(bytes: []byte, i: u64) -> u32 {
    (bytes[i] to u32) | ((bytes[i + (1 to u64)] to u32) << (8 to u32)) | ((bytes[i + (2 to u64)] to u32) << (16 to u32)) | ((bytes[i + (3 to u64)] to u32) << (24 to u32))
}

/**
 * co_u16_at — the little-endian u16 read from `bytes` at byte index `i` (the
 * `IMAGE_FILE_HEADER`/`IMAGE_SECTION_HEADER`/`IMAGE_SYMBOL`/`IMAGE_RELOCATION`
 * 16-bit-field reader).
 *
 * @param []byte bytes  the object bytes
 * @param u64 i  the field's byte offset
 * @return u32  the little-endian u16 at `i`
 */
fn co_u16_at(bytes: []byte, i: u64) -> u32 {
    (bytes[i] to u32) | ((bytes[i + (1 to u64)] to u32) << (8 to u32))
}

/**
 * co_sym — a neutral `Symbol` fixture shorthand (the object-writer input; B3-3
 * runs post-encode, every symbol already resolved).
 *
 * @param str name  the symbol's bare name
 * @param bool defined  true iff this object defines the symbol
 * @param bool local  true iff a defined symbol is file-local (a rodata datum)
 * @param u8 sect  the 1-based section index (1=`.text`, 2=`.rdata`), 0 when undefined
 * @param u32 offset  the section-relative byte offset (defined symbols only)
 * @return Symbol  the built neutral symbol
 */
fn co_sym(name: str, defined: bool, local: bool, sect: u8, offset: u32) -> Symbol {
    Symbol { name = name; defined = defined; sect = sect; offset = offset; local = local }
}

/**
 * co_reloc — a `RelocX86` fixture shorthand carrying the encoder's base addend
 * (`−4` for `Plt32`/`Pc32`, `0` for `Abs64`), formed by subtraction so no negative
 * literal reaches a panicking cast.
 *
 * @param u32 offset  the `.text`-relative field offset
 * @param str sym  the target symbol's name
 * @param RelocKindX86 kind  the relocation kind
 * @param i64 addend  the base addend
 * @return RelocX86  the built relocation
 */
fn co_reloc(offset: u32, sym: str, kind: RelocKindX86, addend: i64) -> RelocX86 {
    RelocX86 { offset = offset; sym = sym; kind = kind; addend = addend; sect = RelocSect::Text }
}

/**
 * co_longname_module — a hand-built module whose call target `tk_region_alloc`
 * (15 bytes, > 8) exercises the string-table name union: a `call` (5 `.text` bytes)
 * with one `Plt32` relocation, no rodata.
 *
 * @return EncodedModuleX86  the hand-built long-name module
 */
fn co_longname_module() -> EncodedModuleX86 {
    let text = [0xE8 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte]
    let main = co_sym("main", true, false, 1 to u8, 0 to u32)
    let ext = co_sym("tk_region_alloc", false, false, 0 to u8, 0 to u32)
    let reloc = co_reloc(1 to u32, "tk_region_alloc", RelocKindX86::Plt32, (0 to i64) - (4 to i64))
    EncodedModuleX86 { text = text; rodata = teko::list::empty(); symbols = [main, ext]; relocs = [reloc] }
}

/**
 * co_noreloc_module — a hand-built module of a single `ret` `main` with no
 * relocations and no rodata: covers the `PointerToRelocations = 0` /
 * `NumberOfRelocations = 0` `.text` header arm.
 *
 * @return EncodedModuleX86  the hand-built relocation-free module
 */
fn co_noreloc_module() -> EncodedModuleX86 {
    let main = co_sym("main", true, false, 1 to u8, 0 to u32)
    EncodedModuleX86 { text = [0xC3 to byte]; rodata = teko::list::empty(); symbols = [main]; relocs = teko::list::empty() }
}

/**
 * co_abs64_module — a hand-built module with an `Abs64` relocation targeting an
 * undefined data global `gv`. `encode_module_x86` never produces this (it raises
 * `B3-globals` first), but feeding it directly pins the `IMAGE_REL_AMD64_ADDR64`
 * (0x0001) encoding the writer will emit for the future data path.
 *
 * @return EncodedModuleX86  the hand-built Abs64 module
 */
fn co_abs64_module() -> EncodedModuleX86 {
    let text = [0x48 to byte, 0xB8 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0xC3 to byte]
    let main = co_sym("main", true, false, 1 to u8, 0 to u32)
    let gv = co_sym("gv", false, false, 0 to u8, 0 to u32)
    let reloc = co_reloc(2 to u32, "gv", RelocKindX86::Abs64, 0 to i64)
    EncodedModuleX86 { text = text; rodata = teko::list::empty(); symbols = [main, gv]; relocs = [reloc] }
}

#test
/**
 * coff_long_name_uses_strtab_union — a > 8-byte name (`tk_region_alloc`) emits the
 * `IMAGE_SYMBOL` `Name` union `[0,0,0,0]` (Zeroes) then `Offset = 4` into the
 * string table (the first long name lands right after the 4-byte size field); the
 * string table's size field is `4 + 16 = 20`, followed by `tk_region_alloc\0`; and
 * the relocation's `SymbolTableIndex` is 1 (the long-named symbol). The object is
 * 131 bytes.
 *
 * @return void
 */
fn coff_long_name_uses_strtab_union() {
    let obj = emit_coff(co_longname_module())
    teko::assert::is_true(obj.len == (131 to u64))
    teko::assert::is_true(co_u32_at(obj, 69 to u64) == (1 to u32))
    teko::assert::is_true(co_u32_at(obj, 93 to u64) == (0 to u32))
    teko::assert::is_true(co_u32_at(obj, 97 to u64) == (4 to u32))
    teko::assert::is_true(co_u32_at(obj, 111 to u64) == (20 to u32))
    teko::assert::is_true(obj[115 to u64] == (0x74 to byte))
    teko::assert::is_true(obj[116 to u64] == (0x6B to byte))
    teko::assert::is_true(obj[130 to u64] == (0 to byte))
}

#test
/**
 * coff_noreloc_section_has_zero_reloc_pointer — a relocation-free module's `.text`
 * header carries `PointerToRelocations = 0` and `NumberOfRelocations = 0`, and the
 * symbol table follows the 1-byte `.text` immediately (`PointerToSymbolTable = 61`,
 * `NumberOfSymbols = 1`).
 *
 * @return void
 */
fn coff_noreloc_section_has_zero_reloc_pointer() {
    let obj = emit_coff(co_noreloc_module())
    teko::assert::is_true(co_u32_at(obj, 44 to u64) == (0 to u32))
    teko::assert::is_true(co_u16_at(obj, 52 to u64) == (0 to u32))
    teko::assert::is_true(co_u32_at(obj, 8 to u64) == (61 to u32))
    teko::assert::is_true(co_u32_at(obj, 12 to u64) == (1 to u32))
}

#test
/**
 * coff_abs64_emits_addr64 — the hand-built `Abs64` module's relocation (at file
 * offset 71) is `Type = IMAGE_REL_AMD64_ADDR64`(0x0001) against the undefined `gv`
 * (`SymbolTableIndex = 1`): the writer's correct future data-global encoding,
 * reachable only by a hand-built input since `encode_module_x86` honest-stops on
 * globals first.
 *
 * @return void
 */
fn coff_abs64_emits_addr64() {
    let obj = emit_coff(co_abs64_module())
    teko::assert::is_true(co_u32_at(obj, 71 to u64) == (2 to u32))
    teko::assert::is_true(co_u32_at(obj, 75 to u64) == (1 to u32))
    teko::assert::is_true(co_u16_at(obj, 79 to u64) == (0x0001 to u32))
}

#test
/**
 * coff_symbol_index_finds_and_sentinels — `coff_symbol_index` returns a present
 * symbol's index and, for an absent name, the one-past-end sentinel (`syms.len`),
 * covering both arms of the lookup the relocation table relies on.
 *
 * @return void
 */
fn coff_symbol_index_finds_and_sentinels() {
    let syms = coff_build_symbols([co_sym("main", true, false, 1 to u8, 0 to u32), co_sym("tk_exit", false, false, 0 to u8, 0 to u32)])
    teko::assert::is_true(coff_symbol_index(syms, "tk_exit") == (1 to u32))
    teko::assert::is_true(coff_symbol_index(syms, "absent") == (2 to u32))
}

#test
/**
 * coff_win64_pipeline_structure — the FULL Win64 pipeline (select → regalloc under
 * `WIN64` → encode → `emit_coff`) of a `main` calling `tk_exit(42)` yields a
 * well-formed COFF object: `Machine = 0x8664`, one section (no rodata), two symbols
 * (`main` + `tk_exit`), and one `REL32`(0x0004) relocation against `SymbolTableIndex
 * = 1` (`tk_exit`). Proves `emit_coff` consumes a real `EncodedModuleX86` from the
 * B3-1/B3-2 encoder, independent of the exact shadow-space frame size.
 *
 * @return void
 */
fn coff_win64_pipeline_structure() {
    let obj = co_win64_object()
    teko::assert::is_true(co_u16_at(obj, 0 to u64) == (0x8664 to u32))
    teko::assert::is_true(co_u16_at(obj, 2 to u64) == (1 to u32))
    teko::assert::is_true(co_u32_at(obj, 12 to u64) == (2 to u32))
    let reloc_ptr = co_u32_at(obj, 44 to u64)
    teko::assert::is_true(co_u16_at(obj, 52 to u64) == (1 to u32))
    teko::assert::is_true(co_u32_at(obj, (reloc_ptr + (4 to u32)) to u64) == (1 to u32))
    teko::assert::is_true(co_u16_at(obj, (reloc_ptr + (8 to u32)) to u64) == (0x0004 to u32))
}

/**
 * co_win64_object — run the real B3 pipeline on a `main` whose single block is one
 * `call tk_exit` (no return, the `exit`-shape) and assemble its COFF object: encode
 * the physical-register module under `WIN64` (the shadow-space frame from B3-2)
 * and `emit_coff` the result, or an empty buffer on an unexpected honest-stop (so a
 * golden assertion fails loudly). Feeds physical registers straight to the encoder
 * — the B1/ELF `el_object_of` precedent, post-regalloc.
 *
 * @return []byte  the COFF object bytes, or empty on error
 */
fn co_win64_object() -> []byte {
    let call = call_x86("tk_exit", teko::list::empty(), preg(0 to u32, MRegClass::GPR), false, false)
    let blk = MBlockX86 { id = 0 to u32; params = teko::list::empty(); insts = [call] }
    let f = MFuncX86 { symbol = "main"; blocks = [blk]; frame = teko::list::empty() }
    let m = MModuleX86 { funcs = [f]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match encode_module_x86(WIN64, m) {
        EncodedModuleX86 as x => emit_coff(x)
        error as e => teko::list::empty()
    }
}

/**
 * co_rodata_ptr_module — a hand-built `EncodedModuleX86`: a 1-byte `ret` `.text`, a
 * 16-byte `.rdata` (an 8-byte pointer slot at offset 0, the target datum `0x41` at
 * offset 8), two section-2 rodata locals collapsing into the `.rdata` STATIC section
 * symbol, and one `Abs64`/`Rodata` relocation at `.rdata` offset 0 targeting the
 * `target` datum. Feeds `emit_coff` directly, pinning the `.rdata` relocation +
 * 8-byte in-place fold the T-B3 writer emits.
 *
 * @return EncodedModuleX86  the hand-built rodata-internal-pointer module
 */
fn co_rodata_ptr_module() -> EncodedModuleX86 {
    let rodata = [0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0x41 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte, 0 to byte]
    let ptr = co_sym("ptr", true, true, 2 to u8, 0 to u32)
    let target = co_sym("target", true, true, 2 to u8, 8 to u32)
    let main = co_sym("main", true, false, 1 to u8, 0 to u32)
    let rr = RelocX86 { offset = 0 to u32; sym = "target"; kind = RelocKindX86::Abs64; addend = 0 to i64; sect = RelocSect::Rodata }
    EncodedModuleX86 { text = [0xC3 to byte]; rodata = rodata; symbols = [ptr, target, main]; relocs = [rr] }
}

/**
 * T-B3: com um data→data reloc presente, o header `.rdata` aponta a sua própria
 * relocation table (ADDR64 contra o símbolo de seção `.rdata`) e o offset do
 * datum-alvo é dobrado in-place no word baixo do slot de 8 bytes.
 */
#test
fn tb3_coff_rdata_reloc_emitted() {
    let obj = emit_coff(co_rodata_ptr_module())
    teko::assert::is_true(obj.len == 167)
    teko::assert::is_true(co_u16_at(obj, 2) == 2)
    teko::assert::is_true(co_u32_at(obj, 12) == 2)
    teko::assert::is_true(co_u32_at(obj, 44) == 0)
    teko::assert::is_true(co_u16_at(obj, 52) == 0)
    teko::assert::is_true(co_u32_at(obj, 84) == 117)
    teko::assert::is_true(co_u16_at(obj, 92) == 1)
    teko::assert::is_true(co_u32_at(obj, 117) == 0)
    teko::assert::is_true(co_u32_at(obj, 121) == 0)
    teko::assert::is_true(co_u16_at(obj, 125) == 0x0001)
    teko::assert::is_true(co_u32_at(obj, 101) == 8)
    teko::assert::is_true(co_u32_at(obj, 105) == 0)
    teko::assert::is_true(obj[109] == (0x41 to byte))
}
