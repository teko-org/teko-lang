use teko::lir

/**
 * p — a physical GPR operand with the given ISA id (a golden-vector fixture
 * shorthand; A4 runs post-regalloc, so every operand is physical).
 *
 * @param u32 id  the ISA register number (x0..x30, SP/XZR=31)
 * @return MReg  the physical GPR operand
 */
fn p(id: u32) -> MReg {
    preg(id, MRegClass::GPR)
}

/**
 * frameless_layout — the `FrameLayout` of a function with no frame: `size=0`,
 * no callee-saved registers, no slots. Threaded through the A4-1 per-`MInst`
 * golden checks so the instruction subset that never touches the frame encodes
 * BYTE-FOR-BYTE as before the `layout` parameter was added.
 *
 * @return FrameLayout  the empty (frameless) frame side-table
 */
fn frameless_layout() -> FrameLayout {
    FrameLayout {
        size = 0 to u32
        saved_gpr = teko::list::empty()
        saved_fpr = teko::list::empty()
        slot_offsets = teko::list::empty()
    }
}

/**
 * layout_of — a `FrameLayout` built directly from its parts, for the frame
 * golden vectors that pin the exact prologue/epilogue/`MFrameAddr` words to a
 * known frame without routing through `compute_frame_layout`.
 *
 * @param u32 size  the total 16-aligned frame size
 * @param []u32 gpr  the callee-saved GPR ids (ascending)
 * @param []u32 fpr  the callee-saved FPR ids (ascending)
 * @param []u32 slots  the SP-relative slot offsets
 * @return FrameLayout  the assembled frame side-table
 */
fn layout_of(size: u32, gpr: []u32, fpr: []u32, slots: []u32) -> FrameLayout {
    FrameLayout { size = size; saved_gpr = gpr; saved_fpr = fpr; slot_offsets = slots }
}

/**
 * alloca_slot — a frame-slot table entry (`LAlloca`) of the given byte size and
 * alignment, the mixed-frame `compute_frame_layout` fixture shorthand.
 *
 * @param u32 bytes  the slot's byte size
 * @param u32 align  the slot's alignment
 * @return lir::LAlloca  the frame-slot entry
 */
fn alloca_slot(bytes: u32, align: u32) -> lir::LAlloca {
    lir::LAlloca { bytes = bytes; align = align }
}

/**
 * func_of — an `MFunc` with the given frame table and a single block holding
 * `insts`, the `compute_frame_layout` / save-set fixture shorthand.
 *
 * @param []lir::LAlloca frame  the frame-slot table
 * @param []MInst insts  the single block's instruction stream
 * @return MFunc  the assembled function
 */
fn func_of(frame: []lir::LAlloca, insts: []MInst) -> MFunc {
    let block = MBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    MFunc { symbol = "t"; blocks = teko::list::push(teko::list::empty(), block); frame = frame }
}

/**
 * l0 — the empty `[]u32` vector, typed for the frame fixtures.
 *
 * @return []u32  an empty u32 list
 */
fn l0() -> []u32 {
    teko::list::empty()
}

/**
 * l1 — a one-element `[]u32` vector.
 *
 * @param u32 a  the sole element
 * @return []u32  `[a]`
 */
fn l1(a: u32) -> []u32 {
    teko::list::push(l0(), a)
}

/**
 * l2 — a two-element `[]u32` vector, in order.
 *
 * @param u32 a  the first element
 * @param u32 b  the second element
 * @return []u32  `[a, b]`
 */
fn l2(a: u32, b: u32) -> []u32 {
    teko::list::push(l1(a), b)
}

/**
 * l3 — a three-element `[]u32` vector, in order.
 *
 * @param u32 a  the first element
 * @param u32 b  the second element
 * @param u32 c  the third element
 * @return []u32  `[a, b, c]`
 */
fn l3(a: u32, b: u32, c: u32) -> []u32 {
    teko::list::push(l2(a, b), c)
}

/**
 * l_frame — the empty frame-slot table, typed for the fixtures.
 *
 * @return []lir::LAlloca  an empty frame table
 */
fn l_frame() -> []lir::LAlloca {
    teko::list::empty()
}

/**
 * l_insts — the empty instruction list, typed for the fixtures.
 *
 * @return []MInst  an empty instruction stream
 */
fn l_insts() -> []MInst {
    teko::list::empty()
}

/**
 * pro — the prologue words of `layout`, or the empty list on an unexpected
 * honest-stop (so a golden length/word assertion fails loudly rather than
 * aborting).
 *
 * @param FrameLayout layout  the resolved frame
 * @return []u32  the prologue words, or empty on error
 */
fn pro(layout: FrameLayout) -> []u32 {
    match emit_prologue(layout) {
        error as e => l0()
        []u32 as w => w
    }
}

/**
 * epi — the epilogue teardown words of `layout`, or the empty list on an
 * unexpected honest-stop.
 *
 * @param FrameLayout layout  the resolved frame
 * @return []u32  the epilogue words, or empty on error
 */
fn epi(layout: FrameLayout) -> []u32 {
    match emit_epilogue(layout) {
        error as e => l0()
        []u32 as w => w
    }
}

/**
 * pro_stop — the prologue honest-stop message of `layout`, or `<ok>` when it
 * emits successfully.
 *
 * @param FrameLayout layout  the resolved frame
 * @return str  the error message, or `<ok>`
 */
fn pro_stop(layout: FrameLayout) -> str {
    match emit_prologue(layout) {
        error as e => e.message
        []u32 as w => "<ok>"
    }
}

/**
 * epi_stop — the epilogue honest-stop message of `layout`, or `<ok>` when it
 * emits successfully.
 *
 * @param FrameLayout layout  the resolved frame
 * @return str  the error message, or `<ok>`
 */
fn epi_stop(layout: FrameLayout) -> str {
    match emit_epilogue(layout) {
        error as e => e.message
        []u32 as w => "<ok>"
    }
}

/**
 * fp — a physical FPR operand with the given ISA id (a golden-vector fixture
 * shorthand for the float honest-stop cases).
 *
 * @param u32 id  the ISA register number (v0..v31)
 * @return MReg  the physical FPR operand
 */
fn fp(id: u32) -> MReg {
    preg(id, MRegClass::FPR)
}

/**
 * m — a base-plus-displacement memory operand (a golden-vector fixture
 * shorthand for the load/store cases).
 *
 * @param MReg base  the base register
 * @param i32 off  the byte displacement
 * @return MMem  the memory operand
 */
fn m(base: MReg, off: i32) -> MMem {
    MMem { base = base; offset = off }
}

/**
 * bad_word — the sentinel `EncWord` returned when a golden fixture that must
 * encode unexpectedly honest-stops: its all-ones word never matches a real
 * expected encoding, so the assertion fails loudly.
 *
 * @return EncWord  the impossible-word sentinel
 */
fn bad_word() -> EncWord {
    EncWord {
        word = 0xFFFFFFFF to u32
        has_branch = false
        target = 0 to u32
        branch_form = 0 to u32
        has_reloc = false
        reloc_sym = "<error>"
        reloc_kind = MRelocKind::Call
    }
}

/**
 * enc — encode `inst`, unwrapping the success case and falling back to the
 * `bad_word` sentinel on an unexpected honest-stop (so a golden assertion on
 * the word fails rather than aborting the test).
 *
 * @param MInst inst  the instruction to encode
 * @return EncWord  the encoded word, or the sentinel on error
 */
fn enc(inst: MInst) -> EncWord {
    match encode_inst_word(frameless_layout(), inst) {
        EncWord as x => x
        error as e => bad_word()
    }
}

/**
 * enc_with — encode `inst` under an explicit `layout` (the `MFrameAddr` golden
 * path), falling back to the `bad_word` sentinel on an unexpected honest-stop.
 *
 * @param FrameLayout layout  the enclosing frame
 * @param MInst inst  the instruction to encode
 * @return EncWord  the encoded word, or the sentinel on error
 */
fn enc_with(layout: FrameLayout, inst: MInst) -> EncWord {
    match encode_inst_word(layout, inst) {
        EncWord as x => x
        error as e => bad_word()
    }
}

/**
 * stop_of — the honest-stop message `inst` produces, or `<ok>` when it encodes
 * successfully. Lets an honest-stop test assert the named stop is raised.
 *
 * @param MInst inst  the instruction to encode
 * @return str  the error message, or `<ok>` when it encodes
 */
fn stop_of(inst: MInst) -> str {
    match encode_inst_word(frameless_layout(), inst) {
        EncWord as x => "<ok>"
        error as e => e.message
    }
}

/**
 * stop_of_with — the honest-stop message `inst` produces under an explicit
 * `layout`, or `<ok>` when it encodes (the `MFrameAddr` big-frame stop path).
 *
 * @param FrameLayout layout  the enclosing frame
 * @param MInst inst  the instruction to encode
 * @return str  the error message, or `<ok>` when it encodes
 */
fn stop_of_with(layout: FrameLayout, inst: MInst) -> str {
    match encode_inst_word(layout, inst) {
        EncWord as x => "<ok>"
        error as e => e.message
    }
}

/**
 * assert_word — assert that `inst` encodes to the exact 32-bit `expected` word
 * (the position-independent golden-vector check).
 *
 * @param MInst inst  the instruction to encode
 * @param u32 expected  the known-good arm64 instruction word
 * @return void
 */
fn assert_word(inst: MInst, expected: u32) {
    teko::assert::is_true(enc(inst).word == expected)
}

/**
 * assert_stop — assert that `inst` honest-stops with a message containing the
 * named token (`A4-fp`/`A4-bigimm`/`A4-ldur`/`A4-bigframe`).
 *
 * @param MInst inst  the instruction to encode
 * @param str name  the named-stop token expected in the message
 * @return void
 */
fn assert_stop(inst: MInst, name: str) {
    teko::assert::str_contains(stop_of(inst), name)
}

#test
/**
 * emit_u32_le_splits_little_endian — `emit_u32_le` splits a word into four
 * ascending little-endian bytes (the shared `[]byte` build idiom).
 *
 * @return void
 */
fn emit_u32_le_splits_little_endian() {
    let bytes = emit_u32_le(teko::list::empty(), 0xD2800540 to u32)
    teko::assert::is_true(bytes.len == 4)
    teko::assert::is_true(bytes[0] == (0x40 to byte))
    teko::assert::is_true(bytes[1] == (0x05 to byte))
    teko::assert::is_true(bytes[2] == (0x80 to byte))
    teko::assert::is_true(bytes[3] == (0xD2 to byte))
}

#test
/**
 * encodes_the_movz_family — MOVZ/MOVK/MOVN across widths and lane shifts.
 *
 * @return void
 */
fn encodes_the_movz_family() {
    assert_word(movz_inst(true, p(0), 42, 0), 0xD2800540)
    assert_word(movz_inst(false, p(0), 42, 0), 0x52800540)
    assert_word(movz_inst(true, p(0), 100, 16), 0xD2A00C80)
    assert_word(movk_inst(true, p(0), 200, 32), 0xF2C01900)
    assert_word(movn_inst(false, p(0), 1, 0), 0x12800020)
}

#test
/**
 * encodes_the_gpr_move — a GPR-GPR move (ORR from XZR) in both widths.
 *
 * @return void
 */
fn encodes_the_gpr_move() {
    assert_word(mov_inst(true, p(0), p(8)), 0xAA0803E0)
    assert_word(mov_inst(false, p(0), p(8)), 0x2A0803E0)
}

#test
/**
 * encodes_every_integer_alu_reg — all eleven register-register ALU ops, over
 * `x0, x1, x2` (dst=0, a=1, b=2), covering `alu_reg_base` end to end.
 *
 * @return void
 */
fn encodes_every_integer_alu_reg() {
    assert_word(alu_inst(MAluOp::Add, true, p(0), p(1), p(2)), 0x8B020020)
    assert_word(alu_inst(MAluOp::Add, false, p(0), p(1), p(2)), 0x0B020020)
    assert_word(alu_inst(MAluOp::Sub, true, p(0), p(1), p(2)), 0xCB020020)
    assert_word(alu_inst(MAluOp::And, true, p(0), p(1), p(2)), 0x8A020020)
    assert_word(alu_inst(MAluOp::Orr, true, p(0), p(1), p(2)), 0xAA020020)
    assert_word(alu_inst(MAluOp::Eor, true, p(0), p(1), p(2)), 0xCA020020)
    assert_word(alu_inst(MAluOp::Mul, true, p(0), p(1), p(2)), 0x9B027C20)
    assert_word(alu_inst(MAluOp::Sdiv, true, p(0), p(1), p(2)), 0x9AC20C20)
    assert_word(alu_inst(MAluOp::Udiv, true, p(0), p(1), p(2)), 0x9AC20820)
    assert_word(alu_inst(MAluOp::Lsl, true, p(0), p(1), p(2)), 0x9AC22020)
    assert_word(alu_inst(MAluOp::Lsr, true, p(0), p(1), p(2)), 0x9AC22420)
    assert_word(alu_inst(MAluOp::Asr, true, p(0), p(1), p(2)), 0x9AC22820)
}

#test
/**
 * encodes_alu_immediate — ADD/SUB immediates in both widths, plus the
 * negative-immediate add/sub flip (`ADD #-k` == `SUB #k`).
 *
 * @return void
 */
fn encodes_alu_immediate() {
    assert_word(alu_imm_inst(MAluOp::Add, true, p(0), p(1), 7 to i64), 0x91001C20)
    assert_word(alu_imm_inst(MAluOp::Sub, true, p(0), p(1), 7 to i64), 0xD1001C20)
    assert_word(alu_imm_inst(MAluOp::Add, false, p(0), p(1), 7 to i64), 0x11001C20)
    assert_word(alu_imm_inst(MAluOp::Add, true, p(0), p(1), (0 to i64) - (7 to i64)), 0xD1001C20)
    assert_word(alu_imm_inst(MAluOp::Sub, true, p(0), p(1), (0 to i64) - (7 to i64)), 0x91001C20)
}

#test
/**
 * encodes_msub_neg_mvn — the MSUB remainder form, NEG (SUB from XZR), and MVN
 * (ORN from XZR).
 *
 * @return void
 */
fn encodes_msub_neg_mvn() {
    assert_word(msub_inst(true, p(0), p(1), p(2), p(3)), 0x9B028C20)
    assert_word(neg_inst(true, p(0), p(1)), 0xCB0103E0)
    assert_word(neg_inst(false, p(0), p(1)), 0x4B0103E0)
    assert_word(mvn_inst(false, p(0), p(1)), 0x2A2103E0)
    assert_word(mvn_inst(true, p(0), p(1)), 0xAA2103E0)
}

#test
/**
 * encodes_compares — CMP (SUBS to XZR) register and immediate forms in both
 * widths.
 *
 * @return void
 */
fn encodes_compares() {
    assert_word(cmp_inst(true, p(1), p(2)), 0xEB02003F)
    assert_word(cmp_inst(false, p(1), p(2)), 0x6B02003F)
    assert_word(cmp_imm_inst(true, p(1), 7 to i64), 0xF1001C3F)
    assert_word(cmp_imm_inst(false, p(1), 7 to i64), 0x71001C3F)
}

#test
/**
 * encodes_cset_all_conditions — CSET (CSINC with the inverted condition) for
 * all ten `MCond` values, covering `cond_code` end to end.
 *
 * @return void
 */
fn encodes_cset_all_conditions() {
    assert_word(cset_inst(true, p(0), MCond::EQ), 0x9A9F17E0)
    assert_word(cset_inst(false, p(0), MCond::NE), 0x1A9F07E0)
    assert_word(cset_inst(true, p(0), MCond::LT), 0x9A9FA7E0)
    assert_word(cset_inst(true, p(0), MCond::LE), 0x9A9FC7E0)
    assert_word(cset_inst(true, p(0), MCond::GT), 0x9A9FD7E0)
    assert_word(cset_inst(true, p(0), MCond::GE), 0x9A9FB7E0)
    assert_word(cset_inst(true, p(0), MCond::LO), 0x9A9F27E0)
    assert_word(cset_inst(true, p(0), MCond::LS), 0x9A9F87E0)
    assert_word(cset_inst(true, p(0), MCond::HI), 0x9A9F97E0)
    assert_word(cset_inst(true, p(0), MCond::HS), 0x9A9F37E0)
}

#test
/**
 * encodes_every_extend — the six narrow sign/zero-extends (SBFM/UBFM),
 * covering `ext_base` end to end.
 *
 * @return void
 */
fn encodes_every_extend() {
    assert_word(ext_inst(MExtOp::Sxtb, p(0), p(1)), 0x93401C20)
    assert_word(ext_inst(MExtOp::Sxth, p(0), p(1)), 0x93403C20)
    assert_word(ext_inst(MExtOp::Sxtw, p(0), p(1)), 0x93407C20)
    assert_word(ext_inst(MExtOp::Uxtb, p(0), p(1)), 0x53001C20)
    assert_word(ext_inst(MExtOp::Uxth, p(0), p(1)), 0x53003C20)
    assert_word(ext_inst(MExtOp::Uxtw, p(0), p(1)), 0xD3407C20)
}

#test
/**
 * encodes_loads — LDR/LDRB/LDRH plus the sign-extending LDRSB/LDRSH/LDRSW,
 * including scaled offsets, covering `load_form` end to end.
 *
 * @return void
 */
fn encodes_loads() {
    assert_word(load_inst(MMemSize::X, false, p(0), m(p(1), 0)), 0xF9400020)
    assert_word(load_inst(MMemSize::X, false, p(0), m(p(1), 8)), 0xF9400420)
    assert_word(load_inst(MMemSize::W, false, p(0), m(p(1), 4)), 0xB9400420)
    assert_word(load_inst(MMemSize::B, false, p(0), m(p(1), 0)), 0x39400020)
    assert_word(load_inst(MMemSize::H, false, p(0), m(p(1), 0)), 0x79400020)
    assert_word(load_inst(MMemSize::B, true, p(0), m(p(1), 0)), 0x39800020)
    assert_word(load_inst(MMemSize::H, true, p(0), m(p(1), 0)), 0x79800020)
    assert_word(load_inst(MMemSize::W, true, p(0), m(p(1), 0)), 0xB9800020)
}

#test
/**
 * encodes_stores — STR/STRB/STRH across widths and scaled offsets, covering
 * `store_form` end to end.
 *
 * @return void
 */
fn encodes_stores() {
    assert_word(store_inst(MMemSize::X, p(0), m(p(1), 0)), 0xF9000020)
    assert_word(store_inst(MMemSize::X, p(0), m(p(1), 16)), 0xF9000820)
    assert_word(store_inst(MMemSize::W, p(0), m(p(1), 4)), 0xB9000420)
    assert_word(store_inst(MMemSize::B, p(0), m(p(1), 0)), 0x39000020)
    assert_word(store_inst(MMemSize::H, p(0), m(p(1), 0)), 0x79000020)
}

#test
/**
 * encodes_indirect_call_and_ret — BLR (position-independent) and the bare RET
 * word.
 *
 * @return void
 */
fn encodes_indirect_call_and_ret() {
    let no_uses: []MReg = teko::list::empty()
    assert_word(call_indirect_inst(p(8), no_uses, p(0), false), 0xD63F0100)
    assert_word(ret_inst(), 0xD65F03C0)
}

#test
/**
 * encodes_unconditional_branch_placeholder — B emits the `0x14000000`
 * placeholder flagged for imm26 patching with its target block id.
 *
 * @return void
 */
fn encodes_unconditional_branch_placeholder() {
    let ew = enc(branch_inst(3))
    teko::assert::is_true(ew.word == (0x14000000 to u32))
    teko::assert::is_true(ew.has_branch)
    teko::assert::is_false(ew.has_reloc)
    teko::assert::is_true(ew.target == (3 to u32))
    teko::assert::is_true(ew.branch_form == (0 to u32))
}

#test
/**
 * encodes_conditional_branch_placeholder — B.cond bakes the condition and flags
 * imm19 patching; the condition rides bits 0-3.
 *
 * @return void
 */
fn encodes_conditional_branch_placeholder() {
    let ew = enc(branch_cond_inst(MCond::NE, 2))
    teko::assert::is_true(ew.word == (0x54000001 to u32))
    teko::assert::is_true(ew.has_branch)
    teko::assert::is_true(ew.target == (2 to u32))
    teko::assert::is_true(ew.branch_form == (1 to u32))
    assert_word(branch_cond_inst(MCond::EQ, 0), 0x54000000)
}

#test
/**
 * encodes_compare_and_branch_placeholder — CBZ/CBNZ bake the register and
 * zero/nonzero opcode and flag imm19 patching, over both widths.
 *
 * @return void
 */
fn encodes_compare_and_branch_placeholder() {
    let ew = enc(cbz_inst(true, true, p(5), 4))
    teko::assert::is_true(ew.word == (0xB4000005 to u32))
    teko::assert::is_true(ew.has_branch)
    teko::assert::is_true(ew.target == (4 to u32))
    teko::assert::is_true(ew.branch_form == (1 to u32))
    assert_word(cbz_inst(false, false, p(5), 4), 0x35000005)
    assert_word(cbz_inst(true, false, p(5), 4), 0xB5000005)
}

#test
/**
 * encodes_direct_call_reloc — BL emits the `0x94000000` placeholder flagged for
 * a `Call` (BRANCH26) relocation on the callee symbol.
 *
 * @return void
 */
fn encodes_direct_call_reloc() {
    let no_uses: []MReg = teko::list::empty()
    let ew = enc(call_inst("tk_exit", no_uses, p(0), false, false))
    teko::assert::is_true(ew.word == (0x94000000 to u32))
    teko::assert::is_true(ew.has_reloc)
    teko::assert::is_false(ew.has_branch)
    teko::assert::str_contains(ew.reloc_sym, "tk_exit")
    teko::assert::str_contains(reloc_kind_name(ew.reloc_kind), "call")
}

#test
/**
 * encodes_adrp_addlo_reloc — ADRP and ADD-lo12 emit their placeholders flagged
 * for the PAGE21/PAGEOFF12 relocations, carrying the instruction's own kind.
 *
 * @return void
 */
fn encodes_adrp_addlo_reloc() {
    let hi = enc(adrp_inst(p(3), "msg", MRelocKind::PageHi))
    teko::assert::is_true(hi.word == (0x90000003 to u32))
    teko::assert::is_true(hi.has_reloc)
    teko::assert::str_contains(reloc_kind_name(hi.reloc_kind), "page_hi")
    let lo = enc(add_lo_inst(p(1), p(2), "msg", MRelocKind::PageLo))
    teko::assert::is_true(lo.word == (0x91000041 to u32))
    teko::assert::is_true(lo.has_reloc)
    teko::assert::str_contains(reloc_kind_name(lo.reloc_kind), "page_lo")
}

#test
/**
 * float_family_honest_stops — every FP-family case raises the `A4-fp` named
 * honest-stop.
 *
 * @return void
 */
fn float_family_honest_stops() {
    assert_stop(falu_inst(MFAluOp::FAdd, true, fp(0), fp(1), fp(2)), "A4-fp")
    assert_stop(fneg_inst(true, fp(0), fp(1)), "A4-fp")
    assert_stop(fcmp_inst(true, fp(0), fp(1)), "A4-fp")
    assert_stop(fmov_inst(true, fp(0), fp(1)), "A4-fp")
    assert_stop(cvt_inst(MCvtOp::Scvtf, fp(0), p(1)), "A4-fp")
}

#test
/**
 * fpr_memory_honest_stops — loads/stores of the `S`/`D` FPR widths raise the
 * `A4-fp` honest-stop.
 *
 * @return void
 */
fn fpr_memory_honest_stops() {
    assert_stop(load_inst(MMemSize::S, false, fp(0), m(p(1), 0)), "A4-fp")
    assert_stop(load_inst(MMemSize::D, false, fp(0), m(p(1), 0)), "A4-fp")
    assert_stop(store_inst(MMemSize::S, fp(0), m(p(1), 0)), "A4-fp")
    assert_stop(store_inst(MMemSize::D, fp(0), m(p(1), 0)), "A4-fp")
}

#test
/**
 * frameless_layout_leaves_a41_goldens_unchanged — threading a frameless
 * `FrameLayout` through `encode_inst_word` leaves the A4-1 integer/control/
 * memory encodings BYTE-FOR-BYTE identical (the layout parameter is inert for
 * every case that does not touch the frame).
 *
 * @return void
 */
fn frameless_layout_leaves_a41_goldens_unchanged() {
    let fl = frameless_layout()
    teko::assert::is_true(enc_with(fl, movz_inst(true, p(0), 42, 0)).word == (0xD2800540 to u32))
    teko::assert::is_true(enc_with(fl, alu_inst(MAluOp::Add, true, p(0), p(1), p(2))).word == (0x8B020020 to u32))
    teko::assert::is_true(enc_with(fl, ret_inst()).word == (0xD65F03C0 to u32))
}

#test
/**
 * empty_frame_is_frameless — a leaf function (a compute + `ret`, no call, no
 * allocas) resolves to a frameless layout: `size=0`, no callee-saved, no slots.
 *
 * @return void
 */
fn empty_frame_is_frameless() {
    let insts = teko::list::push(teko::list::push(l_insts(), mov_inst(true, p(0), p(1))), ret_inst())
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.size == (0 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
    teko::assert::is_true(fl.saved_fpr.len == 0)
    teko::assert::is_true(fl.slot_offsets.len == 0)
}

#test
/**
 * minimal_frame_is_16 — a function that BOTH calls and returns but has no slots
 * and no callee-saved registers still needs FP/LR preserved: a 16-byte frame
 * (the doc's N=16 minimal frame).
 *
 * @return void
 */
fn minimal_frame_is_16() {
    let no_uses: []MReg = teko::list::empty()
    let insts = teko::list::push(teko::list::push(l_insts(), call_inst("callee", no_uses, p(0), false, false)), ret_inst())
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.size == (16 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
    teko::assert::is_true(fl.slot_offsets.len == 0)
}

#test
/**
 * call_without_ret_is_frameless — a function that makes a call but never returns
 * (the `exit(n)`-terminated virtual-`main` shape: no `MRet`) needs no LR save,
 * so with no slots and no callee-saved it is frameless (`size=0`).
 *
 * @return void
 */
fn call_without_ret_is_frameless() {
    let no_uses: []MReg = teko::list::empty()
    let insts = teko::list::push(l_insts(), call_inst("tk_exit", no_uses, p(0), false, false))
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.size == (0 to u32))
}

#test
/**
 * multi_slot_mixed_align_offsets — a frame of three allocas with mixed sizes and
 * alignments lays out each slot at its own aligned offset (`[0, 16, 24]`), and
 * the whole frame rounds to 16 (`48`).
 *
 * @return void
 */
fn multi_slot_mixed_align_offsets() {
    let frame = teko::list::push(teko::list::push(teko::list::push(l_frame(), alloca_slot(16, 8)), alloca_slot(4, 4)), alloca_slot(8, 8))
    let fl = compute_frame_layout(aapcs64(), func_of(frame, l_insts()))
    teko::assert::is_true(fl.slot_offsets.len == 3)
    teko::assert::is_true(fl.slot_offsets[0] == (0 to u32))
    teko::assert::is_true(fl.slot_offsets[1] == (16 to u32))
    teko::assert::is_true(fl.slot_offsets[2] == (24 to u32))
    teko::assert::is_true(fl.size == (48 to u32))
}

#test
/**
 * frame_rounds_to_16 — a single 8-byte slot plus one callee-saved GPR rounds the
 * total (slots 16 + saved 8 + FP/LR 16 = 40) up to 48.
 *
 * @return void
 */
fn frame_rounds_to_16() {
    let frame = teko::list::push(l_frame(), alloca_slot(8, 8))
    let insts = teko::list::push(l_insts(), mov_inst(true, p(19), p(0)))
    let fl = compute_frame_layout(aapcs64(), func_of(frame, insts))
    teko::assert::is_true(fl.slot_offsets[0] == (0 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 1)
    teko::assert::is_true(fl.saved_gpr[0] == (19 to u32))
    teko::assert::is_true(fl.size == (48 to u32))
}

#test
/**
 * save_set_uses_callee_saved — scanning operands that touch the callee-saved
 * x25/x28/x19/x22 (out of order, one repeated) and the caller-saved x0/x1/x2
 * re-derives the ascending, duplicate-free `saved_gpr=[19,22,25,28]` — the
 * front-insert, mid-insert-with-continuation, end-append, and dedup paths of the
 * ordered insert.
 *
 * @return void
 */
fn save_set_uses_callee_saved() {
    let i0 = alu_inst(MAluOp::Add, true, p(0), p(25), p(28))
    let i1 = alu_inst(MAluOp::Add, true, p(1), p(19), p(22))
    let i2 = alu_inst(MAluOp::Add, true, p(2), p(25), p(0))
    let insts = teko::list::push(teko::list::push(teko::list::push(l_insts(), i0), i1), i2)
    let saved = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(saved.saved_gpr.len == 4)
    teko::assert::is_true(saved.saved_gpr[0] == (19 to u32))
    teko::assert::is_true(saved.saved_gpr[1] == (22 to u32))
    teko::assert::is_true(saved.saved_gpr[2] == (25 to u32))
    teko::assert::is_true(saved.saved_gpr[3] == (28 to u32))
    teko::assert::is_true(saved.saved_fpr.len == 0)
}

#test
/**
 * save_set_no_callee_saved — a function touching only caller-saved x0/x1
 * re-derives an empty callee-saved GPR set.
 *
 * @return void
 */
fn save_set_no_callee_saved() {
    let i0 = alu_inst(MAluOp::Add, true, p(0), p(1), p(0))
    let insts = teko::list::push(l_insts(), i0)
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.saved_gpr.len == 0)
    teko::assert::is_true(fl.saved_fpr.len == 0)
}

#test
/**
 * save_set_uses_callee_saved_fpr — an instruction reading the callee-saved v8
 * re-derives `saved_fpr=[8]` (the FPR half of the save-set, exercised via a
 * float op whose registers `inst_regs` reports even though its encoding stops).
 *
 * @return void
 */
fn save_set_uses_callee_saved_fpr() {
    let i0 = fmov_inst(true, fp(8), fp(0))
    let insts = teko::list::push(l_insts(), i0)
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.saved_fpr.len == 1)
    teko::assert::is_true(fl.saved_fpr[0] == (8 to u32))
    teko::assert::is_true(fl.saved_gpr.len == 0)
}

#test
/**
 * frameless_prologue_epilogue_empty — a `size=0` layout emits neither prologue
 * nor epilogue words.
 *
 * @return void
 */
fn frameless_prologue_epilogue_empty() {
    let fl = frameless_layout()
    teko::assert::is_true(pro(fl).len == 0)
    teko::assert::is_true(epi(fl).len == 0)
}

#test
/**
 * minimal_prologue_epilogue_words — the FP/LR-only 16-byte frame's exact
 * prologue (`sub sp,#16`; `stp x29,x30,[sp,#0]`; `add x29,sp,#0`) and epilogue
 * (`ldp x29,x30,[sp,#0]`; `add sp,#16`).
 *
 * @return void
 */
fn minimal_prologue_epilogue_words() {
    let fl = layout_of(16 to u32, l0(), l0(), l0())
    let pr = pro(fl)
    teko::assert::is_true(pr.len == 3)
    teko::assert::is_true(pr[0] == (0xD10043FF to u32))
    teko::assert::is_true(pr[1] == (0xA9007BFD to u32))
    teko::assert::is_true(pr[2] == (0x910003FD to u32))
    let ep = epi(fl)
    teko::assert::is_true(ep.len == 2)
    teko::assert::is_true(ep[0] == (0xA9407BFD to u32))
    teko::assert::is_true(ep[1] == (0x910043FF to u32))
}

#test
/**
 * callee_saved_gpr_pair_words — a 48-byte frame saving the x19/x20 pair emits
 * the FP/LR save at `#32`, the FP-set at `#32`, and the `stp x19,x20,[sp,#16]`
 * pair (restored by `ldp x19,x20,[sp,#16]`).
 *
 * @return void
 */
fn callee_saved_gpr_pair_words() {
    let fl = layout_of(48 to u32, l2(19, 20), l0(), l1(0))
    let pr = pro(fl)
    teko::assert::is_true(pr.len == 4)
    teko::assert::is_true(pr[0] == (0xD100C3FF to u32))
    teko::assert::is_true(pr[1] == (0xA9027BFD to u32))
    teko::assert::is_true(pr[2] == (0x910083FD to u32))
    teko::assert::is_true(pr[3] == (0xA90153F3 to u32))
    let ep = epi(fl)
    teko::assert::is_true(ep.len == 3)
    teko::assert::is_true(ep[0] == (0xA94153F3 to u32))
    teko::assert::is_true(ep[1] == (0xA9427BFD to u32))
    teko::assert::is_true(ep[2] == (0x9100C3FF to u32))
}

#test
/**
 * callee_saved_gpr_single_word — an odd callee-saved count (only x19) in a
 * 32-byte frame emits a single `str x19,[sp,#8]` (restored by `ldr
 * x19,[sp,#8]`).
 *
 * @return void
 */
fn callee_saved_gpr_single_word() {
    let fl = layout_of(32 to u32, l1(19), l0(), l0())
    let pr = pro(fl)
    teko::assert::is_true(pr.len == 4)
    teko::assert::is_true(pr[3] == (0xF90007F3 to u32))
    let ep = epi(fl)
    teko::assert::is_true(ep[0] == (0xF94007F3 to u32))
}

#test
/**
 * callee_saved_fpr_pair_words — a 48-byte frame saving the v8/v9 FPR pair emits
 * `stp d8,d9,[sp,#16]` (restored by `ldp d8,d9,[sp,#16]`).
 *
 * @return void
 */
fn callee_saved_fpr_pair_words() {
    let fl = layout_of(48 to u32, l0(), l2(8, 9), l1(0))
    let pr = pro(fl)
    teko::assert::is_true(pr.len == 4)
    teko::assert::is_true(pr[3] == (0x6D0127E8 to u32))
    let ep = epi(fl)
    teko::assert::is_true(ep[0] == (0x6D4127E8 to u32))
}

#test
/**
 * callee_saved_fpr_single_word — an odd FPR count (only v8) in a 32-byte frame
 * emits a single `str d8,[sp,#8]` (restored by `ldr d8,[sp,#8]`).
 *
 * @return void
 */
fn callee_saved_fpr_single_word() {
    let fl = layout_of(32 to u32, l0(), l1(8), l0())
    let pr = pro(fl)
    teko::assert::is_true(pr.len == 4)
    teko::assert::is_true(pr[3] == (0xFD0007E8 to u32))
    let ep = epi(fl)
    teko::assert::is_true(ep[0] == (0xFD4007E8 to u32))
}

#test
/**
 * frame_addr_resolves_to_add — `MFrameAddr` resolves through the layout to `ADD
 * dst, sp, #slot_offset`: slot 0 at offset 8 → `add x0,sp,#8`; a second slot at
 * offset 16 into x5 → `add x5,sp,#16`. The word carries no branch/reloc fixup.
 *
 * @return void
 */
fn frame_addr_resolves_to_add() {
    let fl = layout_of(32 to u32, l0(), l0(), l2(8, 16))
    let ew0 = enc_with(fl, frame_addr_inst(p(0), 0))
    teko::assert::is_true(ew0.word == (0x910023E0 to u32))
    teko::assert::is_false(ew0.has_branch)
    teko::assert::is_false(ew0.has_reloc)
    teko::assert::is_true(enc_with(fl, frame_addr_inst(p(5), 1)).word == (0x910043E5 to u32))
}

#test
/**
 * frame_addr_slot_zero_offset — a slot at offset 0 resolves to `add dst,sp,#0`.
 *
 * @return void
 */
fn frame_addr_slot_zero_offset() {
    let fl = layout_of(32 to u32, l0(), l0(), l1(0))
    teko::assert::is_true(enc_with(fl, frame_addr_inst(p(0), 0)).word == (0x910003E0 to u32))
}

#test
/**
 * slot_offset_reads_the_map — `slot_offset` is a direct lookup into the
 * alignment-honoring per-slot map.
 *
 * @return void
 */
fn slot_offset_reads_the_map() {
    let fl = layout_of(48 to u32, l0(), l0(), l3(0, 16, 24))
    teko::assert::is_true(slot_offset(fl, 0 to u32) == (0 to u32))
    teko::assert::is_true(slot_offset(fl, 1 to u32) == (16 to u32))
    teko::assert::is_true(slot_offset(fl, 2 to u32) == (24 to u32))
}

#test
/**
 * big_frame_addr_honest_stops — a slot offset beyond the 12-bit ADD-imm field
 * raises the `A4-bigframe` honest-stop.
 *
 * @return void
 */
fn big_frame_addr_honest_stops() {
    let fl = layout_of(8192 to u32, l0(), l0(), l1(5000))
    teko::assert::str_contains(stop_of_with(fl, frame_addr_inst(p(0), 0)), "A4-bigframe")
}

#test
/**
 * big_prologue_epilogue_honest_stops — a frame whose FP/LR pair offset outruns
 * the signed 7-bit STP field raises `A4-bigframe` from both prologue and
 * epilogue.
 *
 * @return void
 */
fn big_prologue_epilogue_honest_stops() {
    let fl = layout_of(1024 to u32, l0(), l0(), l0())
    teko::assert::str_contains(pro_stop(fl), "A4-bigframe")
    teko::assert::str_contains(epi_stop(fl), "A4-bigframe")
}

#test
/**
 * big_immediate_honest_stops — an out-of-range or non-add/sub immediate raises
 * the `A4-bigimm` honest-stop, for both ALU-imm and CMP-imm.
 *
 * @return void
 */
fn big_immediate_honest_stops() {
    assert_stop(alu_imm_inst(MAluOp::Add, true, p(0), p(1), 5000 to i64), "A4-bigimm")
    assert_stop(alu_imm_inst(MAluOp::Add, true, p(0), p(1), (0 to i64) - (5000 to i64)), "A4-bigimm")
    assert_stop(alu_imm_inst(MAluOp::And, true, p(0), p(1), 3 to i64), "A4-bigimm")
    assert_stop(cmp_imm_inst(true, p(1), 5000 to i64), "A4-bigimm")
    assert_stop(cmp_imm_inst(true, p(1), (0 to i64) - (1 to i64)), "A4-bigimm")
}

#test
/**
 * unscaled_offset_honest_stops — a negative, unaligned, or too-large load/store
 * offset raises the `A4-ldur` honest-stop, covering each `scaled_offset` guard.
 *
 * @return void
 */
fn unscaled_offset_honest_stops() {
    assert_stop(load_inst(MMemSize::X, false, p(0), m(p(1), (0 to i32) - (8 to i32))), "A4-ldur")
    assert_stop(load_inst(MMemSize::X, false, p(0), m(p(1), 4)), "A4-ldur")
    assert_stop(load_inst(MMemSize::X, false, p(0), m(p(1), 32768)), "A4-ldur")
    assert_stop(store_inst(MMemSize::H, p(0), m(p(1), 1)), "A4-ldur")
}

#test
/**
 * layout_zero_and_one_align_slots — an alloca with `align = 0` or `align = 1`
 * lays out at the running offset unchanged (the guarded `align_up` no-op arm,
 * the same contract as `lir::align_up`): slots `[{8,0},{8,1},{4,4}]` sit at
 * `[0, 8, 16]` (slots region 32) and the FP/LR pair brings the frame to 48.
 *
 * @return void
 */
fn layout_zero_and_one_align_slots() {
    let frame = teko::list::push(teko::list::push(teko::list::push(l_frame(), alloca_slot(8, 0)), alloca_slot(8, 1)), alloca_slot(4, 4))
    let fl = compute_frame_layout(aapcs64(), func_of(frame, l_insts()))
    teko::assert::is_true(fl.slot_offsets[0] == (0 to u32))
    teko::assert::is_true(fl.slot_offsets[1] == (8 to u32))
    teko::assert::is_true(fl.slot_offsets[2] == (16 to u32))
    teko::assert::is_true(fl.size == (48 to u32))
}

#test
/**
 * callee_saved_only_leaf_is_framed — a no-call, no-slot leaf that touches x19
 * is framed purely by its save-set: size = 16 (FP/LR) + 8 (x19) rounded to 32.
 *
 * @return void
 */
fn callee_saved_only_leaf_is_framed() {
    let insts = teko::list::push(l_insts(), alu_inst(MAluOp::Add, true, p(19), p(0), p(1)))
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.saved_gpr.len == 1)
    teko::assert::is_true(fl.size == (32 to u32))
}

#test
/**
 * indirect_call_without_ret_is_frameless — an `MCallIndirect` with no `MRet`
 * (the BLR-terminated shape) stays frameless, mirroring the direct-call case:
 * `has_call` alone never forces LR preservation.
 *
 * @return void
 */
fn indirect_call_without_ret_is_frameless() {
    let no_uses: []MReg = teko::list::empty()
    let insts = teko::list::push(l_insts(), call_indirect_inst(p(9), no_uses, p(0), false))
    let fl = compute_frame_layout(aapcs64(), func_of(l_frame(), insts))
    teko::assert::is_true(fl.size == (0 to u32))
}
