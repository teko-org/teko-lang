        symbol = "teko__test__no_blocks"; n_params = 0 to u32; param_types = teko::list::empty()
        ret_type = lir::LType::Void; blocks = teko::list::empty(); next_vreg = 0 to u32
    }
    match stackify_control(f, wasm_symtab_empty(), false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "no blocks")
    }
}

#test
/**
 * stackify_func_jump_arity_mismatch_propagates_the_named_error — a `jump`
 * into a block declaring one param, carrying zero args: `render_edge`'s
 * `emit_edge_copies` error propagates through `render_jump_terminator`
 * unchanged.
 *
 * @return void
 */
fn stackify_func_jump_arity_mismatch_propagates_the_named_error() {
    mut f = lir::new_func("teko__test__jump_arity", 0, teko::list::empty(), lir::LType::Void)
    let headb = lir::alloc_block(f)
    let hp = lir::add_block_param(headb.func, headb.block_id)
    f = lir::append_inst(hp.func, 0, lir::jump_inst(headb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, headb.block_id, lir::ret_void_inst(0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "arity mismatch")
    }
}

#test
/**
 * stackify_func_branch_then_arm_arity_mismatch_propagates_the_named_error
 * — an `if`'s THEN edge with a param/arg arity mismatch propagates through
 * `render_arm` and `render_branch_terminator`'s own `then_done` match.
 *
