    let elseb = lir::alloc_block(thenb.func)
    let ep = lir::add_block_param(elseb.func, elseb.block_id)
    f = lir::append_inst(ep.func, 0, lir::branch_inst(0, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, thenb.block_id, lir::ret_void_inst(0, 0))
    f = lir::append_inst(f, elseb.block_id, lir::ret_void_inst(0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "arity mismatch")
    }
}

#test
/**
 * stackify_func_loop_back_edge_arity_mismatch_propagates_through_render_
 * loop — a loop whose back-edge carries the wrong arg count: the error
 * propagates all the way out through `render_loop`'s own `body_done` match
 * (distinct from the plain if/else arity tests above, which never enter a
 * loop at all).
 *
 * @return void
 */
fn stackify_func_loop_back_edge_arity_mismatch_propagates_through_render_loop() {
    mut f = lir::new_func("teko__test__loop_back_arity", 0, teko::list::empty(), lir::LType::Void)
    let headb = lir::alloc_block(f)
    let hp = lir::add_block_param(headb.func, headb.block_id)
    let exitb = lir::alloc_block(hp.func)
    let entry_args = teko::list::push(teko::list::empty(), 0 to u32)
    f = lir::append_inst(exitb.func, 0, lir::jump_inst(headb.block_id, entry_args, 0, 0))
    f = lir::append_inst(f, headb.block_id, lir::branch_inst(hp.vreg, exitb.block_id, teko::list::empty(), headb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, exitb.block_id, lir::ret_void_inst(0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "arity mismatch")
    }
}

#test
/**
 * wst_get_defaults_to_zero_when_unset — the defensive out-of-range default
 * (never reached from valid input — every `LAlloca` is pre-scanned into the
 * table before its own lowering).
 *
 * @return void
 */
fn wst_get_defaults_to_zero_when_unset() {
    teko::assert::is_true(wst_get(wst_empty(), 3) == (0 to u32))
}

#test
/**
 * alloca_of_non_alloca_is_an_all_zero_placeholder — `alloca_of`'s own
 * defensive fallback arm, exercised directly on a non-`LAlloca` instruction
 * (never reached from `collect_alloca_insts`'s own pre-filtered callers).
 *
 * @return void
 */
fn alloca_of_non_alloca_is_an_all_zero_placeholder() {
    let a = alloca_of(lir::ret_void_inst(0, 0))
    teko::assert::is_true(a.bytes == (0 to u32))
    teko::assert::is_true(a.align == (1 to u32))
}

#test
/**
 * compute_wasm_frame_layout_single_alloca — one `LAlloca{bytes=8,align=8}`
 * gets offset `0`, and the frame's own size/alignment match it exactly.
 *
 * @return void
 */
fn compute_wasm_frame_layout_single_alloca() {
    let inst = lir::alloca_inst(0, 8, 8, 0, 0)
    let layout = compute_wasm_frame_layout([inst])
    teko::assert::is_true(wst_get(layout.slots, 0) == (0 to u32))
    teko::assert::is_true(layout.frame_size == (8 to u32))
    teko::assert::is_true(layout.frame_align == (8 to u32))
}

#test
/**
 * compute_wasm_frame_layout_packs_two_allocas_with_padding — a `bytes=4,
 * align=4` slot followed by a `bytes=8,align=8` slot: the second slot is
 * padded up to offset `8` (its own alignment), and the frame's own
 * alignment/size follow the WIDER slot.
 *
 * @return void
 */
fn compute_wasm_frame_layout_packs_two_allocas_with_padding() {
    let a = lir::alloca_inst(0, 4, 4, 0, 0)
    let b = lir::alloca_inst(1, 8, 8, 0, 0)
    let layout = compute_wasm_frame_layout([a, b])
    teko::assert::is_true(wst_get(layout.slots, 0) == (0 to u32))
    teko::assert::is_true(wst_get(layout.slots, 1) == (8 to u32))
    teko::assert::is_true(layout.frame_size == (16 to u32))
    teko::assert::is_true(layout.frame_align == (8 to u32))
}

#test
/**
 * collect_alloca_insts_finds_every_alloca_in_block_order — a two-block
 * function with one `LAlloca` per block: both are found, in block order.
 *
 * @return void
 */
fn collect_alloca_insts_finds_every_alloca_in_block_order() {
    mut f = lir::new_func("teko__test__collect_alloca", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::alloca_inst(r0.vreg, 4, 4, 0, 0))
    f = lir::append_inst(f, 0, lir::jump_inst(1, teko::list::empty(), 0, 0))
    let b1 = lir::alloc_block(f)
    f = b1.func
    let r1 = lir::alloc_vreg(f)
    f = lir::append_inst(r1.func, b1.block_id, lir::alloca_inst(r1.vreg, 8, 8, 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::ret_void_inst(0, 0))
    let found = collect_alloca_insts(f)
    teko::assert::is_true(found.len == 2)
    teko::assert::is_true(found[0].result == r0.vreg)
    teko::assert::is_true(found[1].result == r1.vreg)
}

#test
/**
 * stackify_func_single_alloca_matches_wat2wasm_reference — `fn f() -> i32 {
 * alloca(8, align=8) }`: the shadow-stack prologue, the `LAlloca` site's own
 * offset-`0` address computation, and the epilogue-before-`return`, all
 * byte-for-byte identical to `wat2wasm`.
 *
 * @return void
 */
fn stackify_func_single_alloca_matches_wat2wasm_reference() {
    mut f = lir::new_func("teko__test__single_alloca", 0, teko::list::empty(), lir::LType::I32)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::alloca_inst(r0.vreg, 8, 8, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_inst(r0.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* r0 (the alloca's own address) is single-use, same-block (its ONLY
     * use is the immediately-following `ret`) — it rides the stack (§5),
     * dropping its `local.set 0`/`local.get 0` round-trip. The scratch
     * `frame_base` local (index `1`) is untouched by the peephole — it is
     * not an LIR VReg. */
    let want = [
        0x23 to byte, 0x00 to byte, 0x41 to byte, 0x08 to byte, 0x6B to byte, 0x41 to byte, 0x78 to byte, 0x71 to byte,
        0x22 to byte, 0x01 to byte, 0x24 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x41 to byte, 0x00 to byte,
        0x6A to byte, 0x20 to byte, 0x01 to byte, 0x24 to byte, 0x00 to byte,
        0x0F to byte, 0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (2 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_unaligned_alloca_skips_the_align_down_mask — a single
 * `bytes=3, align=1` alloca needs no `i32.and` mask in its prologue (`align
 * <= 1` is a no-op, `wasm_align_down_i32`'s other arm), byte-for-byte
 * identical to `wat2wasm`.
 *
 * @return void
 */
fn stackify_func_unaligned_alloca_skips_the_align_down_mask() {
    mut f = lir::new_func("teko__test__unaligned_alloca", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::alloca_inst(r0.vreg, 3, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x23 to byte, 0x00 to byte, 0x41 to byte, 0x03 to byte, 0x6B to byte, 0x22 to byte, 0x01 to byte, 0x24 to byte,
        0x00 to byte, 0x20 to byte, 0x01 to byte, 0x41 to byte, 0x00 to byte, 0x6A to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x24 to byte, 0x00 to byte, 0x0F to byte, 0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (2 to u32))
}

#test
/**
 * stackify_func_two_allocas_matches_wat2wasm_reference — two allocas
 * (`bytes=4,align=4` then `bytes=8,align=8`) in one function: ONE prologue
 * bump for the whole `frame_size=16` frame, each site its own fixed offset
 * (`0`/`8`), byte-for-byte identical to `wat2wasm`.
 *
 * @return void
 */
fn stackify_func_two_allocas_matches_wat2wasm_reference() {
    mut f = lir::new_func("teko__test__two_allocas", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::alloca_inst(r0.vreg, 4, 4, 0, 0))
    let r1 = lir::alloc_vreg(f)
    f = lir::append_inst(r1.func, 0, lir::alloca_inst(r1.vreg, 8, 8, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x23 to byte, 0x00 to byte, 0x41 to byte, 0x10 to byte, 0x6B to byte, 0x41 to byte, 0x78 to byte, 0x71 to byte,
        0x22 to byte, 0x02 to byte, 0x24 to byte, 0x00 to byte, 0x20 to byte, 0x02 to byte, 0x41 to byte, 0x00 to byte,
        0x6A to byte, 0x21 to byte, 0x00 to byte, 0x20 to byte, 0x02 to byte, 0x41 to byte, 0x08 to byte, 0x6A to byte,
        0x21 to byte, 0x01 to byte, 0x20 to byte, 0x02 to byte, 0x24 to byte, 0x00 to byte, 0x0F to byte, 0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (3 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

/**
 * srt_rodata — one `LRodata` entry (`symbol`, `bytes`), the fixture
 * `wasm_layout_rodata`'s own tests build from.
 *
 * @param str symbol  the entry's symbol
 * @param []byte bytes  its raw byte content
 * @return lir::LRodata  the entry
 */
fn srt_rodata(symbol: str, bytes: []byte) -> lir::LRodata {
    lir::LRodata { symbol = symbol; bytes = bytes }
}

#test
/**
 * wasm_layout_rodata_places_entries_back_to_back — two entries (`"hi"` then
 * `"!"`) starting at base `0`: contiguous offsets, no padding, and `end` one
 * past the last byte.
 *
 * @return void
 */
fn wasm_layout_rodata_places_entries_back_to_back() {
    let rodata = [srt_rodata("s0", [0x68 to byte, 0x69 to byte]), srt_rodata("s1", [0x21 to byte])]
    let layout = wasm_layout_rodata(rodata, 0 to u32)
    teko::assert::is_true(layout.segment.offset == (0 to u32))
    teko::assert::is_true(wasm_bytes_eq(layout.segment.bytes, [0x68 to byte, 0x69 to byte, 0x21 to byte]))
    teko::assert::is_true(layout.symbols.len == 2)
    teko::assert::is_true(layout.symbols[0] == "s0" && layout.symbols[1] == "s1")
    teko::assert::is_true(layout.offsets[0] == (0 to u32) && layout.offsets[1] == (2 to u32))
    teko::assert::is_true(layout.end == (3 to u32))
}

#test
/**
 * wasm_layout_rodata_honors_a_nonzero_base — the same two entries, but
 * placed starting at base `100` (the caller's own memory-plan choice).
 *
 * @return void
 */
fn wasm_layout_rodata_honors_a_nonzero_base() {
    let rodata = [srt_rodata("s0", [0x68 to byte, 0x69 to byte])]
    let layout = wasm_layout_rodata(rodata, 100 to u32)
    teko::assert::is_true(layout.segment.offset == (100 to u32))
    teko::assert::is_true(layout.offsets[0] == (100 to u32))
    teko::assert::is_true(layout.end == (102 to u32))
}

#test
/**
 * wasm_symtab_add_rodata_registers_every_entry — a laid-out rodata table
 * registers ALL of its own symbols into a `WasmSymbolTable` in one call,
 * each resolving to its own offset.
 *
 * @return void
 */
fn wasm_symtab_add_rodata_registers_every_entry() {
    let rodata = [srt_rodata("s0", [0x68 to byte, 0x69 to byte]), srt_rodata("s1", [0x21 to byte])]
    let layout = wasm_layout_rodata(rodata, 0 to u32)
    let symbols = wasm_symtab_add_rodata(wasm_symtab_empty(), layout)
    match wasm_resolve_data(symbols, "s0") { u32 as o => teko::assert::is_true(o == (0 to u32)); error => teko::assert::is_true(false) }
    match wasm_resolve_data(symbols, "s1") { u32 as o => teko::assert::is_true(o == (2 to u32)); error => teko::assert::is_true(false) }
}

#test
/**
 * wasm_honest_globals_names_c1_globals — the module-level `LGlobal` stop's
 * own message.
 *
 * @return void
 */
fn wasm_honest_globals_names_c1_globals() {
    teko::assert::str_contains(wasm_honest_globals().message, "C1-globals")
}

#test
/**
 * wasm_sp_global_is_a_mutable_i32 — `wasm_sp_global`'s own builder shape:
 * always `i32`, always mutable, carrying the caller's own `init` through
 * unchanged.
 *
 * @return void
 */
fn wasm_sp_global_is_a_mutable_i32() {
    let g = wasm_sp_global(1024 to i64)
    teko::assert::is_true(g.valtype == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(g.mutable)
    teko::assert::is_true(g.init == (1024 to i64))
    teko::assert::is_true(wasm_sp_global_index() == (0 to u32))
}

/**
 * sft_main_func — a minimal `"main"` `LFunc` (`i32`-returning, 0 params):
 * `%0 = const 0; call tk_exit(%0); ret %0` — the `own_exit_zero` fixture's
 * own shape (a call the program-wide symbol table always resolves,
 * `"tk_exit"`). The first fixture of the C1-5 `wasm_assemble_program`
 * suite below — the whole-module assembler that emits a self-contained
 * wasm module (`backend-wasm.md` §1.2, `backend-c1-wasm.md` §9).
 *
 * @return lir::LFunc  the seeded `main` function
 */
fn sft_main_func() -> lir::LFunc {
    let insts = [
        lir::const_int_inst(0, 0, 0, 0),
        lir::void_call_inst("tk_exit", [0 to u32], false, 0, 0),
        lir::ret_inst(0, 0, 0)
    ]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "main"; n_params = 0 to u32; param_types = teko::list::empty(); ret_type = lir::LType::I32; blocks = [block]; next_vreg = 1 to u32 }
}

/**
 * sft_alloca_func — a `Void`-returning `LFunc` with ONE `LAlloca` (`8`
 * bytes, `8`-aligned) then `ret` — the `wasm_program_has_any_frame` /
 * `wasm_program_memory_plan` "needs a shadow-stack frame" fixture.
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_alloca_func() -> lir::LFunc {
    let insts = [lir::alloca_inst(0, 8, 8, 0, 0), lir::ret_inst(0, 0, 0)]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "teko__test__alloca"; n_params = 0 to u32; param_types = teko::list::empty(); ret_type = lir::LType::Void; blocks = [block]; next_vreg = 1 to u32 }
}

/**
 * sft_ptr_load_func — a `Void`-returning `LFunc` with ONE `Ptr`-typed
 * parameter, ONE `Ptr`-typed `LLoad` off it, then `ret` — the `wasm_
 * program_has_ptr_load` / `wasm_assemble_program`'s checked-narrow-panic-
 * message reachability gate "some function loads a `Ptr`" fixture (#389
 * C1-7 review finding #1).
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_ptr_load_func() -> lir::LFunc {
    let insts = [lir::param_inst(0, 0, 0, 0), lir::load_inst(1, 0, lir::LType::Ptr, 0, 0), lir::ret_void_inst(0, 0)]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "teko__test__ptrload"; n_params = 1 to u32; param_types = [lir::LType::Ptr]; ret_type = lir::LType::Void; blocks = [block]; next_vreg = 2 to u32 }
}

/**
 * sft_i128_ret_func — a `Void`-param, `I128`-returning `LFunc` — `wasm_
 * func_type_of`'s own honest-stop (`C1-i128`) fixture, its return side.
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_i128_ret_func() -> lir::LFunc {
    lir::new_func("teko__test__i128ret", 0, teko::list::empty(), lir::LType::I128)
}

/**
 * sft_i128_param_func — an `I128`-param, `Void`-returning `LFunc` —
 * `wasm_func_type_of`'s own honest-stop (`C1-i128`) fixture, its param
 * side.
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_i128_param_func() -> lir::LFunc {
    lir::new_func("teko__test__i128param", 1, [lir::LType::I128], lir::LType::Void)
}

#test
/**
 * mem_pages_for_floors_at_one_page_and_rounds_up — `0` still requests one
 * page (the never-zero floor); a value exactly on a page boundary needs
 * exactly that many pages; one byte OVER a boundary rounds up to the NEXT
 * page.
 *
 * @return void
 */
fn mem_pages_for_floors_at_one_page_and_rounds_up() {
    teko::assert::is_true(wasm_mem_pages_for(0 to u32) == (1 to u32))
    teko::assert::is_true(wasm_mem_pages_for(65536 to u32) == (1 to u32))
    teko::assert::is_true(wasm_mem_pages_for(65537 to u32) == (2 to u32))
}

#test
/**
 * program_func_index_shifts_by_the_import_count — a defined function at
 * position `2`, with `2` host imports ahead of it, resolves to absolute
 * index `4`.
 *
 * @return void
 */
fn program_func_index_shifts_by_the_import_count() {
    teko::assert::is_true(wasm_program_func_index(2 to u64, 2 to u64) == (4 to u32))
}

#test
/**
 * register_program_symbols_resolves_tk_exit_and_every_func — `"tk_exit"`
 * resolves DIRECTLY to the WASI `proc_exit` import's own index; `"main"`
 * resolves to its own absolute index (past the two WASI imports).
 *
 * @return void
 */
fn register_program_symbols_resolves_tk_exit_and_every_func() {
    let wasi = wasm_wasi_import_set()
    let t = wasm_register_program_symbols(wasi, [sft_main_func()])
    let exit_target = match wasm_resolve_call(t, "tk_exit") { WasmCallTarget as x => x; error => return }
    teko::assert::is_true(exit_target.func_index == wasi.proc_exit_index)
    teko::assert::is_true(exit_target.ret_type == lir::LType::Void)
    let main_target = match wasm_resolve_call(t, "main") { WasmCallTarget as x => x; error => return }
    teko::assert::is_true(main_target.func_index == (2 to u32))
    teko::assert::is_true(main_target.ret_type == lir::LType::I32)
}

#test
/**
 * func_type_of_translates_params_and_a_nonvoid_result — `sft_main_func`'s
 * own `() -> i32` signature translates to no params + one `i32` result.
 *
 * @return void
 */
fn func_type_of_translates_params_and_a_nonvoid_result() {
    let t = match wasm_func_type_of(sft_main_func(), false) { WasmFuncType as x => x; error => return }
    teko::assert::is_true(t.params.len == (0 to u64))
    teko::assert::is_true(t.results.len == (1 to u64))
    teko::assert::is_true(t.results[0] == (wasm_vtype_wire(WasmVType::I32) to byte))
}

#test
/**
 * func_type_of_a_void_function_has_no_results — `sft_empty_func`'s own
 * `() -> void` signature translates to zero results (the MVP's no-multi-
 * value shape, §4.3).
 *
 * @return void
 */
fn func_type_of_a_void_function_has_no_results() {
    let t = match wasm_func_type_of(sft_empty_func(), false) { WasmFuncType as x => x; error => return }
    teko::assert::is_true(t.results.len == (0 to u64))
}

#test
/**
 * func_type_of_propagates_the_i128_stop_on_either_side — an `I128` PARAM
 * and an `I128` RESULT both propagate `wasm_valtype`'s own `C1-i128`
 * honest-stop.
 *
 * @return void
 */
fn func_type_of_propagates_the_i128_stop_on_either_side() {
    match wasm_func_type_of(sft_i128_param_func(), false) {
        WasmFuncType => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
    match wasm_func_type_of(sft_i128_ret_func(), false) {
        WasmFuncType => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

#test
/**
 * build_program_types_appends_wasi_then_one_per_func — the WASI import
 * set's own two types come first, then one entry for `sft_main_func`,
 * totaling three.
 *
 * @return void
 */
fn build_program_types_appends_wasi_then_one_per_func() {
    let wasi = wasm_wasi_import_set()
    let types = match wasm_build_program_types(wasi, [sft_main_func()], false) { []WasmFuncType as x => x; error => return }
    teko::assert::is_true(types.len == (3 to u64))
    teko::assert::is_true(types[2].results.len == (1 to u64))
}

#test
/**
 * build_program_types_propagates_a_func_type_of_stop — a function whose
 * own signature honest-stops propagates out of the whole type table build.
 *
 * @return void
 */
fn build_program_types_propagates_a_func_type_of_stop() {
    let wasi = wasm_wasi_import_set()
    match wasm_build_program_types(wasi, [sft_i128_ret_func()], false) {
        []WasmFuncType => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

#test
/**
 * build_program_funcs_packages_a_self_contained_func — `sft_main_func`
 * stackifies into ONE packaged `WasmFunc` at its interned `type_index` (past
 * the two WASI imports), its body carrying the compact, already-final
 * call-site funcidx operands and terminated by the code-entry `end` (`0x0B`)
 * — no relocation table, no operand widening (`backend-wasm.md` §1.2's
 * self-contained module).
 *
 * @return void
 */
fn build_program_funcs_packages_a_self_contained_func() {
    let wasi = wasm_wasi_import_set()
    let symtab = wasm_register_program_symbols(wasi, [sft_main_func()])
    let funcs = match wasm_build_program_funcs(wasi, [sft_main_func()], symtab, false) { []WasmFunc as x => x; error => return }
    teko::assert::is_true(funcs.len == (1 to u64))
    let f = funcs[0]
    teko::assert::is_true(f.type_index == (2 to u32))
    teko::assert::is_true(f.body.len > (0 to u64))
    teko::assert::is_true(f.body[f.body.len - 1] == (0x0B to byte))
}

#test
/**
 * build_program_funcs_propagates_a_stackify_func_stop — a function whose
 * own body honest-stops propagates out of the whole per-function build.
 *
 * @return void
 */
fn build_program_funcs_propagates_a_stackify_func_stop() {
    let wasi = wasm_wasi_import_set()
    match wasm_build_program_funcs(wasi, [sft_i128_ret_func()], wasm_symtab_empty(), false) {
        []WasmFunc => teko::assert::is_true(false)
        error => { }
    }
}

#test
/**
 * find_main_index_locates_main_past_the_imports — `sft_main_func` is the
 * ONLY function, so it resolves to `wasi.imports.len` (right past every
 * host import).
 *
 * @return void
 */
fn find_main_index_locates_main_past_the_imports() {
    let wasi = wasm_wasi_import_set()
    let idx = match wasm_find_main_index(wasi, [sft_main_func()]) { u32 as x => x; error => return }
    teko::assert::is_true(idx == (wasi.imports.len to u32))
}

#test
/**
 * find_main_index_missing_main_is_a_named_internal_error — a function list
 * with no `"main"` symbol is the genuine internal-misuse guard (`emit_
 * native_wasm` never reaches this for a real binary artifact).
 *
 * @return void
 */
fn find_main_index_missing_main_is_a_named_internal_error() {
    let wasi = wasm_wasi_import_set()
    match wasm_find_main_index(wasi, [sft_empty_func()]) {
        u32 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "no `main` entry function found")
    }
}

#test
/**
 * synth_start_i32_main_forwards_the_result_to_proc_exit — an `i32`-returning
 * `main`: `call $main` (compact funcidx `7`) leaves the exit code on the
 * stack, then `call $proc_exit` (compact funcidx `0`) then `end`. The module
 * is self-contained (`backend-wasm.md` §1.2), so the funcidx operands are
 * minimal-width and no relocation is recorded.
 *
 * @return void
 */
fn synth_start_i32_main_forwards_the_result_to_proc_exit() {
    let f = match wasm_synth_start(9 to u32, 7 to u32, 0 to u32, lir::LType::I32) { WasmFunc as x => x; error => return }
    teko::assert::is_true(f.type_index == (9 to u32))
    let want = [
        0x10 to byte, 0x07 to byte,
        0x10 to byte, 0x00 to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(f.body, want))
}

#test
/**
 * synth_start_void_main_pushes_a_default_exit_code — a `Void`-returning
 * `main` leaves NOTHING on the stack, so `_start` pushes a literal `i32.
 * const 0` (`0x41 0x00`) between `call $main` and `call $proc_exit` — the
 * standard WASI "exit 0 on clean fall-through" `_start` shape that keeps
 * `proc_exit`'s `i32` argument balanced instead of underflowing the operand
 * stack (`backend-wasm.md` finding 4).
 *
 * @return void
 */
fn synth_start_void_main_pushes_a_default_exit_code() {
    let f = match wasm_synth_start(9 to u32, 7 to u32, 0 to u32, lir::LType::Void) { WasmFunc as x => x; error => return }
    let want = [
        0x10 to byte, 0x07 to byte,
        0x41 to byte, 0x00 to byte,
        0x10 to byte, 0x00 to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(f.body, want))
}

#test
/**
 * program_has_any_frame_true_when_some_func_has_an_alloca — a two-function
 * list, `main` first (no alloca) then `sft_alloca_func` — `true` overall.
 *
 * @return void
 */
fn program_has_any_frame_true_when_some_func_has_an_alloca() {
    teko::assert::is_true(wasm_program_has_any_frame([sft_main_func(), sft_alloca_func()]))
}

#test
/**
 * program_has_any_frame_false_with_no_alloca_anywhere — neither
 * `sft_main_func` nor `sft_empty_func` has an `LAlloca`.
 *
 * @return void
 */
fn program_has_any_frame_false_with_no_alloca_anywhere() {
    teko::assert::is_true(!wasm_program_has_any_frame([sft_main_func(), sft_empty_func()]))
}

#test
/**
 * program_has_ptr_load_true_when_some_func_loads_a_ptr — a two-function
 * list, `main` first (no `Ptr`-typed `LLoad`) then `sft_ptr_load_func` —
 * `true` overall (#389 C1-7 review finding #1, the checked-narrow-panic-
 * message reachability gate).
 *
 * @return void
 */
fn program_has_ptr_load_true_when_some_func_loads_a_ptr() {
    teko::assert::is_true(wasm_program_has_ptr_load([sft_main_func(), sft_ptr_load_func()]))
}

#test
/**
 * program_has_ptr_load_false_with_no_ptr_load_anywhere — neither `sft_main_
 * func` nor `sft_alloca_func` contains a `Ptr`-typed `LLoad` (an `LAlloca`
 * site is a `Ptr`-VALUED result, never a `Ptr`-typed LOAD, so `sft_alloca_
 * func` does not itself trip this scan).
 *
 * @return void
 */
fn program_has_ptr_load_false_with_no_ptr_load_anywhere() {
    teko::assert::is_true(!wasm_program_has_ptr_load([sft_main_func(), sft_alloca_func()]))
}

#test
/**
 * program_data_segments_omits_an_empty_rodata_layout — a rodata layout
 * with zero interned bytes yields NO data segment at all (not one framed
 * empty segment).
 *
 * @return void
 */
fn program_data_segments_omits_an_empty_rodata_layout() {
    let layout = wasm_layout_rodata(teko::list::empty(), 8 to u32)
    teko::assert::is_true(wasm_program_data_segments(layout).len == (0 to u64))
}

#test
/**
 * program_data_segments_keeps_a_nonempty_rodata_layout — a rodata layout
 * with at least one interned entry yields exactly one data segment.
 *
 * @return void
 */
fn program_data_segments_keeps_a_nonempty_rodata_layout() {
    let rodata = [lir::LRodata { symbol = "teko__rodata__0"; bytes = [0x68 to byte, 0x69 to byte] }]
    let layout = wasm_layout_rodata(rodata, 8 to u32)
    let segs = wasm_program_data_segments(layout)
    teko::assert::is_true(segs.len == (1 to u64))
    teko::assert::is_true(segs[0].offset == (8 to u32))
}

#test
/**
 * narrow_msg_segment_carries_the_reserved_message_at_its_own_fixed_addr —
 * `wasm_narrow_msg_segment`'s own offset/bytes match `wasm_narrow_msg_addr`/
 * `_bytes` exactly (#389 C1-7 review finding #1 — the segment the trap's
 * own `fd_write` needs actually present at the address `tk_panic_str`'s
 * call site hands it).
 *
 * @return void
 */
fn narrow_msg_segment_carries_the_reserved_message_at_its_own_fixed_addr() {
    let seg = wasm_narrow_msg_segment()
    teko::assert::is_true(seg.offset == wasm_narrow_msg_addr())
    teko::assert::is_true(wasm_bytes_eq(seg.bytes, wasm_narrow_msg_bytes()))
}

#test
/**
 * program_narrow_msg_segments_empty_on_wasm64 — the wasm64 gate: even a
 * program with a `Ptr`-typed `LLoad` gets NO narrow-message segment when
 * `ptr64` (the checked narrow is elided entirely on wasm64, §6).
 *
 * @return void
 */
fn program_narrow_msg_segments_empty_on_wasm64() {
    teko::assert::is_true(wasm_program_narrow_msg_segments([sft_ptr_load_func()], true).len == (0 to u64))
}

#test
/**
 * program_narrow_msg_segments_empty_with_no_ptr_load — a wasm32 program
 * with no `Ptr`-typed `LLoad` anywhere gets NO narrow-message segment (a
 * dead segment would otherwise sit at offset `16` unreachably).
 *
 * @return void
 */
fn program_narrow_msg_segments_empty_with_no_ptr_load() {
    teko::assert::is_true(wasm_program_narrow_msg_segments([sft_main_func()], false).len == (0 to u64))
}

#test
/**
 * program_narrow_msg_segments_present_when_reachable_on_wasm32 — a wasm32
 * program with a `Ptr`-typed `LLoad` gets EXACTLY the reserved message
 * segment, at `wasm_narrow_msg_addr`.
 *
 * @return void
 */
fn program_narrow_msg_segments_present_when_reachable_on_wasm32() {
    let segs = wasm_program_narrow_msg_segments([sft_ptr_load_func()], false)
    teko::assert::is_true(segs.len == (1 to u64))
    teko::assert::is_true(segs[0].offset == wasm_narrow_msg_addr())
    teko::assert::is_true(wasm_bytes_eq(segs[0].bytes, wasm_narrow_msg_bytes()))
}

#test
/**
 * program_memory_plan_with_no_frame_and_no_rodata_needs_no_globals — a
 * program with neither rodata nor an `LAlloca` anywhere gets NO globals and
 * the one-page floor.
 *
 * @return void
 */
fn program_memory_plan_with_no_frame_and_no_rodata_needs_no_globals() {
    let lmod = lir::LModule { funcs = [sft_main_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let rodata = wasm_layout_rodata(lmod.rodata, wasm_rodata_base())
    let plan = wasm_program_memory_plan(lmod, rodata)
    teko::assert::is_true(plan.globals.len == (0 to u64))
    teko::assert::is_true(plan.mem_min_pages == (1 to u32))
}

#test
/**
 * program_memory_plan_with_a_frame_adds_the_sp_global — a program with
 * SOME `LAlloca` gets exactly one `SP` global, initialized past the
 * (8-byte-aligned) rodata region's own end plus the fixed stack-region
 * size.
 *
 * @return void
 */
fn program_memory_plan_with_a_frame_adds_the_sp_global() {
    let lmod = lir::LModule { funcs = [sft_alloca_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let rodata = wasm_layout_rodata(lmod.rodata, wasm_rodata_base())
    let plan = wasm_program_memory_plan(lmod, rodata)
    teko::assert::is_true(plan.globals.len == (1 to u64))
    teko::assert::is_true(plan.globals[0].mutable)
    teko::assert::is_true(plan.globals[0].init == ((wasm_rodata_base() to i64) + (65536 to i64)))
    teko::assert::is_true(plan.mem_min_pages == (2 to u32))
}

#test
/**
 * assemble_program_own_exit_zero_shape_exports_start — the `own_exit_zero`
 * corpus fixture's own shape (`main` only, no rodata, no alloca): the
 * assembled module exports `"_start"` (the owner's own C1-5 invariant) at
 * the synthesized entry's own function index (past the two WASI imports,
 * the one defined `main`, and the five C1-6 io/panic trampolines
 * `wasm_assemble_program` always appends) PLUS `"memory"` (the C1-6
 * wasmtime-execution requirement, `wasm_memory_export`), its `funcs` list
 * is `[main, print, println, eprint, eprintln, panic_str, _start]` (seven
 * entries, the last closed by the code-entry `end`), and the type table
 * carries the WASI pair, one entry per defined function, the shared
 * io/panic type, and `_start`'s own.
 *
 * @return void
 */
fn assemble_program_own_exit_zero_shape_exports_start() {
    let lmod = lir::LModule { funcs = [sft_main_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, false) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.exports.len == (2 to u64))
    teko::assert::is_true(m.exports[0].name == "_start")
    teko::assert::is_true(m.exports[0].index == (8 to u32))
    teko::assert::is_true(m.exports[1].name == "memory")
    teko::assert::is_true(m.exports[1].index == (0 to u32))
    teko::assert::is_true(m.funcs.len == (7 to u64))
    let start = m.funcs[6]
    teko::assert::is_true(start.body.len > (0 to u64))
    teko::assert::is_true(start.body[start.body.len - 1] == (0x0B to byte))
    teko::assert::is_true(m.types.len == (5 to u64))
    teko::assert::is_true(m.imports.len == (2 to u64))
    teko::assert::is_true(!m.mem_is64)
}

#test
/**
 * assemble_program_wasm64_omits_the_io_panic_trampolines — the SAME
 * `own_exit_zero` shape, assembled for wasm64 (#389 C1-7, `backend-wasm.md`
 * §6): `mem_is64` is `true`, and the `fd_write`-based io/panic trampolines
 * (WASI preview1's own `i32`-address-only ABI, a genuine ecosystem wall
 * against `memory64`) are OMITTED — `funcs` is `[main, _start]` (two
 * entries, not seven), `types` carries the WASI pair + `main`'s own +
 * `_start`'s own (four, not five — no shared io type), and `_start`'s own
 * funcidx lands immediately after `main` (no io funcs in between). The
 * import set itself (`proc_exit`+`fd_write`) is unchanged — an unused
 * `fd_write` import is harmless; only its CALLING trampoline bodies would
 * have mismatched the `memory64` address width.
 *
 * @return void
 */
fn assemble_program_wasm64_omits_the_io_panic_trampolines() {
    let lmod = lir::LModule { funcs = [sft_main_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, true) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.mem_is64)
    teko::assert::is_true(m.funcs.len == (2 to u64))
    teko::assert::is_true(m.types.len == (4 to u64))
    teko::assert::is_true(m.imports.len == (2 to u64))
    teko::assert::is_true(m.exports[0].name == "_start")
    teko::assert::is_true(m.exports[0].index == (3 to u32))
}

#test
/**
 * assemble_program_wasm64_rejects_a_frame_bearing_program — the wasm64
 * scope guard (#389 C1-7): a function with an `LAlloca` (`wasm_program_
 * has_any_frame`) names the `C1-wasm64-scope` honest-stop when `ptr64` —
 * the shadow-stack `$sp`/`LFieldAddr`/`LAlloca` sites still compute in
 * `i32` unconditionally, so a `memory64` module built from this program
 * would be invalid; fail loud instead (M.3).
 *
 * @return void
 */
fn assemble_program_wasm64_rejects_a_frame_bearing_program() {
    let lmod = lir::LModule { funcs = [sft_alloca_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match wasm_assemble_program(lmod, true) {
        WasmModule => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-wasm64-scope")
    }
}

#test
/**
 * assemble_program_wasm64_rejects_a_rodata_bearing_program — the SAME
 * wasm64 scope guard, triggered by non-empty `LModule.rodata` (`LGlobalAddr`
 * still computes in `i32`).
 *
 * @return void
 */
fn assemble_program_wasm64_rejects_a_rodata_bearing_program() {
    let rodata = [lir::LRodata { symbol = "teko__rodata__0"; bytes = [0x68 to byte, 0x69 to byte] }]
    let lmod = lir::LModule { funcs = [sft_main_func()]; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    match wasm_assemble_program(lmod, true) {
        WasmModule => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-wasm64-scope")
    }
}

#test
/**
 * assemble_program_wasm64_rejects_a_ptr_signature — the SAME wasm64 scope
 * guard, triggered by a function whose own signature names `Ptr`
 * (`wasm_program_uses_ptr` — `sft_rodata_func`'s `Ptr`-returning `main`).
 *
 * @return void
 */
fn assemble_program_wasm64_rejects_a_ptr_signature() {
    let lmod = lir::LModule { funcs = [sft_rodata_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match wasm_assemble_program(lmod, true) {
        WasmModule => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-wasm64-scope")
    }
}

/**
 * sft_rodata_func — a `Ptr`-returning `"main"` `LFunc` that resolves ONE
 * rodata symbol (`LGlobalAddr`) — the ordering regression this fixture
 * guards: `wasm_assemble_program` must lay out + register rodata BEFORE
 * stackifying ANY function, or this `LGlobalAddr` site fails to resolve.
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_rodata_func() -> lir::LFunc {
    let insts = [lir::global_addr_inst(0, "teko__rodata__0", 0, 0), lir::ret_inst(0, 0, 0)]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "main"; n_params = 0 to u32; param_types = teko::list::empty(); ret_type = lir::LType::Ptr; blocks = [block]; next_vreg = 1 to u32 }
}

#test
/**
 * assemble_program_resolves_rodata_symbols_before_stackifying — a program
 * whose only function reads a rodata symbol (`LGlobalAddr`) assembles
 * cleanly, AND the module's own data section places it at `wasm_rodata_
 * base` — proving `wasm_assemble_program` lays rodata out (and registers
 * it into the symbol table) BEFORE stackifying `main`, not after.
 *
 * @return void
 */
fn assemble_program_resolves_rodata_symbols_before_stackifying() {
    let rodata = [lir::LRodata { symbol = "teko__rodata__0"; bytes = [0x68 to byte, 0x69 to byte] }]
    let lmod = lir::LModule { funcs = [sft_rodata_func()]; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, false) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.data.len == (1 to u64))
    teko::assert::is_true(m.data[0].offset == wasm_rodata_base())
}

#test
/**
 * assemble_program_wasm32_emits_the_narrow_msg_segment_when_reachable — a
 * wasm32 program with a `Ptr`-typed `LLoad` (`sft_ptr_load_func`, alongside
 * `sft_main_func`'s own `main`) gets the reserved narrow-message segment in
 * its own data section, at `wasm_narrow_msg_addr` (#389 C1-7 review finding
 * #1 — before this fix `m.data` never carried it at all, so a trap through
 * `tk_panic_str` printed 42 NUL bytes instead of the structured message).
 *
 * @return void
 */
fn assemble_program_wasm32_emits_the_narrow_msg_segment_when_reachable() {
    let lmod = lir::LModule { funcs = [sft_main_func(), sft_ptr_load_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, false) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.data.len == (1 to u64))
    teko::assert::is_true(m.data[0].offset == wasm_narrow_msg_addr())
    teko::assert::is_true(wasm_bytes_eq(m.data[0].bytes, wasm_narrow_msg_bytes()))
}

#test
/**
 * assemble_program_wasm32_orders_the_narrow_msg_segment_before_rodata — a
 * program that BOTH loads a `Ptr` value AND interns rodata gets TWO data
 * segments: the reserved narrow-message segment first (offset `wasm_
 * narrow_msg_addr`), the program's own rodata second (offset `wasm_rodata_
 * base`) — the append order `wasm_assemble_program`'s own `data` field
 * builds (#389 C1-7 review finding #1).
 *
 * @return void
 */
fn assemble_program_wasm32_orders_the_narrow_msg_segment_before_rodata() {
    let rodata = [lir::LRodata { symbol = "teko__rodata__0"; bytes = [0x68 to byte, 0x69 to byte] }]
    let lmod = lir::LModule { funcs = [sft_main_func(), sft_ptr_load_func()]; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, false) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.data.len == (2 to u64))
    teko::assert::is_true(m.data[0].offset == wasm_narrow_msg_addr())
    teko::assert::is_true(m.data[1].offset == wasm_rodata_base())
}

#test
/**
 * assemble_program_rejects_top_level_globals — `LModule.globals` non-empty
 * is the NAMED `C1-globals` honest-stop (mirrors A4-4), checked BEFORE any
 * function is even stackified.
 *
 * @return void
 */
fn assemble_program_rejects_top_level_globals() {
    let lmod = lir::LModule { funcs = [sft_main_func()]; rodata = teko::list::empty(); globals = [lir::LGlobal { symbol = "teko__g__x"; ty = lir::LType::I32; bytes = teko::list::empty() }]; layouts = teko::list::empty() }
    match wasm_assemble_program(lmod, false) {
        WasmModule => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-globals")
    }
}

#test
/**
 * assemble_program_propagates_a_func_type_stop — a program whose only
 * function's own signature honest-stops (`C1-i128`) propagates out of the
 * whole assembly, before `wasm_find_main_index` is even reached.
 *
 * @return void
 */
fn assemble_program_propagates_a_func_type_stop() {
    let lmod = lir::LModule { funcs = [sft_i128_ret_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match wasm_assemble_program(lmod, false) {
        WasmModule => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

#test
/**
 * assemble_program_with_no_main_is_a_named_internal_error — a program with
 * no `"main"` symbol (but an otherwise WELL-FORMED function — `sft_alloca_
 * func`, unlike `sft_empty_func`'s own terminator-less throwaway block,
 * which fails stackification itself before `wasm_find_main_index` is even
 * reached) propagates `wasm_find_main_index`'s own NAMED internal error.
 *
 * @return void
 */
fn assemble_program_with_no_main_is_a_named_internal_error() {
    let lmod = lir::LModule { funcs = [sft_alloca_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match wasm_assemble_program(lmod, false) {
        WasmModule => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "no `main` entry function found")
    }
}

/* ==========================================================================
 * C1-5 — the value-stack peephole: `elide_candidate_kind`'s own per-
 * condition coverage (single-use/same-block -> Drop, multi-use -> Normal,
 * cross-block -> Normal, edge-only -> Normal, block-param -> Normal,
 * dead -> Normal, computational+edge -> Tee), the LIFO/barrier simulation's
 * own unit tests, and end-to-end golden fixtures (§5, `backend-wasm.md`).
 * ========================================================================== */

#test
/**
 * elide_candidate_kind_drop_on_single_same_block_computational_use — the
 * baseline positive case: exactly one use, computational, same block.
 *
 * @return void
 */
fn elide_candidate_kind_drop_on_single_same_block_computational_use() {
    let info = uit_record_use(uit_empty(), 0, 0, false)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Drop)
}

#test
/**
 * elide_candidate_kind_normal_on_multi_use — three same-block computational
 * uses stay Normal (beyond the `Drop`/`Tee` shape entirely).
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_multi_use() {
    let t1 = uit_record_use(uit_empty(), 0, 0, false)
    let t2 = uit_record_use(t1, 0, 0, false)
    let info = uit_record_use(t2, 0, 0, false)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Normal)
}

#test
/**
 * elide_candidate_kind_normal_on_cross_block_use — a single use in a
 * DIFFERENT block than the def stays Normal (§5's own SAME-BLOCK
 * condition).
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_cross_block_use() {
    let info = uit_record_use(uit_empty(), 0, 7 to u32, false)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Normal)
}

#test
/**
 * elide_candidate_kind_normal_on_edge_only_single_use — a single use that
 * is a cross-block edge-copy argument (not computational) stays Normal
 * (§5's own FORCED-LOCAL "block-args" rule).
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_edge_only_single_use() {
    let info = uit_record_use(uit_empty(), 0, 0, true)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Normal)
}

#test
/**
 * elide_candidate_kind_tee_on_computational_plus_edge_same_block — exactly
 * two uses, one computational + one edge-copy argument, BOTH in the def's
 * own block: the "must ALSO persist to a local" `Tee` case.
 *
 * @return void
 */
fn elide_candidate_kind_tee_on_computational_plus_edge_same_block() {
    let t1 = uit_record_use(uit_empty(), 0, 0, false)
    let info = uit_record_use(t1, 0, 0, true)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Tee)
}

#test
/**
 * elide_candidate_kind_normal_on_two_computational_uses — two uses that are
 * BOTH computational (neither is an edge argument) do not fit the `Tee`
 * shape — stays Normal.
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_two_computational_uses() {
    let t1 = uit_record_use(uit_empty(), 0, 0, false)
    let info = uit_record_use(t1, 0, 0, false)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Normal)
}

#test
/**
 * elide_candidate_kind_normal_on_block_param_regardless_of_use_count — a
 * block-param is FORCED-LOCAL even with exactly one same-block
 * computational use (§5).
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_block_param_regardless_of_use_count() {
    let t1 = uit_record_use(uit_empty(), 0, 0, false)
    let info = uit_mark_param(t1, 0)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Normal)
}

#test
/**
 * elide_candidate_kind_normal_on_a_dead_value — a VReg never used at all
 * (count `0`) is the default Normal arm (harmless — its own `local.set` is
 * simply never read).
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_a_dead_value() {
    teko::assert::is_true(elide_candidate_kind(uit_empty(), 0, 0) == ElideKind::Normal)
}

#test
/**
 * resolve_inst_operands_non_lifo_order_cancels_the_whole_pending_stack — a
 * two-operand instruction whose OWN operand order does not match its
 * operands' own production order (§5 condition 3, LIFO): `pending = [older,
 * newer]` but the instruction wants to read `[newer, older]` — the very
 * FIRST (reverse-order) check already mismatches, so NEITHER value may ride
 * the stack; both are cancelled in one shot rather than an unsound "dig
 * through the top and retry" shape (which would wrongly let a value ride
 * into the WRONG operand position).
 *
 * @return void
 */
fn resolve_inst_operands_non_lifo_order_cancels_the_whole_pending_stack() {
    let table0 = et_set(et_set(et_empty(), 10 to u32, ElideKind::Drop), 11 to u32, ElideKind::Drop)
    let pending = teko::list::push(teko::list::push(teko::list::empty(), PendingItem { vreg = 10 to u32; is_load = false }), PendingItem { vreg = 11 to u32; is_load = false })
    let result = resolve_inst_operands(pending, table0, [10 to u32, 11 to u32])
    teko::assert::is_true(result.pending.len == 0)
    teko::assert::is_true(et_get(result.table, 10 to u32) == ElideKind::Normal)
    teko::assert::is_true(et_get(result.table, 11 to u32) == ElideKind::Normal)
}

#test
/**
 * resolve_inst_operands_matching_lifo_order_survives_untouched — the SOUND
 * counterpart: `pending = [older, newer]`, the instruction's own
 * reverse-push-order reads are `[newer, older]` (its LAST-pushed operand
 * checked first) — both match, in order, and neither entry is cancelled.
 *
 * @return void
 */
fn resolve_inst_operands_matching_lifo_order_survives_untouched() {
    let table0 = et_set(et_set(et_empty(), 10 to u32, ElideKind::Drop), 11 to u32, ElideKind::Drop)
    let pending = teko::list::push(teko::list::push(teko::list::empty(), PendingItem { vreg = 10 to u32; is_load = false }), PendingItem { vreg = 11 to u32; is_load = false })
    let result = resolve_inst_operands(pending, table0, [11 to u32, 10 to u32])
    teko::assert::is_true(result.pending.len == 0)
    teko::assert::is_true(et_get(result.table, 10 to u32) == ElideKind::Drop)
    teko::assert::is_true(et_get(result.table, 11 to u32) == ElideKind::Drop)
}

#test
/**
 * cancel_pending_loads_forces_a_load_off_the_stack_across_a_barrier — the
 * §5 condition-4 hazard: a pending `LLoad` result is downgraded to Normal
 * at a barrier; a pending NON-load survives it untouched (`inst_is_load`'s
 * own doc — only a load result is hazarded by a call/store).
 *
 * @return void
 */
fn cancel_pending_loads_forces_a_load_off_the_stack_across_a_barrier() {
    let table0 = et_set(et_set(et_empty(), 20 to u32, ElideKind::Drop), 21 to u32, ElideKind::Drop)
    let pending = teko::list::push(teko::list::push(teko::list::empty(), PendingItem { vreg = 20 to u32; is_load = true }), PendingItem { vreg = 21 to u32; is_load = false })
    let flushed = cancel_pending_loads(pending, table0)
    teko::assert::is_true(flushed.pending.len == 1)
    teko::assert::is_true(flushed.pending[0].vreg == (21 to u32))
    teko::assert::is_true(et_get(flushed.table, 20 to u32) == ElideKind::Normal)
    teko::assert::is_true(et_get(flushed.table, 21 to u32) == ElideKind::Drop)
}

#test
/**
 * stackify_func_load_across_a_call_stays_in_a_local — the barrier golden
 * (§5 condition 4): `v = load(addr); call tk_nop(); return v` — `v`'s one
 * use (the `ret`) is same-block and would otherwise be single-use-eligible,
 * but the intervening `call` forces it off the stack; `addr` (the load's
 * OWN single-use, same-block operand, defined immediately before it with no
 * barrier in between) still elides normally.
 *
 * @return void
 */
fn stackify_func_load_across_a_call_stays_in_a_local() {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I32)
    mut f = lir::new_func("teko__test__load_barrier", 1, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let v = lir::alloc_vreg(f)
    f = lir::append_inst(v.func, 0, lir::load_inst(v.vreg, 0, lir::LType::I32, 0, 0))
    f = lir::append_inst(f, 0, lir::void_call_inst("tk_nop", teko::list::empty(), false, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_inst(v.vreg, 0, 0))
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "tk_nop", sft_void_target())
    let out = match stackify_func(f, symbols, false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte,
        0x28 to byte, 0x02 to byte, 0x00 to byte,
        0x21 to byte, 0x01 to byte,
        0x10 to byte, 0x03 to byte,
        0x20 to byte, 0x01 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * stackify_func_tee_persists_a_value_also_fed_across_an_edge — the `Tee`
 * golden (§5): a branch's own `cond` is ALSO the very block-arg it feeds
 * into its `then` target — exactly two uses, one computational (the `cond`
 * read, fused straight off the stack into the `if`) and one edge-copy
 * argument, both in block 0. `local.tee` writes the local (for the edge
 * copy to read back out) WHILE ALSO leaving the value on the stack for the
 * branch's own `if`.
 *
 * @return void
 */
fn stackify_func_tee_persists_a_value_also_fed_across_an_edge() {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I32)
    mut f = lir::new_func("teko__test__tee_persist", 1, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let thenb = lir::alloc_block(f)
    let tp = lir::add_block_param(thenb.func, thenb.block_id)
    let elseb = lir::alloc_block(tp.func)
    let then_args = teko::list::push(teko::list::empty(), 0 to u32)
    f = lir::append_inst(elseb.func, 0, lir::branch_inst(0, thenb.block_id, then_args, elseb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, thenb.block_id, lir::ret_inst(tp.vreg, 0, 0))
    let r5 = lir::alloc_vreg(f)
    f = lir::append_inst(r5.func, elseb.block_id, lir::const_int_inst(r5.vreg, 5 to i128, 0, 0))
    f = lir::append_inst(f, elseb.block_id, lir::ret_inst(r5.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x22 to byte, 0x00 to byte,
        0x04 to byte, 0x40 to byte,
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte,
        0x20 to byte, 0x01 to byte, 0x0F to byte,
        0x05 to byte,
        0x41 to byte, 0x05 to byte,
        0x0F to byte,
        0x0B to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * wasm_synth_start_rejects_a_non_i32_non_void_main_ret — the defensive
 * NAMED `C1-main-ret` honest-stop (a riders fix, `#389` C1-5 dispatch
 * re-review): `wasm_synth_start` only knows the virtual-main ABI's own
 * `I32`/`Void` return shapes; anything else would feed `proc_exit` a
 * type-mismatched operand rather than silently miscompiling.
 *
 * @return void
 */
fn wasm_synth_start_rejects_a_non_i32_non_void_main_ret() {
    match wasm_synth_start(0 to u32, 0 to u32, 0 to u32, lir::LType::I64) {
        WasmFunc => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-main-ret")
    }
}

/* ==========================================================================
 * C1-5 — the adversarial-review fix (PR #546): `resolve_inst_operands`'s
 * own PARTIAL-match branch (a real, reproduced miscompile — a pop-as-you-go
 * scan that only cancelled what was STILL pending on a mismatch left
 * ALREADY-POPPED top matches wrongly riding the stack, inverting a
 * non-commutative op's operand order) is now ALL-OR-NOTHING, and
 * `sc_use_operands` mirrors the same rule on the emission side.
 * ========================================================================== */

#test
/**
 * resolve_inst_operands_partial_match_cancels_the_whole_pending_stack — the
 * exact shape the adversarial review reproduced end-to-end: `pending =
 * [c]` (one entry, tentatively `Drop`), an instruction whose own reversed
 * reads are `[c, bp]` — the LAST-pushed operand (`c`) matches `pending`'s
 * top, but the operand BEFORE it (`bp`) is not pending at all (it is
 * `Normal`, multi-use). The old "pop the matches, cancel only what's left"
 * shape left `c` wrongly `Drop` (already popped, so never revisited by the
 * cancellation step) — the fix cancels `c` too, over the ORIGINAL pending,
 * because a PARTIAL ride is exactly as unsound as a total mismatch.
 *
 * @return void
 */
fn resolve_inst_operands_partial_match_cancels_the_whole_pending_stack() {
    let table0 = et_set(et_empty(), 10 to u32, ElideKind::Drop)
    let pending = teko::list::push(teko::list::empty(), PendingItem { vreg = 10 to u32; is_load = false })
    let result = resolve_inst_operands(pending, table0, [10 to u32, 99 to u32])
    teko::assert::is_true(result.pending.len == 0)
    teko::assert::is_true(et_get(result.table, 10 to u32) == ElideKind::Normal)
}

/**
 * sft_bp_via_block_param — a 2-block, 1-param `LFunc` whose param reaches a
 * SECOND block purely as that block's own incoming block-arg (`bp`) — a
 * block-param is FORCED-LOCAL regardless of use count (§5), so `bp` is
 * `Normal` with NO extra "give it a second use" fixture noise. `op(bp,
 * const)` (built by the caller) is the fixture's own operand pair: `bp`
 * (`Normal`, never pending) paired with a FRESH single-use constant (a
 * `Drop` CANDIDATE the fix must downgrade back to `Normal`, since `bp`
 * itself can never ride).
 *
 * @param lir::LBinOp op  the binary op `bp op const_val` computes
 * @param i128 const_val  the second operand's own constant value
 * @return lir::LFunc  the seeded function (its own `ret`'s value is the
 *                      op's own result)
 */
fn sft_bp_via_block_param(op: lir::LBinOp, const_val: i128) -> lir::LFunc {
    mut f = lir::new_func("teko__test__bp_op_const", 1, [lir::LType::I32], lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let b1 = lir::alloc_block(f)
    let bp = lir::add_block_param(b1.func, b1.block_id)
    let entry_args = teko::list::push(teko::list::empty(), 0 to u32)
    f = lir::append_inst(bp.func, 0, lir::jump_inst(b1.block_id, entry_args, 0, 0))
    let c = lir::alloc_vreg(f)
    f = lir::append_inst(c.func, b1.block_id, lir::const_int_inst(c.vreg, const_val, 0, 0))
    let r = lir::alloc_vreg(f)
    f = lir::append_inst(r.func, b1.block_id, lir::bin_inst(r.vreg, op, bp.vreg, c.vreg, 0, 0))
    lir::append_inst(f, b1.block_id, lir::ret_inst(r.vreg, 0, 0))
}

#test
/**
 * stackify_func_non_commutative_sub_keeps_the_correct_operand_order — the
 * adversarial review's own repro, end to end: `bp - 7`. Before the fix this
 * emitted `i32.const 7; local.get bp; i32.sub` (`7 - bp`, WRONG); the fix
 * forces BOTH operands off the stack (`bp` was never eligible; `7`'s
 * partial ride is now correctly cancelled too), so the ALL-LOCALS order is
 * preserved: `local.get bp; i32.const 7; i32.sub` (`bp - 7`, CORRECT).
 *
 * @return void
 */
fn stackify_func_non_commutative_sub_keeps_the_correct_operand_order() {
    let f = sft_bp_via_block_param(lir::LBinOp::ISub, 7 to i128)
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte,
        0x41 to byte, 0x07 to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x01 to byte, 0x20 to byte, 0x02 to byte, 0x6B to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * stackify_func_non_commutative_compare_keeps_the_correct_operand_order —
 * the comparison-family repro: `bp < 7` (`ICmpLtS`). Every comparison is
 * non-commutative the SAME way `ISub` is; the fix's own all-or-nothing rule
 * applies identically: `local.get bp; i32.const 7; i32.lt_s`.
 *
 * @return void
 */
fn stackify_func_non_commutative_compare_keeps_the_correct_operand_order() {
    let f = sft_bp_via_block_param(lir::LBinOp::ICmpLtS, 7 to i128)
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte,
        0x41 to byte, 0x07 to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x01 to byte, 0x20 to byte, 0x02 to byte, 0x48 to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * stackify_func_store_with_normal_addr_and_a_would_be_drop_value — an
 * `LStore` golden: `addr` is a block-param (`Normal`, never pending) and
 * `value` is a single-use constant that would (buggily) partially ride the
 * stack alone. The fix forces `value` back to a local too — `local.get
 * addr; local.get value; i32.store` — never `i32.const N` left riding into
 * a store whose OWN address operand comes from a DIFFERENT, unrelated
 * local.get, which would silently store the WRONG value at the WRONG
 * moment relative to the address.
 *
 * @return void
 */
fn stackify_func_store_with_normal_addr_and_a_would_be_drop_value() {
    mut f = lir::new_func("teko__test__store_normal_addr", 1, [lir::LType::I32], lir::LType::Void)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let b1 = lir::alloc_block(f)
    let addr = lir::add_block_param(b1.func, b1.block_id)
    let entry_args = teko::list::push(teko::list::empty(), 0 to u32)
    f = lir::append_inst(addr.func, 0, lir::jump_inst(b1.block_id, entry_args, 0, 0))
    let cval = lir::alloc_vreg(f)
    f = lir::append_inst(cval.func, b1.block_id, lir::const_int_inst(cval.vreg, 42 to i128, 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::store_inst(addr.vreg, cval.vreg, lir::LType::I32, 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte,
        0x41 to byte, 0x2A to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x01 to byte, 0x20 to byte, 0x02 to byte,
        0x36 to byte, 0x02 to byte, 0x00 to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * wasm_synth_io_write_print_no_newline_golden — `wasm_synth_io_write(fd=1,
 * newline=false, …)` (C1-6, the `tk_print`/`tk_write` trampoline body): store
 * `(ptr, len)` into the scratch iovec, ONE `fd_write(1, …)` call + `drop`, no
 * newline tail.
