#test
/**
 * wasm_synth_panic_str_golden — `wasm_synth_panic_str` (§8, C1-6): the same
 * `(ptr, len)`-store prefix, ONE `fd_write(2, …)` (stderr) call + `drop`
 * (§8 step 1 — the host OBSERVES the structured message), then `unreachable`
 * (`0x00`, §8 step 2 — TRAP, never recover) instead of a normal fall-through
 * `end`.
 *
 * @return void
 */
fn wasm_synth_panic_str_golden() {
    let f = wasm_synth_panic_str(5 to u32, 1 to u32)
    teko::assert::is_true(f.type_index == (5 to u32))
    let want = [
        0x41 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x36 to byte, 0x02 to byte, 0x00 to byte,
        0x41 to byte, 0x04 to byte, 0x20 to byte, 0x01 to byte, 0x36 to byte, 0x02 to byte, 0x00 to byte,
        0x41 to byte, 0x02 to byte, 0x41 to byte, 0x00 to byte, 0x41 to byte, 0x01 to byte, 0x41 to byte, 0x08 to byte,
        0x10 to byte, 0x01 to byte, 0x1A to byte,
        0x00 to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(f.body, want))
}

#test
/**
 * wasm_synth_io_panic_funcs_builds_five_funcs_sharing_one_type — the fixed
 * `print, println, eprint, eprintln, panic_str` order (C1-6), every entry
 * sharing the ONE `(i32, i32) -> ()` type index passed in.
 *
 * @return void
 */
fn wasm_synth_io_panic_funcs_builds_five_funcs_sharing_one_type() {
    let out = wasm_synth_io_panic_funcs(5 to u32, 1 to u32)
    teko::assert::is_true(out.funcs.len == (5 to u64))
    teko::assert::is_true(out.funcs[0].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[1].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[2].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[3].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[4].type_index == (5 to u32))
    teko::assert::is_true(println_body_carries_the_newline_tail_print_does_not(out))
    teko::assert::is_true(panic_body_ends_in_unreachable_not_a_bare_end(out))
}

/**
 * println_body_carries_the_newline_tail_print_does_not — `println`'s body
 * (position `1`) is strictly longer than `print`'s (position `0`) — the
 * ONLY structural difference `wasm_synth_io_write`'s `newline` flag makes
 * (the trailing-newline tail, `wasm_io_write_newline`).
 *
 * @param WasmIoPanicFuncs out  the five synthesized trampolines
 * @return bool  true iff `println`'s body is longer than `print`'s
 */
fn println_body_carries_the_newline_tail_print_does_not(out: WasmIoPanicFuncs) -> bool {
    out.funcs[1].body.len > out.funcs[0].body.len
}

/**
 * panic_body_ends_in_unreachable_not_a_bare_end — `panic_str`'s body
 * (position `4`) ends in `unreachable end` (`0x00 0x0B`), not a bare `end`
 * (§8's observe-then-trap shape, never a normal fall-through).
 *
 * @param WasmIoPanicFuncs out  the five synthesized trampolines
 * @return bool  true iff the second-to-last body byte is `unreachable`
 */
fn panic_body_ends_in_unreachable_not_a_bare_end(out: WasmIoPanicFuncs) -> bool {
    let panic_body = out.funcs[4].body
    panic_body[panic_body.len - (2 to u64)] == (0x00 to byte)
}

#test
/**
 * wasm_register_io_symbols_resolves_the_seven_runtime_symbols — `tk_print`/
 * `tk_write` and `tk_eprint`/`tk_ewrite` share a funcidx pair
 * (`teko_rt.c:1300-1303`'s own identical bodies); `tk_println`/`tk_eprintln`
 * get their own; `tk_panic_str` closes the set at `base+4` — every one
 * `Void`-returning (C1-6, §8).
 *
 * @return void
 */
fn wasm_register_io_symbols_resolves_the_seven_runtime_symbols() {
    let t = wasm_register_io_symbols(wasm_symtab_empty(), 10 to u32)
    let print_t = match wasm_resolve_call(t, "tk_print") { WasmCallTarget as x => x; error => return }
    let write_t = match wasm_resolve_call(t, "tk_write") { WasmCallTarget as x => x; error => return }
    let println_t = match wasm_resolve_call(t, "tk_println") { WasmCallTarget as x => x; error => return }
    let eprint_t = match wasm_resolve_call(t, "tk_eprint") { WasmCallTarget as x => x; error => return }
    let ewrite_t = match wasm_resolve_call(t, "tk_ewrite") { WasmCallTarget as x => x; error => return }
    let eprintln_t = match wasm_resolve_call(t, "tk_eprintln") { WasmCallTarget as x => x; error => return }
    let panic_t = match wasm_resolve_call(t, "tk_panic_str") { WasmCallTarget as x => x; error => return }
    teko::assert::is_true(print_t.func_index == (10 to u32))
    teko::assert::is_true(write_t.func_index == (10 to u32))
    teko::assert::is_true(println_t.func_index == (11 to u32))
    teko::assert::is_true(eprint_t.func_index == (12 to u32))
    teko::assert::is_true(ewrite_t.func_index == (12 to u32))
    teko::assert::is_true(eprintln_t.func_index == (13 to u32))
    teko::assert::is_true(panic_t.func_index == (14 to u32))
    teko::assert::is_true(print_t.ret_type == lir::LType::Void)
}

#test
/**
 * wasm_register_io_symbols_leaves_an_unregistered_symbol_unresolved — the
 * table only ever grows by exactly the seven io/panic entries; any other
 * symbol still honest-stops (`wasm_resolve_call`'s own "the caller must
 * register it" NAMED error).
 *
 * @return void
 */
fn wasm_register_io_symbols_leaves_an_unregistered_symbol_unresolved() {
    let t = wasm_register_io_symbols(wasm_symtab_empty(), 10 to u32)
    match wasm_resolve_call(t, "tk_str_concat") {
        WasmCallTarget => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "unresolved call symbol")
    }
}

#test
/**
 * append_wasm_funcs_concatenates_in_order — `[]WasmFunc` has no built-in
 * concat (mirrors `encode_arm64.tks`'s `append_bytes` over a different
 * element type, C1-6): `append_wasm_funcs` appends every `src` entry after
 * `funcs`, in order.
 *
 * @return void
 */
fn append_wasm_funcs_concatenates_in_order() {
    let a = WasmFunc { type_index = 1 to u32; local_groups = teko::list::empty(); body = teko::list::empty() }
    let b = WasmFunc { type_index = 2 to u32; local_groups = teko::list::empty(); body = teko::list::empty() }
    let c = WasmFunc { type_index = 3 to u32; local_groups = teko::list::empty(); body = teko::list::empty() }
    let out = append_wasm_funcs([a], [b, c])
    teko::assert::is_true(out.len == (3 to u64))
    teko::assert::is_true(out[0].type_index == (1 to u32))
    teko::assert::is_true(out[1].type_index == (2 to u32))
    teko::assert::is_true(out[2].type_index == (3 to u32))
}

#test
/**
 * wasm_io_base_index_follows_the_program_funcs — the first io/panic
 * trampoline's own funcidx sits right after every `LModule.funcs` entry, in
 * the shared import-then-defined index space (C1-6).
 *
 * @return void
 */
fn wasm_io_base_index_follows_the_program_funcs() {
    let wasi = wasm_wasi_import_set()
    let lmod = lir::add_func(lir::add_func(lir::empty_module(), sft_main_func()), sft_empty_func())
    teko::assert::is_true(wasm_io_base_index(wasi, lmod) == (4 to u32))
}
