use teko::lir

/**
 * sft_ctx0 — a fresh `StackifyCtx` with an empty body, no VRegs recorded,
 * and no shadow-stack frame (the fixture every lowering-function test
 * starts from).
 *
 * @return StackifyCtx  the empty context
 */
fn sft_ctx0() -> StackifyCtx {
    StackifyCtx { body = teko::list::empty(); vtypes = wvt_empty(); scopes = teko::list::empty(); next_scratch = 0 to u32; has_frame = false; frame_base = 0 to u32; slots = wst_empty(); elide = et_empty(); pending = teko::list::empty() }
}

/**
 * sft_vt_ok — unwrap a `wasm_valtype`/similar `u8 | error` result, defaulting
 * to `0` (a valtype byte no real case produces) on the error arm so an
 * unexpected honest-stop fails the caller's equality assertion instead of
 * the test silently passing.
 *
 * @param u8 | error r  the result to unwrap
 * @return u8  the wrapped valtype, or `0` on error
 */
fn sft_vt_ok(r: u8 | error) -> u8 {
    match r {
        u8 as v => v
        error => 0 to u8
    }
}

/**
 * sft_mem_ok — unwrap a `wasm_mem_op` result, defaulting every field to `0`
 * on the error arm (mirrors `sft_vt_ok`'s fail-by-mismatch design).
 *
 * @param WasmMemOp | error r  the result to unwrap
 * @return WasmMemOp  the wrapped memory-op shape, or an all-zero placeholder
 */
fn sft_mem_ok(r: WasmMemOp | error) -> WasmMemOp {
    match r {
        WasmMemOp as m => m
        error => WasmMemOp { load_op = 0 to byte; store_op = 0 to byte; align = 0 to u32; valtype = 0 to u8 }
    }
}

/**
 * sft_i128_beyond_i64 — `2^64` as an i128, built from arithmetic (never a
 * single huge literal — the same parser-range workaround
 * `isel_arm64_test.tkt`'s `iat_i128` family avoids), the smallest value that
 * overflows `fits_i64` and so triggers the `C1-i128` constant honest-stop.
 *
 * @return i128  `2^64`
 */
fn sft_i128_beyond_i64() -> i128 {
    let half = 4294967296 to i128
    half * half
}

#test
/**
 * sft_vt_ok_and_sft_mem_ok_default_on_error — the two unwrap helpers' own
 * error arm, exercised directly rather than left as dead fixture code.
 *
 * @return void
 */
fn sft_vt_ok_and_sft_mem_ok_default_on_error() {
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I128, false)) == (0 to u8))
    let m = sft_mem_ok(wasm_mem_op(lir::LType::I128))
    teko::assert::is_true(m.load_op == (0 to byte) && m.store_op == (0 to byte) && m.align == (0 to u32) && m.valtype == (0 to u8))
}

#test
/**
 * wasm_valtype_maps_every_narrow_int_and_ptr_to_i32_on_wasm32 — `I8`/`I16`/
 * `I32`/`Ptr` (`ptr64 = false`, the default) all collapse to the wasm `i32`
 * valtype (`backend-c1-wasm.md` §1.1).
 *
 * @return void
 */
fn wasm_valtype_maps_every_narrow_int_and_ptr_to_i32_on_wasm32() {
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I8, false)) == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I16, false)) == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I32, false)) == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::Ptr, false)) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * wasm_valtype_ptr_follows_the_ptr64_switch — the wasm64 switch (#389 C1-7,
 * `backend-wasm.md` §6): `Ptr` maps to `i32` when `ptr64 = false` (wasm32,
 * re-asserted here) and `i64` when `ptr64 = true` (wasm64 — the uniform
 * 64-bit `ptr<>` model needs no narrowing). Every OTHER machine class is
 * `ptr64`-independent (I8/I16/I32/I64/F32/F64 never move between calls).
 *
 * @return void
 */
fn wasm_valtype_ptr_follows_the_ptr64_switch() {
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::Ptr, false)) == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::Ptr, true)) == wasm_vtype_wire(WasmVType::I64))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I32, true)) == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I64, true)) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * wasm_valtype_maps_i64_to_i64 — the one machine class that maps to the wasm
 * `i64` valtype.
 *
 * @return void
 */
fn wasm_valtype_maps_i64_to_i64() {
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::I64, false)) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * wasm_valtype_maps_f32_and_f64_directly — the two float machine classes map
 * to their own-width wasm valtype.
 *
 * @return void
 */
fn wasm_valtype_maps_f32_and_f64_directly() {
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::F32, false)) == wasm_vtype_wire(WasmVType::F32))
    teko::assert::is_true(sft_vt_ok(wasm_valtype(lir::LType::F64, false)) == wasm_vtype_wire(WasmVType::F64))
}

#test
/**
 * wasm_valtype_i128_f16_void_are_named_stops — the two design-named
 * honest-stops (`C1-i128`, `C1-f16`) plus the internal `Void` arm.
 *
 * @return void
 */
fn wasm_valtype_i128_f16_void_are_named_stops() {
    match wasm_valtype(lir::LType::I128, false) {
        u8 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
    match wasm_valtype(lir::LType::F16, false) {
        u8 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-f16")
    }
    match wasm_valtype(lir::LType::Void, false) {
        u8 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "Void")
    }
}

#test
/**
 * wasm_mem_op_i8_i16_zero_extend_into_the_i32_family — the two sub-32 loads
 * zero-extend (`i32.load8_u`/`i32.load16_u`) at their natural alignment.
 *
 * @return void
 */
fn wasm_mem_op_i8_i16_zero_extend_into_the_i32_family() {
    let i8m = sft_mem_ok(wasm_mem_op(lir::LType::I8))
    teko::assert::is_true(i8m.load_op == (0x2D to byte) && i8m.store_op == (0x3A to byte) && i8m.align == (0 to u32) && i8m.valtype == wasm_vtype_wire(WasmVType::I32))
    let i16m = sft_mem_ok(wasm_mem_op(lir::LType::I16))
    teko::assert::is_true(i16m.load_op == (0x2F to byte) && i16m.store_op == (0x3B to byte) && i16m.align == (1 to u32) && i16m.valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * wasm_mem_op_i32_natural_access — `I32`'s own natural-width memory access.
 *
 * @return void
 */
fn wasm_mem_op_i32_natural_access() {
    let i32m = sft_mem_ok(wasm_mem_op(lir::LType::I32))
    teko::assert::is_true(i32m.load_op == (0x28 to byte) && i32m.store_op == (0x36 to byte) && i32m.align == (2 to u32) && i32m.valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * wasm_mem_op_ptr_is_always_the_i64_on_disk_shape — `Ptr`'s memory access is
 * ALWAYS `i64` (8 bytes), matching `ltype_size(Ptr) = 8` (`lir.tks:465`) —
 * REGARDLESS of `ptr64` (#389 C1-7, `backend-wasm.md` §6): the on-disk
 * width is the uniform 64-bit `ptr<>` model; what differs between wasm32/
 * wasm64 is the checked narrow / plain widen `stackify_load`/`stackify_
 * store` apply at the REGISTER boundary on wasm32, vs the identity on
 * wasm64 — `wasm_mem_op` itself makes no `ptr64` distinction.
 *
 * @return void
 */
fn wasm_mem_op_ptr_is_always_the_i64_on_disk_shape() {
    let ptrm = sft_mem_ok(wasm_mem_op(lir::LType::Ptr))
    teko::assert::is_true(ptrm.load_op == (0x29 to byte) && ptrm.store_op == (0x37 to byte) && ptrm.align == (3 to u32) && ptrm.valtype == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * wasm_mem_op_i64_f32_f64_use_their_own_natural_access — the three
 * naturally-8/4-byte-aligned machine classes each get their own load/store
 * opcode pair.
 *
 * @return void
 */
fn wasm_mem_op_i64_f32_f64_use_their_own_natural_access() {
    let i64m = sft_mem_ok(wasm_mem_op(lir::LType::I64))
    teko::assert::is_true(i64m.load_op == (0x29 to byte) && i64m.store_op == (0x37 to byte) && i64m.align == (3 to u32) && i64m.valtype == wasm_vtype_wire(WasmVType::I64))
    let f32m = sft_mem_ok(wasm_mem_op(lir::LType::F32))
    teko::assert::is_true(f32m.load_op == (0x2A to byte) && f32m.store_op == (0x38 to byte) && f32m.align == (2 to u32) && f32m.valtype == wasm_vtype_wire(WasmVType::F32))
    let f64m = sft_mem_ok(wasm_mem_op(lir::LType::F64))
    teko::assert::is_true(f64m.load_op == (0x2B to byte) && f64m.store_op == (0x39 to byte) && f64m.align == (3 to u32) && f64m.valtype == wasm_vtype_wire(WasmVType::F64))
}

#test
/**
 * wasm_mem_op_i128_f16_void_are_named_stops — the same three honest-stop
 * arms as `wasm_valtype`, reachable through the memory-access table too.
 *
 * @return void
 */
fn wasm_mem_op_i128_f16_void_are_named_stops() {
    match wasm_mem_op(lir::LType::I128) {
        WasmMemOp => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
    match wasm_mem_op(lir::LType::F16) {
        WasmMemOp => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-f16")
    }
    match wasm_mem_op(lir::LType::Void) {
        WasmMemOp => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "malformed")
    }
}

#test
/**
 * stackify_const_int_forty_two_matches_design_doc_golden — the design doc's
 * own worked example (§12.1): `LConstInt{42} -> i32.const 42` (`41 2A`).
 *
 * @return void
 */
fn stackify_const_int_forty_two_matches_design_doc_golden() {
    let inst = lir::const_int_inst(0, 42 to i128, 0, 0)
    let out = match stackify_const_int(sft_ctx0(), inst, lir::LConstInt { val = 42 to i128 }) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x41 to byte, 0x2A to byte, 0x21 to byte, 0x00 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 0) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_const_int_beyond_i32_uses_the_i64_form — a value that does not
 * fit i32 but fits i64 picks the wider `i64.const` opcode + wasm valtype.
 *
 * @return void
 */
fn stackify_const_int_beyond_i32_uses_the_i64_form() {
    let val = 5000000000 to i128
    let inst = lir::const_int_inst(1, val, 0, 0)
    let out = match stackify_const_int(sft_ctx0(), inst, lir::LConstInt { val = val }) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x42 to byte, 0x80 to byte, 0xE4 to byte, 0x97 to byte, 0xD0 to byte, 0x12 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 1) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_const_int_beyond_i64_is_the_c1_i128_stop — a value beyond the i64
 * range names the `C1-i128` honest-stop rather than silently truncating.
 *
 * @return void
 */
fn stackify_const_int_beyond_i64_is_the_c1_i128_stop() {
    let val = sft_i128_beyond_i64()
    let inst = lir::const_int_inst(0, val, 0, 0)
    match stackify_const_int(sft_ctx0(), inst, lir::LConstInt { val = val }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

#test
/**
 * stackify_const_float_emits_raw_le_bits_for_one_point_zero — `f64.const`
 * carries the RAW little-endian IEEE754 bit pattern, not LEB128
 * (`1.0`'s bit pattern `0x3FF0000000000000`).
 *
 * @return void
 */
fn stackify_const_float_emits_raw_le_bits_for_one_point_zero() {
    let bits = 0x3FF0000000000000 to u64
    let inst = lir::const_float_inst(2, bits, 0, 0)
    let out = stackify_const_float(sft_ctx0(), inst, lir::LConstFloat { bits = bits })
    let want = [
        0x44 to byte, 0x00 to byte, 0x00 to byte, 0x00 to byte, 0x00 to byte,
        0x00 to byte, 0x00 to byte, 0xF0 to byte, 0x3F to byte, 0x21 to byte, 0x02 to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 2) == wasm_vtype_wire(WasmVType::F64))
}

#test
/**
 * binop_info_integer_arithmetic_opcodes_by_width — the seven arithmetic
 * `LBinOp` cases, narrow (`i32`) and wide (`i64`) forms.
 *
 * @return void
 */
fn binop_info_integer_arithmetic_opcodes_by_width() {
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IAdd, false).opcode == (0x6A to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IAdd, true).opcode == (0x7C to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ISub, false).opcode == (0x6B to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ISub, true).opcode == (0x7D to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IMul, false).opcode == (0x6C to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IMul, true).opcode == (0x7E to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IDivS, false).opcode == (0x6D to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IDivS, true).opcode == (0x7F to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IDivU, false).opcode == (0x6E to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IDivU, true).opcode == (0x80 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IRemS, false).opcode == (0x6F to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IRemS, true).opcode == (0x81 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IRemU, false).opcode == (0x70 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IRemU, true).opcode == (0x82 to byte))
    teko::assert::is_true(!wasm_binop_info(lir::LBinOp::IAdd, false).is_cmp)
}

#test
/**
 * binop_info_integer_bitwise_and_shift_opcodes_by_width — the six
 * bitwise/shift `LBinOp` cases, narrow and wide forms.
 *
 * @return void
 */
fn binop_info_integer_bitwise_and_shift_opcodes_by_width() {
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IAnd, false).opcode == (0x71 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IAnd, true).opcode == (0x83 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IOr, false).opcode == (0x72 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IOr, true).opcode == (0x84 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IXor, false).opcode == (0x73 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IXor, true).opcode == (0x85 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IShl, false).opcode == (0x74 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IShl, true).opcode == (0x86 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IShrS, false).opcode == (0x75 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IShrS, true).opcode == (0x87 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IShrU, false).opcode == (0x76 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::IShrU, true).opcode == (0x88 to byte))
}

#test
/**
 * binop_info_integer_compare_opcodes_are_i32_regardless_of_width — the ten
 * integer-compare `LBinOp` cases, each classified `is_cmp`.
 *
 * @return void
 */
fn binop_info_integer_compare_opcodes_are_i32_regardless_of_width() {
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpEq, false).opcode == (0x46 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpEq, true).opcode == (0x51 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpNe, false).opcode == (0x47 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpNe, true).opcode == (0x52 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLtS, false).opcode == (0x48 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLtS, true).opcode == (0x53 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLtU, false).opcode == (0x49 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLtU, true).opcode == (0x54 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLeS, false).opcode == (0x4C to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLeS, true).opcode == (0x57 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLeU, false).opcode == (0x4D to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpLeU, true).opcode == (0x58 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGtS, false).opcode == (0x4A to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGtS, true).opcode == (0x55 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGtU, false).opcode == (0x4B to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGtU, true).opcode == (0x56 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGeS, false).opcode == (0x4E to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGeS, true).opcode == (0x59 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGeU, false).opcode == (0x4F to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGeU, true).opcode == (0x5A to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpEq, false).is_cmp)
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::ICmpGeU, true).is_cmp)
}

#test
/**
 * binop_info_float_arithmetic_opcodes_by_width — the four float-arithmetic
 * `LBinOp` cases, narrow (`f32`) and wide (`f64`) forms.
 *
 * @return void
 */
fn binop_info_float_arithmetic_opcodes_by_width() {
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FAdd, false).opcode == (0x92 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FAdd, true).opcode == (0xA0 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FSub, false).opcode == (0x93 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FSub, true).opcode == (0xA1 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FMul, false).opcode == (0x94 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FMul, true).opcode == (0xA2 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FDiv, false).opcode == (0x95 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FDiv, true).opcode == (0xA3 to byte))
    teko::assert::is_true(!wasm_binop_info(lir::LBinOp::FAdd, false).is_cmp)
}

#test
/**
 * binop_info_float_compare_opcodes_are_i32_regardless_of_width — the six
 * float-compare `LBinOp` cases, each classified `is_cmp`.
 *
 * @return void
 */
fn binop_info_float_compare_opcodes_are_i32_regardless_of_width() {
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpEq, false).opcode == (0x5B to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpEq, true).opcode == (0x61 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpNe, false).opcode == (0x5C to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpNe, true).opcode == (0x62 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpLt, false).opcode == (0x5D to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpLt, true).opcode == (0x63 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpLe, false).opcode == (0x5F to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpLe, true).opcode == (0x65 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpGt, false).opcode == (0x5E to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpGt, true).opcode == (0x64 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpGe, false).opcode == (0x60 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpGe, true).opcode == (0x66 to byte))
    teko::assert::is_true(wasm_binop_info(lir::LBinOp::FCmpEq, false).is_cmp)
}

#test
/**
 * stackify_bin_arithmetic_inherits_operand_a_type — the design doc's own
 * `IAdd` worked example (§4.4), and the result's wasm valtype inherited
 * from operand `a` (here `i64`, so the wide opcode `0x7C` is selected).
 *
 * @return void
 */
fn stackify_bin_arithmetic_inherits_operand_a_type() {
    let ctx0 = sc_set_vtype(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), 1, wasm_vtype_wire(WasmVType::I64))
    let inst = lir::bin_inst(2, lir::LBinOp::IAdd, 0, 1, 0, 0)
    let out = stackify_bin(ctx0, inst, lir::LBin { op = lir::LBinOp::IAdd; a = 0; b = 1 })
    let want = [0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x7C to byte, 0x21 to byte, 0x02 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 2) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_bin_compare_result_is_always_i32 — a compare over `i64` operands
 * still records an `i32` result valtype (mirrors `isel_arm64.tks`'s own
 * always-narrow compare result).
 *
 * @return void
 */
fn stackify_bin_compare_result_is_always_i32() {
    let ctx0 = sc_set_vtype(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), 1, wasm_vtype_wire(WasmVType::I64))
    let inst = lir::bin_inst(2, lir::LBinOp::ICmpLtS, 0, 1, 0, 0)
    let out = stackify_bin(ctx0, inst, lir::LBin { op = lir::LBinOp::ICmpLtS; a = 0; b = 1 })
    teko::assert::is_true(wvt_get(out.vtypes, 2) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_ineg_narrow_and_wide — `INeg` renders as `0 - a` at both widths
 * (`backend-c1-wasm.md` §4.4's worked example).
 *
 * @return void
 */
fn stackify_ineg_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::INeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x41 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x6B to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(narrow_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::INeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x42 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x7D to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(wide_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_inot_narrow_and_wide — `INot` renders as `a XOR -1` at both
 * widths (`backend-c1-wasm.md` §4.4's worked example).
 *
 * @return void
 */
fn stackify_inot_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::INot, 0, 0, 0), lir::LUn { op = lir::LUnOp::INot; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x41 to byte, 0x7F to byte, 0x20 to byte, 0x00 to byte, 0x73 to byte, 0x21 to byte, 0x01 to byte]))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::INot, 0, 0, 0), lir::LUn { op = lir::LUnOp::INot; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x42 to byte, 0x7F to byte, 0x20 to byte, 0x00 to byte, 0x85 to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_fneg_narrow_and_wide — `FNeg` selects `f32.neg`/`f64.neg` by
 * operand width.
 *
 * @return void
 */
fn stackify_fneg_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F32)), lir::un_inst(1, lir::LUnOp::FNeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::FNeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x20 to byte, 0x00 to byte, 0x8C to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(narrow_out.vtypes, 1) == wasm_vtype_wire(WasmVType::F32))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F64)), lir::un_inst(1, lir::LUnOp::FNeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::FNeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x20 to byte, 0x00 to byte, 0x9A to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(wide_out.vtypes, 1) == wasm_vtype_wire(WasmVType::F64))
}

#test
/**
 * stackify_trunc_from_i32_is_identity_from_i64_wraps — `Trunc` always
 * yields `i32`; an already-`i32` operand is a plain copy, an `i64` operand
 * needs the real `i32.wrap_i64`.
 *
 * @return void
 */
fn stackify_trunc_from_i32_is_identity_from_i64_wraps() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::Trunc, 0, 0, 0), lir::LUn { op = lir::LUnOp::Trunc; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::Trunc, 0, 0, 0), lir::LUn { op = lir::LUnOp::Trunc; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xA7 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from64.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_zext_and_sext_are_identity_at_operand_width — `ZExt`/`SExt` both
 * lower to a plain local-to-local copy at the operand's own width (the LIR
 * carries no further per-value width information, mirroring
 * `isel_arm64.tks`'s own `select_identity_mov` treatment).
 *
 * @return void
 */
fn stackify_zext_and_sext_are_identity_at_operand_width() {
    let zext_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::ZExt, 0, 0, 0), lir::LUn { op = lir::LUnOp::ZExt; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(zext_out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(zext_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let sext_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::SExt, 0, 0, 0), lir::LUn { op = lir::LUnOp::SExt; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(sext_out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(sext_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_itof_from_i32_and_i64 — `IToF` always yields `f64`, its source
 * opcode selected by the operand's own integer width.
 *
 * @return void
 */
fn stackify_itof_from_i32_and_i64() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::IToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::IToF; a = 0 })
