/**
 * sft_panic_symtab — a `WasmSymbolTable` with `tk_panic_str` registered at
 * funcidx `5` — `stackify_narrow_ptr_load`'s own resolver fixture (#389
 * C1-7).
 *
 * @return WasmSymbolTable  the table
 */
fn sft_panic_symtab() -> WasmSymbolTable {
    wasm_symtab_add(wasm_symtab_empty(), "tk_panic_str", WasmCallTarget { func_index = 5 to u32; ret_type = lir::LType::Void })
}

/**
 * sft_ctx_scratch_at — a fresh `StackifyCtx` exactly like `sft_ctx0`, except
 * its `next_scratch` starts at `n` — used by the checked-narrow tests so the
 * reserved scratch local (`sc_alloc_scratch`) never collides with the
 * instruction's own `addr`/`result` VRegs (a real function always seeds
 * `next_scratch` at `f.next_vreg`, past every real VReg; this fixture
 * mirrors that for a hand-built, real-function-free unit test).
 *
 * @param u32 n  the starting scratch id
 * @return StackifyCtx  the empty context, scratch allocation starting at `n`
 */
fn sft_ctx_scratch_at(n: u32) -> StackifyCtx {
    StackifyCtx { body = teko::list::empty(); vtypes = wvt_empty(); scopes = teko::list::empty(); next_scratch = n; has_frame = false; frame_base = 0 to u32; slots = wst_empty(); elide = et_empty(); pending = teko::list::empty() }
}

#test
/**
 * stackify_load_ptr_wasm32_checked_narrows — the wasm32 (`ptr64 = false`)
 * `Ptr`-typed `LLoad` (#389 C1-7, `backend-wasm.md` §6): `local.get addr;
 * i64.load align=3,off=0` (the on-disk shape is ALWAYS `i64`, `wasm_mem_
 * op`), then the checked-narrow tail (`stackify_narrow_ptr_load`, hand-
 * traced): `local.tee $scratch; i64.const 2^32; i64.ge_u; if (then i32.const
 * msg_addr; i32.const msg_len; call $panic; unreachable); local.get
 * $scratch; i32.wrap_i64`, and finally `local.set $result` (the result's
 * own valtype is `i32`, matching `wasm_valtype(Ptr, false)`).
 *
 * @return void
 */
fn stackify_load_ptr_wasm32_checked_narrows() {
    let inst = lir::load_inst(1, 0, lir::LType::Ptr, 0, 0)
    let ctx0 = sft_ctx_scratch_at(2 to u32)
    let out = match stackify_load(ctx0, inst, lir::LLoad { addr = 0; ty = lir::LType::Ptr }, false, sft_panic_symtab()) { StackifyCtx as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte,
        0x29 to byte, 0x03 to byte, 0x00 to byte,
        0x22 to byte, 0x02 to byte,
        0x42 to byte, 0x80 to byte, 0x80 to byte, 0x80 to byte, 0x80 to byte, 0x10 to byte,
        0x5A to byte,
        0x04 to byte, 0x40 to byte,
        0x41 to byte, 0x10 to byte,
        0x41 to byte, 0x2A to byte,
        0x10 to byte, 0x05 to byte,
        0x00 to byte,
        0x0B to byte,
        0x20 to byte, 0x02 to byte,
        0xA7 to byte,
        0x21 to byte, 0x01 to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_load_ptr_wasm32_needs_tk_panic_str_registered — the checked-
 * narrow call site propagates `wasm_resolve_call`'s own "unresolved call
 * symbol" error when `tk_panic_str` is not registered — the narrow path
 * never silently skips the panic hook.
 *
 * @return void
 */
fn stackify_load_ptr_wasm32_needs_tk_panic_str_registered() {
    let inst = lir::load_inst(1, 0, lir::LType::Ptr, 0, 0)
    match stackify_load(sft_ctx_scratch_at(2 to u32), inst, lir::LLoad { addr = 0; ty = lir::LType::Ptr }, false, wasm_symtab_empty()) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "tk_panic_str")
    }
}

#test
/**
 * stackify_load_ptr_wasm64_is_a_plain_i64_load — on wasm64 (`ptr64 = true`),
 * `Ptr` needs NO checked narrow at all: `local.get addr; i64.load
 * align=3,off=0; local.set $result` — byte-identical to any other `i64`
 * load, and the result's own valtype is `i64` (`wasm_valtype(Ptr, true)`).
 *
 * @return void
 */
fn stackify_load_ptr_wasm64_is_a_plain_i64_load() {
    let inst = lir::load_inst(1, 0, lir::LType::Ptr, 0, 0)
    let out = match stackify_load(sft_ctx0(), inst, lir::LLoad { addr = 0; ty = lir::LType::Ptr }, true, wasm_symtab_empty()) { StackifyCtx as x => x; error => return }
    let want = [0x20 to byte, 0x00 to byte, 0x29 to byte, 0x03 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 1) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_store_ptr_wasm32_widens_before_storing — the wasm32 (`ptr64 =
 * false`) `Ptr`-typed `LStore` (#389 C1-7, §6): the `i32` register value is
 * `i64.extend_i32_u`-widened (always lossless — an in-range wasm32 address
 * is never negative) before the `i64.store` (the on-disk shape is ALWAYS
 * `i64`): `local.get addr; local.get value; i64.extend_i32_u; i64.store
 * align=3,off=0`.
 *
 * @return void
 */
fn stackify_store_ptr_wasm32_widens_before_storing() {
    let out = match stackify_store(sft_ctx0(), lir::LStore { addr = 0; value = 1; ty = lir::LType::Ptr }, false) { StackifyCtx as x => x; error => return }
    let want = [0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0xAD to byte, 0x37 to byte, 0x03 to byte, 0x00 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * stackify_store_ptr_wasm64_needs_no_widen — on wasm64 (`ptr64 = true`), the
 * `i64`-valued register already matches the `i64` on-disk shape: `local.get
 * addr; local.get value; i64.store align=3,off=0` — no extend.
 *
 * @return void
 */
fn stackify_store_ptr_wasm64_needs_no_widen() {
    let out = match stackify_store(sft_ctx0(), lir::LStore { addr = 0; value = 1; ty = lir::LType::Ptr }, true) { StackifyCtx as x => x; error => return }
    let want = [0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x37 to byte, 0x03 to byte, 0x00 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

/**
 * sft_void_target — a `WasmCallTarget` for a `Void`-returning callee at
 * funcidx `3`.
 *
 * @return WasmCallTarget  the target
 */
fn sft_void_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 3 to u32; ret_type = lir::LType::Void }
}

/**
 * sft_i32_target — a `WasmCallTarget` for an `I32`-returning callee at
 * funcidx `5`.
 *
 * @return WasmCallTarget  the target
 */
fn sft_i32_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 5 to u32; ret_type = lir::LType::I32 }
}

/**
 * sft_i128_target — a `WasmCallTarget` for an `I128`-returning callee (a
 * genuinely unrepresentable wasm return type, at funcidx `7`).
 *
 * @return WasmCallTarget  the target
 */
fn sft_i128_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 7 to u32; ret_type = lir::LType::I128 }
}

#test
/**
 * wasm_symtab_add_then_resolve_round_trips — the resolver table's basic
 * register/lookup contract.
 *
 * @return void
 */
fn wasm_symtab_add_then_resolve_round_trips() {
    let t = wasm_symtab_add(wasm_symtab_empty(), "tk_exit", sft_void_target())
    match wasm_resolve_call(t, "tk_exit") {
        WasmCallTarget as target => teko::assert::is_true(target.func_index == (3 to u32))
        error => teko::assert::is_true(false)
    }
}

#test
/**
 * stackify_call_void_matches_design_doc_golden — the design doc's own
 * worked example (§12.1): `LCall{tk_exit} -> local.get arg; call funcidx`.
 * The `call` opcode lands at body index `2`, its minimal-width ULEB128
 * funcidx operand (`3`, the callee's final absolute index) at index `3` —
 * the module is self-contained (`backend-wasm.md` §1.2), so the operand is
 * baked directly with no relocation recorded.
 *
 * @return void
 */
fn stackify_call_void_matches_design_doc_golden() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "tk_exit", sft_void_target())
    let args = teko::list::push(teko::list::empty(), 0 to u32)
    let inst = lir::void_call_inst("tk_exit", args, false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "tk_exit"; args = args; variadic = false }, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x20 to byte, 0x00 to byte, 0x10 to byte, 0x03 to byte]))
}

#test
/**
 * stackify_call_captures_a_value_result — a value-returning callee whose
 * caller captures the result into its own local.
 *
 * @return void
 */
fn stackify_call_captures_a_value_result() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__f", sft_i32_target())
    let inst = lir::call_inst(9, "teko__demo__f", teko::list::empty(), false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__f"; args = teko::list::empty(); variadic = false }, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x10 to byte, 0x05 to byte, 0x21 to byte, 0x09 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 9) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_call_drops_a_discarded_value_result — a value-returning callee
 * called at statement level (the result unused) drops it to keep the
 * operand stack balanced.
 *
 * @return void
 */
fn stackify_call_drops_a_discarded_value_result() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__f", sft_i32_target())
    let inst = lir::void_call_inst("teko__demo__f", teko::list::empty(), false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__f"; args = teko::list::empty(); variadic = false }, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x10 to byte, 0x05 to byte, 0x1A to byte]))
}

#test
/**
 * stackify_call_unresolved_symbol_is_a_named_error — a symbol the caller
 * never registered.
 *
 * @return void
 */
fn stackify_call_unresolved_symbol_is_a_named_error() {
    let inst = lir::void_call_inst("teko__missing__f", teko::list::empty(), false, 0, 0)
    match stackify_call(sft_ctx0(), wasm_symtab_empty(), inst, lir::LCall { symbol = "teko__missing__f"; args = teko::list::empty(); variadic = false }, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "unresolved call symbol")
    }
}

#test
/**
 * stackify_call_i128_return_propagates_the_c1_i128_stop — a callee whose
 * return type has no wasm valtype.
 *
 * @return void
 */
fn stackify_call_i128_return_propagates_the_c1_i128_stop() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__big", sft_i128_target())
    let inst = lir::void_call_inst("teko__demo__big", teko::list::empty(), false, 0, 0)
    match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__big"; args = teko::list::empty(); variadic = false }, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

/**
 * sft_empty_func — a fresh 0-param, `Void`-returning function (a throwaway
 * `f`/dispatch fixture for ops that never read it).
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_empty_func() -> lir::LFunc {
    lir::new_func("teko__test__dispatch", 0, teko::list::empty(), lir::LType::Void)
}

#test
/**
 * stackify_inst_jump_and_branch_are_internal_misuse — terminators are now
 * handled by `stackify_control`'s own terminator dispatch (C1-3); reaching
 * `LJump`/`LBranch` through the per-instruction `stackify_inst` is a
 * caller misuse, not a design gap.
 *
 * @return void
 */
fn stackify_inst_jump_and_branch_are_internal_misuse() {
    let jump = lir::jump_inst(1, teko::list::empty(), 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), jump, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "internal misuse")
    }
    let branch = lir::branch_inst(0, 1, teko::list::empty(), 2, teko::list::empty(), 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), branch, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "internal misuse")
    }
}

#test
/**
 * stackify_inst_global_addr_matches_design_doc_golden — `LGlobalAddr`
 * dispatched through `stackify_inst`, resolving via a registered data
 * symbol: `i32.const 100; local.set 0` (`41 E4 00 21 00`, §12.1's own
 * `LGlobalAddr -> i32.const dataaddr` shape).
 *
 * @return void
 */
fn stackify_inst_global_addr_matches_design_doc_golden() {
    let symbols = wasm_symtab_add_data(wasm_symtab_empty(), "teko__rodata__0", 100 to u32)
    let global_addr = lir::global_addr_inst(0, "teko__rodata__0", 0, 0)
    let out = match stackify_inst(sft_ctx0(), sft_empty_func(), symbols, global_addr, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x41 to byte, 0xE4 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 0) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_inst_global_addr_unresolved_symbol_is_a_named_error — a rodata
 * symbol the caller never registered.
 *
 * @return void
 */
fn stackify_inst_global_addr_unresolved_symbol_is_a_named_error() {
    let global_addr = lir::global_addr_inst(0, "teko__rodata__missing", 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), global_addr, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "unresolved data symbol")
    }
}

#test
/**
 * stackify_inst_alloca_dispatches_to_stackify_alloca — `LAlloca` reads its
 * own precomputed slot offset from a manually-seeded frame (`frame_base=9`,
 * slot offset `16`): `local.get 9; i32.const 16; i32.add; local.set 0`.
 *
 * @return void
 */
fn stackify_inst_alloca_dispatches_to_stackify_alloca() {
    let seeded = StackifyCtx {
        body = teko::list::empty()
        vtypes = wvt_empty()
        scopes = teko::list::empty()
        next_scratch = 10 to u32
        has_frame = true
        frame_base = 9 to u32
        slots = wst_set(wst_empty(), 0, 16 to u32)
        elide = et_empty()
        pending = teko::list::empty()
    }
    let alloca = lir::alloca_inst(0, 8, 8, 0, 0)
    let out = match stackify_inst(seeded, sft_empty_func(), wasm_symtab_empty(), alloca, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x20 to byte, 0x09 to byte, 0x41 to byte, 0x10 to byte, 0x6A to byte, 0x21 to byte, 0x00 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 0) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_inst_call_indirect_and_func_addr_are_the_c1_4_5_stop — the wasm
 * funcref table is out of C1-2's scope.
 *
 * @return void
 */
fn stackify_inst_call_indirect_and_func_addr_are_the_c1_4_5_stop() {
    let call_indirect = lir::void_call_indirect_inst(0, teko::list::empty(), false, 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), call_indirect, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-callindirect")
    }
    let func_addr = lir::func_addr_inst(0, "teko__demo__f", 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), func_addr, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-funcaddr")
    }
}

#test
/**
 * stackify_func_two_block_straight_fallthrough_needs_no_br — a bare
 * `jump` into the very next block needs no `br` at all (the plain
 * tail-continue case, C1-3's simplest multi-block shape — the former
 * `C1-3-required` stop is gone, `stackify_func` now accepts this).
 *
 * @return void
 */
fn stackify_func_two_block_straight_fallthrough_needs_no_br() {
    mut f = lir::new_func("teko__test__multi", 0, teko::list::empty(), lir::LType::I32)
    f = lir::append_inst(f, 0, lir::jump_inst(1, teko::list::empty(), 0, 0))
    let b1 = lir::alloc_block(f)
    f = b1.func
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, b1.block_id, lir::const_int_inst(r0.vreg, 7 to i128, 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::ret_inst(r0.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* r0's one use (the ret, same block b1) rides the stack (§5 C1-5) — the
     * `local.set 0; local.get 0` round-trip the pre-peephole baseline paid
     * is gone. */
    let want = [0x41 to byte, 0x07 to byte, 0x0F to byte, 0x0B to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_straight_line_add_matches_golden_bytes — the design doc's
 * own end-to-end shape: `fn add(a, b) { a + b }`, byte-for-byte.
 *
 * @return void
 */
fn stackify_func_straight_line_add_matches_golden_bytes() {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__demo__add", 2, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    let r = lir::alloc_vreg(f)
    f = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, lir::LBinOp::IAdd, 0, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_inst(r.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* Every value here — both params AND the add's own result — is
     * single-use, same-block, and consumed in LIFO order: the whole
     * ALL-LOCALS baseline's `local.set`/`local.get` traffic rides the stack
     * instead (§5 C1-5's own "straight-line arith" golden). */
    let want_body = [
        0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x6A to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want_body))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (1 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_no_locals_when_no_non_param_vregs — a body that defines no
 * VReg beyond its params declares zero locals.
 *
 * @return void
 */
fn stackify_func_no_locals_when_no_non_param_vregs() {
    mut f = lir::new_func("teko__test__void", 0, teko::list::empty(), lir::LType::Void)
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    teko::assert::is_true(out.local_groups.len == 0)
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x0F to byte, 0x0B to byte]))
}

#test
/**
 * stackify_func_local_groups_merge_consecutive_same_type — two
 * consecutive `i32` locals compress into one run-length group.
 *
 * @return void
 */
fn stackify_func_local_groups_merge_consecutive_same_type() {
    mut f = lir::new_func("teko__test__same", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::const_int_inst(r0.vreg, 1 to i128, 0, 0))
    let r1 = lir::alloc_vreg(f)
    f = lir::append_inst(r1.func, 0, lir::const_int_inst(r1.vreg, 2 to i128, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (2 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_local_groups_split_on_a_type_change — an `i32`/`i64`/`i32`
 * VReg sequence run-length-splits into three groups.
 *
 * @return void
 */
fn stackify_func_local_groups_split_on_a_type_change() {
    mut f = lir::new_func("teko__test__mixed", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::const_int_inst(r0.vreg, 1 to i128, 0, 0))
    let r1 = lir::alloc_vreg(f)
    f = lir::append_inst(r1.func, 0, lir::const_int_inst(r1.vreg, 5000000000 to i128, 0, 0))
    let r2 = lir::alloc_vreg(f)
    f = lir::append_inst(r2.func, 0, lir::const_int_inst(r2.vreg, 2 to i128, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    teko::assert::is_true(out.local_groups.len == 3)
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(out.local_groups[1].valtype == wasm_vtype_wire(WasmVType::I64))
    teko::assert::is_true(out.local_groups[2].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * wvt_get_defaults_to_i32_when_unset — the defensive out-of-range default
 * (never reached from valid, def-before-use SSA input, but named and tested
 * directly).
 *
 * @return void
 */
fn wvt_get_defaults_to_i32_when_unset() {
    teko::assert::is_true(wvt_get(wvt_empty(), 0) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_inst_dispatches_every_remaining_straight_line_case —
 * `LConstFloat`/`LUn`/`LFieldAddr`/`LLoad`/`LStore`/`LCall` through the
 * TOP-LEVEL `stackify_inst` dispatcher itself (their own lowering functions
 * are covered directly by the dedicated tests above; this exercises the
 * dispatch match arm that routes to each).
 *
 * @return void
 */
fn stackify_inst_dispatches_every_remaining_straight_line_case() {
    let f = sft_empty_func()
    let float_inst = lir::const_float_inst(0, 0x3FF0000000000000 to u64, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), float_inst, false) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let un_ctx = sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32))
    let un_inst = lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0)
    match stackify_inst(un_ctx, f, wasm_symtab_empty(), un_inst, false) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let field_addr_inst = lir::field_addr_inst(1, 0, 4, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), field_addr_inst, false) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let load_inst = lir::load_inst(1, 0, lir::LType::I32, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), load_inst, false) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let store_inst = lir::store_inst(0, 1, lir::LType::I32, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), store_inst, false) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let call_symbols = wasm_symtab_add(wasm_symtab_empty(), "tk_exit", sft_void_target())
    let call_inst = lir::void_call_inst("tk_exit", teko::list::empty(), false, 0, 0)
    match stackify_inst(sft_ctx0(), f, call_symbols, call_inst, false) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
}

#test
/**
 * stackify_func_propagates_a_mid_stream_instruction_error — a later
 * instruction's own honest-stop short-circuits `stackify_insts` and
 * propagates through `stackify_func` unchanged, rather than lowering the
 * rest of the stream regardless.
 *
 * @return void
 */
fn stackify_func_propagates_a_mid_stream_instruction_error() {
    mut f = lir::new_func("teko__test__callind_mid", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::const_int_inst(r0.vreg, 0 to i128, 0, 0))
    f = lir::append_inst(f, 0, lir::void_call_indirect_inst(r0.vreg, teko::list::empty(), false, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-callindirect")
    }
}

/* ==========================================================================
 * C1-3 — CFGStackify golden-byte fixtures, each cross-checked byte-for-byte
 * against a hand-written `.wat` compiled by `wat2wasm` (never invented).
 * ========================================================================== */

#test
/**
 * stackify_func_if_else_diamond_matches_wat2wasm_golden — `let x = if cond
 * {1} else {2}; return x`: the CFGStackify if/else diamond (§3.3), its
 * merge's block-arg crossing both edges as a local copy (§4.3). Golden
 * bytes cross-checked against a hand-written `.wat` compiled by `wat2wasm`
 * (`wasm-validate`-clean).
 *
 * @return void
 */
fn stackify_func_if_else_diamond_matches_wat2wasm_golden() {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I32)
    mut f = lir::new_func("teko__test__if_else", 1, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let thenb = lir::alloc_block(f)
    let elseb = lir::alloc_block(thenb.func)
    let mergeb = lir::alloc_block(elseb.func)
    let mp = lir::add_block_param(mergeb.func, mergeb.block_id)
    f = lir::append_inst(mp.func, 0, lir::branch_inst(0, thenb.block_id, teko::list::empty(), elseb.block_id, teko::list::empty(), 0, 0))
    let r_then = lir::alloc_vreg(f)
    f = lir::append_inst(r_then.func, thenb.block_id, lir::const_int_inst(r_then.vreg, 1 to i128, 0, 0))
    let then_args = teko::list::push(teko::list::empty(), r_then.vreg)
    f = lir::append_inst(f, thenb.block_id, lir::jump_inst(mergeb.block_id, then_args, 0, 0))
    let r_else = lir::alloc_vreg(f)
    f = lir::append_inst(r_else.func, elseb.block_id, lir::const_int_inst(r_else.vreg, 2 to i128, 0, 0))
    let else_args = teko::list::push(teko::list::empty(), r_else.vreg)
    f = lir::append_inst(f, elseb.block_id, lir::jump_inst(mergeb.block_id, else_args, 0, 0))
    f = lir::append_inst(f, mergeb.block_id, lir::ret_inst(mp.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* param 0 (the branch's own `cond`) is single-use, same-block (block 0)
     * — it rides the stack straight into the `if` (§5's own ALWAYS-STACK
     * fused-compare case), dropping its `local.set 0`/`local.get 0`
     * round-trip. `r_then`/`r_else` stay in locals: each one's ONLY use is
     * an edge-copy argument (FORCED-LOCAL, §5), not a computational
     * consumer. */
    let want = [
        0x20 to byte, 0x00 to byte,
        0x04 to byte, 0x40 to byte,
        0x41 to byte, 0x01 to byte, 0x21 to byte, 0x02 to byte, 0x20 to byte, 0x02 to byte, 0x21 to byte, 0x01 to byte,
        0x05 to byte,
        0x41 to byte, 0x02 to byte, 0x21 to byte, 0x03 to byte, 0x20 to byte, 0x03 to byte, 0x21 to byte, 0x01 to byte,
        0x0B to byte,
        0x20 to byte, 0x01 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (3 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_loop_with_two_breaks_matches_wat2wasm_golden — a loop whose
 * header checks `condA` (breaking to `exitb`) and, when false, falls to a
 * second guard checking `condB` (ALSO breaking to the SAME `exitb`, else
 * the back-edge `continue`): `exitb` has TWO predecessors, so its
 * dominator is the header itself — exactly the shape that (without the
 * `merge_target_of` scope-exclusion fix, §3.3) would be misidentified as
 * an ordinary if/else "new merge" and rendered inline instead of via the
 * loop's own wrapping `block`. Proves the fix: both breaks correctly `br`
 * out to the wrapping block; the continue correctly `br`s to the loop.
 * Golden bytes cross-checked against a hand-written `.wat`.
 *
 * @return void
 */
fn stackify_func_loop_with_two_breaks_matches_wat2wasm_golden() {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__test__loop_break", 2, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    let headb = lir::alloc_block(f)
    let chk2 = lir::alloc_block(headb.func)
    let exitb = lir::alloc_block(chk2.func)
    f = lir::append_inst(exitb.func, 0, lir::jump_inst(headb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, headb.block_id, lir::branch_inst(0, exitb.block_id, teko::list::empty(), chk2.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, chk2.block_id, lir::branch_inst(1, exitb.block_id, teko::list::empty(), headb.block_id, teko::list::empty(), 0, 0))
    let r9 = lir::alloc_vreg(f)
    f = lir::append_inst(r9.func, exitb.block_id, lir::const_int_inst(r9.vreg, 9 to i128, 0, 0))
    f = lir::append_inst(f, exitb.block_id, lir::ret_inst(r9.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x01 to byte,
        0x02 to byte, 0x40 to byte,
        0x03 to byte, 0x40 to byte,
        0x20 to byte, 0x00 to byte,
        0x04 to byte, 0x40 to byte,
        0x0C to byte, 0x02 to byte,
        0x05 to byte,
        0x20 to byte, 0x01 to byte,
        0x04 to byte, 0x40 to byte,
        0x0C to byte, 0x03 to byte,
        0x05 to byte,
        0x0C to byte, 0x02 to byte,
        0x0B to byte,
        0x0B to byte,
        0x0B to byte,
        0x0B to byte,
        0x41 to byte, 0x09 to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (1 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_nested_if_matches_wat2wasm_golden —
 * `if a { if b { 10 } else { 20 } } else { 30 }`: a nested if/else whose
 * inner merge's own continuation renders INSIDE the outer `then` arm (the
 * inner merge is only reachable that way), while the outer merge still
 * renders exactly once after the outer `if`/`else`/`end` — `merge_target_
 * of` correctly attributes each merge to its OWN nearest branch. Golden
 * bytes cross-checked against a hand-written `.wat`.
 *
 * @return void
 */
fn stackify_func_nested_if_matches_wat2wasm_golden() {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__test__nested_if", 2, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    let inner_if = lir::alloc_block(f)
    let inner_then = lir::alloc_block(inner_if.func)
    let inner_else = lir::alloc_block(inner_then.func)
    let inner_merge = lir::alloc_block(inner_else.func)
    let imp = lir::add_block_param(inner_merge.func, inner_merge.block_id)
    let else30 = lir::alloc_block(imp.func)
    let outer_merge = lir::alloc_block(else30.func)
    let omp = lir::add_block_param(outer_merge.func, outer_merge.block_id)
    f = lir::append_inst(omp.func, 0, lir::branch_inst(0, inner_if.block_id, teko::list::empty(), else30.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, inner_if.block_id, lir::branch_inst(1, inner_then.block_id, teko::list::empty(), inner_else.block_id, teko::list::empty(), 0, 0))
    let r10 = lir::alloc_vreg(f)
    f = lir::append_inst(r10.func, inner_then.block_id, lir::const_int_inst(r10.vreg, 10 to i128, 0, 0))
    f = lir::append_inst(f, inner_then.block_id, lir::jump_inst(inner_merge.block_id, teko::list::push(teko::list::empty(), r10.vreg), 0, 0))
    let r20 = lir::alloc_vreg(f)
    f = lir::append_inst(r20.func, inner_else.block_id, lir::const_int_inst(r20.vreg, 20 to i128, 0, 0))
    f = lir::append_inst(f, inner_else.block_id, lir::jump_inst(inner_merge.block_id, teko::list::push(teko::list::empty(), r20.vreg), 0, 0))
    f = lir::append_inst(f, inner_merge.block_id, lir::jump_inst(outer_merge.block_id, teko::list::push(teko::list::empty(), imp.vreg), 0, 0))
    let r30 = lir::alloc_vreg(f)
    f = lir::append_inst(r30.func, else30.block_id, lir::const_int_inst(r30.vreg, 30 to i128, 0, 0))
    f = lir::append_inst(f, else30.block_id, lir::jump_inst(outer_merge.block_id, teko::list::push(teko::list::empty(), r30.vreg), 0, 0))
    f = lir::append_inst(f, outer_merge.block_id, lir::ret_inst(omp.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* param 0's ONE use (the OUTER branch's `cond`) is in block 0 — the
     * SAME block it is defined in — so it rides the stack (§5), dropping
     * its self-copy AND the separate `local.get` the `if` used to need.
     * param 1's ONE use (the INNER branch's `cond`) is in a DIFFERENT
     * block (`inner_if`) than its own def (block 0) — cross-block, so it
     * stays a normal local exactly as before. */
    let want = [
        0x20 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x01 to byte,
        0x04 to byte, 0x40 to byte,
        0x20 to byte, 0x01 to byte,
        0x04 to byte, 0x40 to byte,
        0x41 to byte, 0x0A to byte, 0x21 to byte, 0x04 to byte, 0x20 to byte, 0x04 to byte, 0x21 to byte, 0x02 to byte,
        0x05 to byte,
        0x41 to byte, 0x14 to byte, 0x21 to byte, 0x05 to byte, 0x20 to byte, 0x05 to byte, 0x21 to byte, 0x02 to byte,
        0x0B to byte,
        0x20 to byte, 0x02 to byte, 0x21 to byte, 0x03 to byte,
        0x05 to byte,
        0x41 to byte, 0x1E to byte, 0x21 to byte, 0x06 to byte, 0x20 to byte, 0x06 to byte, 0x21 to byte, 0x03 to byte,
        0x0B to byte,
        0x20 to byte, 0x03 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (5 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_match_three_arm_chain_matches_wat2wasm_golden —
 * `match k { 0 => 100; 1 => 200; _ => 300 }`: the guard-chain cascade
 * `lower_match_*` builds (§3.1), rendered as the MVP's nested if/else guard
 * chain (design doc §3.3 step 4 — `br_table` is the deferred
 * `C1-brtable-opt`). The shared final merge is dominated by the FIRST
 * guard (`merge_target_of` correctly attributes it there even though it is
 * reached two guards deep). Golden bytes cross-checked against a
 * hand-written `.wat`.
 *
 * @return void
 */
fn stackify_func_match_three_arm_chain_matches_wat2wasm_golden() {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I32)
    mut f = lir::new_func("teko__test__match_chain", 1, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let guard1 = lir::alloc_block(f)
    let arm0 = lir::alloc_block(guard1.func)
    let arm1 = lir::alloc_block(arm0.func)
    let arm2 = lir::alloc_block(arm1.func)
    let mergeb = lir::alloc_block(arm2.func)
    let mp = lir::add_block_param(mergeb.func, mergeb.block_id)
    let c0 = lir::alloc_vreg(mp.func)
    f = lir::append_inst(c0.func, 0, lir::const_int_inst(c0.vreg, 0 to i128, 0, 0))
    let cmp0 = lir::alloc_vreg(f)
    f = lir::append_inst(cmp0.func, 0, lir::bin_inst(cmp0.vreg, lir::LBinOp::ICmpEq, 0, c0.vreg, 0, 0))
    f = lir::append_inst(f, 0, lir::branch_inst(cmp0.vreg, arm0.block_id, teko::list::empty(), guard1.block_id, teko::list::empty(), 0, 0))
    let c1 = lir::alloc_vreg(f)
    f = lir::append_inst(c1.func, guard1.block_id, lir::const_int_inst(c1.vreg, 1 to i128, 0, 0))
    let cmp1 = lir::alloc_vreg(f)
    f = lir::append_inst(cmp1.func, guard1.block_id, lir::bin_inst(cmp1.vreg, lir::LBinOp::ICmpEq, 0, c1.vreg, 0, 0))
    f = lir::append_inst(f, guard1.block_id, lir::branch_inst(cmp1.vreg, arm1.block_id, teko::list::empty(), arm2.block_id, teko::list::empty(), 0, 0))
    let r100 = lir::alloc_vreg(f)
    f = lir::append_inst(r100.func, arm0.block_id, lir::const_int_inst(r100.vreg, 100 to i128, 0, 0))
    f = lir::append_inst(f, arm0.block_id, lir::jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), r100.vreg), 0, 0))
    let r200 = lir::alloc_vreg(f)
    f = lir::append_inst(r200.func, arm1.block_id, lir::const_int_inst(r200.vreg, 200 to i128, 0, 0))
    f = lir::append_inst(f, arm1.block_id, lir::jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), r200.vreg), 0, 0))
    let r300 = lir::alloc_vreg(f)
    f = lir::append_inst(r300.func, arm2.block_id, lir::const_int_inst(r300.vreg, 300 to i128, 0, 0))
    f = lir::append_inst(f, arm2.block_id, lir::jump_inst(mergeb.block_id, teko::list::push(teko::list::empty(), r300.vreg), 0, 0))
    f = lir::append_inst(f, mergeb.block_id, lir::ret_inst(mp.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* Each guard's own `cmp*` (the `ICmpEq` result) is single-use,
     * same-block, LIFO — it rides the stack, dropping its own `local.set`/
     * `local.get` traffic (the fused compare feeding `if` directly). Each
     * guard's own `c*` constant does NOT also elide, even though it is
     * ALSO single-use/same-block: `k` (the match scrutinee) is used TWICE,
     * once per guard, in TWO DIFFERENT blocks — cross-block, so `k` itself
     * stays an ordinary local — and `resolve_inst_operands`' own
     * ALL-OR-NOTHING rule (§5 condition 3) means `cmp*`'s two-operand
     * `eq` can only ride ITS OWN operands off the stack as a matched PAIR;
     * since `k` never rides (cross-block), `c*` is forced back to a local
     * too rather than partially riding alone — a partial ride would
     * silently invert `cmp*`'s two operands relative to each other on the
     * real wasm stack (the miscompile this all-or-nothing rule closes;
     * `eq` is symmetric, so an EARLIER, buggy version of this fixture
     * happened to still assert a byte-correct-looking golden with `c*`
     * wrongly eliding — this is the corrected, order-honest shape). Each
     * arm's own `r100`/`r200`/`r300` stays a local too — its one use is an
     * edge-copy argument into `mergeb`, not a computational consumer. */
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x41 to byte, 0x00 to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x00 to byte, 0x20 to byte, 0x02 to byte, 0x46 to byte,
        0x04 to byte, 0x40 to byte,
        0x41 to byte, 0xE4 to byte, 0x00 to byte, 0x21 to byte, 0x06 to byte, 0x20 to byte, 0x06 to byte, 0x21 to byte, 0x01 to byte,
        0x05 to byte,
        0x41 to byte, 0x01 to byte, 0x21 to byte, 0x04 to byte,
        0x20 to byte, 0x00 to byte, 0x20 to byte, 0x04 to byte, 0x46 to byte,
        0x04 to byte, 0x40 to byte,
        0x41 to byte, 0xC8 to byte, 0x01 to byte, 0x21 to byte, 0x07 to byte, 0x20 to byte, 0x07 to byte, 0x21 to byte, 0x01 to byte,
        0x05 to byte,
        0x41 to byte, 0xAC to byte, 0x02 to byte, 0x21 to byte, 0x08 to byte, 0x20 to byte, 0x08 to byte, 0x21 to byte, 0x01 to byte,
        0x0B to byte,
        0x0B to byte,
        0x20 to byte, 0x01 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (8 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_func_loop_swap_block_args_matches_wat2wasm_golden — a
 * single-block loop whose back-edge feeds `[pb, pa]` into params `[pa,
 * pb]` (a genuine swap): sequential `local.set`s would corrupt it (the
 * second copy would read `pa`'s ALREADY-overwritten value), so `emit_edge_
 * copies`' 2-param path must stage both sources into scratch locals FIRST
 * (§4.3) — proves the parallel-copy fix, not just its 1-param fast path
 * (already exercised by every merge above). Golden bytes cross-checked
 * against a hand-written `.wat`.
 *
 * @return void
 */
fn stackify_func_loop_swap_block_args_matches_wat2wasm_golden() {
    let ptypes = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__test__swap_loop", 3, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(2, 2, 0, 0))
    let headb = lir::alloc_block(f)
    let pa = lir::add_block_param(headb.func, headb.block_id)
    let pb = lir::add_block_param(pa.func, headb.block_id)
    let exitb = lir::alloc_block(pb.func)
    let entry_args = teko::list::push(teko::list::push(teko::list::empty(), 1 to u32), 2 to u32)
    f = lir::append_inst(exitb.func, 0, lir::jump_inst(headb.block_id, entry_args, 0, 0))
    let back_args = teko::list::push(teko::list::push(teko::list::empty(), pb.vreg), pa.vreg)
    f = lir::append_inst(f, headb.block_id, lir::branch_inst(0, exitb.block_id, teko::list::empty(), headb.block_id, back_args, 0, 0))
    f = lir::append_inst(f, exitb.block_id, lir::ret_inst(pa.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x01 to byte,
        0x20 to byte, 0x02 to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x05 to byte,
        0x20 to byte, 0x02 to byte, 0x21 to byte, 0x06 to byte,
        0x20 to byte, 0x05 to byte, 0x21 to byte, 0x03 to byte,
        0x20 to byte, 0x06 to byte, 0x21 to byte, 0x04 to byte,
        0x02 to byte, 0x40 to byte,
        0x03 to byte, 0x40 to byte,
        0x20 to byte, 0x00 to byte,
        0x04 to byte, 0x40 to byte,
        0x0C to byte, 0x02 to byte,
        0x05 to byte,
        0x20 to byte, 0x04 to byte, 0x21 to byte, 0x07 to byte,
        0x20 to byte, 0x03 to byte, 0x21 to byte, 0x08 to byte,
        0x20 to byte, 0x07 to byte, 0x21 to byte, 0x03 to byte,
        0x20 to byte, 0x08 to byte, 0x21 to byte, 0x04 to byte,
        0x0C to byte, 0x01 to byte,
        0x0B to byte,
        0x0B to byte,
        0x0B to byte,
        0x20 to byte, 0x03 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (6 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

/* ==========================================================================
 * C1-3 — the `C1-irreducible` honest-stop, and the smaller defensive/
 * internal-error arms the 100%-coverage ruling's "unreachable arm justified
 * in the PR" exception does NOT need here, since every one below is
 * DIRECTLY testable via a fabricated `LFunc` or a direct call — this file's
 * own established style (`wvt_get_defaults_to_i32_when_unset`).
 * ========================================================================== */

#test
/**
 * stackify_func_irreducible_scc_is_the_c1_irreducible_stop — a fabricated
 * 2-block mutual cycle (`entry` branches to both; each jumps to the
 * other) has no single-header natural loop — a back-edge whose target does
 * NOT dominate its source, the Hecht-Ullman irreducibility test
 * (`is_cfg_irreducible`, §3.4). Unreachable from structured Teko source
 * (§3.1); exercised here directly, by construction, for coverage.
 *
 * @return void
 */
fn stackify_func_irreducible_scc_is_the_c1_irreducible_stop() {
    mut f = lir::new_func("teko__test__scc", 0, teko::list::empty(), lir::LType::Void)
    let b1 = lir::alloc_block(f)
    let b2 = lir::alloc_block(b1.func)
    f = lir::append_inst(b2.func, 0, lir::branch_inst(0, b1.block_id, teko::list::empty(), b2.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::jump_inst(b2.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, b2.block_id, lir::jump_inst(b1.block_id, teko::list::empty(), 0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-irreducible")
    }
}

#test
/**
 * stackify_func_loop_with_two_fresh_exits_is_the_c1_irreducible_stop — a
 * fabricated single-header loop whose two branches each name a DIFFERENT
 * fresh block outside the loop body (never producible by `lower_loop`,
 * whose every `break` targets the SAME `exitb`, §3.3): `render_loop`'s own
 * `relevant.len > 1` belt-and-suspenders check, distinct from the
 * function-wide SCC test above. Exercised here directly for coverage.
 *
 * @return void
 */
fn stackify_func_loop_with_two_fresh_exits_is_the_c1_irreducible_stop() {
    mut f = lir::new_func("teko__test__multi_exit", 0, teko::list::empty(), lir::LType::Void)
    let header = lir::alloc_block(f)
    let chk = lir::alloc_block(header.func)
    let exit_a = lir::alloc_block(chk.func)
    let exit_b = lir::alloc_block(exit_a.func)
    f = lir::append_inst(exit_b.func, 0, lir::jump_inst(header.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, header.block_id, lir::branch_inst(0, exit_a.block_id, teko::list::empty(), chk.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, chk.block_id, lir::branch_inst(0, exit_b.block_id, teko::list::empty(), header.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, exit_a.block_id, lir::ret_void_inst(0, 0))
    f = lir::append_inst(f, exit_b.block_id, lir::ret_void_inst(0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-irreducible")
    }
}

#test
/**
 * stackify_func_loop_with_no_break_has_no_exit_wrap — a loop whose ONLY
 * edge is its own back-edge (no `break` anywhere: `filter_relevant_exits`
 * finds zero exit targets) renders `loop … end` with NO wrapping `block`
 * at all — the `has_exit = false` branch of `render_loop`, distinct from
 * every other fixture above (all of which DO have a wrapping block).
 * `wasm-validate`-clean per a hand-written `.wat` (an infinite loop is
 * valid wasm).
 *
 * @return void
 */
fn stackify_func_loop_with_no_break_has_no_exit_wrap() {
    mut f = lir::new_func("teko__test__inf_loop", 0, teko::list::empty(), lir::LType::Void)
    let headb = lir::alloc_block(f)
    f = lir::append_inst(headb.func, 0, lir::jump_inst(headb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, headb.block_id, lir::jump_inst(headb.block_id, teko::list::empty(), 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [0x03 to byte, 0x40 to byte, 0x0C to byte, 0x00 to byte, 0x0B to byte, 0x0B to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 0)
}

#test
/**
 * emit_edge_copies_arity_mismatch_is_a_named_error — an internal-only
 * defensive bound check: a target's param count must match the edge's own
 * argument count.
 *
 * @return void
 */
fn emit_edge_copies_arity_mismatch_is_a_named_error() {
    let params = teko::list::push(teko::list::empty(), 0 to u32)
    match emit_edge_copies(sft_ctx0(), params, teko::list::empty()) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "arity mismatch")
    }
}

#test
/**
 * stackify_func_block_without_a_real_terminator_is_an_internal_error — a
 * block whose last instruction is neither `LRet`/`LJump`/`LBranch` (here, a
 * bare `LConstInt`) is malformed; `render_terminator`'s dispatch is total
 * over the three real terminator ops, so this is a NAMED internal error,
 * not a silent mis-render.
 *
 * @return void
 */
fn stackify_func_block_without_a_real_terminator_is_an_internal_error() {
    mut f = lir::new_func("teko__test__no_term", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::const_int_inst(r0.vreg, 1 to i128, 0, 0))
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "must end in LRet/LJump/LBranch")
    }
}

#test
/**
 * stackify_func_empty_block_has_no_terminator_is_an_internal_error — a
 * function whose entry block never received a single instruction (a
 * malformed `LFunc`, never produced by `lower_program`) is a NAMED
 * internal error, not an out-of-bounds read.
 *
 * @return void
 */
fn stackify_func_empty_block_has_no_terminator_is_an_internal_error() {
    let f = lir::new_func("teko__test__empty_block", 0, teko::list::empty(), lir::LType::Void)
    match stackify_func(f, wasm_symtab_empty(), false) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "has no terminator")
    }
}

#test
/**
 * filter_relevant_exits_excludes_already_open_and_stop_matches — an exit
 * target already open as an ancestor scope, and one equal to the caller's
 * own `stop`, are BOTH excluded (neither needs THIS loop's own wrap); a
 * genuinely fresh target survives the filter.
 *
 * @return void
 */
fn filter_relevant_exits_excludes_already_open_and_stop_matches() {
    let scopes = wasm_scope_stack_push(teko::list::empty(), WasmScopeKind::Block, 5 to u32)
    let exits = teko::list::push(teko::list::push(teko::list::empty(), 5 to u32), 9 to u32)
    let excluded = filter_relevant_exits(exits, scopes, edge_stop_at(9 to u32))
    teko::assert::is_true(excluded.len == 0)
    let survives = filter_relevant_exits(teko::list::push(teko::list::empty(), 7 to u32), teko::list::empty(), edge_stop_none())
    teko::assert::is_true(survives.len == 1)
    teko::assert::is_true(survives[0] == (7 to u32))
}

#test
/**
 * u32_table_get_defaults_to_zero_when_out_of_range — the defensive
 * out-of-range default (never reached from a table sized to the function's
 * own block count).
 *
 * @return void
 */
fn u32_table_get_defaults_to_zero_when_out_of_range() {
    teko::assert::is_true(u32_table_get(teko::list::empty(), 5 to u32) == (0 to u32))
}

#test
/**
 * u32_pos_defaults_to_order_len_when_absent — the defensive "absent target
 * sorts last" default (never reached: every id this file queries `u32_pos`
 * with comes from a block the RPO order itself was built from, or one of
 * its own reachable successors).
 *
 * @return void
 */
fn u32_pos_defaults_to_order_len_when_absent() {
    let order = teko::list::push(teko::list::empty(), 0 to u32)
    teko::assert::is_true(u32_pos(order, 9 to u32) == (order.len to u32))
}

#test
/**
 * first_processed_pred_returns_not_found_when_none_processed — the
 * fixpoint seed-search's own empty case (provably unreachable from any
 * block reachable from `entry` in a real RPO-ordered sweep, since RPO
 * guarantees a forward predecessor always precedes it in the SAME pass;
 * exercised directly, by construction, for coverage).
 *
 * @return void
 */
fn first_processed_pred_returns_not_found_when_none_processed() {
    let idom = idom_table_init(2, 0 to u32)
    let ps = teko::list::push(teko::list::empty(), 1 to u32)
    let r = first_processed_pred(ps, idom)
    teko::assert::is_true(!r.found)
}

#test
/**
 * wasm_scope_stack_pop_on_empty_stays_empty — the defensive "nothing to
 * close" default (never reached: `sc_close_scope` only ever follows a
 * matching `sc_open_*`).
 *
 * @return void
 */
fn wasm_scope_stack_pop_on_empty_stays_empty() {
    teko::assert::is_true(wasm_scope_stack_pop(teko::list::empty()).len == 0)
}

#test
/**
 * stackify_inst_ret_is_internal_misuse — a return terminator is now ALSO
 * routed exclusively through `render_terminator` (mirroring `LJump`/
 * `LBranch`); reaching it through the per-instruction `stackify_inst` is a
 * caller misuse.
 *
 * @return void
 */
fn stackify_inst_ret_is_internal_misuse() {
    let r = lir::ret_void_inst(0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), r, false) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "internal misuse")
    }
}

#test
/**
 * lir_block_search_defaults_to_first_block_when_id_absent — the defensive
 * fallback for a malformed `LFunc` whose block ids skip a value (never
 * produced by `alloc_block`'s own dense-id contract; exercised directly, by
 * construction, since this file's own style does not blind-trust that
 * contract, §3.2).
 *
 * @return void
 */
fn lir_block_search_defaults_to_first_block_when_id_absent() {
    let b0 = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = teko::list::empty() }
    let b5 = lir::LBlock { id = 5 to u32; params = teko::list::empty(); insts = teko::list::empty() }
    let f = lir::LFunc {
        symbol = "teko__test__gappy"; n_params = 0 to u32; param_types = teko::list::empty()
        ret_type = lir::LType::Void; blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b5); next_vreg = 0 to u32
    }
    let found = lir_block_search(f, 1 to u32)
    teko::assert::is_true(found.id == (0 to u32))
}

#test
/**
 * all_but_last_of_empty_list_is_empty — the empty-input ternary arm
 * (`render_straight` never calls this with an empty block, having already
 * guarded that case itself; exercised directly for coverage).
 *
 * @return void
 */
fn all_but_last_of_empty_list_is_empty() {
    teko::assert::is_true(all_but_last(teko::list::empty()).len == 0)
}

#test
/**
 * stackify_control_rejects_a_function_with_no_blocks — a malformed `LFunc`
