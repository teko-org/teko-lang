#test
/**
 * stackify_bin_arithmetic_inherits_operand_a_type — the design doc's own
 * `IAdd` worked example (§4.4), and the result's wasm valtype inherited
 * from operand `a` (here `i64`, so the wide opcode `0x7C` is selected).
 *
 * @return void
 */
fn stackify_bin_arithmetic_inherits_operand_a_type() {
    let ctx0 = sc_set_vtype(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), 1, wasm_vt_i64())
    let inst = lir::bin_inst(2, lir::LBinOp::IAdd, 0, 1, 0, 0)
    let out = stackify_bin(ctx0, inst, lir::LBin { op = lir::LBinOp::IAdd; a = 0; b = 1 })
    let want = [0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x7C to byte, 0x21 to byte, 0x02 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 2) == wasm_vt_i64())
}

#test
/**
 * stackify_bin_compare_result_is_always_i32 — a compare over `i64` operands
 * still records an `i32` result valtype (mirrors `isel_arm64.tks`'s own
 * always-narrow compare result).
 *
 * @return void
 */
fn stackify_bin_compare_result_is_always_i32() {
    let ctx0 = sc_set_vtype(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), 1, wasm_vt_i64())
    let inst = lir::bin_inst(2, lir::LBinOp::ICmpLtS, 0, 1, 0, 0)
    let out = stackify_bin(ctx0, inst, lir::LBin { op = lir::LBinOp::ICmpLtS; a = 0; b = 1 })
    teko::assert::is_true(wvt_get(out.vtypes, 2) == wasm_vt_i32())
}

#test
/**
 * stackify_ineg_narrow_and_wide — `INeg` renders as `0 - a` at both widths
 * (`backend-c1-wasm.md` §4.4's worked example).
 *
 * @return void
 */
fn stackify_ineg_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i32()), lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::INeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x41 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x6B to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(narrow_out.vtypes, 1) == wasm_vt_i32())
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::INeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x42 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x7D to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(wide_out.vtypes, 1) == wasm_vt_i64())
}

#test
/**
 * stackify_inot_narrow_and_wide — `INot` renders as `a XOR -1` at both
 * widths (`backend-c1-wasm.md` §4.4's worked example).
 *
 * @return void
 */
fn stackify_inot_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i32()), lir::un_inst(1, lir::LUnOp::INot, 0, 0, 0), lir::LUn { op = lir::LUnOp::INot; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x41 to byte, 0x7F to byte, 0x20 to byte, 0x00 to byte, 0x73 to byte, 0x21 to byte, 0x01 to byte]))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), lir::un_inst(1, lir::LUnOp::INot, 0, 0, 0), lir::LUn { op = lir::LUnOp::INot; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x42 to byte, 0x7F to byte, 0x20 to byte, 0x00 to byte, 0x85 to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_fneg_narrow_and_wide — `FNeg` selects `f32.neg`/`f64.neg` by
 * operand width.
 *
 * @return void
 */
fn stackify_fneg_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_f32()), lir::un_inst(1, lir::LUnOp::FNeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::FNeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x20 to byte, 0x00 to byte, 0x8C to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(narrow_out.vtypes, 1) == wasm_vt_f32())
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_f64()), lir::un_inst(1, lir::LUnOp::FNeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::FNeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x20 to byte, 0x00 to byte, 0x9A to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(wide_out.vtypes, 1) == wasm_vt_f64())
}

#test
/**
 * stackify_trunc_from_i32_is_identity_from_i64_wraps — `Trunc` always
 * yields `i32`; an already-`i32` operand is a plain copy, an `i64` operand
 * needs the real `i32.wrap_i64`.
 *
 * @return void
 */
fn stackify_trunc_from_i32_is_identity_from_i64_wraps() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i32()), lir::un_inst(1, lir::LUnOp::Trunc, 0, 0, 0), lir::LUn { op = lir::LUnOp::Trunc; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vt_i32())
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), lir::un_inst(1, lir::LUnOp::Trunc, 0, 0, 0), lir::LUn { op = lir::LUnOp::Trunc; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xA7 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from64.vtypes, 1) == wasm_vt_i32())
}

#test
/**
 * stackify_zext_and_sext_are_identity_at_operand_width — `ZExt`/`SExt` both
 * lower to a plain local-to-local copy at the operand's own width (the LIR
 * carries no further per-value width information, mirroring
 * `isel_arm64.tks`'s own `select_identity_mov` treatment).
 *
 * @return void
 */
fn stackify_zext_and_sext_are_identity_at_operand_width() {
    let zext_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i32()), lir::un_inst(1, lir::LUnOp::ZExt, 0, 0, 0), lir::LUn { op = lir::LUnOp::ZExt; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(zext_out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(zext_out.vtypes, 1) == wasm_vt_i32())
    let sext_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), lir::un_inst(1, lir::LUnOp::SExt, 0, 0, 0), lir::LUn { op = lir::LUnOp::SExt; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(sext_out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(sext_out.vtypes, 1) == wasm_vt_i64())
}

#test
/**
 * stackify_itof_from_i32_and_i64 — `IToF` always yields `f64`, its source
 * opcode selected by the operand's own integer width.
 *
 * @return void
 */
fn stackify_itof_from_i32_and_i64() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i32()), lir::un_inst(1, lir::LUnOp::IToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::IToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0xB7 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vt_f64())
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_i64()), lir::un_inst(1, lir::LUnOp::IToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::IToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xB9 to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_ftoi_from_f32_and_f64 — `FToI` always yields `i32`, its source
 * opcode selected by the operand's own float width.
 *
 * @return void
 */
fn stackify_ftoi_from_f32_and_f64() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_f32()), lir::un_inst(1, lir::LUnOp::FToI, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToI; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0xA8 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vt_i32())
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_f64()), lir::un_inst(1, lir::LUnOp::FToI, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToI; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xAA to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_ftof_demotes_from_f64_promotes_from_f32 — `FToF` is the one case
 * whose result width is the OPPOSITE of the operand's.
 *
 * @return void
 */
fn stackify_ftof_demotes_from_f64_promotes_from_f32() {
    let demote_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_f64()), lir::un_inst(1, lir::LUnOp::FToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(demote_out.body, [0x20 to byte, 0x00 to byte, 0xB6 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(demote_out.vtypes, 1) == wasm_vt_f32())
    let promote_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vt_f32()), lir::un_inst(1, lir::LUnOp::FToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(promote_out.body, [0x20 to byte, 0x00 to byte, 0xBB to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(promote_out.vtypes, 1) == wasm_vt_f64())
}

/**
 * sft_one_i32_param — a fresh 1-param (`I32`) -> `I32` function named `sym`.
 *
 * @param str sym  the function's symbol
 * @return lir::LFunc  the seeded function
 */
fn sft_one_i32_param(sym: str) -> lir::LFunc {
    lir::new_func(sym, 1, teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32)
}

#test
/**
 * stackify_param_reads_its_own_local_index — `LParam{index}` always defines
 * VReg `index`, so the copy is redundant-but-correct: `local.get $index;
 * local.set $index`.
 *
 * @return void
 */
fn stackify_param_reads_its_own_local_index() {
    let f = sft_one_i32_param("teko__test__p")
    let inst = lir::param_inst(0, 0, 0, 0)
    let out = match stackify_param(sft_ctx0(), f, inst, lir::LParam { index = 0 }) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 0) == wasm_vt_i32())
}

#test
/**
 * stackify_param_index_out_of_range_is_a_named_error — an internal-only
 * defensive bound check.
 *
 * @return void
 */
fn stackify_param_index_out_of_range_is_a_named_error() {
    let f = sft_one_i32_param("teko__test__p2")
    let inst = lir::param_inst(0, 5, 0, 0)
    match stackify_param(sft_ctx0(), f, inst, lir::LParam { index = 5 }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "out of range")
    }
}

#test
/**
 * stackify_param_i128_propagates_the_c1_i128_stop — an `I128` parameter
 * type propagates `wasm_valtype`'s honest-stop.
 *
 * @return void
 */
fn stackify_param_i128_propagates_the_c1_i128_stop() {
    let f = lir::new_func("teko__test__pi128", 1, teko::list::push(teko::list::empty(), lir::LType::I128), lir::LType::Void)
    let inst = lir::param_inst(0, 0, 0, 0)
    match stackify_param(sft_ctx0(), f, inst, lir::LParam { index = 0 }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

#test
/**
 * stackify_ret_with_value_pushes_then_returns — a value-carrying `LRet`.
 *
 * @return void
 */
fn stackify_ret_with_value_pushes_then_returns() {
    let ctx0 = sc_set_vtype(sft_ctx0(), 3, wasm_vt_i32())
    let out = stackify_ret(ctx0, lir::LRet { has_value = true; value = 3 })
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x20 to byte, 0x03 to byte, 0x0F to byte]))
}

#test
/**
 * stackify_ret_void_just_returns — a void `LRet`.
 *
 * @return void
 */
fn stackify_ret_void_just_returns() {
    let out = stackify_ret(sft_ctx0(), lir::LRet { has_value = false; value = 0 })
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x0F to byte]))
}

#test
/**
 * stackify_field_addr_computes_base_plus_offset — `local.get base; i32.const
 * offset; i32.add; local.set r`.
 *
 * @return void
 */
fn stackify_field_addr_computes_base_plus_offset() {
    let inst = lir::field_addr_inst(1, 0, 8, 0, 0)
    let out = stackify_field_addr(sft_ctx0(), inst, lir::LFieldAddr { base = 0; offset = 8 })
    let want = [0x20 to byte, 0x00 to byte, 0x41 to byte, 0x08 to byte, 0x6A to byte, 0x21 to byte, 0x01 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 1) == wasm_vt_i32())
}

#test
/**
 * stackify_load_i32_matches_design_doc_golden — the design doc's own worked
 * example (§12.1): `LLoad{I32} -> local.get addr; i32.load align,off;
 * local.set r`.
 *
 * @return void
 */
fn stackify_load_i32_matches_design_doc_golden() {
    let inst = lir::load_inst(1, 0, lir::LType::I32, 0, 0)
    let out = match stackify_load(sft_ctx0(), inst, lir::LLoad { addr = 0; ty = lir::LType::I32 }) { StackifyCtx as x => x; error => return }
    let want = [0x20 to byte, 0x00 to byte, 0x28 to byte, 0x02 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 1) == wasm_vt_i32())
}

#test
/**
 * stackify_load_i128_propagates_the_c1_i128_stop.
 *
 * @return void
 */
fn stackify_load_i128_propagates_the_c1_i128_stop() {
    let inst = lir::load_inst(1, 0, lir::LType::I128, 0, 0)
    match stackify_load(sft_ctx0(), inst, lir::LLoad { addr = 0; ty = lir::LType::I128 }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

#test
/**
 * stackify_store_i64_matches_expected_bytes — `local.get addr; local.get
 * value; i64.store align,off`.
 *
 * @return void
 */
fn stackify_store_i64_matches_expected_bytes() {
    let out = match stackify_store(sft_ctx0(), lir::LStore { addr = 0; value = 1; ty = lir::LType::I64 }) { StackifyCtx as x => x; error => return }
    let want = [0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x37 to byte, 0x03 to byte, 0x00 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * stackify_store_f16_propagates_the_c1_f16_stop.
 *
 * @return void
 */
fn stackify_store_f16_propagates_the_c1_f16_stop() {
    match stackify_store(sft_ctx0(), lir::LStore { addr = 0; value = 1; ty = lir::LType::F16 }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-f16")
    }
}

/**
 * sft_void_target — a `WasmCallTarget` for a `Void`-returning callee at
 * funcidx `3`.
 *
 * @return WasmCallTarget  the target
 */
fn sft_void_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 3 to u32; ret_type = lir::LType::Void }
}

/**
 * sft_i32_target — a `WasmCallTarget` for an `I32`-returning callee at
 * funcidx `5`.
 *
 * @return WasmCallTarget  the target
 */
fn sft_i32_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 5 to u32; ret_type = lir::LType::I32 }
}

/**
 * sft_i128_target — a `WasmCallTarget` for an `I128`-returning callee (a
 * genuinely unrepresentable wasm return type, at funcidx `7`).
 *
 * @return WasmCallTarget  the target
 */
fn sft_i128_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 7 to u32; ret_type = lir::LType::I128 }
}

#test
/**
 * wasm_symtab_add_then_resolve_round_trips — the resolver table's basic
 * register/lookup contract.
 *
 * @return void
 */
fn wasm_symtab_add_then_resolve_round_trips() {
    let t = wasm_symtab_add(wasm_symtab_empty(), "tk_exit", sft_void_target())
    match wasm_resolve_call(t, "tk_exit") {
        WasmCallTarget as target => teko::assert::is_true(target.func_index == (3 to u32))
        error => teko::assert::is_true(false)
    }
}

#test
/**
 * stackify_call_void_matches_design_doc_golden — the design doc's own
 * worked example (§12.1): `LCall{tk_exit} -> local.get arg; call funcidx`.
 *
 * @return void
 */
fn stackify_call_void_matches_design_doc_golden() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "tk_exit", sft_void_target())
    let args = teko::list::push(teko::list::empty(), 0 to u32)
    let inst = lir::void_call_inst("tk_exit", args, false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "tk_exit"; args = args; variadic = false }) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x20 to byte, 0x00 to byte, 0x10 to byte, 0x03 to byte]))
}

#test
/**
 * stackify_call_captures_a_value_result — a value-returning callee whose
 * caller captures the result into its own local.
 *
 * @return void
 */
fn stackify_call_captures_a_value_result() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__f", sft_i32_target())
    let inst = lir::call_inst(9, "teko__demo__f", teko::list::empty(), false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__f"; args = teko::list::empty(); variadic = false }) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x10 to byte, 0x05 to byte, 0x21 to byte, 0x09 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 9) == wasm_vt_i32())
}

#test
/**
 * stackify_call_drops_a_discarded_value_result — a value-returning callee
 * called at statement level (the result unused) drops it to keep the
 * operand stack balanced.
 *
 * @return void
 */
fn stackify_call_drops_a_discarded_value_result() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__f", sft_i32_target())
    let inst = lir::void_call_inst("teko__demo__f", teko::list::empty(), false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__f"; args = teko::list::empty(); variadic = false }) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x10 to byte, 0x05 to byte, 0x1A to byte]))
}

#test
/**
 * stackify_call_unresolved_symbol_is_a_named_error — a symbol the caller
 * never registered.
 *
 * @return void
 */
fn stackify_call_unresolved_symbol_is_a_named_error() {
    let inst = lir::void_call_inst("teko__missing__f", teko::list::empty(), false, 0, 0)
    match stackify_call(sft_ctx0(), wasm_symtab_empty(), inst, lir::LCall { symbol = "teko__missing__f"; args = teko::list::empty(); variadic = false }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "unresolved call symbol")
    }
}

#test
/**
 * stackify_call_i128_return_propagates_the_c1_i128_stop — a callee whose
 * return type has no wasm valtype.
 *
 * @return void
 */
fn stackify_call_i128_return_propagates_the_c1_i128_stop() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__big", sft_i128_target())
    let inst = lir::void_call_inst("teko__demo__big", teko::list::empty(), false, 0, 0)
    match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__big"; args = teko::list::empty(); variadic = false }) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-i128")
    }
}

/**
 * sft_empty_func — a fresh 0-param, `Void`-returning function (a throwaway
 * `f`/dispatch fixture for ops that never read it).
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_empty_func() -> lir::LFunc {
    lir::new_func("teko__test__dispatch", 0, teko::list::empty(), lir::LType::Void)
}

#test
/**
 * stackify_inst_jump_and_branch_are_the_c1_3_stop — inter-block control
 * flow is out of C1-2's scope.
 *
 * @return void
 */
fn stackify_inst_jump_and_branch_are_the_c1_3_stop() {
    let jump = lir::jump_inst(1, teko::list::empty(), 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), jump) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-3")
    }
    let branch = lir::branch_inst(0, 1, teko::list::empty(), 2, teko::list::empty(), 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), branch) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-3")
    }
}

#test
/**
 * stackify_inst_alloca_and_global_addr_are_the_c1_4_stop — the
 * shadow-stack/rodata linear-memory layout is out of C1-2's scope.
 *
 * @return void
 */
fn stackify_inst_alloca_and_global_addr_are_the_c1_4_stop() {
    let alloca = lir::alloca_inst(0, 8, 8, 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), alloca) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-alloca")
    }
    let global_addr = lir::global_addr_inst(0, "teko__rodata__0", 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), global_addr) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-globaladdr")
    }
}

#test
/**
 * stackify_inst_call_indirect_and_func_addr_are_the_c1_4_5_stop — the wasm
 * funcref table is out of C1-2's scope.
 *
 * @return void
 */
fn stackify_inst_call_indirect_and_func_addr_are_the_c1_4_5_stop() {
    let call_indirect = lir::void_call_indirect_inst(0, teko::list::empty(), false, 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), call_indirect) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-callindirect")
    }
    let func_addr = lir::func_addr_inst(0, "teko__demo__f", 0, 0)
    match stackify_inst(sft_ctx0(), sft_empty_func(), wasm_symtab_empty(), func_addr) {
        StackifyCtx => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-funcaddr")
    }
}

#test
/**
 * stackify_func_multi_block_is_the_c1_3_required_stop — `stackify_func`
 * refuses (rather than silently drops) a function with more than one block.
 *
 * @return void
 */
fn stackify_func_multi_block_is_the_c1_3_required_stop() {
    let extra = lir::alloc_block(sft_empty_func())
    match stackify_func(extra.func, wasm_symtab_empty()) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-3-required")
    }
}

#test
/**
 * stackify_func_straight_line_add_matches_golden_bytes — the design doc's
 * own end-to-end shape: `fn add(a, b) { a + b }`, byte-for-byte.
 *
 * @return void
 */
fn stackify_func_straight_line_add_matches_golden_bytes() {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__demo__add", 2, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    let r = lir::alloc_vreg(f)
    f = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, lir::LBinOp::IAdd, 0, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_inst(r.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty()) { WasmFuncBody as x => x; error => return }
    let want_body = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x01 to byte,
        0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x6A to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x02 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want_body))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (1 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vt_i32())
}

#test
/**
 * stackify_func_no_locals_when_no_non_param_vregs — a body that defines no
 * VReg beyond its params declares zero locals.
 *
 * @return void
 */
fn stackify_func_no_locals_when_no_non_param_vregs() {
    mut f = lir::new_func("teko__test__void", 0, teko::list::empty(), lir::LType::Void)
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty()) { WasmFuncBody as x => x; error => return }
    teko::assert::is_true(out.local_groups.len == 0)
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x0F to byte, 0x0B to byte]))
}

#test
/**
 * stackify_func_local_groups_merge_consecutive_same_type — two
 * consecutive `i32` locals compress into one run-length group.
 *
 * @return void
 */
fn stackify_func_local_groups_merge_consecutive_same_type() {
    mut f = lir::new_func("teko__test__same", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::const_int_inst(r0.vreg, 1 to i128, 0, 0))
    let r1 = lir::alloc_vreg(f)
    f = lir::append_inst(r1.func, 0, lir::const_int_inst(r1.vreg, 2 to i128, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty()) { WasmFuncBody as x => x; error => return }
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (2 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vt_i32())
}

#test
/**
 * stackify_func_local_groups_split_on_a_type_change — an `i32`/`i64`/`i32`
 * VReg sequence run-length-splits into three groups.
 *
 * @return void
 */
fn stackify_func_local_groups_split_on_a_type_change() {
    mut f = lir::new_func("teko__test__mixed", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::const_int_inst(r0.vreg, 1 to i128, 0, 0))
    let r1 = lir::alloc_vreg(f)
    f = lir::append_inst(r1.func, 0, lir::const_int_inst(r1.vreg, 5000000000 to i128, 0, 0))
    let r2 = lir::alloc_vreg(f)
    f = lir::append_inst(r2.func, 0, lir::const_int_inst(r2.vreg, 2 to i128, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty()) { WasmFuncBody as x => x; error => return }
    teko::assert::is_true(out.local_groups.len == 3)
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vt_i32())
    teko::assert::is_true(out.local_groups[1].valtype == wasm_vt_i64())
    teko::assert::is_true(out.local_groups[2].valtype == wasm_vt_i32())
}

#test
/**
 * wvt_get_defaults_to_i32_when_unset — the defensive out-of-range default
 * (never reached from valid, def-before-use SSA input, but named and tested
 * directly).
 *
 * @return void
 */
fn wvt_get_defaults_to_i32_when_unset() {
    teko::assert::is_true(wvt_get(wvt_empty(), 0) == wasm_vt_i32())
}

#test
/**
 * stackify_inst_dispatches_every_remaining_straight_line_case —
 * `LConstFloat`/`LUn`/`LFieldAddr`/`LLoad`/`LStore`/`LCall` through the
 * TOP-LEVEL `stackify_inst` dispatcher itself (their own lowering functions
 * are covered directly by the dedicated tests above; this exercises the
 * dispatch match arm that routes to each).
 *
 * @return void
 */
fn stackify_inst_dispatches_every_remaining_straight_line_case() {
    let f = sft_empty_func()
    let float_inst = lir::const_float_inst(0, 0x3FF0000000000000 to u64, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), float_inst) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let un_ctx = sc_set_vtype(sft_ctx0(), 0, wasm_vt_i32())
    let un_inst = lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0)
    match stackify_inst(un_ctx, f, wasm_symtab_empty(), un_inst) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let field_addr_inst = lir::field_addr_inst(1, 0, 4, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), field_addr_inst) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let load_inst = lir::load_inst(1, 0, lir::LType::I32, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), load_inst) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let store_inst = lir::store_inst(0, 1, lir::LType::I32, 0, 0)
    match stackify_inst(sft_ctx0(), f, wasm_symtab_empty(), store_inst) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
    let call_symbols = wasm_symtab_add(wasm_symtab_empty(), "tk_exit", sft_void_target())
    let call_inst = lir::void_call_inst("tk_exit", teko::list::empty(), false, 0, 0)
    match stackify_inst(sft_ctx0(), f, call_symbols, call_inst) {
        StackifyCtx => { }
        error => teko::assert::is_true(false)
    }
}

#test
/**
 * stackify_func_propagates_a_mid_stream_instruction_error — a later
 * instruction's own honest-stop short-circuits `stackify_insts` and
 * propagates through `stackify_func` unchanged, rather than lowering the
 * rest of the stream regardless.
 *
 * @return void
 */
fn stackify_func_propagates_a_mid_stream_instruction_error() {
    mut f = lir::new_func("teko__test__alloca_mid", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::alloca_inst(r0.vreg, 8, 8, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    match stackify_func(f, wasm_symtab_empty()) {
        WasmFuncBody => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "C1-alloca")
    }
}
