#test
/**
 * stackify_ineg_narrow_and_wide — `INeg` renders as `0 - a` at both widths
 * (`backend-c1-wasm.md` §4.4's worked example).
 *
 * @return void
 */
fn stackify_ineg_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::INeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x41 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x6B to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(narrow_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::INeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::INeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x42 to byte, 0x00 to byte, 0x20 to byte, 0x00 to byte, 0x7D to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(wide_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_inot_narrow_and_wide — `INot` renders as `a XOR -1` at both
 * widths (`backend-c1-wasm.md` §4.4's worked example).
 *
 * @return void
 */
fn stackify_inot_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::INot, 0, 0, 0), lir::LUn { op = lir::LUnOp::INot; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x41 to byte, 0x7F to byte, 0x20 to byte, 0x00 to byte, 0x73 to byte, 0x21 to byte, 0x01 to byte]))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::INot, 0, 0, 0), lir::LUn { op = lir::LUnOp::INot; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x42 to byte, 0x7F to byte, 0x20 to byte, 0x00 to byte, 0x85 to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_fneg_narrow_and_wide — `FNeg` selects `f32.neg`/`f64.neg` by
 * operand width.
 *
 * @return void
 */
fn stackify_fneg_narrow_and_wide() {
    let narrow_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F32)), lir::un_inst(1, lir::LUnOp::FNeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::FNeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(narrow_out.body, [0x20 to byte, 0x00 to byte, 0x8C to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(narrow_out.vtypes, 1) == wasm_vtype_wire(WasmVType::F32))
    let wide_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F64)), lir::un_inst(1, lir::LUnOp::FNeg, 0, 0, 0), lir::LUn { op = lir::LUnOp::FNeg; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(wide_out.body, [0x20 to byte, 0x00 to byte, 0x9A to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(wide_out.vtypes, 1) == wasm_vtype_wire(WasmVType::F64))
}

#test
/**
 * stackify_trunc_from_i32_is_identity_from_i64_wraps — `Trunc` always
 * yields `i32`; an already-`i32` operand is a plain copy, an `i64` operand
 * needs the real `i32.wrap_i64`.
 *
 * @return void
 */
fn stackify_trunc_from_i32_is_identity_from_i64_wraps() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::Trunc, 0, 0, 0), lir::LUn { op = lir::LUnOp::Trunc; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::Trunc, 0, 0, 0), lir::LUn { op = lir::LUnOp::Trunc; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xA7 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from64.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_zext_and_sext_are_identity_at_operand_width — `ZExt`/`SExt` both
 * lower to a plain local-to-local copy at the operand's own width (the LIR
 * carries no further per-value width information, mirroring
 * `isel_arm64.tks`'s own `select_identity_mov` treatment).
 *
 * @return void
 */
fn stackify_zext_and_sext_are_identity_at_operand_width() {
    let zext_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::ZExt, 0, 0, 0), lir::LUn { op = lir::LUnOp::ZExt; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(zext_out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(zext_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let sext_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::SExt, 0, 0, 0), lir::LUn { op = lir::LUnOp::SExt; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(sext_out.body, [0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(sext_out.vtypes, 1) == wasm_vtype_wire(WasmVType::I64))
}

#test
/**
 * stackify_itof_from_i32_and_i64 — `IToF` always yields `f64`, its source
 * opcode selected by the operand's own integer width.
 *
 * @return void
 */
fn stackify_itof_from_i32_and_i64() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I32)), lir::un_inst(1, lir::LUnOp::IToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::IToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0xB7 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vtype_wire(WasmVType::F64))
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::I64)), lir::un_inst(1, lir::LUnOp::IToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::IToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xB9 to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_ftoi_from_f32_and_f64 — `FToI` always yields `i32`, its source
 * opcode selected by the operand's own float width.
 *
 * @return void
 */
fn stackify_ftoi_from_f32_and_f64() {
    let from32 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F32)), lir::un_inst(1, lir::LUnOp::FToI, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToI; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from32.body, [0x20 to byte, 0x00 to byte, 0xA8 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(from32.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
    let from64 = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F64)), lir::un_inst(1, lir::LUnOp::FToI, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToI; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(from64.body, [0x20 to byte, 0x00 to byte, 0xAA to byte, 0x21 to byte, 0x01 to byte]))
}

#test
/**
 * stackify_ftof_demotes_from_f64_promotes_from_f32 — `FToF` is the one case
 * whose result width is the OPPOSITE of the operand's.
 *
 * @return void
 */
fn stackify_ftof_demotes_from_f64_promotes_from_f32() {
    let demote_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F64)), lir::un_inst(1, lir::LUnOp::FToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(demote_out.body, [0x20 to byte, 0x00 to byte, 0xB6 to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(demote_out.vtypes, 1) == wasm_vtype_wire(WasmVType::F32))
    let promote_out = stackify_un(sc_set_vtype(sft_ctx0(), 0, wasm_vtype_wire(WasmVType::F32)), lir::un_inst(1, lir::LUnOp::FToF, 0, 0, 0), lir::LUn { op = lir::LUnOp::FToF; a = 0 })
    teko::assert::is_true(wasm_bytes_eq(promote_out.body, [0x20 to byte, 0x00 to byte, 0xBB to byte, 0x21 to byte, 0x01 to byte]))
    teko::assert::is_true(wvt_get(promote_out.vtypes, 1) == wasm_vtype_wire(WasmVType::F64))
}

/**
 * sft_panic_symtab — a `WasmSymbolTable` with `tk_panic_str` registered at
 * funcidx `5` — `stackify_narrow_ptr_load`'s own resolver fixture (#389
 * C1-7).
 *
 * @return WasmSymbolTable  the table
 */
fn sft_panic_symtab() -> WasmSymbolTable {
    wasm_symtab_add(wasm_symtab_empty(), "tk_panic_str", WasmCallTarget { func_index = 5 to u32; ret_type = lir::LType::Void })
}

/**
 * sft_ctx_scratch_at — a fresh `StackifyCtx` exactly like `sft_ctx0`, except
 * its `next_scratch` starts at `n` — used by the checked-narrow tests so the
 * reserved scratch local (`sc_alloc_scratch`) never collides with the
 * instruction's own `addr`/`result` VRegs (a real function always seeds
 * `next_scratch` at `f.next_vreg`, past every real VReg; this fixture
 * mirrors that for a hand-built, real-function-free unit test).
 *
 * @param u32 n  the starting scratch id
 * @return StackifyCtx  the empty context, scratch allocation starting at `n`
 */
fn sft_ctx_scratch_at(n: u32) -> StackifyCtx {
    StackifyCtx { body = teko::list::empty(); vtypes = wvt_empty(); scopes = teko::list::empty(); next_scratch = n; has_frame = false; frame_base = 0 to u32; slots = wst_empty(); elide = et_empty(); pending = teko::list::empty() }
}

#test
/**
 * stackify_load_ptr_wasm32_checked_narrows — the wasm32 (`ptr64 = false`)
 * `Ptr`-typed `LLoad` (#389 C1-7, `backend-wasm.md` §6): `local.get addr;
 * i64.load align=3,off=0` (the on-disk shape is ALWAYS `i64`, `wasm_mem_
 * op`), then the checked-narrow tail (`stackify_narrow_ptr_load`, hand-
 * traced): `local.tee $scratch; i64.const 2^32; i64.ge_u; if (then i32.const
 * msg_addr; i32.const msg_len; call $panic; unreachable); local.get
 * $scratch; i32.wrap_i64`, and finally `local.set $result` (the result's
 * own valtype is `i32`, matching `wasm_valtype(Ptr, false)`).
 *
 * @return void
 */
fn stackify_load_ptr_wasm32_checked_narrows() {
    let inst = lir::load_inst(1, 0, lir::LType::Ptr, 0, 0)
    let ctx0 = sft_ctx_scratch_at(2 to u32)
    let out = match stackify_load(ctx0, inst, lir::LLoad { addr = 0; ty = lir::LType::Ptr }, false, sft_panic_symtab()) { StackifyCtx as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte,
        0x29 to byte, 0x03 to byte, 0x00 to byte,
        0x22 to byte, 0x02 to byte,
        0x42 to byte, 0x80 to byte, 0x80 to byte, 0x80 to byte, 0x80 to byte, 0x10 to byte,
        0x5A to byte,
        0x04 to byte, 0x40 to byte,
        0x41 to byte, 0x10 to byte,
        0x41 to byte, 0x2A to byte,
        0x10 to byte, 0x05 to byte,
        0x00 to byte,
        0x0B to byte,
        0x20 to byte, 0x02 to byte,
        0xA7 to byte,
        0x21 to byte, 0x01 to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(wvt_get(out.vtypes, 1) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_store_ptr_wasm32_widens_before_storing — the wasm32 (`ptr64 =
 * false`) `Ptr`-typed `LStore` (#389 C1-7, §6): the `i32` register value is
 * `i64.extend_i32_u`-widened (always lossless — an in-range wasm32 address
 * is never negative) before the `i64.store` (the on-disk shape is ALWAYS
 * `i64`): `local.get addr; local.get value; i64.extend_i32_u; i64.store
 * align=3,off=0`.
 *
 * @return void
 */
fn stackify_store_ptr_wasm32_widens_before_storing() {
    let out = match stackify_store(sft_ctx0(), lir::LStore { addr = 0; value = 1; ty = lir::LType::Ptr }, false) { StackifyCtx as x => x; error => return }
    let want = [0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0xAD to byte, 0x37 to byte, 0x03 to byte, 0x00 to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

/**
 * sft_void_target — a `WasmCallTarget` for a `Void`-returning callee at
 * funcidx `3`.
 *
 * @return WasmCallTarget  the target
 */
fn sft_void_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 3 to u32; ret_type = lir::LType::Void }
}

/**
 * sft_i32_target — a `WasmCallTarget` for an `I32`-returning callee at
 * funcidx `5`.
 *
 * @return WasmCallTarget  the target
 */
fn sft_i32_target() -> WasmCallTarget {
    WasmCallTarget { func_index = 5 to u32; ret_type = lir::LType::I32 }
}

#test
/**
 * stackify_call_captures_a_value_result — a value-returning callee whose
 * caller captures the result into its own local.
 *
 * @return void
 */
fn stackify_call_captures_a_value_result() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__f", sft_i32_target())
    let inst = lir::call_inst(9, "teko__demo__f", teko::list::empty(), false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__f"; args = teko::list::empty(); variadic = false }, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x10 to byte, 0x05 to byte, 0x21 to byte, 0x09 to byte]))
    teko::assert::is_true(wvt_get(out.vtypes, 9) == wasm_vtype_wire(WasmVType::I32))
}

#test
/**
 * stackify_call_drops_a_discarded_value_result — a value-returning callee
 * called at statement level (the result unused) drops it to keep the
 * operand stack balanced.
 *
 * @return void
 */
fn stackify_call_drops_a_discarded_value_result() {
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "teko__demo__f", sft_i32_target())
    let inst = lir::void_call_inst("teko__demo__f", teko::list::empty(), false, 0, 0)
    let out = match stackify_call(sft_ctx0(), symbols, inst, lir::LCall { symbol = "teko__demo__f"; args = teko::list::empty(); variadic = false }, false) { StackifyCtx as x => x; error => return }
    teko::assert::is_true(wasm_bytes_eq(out.body, [0x10 to byte, 0x05 to byte, 0x1A to byte]))
}

#test
/**
 * stackify_func_straight_line_add_matches_golden_bytes — the design doc's
 * own end-to-end shape: `fn add(a, b) { a + b }`, byte-for-byte.
 *
 * @return void
 */
fn stackify_func_straight_line_add_matches_golden_bytes() {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__demo__add", 2, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    let r = lir::alloc_vreg(f)
    f = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, lir::LBinOp::IAdd, 0, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_inst(r.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    /* Every value here — both params AND the add's own result — is
     * single-use, same-block, and consumed in LIFO order: the whole
     * ALL-LOCALS baseline's `local.set`/`local.get` traffic rides the stack
     * instead (§5 C1-5's own "straight-line arith" golden). */
    let want_body = [
        0x20 to byte, 0x00 to byte, 0x20 to byte, 0x01 to byte, 0x6A to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want_body))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (1 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

/* ==========================================================================
 * C1-3 — CFGStackify golden-byte fixtures, each cross-checked byte-for-byte
 * against a hand-written `.wat` compiled by `wat2wasm` (never invented).
 * ========================================================================== */

#test
/**
 * stackify_func_loop_swap_block_args_matches_wat2wasm_golden — a
 * single-block loop whose back-edge feeds `[pb, pa]` into params `[pa,
 * pb]` (a genuine swap): sequential `local.set`s would corrupt it (the
 * second copy would read `pa`'s ALREADY-overwritten value), so `emit_edge_
 * copies`' 2-param path must stage both sources into scratch locals FIRST
 * (§4.3) — proves the parallel-copy fix, not just its 1-param fast path
 * (already exercised by every merge above). Golden bytes cross-checked
 * against a hand-written `.wat`.
 *
 * @return void
 */
fn stackify_func_loop_swap_block_args_matches_wat2wasm_golden() {
    let ptypes = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I32), lir::LType::I32), lir::LType::I32)
    mut f = lir::new_func("teko__test__swap_loop", 3, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::param_inst(2, 2, 0, 0))
    let headb = lir::alloc_block(f)
    let pa = lir::add_block_param(headb.func, headb.block_id)
    let pb = lir::add_block_param(pa.func, headb.block_id)
    let exitb = lir::alloc_block(pb.func)
    let entry_args = teko::list::push(teko::list::push(teko::list::empty(), 1 to u32), 2 to u32)
    f = lir::append_inst(exitb.func, 0, lir::jump_inst(headb.block_id, entry_args, 0, 0))
    let back_args = teko::list::push(teko::list::push(teko::list::empty(), pb.vreg), pa.vreg)
    f = lir::append_inst(f, headb.block_id, lir::branch_inst(0, exitb.block_id, teko::list::empty(), headb.block_id, back_args, 0, 0))
    f = lir::append_inst(f, exitb.block_id, lir::ret_inst(pa.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x01 to byte,
        0x20 to byte, 0x02 to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x01 to byte, 0x21 to byte, 0x05 to byte,
        0x20 to byte, 0x02 to byte, 0x21 to byte, 0x06 to byte,
        0x20 to byte, 0x05 to byte, 0x21 to byte, 0x03 to byte,
        0x20 to byte, 0x06 to byte, 0x21 to byte, 0x04 to byte,
        0x02 to byte, 0x40 to byte,
        0x03 to byte, 0x40 to byte,
        0x20 to byte, 0x00 to byte,
        0x04 to byte, 0x40 to byte,
        0x0C to byte, 0x02 to byte,
        0x05 to byte,
        0x20 to byte, 0x04 to byte, 0x21 to byte, 0x07 to byte,
        0x20 to byte, 0x03 to byte, 0x21 to byte, 0x08 to byte,
        0x20 to byte, 0x07 to byte, 0x21 to byte, 0x03 to byte,
        0x20 to byte, 0x08 to byte, 0x21 to byte, 0x04 to byte,
        0x0C to byte, 0x01 to byte,
        0x0B to byte,
        0x0B to byte,
        0x0B to byte,
        0x20 to byte, 0x03 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (6 to u32))
    teko::assert::is_true(out.local_groups[0].valtype == wasm_vtype_wire(WasmVType::I32))
}

/* ==========================================================================
 * C1-3 — the `C1-irreducible` honest-stop, and the smaller defensive/
 * internal-error arms the 100%-coverage ruling's "unreachable arm justified
 * in the PR" exception does NOT need here, since every one below is
 * DIRECTLY testable via a fabricated `LFunc` or a direct call — this file's
 * own established style (`wvt_get_defaults_to_i32_when_unset`).
 * ========================================================================== */

#test
/**
 * stackify_func_loop_with_no_break_has_no_exit_wrap — a loop whose ONLY
 * edge is its own back-edge (no `break` anywhere: `filter_relevant_exits`
 * finds zero exit targets) renders `loop … end` with NO wrapping `block`
 * at all — the `has_exit = false` branch of `render_loop`, distinct from
 * every other fixture above (all of which DO have a wrapping block).
 * `wasm-validate`-clean per a hand-written `.wat` (an infinite loop is
 * valid wasm).
 *
 * @return void
 */
fn stackify_func_loop_with_no_break_has_no_exit_wrap() {
    mut f = lir::new_func("teko__test__inf_loop", 0, teko::list::empty(), lir::LType::Void)
    let headb = lir::alloc_block(f)
    f = lir::append_inst(headb.func, 0, lir::jump_inst(headb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, headb.block_id, lir::jump_inst(headb.block_id, teko::list::empty(), 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [0x03 to byte, 0x40 to byte, 0x0C to byte, 0x00 to byte, 0x0B to byte, 0x0B to byte]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 0)
}

#test
/**
 * u32_table_get_defaults_to_zero_when_out_of_range — the defensive
 * out-of-range default (never reached from a table sized to the function's
 * own block count).
 *
 * @return void
 */
fn u32_table_get_defaults_to_zero_when_out_of_range() {
    teko::assert::is_true(u32_table_get(teko::list::empty(), 5 to u32) == (0 to u32))
}

#test
/**
 * u32_pos_defaults_to_order_len_when_absent — the defensive "absent target
 * sorts last" default (never reached: every id this file queries `u32_pos`
 * with comes from a block the RPO order itself was built from, or one of
 * its own reachable successors).
 *
 * @return void
 */
fn u32_pos_defaults_to_order_len_when_absent() {
    let order = teko::list::push(teko::list::empty(), 0 to u32)
    teko::assert::is_true(u32_pos(order, 9 to u32) == (order.len to u32))
}

#test
/**
 * first_processed_pred_returns_not_found_when_none_processed — the
 * fixpoint seed-search's own empty case (provably unreachable from any
 * block reachable from `entry` in a real RPO-ordered sweep, since RPO
 * guarantees a forward predecessor always precedes it in the SAME pass;
 * exercised directly, by construction, for coverage).
 *
 * @return void
 */
fn first_processed_pred_returns_not_found_when_none_processed() {
    let idom = idom_table_init(2, 0 to u32)
    let ps = teko::list::push(teko::list::empty(), 1 to u32)
    let r = first_processed_pred(ps, idom)
    teko::assert::is_true(!r.found)
}

#test
/**
 * wasm_scope_stack_pop_on_empty_stays_empty — the defensive "nothing to
 * close" default (never reached: `sc_close_scope` only ever follows a
 * matching `sc_open_*`).
 *
 * @return void
 */
fn wasm_scope_stack_pop_on_empty_stays_empty() {
    teko::assert::is_true(wasm_scope_stack_pop(teko::list::empty()).len == 0)
}

#test
/**
 * lir_block_search_defaults_to_first_block_when_id_absent — the defensive
 * fallback for a malformed `LFunc` whose block ids skip a value (never
 * produced by `alloc_block`'s own dense-id contract; exercised directly, by
 * construction, since this file's own style does not blind-trust that
 * contract, §3.2).
 *
 * @return void
 */
fn lir_block_search_defaults_to_first_block_when_id_absent() {
    let b0 = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = teko::list::empty() }
    let b5 = lir::LBlock { id = 5 to u32; params = teko::list::empty(); insts = teko::list::empty() }
    let f = lir::LFunc {
        symbol = "teko__test__gappy"; n_params = 0 to u32; param_types = teko::list::empty()
        ret_type = lir::LType::Void; blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b5); next_vreg = 0 to u32
    }
    let found = lir_block_search(f, 1 to u32)
    teko::assert::is_true(found.id == (0 to u32))
}

#test
/**
 * all_but_last_of_empty_list_is_empty — the empty-input ternary arm
 * (`render_straight` never calls this with an empty block, having already
 * guarded that case itself; exercised directly for coverage).
 *
 * @return void
 */
fn all_but_last_of_empty_list_is_empty() {
    teko::assert::is_true(all_but_last(teko::list::empty()).len == 0)
}

#test
/**
 * wst_get_defaults_to_zero_when_unset — the defensive out-of-range default
 * (never reached from valid input — every `LAlloca` is pre-scanned into the
 * table before its own lowering).
 *
 * @return void
 */
fn wst_get_defaults_to_zero_when_unset() {
    teko::assert::is_true(wst_get(wst_empty(), 3) == (0 to u32))
}

#test
/**
 * alloca_of_non_alloca_is_an_all_zero_placeholder — `alloca_of`'s own
 * defensive fallback arm, exercised directly on a non-`LAlloca` instruction
 * (never reached from `collect_alloca_insts`'s own pre-filtered callers).
 *
 * @return void
 */
fn alloca_of_non_alloca_is_an_all_zero_placeholder() {
    let a = alloca_of(lir::ret_void_inst(0, 0))
    teko::assert::is_true(a.bytes == (0 to u32))
    teko::assert::is_true(a.align == (1 to u32))
}

#test
/**
 * stackify_func_unaligned_alloca_skips_the_align_down_mask — a single
 * `bytes=3, align=1` alloca needs no `i32.and` mask in its prologue (`align
 * <= 1` is a no-op, `wasm_align_down_i32`'s other arm), byte-for-byte
 * identical to `wat2wasm`.
 *
 * @return void
 */
fn stackify_func_unaligned_alloca_skips_the_align_down_mask() {
    mut f = lir::new_func("teko__test__unaligned_alloca", 0, teko::list::empty(), lir::LType::Void)
    let r0 = lir::alloc_vreg(f)
    f = lir::append_inst(r0.func, 0, lir::alloca_inst(r0.vreg, 3, 1, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x23 to byte, 0x00 to byte, 0x41 to byte, 0x03 to byte, 0x6B to byte, 0x22 to byte, 0x01 to byte, 0x24 to byte,
        0x00 to byte, 0x20 to byte, 0x01 to byte, 0x41 to byte, 0x00 to byte, 0x6A to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x01 to byte, 0x24 to byte, 0x00 to byte, 0x0F to byte, 0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
    teko::assert::is_true(out.local_groups.len == 1)
    teko::assert::is_true(out.local_groups[0].count == (2 to u32))
}

#test
/**
 * wasm_sp_global_is_a_mutable_i32 — `wasm_sp_global`'s own builder shape:
 * always `i32`, always mutable, carrying the caller's own `init` through
 * unchanged.
 *
 * @return void
 */
fn wasm_sp_global_is_a_mutable_i32() {
    let g = wasm_sp_global(1024 to i64)
    teko::assert::is_true(g.valtype == wasm_vtype_wire(WasmVType::I32))
    teko::assert::is_true(g.mutable)
    teko::assert::is_true(g.init == (1024 to i64))
    teko::assert::is_true(wasm_sp_global_index() == (0 to u32))
}

/**
 * sft_main_func — a minimal `"main"` `LFunc` (`i32`-returning, 0 params):
 * `%0 = const 0; call tk_exit(%0); ret %0` — the `own_exit_zero` fixture's
 * own shape (a call the program-wide symbol table always resolves,
 * `"tk_exit"`). The first fixture of the C1-5 `wasm_assemble_program`
 * suite below — the whole-module assembler that emits a self-contained
 * wasm module (`backend-wasm.md` §1.2, `backend-c1-wasm.md` §9).
 *
 * @return lir::LFunc  the seeded `main` function
 */
fn sft_main_func() -> lir::LFunc {
    let insts = [
        lir::const_int_inst(0, 0, 0, 0),
        lir::void_call_inst("tk_exit", [0 to u32], false, 0, 0),
        lir::ret_inst(0, 0, 0)
    ]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "main"; n_params = 0 to u32; param_types = teko::list::empty(); ret_type = lir::LType::I32; blocks = [block]; next_vreg = 1 to u32 }
}

/**
 * sft_alloca_func — a `Void`-returning `LFunc` with ONE `LAlloca` (`8`
 * bytes, `8`-aligned) then `ret` — the `wasm_program_has_any_frame` /
 * `wasm_program_memory_plan` "needs a shadow-stack frame" fixture.
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_alloca_func() -> lir::LFunc {
    let insts = [lir::alloca_inst(0, 8, 8, 0, 0), lir::ret_inst(0, 0, 0)]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "teko__test__alloca"; n_params = 0 to u32; param_types = teko::list::empty(); ret_type = lir::LType::Void; blocks = [block]; next_vreg = 1 to u32 }
}

/**
 * sft_ptr_load_func — a `Void`-returning `LFunc` with ONE `Ptr`-typed
 * parameter, ONE `Ptr`-typed `LLoad` off it, then `ret` — the `wasm_
 * program_has_ptr_load` / `wasm_assemble_program`'s checked-narrow-panic-
 * message reachability gate "some function loads a `Ptr`" fixture (#389
 * C1-7 review finding #1).
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_ptr_load_func() -> lir::LFunc {
    let insts = [lir::param_inst(0, 0, 0, 0), lir::load_inst(1, 0, lir::LType::Ptr, 0, 0), lir::ret_void_inst(0, 0)]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "teko__test__ptrload"; n_params = 1 to u32; param_types = [lir::LType::Ptr]; ret_type = lir::LType::Void; blocks = [block]; next_vreg = 2 to u32 }
}

#test
/**
 * mem_pages_for_floors_at_one_page_and_rounds_up — `0` still requests one
 * page (the never-zero floor); a value exactly on a page boundary needs
 * exactly that many pages; one byte OVER a boundary rounds up to the NEXT
 * page.
 *
 * @return void
 */
fn mem_pages_for_floors_at_one_page_and_rounds_up() {
    teko::assert::is_true(wasm_mem_pages_for(0 to u32) == (1 to u32))
    teko::assert::is_true(wasm_mem_pages_for(65536 to u32) == (1 to u32))
    teko::assert::is_true(wasm_mem_pages_for(65537 to u32) == (2 to u32))
}

#test
/**
 * synth_start_void_main_pushes_a_default_exit_code — a `Void`-returning
 * `main` leaves NOTHING on the stack, so `_start` pushes a literal `i32.
 * const 0` (`0x41 0x00`) between `call $main` and `call $proc_exit` — the
 * standard WASI "exit 0 on clean fall-through" `_start` shape that keeps
 * `proc_exit`'s `i32` argument balanced instead of underflowing the operand
 * stack (`backend-wasm.md` finding 4).
 *
 * @return void
 */
fn synth_start_void_main_pushes_a_default_exit_code() {
    let f = match wasm_synth_start(9 to u32, 7 to u32, 0 to u32, lir::LType::Void) { WasmFunc as x => x; error => return }
    let want = [
        0x10 to byte, 0x07 to byte,
        0x41 to byte, 0x00 to byte,
        0x10 to byte, 0x00 to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(f.body, want))
}

#test
/**
 * program_memory_plan_with_a_frame_adds_the_sp_global — a program with
 * SOME `LAlloca` gets exactly one `SP` global, initialized past the
 * (8-byte-aligned) rodata region's own end plus the fixed stack-region
 * size.
 *
 * @return void
 */
fn program_memory_plan_with_a_frame_adds_the_sp_global() {
    let lmod = lir::LModule { funcs = [sft_alloca_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let rodata = wasm_layout_rodata(lmod.rodata, wasm_rodata_base())
    let plan = wasm_program_memory_plan(lmod, rodata)
    teko::assert::is_true(plan.globals.len == (1 to u64))
    teko::assert::is_true(plan.globals[0].mutable)
    teko::assert::is_true(plan.globals[0].init == ((wasm_rodata_base() to i64) + (65536 to i64)))
    teko::assert::is_true(plan.mem_min_pages == (2 to u32))
}

#test
/**
 * assemble_program_wasm64_omits_the_io_panic_trampolines — the SAME
 * `own_exit_zero` shape, assembled for wasm64 (#389 C1-7, `backend-wasm.md`
 * §6): `mem_is64` is `true`, and the `fd_write`-based io/panic trampolines
 * (WASI preview1's own `i32`-address-only ABI, a genuine ecosystem wall
 * against `memory64`) are OMITTED — `funcs` is `[main, _start]` (two
 * entries, not seven), `types` carries the WASI pair + `main`'s own +
 * `_start`'s own (four, not five — no shared io type), and `_start`'s own
 * funcidx lands immediately after `main` (no io funcs in between). The
 * import set itself (`proc_exit`+`fd_write`) is unchanged — an unused
 * `fd_write` import is harmless; only its CALLING trampoline bodies would
 * have mismatched the `memory64` address width.
 *
 * @return void
 */
fn assemble_program_wasm64_omits_the_io_panic_trampolines() {
    let lmod = lir::LModule { funcs = [sft_main_func()]; rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, true) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.mem_is64)
    teko::assert::is_true(m.funcs.len == (2 to u64))
    teko::assert::is_true(m.types.len == (4 to u64))
    teko::assert::is_true(m.imports.len == (2 to u64))
    teko::assert::is_true(m.exports[0].name == "_start")
    teko::assert::is_true(m.exports[0].index == (3 to u32))
}

/**
 * sft_rodata_func — a `Ptr`-returning `"main"` `LFunc` that resolves ONE
 * rodata symbol (`LGlobalAddr`) — the ordering regression this fixture
 * guards: `wasm_assemble_program` must lay out + register rodata BEFORE
 * stackifying ANY function, or this `LGlobalAddr` site fails to resolve.
 *
 * @return lir::LFunc  the seeded function
 */
fn sft_rodata_func() -> lir::LFunc {
    let insts = [lir::global_addr_inst(0, "teko__rodata__0", 0, 0), lir::ret_inst(0, 0, 0)]
    let block = lir::LBlock { id = 0 to u32; params = teko::list::empty(); insts = insts }
    lir::LFunc { symbol = "main"; n_params = 0 to u32; param_types = teko::list::empty(); ret_type = lir::LType::Ptr; blocks = [block]; next_vreg = 1 to u32 }
}

#test
/**
 * assemble_program_resolves_rodata_symbols_before_stackifying — a program
 * whose only function reads a rodata symbol (`LGlobalAddr`) assembles
 * cleanly, AND the module's own data section places it at `wasm_rodata_
 * base` — proving `wasm_assemble_program` lays rodata out (and registers
 * it into the symbol table) BEFORE stackifying `main`, not after.
 *
 * @return void
 */
fn assemble_program_resolves_rodata_symbols_before_stackifying() {
    let rodata = [lir::LRodata { symbol = "teko__rodata__0"; bytes = [0x68 to byte, 0x69 to byte]; relocs = teko::list::empty() }]
    let lmod = lir::LModule { funcs = [sft_rodata_func()]; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, false) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.data.len == (1 to u64))
    teko::assert::is_true(m.data[0].offset == wasm_rodata_base())
}

#test
/**
 * assemble_program_wasm32_orders_the_narrow_msg_segment_before_rodata — a
 * program that BOTH loads a `Ptr` value AND interns rodata gets TWO data
 * segments: the reserved narrow-message segment first (offset `wasm_
 * narrow_msg_addr`), the program's own rodata second (offset `wasm_rodata_
 * base`) — the append order `wasm_assemble_program`'s own `data` field
 * builds (#389 C1-7 review finding #1).
 *
 * @return void
 */
fn assemble_program_wasm32_orders_the_narrow_msg_segment_before_rodata() {
    let rodata = [lir::LRodata { symbol = "teko__rodata__0"; bytes = [0x68 to byte, 0x69 to byte]; relocs = teko::list::empty() }]
    let lmod = lir::LModule { funcs = [sft_main_func(), sft_ptr_load_func()]; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    let m = match wasm_assemble_program(lmod, false) { WasmModule as x => x; error => return }
    teko::assert::is_true(m.data.len == (2 to u64))
    teko::assert::is_true(m.data[0].offset == wasm_narrow_msg_addr())
    teko::assert::is_true(m.data[1].offset == wasm_rodata_base())
}

/* ==========================================================================
 * C1-5 — the value-stack peephole: `elide_candidate_kind`'s own per-
 * condition coverage (single-use/same-block -> Drop, multi-use -> Normal,
 * cross-block -> Normal, edge-only -> Normal, block-param -> Normal,
 * dead -> Normal, computational+edge -> Tee), the LIFO/barrier simulation's
 * own unit tests, and end-to-end golden fixtures (§5, `backend-wasm.md`).
 * ========================================================================== */

#test
/**
 * elide_candidate_kind_normal_on_multi_use — three same-block computational
 * uses stay Normal (beyond the `Drop`/`Tee` shape entirely).
 *
 * @return void
 */
fn elide_candidate_kind_normal_on_multi_use() {
    let t1 = uit_record_use(uit_empty(), 0, 0, false)
    let t2 = uit_record_use(t1, 0, 0, false)
    let info = uit_record_use(t2, 0, 0, false)
    teko::assert::is_true(elide_candidate_kind(info, 0, 0) == ElideKind::Normal)
}

#test
/**
 * cancel_pending_loads_forces_a_load_off_the_stack_across_a_barrier — the
 * §5 condition-4 hazard: a pending `LLoad` result is downgraded to Normal
 * at a barrier; a pending NON-load survives it untouched (`inst_is_load`'s
 * own doc — only a load result is hazarded by a call/store).
 *
 * @return void
 */
fn cancel_pending_loads_forces_a_load_off_the_stack_across_a_barrier() {
    let table0 = et_set(et_set(et_empty(), 20 to u32, ElideKind::Drop), 21 to u32, ElideKind::Drop)
    let pending = teko::list::push(teko::list::push(teko::list::empty(), PendingItem { vreg = 20 to u32; is_load = true }), PendingItem { vreg = 21 to u32; is_load = false })
    let flushed = cancel_pending_loads(pending, table0)
    teko::assert::is_true(flushed.pending.len == 1)
    teko::assert::is_true(flushed.pending[0].vreg == (21 to u32))
    teko::assert::is_true(et_get(flushed.table, 20 to u32) == ElideKind::Normal)
    teko::assert::is_true(et_get(flushed.table, 21 to u32) == ElideKind::Drop)
}

#test
/**
 * stackify_func_load_across_a_call_stays_in_a_local — the barrier golden
 * (§5 condition 4): `v = load(addr); call tk_nop(); return v` — `v`'s one
 * use (the `ret`) is same-block and would otherwise be single-use-eligible,
 * but the intervening `call` forces it off the stack; `addr` (the load's
 * OWN single-use, same-block operand, defined immediately before it with no
 * barrier in between) still elides normally.
 *
 * @return void
 */
fn stackify_func_load_across_a_call_stays_in_a_local() {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I32)
    mut f = lir::new_func("teko__test__load_barrier", 1, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let v = lir::alloc_vreg(f)
    f = lir::append_inst(v.func, 0, lir::load_inst(v.vreg, 0, lir::LType::I32, 0, 0))
    f = lir::append_inst(f, 0, lir::void_call_inst("tk_nop", teko::list::empty(), false, 0, 0))
    f = lir::append_inst(f, 0, lir::ret_inst(v.vreg, 0, 0))
    let symbols = wasm_symtab_add(wasm_symtab_empty(), "tk_nop", sft_void_target())
    let out = match stackify_func(f, symbols, false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte,
        0x28 to byte, 0x02 to byte, 0x00 to byte,
        0x21 to byte, 0x01 to byte,
        0x10 to byte, 0x03 to byte,
        0x20 to byte, 0x01 to byte, 0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * stackify_func_tee_persists_a_value_also_fed_across_an_edge — the `Tee`
 * golden (§5): a branch's own `cond` is ALSO the very block-arg it feeds
 * into its `then` target — exactly two uses, one computational (the `cond`
 * read, fused straight off the stack into the `if`) and one edge-copy
 * argument, both in block 0. `local.tee` writes the local (for the edge
 * copy to read back out) WHILE ALSO leaving the value on the stack for the
 * branch's own `if`.
 *
 * @return void
 */
fn stackify_func_tee_persists_a_value_also_fed_across_an_edge() {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I32)
    mut f = lir::new_func("teko__test__tee_persist", 1, ptypes, lir::LType::I32)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let thenb = lir::alloc_block(f)
    let tp = lir::add_block_param(thenb.func, thenb.block_id)
    let elseb = lir::alloc_block(tp.func)
    let then_args = teko::list::push(teko::list::empty(), 0 to u32)
    f = lir::append_inst(elseb.func, 0, lir::branch_inst(0, thenb.block_id, then_args, elseb.block_id, teko::list::empty(), 0, 0))
    f = lir::append_inst(f, thenb.block_id, lir::ret_inst(tp.vreg, 0, 0))
    let r5 = lir::alloc_vreg(f)
    f = lir::append_inst(r5.func, elseb.block_id, lir::const_int_inst(r5.vreg, 5 to i128, 0, 0))
    f = lir::append_inst(f, elseb.block_id, lir::ret_inst(r5.vreg, 0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x22 to byte, 0x00 to byte,
        0x04 to byte, 0x40 to byte,
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte,
        0x20 to byte, 0x01 to byte, 0x0F to byte,
        0x05 to byte,
        0x41 to byte, 0x05 to byte,
        0x0F to byte,
        0x0B to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

/* ==========================================================================
 * C1-5 — the adversarial-review fix (PR #546): `resolve_inst_operands`'s
 * own PARTIAL-match branch (a real, reproduced miscompile — a pop-as-you-go
 * scan that only cancelled what was STILL pending on a mismatch left
 * ALREADY-POPPED top matches wrongly riding the stack, inverting a
 * non-commutative op's operand order) is now ALL-OR-NOTHING, and
 * `sc_use_operands` mirrors the same rule on the emission side.
 * ========================================================================== */

#test
/**
 * stackify_func_store_with_normal_addr_and_a_would_be_drop_value — an
 * `LStore` golden: `addr` is a block-param (`Normal`, never pending) and
 * `value` is a single-use constant that would (buggily) partially ride the
 * stack alone. The fix forces `value` back to a local too — `local.get
 * addr; local.get value; i32.store` — never `i32.const N` left riding into
 * a store whose OWN address operand comes from a DIFFERENT, unrelated
 * local.get, which would silently store the WRONG value at the WRONG
 * moment relative to the address.
 *
 * @return void
 */
fn stackify_func_store_with_normal_addr_and_a_would_be_drop_value() {
    mut f = lir::new_func("teko__test__store_normal_addr", 1, [lir::LType::I32], lir::LType::Void)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    let b1 = lir::alloc_block(f)
    let addr = lir::add_block_param(b1.func, b1.block_id)
    let entry_args = teko::list::push(teko::list::empty(), 0 to u32)
    f = lir::append_inst(addr.func, 0, lir::jump_inst(b1.block_id, entry_args, 0, 0))
    let cval = lir::alloc_vreg(f)
    f = lir::append_inst(cval.func, b1.block_id, lir::const_int_inst(cval.vreg, 42 to i128, 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::store_inst(addr.vreg, cval.vreg, lir::LType::I32, 0, 0))
    f = lir::append_inst(f, b1.block_id, lir::ret_void_inst(0, 0))
    let out = match stackify_func(f, wasm_symtab_empty(), false) { WasmFuncBody as x => x; error => return }
    let want = [
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x00 to byte,
        0x20 to byte, 0x00 to byte, 0x21 to byte, 0x01 to byte,
        0x41 to byte, 0x2A to byte, 0x21 to byte, 0x02 to byte,
        0x20 to byte, 0x01 to byte, 0x20 to byte, 0x02 to byte,
        0x36 to byte, 0x02 to byte, 0x00 to byte,
        0x0F to byte,
        0x0B to byte
    ]
    teko::assert::is_true(wasm_bytes_eq(out.body, want))
}

#test
/**
 * wasm_synth_io_panic_funcs_builds_five_funcs_sharing_one_type — the fixed
 * `print, println, eprint, eprintln, panic_str` order (C1-6), every entry
 * sharing the ONE `(i32, i32) -> ()` type index passed in.
 *
 * @return void
 */
fn wasm_synth_io_panic_funcs_builds_five_funcs_sharing_one_type() {
    let out = wasm_synth_io_panic_funcs(5 to u32, 1 to u32)
    teko::assert::is_true(out.funcs.len == (5 to u64))
    teko::assert::is_true(out.funcs[0].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[1].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[2].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[3].type_index == (5 to u32))
    teko::assert::is_true(out.funcs[4].type_index == (5 to u32))
    teko::assert::is_true(println_body_carries_the_newline_tail_print_does_not(out))
    teko::assert::is_true(panic_body_ends_in_unreachable_not_a_bare_end(out))
}

/**
 * println_body_carries_the_newline_tail_print_does_not — `println`'s body
 * (position `1`) is strictly longer than `print`'s (position `0`) — the
 * ONLY structural difference `wasm_synth_io_write`'s `newline` flag makes
 * (the trailing-newline tail, `wasm_io_write_newline`).
 *
 * @param WasmIoPanicFuncs out  the five synthesized trampolines
 * @return bool  true iff `println`'s body is longer than `print`'s
 */
fn println_body_carries_the_newline_tail_print_does_not(out: WasmIoPanicFuncs) -> bool {
    out.funcs[1].body.len > out.funcs[0].body.len
}

/**
 * panic_body_ends_in_unreachable_not_a_bare_end — `panic_str`'s body
 * (position `4`) ends in `unreachable end` (`0x00 0x0B`), not a bare `end`
 * (§8's observe-then-trap shape, never a normal fall-through).
 *
 * @param WasmIoPanicFuncs out  the five synthesized trampolines
 * @return bool  true iff the second-to-last body byte is `unreachable`
 */
fn panic_body_ends_in_unreachable_not_a_bare_end(out: WasmIoPanicFuncs) -> bool {
    let panic_body = out.funcs[4].body
    panic_body[panic_body.len - (2 to u64)] == (0x00 to byte)
}
