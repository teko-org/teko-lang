    teko::assert::is_true(!all_physical_x86(def_virtual))
    let use_virtual = rx_named_func("main", teko::list::push(teko::list::empty(), mov_x86(rx_p(0), rx_v(0), true)))
    teko::assert::is_true(!all_physical_x86(use_virtual))
    let phys = rx_named_func("main", teko::list::push(teko::list::empty(), mov_x86(rx_p(0), rx_p(1), true)))
    teko::assert::is_true(all_physical_x86(phys))
}

/**
 * rx_spill_abi — a tiny GPR register file (allocatable R12/R13; spill scratch
 * R10/R11) that forces a spill under three-value pressure; no caller-saved so
 * `crosses_call` filtering does not interfere.
 *
 * @return AbiDescriptor  the tiny descriptor
 */
fn rx_spill_abi() -> AbiDescriptor {
    AbiDescriptor {
        gpr_arg = push_range(teko::list::empty(), 7, 7)
        fpr_arg = teko::list::empty()
        gpr_allocatable = push_range(teko::list::empty(), 12, 13)
        fpr_allocatable = teko::list::empty()
        gpr_caller_saved = teko::list::empty()
        fpr_caller_saved = teko::list::empty()
        gpr_spill_scratch = push_range(teko::list::empty(), 10, 11)
        fpr_spill_scratch = teko::list::empty()
        spill_slot_bytes = 8
        spill_slot_align = 8
        shadow_space = 0 to u32
    }
}

/**
 * rx_spill_fixture — `mov v0=#3; v1=#5; v2=#7; mov v3=v0; add v3,v1;
 * mov v4=v3; add v4,v2; mov rax=v4; ret`; three values overlap under
 * `rx_spill_abi`'s two allocatable registers, forcing a GPR spill.
 *
 * @return []MInstX86  the fixture stream
 */
fn rx_spill_fixture() -> []MInstX86 {
    mut insts: []MInstX86 = teko::list::empty()
    insts = teko::list::push(insts, movimm_x86(rx_v(0), 3 to i64, true))
    insts = teko::list::push(insts, movimm_x86(rx_v(1), 5 to i64, true))
    insts = teko::list::push(insts, movimm_x86(rx_v(2), 7 to i64, true))
    insts = teko::list::push(insts, mov_x86(rx_v(3), rx_v(0), true))
    insts = teko::list::push(insts, alu_rm_x86(MAluOpX86::Add, rx_v(3), rx_v(1), true))
    insts = teko::list::push(insts, mov_x86(rx_v(4), rx_v(3), true))
    insts = teko::list::push(insts, alu_rm_x86(MAluOpX86::Add, rx_v(4), rx_v(2), true))
    insts = teko::list::push(insts, mov_x86(rx_p(0), rx_v(4), true))
    insts = teko::list::push(insts, ret_x86())
    insts
}

#test
fn rx_regalloc_gpr_spill_all_physical_and_frame_grows() {
    let f = rx_func(rx_spill_fixture())
    let iset = match rx_intervals(f) { IntervalSet as s => s; error => return }
    let scan = linear_scan(rx_spill_abi(), iset)
    teko::assert::is_true(rx_spilled(scan, 0) || rx_spilled(scan, 1) || rx_spilled(scan, 2))
    let cf = match regalloc_func_x86(rx_spill_abi(), f) { MFuncX86 as g => g; error => return }
    teko::assert::is_true(all_physical_x86(cf))
    teko::assert::is_true(cf.frame.len > 0 to u64)
}

/**
 * rx_fpr_spill_abi — a register file with a single FPR (XMM0) so any function
 * with FPR pressure spills an FPR value (the inherited A3 honest-stop); ample
 * GPRs so only the FPRs spill.
 *
 * @return AbiDescriptor  the descriptor
 */
fn rx_fpr_spill_abi() -> AbiDescriptor {
    AbiDescriptor {
        gpr_arg = push_range(teko::list::empty(), 7, 7)
        fpr_arg = teko::list::empty()
        gpr_allocatable = push_range(teko::list::empty(), 12, 15)
        fpr_allocatable = push_range(teko::list::empty(), 0, 0)
        gpr_caller_saved = teko::list::empty()
        fpr_caller_saved = teko::list::empty()
        gpr_spill_scratch = push_range(teko::list::empty(), 10, 11)
        fpr_spill_scratch = push_range(teko::list::empty(), 14, 15)
        spill_slot_bytes = 8
        spill_slot_align = 8
        shadow_space = 0 to u32
    }
}

/**
 * rx_fpr_spill_fixture — two FPR values live at once (loaded from `[rdi]`, then
 * both stored), forcing an FPR spill under `rx_fpr_spill_abi`. Constructed to
 * exercise the FPR honest-stop; isel never emits FPR values for B1 (the float
 * family is the `B1-fp` stop), so this is a hand-built pressure case.
 *
 * @return []MInstX86  the fixture stream
 */
fn rx_fpr_spill_fixture() -> []MInstX86 {
    let mem = rx_mem(rx_p(7), 0 to i32)
    mut insts: []MInstX86 = teko::list::empty()
    insts = teko::list::push(insts, load_x86(MMemSizeX86::Q, false, rx_vf(10), mem))
    insts = teko::list::push(insts, load_x86(MMemSizeX86::Q, false, rx_vf(11), mem))
    insts = teko::list::push(insts, store_x86(MMemSizeX86::Q, rx_vf(10), mem))
    insts = teko::list::push(insts, store_x86(MMemSizeX86::Q, rx_vf(11), mem))
    insts = teko::list::push(insts, ret_x86())
    insts
}

#test
fn rx_regalloc_fpr_spill_honest_stops() {
    let f = rx_func(rx_fpr_spill_fixture())
    let is_err = match regalloc_func_x86(rx_fpr_spill_abi(), f) {
        MFuncX86 => false
        error => true
    }
    teko::assert::is_true(is_err)
}

#test
fn rx_regalloc_module_carries_tables_and_propagates() {
    let f1 = rx_named_func("a", rx_entry_param_add_fixture())
    let f2 = rx_named_func("b", rx_entry_param_add_fixture())
    let funcs = teko::list::push(teko::list::push(teko::list::empty(), f1), f2)
    let rodata = teko::list::push(teko::list::empty(), lir::LRodata { symbol = "r0"; bytes = teko::list::empty() })
    let m = MModuleX86 { funcs = funcs; rodata = rodata; globals = teko::list::empty(); layouts = teko::list::empty() }
    let cm = match regalloc_module_x86(sysv64(), m) {
        MModuleX86 as x => x
        error => return
    }
    teko::assert::is_true(cm.funcs.len == 2 to u64)
    teko::assert::is_true(cm.rodata.len == 1 to u64)
    let bad = rx_module_of(rx_named_func("main", rx_fpr_spill_fixture()))
    let is_err = match regalloc_module_x86(rx_fpr_spill_abi(), bad) {
        MModuleX86 => false
        error => true
    }
    teko::assert::is_true(is_err)
}

#test
fn rx_regalloc_func_two_block_loop_allocates() {
    let b0 = MBlockX86 { id = 0; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), jmp_x86(1 to u32)) }
    let b1 = MBlockX86 { id = 1; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), jmp_x86(0 to u32)) }
    let f = MFuncX86 { symbol = "main"; blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b1); frame = teko::list::empty() }
    let ok = match regalloc_func_x86(sysv64(), f) {
        MFuncX86 => true
        error => false
    }
    teko::assert::is_true(ok)
}

/**
 * rx_natural_loops_x86_two_block_loop_golden — the x86 mirror of the neutral
 * `natural_loops` golden (#389 F2 review NIT 3): a two-block loop (`b0: jmp b1`;
 * `b1: jmp b0`) numbers `b0`'s instruction at point 0 and `b1`'s at point 1, so
 * the retreating edge (`b1`'s jump back to `b0`) yields exactly one
 * `NaturalLoop{header_pt=0, latch_pt=1}`.
 */
#test
fn rx_natural_loops_x86_two_block_loop_golden() {
    let b0 = MBlockX86 { id = 0; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), jmp_x86(1 to u32)) }
    let b1 = MBlockX86 { id = 1; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), jmp_x86(0 to u32)) }
    let f = MFuncX86 { symbol = "main"; blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b1); frame = teko::list::empty() }
    let o = rpo_block_order_x86(f)
    let stream = number_insts_x86(f, o)
    let loops = natural_loops_x86(stream, o, reachable_blocks_x86(f))
    teko::assert::is_true(loops.len == (1 to u64))
    teko::assert::is_true(loops[0].header_pt == (0 to u32))
    teko::assert::is_true(loops[0].latch_pt == (1 to u32))
}

/**
 * rx_diamond_fixture — an acyclic id-inverted diamond mirroring isel output: the
 * MERGE block has id 1 (lowest) but is targeted by the arm blocks id 2/3, and
 * `v10` is defined in the arms and used in the merge — the numbering inversion
 * the #443 RPO fix handles. B0 compares `v0` with itself and branches on EQ.
 *
 * @return MFuncX86  the diamond function
 */
fn rx_diamond_fixture() -> MFuncX86 {
    mut i0: []MInstX86 = teko::list::empty()
    i0 = teko::list::push(i0, movimm_x86(rx_v(0), 1 to i64, true))
    i0 = teko::list::push(i0, cmp_x86(rx_v(0), rx_v(0), true))
    i0 = teko::list::push(i0, jcc_x86(MCond::EQ, 3 to u32))
    i0 = teko::list::push(i0, jmp_x86(2 to u32))
    let b0 = MBlockX86 { id = 0; params = teko::list::empty(); insts = i0 }
    mut i1: []MInstX86 = teko::list::empty()
    i1 = teko::list::push(i1, mov_x86(rx_p(0), rx_v(10), true))
    i1 = teko::list::push(i1, ret_x86())
    let b1 = MBlockX86 { id = 1; params = teko::list::push(teko::list::empty(), rx_v(10)); insts = i1 }
    mut i2: []MInstX86 = teko::list::empty()
    i2 = teko::list::push(i2, movimm_x86(rx_v(1), 42 to i64, true))
    i2 = teko::list::push(i2, mov_x86(rx_v(10), rx_v(1), true))
    i2 = teko::list::push(i2, jmp_x86(1 to u32))
    let b2 = MBlockX86 { id = 2; params = teko::list::empty(); insts = i2 }
    mut i3: []MInstX86 = teko::list::empty()
    i3 = teko::list::push(i3, movimm_x86(rx_v(2), 99 to i64, true))
    i3 = teko::list::push(i3, mov_x86(rx_v(10), rx_v(2), true))
    i3 = teko::list::push(i3, jmp_x86(1 to u32))
    let b3 = MBlockX86 { id = 3; params = teko::list::empty(); insts = i3 }
    mut blocks: []MBlockX86 = teko::list::empty()
    blocks = teko::list::push(blocks, b0)
    blocks = teko::list::push(blocks, b1)
    blocks = teko::list::push(blocks, b2)
    blocks = teko::list::push(blocks, b3)
    MFuncX86 { symbol = "main"; blocks = blocks; frame = teko::list::empty() }
}

#test
fn rx_rpo_order_ranks_merge_after_arms() {
    let order = rpo_block_order_x86(rx_diamond_fixture())
    teko::assert::is_true(order.len == 4 to u64)
    teko::assert::is_true(order[0] == 0 to u32)
    teko::assert::is_true(block_pos(order, 1 to u32) > block_pos(order, 2 to u32))
    teko::assert::is_true(block_pos(order, 1 to u32) > block_pos(order, 3 to u32))
}

#test
fn rx_rpo_numbering_places_arms_before_merge() {
    let stream = rx_number(rx_diamond_fixture())
    mut max_b2: u32 = 0 to u32
    mut min_b1: u32 = 1000000 to u32
    mut i: u64 = 0
    loop {
        if i >= stream.len { break }
        let ni = stream[i]
        if ni.block_id == 2 to u32 { max_b2 = ni.point }
        if ni.block_id == 1 to u32 {
            if ni.point < min_b1 { min_b1 = ni.point }
        }
        i++
    }
    teko::assert::is_true(max_b2 < min_b1)
}

#test
fn rx_regalloc_diamond_allocates_all_physical() {
    let f = rx_diamond_fixture()
    teko::assert::is_true(!all_physical_x86(f))
    let cf = match regalloc_func_x86(sysv64(), f) { MFuncX86 as g => g; error => return }
    teko::assert::is_true(all_physical_x86(cf))
}

/**
 * rx_dead_block_fixture — a reachable leaf (`mov rax=v0; ret`) plus an
 * UNREACHABLE block id 7 whose `jmp 0` retreats to the entry. The dead edge must
 * NOT count as a loop back-edge (the #455 reachability lesson), so allocation
 * succeeds even though block 7 lands last in the numbering and jumps backward.
 *
 * @return MFuncX86  the function with a dead retreating block
 */
fn rx_dead_block_fixture() -> MFuncX86 {
    mut i0: []MInstX86 = teko::list::empty()
    i0 = teko::list::push(i0, movimm_x86(rx_v(0), 5 to i64, true))
    i0 = teko::list::push(i0, mov_x86(rx_p(0), rx_v(0), true))
    i0 = teko::list::push(i0, ret_x86())
    let b0 = MBlockX86 { id = 0; params = teko::list::empty(); insts = i0 }
    let b7 = MBlockX86 { id = 7; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), jmp_x86(0 to u32)) }
    MFuncX86 { symbol = "main"; blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b7); frame = teko::list::empty() }
}

#test
fn rx_dead_block_excluded_and_allocation_succeeds() {
    let f = rx_dead_block_fixture()
    teko::assert::is_false(u32_in(reachable_blocks_x86(f), 7 to u32))
    teko::assert::is_true(u32_in(rpo_block_order_x86(f), 7 to u32))
    let cf = match regalloc_func_x86(sysv64(), f) { MFuncX86 as g => g; error => return }
    teko::assert::is_true(all_physical_x86(cf))
}

#test
fn rx_rpo_defensive_paths() {
    teko::assert::is_true(block_insts_of_x86(rx_func(teko::list::push(teko::list::empty(), ret_x86())), 99 to u32).len == 0 to u64)
    let empty_f = MFuncX86 { symbol = "main"; blocks = teko::list::empty(); frame = teko::list::empty() }
    teko::assert::is_true(rpo_block_order_x86(empty_f).len == 0 to u64)
    teko::assert::is_true(reachable_blocks_x86(empty_f).len == 0 to u64)
    let b0 = MBlockX86 { id = 0; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), ret_x86()) }
    let b9 = MBlockX86 { id = 9; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), ret_x86()) }
    let f2 = MFuncX86 { symbol = "main"; blocks = teko::list::push(teko::list::push(teko::list::empty(), b0), b9); frame = teko::list::empty() }
    let ord2 = rpo_block_order_x86(f2)
    teko::assert::is_true(ord2.len == 2 to u64)
    teko::assert::is_true(u32_in(ord2, 9 to u32))
}
