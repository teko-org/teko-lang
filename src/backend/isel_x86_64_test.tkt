#test
fn xat_const_beyond_i64_honest_stops() {
    let big = (4294967296 to i128) * (4294967296 to i128)
    let f = xat_main_ret()
    let r = lir::alloc_vreg(f)
    let f2 = lir::append_inst(r.func, 0, lir::const_int_inst(r.vreg, big, 0, 0))
    match select_lfunc_x86(sysv64(), xat_ret(f2, r.vreg)) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "register-pair materialization")
    }
}

/**
 * xat_one_param_func — a single-parameter function of machine class `ty` (its
 * own return type too), its param read via `LParam` and returned directly — the
 * coverage sweep for `select_param_x86`'s GPR path and its float/i128 stops.
 *
 * @param lir::LType ty  the parameter's (and return's) machine class
 * @return lir::LFunc  the built function
 */
fn xat_one_param_func(ty: lir::LType) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::empty(), ty)
    mut f = lir::new_func("teko__demo__one_param", 1, ptypes, ty)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    xat_ret(f, 0)
}

/**
 * xat_select_succeeds — whether `select_lfunc_x86(f)` selects without error.
 *
 * @param lir::LFunc f  the function to select
 * @return bool  whether selection succeeded
 */
fn xat_select_succeeds(f: lir::LFunc) -> bool {
    match select_lfunc_x86(sysv64(), f) { MFuncX86 => true; error => false }
}

#test
fn xat_param_covers_scalar_gpr_classes_and_float_stops() {
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I8)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I16)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I32)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I64)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::Ptr)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::Void)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::F16)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::F32)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::F64)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::I128)))
}

#test
fn xat_float_param_names_b1_fp() {
    match select_lfunc_x86(sysv64(), xat_one_param_func(lir::LType::F64)) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_i128_param_honest_stops() {
    match select_lfunc_x86(sysv64(), xat_one_param_func(lir::LType::I128)) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "register-pair ABI slot")
    }
}

/**
 * xat_n_i64_ptypes — `n` `I64` parameter machine classes (the SysV
 * GPR-window-overflow fixture: 6 fill RDI..R9, the 7th needs the stack slot).
 *
 * @param u32 n  how many parameter types to build
 * @return []lir::LType  the n-entry parameter-type list
 */
fn xat_n_i64_ptypes(n: u32) -> []lir::LType {
    mut out: []lir::LType = teko::list::empty()
    mut i: u32 = 0
    loop {
        if i >= n { break }
        out = teko::list::push(out, lir::LType::I64)
        i++
    }
    out
}

#test
fn xat_seventh_gpr_param_honest_stops() {
    mut f = lir::new_func("teko__demo__seven_params", 7, xat_n_i64_ptypes(7), lir::LType::I64)
    mut i: u32 = 0
    loop {
        if i >= 7 { break }
        f = lir::append_inst(f, 0, lir::param_inst(i, i, 0, 0))
        i++
    }
    match select_lfunc_x86(sysv64(), xat_ret(f, 0)) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-args")
    }
}

