use teko::lir

/**
 * xat_i128 — the i128 carrier for a small integer literal in the x86 isel
 * fixtures (mirrors `isel_arm64_test.tkt`'s `iat_i128`).
 *
 * @param i64 v  the literal value
 * @return i128  its i128 carrier
 */
fn xat_i128(v: i64) -> i128 {
    v to i128
}

/**
 * xat_bin — append `%r = op a, b` to `f0`, returning the advanced function
 * plus the fresh result VReg (a fixture-building shorthand).
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LBinOp op  the binary op
 * @param u32 a  the first operand VReg
 * @param u32 b  the second operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_bin(f0: lir::LFunc, op: lir::LBinOp, a: u32, b: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, op, a, b, 0, 0)); vreg = r.vreg }
}

/**
 * xat_un — append `%r = op a` to `f0`, returning the advanced function plus
 * the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LUnOp op  the unary op
 * @param u32 a  the operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_un(f0: lir::LFunc, op: lir::LUnOp, a: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::un_inst(r.vreg, op, a, 0, 0)); vreg = r.vreg }
}

/**
 * xat_const — append `%r = const val` to `f0`, returning the advanced function
 * plus the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param i64 val  the literal value
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_const(f0: lir::LFunc, val: i64) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::const_int_inst(r.vreg, xat_i128(val), 0, 0)); vreg = r.vreg }
}

/**
 * xat_const_float — append `%r = const.float bits` to `f0`, returning the
 * advanced function plus the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param u64 bits  the IEEE bit pattern
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_const_float(f0: lir::LFunc, bits: u64) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::const_float_inst(r.vreg, bits, 0, 0)); vreg = r.vreg }
}

/**
 * xat_ret — append `ret value` to `f0`.
 *
 * @param lir::LFunc f0  the function to extend
 * @param u32 value  the returned VReg
 * @return lir::LFunc  the advanced function
 */
fn xat_ret(f0: lir::LFunc, value: u32) -> lir::LFunc {
    lir::append_inst(f0, 0, lir::ret_inst(value, 0, 0))
}

/**
 * xat_two_i64_params — a fresh 2-param (I64, I64) -> I64 function named `sym`,
 * its entry block already carrying both `LParam` instructions.
 *
 * @param str sym  the function's symbol
 * @return lir::LFunc  the seeded function
 */
fn xat_two_i64_params(sym: str) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I64), lir::LType::I64)
    mut f = lir::new_func(sym, 2, ptypes, lir::LType::I64)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
}

/**
 * xat_main_ret — a zero-param `main` seed (the straight-line fixture base).
 *
 * @return lir::LFunc  the seeded, empty-bodied function
 */
fn xat_main_ret() -> lir::LFunc {
    lir::new_func("main", 0, teko::list::empty(), lir::LType::I32)
}

/**
 * xat_dump — select `f` for x86-64 under the SysV ABI and render the machine
 * module as text (the golden-dump fixtures assert against key lines of this);
 * "" on a selection error. The SysV output is the byte-identity guardrail: it is
 * unchanged from before the ABI descriptor was threaded, because `sysv64()` is
 * exactly the descriptor the old code hardcoded.
 *
 * @param lir::LFunc f  the function to select and print
 * @return str  the rendered machine text ("" on a selection error)
 */
fn xat_dump(f: lir::LFunc) -> str {
    let mf = match select_lfunc_x86(sysv64(), f) { MFuncX86 as x => x; error => return "" }
    minst_print_x86(add_mfunc_x86(empty_mmodule_x86(), mf))
}

/**
 * xat_dump_win — select `f` for x86-64 under the Win64 ABI and render the
 * machine module as text; "" on a selection error. The SAME isel as `xat_dump`,
 * differing only in the threaded descriptor (`win64()`), so a param-receipt or
 * call-argument golden over this printer shows arguments in RCX/RDX/R8/R9
 * (`%p1`/`%p2`/`%p8`/`%p9`) instead of the SysV RDI/RSI/RDX/RCX
 * (`%p7`/`%p6`/`%p2`/`%p1`) — the whole B3-5 fix, observed.
 *
 * @param lir::LFunc f  the function to select and print
 * @return str  the rendered machine text ("" on a selection error)
 */
fn xat_dump_win(f: lir::LFunc) -> str {
    let mf = match select_lfunc_x86(win64(), f) { MFuncX86 as x => x; error => return "" }
    minst_print_x86(add_mfunc_x86(empty_mmodule_x86(), mf))
}

/**
 * xat_bare_ctx — a bare single-block `SelCtxX86` seed for the direct-call unit
 * tests (the honest-stops unreachable through a normal fixture, because their
 * float source instruction stops selection first).
 *
 * @param str sym  the machine function's symbol
 * @return SelCtxX86  the seeded context
 */
fn xat_bare_ctx(sym: str) -> SelCtxX86 {
    SelCtxX86 { func = new_mfunc_x86(sym); vinfo = vinfo_empty(); next_scratch = 0; cur_block = 0; next_block = 1 }
}

#test
fn xat_two_param_add_is_two_address() {
    mut f = xat_two_i64_params("teko__demo__add")
    let r = xat_bin(f, lir::LBinOp::IAdd, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "func @teko__demo__add {")
    teko::assert::str_contains(text, "mov.q %0, %p7")
    teko::assert::str_contains(text, "mov.q %1, %p6")
    teko::assert::str_contains(text, "mov.q %2, %0")
    teko::assert::str_contains(text, "add.q %2, %1")
    teko::assert::str_contains(text, "mov.q %p0, %2")
    teko::assert::str_contains(text, "ret")
}

#test
fn xat_win64_two_param_receipt_reads_rcx_rdx() {
    mut f = xat_two_i64_params("teko__demo__add")
    let r = xat_bin(f, lir::LBinOp::IAdd, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let text = xat_dump_win(f)
    teko::assert::str_contains(text, "mov.q %0, %p1")
    teko::assert::str_contains(text, "mov.q %1, %p2")
    teko::assert::str_contains(text, "mov.q %p0, %2")
    teko::assert::str_contains(text, "ret")
}

#test
fn xat_win64_param_receipt_diverges_from_sysv() {
    mut f = xat_two_i64_params("teko__demo__add")
    let r = xat_bin(f, lir::LBinOp::IAdd, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let sysv = xat_dump(f)
    let win = xat_dump_win(f)
    teko::assert::str_contains(sysv, "mov.q %0, %p7")
    teko::assert::str_contains(win, "mov.q %0, %p1")
}

#test
fn xat_win64_fifth_param_honest_stops() {
    mut f = lir::new_func("teko__demo__five_params", 5, xat_n_i64_ptypes(5), lir::LType::I64)
    mut i: u32 = 0
    loop {
        if i >= 5 { break }
        f = lir::append_inst(f, 0, lir::param_inst(i, i, 0, 0))
        i++
    }
    match select_lfunc_x86(win64(), xat_ret(f, 0)) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-args")
    }
}

#test
fn xat_two_param_sub_is_two_address() {
    mut f = xat_two_i64_params("teko__demo__sub")
    let r = xat_bin(f, lir::LBinOp::ISub, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "mov.q %2, %0")
    teko::assert::str_contains(text, "sub.q %2, %1")
}

#test
fn xat_mul_is_two_operand_imul() {
    mut f = xat_two_i64_params("teko__demo__mul")
    let r = xat_bin(f, lir::LBinOp::IMul, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "mov.q %2, %0")
    teko::assert::str_contains(text, "imul.q %2, %1")
}

#test
fn xat_sdiv_is_divseq_with_rax_rdx_pins() {
