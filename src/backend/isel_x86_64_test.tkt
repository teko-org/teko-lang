#test
fn xat_jump_emits_edge_move_and_jmp() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let v0 = lir::alloc_vreg(b1.func)
    let bp = lir::add_block_param(v0.func, b1.block_id)
    let s0 = lir::append_inst(bp.func, 0, lir::const_int_inst(v0.vreg, 7 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::jump_inst(b1.block_id, teko::list::push(teko::list::empty(), v0.vreg), 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::ret_inst(bp.vreg, 0, 0))
    let text = xat_dump(s2)
    teko::assert::str_contains(text, "#M1(%1")
    teko::assert::str_contains(text, "mov.q %1, %0")
    teko::assert::str_contains(text, "jmp #M1")
}

