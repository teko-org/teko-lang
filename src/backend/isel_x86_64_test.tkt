#test
fn xat_shift_moves_count_into_cl() {
    mut f = xat_two_i64_params("teko__demo__shl")
    let r = xat_bin(f, lir::LBinOp::IShl, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "mov.q %2, %0")
    teko::assert::str_contains(text, "mov.q %p1, %1")
    teko::assert::str_contains(text, "shl.q %2, cl")
}

#test
fn xat_value_compare_is_cmp_then_setcc() {
    mut f = xat_two_i64_params("teko__demo__lt")
    let r = xat_bin(f, lir::LBinOp::ICmpLtS, 0, 1)
    f = xat_ret(r.func, r.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "cmp.q %0, %1")
    teko::assert::str_contains(text, "setl %2")
}

#test
fn xat_const_is_single_mov_imm() {
    let c = xat_const(xat_main_ret(), 42)
    let f = xat_ret(c.func, c.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "func @main {")
    teko::assert::str_contains(text, "mov.q %0, #42")
    teko::assert::str_contains(text, "mov.q %p0, %0")
    teko::assert::str_contains(text, "ret")
}

#test
fn xat_negate_is_two_address_neg() {
    let c = xat_const(xat_main_ret(), 42)
    let n = xat_un(c.func, lir::LUnOp::INeg, c.vreg)
    let f = xat_ret(n.func, n.vreg)
    let text = xat_dump(f)
    teko::assert::str_contains(text, "mov.q %1, %0")
    teko::assert::str_contains(text, "neg.q %1")
}

#test
fn xat_complement_is_two_address_not() {
    let c = xat_const(xat_main_ret(), 42)
    let n = xat_un(c.func, lir::LUnOp::INot, c.vreg)
    let f = xat_ret(n.func, n.vreg)
    teko::assert::str_contains(xat_dump(f), "not.q %1")
}

/**
 * xat_kitchen_sink — a two-param (I64,I64) function exercising every integer
 * `LBinOp` arithmetic/bitwise/shift/compare case plus every integer `LUnOp`
 * case (the coverage sweep for `select_bin_x86`/`select_un_x86`'s integer
 * dispatch), ending `ret`. The float cases stop and are covered by direct
 * unit calls (`xat_float_bin_honest_stops`/`xat_float_un_honest_stops`).
 *
 * @return lir::LFunc  the built function
 */
fn xat_kitchen_sink() -> lir::LFunc {
    mut f = xat_two_i64_params("teko__demo__kitchen_sink")
    f = xat_bin(f, lir::LBinOp::IAdd, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ISub, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IMul, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IDivS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IDivU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IRemS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IRemU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IAnd, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IOr, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IXor, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IShl, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IShrS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IShrU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpEq, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpNe, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLtS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLtU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLeS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLeU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGtS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGtU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGeS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGeU, 0, 1).func
    f = xat_un(f, lir::LUnOp::INeg, 0).func
    f = xat_un(f, lir::LUnOp::INot, 0).func
    f = xat_un(f, lir::LUnOp::Trunc, 0).func
    f = xat_un(f, lir::LUnOp::ZExt, 0).func
    let last = xat_un(f, lir::LUnOp::SExt, 0)
    f = last.func
    xat_ret(f, last.vreg)
}

#test
fn xat_kitchen_sink_covers_every_int_bin_and_un_op() {
    let text = xat_dump(xat_kitchen_sink())
    teko::assert::str_contains(text, "add.q ")
    teko::assert::str_contains(text, "sub.q ")
    teko::assert::str_contains(text, "imul.q ")
    teko::assert::str_contains(text, "idiv.q ")
    teko::assert::str_contains(text, "div.q ")
    teko::assert::str_contains(text, "irem.q ")
    teko::assert::str_contains(text, "rem.q ")
    teko::assert::str_contains(text, "and.q ")
    teko::assert::str_contains(text, "or.q ")
    teko::assert::str_contains(text, "xor.q ")
    teko::assert::str_contains(text, "shl.q ")
    teko::assert::str_contains(text, "sar.q ")
    teko::assert::str_contains(text, "shr.q ")
    teko::assert::str_contains(text, "sete ")
    teko::assert::str_contains(text, "setne ")
    teko::assert::str_contains(text, "setl ")
    teko::assert::str_contains(text, "setb ")
    teko::assert::str_contains(text, "setle ")
    teko::assert::str_contains(text, "setbe ")
    teko::assert::str_contains(text, "setg ")
    teko::assert::str_contains(text, "seta ")
    teko::assert::str_contains(text, "setge ")
    teko::assert::str_contains(text, "setae ")
    teko::assert::str_contains(text, "neg.q ")
    teko::assert::str_contains(text, "not.q ")
    teko::assert::str_contains(text, "mov.d ")
}

#test
fn xat_const_float_honest_stops_b1_fp() {
    let c = xat_const_float(xat_main_ret(), 4607182418800017408 to u64)
    match select_lfunc_x86(sysv64(), xat_ret(c.func, c.vreg)) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_float_bin_honest_stops() {
    let ctx = xat_bare_ctx("main")
    let f = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let inst = lir::bin_inst(5, lir::LBinOp::FAdd, 0, 1, 0, 0)
    match select_bin_x86(ctx, f, inst, lir::LBin { op = lir::LBinOp::FAdd; a = 0; b = 1 }) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_float_compare_value_honest_stops() {
    let ctx = xat_bare_ctx("main")
    let f = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let inst = lir::bin_inst(5, lir::LBinOp::FCmpEq, 0, 1, 0, 0)
    match select_bin_x86(ctx, f, inst, lir::LBin { op = lir::LBinOp::FCmpEq; a = 0; b = 1 }) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_float_un_honest_stops() {
    let ctx = xat_bare_ctx("main")
    let inst = lir::un_inst(5, lir::LUnOp::FNeg, 0, 0, 0)
    match select_un_x86(ctx, inst, lir::LUn { op = lir::LUnOp::FNeg; a = 0 }) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_convert_ops_honest_stop() {
    let ctx = xat_bare_ctx("main")
    let inst = lir::un_inst(5, lir::LUnOp::IToF, 0, 0, 0)
    match select_un_x86(ctx, inst, lir::LUn { op = lir::LUnOp::FToF; a = 0 }) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
