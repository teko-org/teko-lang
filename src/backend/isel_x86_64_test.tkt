/**
 * xat_load_ty_succeeds — whether an `alloca`+`load ty`+`ret` function selects
 * for x86-64 (the coverage sweep over `mem_size_of_x86`'s every arm).
 *
 * @param lir::LType ty  the loaded machine class
 * @return bool  whether selection succeeded
 */
fn xat_load_ty_succeeds(ty: lir::LType) -> bool {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let base = lir::alloc_vreg(f0)
    let ld = lir::alloc_vreg(base.func)
    let s0 = lir::append_inst(ld.func, 0, lir::alloca_inst(base.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::load_inst(ld.vreg, base.vreg, ty, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(ld.vreg, 0, 0))
    match select_lfunc_x86(sysv64(), s2) { MFuncX86 => true; error => false }
}

#test
fn xat_mem_size_covers_every_transfer_class() {
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I8))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I16))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I32))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I64))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::Ptr))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::F32))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::F64))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::F16))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::I128))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::Void))
}

