    let s2 = lir::append_inst(s1, 0, lir::bin_inst(v2.vreg, lir::LBinOp::ICmpGtS, v0.vreg, v1.vreg, 0, 0))
    let s3 = lir::append_inst(s2, 0, lir::branch_inst(v2.vreg, b1.block_id, teko::list::push(teko::list::empty(), v2.vreg), b2.block_id, teko::list::empty(), 0, 0))
    let s4 = lir::append_inst(s3, b1.block_id, lir::ret_inst(bp.vreg, 0, 0))
