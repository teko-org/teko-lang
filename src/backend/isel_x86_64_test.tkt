#test
fn xat_branch_with_edge_args_splits_edge_block() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let bp = lir::add_block_param(v0.func, b1.block_id)
    let s0 = lir::append_inst(bp.func, 0, lir::const_int_inst(v0.vreg, 1 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(v0.vreg, b1.block_id, teko::list::push(teko::list::empty(), v0.vreg), b2.block_id, teko::list::empty(), 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::ret_inst(bp.vreg, 0, 0))
    let s3 = lir::append_inst(s2, b2.block_id, lir::ret_inst(v0.vreg, 0, 0))
    let text = xat_dump(s3)
    teko::assert::str_contains(text, "jne #M3")
    teko::assert::str_contains(text, "jmp #M1")
}

#test
fn xat_branch_taken_edge_mismatch_propagates() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let s0 = lir::append_inst(v0.func, 0, lir::const_int_inst(v0.vreg, 1 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(v0.vreg, b1.block_id, teko::list::push(teko::list::empty(), v0.vreg), b2.block_id, teko::list::empty(), 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::ret_inst(v0.vreg, 0, 0))
    let s3 = lir::append_inst(s2, b2.block_id, lir::ret_inst(v0.vreg, 0, 0))
    match select_lfunc_x86(sysv64(), s3) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "does not match")
    }
}

#test
fn xat_branch_else_edge_mismatch_propagates() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let s0 = lir::append_inst(v0.func, 0, lir::const_int_inst(v0.vreg, 1 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(v0.vreg, b1.block_id, teko::list::empty(), b2.block_id, teko::list::push(teko::list::empty(), v0.vreg), 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::ret_inst(v0.vreg, 0, 0))
    let s3 = lir::append_inst(s2, b2.block_id, lir::ret_inst(v0.vreg, 0, 0))
    match select_lfunc_x86(sysv64(), s3) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "does not match")
    }
}

#test
fn xat_branch_on_fused_float_compare_propagates() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let s0 = lir::append_inst(f0, 0, lir::bin_inst(0, lir::LBinOp::FCmpEq, 1, 2, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(0, 1, teko::list::empty(), 2, teko::list::empty(), 0, 0))
    let br = lir::LBranch { cond = 0; t_target = 1; t_args = teko::list::empty(); f_target = 2; f_args = teko::list::empty() }
    match select_branch_x86(xat_bare_ctx("main"), s1, br) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_variadic_indirect_call_propagates() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let t = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(t.func, 0, lir::alloca_inst(t.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::void_call_indirect_inst(t.vreg, teko::list::empty(), true, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(t.vreg, 0, 0))
    match select_lfunc_x86(sysv64(), s2) {
        MFuncX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "variadic")
    }
}

#test
fn xat_fused_float_compare_branch_names_b1_fp() {
    let ctx = xat_bare_ctx("main")
    let dc = DefCmp { found = true; op = lir::LBinOp::FCmpEq; a = 0; bb = 1 }
    match select_fused_branch_x86(ctx, dc, 0) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_edge_move_of_float_value_names_b1_fp() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let bp = lir::add_block_param(b1.func, b1.block_id)
    let ctx = selctx_x86_set_vinfo(xat_bare_ctx("main"), 0, MRegClass::FPR, true)
    match emit_edge_moves_x86(ctx, bp.func, b1.block_id, teko::list::push(teko::list::empty(), 0 to u32)) {
        SelCtxX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B1-fp")
    }
}

#test
fn xat_multi_block_function_selects() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let v0 = lir::alloc_vreg(b1.func)
    let s0 = lir::append_inst(v0.func, 0, lir::jump_inst(b1.block_id, teko::list::empty(), 0, 0))
    let s1 = lir::append_inst(s0, b1.block_id, lir::const_int_inst(v0.vreg, 3 to i128, 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::ret_inst(v0.vreg, 0, 0))
    match select_lfunc_x86(sysv64(), s2) {
        MFuncX86 as mf => teko::assert::is_true(mf.blocks.len == 2)
        error => teko::assert::is_true(false)
    }
}

#test
fn xat_select_module_carries_rodata_globals_layouts_through() {
    let rodata = teko::list::push(teko::list::empty(), lir::LRodata { symbol = ".Lstr0"; bytes = teko::list::empty() })
    let inner = xat_ret(xat_const(xat_main_ret(), 7).func, xat_const(xat_main_ret(), 7).vreg)
    let m0 = lir::with_rodata(lir::add_func(lir::empty_module(), inner), rodata)
    let selected = match select_module_x86(sysv64(), m0) { MModuleX86 as x => x; error => return }
    teko::assert::is_true(selected.rodata.len == 1)
    teko::assert::is_true(selected.funcs.len == 1)
}

#test
fn xat_select_module_propagates_a_function_error() {
    let f = lir::append_inst(lir::new_func("main", 0, teko::list::empty(), lir::LType::I64), 0, lir::void_call_inst("tk_printf", teko::list::empty(), true, 0, 0))
    let bad = lir::add_func(lir::empty_module(), f)
    match select_module_x86(sysv64(), bad) {
        MModuleX86 => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "variadic")
    }
}
