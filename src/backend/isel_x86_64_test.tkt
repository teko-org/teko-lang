use teko::lir

/**
 * xat_i128 — the i128 carrier for a small integer literal in the x86 isel
 * fixtures (mirrors `isel_arm64_test.tkt`'s `iat_i128`).
 *
 * @param i64 v  the literal value
 * @return i128  its i128 carrier
 */
fn xat_i128(v: i64) -> i128 {
    v to i128
}

/**
 * xat_bin — append `%r = op a, b` to `f0`, returning the advanced function
 * plus the fresh result VReg (a fixture-building shorthand).
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LBinOp op  the binary op
 * @param u32 a  the first operand VReg
 * @param u32 b  the second operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_bin(f0: lir::LFunc, op: lir::LBinOp, a: u32, b: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, op, a, b, 0, 0)); vreg = r.vreg }
}

/**
 * xat_un — append `%r = op a` to `f0`, returning the advanced function plus
 * the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LUnOp op  the unary op
 * @param u32 a  the operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_un(f0: lir::LFunc, op: lir::LUnOp, a: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::un_inst(r.vreg, op, a, 0, 0)); vreg = r.vreg }
}

/**
 * xat_const — append `%r = const val` to `f0`, returning the advanced function
 * plus the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param i64 val  the literal value
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn xat_const(f0: lir::LFunc, val: i64) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::const_int_inst(r.vreg, xat_i128(val), 0, 0)); vreg = r.vreg }
}

/**
 * xat_ret — append `ret value` to `f0`.
 *
 * @param lir::LFunc f0  the function to extend
 * @param u32 value  the returned VReg
 * @return lir::LFunc  the advanced function
 */
fn xat_ret(f0: lir::LFunc, value: u32) -> lir::LFunc {
    lir::append_inst(f0, 0, lir::ret_inst(value, 0, 0))
}

/**
 * xat_two_i64_params — a fresh 2-param (I64, I64) -> I64 function named `sym`,
 * its entry block already carrying both `LParam` instructions.
 *
 * @param str sym  the function's symbol
 * @return lir::LFunc  the seeded function
 */
fn xat_two_i64_params(sym: str) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I64), lir::LType::I64)
    mut f = lir::new_func(sym, 2, ptypes, lir::LType::I64)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
}

/**
 * xat_main_ret — a zero-param `main` seed (the straight-line fixture base).
 *
 * @return lir::LFunc  the seeded, empty-bodied function
 */
fn xat_main_ret() -> lir::LFunc {
    lir::new_func("main", 0, teko::list::empty(), lir::LType::I32)
}

/**
 * xat_dump — select `f` for x86-64 under the SysV ABI and render the machine
 * module as text (the golden-dump fixtures assert against key lines of this);
 * "" on a selection error. The SysV output is the byte-identity guardrail: it is
 * unchanged from before the ABI descriptor was threaded, because `SYSV64` is
 * exactly the descriptor the old code hardcoded.
 *
 * @param lir::LFunc f  the function to select and print
 * @return str  the rendered machine text ("" on a selection error)
 */
fn xat_dump(f: lir::LFunc) -> str {
    let mf = match select_lfunc_x86(SYSV64, f) { MFuncX86 as x => x; error => return "" }
    minst_print_x86(add_mfunc_x86(empty_mmodule_x86(), mf))
}

/**
 * xat_kitchen_sink — a two-param (I64,I64) function exercising every integer
 * `LBinOp` arithmetic/bitwise/shift/compare case plus every integer `LUnOp`
 * case (the coverage sweep for `select_bin_x86`/`select_un_x86`'s integer
 * dispatch), ending `ret`. The float cases stop and are covered by direct
 * unit calls (`xat_float_bin_honest_stops`/`xat_float_un_honest_stops`).
 *
 * @return lir::LFunc  the built function
 */
fn xat_kitchen_sink() -> lir::LFunc {
    mut f = xat_two_i64_params("teko__demo__kitchen_sink")
    f = xat_bin(f, lir::LBinOp::IAdd, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ISub, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IMul, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IDivS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IDivU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IRemS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IRemU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IAnd, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IOr, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IXor, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IShl, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IShrS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::IShrU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpEq, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpNe, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLtS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLtU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLeS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpLeU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGtS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGtU, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGeS, 0, 1).func
    f = xat_bin(f, lir::LBinOp::ICmpGeU, 0, 1).func
    f = xat_un(f, lir::LUnOp::INeg, 0).func
    f = xat_un(f, lir::LUnOp::INot, 0).func
    f = xat_un(f, lir::LUnOp::Trunc, 0).func
    f = xat_un(f, lir::LUnOp::ZExt, 0).func
    let last = xat_un(f, lir::LUnOp::SExt, 0)
    f = last.func
    xat_ret(f, last.vreg)
}

#test
fn xat_kitchen_sink_covers_every_int_bin_and_un_op() {
    let text = xat_dump(xat_kitchen_sink())
    teko::assert::str_contains(text, "add.q ")
    teko::assert::str_contains(text, "sub.q ")
    teko::assert::str_contains(text, "imul.q ")
    teko::assert::str_contains(text, "idiv.q ")
    teko::assert::str_contains(text, "div.q ")
    teko::assert::str_contains(text, "irem.q ")
    teko::assert::str_contains(text, "rem.q ")
    teko::assert::str_contains(text, "and.q ")
    teko::assert::str_contains(text, "or.q ")
    teko::assert::str_contains(text, "xor.q ")
    teko::assert::str_contains(text, "shl.q ")
    teko::assert::str_contains(text, "sar.q ")
    teko::assert::str_contains(text, "shr.q ")
    teko::assert::str_contains(text, "sete ")
    teko::assert::str_contains(text, "setne ")
    teko::assert::str_contains(text, "setl ")
    teko::assert::str_contains(text, "setb ")
    teko::assert::str_contains(text, "setle ")
    teko::assert::str_contains(text, "setbe ")
    teko::assert::str_contains(text, "setg ")
    teko::assert::str_contains(text, "seta ")
    teko::assert::str_contains(text, "setge ")
    teko::assert::str_contains(text, "setae ")
    teko::assert::str_contains(text, "neg.q ")
    teko::assert::str_contains(text, "not.q ")
    teko::assert::str_contains(text, "mov.d ")
}

/**
 * xat_one_param_func — a single-parameter function of machine class `ty` (its
 * own return type too), its param read via `LParam` and returned directly — the
 * coverage sweep for `select_param_x86`'s GPR path and its float/i128 stops.
 *
 * @param lir::LType ty  the parameter's (and return's) machine class
 * @return lir::LFunc  the built function
 */
fn xat_one_param_func(ty: lir::LType) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::empty(), ty)
    mut f = lir::new_func("teko__demo__one_param", 1, ptypes, ty)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    xat_ret(f, 0)
}

/**
 * xat_select_succeeds — whether `select_lfunc_x86(f)` selects without error.
 *
 * @param lir::LFunc f  the function to select
 * @return bool  whether selection succeeded
 */
fn xat_select_succeeds(f: lir::LFunc) -> bool {
    match select_lfunc_x86(SYSV64, f) { MFuncX86 => true; error => false }
}

#test
fn xat_param_covers_scalar_gpr_classes_and_float_stops() {
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I8)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I16)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I32)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::I64)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::Ptr)))
    teko::assert::is_true(xat_select_succeeds(xat_one_param_func(lir::LType::Void)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::F16)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::F32)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::F64)))
    teko::assert::is_true(!xat_select_succeeds(xat_one_param_func(lir::LType::I128)))
}

#test
fn xat_field_addr_materializes_offset_then_adds() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let base = lir::alloc_vreg(f0)
    let fa = lir::alloc_vreg(base.func)
    let s0 = lir::append_inst(fa.func, 0, lir::alloca_inst(base.vreg, 16, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::field_addr_inst(fa.vreg, base.vreg, 8, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(fa.vreg, 0, 0))
    let text = xat_dump(s2)
    teko::assert::str_contains(text, "mov.q %2, #8")
    teko::assert::str_contains(text, "mov.q %1, %0")
    teko::assert::str_contains(text, "add.q %1, %2")
}

#test
fn xat_store_i64_is_qword_mov() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let base = lir::alloc_vreg(f0)
    let val = lir::alloc_vreg(base.func)
    let s0 = lir::append_inst(val.func, 0, lir::alloca_inst(base.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::const_int_inst(val.vreg, 42 to i128, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::store_inst(base.vreg, val.vreg, lir::LType::I64, 0, 0))
    let s3 = lir::append_inst(s2, 0, lir::ret_inst(val.vreg, 0, 0))
    teko::assert::str_contains(xat_dump(s3), "mov.q [%0 + 0], %1")
}

/**
 * xat_load_ty_succeeds — whether an `alloca`+`load ty`+`ret` function selects
 * for x86-64 (the coverage sweep over `mem_size_of_x86`'s every arm).
 *
 * @param lir::LType ty  the loaded machine class
 * @return bool  whether selection succeeded
 */
fn xat_load_ty_succeeds(ty: lir::LType) -> bool {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let base = lir::alloc_vreg(f0)
    let ld = lir::alloc_vreg(base.func)
    let s0 = lir::append_inst(ld.func, 0, lir::alloca_inst(base.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::load_inst(ld.vreg, base.vreg, ty, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(ld.vreg, 0, 0))
    match select_lfunc_x86(SYSV64, s2) { MFuncX86 => true; error => false }
}

#test
fn xat_mem_size_covers_every_transfer_class() {
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I8))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I16))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I32))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::I64))
    teko::assert::is_true(xat_load_ty_succeeds(lir::LType::Ptr))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::F32))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::F64))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::F16))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::I128))
    teko::assert::is_true(!xat_load_ty_succeeds(lir::LType::Void))
}

#test
fn xat_global_addr_is_single_lea_rip() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let v = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(v.func, 0, lir::global_addr_inst(v.vreg, ".Lstr0", 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(v.vreg, 0, 0))
    teko::assert::str_contains(xat_dump(s1), "lea.pc32 %0, [rip @.Lstr0]")
}

#test
fn xat_func_addr_is_single_lea_rip() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let v = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(v.func, 0, lir::func_addr_inst(v.vreg, "teko__demo__f", 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(v.vreg, 0, 0))
    teko::assert::str_contains(xat_dump(s1), "lea.pc32 %0, [rip @teko__demo__f]")
}

#test
fn xat_call_with_result_moves_rax_out() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let r = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(r.func, 0, lir::call_inst(r.vreg, "teko__demo__f", teko::list::empty(), false, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(r.vreg, 0, 0))
    let text = xat_dump(s1)
    teko::assert::str_contains(text, "call @teko__demo__f() -> %p0")
    teko::assert::str_contains(text, "mov.q %0, %p0")
}

#test
fn xat_call_indirect_is_call_through_target() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let t = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(t.func, 0, lir::alloca_inst(t.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::void_call_indirect_inst(t.vreg, teko::list::empty(), false, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(t.vreg, 0, 0))
    teko::assert::str_contains(xat_dump(s2), "call.indirect %0()")
}

#test
fn xat_fused_compare_branch_is_cmp_jcc_jmp() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let v1 = lir::alloc_vreg(v0.func)
    let v2 = lir::alloc_vreg(v1.func)
    let v3 = lir::alloc_vreg(v2.func)
    let v4 = lir::alloc_vreg(v3.func)
    let s0 = lir::append_inst(v4.func, 0, lir::const_int_inst(v0.vreg, 5 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::const_int_inst(v1.vreg, 3 to i128, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::bin_inst(v2.vreg, lir::LBinOp::ICmpGtS, v0.vreg, v1.vreg, 0, 0))
    let s3 = lir::append_inst(s2, 0, lir::branch_inst(v2.vreg, b1.block_id, teko::list::empty(), b2.block_id, teko::list::empty(), 0, 0))
    let s4 = lir::append_inst(s3, b1.block_id, lir::const_int_inst(v3.vreg, 1 to i128, 0, 0))
    let s5 = lir::append_inst(s4, b1.block_id, lir::ret_inst(v3.vreg, 0, 0))
    let s6 = lir::append_inst(s5, b2.block_id, lir::const_int_inst(v4.vreg, 2 to i128, 0, 0))
    let s7 = lir::append_inst(s6, b2.block_id, lir::ret_inst(v4.vreg, 0, 0))
    let text = xat_dump(s7)
    teko::assert::str_contains(text, "cmp.q %0, %1")
    teko::assert::str_contains(text, "jg #M1")
    teko::assert::str_contains(text, "jmp #M2")
}

#test
fn xat_select_module_carries_rodata_globals_layouts_through() {
    let rodata = teko::list::push(teko::list::empty(), lir::LRodata { symbol = ".Lstr0"; bytes = teko::list::empty(); relocs = teko::list::empty() })
    let inner = xat_ret(xat_const(xat_main_ret(), 7).func, xat_const(xat_main_ret(), 7).vreg)
    let m0 = lir::with_rodata(lir::add_func(lir::empty_module(), inner), rodata)
    let selected = match select_module_x86(SYSV64, m0) { MModuleX86 as x => x; error => return }
    teko::assert::is_true(selected.rodata.len == 1)
    teko::assert::is_true(selected.funcs.len == 1)
}
