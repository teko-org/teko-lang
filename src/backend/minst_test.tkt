/**
 * r — a virtual GPR register operand with the given id (a fixture-building
 * shorthand shared by every test below).
 *
 * @param u32 id  the virtual register's abstract id
 * @return MReg  the virtual GPR register operand
 */
fn r(id: u32) -> MReg {
    vreg(id, MRegClass::GPR)
}

/**
 * fr — a virtual FPR register operand with the given id (a fixture-building
 * shorthand shared by every test below).
 *
 * @param u32 id  the virtual register's abstract id
 * @return MReg  the virtual FPR register operand
 */
fn fr(id: u32) -> MReg {
    vreg(id, MRegClass::FPR)
}

/**
 * mem — a base-plus-displacement memory operand (a fixture-building
 * shorthand shared by every test below).
 *
 * @param MReg base  the base register
 * @param i32 offset  the byte displacement
 * @return MMem  the memory operand
 */
fn mem(base: MReg, offset: i32) -> MMem {
    MMem { base = base; offset = offset }
}

/**
 * mk_block0 — the first machine block of `mk_full_module`'s fixture
 * function: every value-producing `MInst` case (ALU/float-ALU/compare/
 * move/extend/convert/memory/address), ending in a branch to block #M1.
 * Split out of `mk_full_module` so no single function grows unbounded
 * (W15 — flatten by extraction).
 *
 * @return MBlock  the value-producing block
 */
fn mk_block0() -> MBlock {
    mut insts: []MInst = teko::list::empty()
    insts = teko::list::push(insts, alu_inst(MAluOp::Add, true, r(10), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Sub, false, r(11), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Mul, true, r(12), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Sdiv, true, r(13), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Udiv, true, r(14), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::And, true, r(15), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Orr, true, r(16), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Eor, true, r(17), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Lsl, true, r(18), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Asr, true, r(19), r(0), r(1)))
    insts = teko::list::push(insts, alu_inst(MAluOp::Lsr, true, r(20), r(0), r(1)))
    insts = teko::list::push(insts, alu_imm_inst(MAluOp::Add, false, r(21), r(0), 5 to i64))
    insts = teko::list::push(insts, msub_inst(true, r(22), r(13), r(1), r(0)))
    insts = teko::list::push(insts, neg_inst(true, r(23), r(0)))
    insts = teko::list::push(insts, mvn_inst(false, r(24), r(0)))
    insts = teko::list::push(insts, falu_inst(MFAluOp::FAdd, true, fr(25), fr(0), fr(1)))
    insts = teko::list::push(insts, falu_inst(MFAluOp::FSub, false, fr(26), fr(0), fr(1)))
    insts = teko::list::push(insts, falu_inst(MFAluOp::FMul, true, fr(27), fr(0), fr(1)))
    insts = teko::list::push(insts, falu_inst(MFAluOp::FDiv, false, fr(28), fr(0), fr(1)))
    insts = teko::list::push(insts, fneg_inst(true, fr(29), fr(0)))
    insts = teko::list::push(insts, cmp_inst(true, r(0), r(1)))
    insts = teko::list::push(insts, cmp_imm_inst(false, r(0), 7 to i64))
    insts = teko::list::push(insts, fcmp_inst(true, fr(0), fr(1)))
    insts = teko::list::push(insts, cset_inst(true, r(30), MCond::EQ))
    insts = teko::list::push(insts, cset_inst(true, r(31), MCond::NE))
    insts = teko::list::push(insts, cset_inst(true, r(32), MCond::LT))
    insts = teko::list::push(insts, cset_inst(true, r(33), MCond::LE))
    insts = teko::list::push(insts, cset_inst(true, r(34), MCond::GT))
    insts = teko::list::push(insts, cset_inst(true, r(35), MCond::GE))
    insts = teko::list::push(insts, cset_inst(true, r(36), MCond::LO))
    insts = teko::list::push(insts, cset_inst(true, r(37), MCond::LS))
    insts = teko::list::push(insts, cset_inst(true, r(38), MCond::HI))
    insts = teko::list::push(insts, cset_inst(true, r(39), MCond::HS))
    insts = teko::list::push(insts, movz_inst(true, r(40), 100, 16))
    insts = teko::list::push(insts, movk_inst(true, r(40), 200, 32))
    insts = teko::list::push(insts, movn_inst(false, r(41), 1, 0))
    insts = teko::list::push(insts, fmov_inst(true, fr(42), r(0)))
    insts = teko::list::push(insts, mov_inst(false, r(43), r(0)))
    insts = teko::list::push(insts, ext_inst(MExtOp::Sxtb, r(44), r(0)))
    insts = teko::list::push(insts, ext_inst(MExtOp::Sxth, r(45), r(0)))
    insts = teko::list::push(insts, ext_inst(MExtOp::Sxtw, r(46), r(0)))
    insts = teko::list::push(insts, ext_inst(MExtOp::Uxtb, r(47), r(0)))
    insts = teko::list::push(insts, ext_inst(MExtOp::Uxth, r(48), r(0)))
    insts = teko::list::push(insts, ext_inst(MExtOp::Uxtw, r(49), r(0)))
    insts = teko::list::push(insts, cvt_inst(MCvtOp::Scvtf, fr(50), r(0)))
    insts = teko::list::push(insts, cvt_inst(MCvtOp::Ucvtf, fr(51), r(0)))
    insts = teko::list::push(insts, cvt_inst(MCvtOp::Fcvtzs, r(52), fr(0)))
    insts = teko::list::push(insts, cvt_inst(MCvtOp::Fcvtzu, r(53), fr(0)))
    insts = teko::list::push(insts, cvt_inst(MCvtOp::Fcvt, fr(54), fr(0)))
    insts = teko::list::push(insts, load_inst(MMemSize::X, false, r(60), mem(r(0), 8)))
    insts = teko::list::push(insts, load_inst(MMemSize::W, false, r(61), mem(r(0), 0)))
    insts = teko::list::push(insts, load_inst(MMemSize::H, false, r(62), mem(r(0), 2)))
    insts = teko::list::push(insts, load_inst(MMemSize::B, true, r(63), mem(r(0), -4 to i32)))
    insts = teko::list::push(insts, load_inst(MMemSize::S, false, fr(64), mem(r(0), 4)))
    insts = teko::list::push(insts, load_inst(MMemSize::D, false, fr(65), mem(r(0), 8)))
    insts = teko::list::push(insts, store_inst(MMemSize::X, r(0), mem(r(1), 0)))
    insts = teko::list::push(insts, store_inst(MMemSize::W, r(0), mem(r(1), 4)))
    insts = teko::list::push(insts, frame_addr_inst(r(70), 3))
    insts = teko::list::push(insts, adrp_inst(r(71), "some_global", MRelocKind::PageHi))
    insts = teko::list::push(insts, add_lo_inst(r(72), r(71), "some_global", MRelocKind::PageLo))
    insts = teko::list::push(insts, adrp_inst(r(73), "some_func", MRelocKind::Call))
    insts = teko::list::push(insts, add_lo_inst(r(74), r(73), "some_func", MRelocKind::Call))
    insts = teko::list::push(insts, branch_inst(1))
    MBlock { id = 0; params = teko::list::empty(); insts = insts }
}

/**
 * mk_block1 — the second machine block of `mk_full_module`'s fixture
 * function: the control-flow + call terminators (`MBranchCond`/`MCbz`/
 * `MCall`/`MCallIndirect`/`MRet`), carrying one block-arg so the printer's
 * params-header branch is exercised (W15 — flatten by extraction).
 *
 * @return MBlock  the control-flow block
 */
fn mk_block1() -> MBlock {
    mut insts: []MInst = teko::list::empty()
    insts = teko::list::push(insts, branch_cond_inst(MCond::EQ, 0))
    insts = teko::list::push(insts, cbz_inst(true, true, r(0), 0))
    insts = teko::list::push(insts, cbz_inst(false, false, r(0), 1))
    insts = teko::list::push(insts, call_inst("tk_exit", teko::list::push(teko::list::empty(), preg(0, MRegClass::GPR)), preg(0, MRegClass::GPR), false, false))
    let two_uses = teko::list::push(teko::list::push(teko::list::empty(), preg(0, MRegClass::GPR)), preg(1, MRegClass::GPR))
    insts = teko::list::push(insts, call_inst("tk_add", two_uses, preg(0, MRegClass::GPR), true, true))
    insts = teko::list::push(insts, call_indirect_inst(r(0), teko::list::empty(), preg(0, MRegClass::GPR), false))
    insts = teko::list::push(insts, call_indirect_inst(r(0), teko::list::push(teko::list::empty(), preg(0, MRegClass::GPR)), preg(0, MRegClass::FPR), true))
    insts = teko::list::push(insts, RET_INST)
    MBlock { id = 1; params = teko::list::push(teko::list::empty(), r(80)); insts = insts }
}

/**
 * mk_full_module — a module with two functions: `kitchen_sink` (one
 * instance of every `MInst` case, spanning both `wide`/`dbl` forms, every
 * `MCond`, every `MRelocKind`, and both `is_phys` states) plus `leaf` (a
 * minimal one-block function), exercising the whole printer surface the
 * golden-dump tests below assert against.
 *
 * @return MModule  the fixture module
 */
fn mk_full_module() -> MModule {
    let sink = MFunc {
        symbol = "kitchen_sink"
        blocks = teko::list::push(teko::list::push(teko::list::empty(), mk_block0()), mk_block1())
        frame = teko::list::empty()
    }
    let leaf_block = MBlock { id = 0; params = teko::list::empty(); insts = teko::list::push(teko::list::empty(), RET_INST) }
    let leaf = MFunc { symbol = "leaf"; blocks = teko::list::push(teko::list::empty(), leaf_block); frame = teko::list::empty() }
    add_mfunc(add_mfunc(empty_mmodule(), sink), leaf)
}

#test
fn builds_a_two_block_function_with_the_incremental_api() {
    mut f = new_mfunc("teko__demo__add")
    f = append_minst(f, 0, alu_inst(MAluOp::Add, true, r(2), r(0), r(1)))
    f = append_minst(f, 0, branch_inst(1))
    let blk1 = MBlock { id = 1; params = teko::list::push(teko::list::empty(), r(3)); insts = teko::list::empty() }
    f = MFunc { symbol = f.symbol; blocks = teko::list::push(f.blocks, blk1); frame = f.frame }
    f = append_minst(f, 1, mov_inst(true, preg(0, MRegClass::GPR), r(3)))
    f = append_minst(f, 1, RET_INST)
    let text = minst_print(add_mfunc(empty_mmodule(), f))
    teko::assert::str_contains(text, "func @teko__demo__add {")
    teko::assert::str_contains(text, "  #M0:")
    teko::assert::str_contains(text, "    add.x %2, %0, %1")
    teko::assert::str_contains(text, "    b #M1")
    teko::assert::str_contains(text, "  #M1(%3):")
    teko::assert::str_contains(text, "    mov.x %p0, %3")
    teko::assert::str_contains(text, "    ret")
}

#test
fn prints_every_integer_alu_op() {
    let text = minst_print(mk_full_module())
    teko::assert::str_contains(text, "add.x %10, %0, %1")
    teko::assert::str_contains(text, "sub.w %11, %0, %1")
    teko::assert::str_contains(text, "mul.x %12, %0, %1")
    teko::assert::str_contains(text, "sdiv.x %13, %0, %1")
    teko::assert::str_contains(text, "udiv.x %14, %0, %1")
    teko::assert::str_contains(text, "and.x %15, %0, %1")
    teko::assert::str_contains(text, "orr.x %16, %0, %1")
    teko::assert::str_contains(text, "eor.x %17, %0, %1")
    teko::assert::str_contains(text, "lsl.x %18, %0, %1")
    teko::assert::str_contains(text, "asr.x %19, %0, %1")
    teko::assert::str_contains(text, "lsr.x %20, %0, %1")
    teko::assert::str_contains(text, "add.w %21, %0, #5")
    teko::assert::str_contains(text, "msub.x %22, %13, %1, %0")
    teko::assert::str_contains(text, "neg.x %23, %0")
    teko::assert::str_contains(text, "mvn.w %24, %0")
}
