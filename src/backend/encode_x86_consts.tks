/**
 * The named x86-64 encoding constants for `encode_x86_64`: the ModRM/SIB/REX
 * field masks/bits, opcode bytes, and immediate/displacement range bounds the
 * encoder assembles byte strings from, split out as a sibling of the same
 * `backend` namespace. Each is named `X86_<ROLE>` (a bit mask/shift/field
 * value), `X86_OP_<mnemonic>`/`X86_EXT_<mnemonic>` (an opcode byte or ModRM
 * opcode-extension), or a `REX_`/`MODRM_` field constant; the golden hex
 * vectors in `encode_x86_64_test.tkt` pin every value.
 */

/**
 * X86_BYTE_MASK — the low-8-bits mask every byte-narrowing cast in this file
 * runs through first (all bit-slicing stays in `u32`/`i64`; only this final
 * `& 0xFF` narrows to `byte`, the VM byte-width anchoring rule). The first of
 * this file's whole W15 sweep (crumb S2) of named ModRM/SIB/REX field
 * masks/bits and opcode-byte constants below: each is named `X86_<ROLE>` (a
 * bit mask/shift/field value) or `X86_OP_<mnemonic>`/`X86_EXT_<mnemonic>` (an
 * opcode byte or ModRM opcode-extension), and its value is EXACTLY the x86-64
 * encoding byte the corpus's golden hex vectors (`encode_x86_64_test.tkt`)
 * already pin — only the SOURCE SPELLING changes; every emitted byte stays
 * identical (those goldens + `diff_c_own.sh` prove it).
 */
const X86_BYTE_MASK: u32 = 0xFF to u32

/**
 * X86_LOW32_MASK — the low-32-bits mask that forms a two's-complement 32-bit
 * pattern from an `i64` without ever reaching a panicking signed cast (the
 * imm32/disp32 split and the `rel32` patch's negative-displacement path).
 */
const X86_LOW32_MASK: i64 = 0xFFFFFFFF to i64

/**
 * REX_BASE — the bare REX prefix byte with no W/R/X/B bit set: `rex_x86`'s
 * base value, and the sentinel `push_rex_x86` compares against to elide a
 * REX prefix that carries no information.
 */
const REX_BASE: u32 = 0x40 to u32

/**
 * REX_W_SHIFT — the REX byte bit position of the W (64-bit operand size) bit.
 */
const REX_W_SHIFT: u32 = 3 to u32

/**
 * REX_R_SHIFT — the REX byte bit position of the R (ModRM.reg extension) bit.
 */
const REX_R_SHIFT: u32 = 2 to u32

/**
 * REX_X_SHIFT — the REX byte bit position of the X (SIB.index extension) bit.
 */
const REX_X_SHIFT: u32 = 1 to u32

/**
 * REX_W_PREFIX — the bare "REX.W only" prefix byte (`REX_BASE | 1<<REX_W_SHIFT`),
 * emitted directly wherever an instruction needs the 64-bit operand size but no
 * register-extension bit (the `divseq`/prologue/epilogue fixed-register forms
 * that never touch R8..R15).
 */
const REX_W_PREFIX: u32 = 0x48 to u32

/**
 * REX_B_PREFIX — the bare "REX.B only" prefix byte, forced before a `push`/`pop`
 * of R8..R15 (whose opcode `+rd` field cannot itself carry the high bit).
 */
const REX_B_PREFIX: u32 = 0x41 to u32

/**
 * X86_REG_HIGH_BIT — a physical register id's 4th bit: set for R8..R15/XMM8..15
 * (`reg_ext_x86`'s test) and, identically, the id range a `push`/`pop` opcode's
 * `+rd` field must instead route through `REX_B_PREFIX`.
 */
const X86_REG_HIGH_BIT: u32 = 0x8 to u32

/**
 * MODRM_MOD_SHIFT — the ModRM byte bit position of the 2-bit `mod` field.
 */
const MODRM_MOD_SHIFT: u32 = 6 to u32

/**
 * MODRM_MOD_MASK — the 2-bit width mask of the ModRM `mod` field.
 */
const MODRM_MOD_MASK: u32 = 0x3 to u32

/**
 * X86_FIELD3_SHIFT — the bit position shared by ModRM.reg (`modrm_x86`) and
 * SIB.index (`push_mem_operand_x86`'s forced-SIB byte): both are the middle
 * 3-bit sub-field of their byte.
 */
const X86_FIELD3_SHIFT: u32 = 3 to u32

/**
 * X86_FIELD3_MASK — the 3-bit field mask shared by ModRM.reg, ModRM.rm, and a
 * physical register id's low 3 bits (the bits that ride ModRM/SIB/opcode-`+rd`;
 * the high bit needing a REX extension is masked separately by
 * `X86_REG_HIGH_BIT`).
 */
const X86_FIELD3_MASK: u32 = 0x7 to u32

/**
 * MODRM_MOD_INDIRECT — the ModRM `mod=00` value: `[base]` with no displacement
 * (or, with `rm=101`, the RIP-relative escape — see `MODRM_RM_RIP_RELATIVE`).
 */
const MODRM_MOD_INDIRECT: u32 = 0 to u32

/**
 * MODRM_MOD_DISP8 — the ModRM `mod=01` value: `[base+disp8]`.
 */
const MODRM_MOD_DISP8: u32 = 1 to u32

/**
 * MODRM_MOD_DISP32 — the ModRM `mod=10` value: `[base+disp32]`.
 */
const MODRM_MOD_DISP32: u32 = 2 to u32

/**
 * MODRM_MOD_REGISTER — the ModRM `mod=11` value: register-direct addressing
 * (every reg-reg / reg-only encoding in this file rides this mod value).
 */
const MODRM_MOD_REGISTER: u32 = 3 to u32

/**
 * MODRM_RM_RIP_RELATIVE — the ModRM `rm=101` value under `MODRM_MOD_INDIRECT`:
 * not a real base register, but the `[rip+disp32]` addressing escape
 * `encode_lea_rip_x86` relies on (never confused with `X86_REG_RBP_ID`, whose
 * numeric value coincides but whose meaning does not — RBP addressing always
 * carries at least a disp8, per `is_rbp` in `push_mem_operand_x86`).
 */
const MODRM_RM_RIP_RELATIVE: u32 = 0x5 to u32

/**
 * X86_REG_RAX_ID — the RAX physical register id (the fixed dividend/quotient
 * register of `encode_divseq_x86`).
 */
const X86_REG_RAX_ID: u32 = 0 to u32

/**
 * X86_REG_RDX_ID — the RDX physical register id (the fixed high-half/remainder
 * register of `encode_divseq_x86`).
 */
const X86_REG_RDX_ID: u32 = 2 to u32

/**
 * X86_REG_RSP_ID — the RSP physical register id: `encode_frame_addr_x86`'s
 * frame base, and — because RSP/R12 share this low-3-bit pattern — the same
 * value `push_mem_operand_x86` compares a base register against to decide a
 * SIB byte is required, and the SIB `index=100` ("no index register") field
 * value it then emits.
 */
const X86_REG_RSP_ID: u32 = 4 to u32

/**
 * X86_REG_RBP_ID — the RBP physical register id: `emit_prologue_x86`'s frame-
 * pointer save, and — because RBP/R13 share this low-3-bit pattern — the same
 * value `push_mem_operand_x86` compares a base register against to force at
 * least a disp8 (mod=00 with this rm would otherwise mean RIP-relative, see
 * `MODRM_RM_RIP_RELATIVE`).
 */
const X86_REG_RBP_ID: u32 = 5 to u32

/**
 * X86_BYTE_REG_MIN_ID — the register id at and above which a REX prefix is
 * required to reach the low byte (SIL/DIL/BPL/SPL are ids 4..7, which without
 * REX alias AH/CH/DH/BH instead; R8..R15 already carry REX for other reasons).
 * Shared by a byte-store's source register and `SETcc`'s destination.
 */
const X86_BYTE_REG_MIN_ID: u32 = 4 to u32

/**
 * X86_CC_E — the x86 condition-code (`tttn`) field for `MCond::EQ`.
 */
const X86_CC_E: u32 = 0x4 to u32

/**
 * X86_CC_NE — the x86 condition-code field for `MCond::NE`.
 */
const X86_CC_NE: u32 = 0x5 to u32

/**
 * X86_CC_L — the x86 condition-code field for `MCond::LT` (signed less-than).
 */
const X86_CC_L: u32 = 0xC to u32

/**
 * X86_CC_LE — the x86 condition-code field for `MCond::LE` (signed).
 */
const X86_CC_LE: u32 = 0xE to u32

/**
 * X86_CC_G — the x86 condition-code field for `MCond::GT` (signed).
 */
const X86_CC_G: u32 = 0xF to u32

/**
 * X86_CC_GE — the x86 condition-code field for `MCond::GE` (signed).
 */
const X86_CC_GE: u32 = 0xD to u32

/**
 * X86_CC_B — the x86 condition-code field for `MCond::LO` (unsigned below).
 */
const X86_CC_B: u32 = 0x2 to u32

/**
 * X86_CC_BE — the x86 condition-code field for `MCond::LS` (unsigned).
 */
const X86_CC_BE: u32 = 0x6 to u32

/**
 * X86_CC_A — the x86 condition-code field for `MCond::HI` (unsigned above).
 */
const X86_CC_A: u32 = 0x7 to u32

/**
 * X86_CC_AE — the x86 condition-code field for `MCond::HS` (unsigned).
 */
const X86_CC_AE: u32 = 0x3 to u32

/**
 * X86_OP_ADD_RM_R — the `add r/m64, r64` opcode (two-address ALU, reg-into-rm
 * direction).
 */
const X86_OP_ADD_RM_R: u32 = 0x01 to u32

/**
 * X86_OP_SUB_RM_R — the `sub r/m64, r64` opcode.
 */
const X86_OP_SUB_RM_R: u32 = 0x29 to u32

/**
 * X86_OP_AND_RM_R — the `and r/m64, r64` opcode.
 */
const X86_OP_AND_RM_R: u32 = 0x21 to u32

/**
 * X86_OP_OR_RM_R — the `or r/m64, r64` opcode.
 */
const X86_OP_OR_RM_R: u32 = 0x09 to u32

/**
 * X86_OP_XOR_RM_R — the `xor r/m64, r64` opcode: `alu_opcode_x86`'s Xor arm,
 * and — reused directly — `encode_divseq_x86`'s `xor edx,edx` (unsigned
 * remainder-register zeroing).
 */
const X86_OP_XOR_RM_R: u32 = 0x31 to u32

/**
 * X86_EXT_SHL — the `D3 /4` ModRM opcode-extension for `shl r/m64, cl`.
 */
const X86_EXT_SHL: u32 = 0x4 to u32

/**
 * X86_EXT_SHR — the `D3 /5` ModRM opcode-extension for `shr r/m64, cl`.
 */
const X86_EXT_SHR: u32 = 0x5 to u32

/**
 * X86_EXT_SAR — the `D3 /7` ModRM opcode-extension for `sar r/m64, cl`.
 */
const X86_EXT_SAR: u32 = 0x7 to u32

/**
 * X86_OPERAND_SIZE_PREFIX — the `0x66` operand-size override prefix (the
 * 16-bit word memory-operand forms).
 */
const X86_OPERAND_SIZE_PREFIX: u32 = 0x66 to u32

/**
 * X86_OP_MOV_RM_R — the `mov r/m64, r64` opcode (reg-into-rm direction): the
 * GPR-GPR move, the qword/dword/word memory store, `mov rbp,rsp`, and both
 * fixed-register moves of `encode_divseq_x86`.
 */
const X86_OP_MOV_RM_R: u32 = 0x89 to u32

/**
 * X86_OP_MOV_R_RM — the `mov r64, r/m64` opcode (rm-into-reg direction): the
 * qword load and the dword non-sign-extending load (which zero-extends by
 * writing the 32-bit destination).
 */
const X86_OP_MOV_R_RM: u32 = 0x8B to u32

/**
 * X86_OP_MOVSXD — the `movsxd r64, r/m32` opcode (`63`): the sign-extending
 * dword load.
 */
const X86_OP_MOVSXD: u32 = 0x63 to u32

/**
 * X86_OP_MOVZX_R32_RM16 — the two-byte `movzx r32, r/m16` opcode (`0F B7`):
 * the zero-extending word load.
 */
const X86_OP_MOVZX_R32_RM16: u32 = 0xB7 to u32

/**
 * X86_OP_MOVZX_R32_RM8 — the two-byte `movzx r32, r/m8` opcode (`0F B6`): the
 * zero-extending byte load, and — reused directly — `SETcc`'s materializing
 * `movzx dst32, dst8` half.
 */
const X86_OP_MOVZX_R32_RM8: u32 = 0xB6 to u32

/**
 * X86_OP_MOVSX_R32_RM16 — the two-byte `movsx r32, r/m16` opcode (`0F BF`):
 * the sign-extending word load.
 */
const X86_OP_MOVSX_R32_RM16: u32 = 0xBF to u32

/**
 * X86_OP_MOVSX_R32_RM8 — the two-byte `movsx r32, r/m8` opcode (`0F BE`): the
 * sign-extending byte load.
 */
const X86_OP_MOVSX_R32_RM8: u32 = 0xBE to u32

/**
 * X86_OP_MOV_RM8_R8 — the `mov r/m8, r8` opcode (`88`): the byte store (whose
 * source register forces `byte_reg` handling).
 */
const X86_OP_MOV_RM8_R8: u32 = 0x88 to u32

/**
 * X86_OP_MOV_R_IMM — the `mov r32/r64, imm32/imm64` opcode (`B8+rd`): the
 * 32-bit immediate-move form and the `movabs` 64-bit immediate form (both
 * `encode_movimm_x86` cases whose opcode carries the destination in its low 3
 * bits).
 */
const X86_OP_MOV_R_IMM: u32 = 0xB8 to u32

/**
 * X86_OP_MOV_RM_IMM32 — the `mov r/m64, imm32` (sign-extended) opcode (`C7
 * /0`): the 64-bit immediate-move form that fits a signed 32-bit field.
 */
const X86_OP_MOV_RM_IMM32: u32 = 0xC7 to u32

/**
 * X86_OP_TWO_BYTE_ESCAPE — the `0x0F` two-byte-opcode escape prefix: `imul`,
 * every `movzx`/`movsx` memory load, `SETcc`, and `Jcc`.
 */
const X86_OP_TWO_BYTE_ESCAPE: u32 = 0x0F to u32

/**
 * X86_OP_IMUL_R_RM — the two-byte `imul r64, r/m64` opcode (`0F AF`): unlike
 * the `OP r/m,r` ALU direction, the DESTINATION rides the ModRM.reg field.
 */
const X86_OP_IMUL_R_RM: u32 = 0xAF to u32

/**
 * X86_OP_CQO — the `cqo` opcode (`99`): sign-extends RAX into RDX:RAX ahead
 * of a signed 64-bit `idiv`.
 */
const X86_OP_CQO: u32 = 0x99 to u32

/**
 * X86_OP_GRP3_F7 — the unary Group-3 opcode (`F7`): `neg`(`/3`), `not`(`/2`),
 * `idiv`(`/7`), `div`(`/6`) all share this primary byte, differing only in
 * the ModRM opcode-extension.
 */
const X86_OP_GRP3_F7: u32 = 0xF7 to u32

/**
 * X86_EXT_IDIV — the `F7 /7` ModRM opcode-extension for a signed `idiv`.
 */
const X86_EXT_IDIV: u32 = 0x7 to u32

/**
 * X86_EXT_DIV — the `F7 /6` ModRM opcode-extension for an unsigned `div`.
 */
const X86_EXT_DIV: u32 = 0x6 to u32

/**
 * X86_OP_SHIFT_CL — the `shl`/`shr`/`sar r/m64, cl` opcode (`D3`), the shift
 * variant differentiated only by its ModRM opcode-extension
 * (`X86_EXT_SHL`/`SHR`/`SAR`).
 */
const X86_OP_SHIFT_CL: u32 = 0xD3 to u32

/**
 * X86_OP_CMP_RM_R — the `cmp r/m64, r64` opcode (`39`), setting flags from
 * `a - b`.
 */
const X86_OP_CMP_RM_R: u32 = 0x39 to u32

/**
 * X86_OP_SETCC_BASE — the `SETcc r/m8` opcode base (`0F 90+cc`): materializes
 * a preceding compare as a 0/1 byte.
 */
const X86_OP_SETCC_BASE: u32 = 0x90 to u32

/**
 * X86_EXT_NEG — the `F7 /3` ModRM opcode-extension for `neg r/m64`.
 */
const X86_EXT_NEG: u32 = 0x3 to u32

/**
 * X86_EXT_NOT — the `F7 /2` ModRM opcode-extension for `not r/m64`.
 */
const X86_EXT_NOT: u32 = 0x2 to u32

/**
 * X86_OP_LEA — the `lea r64, m` opcode (`8D`): resolves a frame-slot address
 * and a `[rip+disp32]` symbol address alike.
 */
const X86_OP_LEA: u32 = 0x8D to u32

/**
 * X86_OP_JMP_REL32 — the `jmp rel32` opcode (`E9`).
 */
const X86_OP_JMP_REL32: u32 = 0xE9 to u32

/**
 * X86_OP_JCC_BASE — the `Jcc rel32` opcode base (`0F 80+cc`).
 */
const X86_OP_JCC_BASE: u32 = 0x80 to u32

/**
 * X86_OP_CALL_REL32 — the direct `call rel32` opcode (`E8`).
 */
const X86_OP_CALL_REL32: u32 = 0xE8 to u32

/**
 * X86_OP_GRP5_FF — the Group-5 opcode (`FF`) housing the indirect `call
 * r/m64` (`/2`, see `X86_EXT_CALL_IND`) among other unary forms this file
 * does not (yet) emit.
 */
const X86_OP_GRP5_FF: u32 = 0xFF to u32

/**
 * X86_EXT_CALL_IND — the `FF /2` ModRM opcode-extension for an indirect
 * `call r/m64`.
 */
const X86_EXT_CALL_IND: u32 = 0x2 to u32

/**
 * X86_OP_RET — the `ret` opcode (`C3`): the bare function-return terminator
 * byte (the B1-6 frame slice prepends the epilogue separately).
 */
const X86_OP_RET: u32 = 0xC3 to u32

/**
 * X86_OP_PUSH_R64 — the `push r64` opcode base (`50+rd`).
 */
const X86_OP_PUSH_R64: u32 = 0x50 to u32

/**
 * X86_OP_POP_R64 — the `pop r64` opcode base (`58+rd`).
 */
const X86_OP_POP_R64: u32 = 0x58 to u32

/**
 * X86_MODRM_MOV_RBP_RSP — the ModRM byte of `mov rbp, rsp` (`mod=11 reg=RSP
 * rm=RBP`, i.e. `modrm_x86(MODRM_MOD_REGISTER, X86_REG_RSP_ID,
 * X86_REG_RBP_ID)`), the frame-pointer setup that follows `push rbp`.
 */
const X86_MODRM_MOV_RBP_RSP: u32 = 0xE5 to u32

/**
 * X86_OP_GRP1_IMM8 — the Group-1 `sub r/m32, imm8` opcode (`83 /5`, sign-
 * extended): the short `sub rsp,#N` form for `N < X86_SUB_RSP_IMM8_MAX`.
 */
const X86_OP_GRP1_IMM8: u32 = 0x83 to u32

/**
 * X86_OP_GRP1_IMM32 — the Group-1 `sub r/m32, imm32` opcode (`81 /5`): the
 * wide `sub rsp,#N` form.
 */
const X86_OP_GRP1_IMM32: u32 = 0x81 to u32

/**
 * X86_MODRM_SUB_RSP — the ModRM byte of `sub rsp, #N` (`mod=11 reg=/5
 * rm=RSP`, i.e. `modrm_x86(MODRM_MOD_REGISTER, 5, X86_REG_RSP_ID)`), shared by
 * both the imm8 and imm32 `sub rsp` forms.
 */
const X86_MODRM_SUB_RSP: u32 = 0xEC to u32

/**
 * X86_OP_LEAVE — the `leave` opcode (`C9`): `mov rsp,rbp ; pop rbp` in one
 * byte, the frame-teardown counterpart of `push rbp ; mov rbp,rsp`.
 */
const X86_OP_LEAVE: u32 = 0xC9 to u32

/**
 * X86_IMM32_MAX — the largest value a signed 32-bit immediate field can hold
 * (`2^31 - 1`): `fits_i32_x86`'s upper bound, and (cast to `u32`) the frame-size
 * overflow guard `emit_sub_rsp_x86` checks before emitting `sub rsp,imm32`.
 */
const X86_IMM32_MAX: i64 = 2147483647 to i64

/**
 * X86_IMM32_MIN_MAGNITUDE — the magnitude of the smallest signed 32-bit
 * immediate (`2^31`); `fits_i32_x86`'s lower bound is `0 - X86_IMM32_MIN_MAGNITUDE`
 * (the two's-complement `INT32_MIN`, formed by subtraction since a negative
 * literal is not direct syntax).
 */
const X86_IMM32_MIN_MAGNITUDE: i64 = 2147483648 to i64

/**
 * X86_DISP8_MAGNITUDE — the magnitude of the smallest disp8 value (`-128`);
 * `push_mem_operand_x86`'s disp8 lower bound is `0 - X86_DISP8_MAGNITUDE`.
 */
const X86_DISP8_MAGNITUDE: i64 = 128 to i64

/**
 * X86_DISP8_MAX — the largest disp8 value (`127`); `push_mem_operand_x86`'s
 * disp8 upper bound.
 */
const X86_DISP8_MAX: i64 = 127 to i64

/**
 * X86_SUB_RSP_IMM8_MAX — the frame-size threshold at which `emit_sub_rsp_x86`
 * switches from the short `83 /5 ib` form to the wide `81 /5 id` form: an
 * amount at or above this would sign-extend the one byte into a NEGATIVE
 * 32-bit subtrahend under `X86_OP_GRP1_IMM8` (the same "positive range of a
 * sign-extending single byte" rule as `X86_DISP8_MAX + 1`).
 */
const X86_SUB_RSP_IMM8_MAX: u32 = 128 to u32

/**
 * X86_GPR_BYTES — the byte size of one pushed 64-bit GPR: the per-register
 * contribution `frame_sub_size_x86`/`compute_frame_layout_x86` fold into the
 * callee-saved push-region size.
 */
const X86_GPR_BYTES: u32 = 8 to u32

/**
 * X86_STACK_ALIGN — the SysV AMD64 16-byte call-boundary stack alignment
 * `frame_sub_size_x86` rounds the `sub rsp` region up to.
 */
const X86_STACK_ALIGN: u32 = 16 to u32

/**
 * X86_BITS_PER_BYTE — the bit width of one byte: `byte_of_u32_le`'s shift-per-
 * index step when slicing a little-endian byte out of a 32-bit value.
 */
const X86_BITS_PER_BYTE: u32 = 8 to u32

/**
 * X86_REL32_FIELD_BYTES — the byte width of a `rel32` field (4): the constant
 * `reloc_addend_x86` negates for the `Plt32`/`Pc32` PC-relative addend
 * (relative to the END of the field, per `R_X86_64_PLT32`/`PC32`), the same
 * field width `patch_branches_x86` adds to a fixup's `field_off` when
 * computing an intra-function branch displacement from that same field end,
 * and (cast to `u32`) the span `write_u32_le_at` overwrites at a patched
 * offset.
 */
const X86_REL32_FIELD_BYTES: i64 = 4 to i64
