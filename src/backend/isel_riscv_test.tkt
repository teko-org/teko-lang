    let bp = lir::add_block_param(v0.func, b1.block_id)
    let s0 = lir::append_inst(bp.func, 0, lir::const_int_inst(v0.vreg, 1 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(v0.vreg, b1.block_id, teko::list::push(teko::list::empty(), v0.vreg), b2.block_id, teko::list::empty(), 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::ret_inst(bp.vreg, 0, 0))
    let s3 = lir::append_inst(s2, b2.block_id, lir::ret_inst(v0.vreg, 0, 0))
    let text = rat_dump(s3)
    teko::assert::str_contains(text, "bne %0, %p0, #M3")
    teko::assert::str_contains(text, "jal x0, #M1")
}

