#test
fn rat_call_pins_a0_and_emits_call() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let v = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(v.func, 0, lir::const_int_inst(v.vreg, 42 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::void_call_inst("tk_exit", teko::list::push(teko::list::empty(), v.vreg), false, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(v.vreg, 0, 0))
    let text = rat_dump(s2)
    teko::assert::str_contains(text, "addi %p10, %0, #0")
    teko::assert::str_contains(text, "call @tk_exit(%p10)")
}

#test
fn rat_call_with_result_moves_a0_out() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let r = lir::alloc_vreg(f0)
    let s0 = lir::append_inst(r.func, 0, lir::call_inst(r.vreg, "teko__demo__f", teko::list::empty(), false, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::ret_inst(r.vreg, 0, 0))
    let text = rat_dump(s1)
    teko::assert::str_contains(text, "call @teko__demo__f() -> %p10")
    teko::assert::str_contains(text, "addi %0, %p10, #0")
}

