#test
fn rat_extend_and_truncate_are_identity_moves() {
    let ft = rat_one_i64_param("teko__demo__trunc")
    let rt = rat_un(ft, lir::LUnOp::Trunc, 0)
    teko::assert::str_contains(rat_dump(rat_ret(rt.func, rt.vreg)), "addi %1, %0, #0")
    let fz = rat_one_i64_param("teko__demo__zext")
    let rz = rat_un(fz, lir::LUnOp::ZExt, 0)
    teko::assert::str_contains(rat_dump(rat_ret(rz.func, rz.vreg)), "addi %1, %0, #0")
    let fs = rat_one_i64_param("teko__demo__sext")
    let rs = rat_un(fs, lir::LUnOp::SExt, 0)
    teko::assert::str_contains(rat_dump(rat_ret(rs.func, rs.vreg)), "addi %1, %0, #0")
}

#test
fn rat_void_ret_selects_bare_ret() {
    let f = lir::append_inst(rat_main_ret(), 0, lir::ret_void_inst(0, 0))
    teko::assert::str_contains(rat_dump(f), "ret")
}

#test
fn rat_param_covers_scalar_gpr_classes_and_float_stops() {
    teko::assert::is_true(rat_select_succeeds(rat_one_param_func(lir::LType::I8)))
    teko::assert::is_true(rat_select_succeeds(rat_one_param_func(lir::LType::I16)))
    teko::assert::is_true(rat_select_succeeds(rat_one_param_func(lir::LType::I32)))
    teko::assert::is_true(rat_select_succeeds(rat_one_param_func(lir::LType::I64)))
    teko::assert::is_true(rat_select_succeeds(rat_one_param_func(lir::LType::Ptr)))
    teko::assert::is_true(rat_select_succeeds(rat_one_param_func(lir::LType::Void)))
    teko::assert::is_true(!rat_select_succeeds(rat_one_param_func(lir::LType::F16)))
    teko::assert::is_true(!rat_select_succeeds(rat_one_param_func(lir::LType::F32)))
    teko::assert::is_true(!rat_select_succeeds(rat_one_param_func(lir::LType::F64)))
    teko::assert::is_true(!rat_select_succeeds(rat_one_param_func(lir::LType::I128)))
}

