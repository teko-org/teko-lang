#test
fn rat_complement_is_xori_minus_one() {
    let f = rat_one_i64_param("teko__demo__not")
    let r = rat_un(f, lir::LUnOp::INot, 0)
    teko::assert::str_contains(rat_dump(rat_ret(r.func, r.vreg)), "xori %1, %0, #-1")
