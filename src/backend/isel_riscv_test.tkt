#test
fn rat_branch_on_fused_float_compare_propagates() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let s0 = lir::append_inst(f0, 0, lir::bin_inst(0, lir::LBinOp::FCmpEq, 1, 2, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(0, 1, teko::list::empty(), 2, teko::list::empty(), 0, 0))
    let br = lir::LBranch { cond = 0; t_target = 1; t_args = teko::list::empty(); f_target = 2; f_args = teko::list::empty() }
    match select_branch_riscv(rat_bare_ctx("main"), s1, br) {
        SelCtxRiscv => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B2-fp")
    }
}

#test
fn rat_fused_float_compare_branch_names_b2_fp() {
    let ctx = rat_bare_ctx("main")
    let dc = DefCmp { found = true; op = lir::LBinOp::FCmpEq; a = 0; bb = 1 }
    match select_fused_branch_riscv(ctx, dc, 0) {
        SelCtxRiscv => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B2-fp")
    }
}

#test
fn rat_edge_move_of_float_value_names_b2_fp() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let bp = lir::add_block_param(b1.func, b1.block_id)
    let ctx = selctx_riscv_set_vinfo(rat_bare_ctx("main"), 0, MRegClass::FPR, true)
    match emit_edge_moves_riscv(ctx, bp.func, b1.block_id, teko::list::push(teko::list::empty(), 0 to u32)) {
        SelCtxRiscv => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B2-fp")
    }
}

#test
fn rat_module_selects_every_function() {
    let f = rat_two_i64_params("teko__demo__add")
    let r = rat_bin(f, lir::LBinOp::IAdd, 0, 1)
    let done = rat_ret(r.func, r.vreg)
    let m = lir::LModule { funcs = teko::list::push(teko::list::empty(), done); rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match select_module_riscv(m) {
        MModuleRiscv as mm => teko::assert::str_contains(minst_print_riscv(mm), "add %2, %0, %1")
        error => teko::assert::is_true(false)
    }
}

#test
fn rat_module_propagates_first_error() {
    let c = rat_const(rat_main_ret(), 4294967296)
    let bad = rat_ret(c.func, c.vreg)
    let m = lir::LModule { funcs = teko::list::push(teko::list::empty(), bad); rodata = teko::list::empty(); globals = teko::list::empty(); layouts = teko::list::empty() }
    match select_module_riscv(m) {
        MModuleRiscv => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "B2-bigimm")
    }
}
