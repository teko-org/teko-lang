#test
fn rat_mem_size_covers_every_transfer_class() {
    teko::assert::is_true(rat_load_ty_succeeds(lir::LType::I8))
    teko::assert::is_true(rat_load_ty_succeeds(lir::LType::I16))
    teko::assert::is_true(rat_load_ty_succeeds(lir::LType::I32))
    teko::assert::is_true(rat_load_ty_succeeds(lir::LType::I64))
    teko::assert::is_true(rat_load_ty_succeeds(lir::LType::Ptr))
    teko::assert::is_true(!rat_load_ty_succeeds(lir::LType::F32))
    teko::assert::is_true(!rat_load_ty_succeeds(lir::LType::F64))
    teko::assert::is_true(!rat_load_ty_succeeds(lir::LType::F16))
    teko::assert::is_true(!rat_load_ty_succeeds(lir::LType::I128))
    teko::assert::is_true(!rat_load_ty_succeeds(lir::LType::Void))
}

