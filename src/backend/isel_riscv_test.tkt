use teko::lir

/**
 * rat_i128 — the i128 carrier for a small integer literal in the RISC-V isel
 * fixtures (mirrors `isel_x86_64_test.tkt`'s `xat_i128`).
 *
 * @param i64 v  the literal value
 * @return i128  its i128 carrier
 */
fn rat_i128(v: i64) -> i128 {
    v to i128
}

/**
 * rat_bin — append `%r = op a, b` to `f0`, returning the advanced function plus
 * the fresh result VReg (a fixture-building shorthand).
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LBinOp op  the binary op
 * @param u32 a  the first operand VReg
 * @param u32 b  the second operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn rat_bin(f0: lir::LFunc, op: lir::LBinOp, a: u32, b: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::bin_inst(r.vreg, op, a, b, 0, 0)); vreg = r.vreg }
}

/**
 * rat_un — append `%r = op a` to `f0`, returning the advanced function plus the
 * fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param lir::LUnOp op  the unary op
 * @param u32 a  the operand VReg
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn rat_un(f0: lir::LFunc, op: lir::LUnOp, a: u32) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::un_inst(r.vreg, op, a, 0, 0)); vreg = r.vreg }
}

/**
 * rat_const — append `%r = const val` to `f0`, returning the advanced function
 * plus the fresh result VReg.
 *
 * @param lir::LFunc f0  the function to extend
 * @param i64 val  the literal value
 * @return lir::FreshVReg  the advanced function + the result VReg
 */
fn rat_const(f0: lir::LFunc, val: i64) -> lir::FreshVReg {
    let r = lir::alloc_vreg(f0)
    lir::FreshVReg { func = lir::append_inst(r.func, 0, lir::const_int_inst(r.vreg, rat_i128(val), 0, 0)); vreg = r.vreg }
}

/**
 * rat_ret — append `ret value` to `f0`.
 *
 * @param lir::LFunc f0  the function to extend
 * @param u32 value  the returned VReg
 * @return lir::LFunc  the advanced function
 */
fn rat_ret(f0: lir::LFunc, value: u32) -> lir::LFunc {
    lir::append_inst(f0, 0, lir::ret_inst(value, 0, 0))
}

/**
 * rat_two_i64_params — a fresh 2-param (I64, I64) -> I64 function named `sym`,
 * its entry block already carrying both `LParam` instructions.
 *
 * @param str sym  the function's symbol
 * @return lir::LFunc  the seeded function
 */
fn rat_two_i64_params(sym: str) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::push(teko::list::empty(), lir::LType::I64), lir::LType::I64)
    mut f = lir::new_func(sym, 2, ptypes, lir::LType::I64)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    lir::append_inst(f, 0, lir::param_inst(1, 1, 0, 0))
}

/**
 * rat_one_i64_param — a fresh 1-param (I64) -> I64 function named `sym`, its
 * entry block already carrying the single `LParam`.
 *
 * @param str sym  the function's symbol
 * @return lir::LFunc  the seeded function
 */
fn rat_one_i64_param(sym: str) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::empty(), lir::LType::I64)
    mut f = lir::new_func(sym, 1, ptypes, lir::LType::I64)
    lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
}

/**
 * rat_main_ret — a zero-param `main` seed (the straight-line fixture base).
 *
 * @return lir::LFunc  the seeded, empty-bodied function
 */
fn rat_main_ret() -> lir::LFunc {
    lir::new_func("main", 0, teko::list::empty(), lir::LType::I32)
}

/**
 * rat_dump — select `f` for RISC-V and render the machine module as text (the
 * golden-dump fixtures assert against key lines of this); "" on a selection
 * error.
 *
 * @param lir::LFunc f  the function to select and print
 * @return str  the rendered machine text ("" on a selection error)
 */
fn rat_dump(f: lir::LFunc) -> str {
    let mf = match select_lfunc_riscv(f) { MFuncRiscv as x => x; error => return "" }
    minst_print_riscv(add_mfunc_riscv(empty_mmodule_riscv(), mf))
}

/**
 * rat_bare_ctx — a bare single-block `SelCtxRiscv` seed for the direct-call unit
 * tests (the honest-stops unreachable through a normal fixture, because their
 * float source instruction stops selection first).
 *
 * @param str sym  the machine function's symbol
 * @return SelCtxRiscv  the seeded context
 */
fn rat_bare_ctx(sym: str) -> SelCtxRiscv {
    SelCtxRiscv { func = new_mfunc_riscv(sym); vinfo = vinfo_empty(); next_scratch = 0; cur_block = 0; next_block = 1 }
}

/**
 * rat_one_param_func — a single-parameter function of machine class `ty` (its
 * own return type too), its param read via `LParam` and returned directly — the
 * coverage sweep for `select_param_riscv`'s GPR path and its float/i128 stops.
 *
 * @param lir::LType ty  the parameter's (and return's) machine class
 * @return lir::LFunc  the built function
 */
fn rat_one_param_func(ty: lir::LType) -> lir::LFunc {
    let ptypes = teko::list::push(teko::list::empty(), ty)
    mut f = lir::new_func("teko__demo__one_param", 1, ptypes, ty)
    f = lir::append_inst(f, 0, lir::param_inst(0, 0, 0, 0))
    rat_ret(f, 0)
}

/**
 * rat_select_succeeds — whether `select_lfunc_riscv(f)` selects without error.
 *
 * @param lir::LFunc f  the function to select
 * @return bool  whether selection succeeded
 */
fn rat_select_succeeds(f: lir::LFunc) -> bool {
    match select_lfunc_riscv(f) { MFuncRiscv => true; error => false }
}

/**
 * rat_load_ty_succeeds — whether an `alloca`+`load ty`+`ret` function selects
 * for RISC-V (the coverage sweep over `mem_size_riscv`'s every arm).
 *
 * @param lir::LType ty  the loaded machine class
 * @return bool  whether selection succeeded
 */
fn rat_load_ty_succeeds(ty: lir::LType) -> bool {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let base = lir::alloc_vreg(f0)
    let ld = lir::alloc_vreg(base.func)
    let s0 = lir::append_inst(ld.func, 0, lir::alloca_inst(base.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::load_inst(ld.vreg, base.vreg, ty, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(ld.vreg, 0, 0))
    match select_lfunc_riscv(s2) { MFuncRiscv => true; error => false }
}

/**
 * rat_cmp_dump — a 2-param function whose only body is `%2 = op %0, %1` then
 * `ret %2` (the compare is NOT fused — a `ret` is no branch — so it lowers as a
 * value), selected and rendered. The per-condition value-compare golden reads
 * this.
 *
 * @param lir::LBinOp op  the compare opcode
 * @return str  the rendered machine text
 */
fn rat_cmp_dump(op: lir::LBinOp) -> str {
    let f = rat_two_i64_params("teko__demo__cmp")
    let r = rat_bin(f, op, 0, 1)
    rat_dump(rat_ret(r.func, r.vreg))
}

/**
 * rat_n_i64_params — a `main`-like function with `n` `I64` parameters, each read
 * via `LParam`, returning the first (the LP64D GPR-window-overflow fixture: 8
 * fill a0..a7, the 9th needs the stack slot).
 *
 * @param u32 n  how many parameters to build
 * @return lir::LFunc  the built function
 */
fn rat_n_i64_params(n: u32) -> lir::LFunc {
    mut ptypes: []lir::LType = teko::list::empty()
    mut k: u32 = 0
    loop {
        if k >= n { break }
        ptypes = teko::list::push(ptypes, lir::LType::I64)
        k++
    }
    mut f = lir::new_func("teko__demo__many", n, ptypes, lir::LType::I64)
    mut i: u32 = 0
    loop {
        if i >= n { break }
        f = lir::append_inst(f, 0, lir::param_inst(i, i, 0, 0))
        i++
    }
    rat_ret(f, 0)
}

/**
 * rat_call_n_args — a `main` calling `tk_sink` with `n` integer arguments (each
 * a fresh const), the LP64D call-window-overflow fixture (9 arguments exceed the
 * 8-register integer window).
 *
 * @param u32 n  how many integer arguments to pass
 * @return lir::LFunc  the built function
 */
fn rat_call_n_args(n: u32) -> lir::LFunc {
    mut f = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    mut args: []u32 = teko::list::empty()
    mut i: u32 = 0
    loop {
        if i >= n { break }
        let r = lir::alloc_vreg(f)
        f = lir::append_inst(r.func, 0, lir::const_int_inst(r.vreg, 1 to i128, 0, 0))
        args = teko::list::push(args, r.vreg)
        i++
    }
    f = lir::append_inst(f, 0, lir::void_call_inst("tk_sink", args, false, 0, 0))
    lir::append_inst(f, 0, lir::ret_void_inst(0, 0))
}

#test
fn rat_two_param_add_is_three_address_no_copy() {
    let f = rat_two_i64_params("teko__demo__add")
    let r = rat_bin(f, lir::LBinOp::IAdd, 0, 1)
    let text = rat_dump(rat_ret(r.func, r.vreg))
    teko::assert::str_contains(text, "func @teko__demo__add {")
    teko::assert::str_contains(text, "addi %0, %p10, #0")
    teko::assert::str_contains(text, "addi %1, %p11, #0")
    teko::assert::str_contains(text, "add %2, %0, %1")
    teko::assert::str_contains(text, "addi %p10, %2, #0")
    teko::assert::str_contains(text, "ret")
}

#test
fn rat_every_integer_alu_is_one_native_instruction() {
    let f = rat_two_i64_params("teko__demo__alu")
    let add = rat_bin(f, lir::LBinOp::IAdd, 0, 1)
    let sub = rat_bin(add.func, lir::LBinOp::ISub, 0, 1)
    let mul = rat_bin(sub.func, lir::LBinOp::IMul, 0, 1)
    let and = rat_bin(mul.func, lir::LBinOp::IAnd, 0, 1)
    let orr = rat_bin(and.func, lir::LBinOp::IOr, 0, 1)
    let xor = rat_bin(orr.func, lir::LBinOp::IXor, 0, 1)
    let shl = rat_bin(xor.func, lir::LBinOp::IShl, 0, 1)
    let shrs = rat_bin(shl.func, lir::LBinOp::IShrS, 0, 1)
    let shru = rat_bin(shrs.func, lir::LBinOp::IShrU, 0, 1)
    let text = rat_dump(rat_ret(shru.func, add.vreg))
    teko::assert::str_contains(text, "add %2, %0, %1")
    teko::assert::str_contains(text, "sub %3, %0, %1")
    teko::assert::str_contains(text, "mul %4, %0, %1")
    teko::assert::str_contains(text, "and %5, %0, %1")
    teko::assert::str_contains(text, "or %6, %0, %1")
    teko::assert::str_contains(text, "xor %7, %0, %1")
    teko::assert::str_contains(text, "sll %8, %0, %1")
    teko::assert::str_contains(text, "sra %9, %0, %1")
    teko::assert::str_contains(text, "srl %10, %0, %1")
}

#test
fn rat_div_and_rem_are_native_m_extension() {
    let f = rat_two_i64_params("teko__demo__divrem")
    let divs = rat_bin(f, lir::LBinOp::IDivS, 0, 1)
    let divu = rat_bin(divs.func, lir::LBinOp::IDivU, 0, 1)
    let rems = rat_bin(divu.func, lir::LBinOp::IRemS, 0, 1)
    let remu = rat_bin(rems.func, lir::LBinOp::IRemU, 0, 1)
    let text = rat_dump(rat_ret(remu.func, divs.vreg))
    teko::assert::str_contains(text, "div %2, %0, %1")
    teko::assert::str_contains(text, "divu %3, %0, %1")
    teko::assert::str_contains(text, "rem %4, %0, %1")
    teko::assert::str_contains(text, "remu %5, %0, %1")
}

