    let s0 = lir::append_inst(bp.func, 0, lir::jump_inst(b1.block_id, teko::list::empty(), 0, 0))
    let s1 = lir::append_inst(s0, b1.block_id, lir::ret_inst(bp.vreg, 0, 0))
    match select_lfunc_riscv(s1) {
        MFuncRiscv => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "does not match")
    }
}

#test
fn rat_fused_compare_branch_is_one_branch_then_jal() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let v1 = lir::alloc_vreg(v0.func)
    let v2 = lir::alloc_vreg(v1.func)
    let v3 = lir::alloc_vreg(v2.func)
    let v4 = lir::alloc_vreg(v3.func)
    let s0 = lir::append_inst(v4.func, 0, lir::const_int_inst(v0.vreg, 5 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::const_int_inst(v1.vreg, 3 to i128, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::bin_inst(v2.vreg, lir::LBinOp::ICmpGtS, v0.vreg, v1.vreg, 0, 0))
    let s3 = lir::append_inst(s2, 0, lir::branch_inst(v2.vreg, b1.block_id, teko::list::empty(), b2.block_id, teko::list::empty(), 0, 0))
    let s4 = lir::append_inst(s3, b1.block_id, lir::const_int_inst(v3.vreg, 1 to i128, 0, 0))
    let s5 = lir::append_inst(s4, b1.block_id, lir::ret_inst(v3.vreg, 0, 0))
    let s6 = lir::append_inst(s5, b2.block_id, lir::const_int_inst(v4.vreg, 2 to i128, 0, 0))
    let s7 = lir::append_inst(s6, b2.block_id, lir::ret_inst(v4.vreg, 0, 0))
    let text = rat_dump(s7)
    teko::assert::str_contains(text, "blt %1, %0, #M1")
    teko::assert::str_contains(text, "jal x0, #M2")
}

#test
fn rat_generic_boolean_branch_tests_against_zero() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let v1 = lir::alloc_vreg(v0.func)
    let v2 = lir::alloc_vreg(v1.func)
    let s0 = lir::append_inst(v2.func, 0, lir::const_int_inst(v0.vreg, 1 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::branch_inst(v0.vreg, b1.block_id, teko::list::empty(), b2.block_id, teko::list::empty(), 0, 0))
    let s2 = lir::append_inst(s1, b1.block_id, lir::const_int_inst(v1.vreg, 10 to i128, 0, 0))
    let s3 = lir::append_inst(s2, b1.block_id, lir::ret_inst(v1.vreg, 0, 0))
    let s4 = lir::append_inst(s3, b2.block_id, lir::const_int_inst(v2.vreg, 20 to i128, 0, 0))
    let s5 = lir::append_inst(s4, b2.block_id, lir::ret_inst(v2.vreg, 0, 0))
    let text = rat_dump(s5)
    teko::assert::str_contains(text, "bne %0, %p0, #M1")
    teko::assert::str_contains(text, "jal x0, #M2")
}

#test
fn rat_unfused_compare_branch_tests_the_value() {
    let f0 = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let b1 = lir::alloc_block(f0)
    let b2 = lir::alloc_block(b1.func)
    let v0 = lir::alloc_vreg(b2.func)
    let v1 = lir::alloc_vreg(v0.func)
    let v2 = lir::alloc_vreg(v1.func)
    let bp = lir::add_block_param(v2.func, b1.block_id)
    let s0 = lir::append_inst(bp.func, 0, lir::const_int_inst(v0.vreg, 5 to i128, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::const_int_inst(v1.vreg, 3 to i128, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::bin_inst(v2.vreg, lir::LBinOp::ICmpGtS, v0.vreg, v1.vreg, 0, 0))
    let s3 = lir::append_inst(s2, 0, lir::branch_inst(v2.vreg, b1.block_id, teko::list::push(teko::list::empty(), v2.vreg), b2.block_id, teko::list::empty(), 0, 0))
    let s4 = lir::append_inst(s3, b1.block_id, lir::ret_inst(bp.vreg, 0, 0))
    let s5 = lir::append_inst(s4, b2.block_id, lir::ret_inst(v2.vreg, 0, 0))
    let text = rat_dump(s5)
    teko::assert::str_contains(text, "slt %2, %1, %0")
    teko::assert::str_contains(text, "bne %2, %p0, #M3")
}

#test
fn rat_branch_with_edge_args_splits_edge_block() {
