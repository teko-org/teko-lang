#test
fn rat_value_compares_lower_per_condition() {
    teko::assert::str_contains(rat_cmp_dump(lir::LBinOp::ICmpLtS), "slt %2, %0, %1")
    teko::assert::str_contains(rat_cmp_dump(lir::LBinOp::ICmpLtU), "sltu %2, %0, %1")
    teko::assert::str_contains(rat_cmp_dump(lir::LBinOp::ICmpGtS), "slt %2, %1, %0")
    teko::assert::str_contains(rat_cmp_dump(lir::LBinOp::ICmpGtU), "sltu %2, %1, %0")
    let ges = rat_cmp_dump(lir::LBinOp::ICmpGeS)
    teko::assert::str_contains(ges, "slt %2, %0, %1")
    teko::assert::str_contains(ges, "xori %2, %2, #1")
    let geu = rat_cmp_dump(lir::LBinOp::ICmpGeU)
    teko::assert::str_contains(geu, "sltu %2, %0, %1")
    teko::assert::str_contains(geu, "xori %2, %2, #1")
    let les = rat_cmp_dump(lir::LBinOp::ICmpLeS)
    teko::assert::str_contains(les, "slt %2, %1, %0")
    teko::assert::str_contains(les, "xori %2, %2, #1")
    let leu = rat_cmp_dump(lir::LBinOp::ICmpLeU)
    teko::assert::str_contains(leu, "sltu %2, %1, %0")
    teko::assert::str_contains(leu, "xori %2, %2, #1")
    let eq = rat_cmp_dump(lir::LBinOp::ICmpEq)
    teko::assert::str_contains(eq, "sub %2, %0, %1")
    teko::assert::str_contains(eq, "sltiu %2, %2, #1")
    let ne = rat_cmp_dump(lir::LBinOp::ICmpNe)
    teko::assert::str_contains(ne, "sub %2, %0, %1")
    teko::assert::str_contains(ne, "sltu %2, %p0, %2")
}

#test
fn rat_negate_is_sub_from_zero() {
    let f = rat_one_i64_param("teko__demo__neg")
    let r = rat_un(f, lir::LUnOp::INeg, 0)
    teko::assert::str_contains(rat_dump(rat_ret(r.func, r.vreg)), "sub %1, %p0, %0")
