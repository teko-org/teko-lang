#test
fn rat_narrow_loads_zero_extend() {
    let fb = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let base = lir::alloc_vreg(fb)
    let lb = lir::alloc_vreg(base.func)
    let s0 = lir::append_inst(lb.func, 0, lir::alloca_inst(base.vreg, 8, 8, 0, 0))
    let s1 = lir::append_inst(s0, 0, lir::load_inst(lb.vreg, base.vreg, lir::LType::I8, 0, 0))
    let s2 = lir::append_inst(s1, 0, lir::ret_inst(lb.vreg, 0, 0))
    teko::assert::str_contains(rat_dump(s2), "lbu %1, 0(%0)")
    let fw = lir::new_func("main", 0, teko::list::empty(), lir::LType::I64)
    let wbase = lir::alloc_vreg(fw)
    let lw = lir::alloc_vreg(wbase.func)
    let w0 = lir::append_inst(lw.func, 0, lir::alloca_inst(wbase.vreg, 8, 8, 0, 0))
    let w1 = lir::append_inst(w0, 0, lir::load_inst(lw.vreg, wbase.vreg, lir::LType::I32, 0, 0))
    let w2 = lir::append_inst(w1, 0, lir::ret_inst(lw.vreg, 0, 0))
    teko::assert::str_contains(rat_dump(w2), "lwu %1, 0(%0)")
}

