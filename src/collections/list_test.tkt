#test
/**
 * push then read back three i64 elements — len tracks the growth and get returns each element.
 *
 * This file tests teko::collections::List<T> (issue #163): the growable-sequence contract at TWO
 * instantiations (i64 + str, proving the body monomorphizes per element width) — push / get / len /
 * is_empty round-trips, in-place set, pop and remove_at shrink, the reference-semantic aliasing law
 * (two references to one list observe each other's mutations), and the to_array iteration snapshot.
 * Pure Teko, VM-runnable — every case gates BOTH engines.
 */
fn list_i64_push_get_len() {
    let xs = List<i64>::make()
    teko::assert::is_true(xs.is_empty())
    xs.push(10)
    xs.push(20)
    xs.push(30)
    teko::assert::is_false(xs.is_empty())
    teko::assert::is_true(xs.len() == 3)
    teko::assert::is_true(xs.get(0) == 10)
    teko::assert::is_true(xs.get(1) == 20)
    teko::assert::is_true(xs.get(2) == 30)
}

#test
/**
 * The SAME body at `str` — the second instantiation, proving push/get/len monomorphize per width.
 */
fn list_str_push_get_len() {
    let xs = List<str>::make()
    xs.push("a")
    xs.push("bb")
    xs.push("ccc")
    teko::assert::is_true(xs.len() == 3)
    teko::assert::is_true(xs.get(0) == "a")
    teko::assert::is_true(xs.get(2) == "ccc")
}

#test
/**
 * set overwrites one slot in place without changing the length; the other slots are untouched.
 */
fn list_set_overwrites_in_place() {
    let xs = List<i64>::make()
    xs.push(1)
    xs.push(2)
    xs.push(3)
    xs.set(1, 99)
    teko::assert::is_true(xs.len() == 3)
    teko::assert::is_true(xs.get(0) == 1)
    teko::assert::is_true(xs.get(1) == 99)
    teko::assert::is_true(xs.get(2) == 3)
}

#test
/**
 * pop shrinks the list from the end; remove_at drops an interior element and shifts the rest down.
 */
fn list_pop_and_remove_at_shrink() {
    let xs = List<i64>::make()
    xs.push(1)
    xs.push(2)
    xs.push(3)
    xs.pop()
    teko::assert::is_true(xs.len() == 2)
    teko::assert::is_true(xs.get(1) == 2)
    xs.remove_at(0)
    teko::assert::is_true(xs.len() == 1)
    teko::assert::is_true(xs.get(0) == 2)
}

#test
/**
 * Popping an empty list is a no-op — the length stays zero (no fail-loud, the caller guards).
 */
fn list_pop_empty_is_noop() {
    let xs = List<i64>::make()
    xs.pop()
    teko::assert::is_true(xs.is_empty())
    teko::assert::is_true(xs.len() == 0)
}

#test
/**
 * Reference semantics: two bindings to the SAME list observe each other's mutations (a class is a
 * reference type — the collections ruling's whole reason for List being a class, not a struct).
 */
fn list_aliasing_is_reference_semantic() {
    let a = List<i64>::make()
    let b = a
    a.push(7)
    b.push(8)
    teko::assert::is_true(a.len() == 2)
    teko::assert::is_true(b.len() == 2)
    teko::assert::is_true(a.get(0) == 7)
    teko::assert::is_true(b.get(1) == 8)
}

#test
/**
 * to_array yields a value snapshot that a `loop` can iterate; the snapshot is independent of later
 * mutations to the list.
 */
fn list_to_array_snapshot_iterates() {
    let xs = List<i64>::make()
    xs.push(2)
    xs.push(3)
    xs.push(4)
    let snap = xs.to_array()
    mut sum: i64 = 0
    mut i: u64 = 0
    loop {
        if i >= snap.len { break }
        sum = sum + snap[i]
        i++
    }
    teko::assert::is_true(sum == 9)
    xs.push(100)
    teko::assert::is_true(snap.len == 3)
}
