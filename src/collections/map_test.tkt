/**
 * Unwrap a `Map<i64>::get` result (an `i64?`) to a plain i64, substituting `fallback` for the null
 * (missing-key) case ŌĆö a test helper (a `V?` match is verbose to repeat inline; the null case is
 * exercised directly by map_key_not_found). Takes the ALREADY-looked-up optional, not the map, so it
 * carries no generic-class parameter.
 *
 * This file tests teko::collections::Map<V> (issue #163): the str-keyed hash-map contract at TWO
 * value instantiations (i64 + str, proving the body monomorphizes per value width) ŌĆö insert / get /
 * contains / len round-trips, insert-as-update (no count growth on a duplicate key), key-not-found
 * (`get` ŌåÆ null, `contains` ŌåÆ false), remove (present + absent), many-key distinctness (the property
 * collisions could break), the reference-semantic aliasing law, and the keys snapshot. Pure Teko,
 * VM-runnable ŌĆö both engines gate.
 *
 * @param got       the optional value returned by `Map<i64>::get`
 * @param fallback  the value returned when `got` is null
 * @return          the wrapped value, or `fallback` if `got` is null
 */
fn unwrap_or(got: i64?, fallback: i64) -> i64 {
    match got {
        i64 as v => v
        null => fallback
    }
}

/**
 * A batch of clustering-prone keys for the many-keys distinctness test: single characters and
 * shared-prefix pairs, the shapes most apt to land near each other under a byte-fold hash.
 *
 * @return the key batch as a `[]str`
 */
fn build_key_batch() -> []str {
    mut ks: []str = teko::list::empty()
    ks = teko::list::push(ks, "a")
    ks = teko::list::push(ks, "b")
    ks = teko::list::push(ks, "c")
    ks = teko::list::push(ks, "aa")
    ks = teko::list::push(ks, "ab")
    ks = teko::list::push(ks, "ba")
    ks = teko::list::push(ks, "abc")
    ks = teko::list::push(ks, "abd")
    ks = teko::list::push(ks, "xyz")
    ks = teko::list::push(ks, "xyzzy")
    ks
}

#test
/**
 * insert two keys, read both back; len and contains track the entries; an absent key is not found.
 */
fn map_i64_insert_get_contains() {
    let m = Map<i64>::make()
    teko::assert::is_true(m.is_empty())
    m.insert("a", 1)
    m.insert("b", 2)
    teko::assert::is_true(m.len() == 2)
    teko::assert::is_true(m.contains("a"))
    teko::assert::is_true(m.contains("b"))
    teko::assert::is_false(m.contains("z"))
    teko::assert::is_true(unwrap_or(m.get("a"), -1) == 1)
    teko::assert::is_true(unwrap_or(m.get("b"), -1) == 2)
}

#test
/**
 * Re-inserting an existing key UPDATES its value in place ŌĆö the entry count does not grow.
 */
fn map_insert_is_update_on_existing_key() {
    let m = Map<i64>::make()
    m.insert("k", 1)
    m.insert("k", 9)
    teko::assert::is_true(m.len() == 1)
    teko::assert::is_true(unwrap_or(m.get("k"), -1) == 9)
}

#test
/**
 * remove drops a present key (returns true, len shrinks, the key is gone) and is a no-op reporting
 * false for an absent key.
 */
fn map_remove_present_and_absent() {
    let m = Map<i64>::make()
    m.insert("a", 1)
    m.insert("b", 2)
    teko::assert::is_true(m.remove("a"))
    teko::assert::is_true(m.len() == 1)
    teko::assert::is_false(m.contains("a"))
    teko::assert::is_true(m.contains("b"))
    teko::assert::is_false(m.remove("a"))
    teko::assert::is_false(m.remove("never"))
}

#test
/**
 * Collision handling ŌĆö the correctness property collisions could break: distinct keys must resolve
 * to their OWN values even when many share the same bucket scan. The map compares the cheap u64 hash
 * first and only then the exact key bytes, so a hash tie still disambiguates by bytes. Insert many
 * short keys (some single-character, some sharing prefixes ŌĆö the shapes most likely to cluster),
 * then assert every one reads back its own distinct value and that removing one leaves the rest.
 */
fn map_many_keys_stay_distinct() {
    let m = Map<i64>::make()
    let ks = build_key_batch()
    mut i: u64 = 0
    loop {
        if i >= ks.len { break }
        m.insert(ks[i], i to i64)
        i++
    }
    teko::assert::is_true(m.len() == ks.len)
    mut j: u64 = 0
    loop {
        if j >= ks.len { break }
        teko::assert::is_true(unwrap_or(m.get(ks[j]), -1) == j to i64)
        j++
    }
    teko::assert::is_true(m.remove(ks[0]))
    teko::assert::is_false(m.contains(ks[0]))
    teko::assert::is_true(m.contains(ks[1]))
    teko::assert::is_true(unwrap_or(m.get(ks[ks.len - 1]), -1) == (ks.len - 1) to i64)
}

#test
/**
 * keys yields a value snapshot of the current keys that a `loop` can iterate; every listed key is
 * present in the map.
 */
fn map_keys_snapshot_lists_all() {
    let m = Map<i64>::make()
    m.insert("a", 1)
    m.insert("b", 2)
    m.insert("c", 3)
    let ks = m.keys()
    teko::assert::is_true(ks.len == 3)
    mut all_present = true
    mut i: u64 = 0
    loop {
        if i >= ks.len { break }
        if !m.contains(ks[i]) { all_present = false }
        i++
    }
    teko::assert::is_true(all_present)
}
