// src/fmt/fmt_test.tkt — tests for teko::fmt (DT0 — the canonical formatter).
//
// Covers the core canonical rules (spacing, indentation, blank-line policy, comment
// preservation, string kinds, unary vs binary, angle-adjacency preservation), the two
// DT0 verification properties on fixtures — IDEMPOTENCE (fmt(fmt(x)) == fmt(x)) and
// SEMANTIC PRESERVATION (format_source itself refuses any token-stream change — every
// successful call below has passed that internal check) — plus refusal of invalid input.

// helper (not a test): unwrap `str | error` — a formatting failure in these tests is
// itself a test failure (the fixture is meant to be valid).
fn fmts(source: str) -> str {
    match teko::fmt::format_source(source) {
        str as out => out
        error => { teko::assert::is_true(false); "" }
    }
}

// helper (not a test): assert the fixture is already canonical (a formatting FIXPOINT).
fn assert_fixpoint(source: str) {
    teko::assert::is_true(fmts(source) == source)
}

// --- inter-token spacing ---

#test
fn binary_operators_get_one_space() {
    teko::assert::is_true(fmts("let x=1+2\n") == "let x = 1 + 2\n")
    teko::assert::is_true(fmts("let y  =  1  *  2  %  3\n") == "let y = 1 * 2 % 3\n")
    teko::assert::is_true(fmts("let z = a&&b||c\n") == "let z = a && b || c\n")
}

#test
fn calls_are_tight_and_commas_canonical() {
    teko::assert::is_true(fmts("let y = f( 1 ,2 )\n") == "let y = f(1, 2)\n")
    teko::assert::is_true(fmts("let z = g ()\n") == "let z = g()\n")
}

#test
fn keyword_before_paren_keeps_its_space() {
    let src = "fn a() -> i64 {\n    return (1)\n}\n"
    assert_fixpoint(src)
}

#test
fn namespace_and_member_access_are_tight() {
    teko::assert::is_true(fmts("let n = teko :: list :: empty()\n") == "let n = teko::list::empty()\n")
    teko::assert::is_true(fmts("let m = s . len\n") == "let m = s.len\n")
}

#test
fn colon_annotations_are_canonical() {
    teko::assert::is_true(fmts("fn c(xs :[]str) -> u64 { xs.len }\n") == "fn c(xs: []str) -> u64 { xs.len }\n")
}

#test
fn struct_literal_braces_are_spaced() {
    let got = fmts("type P = struct { x: i64; y: i64 }\nfn m() -> P { P {x = 1;y = 2} }\n")
    teko::assert::is_true(got == "type P = struct { x: i64; y: i64 }\nfn m() -> P { P { x = 1; y = 2 } }\n")
}

#test
fn empty_braces_keep_one_space() {
    // the corpus majority style: `{ }` (466 uses) over `{}` (253) — canonical is `{ }`.
    teko::assert::is_true(fmts("fn t() {}\n") == "fn t() { }\n")
}

// --- unary vs binary ---

#test
fn unary_operators_are_tight() {
    teko::assert::is_true(fmts("let x = - 1\n") == "let x = -1\n")
    teko::assert::is_true(fmts("let z = ! true\n") == "let z = !true\n")
    teko::assert::is_true(fmts("let w = -(1 + 2)\n") == "let w = -(1 + 2)\n")
}

#test
fn binary_then_unary_minus_keeps_the_separating_space() {
    assert_fixpoint("let y = 1 - -2\n")
}

// --- angle tokens (generics vs comparison): source adjacency is preserved ---

#test
fn generics_stay_tight() {
    assert_fixpoint("fn id<T>(x: T) -> T { x }\n")
}

#test
fn spaced_comparison_stays_spaced() {
    assert_fixpoint("let c = 1 < 2\n")
    teko::assert::is_true(fmts("let d = 1   <   2\n") == "let d = 1 < 2\n")
}

// --- nullability & ranges & spread & membership ---

#test
fn nullability_tokens_are_canonical() {
    teko::assert::is_true(fmts("fn h(s: str?) -> str { s??\"x\" }\n") == "fn h(s: str?) -> str { s ?? \"x\" }\n")
    teko::assert::is_true(fmts("let v = o ?. field\n") == "let v = o?.field\n")
}

#test
fn ranges_and_spread_are_tight() {
    assert_fixpoint("fn r(v: i64) -> i64 {\n    match v {\n        1..=9 => 1\n        _ => 0\n    }\n}\n")
    assert_fixpoint("fn g(xs: []i64, x: i64) -> []i64 { [..xs, x] }\n")
}

#test
fn membership_set_is_canonical() {
    teko::assert::is_true(fmts("fn e(x: i64) -> bool { x in [ 1,2 ] }\n") == "fn e(x: i64) -> bool { x in [1, 2] }\n")
}

// --- indentation ---

#test
fn bodies_indent_four_spaces() {
    teko::assert::is_true(fmts("fn a() -> i64 {\nreturn 1\n}\n") == "fn a() -> i64 {\n    return 1\n}\n")
}

#test
fn nested_blocks_indent_by_depth() {
    let src = "fn a(c: bool) -> i64 {\n    if c {\n        1\n    } else {\n        2\n    }\n}\n"
    assert_fixpoint(src)
    teko::assert::is_true(fmts("fn a(c: bool) -> i64 {\nif c {\n1\n} else {\n2\n}\n}\n") == src)
}

#test
fn multiline_call_arguments_indent_by_paren_depth() {
    let src = "fn a(s: str) -> str {\n    teko::str::concat(\n        s,\n        s)\n}\n"
    assert_fixpoint(src)
}

// --- blank lines ---

#test
fn blank_runs_collapse_to_one() {
    teko::assert::is_true(fmts("let a = 1\n\n\n\nlet b = 2\n") == "let a = 1\n\nlet b = 2\n")
}

#test
fn blanks_vanish_after_openers_and_before_closers() {
    teko::assert::is_true(fmts("fn a() -> i64 {\n\n    1\n\n}\n") == "fn a() -> i64 {\n    1\n}\n")
}

#test
fn leading_blanks_drop_and_final_newline_is_ensured() {
    teko::assert::is_true(fmts("\n\nlet x = 1") == "let x = 1\n")
}

// --- comment preservation (the DT0 hard part) ---

#test
fn trailing_comment_sits_three_spaces_after_code() {
    teko::assert::is_true(fmts("let x = 1  // note\n") == "let x = 1   // note\n")
    assert_fixpoint("let x = 1   // note\n")
}

#test
fn standalone_comments_are_preserved_and_indented() {
    assert_fixpoint("// leading\nlet x = 1\n")
    teko::assert::is_true(fmts("fn a() -> i64 {\n// inner\n1\n}\n") == "fn a() -> i64 {\n    // inner\n    1\n}\n")
}

#test
fn comment_trailing_whitespace_is_trimmed() {
    teko::assert::is_true(fmts("// padded   \nlet x = 1\n") == "// padded\nlet x = 1\n")
}

#test
fn doc_comments_are_preserved_verbatim() {
    // a doc comment may attach either on the SAME line as its declaration (see
    // parser_test.tkt's `/** hi */ fn h() { }`) or on its OWN line before it (#111,
    // `/** hi */\nfn h() { }`) — fmt preserves whichever placement the input already used.
    assert_fixpoint("/** the doc of a. */ fn a() -> i64 { 1 }\n")
    teko::assert::is_true(fmts("/** the doc of a. */   fn a() -> i64 { 1 }\n") == "/** the doc of a. */ fn a() -> i64 { 1 }\n")
}

#test
fn own_line_doc_comments_are_idempotent() {
    // (#111) an own-line doc comment before a declaration: fmt must (a) accept it now that
    // the parser grammar does, (b) keep it on its own line (never collapse it onto the
    // declaration's line), and (c) be a fixpoint — fmt(fmt(x)) == fmt(x).
    assert_fixpoint("/** the doc of a. */\nfn a() -> i64 { 1 }\n")
    assert_fixpoint("/** the doc of b. */\nexp fn b() -> i64 { 1 }\n")
    // extra blank lines between the doc and the decl collapse to the canonical single blank
    // line (the pre-existing blank-line policy, unrelated to doc comments specifically) but
    // the doc STAYS on its own line, never glued to the declaration.
    let collapsed = fmts("/** the doc of c. */\n\n\nfn c() -> i64 { 1 }\n")
    teko::assert::is_true(collapsed == "/** the doc of c. */\n\nfn c() -> i64 { 1 }\n")
    assert_fixpoint(collapsed)
}

#test
fn attributes_are_preserved() {
    assert_fixpoint("#test\nfn t() {\n    teko::assert::is_true(true)\n}\n")
}

// --- string kinds: bytes are never altered ---

#test
fn string_literals_are_untouched() {
    assert_fixpoint("let s = \"a=b, c \\n d\"\n")
    assert_fixpoint("let v = @\"a \"\"b\"\" \\ c\"\n")
    assert_fixpoint("let b = b'\\n'\nlet c = c'x'\n")
}

#test
fn interpolation_holes_are_untouched() {
    // the raw inner text of `$"…"` (holes included) is a single token — inner spacing survives.
    assert_fixpoint("let t = $\"v={v  +  1} w\"\n")
}

#test
fn multiline_strings_keep_their_inner_lines() {
    assert_fixpoint("let s = \"\"\"\nline1\n  line2\n\"\"\"\n")
}

// --- statement separators ---

#test
fn semicolon_separated_statements_are_canonical() {
    teko::assert::is_true(fmts("fn a() -> i64 { let x = 1 ;x }\n") == "fn a() -> i64 { let x = 1; x }\n")
}

#test
fn increment_is_tight() {
    assert_fixpoint("fn a(n: i64) -> i64 {\n    mut i = n\n    i++\n    i\n}\n")
}

// --- casts / match / closures ---

#test
fn cast_and_match_arms_are_canonical() {
    let want = "fn d(v: i64) -> i64 {\n    match v {\n        1 => 2\n        _ => 3\n    }\n}\n"
    teko::assert::is_true(fmts("fn d(v: i64) -> i64 {\n    match v {\n        1=>2\n        _=>3\n    }\n}\n") == want)
    assert_fixpoint(want)
    assert_fixpoint("fn c(b: byte) -> i64 { b to i64 }\n")
}

#test
fn closures_are_canonical() {
    assert_fixpoint("fn a() -> i64 {\n    let f: (i64) -> i64 = (x: i64) => x + 1\n    f(1)\n}\n")
}

// --- the DT0 verification properties, on a mixed fixture ---

#test
fn idempotence_on_a_mixed_fixture() {
    let src = "// header\nfn a(xs: []str, k: u64) -> u64 {\nmut n:u64=0\nloop {\nif n>=k { break }   // guard\nn++\n}\nn\n}\n\n\ntype Q = struct { a: i64; b: str }\n"
    let once = fmts(src)
    let twice = fmts(once)
    teko::assert::is_true(once == twice)
}

#test
fn formatting_is_a_noop_on_canonical_source() {
    let src = "// m\nfn a(x: i64) -> i64 {\n    let y = x + 1   // add\n    y\n}\n"
    assert_fixpoint(src)
}

// --- real corpus files: idempotence on actual project source (tolerant of cwd) ---

#test
fn real_corpus_files_format_idempotently() {
    mut paths: []str = teko::list::empty()
    paths = teko::list::push(paths, "src/fs/fs.tks")
    paths = teko::list::push(paths, "src/assert/assert.tks")
    mut i: u64 = 0
    loop {
        if i >= paths.len { break }
        match teko::io::read_file(paths[i]) {
            str as src => {
                let once = match teko::fmt::format_source(src) {
                    str as o => o
                    error => { teko::assert::is_true(false); "" }
                }
                let twice = match teko::fmt::format_source(once) {
                    str as o => o
                    error => { teko::assert::is_true(false); "" }
                }
                teko::assert::is_true(once == twice)
            }
            error => { }
        }
        i = i + 1
    }
}

// --- refusal: invalid input is an error, never a rewrite ---

#test
fn invalid_source_is_refused() {
    match teko::fmt::format_source("fn (\n") {
        str => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn unterminated_string_is_refused() {
    match teko::fmt::format_source("let s = \"oops\n") {
        str => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn check_mode_reports_zero_on_an_already_canonical_file() {
    mut args: []str = teko::list::empty()
    args = teko::list::push(args, "teko")
    args = teko::list::push(args, "fmt")
    args = teko::list::push(args, "--check")
    args = teko::list::push(args, "src/fs/fs.tks")
    teko::assert::is_true(teko::fmt::run_cli(args) == 0)
}

#test
fn check_mode_walks_a_directory_recursively_read_only() {
    mut args: []str = teko::list::empty()
    args = teko::list::push(args, "teko")
    args = teko::list::push(args, "fmt")
    args = teko::list::push(args, "--check")
    args = teko::list::push(args, "src/assert")
    teko::assert::is_true(teko::fmt::run_cli(args) == 0)
}

#test
fn missing_paths_and_no_stdin_marker_is_a_usage_error() {
    mut args: []str = teko::list::empty()
    args = teko::list::push(args, "teko")
    args = teko::list::push(args, "fmt")
    teko::assert::is_true(teko::fmt::run_cli(args) == 2)
}
