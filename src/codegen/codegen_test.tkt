// ---------------------------------------------------------------------------
// Group M: emit_if_value — builds fresh_tmp_name, emit_branch_value,
//   emit_stmt_value (via emit_expr on a TIfExpr with has_else=true)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_if_value() {
    let prog = cgt_prog()

    // Build: if (true) { 1 } else { 0 }  — as an expression (has_else=true)
    let then_stmt: checker::TStatement = cgt_stmt(cgt_num_i64(1))
    let else_stmt: checker::TStatement = cgt_stmt(cgt_num_i64(0))
    let then_blk: []checker::TStatement = teko::list::push(teko::list::empty(), then_stmt)
    let else_blk: []checker::TStatement = teko::list::push(teko::list::empty(), else_stmt)
    let if_e = checker::TIfExpr {
        cond     = cgt_e_bool_t()
        then_blk = then_blk
        has_else = true
        else_blk = else_blk
    }
    let e_if = checker::TExpr {
        kind = if_e
        type = checker::Prim { kind = checker::PrimKind::I64 }
        line = 0; col = 0
    }
    let result = match emit_expr(cgt_empty(), prog, e_if) { []byte as o => str(o); error => "" }
    // emit_if_value produces a GNU stmt-expr `({ ... })`
    teko::assert::is_true(result.len > 0)
    teko::assert::is_true(teko::str::contains(result, "if"))
}

// ---------------------------------------------------------------------------
// Group M2: S2/W9 — VALUE-position arm regions. A value `if`/`match` arm with a NON-tail
//   binding takes the value-arm path (emit_branch_value / emit_arm_value) and yields its tail
//   to the enclosing sink. With NO escape context (emit_expr threads empty escaping/regions/
//   fn_body) NO region is opened — so the output is the pre-W9 value-form, byte-identical: the
//   `sink = (…); break;` commit with no `tk_region_new`. (The genuine region-opening path is
//   covered end-to-end by the value-arm regression examples — the predicate needs the live
//   per-function escape set, which only the full build pipeline supplies.)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_value_arm_no_region_when_no_context() {
    let prog = cgt_prog()
    // if (true) { let tmp = 5; tmp } else { 0 }  — a value `if` whose then-branch has a non-tail
    // binding + a tail read. emit_branch_value runs; with empty escape context no region opens.
    let bind_tmp: checker::TStatement = checker::TBinding {
        kind   = parser::BindKind::Let
        target = parser::SimpleName { name = "tmp" }
        bound  = checker::Prim { kind = checker::PrimKind::I64 }
        value  = cgt_num_i64(5)
    }
    let tail_read: checker::TStatement = cgt_stmt(cgt_e_var("tmp"))
    mut then_blk: []checker::TStatement = teko::list::push(teko::list::empty(), bind_tmp)
    then_blk = teko::list::push(then_blk, tail_read)
    let else_blk: []checker::TStatement = teko::list::push(teko::list::empty(), cgt_stmt(cgt_num_i64(0)))
    let if_e = checker::TIfExpr { cond = cgt_e_bool_t(); then_blk = then_blk; has_else = true; else_blk = else_blk }
    let e_if = checker::TExpr { kind = if_e; type = checker::Prim { kind = checker::PrimKind::I64 }; line = 0; col = 0 }
    let result = match emit_expr(cgt_empty(), prog, e_if) { []byte as o => str(o); error => "" }
    teko::assert::is_true(result.len > 0)
    teko::assert::is_true(teko::str::contains(result, "tmp"))
    // No live escape context ⇒ no value-arm region opened (leak-safe pre-W9 output).
    teko::assert::is_true(!teko::str::contains(result, "tk_region_new"))
}

// A value `match` arm with a non-tail binding takes emit_arm_value's value path: the tail value
// commits with `_rN = (…); break;`. No escape context ⇒ no region (byte-identical to pre-W9).
#test
fn cgt_emit_value_match_arm_commits_tail() {
    let prog = cgt_prog()
    let bind_tmp: checker::TStatement = checker::TBinding {
        kind   = parser::BindKind::Let
        target = parser::SimpleName { name = "tmp" }
        bound  = checker::Prim { kind = checker::PrimKind::I64 }
        value  = cgt_num_i64(7)
    }
    let arm_lit: parser::Pattern = parser::LiteralPattern {
        value = parser::Expr { kind = parser::Number { is_float = false; value = 1 to i128; fval = 0.0 }; line = 0; col = 0 }
    }
    mut arm_body: []checker::TStatement = teko::list::push(teko::list::empty(), bind_tmp)
    arm_body = teko::list::push(arm_body, cgt_stmt(cgt_e_var("tmp")))
    let arm1 = checker::TArm { pattern = arm_lit; has_when = false; guard = cgt_num_i64(0); body = arm_body }
    let arm_w = checker::TArm { pattern = parser::WildcardPattern { }; has_when = false; guard = cgt_num_i64(0); body = teko::list::push(teko::list::empty(), cgt_stmt(cgt_num_i64(0))) }
    mut arms: []checker::TArm = teko::list::push(teko::list::empty(), arm1)
    arms = teko::list::push(arms, arm_w)
    let m_e = checker::TMatchExpr { subject = cgt_num_i64(1); arms = arms }
    let e_m = checker::TExpr { kind = m_e; type = checker::Prim { kind = checker::PrimKind::I64 }; line = 0; col = 0 }
    let result = match emit_expr(cgt_empty(), prog, e_m) { []byte as o => str(o); error => "" }
    teko::assert::is_true(result.len > 0)
    teko::assert::is_true(teko::str::contains(result, "break;"))
    teko::assert::is_true(!teko::str::contains(result, "tk_region_new"))
}

// ---------------------------------------------------------------------------
// Group N: emit_function — the full pipeline
//   emit_function, emit_function_sig, emit_block_tail, emit_block, emit_stmt,
//   emit_binding, emit_assign, emit_loop, emit_return, emit_if_stmt,
//   emit_exprstmt_tail, emit_as_r, cg_stmt_c_terminates, is_void_type,
//   cb_indent_deeper, emit_type_expr (via params)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_function_comprehensive() {
    let prog = cgt_prog()

    // Body 1: loop{break} + if-stmt + binding + assign + return tail
    let break_body: []checker::TStatement = teko::list::push(cgt_empty_stmts(), checker::TBreakStmt { label = "" })
    let loop_s: checker::TStatement = checker::TLoopStmt { label = ""; body = break_body }

    // if (true) { } — no else — statement position → emit_if_stmt → cb_indent_deeper
    let empty_blk = cgt_empty_stmts()
    let if_s: checker::TStatement = cgt_stmt(checker::TExpr {
        kind = checker::TIfExpr { cond = cgt_e_bool_t(); then_blk = empty_blk; has_else = false; else_blk = empty_blk }
        type = checker::Void { }
        line = 0; col = 0
    })

    let bind_s: checker::TStatement = checker::TBinding {
        kind   = parser::BindKind::Let
        target = parser::SimpleName { name = "x" }
        bound  = checker::Prim { kind = checker::PrimKind::I64 }
        value  = cgt_num_i64(10)
    }
    let assign_s: checker::TStatement = checker::TAssign {
        name  = "x"
        op    = lexer::TokenKind::PlusEq
        bound = checker::Prim { kind = checker::PrimKind::I64 }
        value = cgt_num_i64(1)
        deref = false
    }
    let ret_s: checker::TStatement = cgt_ret(cgt_num_i64(42))

    mut body1: []checker::TStatement = cgt_empty_stmts()
    body1 = teko::list::push(body1, loop_s)
    body1 = teko::list::push(body1, if_s)
    body1 = teko::list::push(body1, bind_s)
    body1 = teko::list::push(body1, assign_s)
    body1 = teko::list::push(body1, ret_s)

    let ret_type = checker::Prim { kind = checker::PrimKind::I64 }
    let f1 = cgt_fn0("cgt_fn_ret", "teko::cgt", ret_type, body1)
    let r1 = match emit_function(cgt_empty(), prog, f1) { []byte as o => str(o); error => "" }
    teko::assert::is_true(r1.len > 0)
    teko::assert::is_true(teko::str::contains(r1, "cgt_fn_ret"))
    teko::assert::is_true(teko::str::contains(r1, "while"))     // emit_loop → while(1)
    teko::assert::is_true(teko::str::contains(r1, "break"))
    teko::assert::is_true(teko::str::contains(r1, "int64_t x"))
    teko::assert::is_true(teko::str::contains(r1, "return"))

    // Body 2: single TExprStmt tail → covers emit_exprstmt_tail (non-if/match path)
    let tail_s: checker::TStatement = cgt_stmt(cgt_num_i64(99))
    let body2: []checker::TStatement = teko::list::push(cgt_empty_stmts(), tail_s)
    let f2 = cgt_fn0("cgt_fn_tail", "teko::cgt", ret_type, body2)
    let r2 = match emit_function(cgt_empty(), prog, f2) { []byte as o => str(o); error => "" }
    teko::assert::is_true(r2.len > 0)
    teko::assert::is_true(teko::str::contains(r2, "cgt_fn_tail"))
    teko::assert::is_true(teko::str::contains(r2, "return"))

    // Body 3: void function, empty body → needs_unreachable = false
    let f3 = cgt_fn0("cgt_fn_void", "teko::cgt", checker::Void { }, cgt_empty_stmts())
    let r3 = match emit_function(cgt_empty(), prog, f3) { []byte as o => str(o); error => "" }
    teko::assert::is_true(r3.len > 0)
    teko::assert::is_true(teko::str::contains(r3, "void"))

    // Function with a parameter → emit_type_expr is called from emit_function_sig
    let param = parser::Param { name = "n"; type_ann = cgt_named_te("u64"); is_params = false }
    let params: []parser::Param = teko::list::push(teko::list::empty(), param)
    let body4: []checker::TStatement = teko::list::push(cgt_empty_stmts(), cgt_ret(cgt_num_i64(0)))
    let f4 = checker::TFunction {
        name        = "cgt_fn_param"
        type_params = teko::list::empty()
        namespace   = "teko::cgt"
        params      = params
        return_type = checker::Prim { kind = checker::PrimKind::I64 }
        body        = body4
        vis         = parser::Visibility::Private
        has_doc     = false
        doc         = ""
        file        = ""
        line        = 0; col = 0
        is_test     = false
        is_extern   = false; c_symbol = ""; from_lib = ""
    }
    let r4 = match emit_function(cgt_empty(), prog, f4) { []byte as o => str(o); error => "" }
    teko::assert::is_true(r4.len > 0)
    teko::assert::is_true(teko::str::contains(r4, "uint64_t"))  // emit_type_expr("u64")
    teko::assert::is_true(teko::str::contains(r4, "n"))          // cb_ident("n")
}

// ---------------------------------------------------------------------------
// Group N1b: void TAIL match must CHAIN its arms with a commit jump (REGRESSION).
//   A statement-position / tail `match` in a `-> void` fn has arm bodies that do NOT diverge
//   (no implicit `return`). emit_match_tail must emit the FIRST winning arm's body then `goto`
//   a unique commit label past the rest — otherwise the arms fall through as independent `if`s
//   (`if(c){a} if(1){b}`) and MULTIPLE arms fire (the wildcard `if(1)` ALWAYS fires). The fix
//   makes EXACTLY ONE arm run, matching the VM and the value-form match. This test asserts the
//   emitted C carries the commit `goto …_done` chain (the structural guarantee).
// ---------------------------------------------------------------------------
fn cgt_lit_arm(v: i128, body_name: str) -> checker::TArm {
    // arm: `v => { let <body_name> = <v> }` — a NON-diverging effect body (the bug trigger).
    let lit: parser::Pattern = parser::LiteralPattern {
        value = parser::Expr { kind = parser::Number { is_float = false; value = v; fval = 0.0 }; line = 0; col = 0 }
    }
    let eff: checker::TStatement = checker::TBinding {
        kind   = parser::BindKind::Let
        target = parser::SimpleName { name = body_name }
        bound  = checker::Prim { kind = checker::PrimKind::I64 }
        value  = cgt_num_i64(v)
    }
    checker::TArm { pattern = lit; has_when = false; guard = cgt_num_i64(0); body = teko::list::push(cgt_empty_stmts(), eff) }
}
fn cgt_wild_arm(body_name: str) -> checker::TArm {
    let eff: checker::TStatement = checker::TBinding {
        kind   = parser::BindKind::Let
        target = parser::SimpleName { name = body_name }
        bound  = checker::Prim { kind = checker::PrimKind::I64 }
        value  = cgt_num_i64(99)
    }
    checker::TArm { pattern = parser::WildcardPattern { }; has_when = false; guard = cgt_num_i64(0); body = teko::list::push(cgt_empty_stmts(), eff) }
}

#test
fn cgt_void_tail_match_chains_arms() {
    let prog = cgt_prog()

    // subject `k: i64`, two arms (1 => {effect}; _ => {effect}); the match is the void fn's tail.
    let subj = cgt_e_var("k")
    mut arms: []checker::TArm = teko::list::empty()
    arms = teko::list::push(arms, cgt_lit_arm(1, "a1"))
    arms = teko::list::push(arms, cgt_wild_arm("aw"))
    let match_e = checker::TExpr {
        kind = checker::TMatchExpr { subject = subj; arms = arms }
        type = checker::Void { }
        line = 0; col = 0
    }
    let tail: []checker::TStatement = teko::list::push(cgt_empty_stmts(), cgt_stmt(match_e))
    let f = cgt_fn0("cgt_fn_void_match", "teko::cgt", checker::Void { }, tail)
    let r = match emit_function(cgt_empty(), prog, f) { []byte as o => str(o); error => "" }

    teko::assert::is_true(r.len > 0)
    teko::assert::is_true(teko::str::contains(r, "cgt_fn_void_match"))
    // Both arm bodies present...
    teko::assert::is_true(teko::str::contains(r, "a1"))
    teko::assert::is_true(teko::str::contains(r, "aw"))
    // ...but chained with a commit jump so EXACTLY ONE arm runs (the regression guarantee).
    // Before the fix the arms were independent `if`s with NO goto, so both fired.
    teko::assert::is_true(teko::str::contains(r, "goto "))
    teko::assert::is_true(teko::str::contains(r, "_done"))

    // 3-arm shape (1 => ; 2 => ; _ =>) must likewise chain — assert TWO commit jumps reach the
    // single shared label (one per non-final arm + the final wildcard = 3 gotos to one label).
    mut arms3: []checker::TArm = teko::list::empty()
    arms3 = teko::list::push(arms3, cgt_lit_arm(1, "b1"))
    arms3 = teko::list::push(arms3, cgt_lit_arm(2, "b2"))
    arms3 = teko::list::push(arms3, cgt_wild_arm("bw"))
    let match3 = checker::TExpr {
        kind = checker::TMatchExpr { subject = cgt_e_var("k"); arms = arms3 }
        type = checker::Void { }
        line = 0; col = 0
    }
    let tail3: []checker::TStatement = teko::list::push(cgt_empty_stmts(), cgt_stmt(match3))
    let f3 = cgt_fn0("cgt_fn_void_match3", "teko::cgt", checker::Void { }, tail3)
    let r3 = match emit_function(cgt_empty(), prog, f3) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(r3, "b1"))
    teko::assert::is_true(teko::str::contains(r3, "b2"))
    teko::assert::is_true(teko::str::contains(r3, "bw"))
    teko::assert::is_true(teko::str::contains(r3, "goto "))
    teko::assert::is_true(teko::str::contains(r3, "_done"))
}

// ---------------------------------------------------------------------------
// Group N2: (C7.18/W9.3) defer lowering — the .tks twin's per-block DeferCtx + defer_base fires
// each block's defers (LIFO) at its scope exit, matching codegen.c's g_cg_defers/emit_defers OUTPUT.
// ---------------------------------------------------------------------------
#test
fn cgt_emit_defer() {
    let prog = cgt_prog()
    let ret_type = checker::Prim { kind = checker::PrimKind::I64 }

    // defer { let _c = 0 } — the with_defer() shape: [defer, return 42].
    let defer_body: []checker::TStatement = teko::list::push(cgt_empty_stmts(), checker::TBinding {
        kind   = parser::BindKind::Let
        target = parser::SimpleName { name = "_c" }
        bound  = checker::Prim { kind = checker::PrimKind::I64 }
        value  = cgt_num_i64(0)
    })
    let defer_s: checker::TStatement = checker::TDeferStmt { body = defer_body }

    mut body: []checker::TStatement = cgt_empty_stmts()
    body = teko::list::push(body, defer_s)
    body = teko::list::push(body, cgt_ret(cgt_num_i64(42)))
    let f = cgt_fn0("cgt_fn_defer", "teko::cgt", ret_type, body)
    let r = match emit_function(cgt_empty(), prog, f) { []byte as o => str(o); error => "" }
    teko::assert::is_true(r.len > 0)
    teko::assert::is_true(teko::str::contains(r, "cgt_fn_defer"))
    teko::assert::is_true(teko::str::contains(r, "_c"))       // defer body emitted before the return
    teko::assert::is_true(teko::str::contains(r, "return"))

    // early_return_with_defer() shape: [defer, if true { return 1 }, return 2] — the defer body
    // is drained before BOTH returns (the TIfExpr recursion + the trailing return).
    let inner: []checker::TStatement = teko::list::push(cgt_empty_stmts(), cgt_ret(cgt_num_i64(1)))
    let if_s: checker::TStatement = cgt_stmt(checker::TExpr {
        kind = checker::TIfExpr { cond = cgt_e_bool_t(); then_blk = inner; has_else = false; else_blk = cgt_empty_stmts() }
        type = checker::Void { }
        line = 0; col = 0
    })
    mut body2: []checker::TStatement = cgt_empty_stmts()
    body2 = teko::list::push(body2, defer_s)
    body2 = teko::list::push(body2, if_s)
    body2 = teko::list::push(body2, cgt_ret(cgt_num_i64(2)))
    let f2 = cgt_fn0("cgt_fn_defer2", "teko::cgt", ret_type, body2)
    let r2 = match emit_function(cgt_empty(), prog, f2) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(r2, "cgt_fn_defer2"))
    teko::assert::is_true(teko::str::contains(r2, "_c"))      // drained inside the if AND at the tail
}

// ---------------------------------------------------------------------------
// Helper: 3-segment path for teko::list::empty / push
// ---------------------------------------------------------------------------
fn cgt_path3(a: str, b: str, c: str) -> parser::Path {
    let s1: []parser::Segment = teko::list::push(teko::list::empty(), cgt_seg(a))
    let s2: []parser::Segment = teko::list::push(s1, cgt_seg(b))
    let s3: []parser::Segment = teko::list::push(s2, cgt_seg(c))
    parser::Path { segments = s3 }
}

// ---------------------------------------------------------------------------
// Group O: type-name mangling helpers
//   cg_opt_typename, cg_slice_typename, cg_emit_variant_ctype,
//   cg_opt_mangle_texpr_str, cg_member_key_texpr_str,
//   cg_variant_typename_texpr, cg_opt_mangle_texpr
// ---------------------------------------------------------------------------
#test
fn cgt_mangle_helpers() {
    // cg_opt_typename: Str inner → "tk_opt_str"
    let opt_r = match cg_opt_typename(cgt_empty(), checker::Str {}) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(opt_r, "tk_opt_str"))

    // cg_slice_typename: I64 element → "tk_slice_i64"
    let sl_r = match cg_slice_typename(cgt_empty(), checker::Prim { kind = checker::PrimKind::I64 }) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(sl_r, "tk_slice_i64"))

    // cg_emit_variant_ctype: Named "Foo" → "tk_t_Foo"
    let vc_r = match cg_emit_variant_ctype(cgt_empty(), checker::Named { name = "Foo" }) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(vc_r, "Foo"))

    // cg_opt_mangle_texpr_str: NamedType "str" → "str"
    let oms = match cg_opt_mangle_texpr_str(cgt_named_te("str")) { str as s => s; error => "" }
    teko::assert::is_true(oms == "str")

    // cg_member_key_texpr_str: "bool" (C keyword) → "bool_"; "i64" → "i64"
    let mks_bool = match cg_member_key_texpr_str(cgt_named_te("bool")) { str as s => s; error => "" }
    teko::assert::is_true(mks_bool == "bool_")
    let mks_i64 = match cg_member_key_texpr_str(cgt_named_te("i64")) { str as s => s; error => "" }
    teko::assert::is_true(mks_i64 == "i64")

    // cg_variant_typename_texpr: UnionType[str, error] → "tk_u_str_error"
    let um1: []parser::TypeExpr = teko::list::push(teko::list::empty(), cgt_named_te("str"))
    let um2: []parser::TypeExpr = teko::list::push(um1, cgt_named_te("error"))
    let ut = parser::UnionType { members = um2 }
    let vtt = match cg_variant_typename_texpr(cgt_empty(), ut) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(vtt, "tk_u_str_error"))

    // cg_opt_mangle_texpr: NamedType "u64" → "u64"
    let omt = match cg_opt_mangle_texpr(cgt_empty(), cgt_named_te("u64")) { []byte as o => str(o); error => "" }
    teko::assert::is_true(omt == "u64")
}

// ---------------------------------------------------------------------------
// Group P: by-value cycle detection + variant membership
//   cg_te_reaches_byvalue, cg_name_reaches_byvalue,
//   cg_field_boxed, cg_variant_has_member
// ---------------------------------------------------------------------------
#test
fn cgt_byvalue_boxed_variant() {
    // cg_te_reaches_byvalue: "str" is a prim name → returns false immediately
    let reaches_prim = cg_te_reaches_byvalue(cgt_prog(), cgt_named_te("str"), "Foo", teko::list::empty())
    teko::assert::is_false(reaches_prim)

    // cg_te_reaches_byvalue: "Box" is not a prim name, not == "Foo" →
    // calls cg_name_reaches_byvalue; empty prog → cg_find_decl returns error → false
    let reaches_box = cg_te_reaches_byvalue(cgt_prog(), cgt_named_te("Box"), "Foo", teko::list::empty())
    teko::assert::is_false(reaches_box)

    // cg_field_boxed: SliceType is not a box candidate → false
    let slice_te = parser::SliceType { element = cgt_named_te("i64") }
    let field_boxed = cg_field_boxed(cgt_prog(), "MyStruct", slice_te)
    teko::assert::is_false(field_boxed)

    // cg_variant_has_member: variant TypeDecl with "i64" and "str" members
    let vm1: []parser::TypeExpr = teko::list::push(teko::list::empty(), cgt_named_te("i64"))
    let vm2: []parser::TypeExpr = teko::list::push(vm1, cgt_named_te("str"))
    let vbody = parser::VariantBody { type_expr = parser::UnionType { members = vm2 } }
    let vdecl = parser::TypeDecl { name = "MyV"; type_params = teko::list::empty(); body = vbody; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    teko::assert::is_true(cg_variant_has_member(vdecl, "i64"))
    teko::assert::is_false(cg_variant_has_member(vdecl, "unknown"))
}

// ---------------------------------------------------------------------------
// Group Q: emit_call, emit_list_empty, get_push_elem, emit_list_push,
//           emit_field_access (slice.len + Named receiver → cg_find_struct_field_type)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_calls_and_field() {
    // emit_call builtin: "print" → tk_print(...)
    let print_arg = checker::TExpr {
        kind = checker::TStrLit { text = "hi" }
        type = checker::Str {}
        line = 0; col = 0
    }
    let print_args: []checker::TExpr = teko::list::push(teko::list::empty(), print_arg)
    let print_e = checker::TExpr {
        kind = checker::TCall { callee = cgt_path1("print"); args = print_args; call_ns = ""; is_closure_call = false; callee_type = checker::Void { } }
        type = checker::Void {}
        line = 0; col = 0
    }
    let print_out = match emit_expr(cgt_empty(), cgt_prog(), print_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(print_out, "tk_print"))

    // emit_list_empty: TCall to teko::list::empty with Slice{I64} result type
    let empty_e = checker::TExpr {
        kind = checker::TCall { callee = cgt_path3("teko", "list", "empty"); args = teko::list::empty(); call_ns = ""; is_closure_call = false; callee_type = checker::Void { } }
        type = checker::Slice { element = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let empty_out = match emit_expr(cgt_empty(), cgt_prog(), empty_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(empty_out, "tk_slice_i64"))

    // emit_list_push / get_push_elem: TCall to teko::list::push with base+item args
    let base_arg = checker::TExpr {
        kind = checker::TVar { name = "xs"; is_func = false; func_ns = "" }
        type = checker::Slice { element = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let push_args: []checker::TExpr = teko::list::push(teko::list::push(teko::list::empty(), base_arg), cgt_num_i64(42))
    let push_e = checker::TExpr {
        kind = checker::TCall { callee = cgt_path3("teko", "list", "push"); args = push_args; call_ns = ""; is_closure_call = false; callee_type = checker::Void { } }
        type = checker::Slice { element = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let push_out = match emit_expr(cgt_empty(), cgt_prog(), push_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(push_out.len > 0)
    teko::assert::is_true(teko::str::contains(push_out, "tk_slice_push"))

    // emit_field_access — slice.len → simple path
    let slice_recv = checker::TExpr {
        kind = checker::TVar { name = "xs"; is_func = false; func_ns = "" }
        type = checker::Slice { element = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let fa_slice_e = checker::TExpr {
        kind = checker::TFieldAccess { receiver = slice_recv; field = "len" }
        type = checker::Prim { kind = checker::PrimKind::U64 }
        line = 0; col = 0
    }
    let fa_slice_out = match emit_expr(cgt_empty(), cgt_prog(), fa_slice_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(fa_slice_out, ".len"))

    // emit_field_access — Named receiver → cg_find_struct_field_type (empty prog → null → fa_boxed=false)
    let named_recv = checker::TExpr {
        kind = checker::TVar { name = "box_val"; is_func = false; func_ns = "" }
        type = checker::Named { name = "Box" }
        line = 0; col = 0
    }
    let fa_named_e = checker::TExpr {
        kind = checker::TFieldAccess { receiver = named_recv; field = "value" }
        type = checker::Prim { kind = checker::PrimKind::I64 }
        line = 0; col = 0
    }
    let fa_named_out = match emit_expr(cgt_empty(), cgt_prog(), fa_named_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(fa_named_out, "box_val"))
}

// ---------------------------------------------------------------------------
// Group R: emit_index (slice), emit_in, emit_array_lit, emit_interp (+ emit_piece_lit)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_index_in_array_interp() {
    // emit_index — slice receiver: bounds-checked element access
    let slice_recv = checker::TExpr {
        kind = checker::TVar { name = "items"; is_func = false; func_ns = "" }
        type = checker::Slice { element = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let ix_e = checker::TExpr {
        kind = checker::TIndex { receiver = slice_recv; index = cgt_num_i64(0) }
        type = checker::Prim { kind = checker::PrimKind::I64 }
        line = 0; col = 0
    }
    let ix_out = match emit_expr(cgt_empty(), cgt_prog(), ix_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(ix_out, "items"))
    teko::assert::is_true(teko::str::contains(ix_out, "tk_panic_oob"))

    // emit_in — non-empty element list: lhs in [42]
    let in_elems: []checker::TExpr = teko::list::push(teko::list::empty(), cgt_num_i64(42))
    let in_node = checker::TInExpr { lhs = cgt_num_i64(7); elems = in_elems }
    let in_e = checker::TExpr {
        kind = in_node
        type = checker::Prim { kind = checker::PrimKind::Bool }
        line = 0; col = 0
    }
    let in_out = match emit_expr(cgt_empty(), cgt_prog(), in_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(in_out, "=="))

    // emit_array_lit — one-element array [42] of I64 (plain, no spread)
    let arr_ae: checker::TArrayElem = checker::TArrayElem { is_spread = false; expr = cgt_num_i64(42) }
    let arr_elems: []checker::TArrayElem = teko::list::push(teko::list::empty(), arr_ae)
    let arr_e = checker::TExpr {
        kind = checker::TArrayLit { elements = arr_elems }
        type = checker::Slice { element = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let arr_out = match emit_expr(cgt_empty(), cgt_prog(), arr_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(arr_out, "malloc"))
    teko::assert::is_true(teko::str::contains(arr_out, "tk_slice_i64"))

    // emit_interp — $"pre_{n}_suf" with one i64 hole: pieces=["pre_","_suf"], holes=[i64_expr]
    let interp_pieces1: []str = teko::list::push(teko::list::empty(), "pre_")
    let interp_pieces: []str = teko::list::push(interp_pieces1, "_suf")
    let interp_holes: []checker::TExpr = teko::list::push(teko::list::empty(), cgt_num_i64(7))
    let interp_node = checker::TInterp { pieces = interp_pieces; holes = interp_holes; specs = teko::list::empty() }
    let interp_e = checker::TExpr {
        kind = interp_node
        type = checker::Str {}
        line = 0; col = 0
    }
    let interp_out = match emit_expr(cgt_empty(), cgt_prog(), interp_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(interp_out, "tk_str_concat"))
    teko::assert::is_true(teko::str::contains(interp_out, "tk_i64_to_str"))
}

// ---------------------------------------------------------------------------
// Group S: emit_safe_field_access (→ fresh_named), emit_coalesce (→ cg_expr_diverges)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_coalesce_and_safe_field() {
    // emit_safe_field_access: recv?.field where recv: Optional{I64}
    let opt_recv = checker::TExpr {
        kind = checker::TVar { name = "opt_x"; is_func = false; func_ns = "" }
        type = checker::Optional { inner = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let sfa_e = checker::TExpr {
        kind = checker::TSafeFieldAccess { receiver = opt_recv; field = "foo" }
        type = checker::Optional { inner = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let sfa_out = match emit_expr(cgt_empty(), cgt_prog(), sfa_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(sfa_out, "_o"))
    teko::assert::is_true(teko::str::contains(sfa_out, ".present"))
    teko::assert::is_true(teko::str::contains(sfa_out, "foo"))

    // cg_expr_diverges: direct call — non-TCall returns false, TCall to "panic" returns true
    let non_call_e = cgt_num_i64(0)
    teko::assert::is_false(cg_expr_diverges(non_call_e))
    let panic_arg = checker::TExpr {
        kind = checker::TStrLit { text = "oops" }
        type = checker::Str {}
        line = 0; col = 0
    }
    let panic_args: []checker::TExpr = teko::list::push(teko::list::empty(), panic_arg)
    let panic_e = checker::TExpr {
        kind = checker::TCall { callee = cgt_path1("panic"); args = panic_args; call_ns = ""; is_closure_call = false; callee_type = checker::Void { } }
        type = checker::Void {}
        line = 0; col = 0
    }
    teko::assert::is_true(cg_expr_diverges(panic_e))

    // emit_coalesce: opt_left ?? fallback_i64 → (result type = I64, not Optional)
    let opt_left = checker::TExpr {
        kind = checker::TVar { name = "maybe_x"; is_func = false; func_ns = "" }
        type = checker::Optional { inner = checker::Prim { kind = checker::PrimKind::I64 } }
        line = 0; col = 0
    }
    let co_e = checker::TExpr {
        kind = checker::TCoalesce { left = opt_left; right = cgt_num_i64(0) }
        type = checker::Prim { kind = checker::PrimKind::I64 }
        line = 0; col = 0
    }
    let co_out = match emit_expr(cgt_empty(), cgt_prog(), co_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(teko::str::contains(co_out, "_c"))
    teko::assert::is_true(teko::str::contains(co_out, ".present"))
    teko::assert::is_true(teko::str::contains(co_out, ".value"))
}

// ---------------------------------------------------------------------------
// Group T: emit_struct_init (error literal path → emit_expr on message field)
// ---------------------------------------------------------------------------
#test
fn cgt_emit_struct_init_error() {
    // emit_struct_init: e.type = Error → emits the message field value directly
    let msg_e = checker::TExpr {
        kind = checker::TStrLit { text = "oops" }
        type = checker::Str {}
        line = 0; col = 0
    }
    let si_names: []str = teko::list::push(teko::list::empty(), "message")
    let si_vals: []checker::TExpr = teko::list::push(teko::list::empty(), msg_e)
    let si_e = checker::TExpr {
        kind = checker::TStructInit { field_names = si_names; field_vals = si_vals }
        type = checker::Error {}
        line = 0; col = 0
    }
    let si_out = match emit_expr(cgt_empty(), cgt_prog(), si_e) { []byte as o => str(o); error => "" }
    teko::assert::is_true(si_out.len > 0)
    teko::assert::is_true(teko::str::contains(si_out, "oops"))
}

// ---------------------------------------------------------------------------
// Original invariant tests (kept from initial version)
// ---------------------------------------------------------------------------

// emit_binary — `(L op R)` for +,-,*,&,|,^,<<,>> must preserve C integer semantics.
#test
fn lowers_integer_arithmetic() {
    teko::assert::is_true(1 + 2 == 3)
    teko::assert::is_true(7 - 4 == 3)
    teko::assert::is_true(6 * 7 == 42)
    teko::assert::is_true((6 & 3) == 2)
    teko::assert::is_true((4 | 1) == 5)
    teko::assert::is_true((5 ^ 1) == 4)
    teko::assert::is_true((1 << 4) == 16)
    teko::assert::is_true((32 >> 2) == 8)
}

// emit_div_mod — the checked `/` and `%` path (tk_div_*/tk_mod_*) on a non-zero divisor
// must produce the plain quotient / remainder.
#test
fn lowers_checked_div_mod() {
    teko::assert::is_true(42 / 6 == 7)
    teko::assert::is_true(43 % 6 == 1)
}

// emit_compare — chained comparisons lower to `((a<b) && (b<c))`.
#test
fn lowers_chained_compare() {
    teko::assert::is_true(1 < 2)
    teko::assert::is_false(2 < 1)
    teko::assert::is_true(1 <= 1)
    teko::assert::is_false(1 == 2)
}

// emit_unary — `(op X)` for -, ~, !.
#test
fn lowers_unary_ops() {
    teko::assert::is_true(-(3) + 3 == 0)
    teko::assert::is_false(!(1 < 2))
}

// emit_cast — a widening / same-range cast is the plain C cast (no guard) and is lossless.
#test
fn lowers_widening_cast() {
    let x = 200 to i64
    teko::assert::is_true(x == 200)
}
