// src/codegen/codegen.tks   (namespace 'teko::codegen')
//
// THE CANONICAL ORIGINAL of the C backend: lower a CHECKED typed program (TProgram)
// to C source text. The host `cc` then compiles that text to the first native Teko
// binary (M0). This is the Teko pair of src/codegen/codegen_c.{c,h} — the only
// namespace that was C-only; this file closes the gap (it feeds self-hosting).
//
// Lowering design (M0 = integer arithmetic + let + return -> running native binary):
//   * types  : Type -> C type text (U8..U64 -> uintN_t, I8..I64 -> intN_t,
//              Bool -> bool, byte -> uint8_t, void -> void, Str -> tk_str). Everything
//              else = "not yet supported".
//   * exprs  : TNumber -> literal; TVar -> identifier; TBinary -> (L op R);
//              TUnary -> (op X); TCompare -> chained && of adjacent C comparisons;
//              TCast -> ((Ctype)(inner)); TCall -> name(args…); TFieldAccess ->
//              (recv.field); TStrLit -> tk_str compound literal (explicit length);
//              TByteLit -> decimal octet. TIfExpr/TMatchExpr AS A VALUE = not yet supported.
//   * stmts  : TBinding -> Ctype x = v; TAssign -> x op= v; TReturn -> early exit in
//              main / `return v;` in a fn; TExprStmt -> expr; TLoopStmt -> while(1){…}
//              (labeled: + tk_lbl_<NAME>_cont/_break goto-targets — M.5);
//              TBreakStmt/TContinueStmt -> break;/continue; (labeled: goto tk_lbl_<NAME>_break/_cont;).
//   * program: each TFunction -> a C function; the loose top-level statements (the
//              VIRTUAL-MAIN) -> int main(void){ … return 0; } with early-return.
//
// COVERAGE RULE (M.3 — honesty): every unsupported node FAILS with a clear message;
// codegen never emits broken C, never crashes. The barrier is named, not silent (M.1).
//
// HOW THIS DIFFERS FROM THE C (faithful, not literal — Teko is cleaner):
//   * The C growable `cbuf` (malloc/realloc + NUL, abort-on-OOM) is SCAFFOLDING for
//     what Teko does natively: the C-source under construction is a `[]byte` grown by
//     `teko::list::push` (the one true intrinsic — core.tks). The append helpers take a
//     buffer and RETURN the grown buffer (the emit/* functional convention — tkb_buf.tks),
//     instead of mutating a `cbuf*` through a pointer.
//   * The C `bool ok + const char **err` plumbing collapses into `[]byte | error`
//     (native variant — B.14): the FIRST error short-circuits via `return e`, exactly
//     as the C's `if (!…) return false` chain did. `T | error` IS the C's TK_RESULT.
//   * The C `seg_is(span, lit)` (memcmp a non-NUL span) is just `==` on `str` here.
//   * The C operator lookup tables that return `const char *` (NULL == unsupported) are
//     `str | error` here — the NULL sentinel becomes an honest error case.

use teko::checker
use teko::lexer
use teko::parser

// ---------------------------------------------------------------------------
// The growable C-source buffer == a `[]byte`. These mirror cbuf's cb/cb_str/cb_i64/
// cb_cstr_escaped. Each APPENDS to `buf` and returns the grown buffer (functional).
// ---------------------------------------------------------------------------

// cb — append a str (its UTF-8 bytes) to the C-source buffer. (C: `cb`.)
fn cb(buf: []byte, s: str) -> []byte {
    mut b = buf
    mut i = 0
    loop {
        if i >= s.len { break }
        b = teko::list::push(b, s[i])
        i++
    }
    b
}

// cb_str — append a str span. In C this appended a tk_str's raw bytes (no NUL); in
// Teko a str IS already a {ptr,len} view, so this is identical to `cb`. (C: `cb_str`.)
fn cb_str(buf: []byte, s: str) -> []byte { cb(buf, s) }

// cb_byte — append a single byte. (No direct C name — folds the C `tmp[0]=c; cb(b,tmp)`
// one-char path into a native byte push.)
fn cb_byte(buf: []byte, x: byte) -> []byte { teko::list::push(buf, x) }

// cb_i64 — append an i64 as decimal text. (C: `cb_i64`, which used snprintf("%PRId64").)
// Teko has no snprintf, so the decimal render is spelled out: emit the sign, then the
// digits high-to-low. Self-contained — no dependency on the lexer's number path.
fn cb_i64(buf: []byte, v: i64) -> []byte {
    if v == 0 { return cb_byte(buf, b'0') }
    mut b = buf
    mut n = v
    if n < 0 { b = cb_byte(b, b'-'); n = -n }   // -n is safe for the M0 magnitudes codegen emits
    // collect digits low-to-high into a scratch list, then emit reversed.
    mut digits: []byte = teko::list::empty()   // byte builder (indexed below — needs a concrete element)
    loop {
        if n == 0 { break }
        let d = (n % 10) to byte                 // 0..9
        digits = teko::list::push(digits, (b'0' to i64 + (d to i64)) to byte)
        n = n / 10
    }
    mut i = digits.len
    loop {
        if i == 0 { break }
        b = cb_byte(b, digits[i - 1])            // reverse: most-significant first
        i--
    }
    b
}

// cb_u128_digits — append the decimal MAGNITUDE of an unsigned 128-bit value (no sign).
// __int128 has no printf specifier in the C backend, so the digits are spelled out
// high-to-low (collect low-to-high, emit reversed) — the C twin is `cb_u128_digits`.
fn cb_u128_digits(buf: []byte, v: u128) -> []byte {
    if v == 0 { return cb_byte(buf, b'0') }
    mut b = buf
    mut n = v
    mut digits: []byte = teko::list::empty()   // byte builder (indexed below — needs a concrete element)
    loop {
        if n == 0 { break }
        let d = (n % 10) to byte                 // 0..9
        digits = teko::list::push(digits, (b'0' to i64 + (d to i64)) to byte)
        n = n / 10
    }
    mut i = digits.len
    loop {
        if i == 0 { break }
        b = cb_byte(b, digits[i - 1])            // reverse: most-significant first
        i--
    }
    b
}

// cb_u128_c_expr — a u128 MAGNITUDE as a C constant EXPRESSION of type `unsigned __int128`. A
// 128-bit value has NO C literal: a decimal token wider than `unsigned long long` is rejected
// BEFORE any cast applies, so when it exceeds 64 bits we BUILD it from two 64-bit halves via
// shifts: `(((unsigned __int128)<hi>ULL << 64) | (unsigned __int128)<lo>ULL)`. ≤64-bit values
// stay a plain `(unsigned __int128)<dec>ULL`. (C: `cb_u128_c_expr`.)
fn cb_u128_c_expr(buf: []byte, v: u128) -> []byte {
    let lo = v & 0xFFFFFFFFFFFFFFFF      // low 64 bits (fits a C decimal)
    let hi = v >> 64                     // high 64 bits
    if hi == 0 {
        mut b = cb(buf, "(unsigned __int128)")
        b = cb_u128_digits(b, lo)
        return cb(b, "ULL")
    }
    mut b = cb(buf, "(((unsigned __int128)")
    b = cb_u128_digits(b, hi)
    b = cb(b, "ULL << 64) | (unsigned __int128)")
    b = cb_u128_digits(b, lo)
    cb(b, "ULL)")
}

// cb_i128 — append a signed 128-bit value as a C constant expression (sign + magnitude via the
// shift form). For the most-negative value, negating in i128 overflows, so the magnitude is
// derived via unsigned wrap. (C: `cb_i128`.)
fn cb_i128(buf: []byte, v: i128) -> []byte {
    if v < 0 {
        mut b = cb(buf, "-(")
        b = cb_u128_c_expr(b, (0 to u128) - (v to u128))
        return cb(b, ")")
    }
    cb_u128_c_expr(buf, v to u128)
}

// cb_f64_literal — append a f64 as a round-trippable decimal literal. The C twin used
// snprintf("%.17g"); Teko has no snprintf, so this defers to the runtime float renderer
// (teko::ftoa) which guarantees an exact binary64 round-trip. (C: `cb_f64_literal`.)
fn cb_f64_literal(buf: []byte, v: f64) -> []byte { cb(buf, teko::ftoa(v)) }

// cb_cstr_escaped — append `s` C-escaped, INSIDE an already-open C string literal. The
// bytes are raw (may contain NUL, quotes, newlines) — see TStrLit. We never rely on
// length here; the caller emits the explicit byte count separately (M.1).
// (C: `cb_cstr_escaped`.)
fn cb_cstr_escaped(buf: []byte, s: str) -> []byte {
    mut b = buf
    mut i = 0
    loop {
        if i >= s.len { break }
        let c = s[i]
        if      c == b'\\' { b = cb(b, "\\\\") }
        else if c == b'"'  { b = cb(b, "\\\"") }
        else if c == b'\n' { b = cb(b, "\\n") }
        else if c == b'\t' { b = cb(b, "\\t") }
        else if c == b'\r' { b = cb(b, "\\r") }
        else if c < 0x20 || c >= 0x7F {
            // 3-digit octal — fixed width dodges the hex "run-on digit" hazard.
            b = cb_byte(b, b'\\')
            b = cb_byte(b, (b'0' to i64 + ((c to i64 / 64) % 8)) to byte)   // octal hundreds
            b = cb_byte(b, (b'0' to i64 + ((c to i64 / 8)  % 8)) to byte)   // octal tens
            b = cb_byte(b, (b'0' to i64 + ( c to i64        % 8)) to byte)   // octal ones
        }
        else { b = cb_byte(b, c) }
        i++
    }
    b
}

// (C7.1k) tk_emit_meta — the build-metadata C appended to EVERY binary by the backend (after
// tk_emit_c), so the artifact carries its identity on every OS. An `@(#)`-marked string literal,
// readable by what(1) / `strings`: "@(#)<name> <version>[-<suffix>] | <description>". (The macOS
// build additionally embeds an Info.plist section; Windows VERSIONINFO + a Linux ELF note follow.)
// (C: `tk_emit_meta`.)
pub fn tk_emit_meta(name: str, version: str, suffix: str, description: str) -> str {
    mut b: []byte = teko::list::empty()
    b = cb(b, "\n/* build metadata (teko C7.1k) — what(1)/strings-readable */\n")
    b = cb(b, "__attribute__((used)) static const char tk_build_meta[] = \"@(#)")
    b = cb_cstr_escaped(b, name)
    b = cb(b, " ")
    b = cb_cstr_escaped(b, version)
    if suffix != "" { b = cb(b, "-"); b = cb_cstr_escaped(b, suffix) }
    if description != "" { b = cb(b, " | "); b = cb_cstr_escaped(b, description) }
    b = cb(b, "\";\n")
    str(b)
}

// ---------------------------------------------------------------------------
// Types -> C type text.
// ---------------------------------------------------------------------------

// emit_prim — a PrimKind -> its C fixed-width type name. (C: `emit_prim`.)
fn emit_prim(buf: []byte, k: checker::PrimKind) -> []byte | error {
    match k {
        checker::PrimKind::U8   => cb(buf, "uint8_t")
        checker::PrimKind::U16  => cb(buf, "uint16_t")
        checker::PrimKind::U32  => cb(buf, "uint32_t")
        checker::PrimKind::U64  => cb(buf, "uint64_t")
        checker::PrimKind::U128 => cb(buf, "unsigned __int128")
        checker::PrimKind::I8   => cb(buf, "int8_t")
        checker::PrimKind::I16  => cb(buf, "int16_t")
        checker::PrimKind::I32  => cb(buf, "int32_t")
        checker::PrimKind::I64  => cb(buf, "int64_t")
        checker::PrimKind::I128 => cb(buf, "__int128")
        checker::PrimKind::F16  => cb(buf, "_Float16")
        checker::PrimKind::F32  => cb(buf, "float")
        checker::PrimKind::F64  => cb(buf, "double")
        checker::PrimKind::Bool => cb(buf, "bool")
    }
}

// ---------------------------------------------------------------------------
// W4c — NAME MANGLING for named aggregate types.
// A named aggregate `T` in namespace `N` -> the C identifier
//   tk_t_<N with :: -> __>__<T>      (for the bare root ns, just tk_t_<T>).
// ONE helper used by BOTH the type-decl emitter and emit_type's Named case so a
// declaration and its references always agree. NOTE: the semantic Named carries only the
// BARE name (resolve.tks drops the namespace) and the typed item carries no namespace
// either, so both call sites pass an EMPTY namespace and mangle by bare name alone —
// consistent for decl + ref (the "keep it simple and consistent" rule). The namespace
// parameter is honored (`::` -> `__`) for the day the typed item carries provenance.
// (C: `mangle_type_name`.)
// ---------------------------------------------------------------------------
fn mangle_type_name(buf: []byte, namespace: str, name: str) -> []byte {
    mut out = cb(buf, "tk_t_")
    if namespace.len > 0 {
        mut i = 0
        loop {
            if i >= namespace.len { break }
            // collapse a "::" pair into "__"; copy any other byte verbatim.
            if i + 1 < namespace.len && namespace[i] == b':' && namespace[i + 1] == b':' {
                out = cb(out, "__")
                i = i + 2
            } else {
                out = cb_byte(out, namespace[i])
                i++
            }
        }
        out = cb(out, "__")
    }
    cb_str(out, name)
}

// (#49) a top-level user FUNCTION's C name = its namespace mangled (each `:` -> `_`) + `__` + the
// bare (keyword-escaped) name, so same-named functions across namespaces (and libc clashes like
// `div`) never collide. An empty namespace (a local/builtin) -> the bare name. Def and call agree by
// using this for BOTH the definition/prototype and the resolved call (TCall.call_ns). (C: cb_fn_name.)
fn cb_fn_name(buf: []byte, ns: str, name: str) -> []byte {
    mut out = buf
    if ns.len != 0 {
        mut i = 0
        loop {
            if i >= ns.len { break }
            if ns[i] == b':' { out = cb_byte(out, b'_') } else { out = cb_byte(out, ns[i]) }
            i++
        }
        out = cb(out, "__")
    }
    cb_ident(out, name)
}

// ---------------------------------------------------------------------------
// W5b — VARIANT-DECL lookup (the .tks twin of the C's g_cg_prog static + scans).
//
// The C stashes the program in a file-scope `static tk_tprogram g_cg_prog` and scans its
// TYPE_DECL items. Teko has NO module-level mutable state (modules hold only `use` + decls;
// loose statements live only in main.tks), so the FUNCTIONAL mirror THREADS the program
// `prog` into the helpers that need it — the same functional-vs-static divergence the file
// header already notes (cbuf*→[]byte, err**→|error). The scans use the SAME tag/field
// spellings as emit_type_decl so wrap + decl agree byte-for-byte.
// ---------------------------------------------------------------------------

// cg_path_last — the bare last segment of a path (cases/types match by their final
// identifier, like the VM's path_last). (C: `cg_path_last`.)
fn cg_path_last(p: parser::Path) -> str {
    if p.segments.len == 0 { "" } else { p.segments[p.segments.len - 1].name }
}

// cg_find_variant_decl — the TypeDecl for a VARIANT named `name` (its body is a union of
// named members), or a `not found` error. (C: `cg_find_variant_decl`, which returned NULL.)
fn cg_find_variant_decl(prog: checker::TProgram, name: str) -> parser::TypeDecl | error {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => {
                match d.body {
                    parser::VariantBody => { if d.name == name { return d } }
                    _ => { }
                }
            }
            _ => { }
        }
        i++
    }
    error { message = "codegen: not a declared variant" }
}

// cg_named_is_variant — is the NAMED type `name` a (declared) variant? (C: `cg_named_is_variant`.)
fn cg_named_is_variant(prog: checker::TProgram, name: str) -> bool {
    match cg_find_variant_decl(prog, name) { parser::TypeDecl => true; error => false }
}

// cg_named_is_enum — is the NAMED type `name` a (declared) enum? (C: `cg_named_is_enum`.)
fn cg_named_is_enum(prog: checker::TProgram, name: str) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => {
                if d.name == name {
                    match d.body { parser::EnumBody => return true; _ => return false }
                }
            }
            _ => { }
        }
        i++
    }
    false
}

// (C8.4) cg_named_is_flags — is the NAMED type `name` a (declared) flags? A flags member is a
// pre-emitted C constant `tk_t_<Name>_<MEMBER>` (power-of-2 unsigned int), not a C enum constant.
// (C: `cg_named_is_flags`.)
fn cg_named_is_flags(prog: checker::TProgram, name: str) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => {
                if d.name == name {
                    match d.body { parser::FlagsBody => return true; _ => return false }
                }
            }
            _ => { }
        }
        i++
    }
    false
}

// cg_find_decl — any TYPE_DECL (struct/variant/enum/alias) named `name`, or a `not found`
// error. (C: `cg_find_decl`, which returned NULL.)
fn cg_find_decl(prog: checker::TProgram, name: str) -> parser::TypeDecl | error {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => { if d.name == name { return d } }
            _ => { }
        }
        i++
    }
    error { message = "codegen: no such type decl" }
}

// cg_find_function — the top-level FUNCTION `name` in namespace `ns`, or a `not found` error.
// (For call-arg wrapping — emit_call needs the callee's parameter types to wrap a bare case arg
// into a variant param via emit_as.) (C: `cg_find_function`, which returned NULL.)
fn cg_find_function(prog: checker::TProgram, ns: str, name: str) -> checker::TFunction | error {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => { if f.name == name && f.namespace == ns { return f } }
            _ => { }
        }
        i++
    }
    error { message = "codegen: no such function" }
}

// cg_is_prim_name — is `name` a builtin scalar (prim/byte/str/error), i.e. carries no user
// decl? (C: `cg_is_prim_name`; same set as cg_is_builtin_scalar.)
fn cg_is_prim_name(name: str) -> bool { cg_is_builtin_scalar(name) }

// =========================================================================
// AUTO-BOX recursive value-type back-edges. A struct field whose (named) type can reach BACK
// to the enclosing type through BY-VALUE embedding (struct field / optional inner / variant
// member / inline-union member — a SLICE is a pointer, not a by-value edge) closes an
// infinite-size cycle in C. Such a field is emitted as a heap POINTER (tk_alloc) instead of an
// inline value: construction mallocs+copies the child, field-access derefs. Mirrors the C twin.
// A VISITED set of type names (here a `[]str` threaded by return — the functional twin of the C
// stack buffer + len/cap) dedups the reachability walk so a CYCLIC type graph is explored in
// O(V+E) (a naive depth-bounded DFS revisits exponentially on cycles → codegen hangs).
// (C: `cg_nameset`/`cg_nameset_seen`/`cg_nameset_mark`.)
// =========================================================================
fn cg_nameset_seen(seen: []str, n: str) -> bool { cg_str_in(seen, n) }

// cg_te_reaches_byvalue — does this type-expr's BY-VALUE content reach the named type `to`?
// (C: `cg_te_reaches_byvalue`.)
fn cg_te_reaches_byvalue(prog: checker::TProgram, te: parser::TypeExpr, to: str, seen: []str) -> bool {
    match te {
        parser::NamedType as nt => {
            let base = nt.path.segments[nt.path.segments.len - 1].name
            if cg_is_prim_name(base) { return false }
            // (S4) a generic-type USE reaches its concrete instance `Box__g__i64`, not the template.
            let y = if nt.args.len == 0 { base } else { cg_texpr_inst_name(base, nt.args) }
            if y == to { return true }
            cg_name_reaches_byvalue(prog, y, to, seen)
        }
        parser::OptionalType as ot => cg_te_reaches_byvalue(prog, ot.inner, to, seen)   // opt embeds inner by value
        parser::UnionType as ut => {
            mut i = 0
            loop {
                if i >= ut.members.len { break }
                if cg_te_reaches_byvalue(prog, ut.members[i], to, seen) { return true }
                i++
            }
            false
        }
        parser::SliceType => false   // a slice is a pointer — not a by-value edge
        parser::FunctionType => false   // (W10a) a function pointer — not a by-value aggregate edge
    }
}
// cg_name_reaches_byvalue — does named type `from` reach named type `to` through by-value edges?
// (visited-set guarded). (C: `cg_name_reaches_byvalue`.)
fn cg_name_reaches_byvalue(prog: checker::TProgram, from: str, to: str, seen: []str) -> bool {
    if cg_nameset_seen(seen, from) { return false }   // already explored this node
    let seen2 = teko::list::push(seen, from)
    let d = match cg_find_decl(prog, from) { parser::TypeDecl as dd => dd; error => return false }
    match d.body {
        parser::StructBody as sb => {
            mut i = 0
            loop {
                if i >= sb.fields.len { break }
                if cg_te_reaches_byvalue(prog, sb.fields[i].type_ann, to, seen2) { return true }
                i++
            }
            false
        }
        parser::VariantBody as vb => match vb.type_expr {
            parser::UnionType as u => {
                mut i = 0
                loop {
                    if i >= u.members.len { break }
                    if cg_te_reaches_byvalue(prog, u.members[i], to, seen2) { return true }
                    i++
                }
                false
            }
            _ => false
        }
        _ => false   // enum/alias — no by-value aggregate edges
    }
}
// cg_field_boxed — is the struct `sname`'s field of declared type `fte` a recursive back-edge
// (→ box as pointer)? A NAMED `Y` or OPTIONAL `Y?` field is boxed iff its by-value content
// reaches BACK to `sname`. A SLICE field is already a pointer (never boxed); an inline-UNION
// field is left unboxed (none close a cycle in the corpus). (C: `cg_field_boxed`.)
fn cg_field_boxed(prog: checker::TProgram, sname: str, fte: parser::TypeExpr) -> bool {
    let is_box_candidate = match fte {
        parser::NamedType    => true
        parser::OptionalType => true
        _ => false
    }
    if !is_box_candidate { return false }
    cg_te_reaches_byvalue(prog, fte, sname, teko::list::empty())
}

// cg_variant_has_member — does variant decl `d` have a member whose bare name is `member`?
// (The member name is the union FIELD name and the UPPERCASE tag suffix.) (C: `cg_variant_has_member`.)
fn cg_variant_has_member(d: parser::TypeDecl, member: str) -> bool {
    let members = match d.body {
        parser::VariantBody as vb => match vb.type_expr {
            parser::UnionType as u => u.members
            _             => return false
        }
        _ => return false
    }
    mut i = 0
    loop {
        if i >= members.len { break }
        match variant_member_name(members[i]) {
            str as mn => { if mn == member { return true } }
            error     => { }
        }
        i++
    }
    false
}

// emit_type — a resolved Type -> C type text. STR -> tk_str; a Named aggregate references
// its mangled typedef (decl + ref agree via mangle_type_name). The remaining structured
// types stay the honest "not yet supported" barrier (M.3). (C: `emit_type`.)
fn emit_type(buf: []byte, t: checker::Type) -> []byte | error {
    match t {
        checker::Prim as p => emit_prim(buf, p.kind)
        checker::Byte      => cb(buf, "uint8_t")
        // CHAR — a UTF-8 codepoint; runtime layout == the byte-slice `tk_char` (teko_rt.h),
        // the SAME {uint8_t*,uint64_t} shape as tk_slice_byte. Distinct only by the checker tag.
        checker::Char      => cb(buf, "tk_char")
        // VOID is the return-only marker (M.3): a `-> void` function lowers to C `void`.
        // The checker (Z2a) forbids void as a value/binding/variant member, so reaching
        // here is always a Func.ret position.
        checker::Void      => cb(buf, "void")
        checker::Str       => cb(buf, "tk_str")
        // OPTIONAL (T?) — the generated `tk_opt_<innerMangle>` struct (REBOOT_PLAN §202). The
        // sentinel optional (a bare `null`, inner = the Void marker) never reaches here on its
        // own — it is always wrapped to a concrete slot type via emit_as.
        checker::Optional as opt => match opt.inner {
            checker::Void => error { message = "codegen: a bare `null` needs a known optional type from context (internal)" }
            _ => cg_opt_typename(buf, opt.inner)
        }
        // SLICE (`[]T`) — the generated tk_slice_<elem> struct. The sentinel/untyped slice
        // (element = the Void marker, from teko::list::empty()) never reaches here on its own —
        // emit_as wraps it to a concrete slot type, exactly like a bare `null` optional.
        checker::Slice as sl => match sl.element {
            checker::Void => error { message = "codegen: an untyped empty slice needs a known element type from context (internal)" }
            _ => cg_slice_typename(buf, sl.element)
        }
        // W4c — a Named aggregate -> its mangled typedef name (the bare name; resolve
        // drops the namespace). decl + ref agree via mangle_type_name.
        checker::Named as nm => mangle_type_name(buf, "", nm.name)
        // VARIANT (`A | B | …`) — the generated tk_u_<keys> tagged-union struct (B-cg2). Its
        // typedef is stamped in the prelude. A Named variant decl is reached via Named, not here.
        checker::Variant as va => cg_variant_typename(buf, va)
        // (W10a) a function/closure VALUE type `(A, B) -> R` lowers to the uniform runtime
        // `tk_closure { void *fn; void *env; }` (teko_rt.h). The per-signature C type is only
        // needed at the CALL site (a cast on `.fn`), never as a storage type — so one struct
        // serves every function type.
        checker::Func      => cb(buf, "tk_closure")
        // `error` — the runtime tk_error struct (E2-NATIVE; teko_rt.h). Full diagnostic fields.
        checker::Error     => cb(buf, "tk_error")
        // (C7.1a) opaque FFI transport types — `ptr` is a bare `void *`, `uptr` a word-size
        // unsigned. Never dereferenced in Teko; only crosses the extern boundary.
        // (S-mem) `ptr<T>` → `<T> *`; opaque ptr (null inner) → `void *`.
        checker::Ptr as p  => match p.inner {
            null               => cb(buf, "void *")
            checker::Type as t => cb(match emit_type(buf, t) { []byte as o => o; error as e => return e }, " *")
        }
        checker::Uptr      => cb(buf, "uintptr_t")
        // (MEM-1b) Ref<T> → a bare `<T> *` today ("C pointer without `*`/`&`"; struct wrapper waits for W9+ metadata).
        checker::Reference as r => cb(match emit_type(buf, r.inner) { []byte as o => o; error as e => return e }, " *")
    }
}

// (W10a) the C function-pointer SIGNATURE for a closure call's cast: `R (*)(A, B)`. Built from the
// callee's resolved Func type so `((R(*)(A,B))f.fn)(args)` invokes the code pointer with the right
// ABI. Empty params → `(void)`. `with_env` prepends a leading `void *` (the env-first ABI used by a
// CAPTURING closure). (C: `cg_emit_fnptr_sig`.)
fn cg_emit_fnptr_sig_ex(buf: []byte, t: checker::Type, with_env: bool) -> []byte | error {
    match t {
        checker::Func as f => {
            mut out = match emit_type(buf, f.ret) { []byte as o => o; error as e => return e }
            out = cb(out, " (*)(")
            mut first = true
            if with_env { out = cb(out, "void *"); first = false }
            if f.params.len == 0 {
                if first { out = cb(out, "void") }
            } else {
                mut i = 0
                loop {
                    if i >= f.params.len { break }
                    if !first { out = cb(out, ", ") }
                    first = false
                    out = match emit_type(out, f.params[i]) { []byte as o => o; error as e => return e }
                    i++
                }
            }
            cb(out, ")")
        }
        _ => error { message = "codegen: closure call on a non-function type (internal)" }
    }
}
fn cg_emit_fnptr_sig(buf: []byte, t: checker::Type) -> []byte | error { cg_emit_fnptr_sig_ex(buf, t, false) }

// (W10) emit a CLOSURE CALL through a `tk_closure` value as a GNU statement-expression that evaluates
// each argument ONCE and DISPATCHES on `env`: a NON-capturing closure / named-fn value (env == NULL)
// calls with the no-env ABI `R(params)`; a CAPTURING closure (env != NULL) calls with the env-first
// ABI `R(void*, params)`. The callee is a local of function type (its name is the callee's last seg).
fn emit_closure_call(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, c: checker::TCall, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let nm = c.callee.segments[c.callee.segments.len - 1].name
    mut out = cb(buf, "({ ")
    // bind each argument to a temp (single evaluation, preserving side effects).
    mut j = 0
    loop {
        if j >= c.args.len { break }
        out = match emit_type(out, c.args[j].type) { []byte as o => o; error as e => return e }
        out = cb(out, " ")
        out = cb(out, teko::str::concat("_tca", teko::u64_to_str(j to u64)))
        out = cb(out, " = ")
        out = match emit_expr_ctx(out, prog, ret_type, c.args[j], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        out = cb(out, "; ")
        j++
    }
    out = cb(out, "tk_closure _tcf = ")
    out = cb_ident(out, nm)
    out = cb(out, "; _tcf.env ? ((")
    out = match cg_emit_fnptr_sig_ex(out, c.callee_type, true) { []byte as o => o; error as e => return e }
    out = cb(out, ")_tcf.fn)(_tcf.env")
    mut k = 0
    loop { if k >= c.args.len { break }; out = cb(out, ", "); out = cb(out, teko::str::concat("_tca", teko::u64_to_str(k to u64))); k++ }
    out = cb(out, ") : ((")
    out = match cg_emit_fnptr_sig_ex(out, c.callee_type, false) { []byte as o => o; error as e => return e }
    out = cb(out, ")_tcf.fn)(")
    mut m = 0
    loop { if m >= c.args.len { break }; if m > 0 { out = cb(out, ", ") }; out = cb(out, teko::str::concat("_tca", teko::u64_to_str(m to u64))); m++ }
    cb(out, "); })")
}

// OPTIONAL `T?` C REPRESENTATION (REBOOT_PLAN §202). Each distinct optional inner type maps to a
// generated struct `tk_opt_<innerMangle>` = `{ bool present; <innerCtype> value; }`. The mangle
// suffix is a deterministic function of the inner type so the typedef + every use agree. `error`
// lowers to its message tk_str, so `error?` is `tk_opt_error`. (C: `cg_opt_typename`/`cg_opt_mangle`.)
fn cg_opt_typename(buf: []byte, inner: checker::Type) -> []byte | error {
    cg_opt_mangle(cb(buf, "tk_opt_"), inner)
}
// SLICE value layer (fixed+copy): a `[]T` lowers to the generated `tk_slice_<elemMangle>`
// struct `{ <elemC> *ptr; uint64_t len; }` (same shape as tk_str). Reuses the optional element
// mangle for the suffix, so decl + every use agree byte-for-byte. (C: `cg_slice_typename`.)
fn cg_slice_typename(buf: []byte, elem: checker::Type) -> []byte | error {
    cg_opt_mangle(cb(buf, "tk_slice_"), elem)
}
// The deterministic mangle SUFFIX for an optional inner type (used in tk_opt_<suffix>).
fn cg_opt_mangle(buf: []byte, inner: checker::Type) -> []byte | error {
    match inner {
        checker::Prim as p => match p.kind {
            checker::PrimKind::U8 => cb(buf, "u8");   checker::PrimKind::U16 => cb(buf, "u16")
            checker::PrimKind::U32 => cb(buf, "u32"); checker::PrimKind::U64 => cb(buf, "u64")
            checker::PrimKind::U128 => cb(buf, "u128"); checker::PrimKind::I8 => cb(buf, "i8")
            checker::PrimKind::I16 => cb(buf, "i16"); checker::PrimKind::I32 => cb(buf, "i32")
            checker::PrimKind::I64 => cb(buf, "i64"); checker::PrimKind::I128 => cb(buf, "i128")
            checker::PrimKind::F16 => cb(buf, "f16"); checker::PrimKind::F32 => cb(buf, "f32")
            checker::PrimKind::F64 => cb(buf, "f64"); checker::PrimKind::Bool => cb(buf, "bool")
        }
        checker::Byte  => cb(buf, "byte")
        checker::Char  => cb(buf, "char")
        checker::Str   => cb(buf, "str")
        checker::Error => cb(buf, "error")
        checker::Named as nm => cb_str(buf, nm.name)
        checker::Optional as o => match o.inner {
            checker::Void => error { message = "codegen: nested bare-null optional (internal)" }
            _ => cg_opt_mangle(cb(buf, "opt_"), o.inner)
        }
        _ => error { message = "codegen: optional inner type not yet supported" }
    }
}

// ---------------------------------------------------------------------------
// B-cg2 — VARIANT codegen (the `T | error` sum types the corpus uses pervasively).
// ---------------------------------------------------------------------------

// cg_opt_mangle_str — the resolved-type mangle SUFFIX as a STRING (the str twin of
// cg_opt_mangle, which appends to a buffer). Used to compose member keys via str concat.
fn cg_opt_mangle_str(inner: checker::Type) -> str | error {
    match inner {
        checker::Prim as p => match p.kind {
            checker::PrimKind::U8 => "u8";   checker::PrimKind::U16 => "u16"
            checker::PrimKind::U32 => "u32"; checker::PrimKind::U64 => "u64"
            checker::PrimKind::U128 => "u128"; checker::PrimKind::I8 => "i8"
            checker::PrimKind::I16 => "i16"; checker::PrimKind::I32 => "i32"
            checker::PrimKind::I64 => "i64"; checker::PrimKind::I128 => "i128"
            checker::PrimKind::F16 => "f16"; checker::PrimKind::F32 => "f32"
            checker::PrimKind::F64 => "f64"; checker::PrimKind::Bool => "bool"
        }
        checker::Byte  => "byte"
        checker::Char  => "char"
        checker::Str   => "str"
        checker::Error => "error"
        checker::Named as nm => nm.name
        checker::Optional as o => match o.inner {
            checker::Void => error { message = "codegen: nested bare-null optional (internal)" }
            // (2026-07-01) bind the recursive result FIRST — `concat` is now variadic, so its 2nd
            // arg packs into a synthetic array literal; an early `return` embedded directly inside
            // an array-literal element trips a pre-existing codegen gap (the union-error wrap
            // isn't threaded through nested array-element stmt-exprs). A plain TVar arg sidesteps it.
            _ => { let inner_s = match cg_opt_mangle_str(o.inner) { str as s => s; error as e => return e }; teko::str::concat("opt_", inner_s) }
        }
        _ => error { message = "codegen: optional inner type not yet supported" }
    }
}

// cg_is_c_keyword — does `s` collide with a C(23) keyword? A variant member KEY (a union
// FIELD identifier) or a user identifier that spells a C keyword (`bool bool;`) is invalid, so
// it gets a trailing `_`. (C: `cg_is_c_keyword`.)
fn cg_is_c_keyword(s: str) -> bool {
    s == "bool" || s == "int" || s == "char" || s == "short" || s == "long" ||
    s == "float" || s == "double" || s == "void" || s == "unsigned" || s == "signed" ||
    s == "const" || s == "volatile" || s == "register" || s == "auto" || s == "static" ||
    s == "struct" || s == "union" || s == "enum" || s == "return" || s == "default" ||
    s == "goto" || s == "break" || s == "continue" || s == "case" || s == "switch" ||
    s == "do" || s == "for" || s == "while" || s == "if" || s == "else" || s == "sizeof" ||
    s == "typedef" || s == "extern" || s == "inline" || s == "restrict"
}

// cb_ident — emit a user IDENTIFIER (variable / parameter / binding / assignment target),
// escaping a C keyword with a trailing `_` (e.g. a parameter named `signed` → `signed_`).
// Applied at the definition AND every use so they agree. (C: `cb_ident`.)
fn cb_ident(buf: []byte, name: str) -> []byte {
    let out = cb_str(buf, name)
    if cg_is_c_keyword(name) { cb(out, "_") } else { out }
}

// cg_member_key_str — a variant member's C-IDENTIFIER-SAFE KEY (str) for a RESOLVED member
// type: the spelling used for BOTH the tag constant (TK_TAG_<V>_<UPPER key>) and the union
// field (.as.<key>). Extends cg_opt_mangle_str with the SLICE member (`slice_<elem>`), so
// EVERY member kind maps to a key. A key that collides with a C keyword (`bool`) gets a
// trailing `_` so the union field, the `.as.<key>` construction, and the destructure agree.
// (C: `cg_member_key`.)
fn cg_member_key_str(m: checker::Type) -> str | error {
    let k = match m {
        checker::Slice as sl => match sl.element {
            checker::Void => return error { message = "codegen: an untyped slice variant member needs a known element type (internal)" }
            _ => { let inner_s = match cg_opt_mangle_str(sl.element) { str as s => s; error as e => return e }; teko::str::concat("slice_", inner_s) }
        }
        _ => match cg_opt_mangle_str(m) { str as s => s; error as e => return e }
    }
    if cg_is_c_keyword(k) { teko::str::concat(k, "_") } else { k }
}

// cg_member_key — append a resolved member's key to a buffer. (C: `cg_member_key`.)
fn cg_member_key(buf: []byte, m: checker::Type) -> []byte | error {
    cb(buf, match cg_member_key_str(m) { str as s => s; error as e => return e })
}

// cg_variant_typename_str — the deterministic C type NAME of an INLINE variant `A | B | …`:
// `tk_u_` then each member's key joined by `_`, in SOURCE ORDER. (C: `cg_variant_typename`.)
fn cg_variant_typename_str(v: checker::Variant) -> str | error {
    mut name = "tk_u"
    mut i = 0
    loop {
        if i >= v.members.len { break }
        let k = match cg_member_key_str(v.members[i]) { str as s => s; error as e => return e }
        name = teko::str::concat(name, "_", k)
        i++
    }
    name
}

// cg_variant_typename — append the inline-variant tk_u_<keys> name to a buffer. (C: `cg_variant_typename`.)
fn cg_variant_typename(buf: []byte, v: checker::Variant) -> []byte | error {
    cb(buf, match cg_variant_typename_str(v) { str as s => s; error as e => return e })
}

// cg_emit_variant_ctype — emit the C TYPE for any variant-shaped resolved type: a Named
// variant decl → its mangled tk_t_<Name>; an inline `A | B | …` → its tk_u_<keys>. (C: `cg_emit_variant_ctype`.)
fn cg_emit_variant_ctype(buf: []byte, v: checker::Type) -> []byte | error {
    match v {
        checker::Named as nm => mangle_type_name(buf, "", nm.name)
        checker::Variant as va => cg_variant_typename(buf, va)
        _ => error { message = "codegen: cg_emit_variant_ctype on a non-variant type (internal)" }
    }
}

// cg_opt_mangle_texpr_str — the SYNTACTIC mangle suffix as a STRING (str twin of
// cg_opt_mangle_texpr). Agrees byte-for-byte with cg_opt_mangle_str. (C: `cg_opt_mangle_texpr`.)
fn cg_opt_mangle_texpr_str(te: parser::TypeExpr) -> str | error {
    match te {
        parser::NamedType as nt => nt.path.segments[nt.path.segments.len - 1].name
        parser::OptionalType as ot => { let inner_s = match cg_opt_mangle_texpr_str(ot.inner) { str as s => s; error as e => return e }; teko::str::concat("opt_", inner_s) }
        parser::SliceType as st => { let inner_s = match cg_opt_mangle_texpr_str(st.element) { str as s => s; error as e => return e }; teko::str::concat("slice_", inner_s) }
        _ => error { message = "codegen: optional inner type-expr not yet supported" }
    }
}

// cg_member_key_texpr_str — a SYNTACTIC member's key (str). A C-keyword key (`bool`) → `bool_`
// so the union field, construction, and destructure agree. (C: `cg_member_key_texpr`.)
fn cg_member_key_texpr_str(m: parser::TypeExpr) -> str | error {
    let k = match cg_opt_mangle_texpr_str(m) { str as s => s; error as e => return e }
    if cg_is_c_keyword(k) { teko::str::concat(k, "_") } else { k }
}

// cg_variant_typename_texpr — the SYNTACTIC twin of cg_variant_typename — the inline-union
// tk_u_<keys> name from a UnionType type-expr (a signature/field position). (C: `cg_variant_typename_texpr`.)
fn cg_variant_typename_texpr(buf: []byte, te: parser::UnionType) -> []byte | error {
    mut out = cb(buf, "tk_u")
    mut i = 0
    loop {
        if i >= te.members.len { break }
        out = cb(out, "_")
        out = cb(out, match cg_member_key_texpr_str(te.members[i]) { str as s => s; error as e => return e })
        i++
    }
    out
}

// emit_type_expr — a SYNTACTIC type-expr (parser TypeExpr) -> C type text. Needed for
// type-decl member positions (struct field annotations, variant member types), where the
// typed item carries the SYNTACTIC body, not the resolved Type. A NamedType's last path
// segment is either a built-in name (u8..f64/bool/byte/str -> its C type) or a user type
// (-> its mangled typedef). Slice/union/optional members are honest barriers (later
// waves). (C: `emit_type_expr`.)
// (S4) a type-expr → its mangle fragment, matching checker::type_mangle (prim/str/byte/named → the
// name, slice_/opt_ prefixes, a nested generic use → its own instance name). So the instance name a
// generic USE emits agrees byte-for-byte with the stamped decl's name.
fn cg_texpr_mangle(te: parser::TypeExpr) -> str {
    match te {
        parser::NamedType as nt => {
            let last = nt.path.segments[nt.path.segments.len - 1].name
            if nt.args.len == 0 { last } else { cg_texpr_inst_name(last, nt.args) }
        }
        parser::SliceType as st    => teko::str::concat("slice_", cg_texpr_mangle(st.element))
        parser::OptionalType as ot => teko::str::concat("opt_", cg_texpr_mangle(ot.inner))
        parser::UnionType          => "variant"
        parser::FunctionType       => "func"   // (W10a) matches checker type_mangle's Func fragment
    }
}
// `<base>__g__<arg0>[__<arg1>…]` over type-arg exprs (matches checker::generic_inst_name).
fn cg_texpr_inst_name(base: str, args: []parser::TypeExpr) -> str {
    mut out = teko::str::concat(base, "__g__")
    mut i = 0
    loop {
        if i >= args.len { break }
        if i > 0 { out = teko::str::concat(out, "__") }
        out = teko::str::concat(out, cg_texpr_mangle(args[i]))
        i++
    }
    out
}

fn emit_type_expr(buf: []byte, prog: checker::TProgram, te: parser::TypeExpr) -> []byte | error {
    match te {
        parser::NamedType as nt => {
            let last = nt.path.segments[nt.path.segments.len - 1].name
            if      last == "u8"    { return cb(buf, "uint8_t") }
            else if last == "u16"   { return cb(buf, "uint16_t") }
            else if last == "u32"   { return cb(buf, "uint32_t") }
            else if last == "u64"   { return cb(buf, "uint64_t") }
            else if last == "u128"  { return cb(buf, "unsigned __int128") }
            else if last == "i8"    { return cb(buf, "int8_t") }
            else if last == "i16"   { return cb(buf, "int16_t") }
            else if last == "i32"   { return cb(buf, "int32_t") }
            else if last == "i64"   { return cb(buf, "int64_t") }
            else if last == "i128"  { return cb(buf, "__int128") }
            else if last == "f16"   { return cb(buf, "_Float16") }
            else if last == "f32"   { return cb(buf, "float") }
            else if last == "f64"   { return cb(buf, "double") }
            else if last == "bool"  { return cb(buf, "bool") }
            else if last == "byte"  { return cb(buf, "uint8_t") }
            else if last == "char"  { return cb(buf, "tk_char") }   // UTF-8 codepoint (byte-slice layout)
            else if last == "str"   { return cb(buf, "tk_str") }
            else if last == "error" { return cb(buf, "tk_error") }   // error → runtime tk_error struct (E2-NATIVE)
            else if last == "ptr"   { if nt.args.len > 0 { return cb(match emit_type_expr(buf, prog, nt.args[0]) { []byte as o => o; error as e => return e }, " *") } else { return cb(buf, "void *") } }   // ptr<T> → <T> * ; ptr → void *
            else if last == "uptr"  { return cb(buf, "uintptr_t") }  // (C7.1a) opaque word-size unsigned
            else if last == "Ref"   { if nt.args.len > 0 { return cb(match emit_type_expr(buf, prog, nt.args[0]) { []byte as o => o; error as e => return e }, " *") } else { return error { message = "`Ref<T>` needs a type argument" } } }   // (MEM-1b) Ref<T> → <T> *
            // a TRANSPARENT alias (`type Name = <type-expr>`) emits NO C type of its own —
            // resolve through to the aliased type-expr at every use site (e.g. a field `[]TypeReg`
            // → tk_slice_TypeReg). Matches the checker, which resolves aliases transparently.
            match cg_find_decl(prog, last) {
                parser::TypeDecl as ad => match ad.body {
                    parser::AliasBody as alb => return emit_type_expr(buf, prog, alb.alias)
                    _ => { }
                }
                error => { }
            }
            // (S4) a generic-type USE `Box<i64>` → the concrete instance typedef `tk_t_Box__g__i64`
            // (the mangled name matches checker::generic_inst_name, so decl + ref agree).
            if nt.args.len > 0 { return mangle_type_name(buf, "", cg_texpr_inst_name(last, nt.args)) }
            // a user-defined named aggregate -> its mangled typedef name (matches emit_type).
            mangle_type_name(buf, "", last)
        }
        // SLICE `[]T` in a signature / field position → the generated `tk_slice_<elem>` struct (the
        // same name cg_slice_typename produces from the resolved type, so decl + ref agree).
        parser::SliceType as st => cg_opt_mangle_texpr(cb(buf, "tk_slice_"), st.element)
        // INLINE union `A | B | …` in a signature/field position → the generated tk_u_<keys>
        // tagged-union struct (B-cg2); the typedef is stamped in the prelude. (C: emit_type_expr TEXPR_UNION arm.)
        parser::UnionType as ut => cg_variant_typename_texpr(buf, ut)
        // `T?` field/member position → the generated tk_opt_<innerMangle> struct (REBOOT §202).
        parser::OptionalType as ot => cg_opt_mangle_texpr(cb(buf, "tk_opt_"), ot.inner)
        // (W10a) a function-type field/param annotation → the uniform `tk_closure` (teko_rt.h).
        parser::FunctionType => cb(buf, "tk_closure")
    }
}

// The deterministic optional-mangle SUFFIX for a SYNTACTIC inner type-expr (the struct-field /
// member position twin of cg_opt_mangle). Must agree byte-for-byte with cg_opt_mangle.
// (C: `cg_opt_mangle_texpr`.)
fn cg_opt_mangle_texpr(buf: []byte, te: parser::TypeExpr) -> []byte | error {
    match te {
        parser::NamedType as nt => cb_str(buf, nt.path.segments[nt.path.segments.len - 1].name)
        parser::OptionalType as ot => cg_opt_mangle_texpr(cb(buf, "opt_"), ot.inner)
        _ => error { message = "codegen: optional inner type-expr not yet supported" }
    }
}

// ---------------------------------------------------------------------------
// Operator token kind -> C operator text. The C returned `const char *` with NULL ==
// unsupported; here the NULL sentinel is an honest `str | error` (M.3).
// ---------------------------------------------------------------------------

// binop_c — a binary operator token -> its C spelling. (C: `binop_c`.)
fn binop_c(op: lexer::TokenKind) -> str | error {
    match op {
        lexer::TokenKind::Plus    => "+"
        lexer::TokenKind::Minus   => "-"
        lexer::TokenKind::Star    => "*"
        lexer::TokenKind::Slash   => "/"
        lexer::TokenKind::Percent => "%"
        lexer::TokenKind::Amp     => "&"
        lexer::TokenKind::Pipe    => "|"
        lexer::TokenKind::Caret   => "^"
        lexer::TokenKind::Shl     => "<<"
        lexer::TokenKind::Shr     => ">>"
        lexer::TokenKind::AndAnd  => "&&"
        lexer::TokenKind::OrOr    => "||"
        _                         => error { message = "codegen: binary operator not yet supported" }
    }
}

// unop_c — a unary prefix operator token -> its C spelling. (C: `unop_c`.)
fn unop_c(op: lexer::TokenKind) -> str | error {
    match op {
        lexer::TokenKind::Minus => "-"
        lexer::TokenKind::Tilde => "~"
        lexer::TokenKind::Bang  => "!"
        _                       => error { message = "codegen: unary operator not yet supported" }
    }
}

// cmpop_c — a comparison operator token -> its C spelling. (C: `cmpop_c`.)
fn cmpop_c(op: lexer::TokenKind) -> str | error {
    match op {
        lexer::TokenKind::EqEq => "=="
        lexer::TokenKind::Ne   => "!="
        lexer::TokenKind::Lt   => "<"
        lexer::TokenKind::Le   => "<="
        lexer::TokenKind::Gt   => ">"
        lexer::TokenKind::Ge   => ">="
        _                      => error { message = "codegen: comparison operator not yet supported" }
    }
}

// assignop_c — an assignment operator token -> its C spelling. (C: `assignop_c`.)
fn assignop_c(op: lexer::TokenKind) -> str | error {
    match op {
        lexer::TokenKind::Assign    => "="
        lexer::TokenKind::PlusEq    => "+="
        lexer::TokenKind::MinusEq   => "-="
        lexer::TokenKind::StarEq    => "*="
        lexer::TokenKind::SlashEq   => "/="
        lexer::TokenKind::PercentEq => "%="
        lexer::TokenKind::AmpEq     => "&="
        lexer::TokenKind::PipeEq    => "|="
        lexer::TokenKind::CaretEq   => "^="
        lexer::TokenKind::ShlEq     => "<<="
        lexer::TokenKind::ShrEq     => ">>="
        _                           => error { message = "codegen: assignment operator not yet supported" }
    }
}

// ---------------------------------------------------------------------------
// F3 GUARDS (M.1 — fail loud): the prim helpers that pick the right runtime guard.
// Integer prims only; bool is never a guard target.
// ---------------------------------------------------------------------------

// These mirror the type.tks predicates (prim_is_float/prim_is_int/…) but stay local so
// the F3 logic is self-contained; they are now exhaustive over the Tier-1 prim set
// (incl. U128/I128 + the floats F16/F32/F64). (C twins: cg_prim_is_*.)

// cg_prim_is_float — the IEEE float prims (F16/F32/F64). (type.tks: prim_is_float.)
fn cg_prim_is_float(k: checker::PrimKind) -> bool { checker::prim_is_float(k) }

// cg_prim_is_int — the integer prims (U8..U128, I8..I128). NOT bool, NOT float.
fn cg_prim_is_int(k: checker::PrimKind) -> bool { checker::prim_is_int(k) }

// cg_prim_is_signed_int — the SIGNED integer prims (I8..I128). (type.tks: prim_is_signed.)
fn cg_prim_is_signed_int(k: checker::PrimKind) -> bool { checker::prim_is_signed(k) }

// cg_int_width — bit-width ordinal (8/16/32/64/128) for narrowing analysis; ints only.
fn cg_int_width(k: checker::PrimKind) -> i64 {
    match k {
        checker::PrimKind::U8   => 8
        checker::PrimKind::I8   => 8
        checker::PrimKind::U16  => 16
        checker::PrimKind::I16  => 16
        checker::PrimKind::U32  => 32
        checker::PrimKind::I32  => 32
        checker::PrimKind::U64  => 64
        checker::PrimKind::I64  => 64
        checker::PrimKind::U128 => 128
        checker::PrimKind::I128 => 128
        _              => 0
    }
}

// prim_div_tag — the tag ("u8".."i128", "f16".."f64") naming a div/mod (or cast) helper,
// e.g. tk_div_u32 / tk_div_f64 / tk_to_i16. Bool has no tag (never a guard target); the
// C returned NULL for Bool, here that is an honest `str | error`. (C: `prim_div_tag`.)
fn prim_div_tag(k: checker::PrimKind) -> str | error {
    match k {
        checker::PrimKind::U8   => "u8"
        checker::PrimKind::U16  => "u16"
        checker::PrimKind::U32  => "u32"
        checker::PrimKind::U64  => "u64"
        checker::PrimKind::U128 => "u128"
        checker::PrimKind::I8   => "i8"
        checker::PrimKind::I16  => "i16"
        checker::PrimKind::I32  => "i32"
        checker::PrimKind::I64  => "i64"
        checker::PrimKind::I128 => "i128"
        checker::PrimKind::F16  => "f16"
        checker::PrimKind::F32  => "f32"
        checker::PrimKind::F64  => "f64"
        checker::PrimKind::Bool => error { message = "codegen: bool has no div/cast helper tag" }
    }
}

// prim_int_tag — the integer-target tag ("u8".."i128") naming a cast helper; error for
// non-ints (float/bool). Reuses prim_div_tag once integer-ness is established.
fn prim_int_tag(k: checker::PrimKind) -> str | error {
    if cg_prim_is_int(k) { return prim_div_tag(k) }
    error { message = "codegen: cast to a non-integer type not yet supported" }
}

// prim_float_tag — the float-source suffix ("f16"/"f32"/"f64") for a float->int cast
// helper (tk_to_<dst>_from_<fsrc>); error for non-floats.
fn prim_float_tag(k: checker::PrimKind) -> str | error {
    match k {
        checker::PrimKind::F16 => "f16"
        checker::PrimKind::F32 => "f32"
        checker::PrimKind::F64 => "f64"
        _             => error { message = "codegen: not a float source type" }
    }
}

// cast_may_lose — an INT->INT cast src->dst may lose data (needs a runtime guard) when
// SOME value of the source type falls outside the destination's representable range.
// Conservative: if we cannot prove source range ⊆ dest range, guard. Floats are handled
// separately (float->int always guards). (C: `cast_may_lose`.)
pub fn cast_may_lose(src: checker::PrimKind, dst: checker::PrimKind) -> bool {
    let ss = cg_prim_is_signed_int(src)
    let ds = cg_prim_is_signed_int(dst)
    let sw = cg_int_width(src)
    let dw = cg_int_width(dst)
    if ss == ds { return sw > dw }          // same signedness: only true narrowing loses
    if !ss && ds { return sw >= dw }        // u->i: dest loses one bit of magnitude at equal width
    true                                    // i->u: negatives never fit
}

// ---------------------------------------------------------------------------
// Expressions -> C expression text. The C threaded `cbuf *b` + `const char **err` and
// returned bool; here each helper takes `buf` and returns the grown `[]byte | error`
// (the buffer carries the result; the error short-circuits the walk).
// ---------------------------------------------------------------------------

// emit_div_mod — the F3 (M.1) `/` and `%` path: a checked runtime helper (tk_div_*/
// tk_mod_*) that PANICS on a zero divisor instead of UB/SIGFPE. Single-eval — each
// operand emitted once, passed by value. The helper width comes from the node's result
// prim. (C: inlined inside emit_expr's TK_TEXPR_BINARY `/` `%` branch.)
// NOTE (W5b threading): the C reaches the stashed program via a file-scope `static
// g_cg_prog`; Teko has no module-level mutable state, so the FUNCTIONAL mirror THREADS the
// read-only `prog` through the expr/stmt chain (the same functional-vs-static divergence the
// file header notes for cbuf*→[]byte and err**→|error). It is needed only at the variant
// frontier (emit_as / the match emitters), but the chain that can reach those carries it.
fn emit_div_mod(buf: []byte, prog: checker::TProgram, e: checker::TExpr, b: checker::TBinary, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let prim = match e.type {
        checker::Prim as p => p
        _                  => return error { message = "codegen: division/modulo on a non-primitive type not yet supported" }
    }
    // `%` is invalid on floats (no C float modulo operator). Ruling §5: error.
    if b.op == lexer::TokenKind::Percent && cg_prim_is_float(prim.kind) {
        return error { message = "codegen: modulo on a float type is not allowed" }
    }
    let tag = match prim_div_tag(prim.kind) {
        str as t     => t                          // covers u8..i128 AND f16..f64
        error        => return error { message = "codegen: division/modulo on a non-numeric type not yet supported" }
    }
    // Float `/` -> tk_div_f64/f32/f16 (ruling §5: float ÷0 PANICS, parity with int).
    // Int `/`,`%` -> tk_div_*/tk_mod_* as before. Single-eval (each operand emitted once).
    mut out = buf
    if b.op == lexer::TokenKind::Slash { out = cb(out, "tk_div_") } else { out = cb(out, "tk_mod_") }
    out = cb(out, tag)
    out = cb(out, "(")
    out = match emit_expr_ctx(out, prog, checker::Void { }, b.left, escaping, regions, fn_body, dctx)  { []byte as o => o; error as err => return err }
    out = cb(out, ", ")
    out = match emit_expr_ctx(out, prog, checker::Void { }, b.right, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ")")
}

// emit_arith — C7.15: the `+`, `-`, `*` path for INTEGER prims.
// Routes through tk_add_*/tk_sub_*/tk_mul_* helpers (teko_rt.h C7.15 block).
// When TEKO_OVERFLOW_DEBUG is set these call tk_panic_overflow() on overflow;
// without it they compile to the plain C operator — zero overhead.
// Float +,-,* fall through to emit_binary's plain-C path (float overflow ≠ panic).
// (C: the `if (bop == TK_TOKEN_PLUS || …)` block inside TK_TEXPR_BINARY.)
fn emit_arith(buf: []byte, prog: checker::TProgram, e: checker::TExpr, b: checker::TBinary, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let prim = match e.type {
        checker::Prim as p => p
        _                  => return error { message = "codegen: arithmetic on a non-primitive type not yet supported" }
    }
    if !cg_prim_is_int(prim.kind) {
        return error { message = "codegen: emit_arith called on non-integer type" }
    }
    let tag = match prim_int_tag(prim.kind) {
        str as t  => t
        error     => return error { message = "codegen: arithmetic on a non-integer primitive" }
    }
    let fn_prefix = if b.op == lexer::TokenKind::Plus  { "tk_add_" }
                    else if b.op == lexer::TokenKind::Minus { "tk_sub_" }
                    else { "tk_mul_" }
    mut out = cb(buf, fn_prefix)
    out = cb(out, tag)
    out = cb(out, "(")
    out = match emit_expr_ctx(out, prog, checker::Void { }, b.left, escaping, regions, fn_body, dctx)  { []byte as o => o; error as err => return err }
    out = cb(out, ", ")
    out = match emit_expr_ctx(out, prog, checker::Void { }, b.right, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ")")
}

// emit_binary — a TBinary. `/` and `%` go through emit_div_mod; `+`, `-`, `*`
// on integer prims go through emit_arith (C7.15 overflow guards); everything
// else emits plain C `(L op R)`. (C: TK_TEXPR_BINARY branch of emit_expr.)
fn emit_binary(buf: []byte, prog: checker::TProgram, e: checker::TExpr, b: checker::TBinary, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    if b.op == lexer::TokenKind::Slash || b.op == lexer::TokenKind::Percent {
        return emit_div_mod(buf, prog, e, b, escaping, regions, fn_body, dctx)
    }
    // C7.15 — +,-,* on integer prims: route through overflow-guarded helpers.
    if b.op == lexer::TokenKind::Plus || b.op == lexer::TokenKind::Minus || b.op == lexer::TokenKind::Star {
        let is_int_prim = match e.type {
            checker::Prim as p => cg_prim_is_int(p.kind)
            _                  => false
        }
        if is_int_prim { return emit_arith(buf, prog, e, b, escaping, regions, fn_body, dctx) }
    }
    let op = match binop_c(b.op) { str as s => s; error as err => return err }
    mut out = cb(buf, "(")
    out = match emit_expr_ctx(out, prog, checker::Void { }, b.left, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb(out, op)
    out = cb(out, " ")
    out = match emit_expr_ctx(out, prog, checker::Void { }, b.right, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ")")
}

// emit_unary — a TUnary -> `(op X)`. (C: TK_TEXPR_UNARY branch.)
fn emit_unary(buf: []byte, prog: checker::TProgram, u: checker::TUnary, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let op = match unop_c(u.op) { str as s => s; error as err => return err }
    mut out = cb(buf, "(")
    out = cb(out, op)
    out = match emit_expr_ctx(out, prog, checker::Void { }, u.operand, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ")")
}

// emit_compare — a TCompare -> chained `a<b<c` => `((a<b) && (b<c))` over ADJACENT
// operands. A lone subject (no rest) is degenerate: emit it bare. (C: TK_TEXPR_COMPARE.)
fn emit_compare(buf: []byte, prog: checker::TProgram, c: checker::TCompare, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    if c.rest.len == 0 { return emit_expr_ctx(buf, prog, checker::Void { }, c.first, escaping, regions, fn_body, dctx) }
    mut out = cb(buf, "(")
    mut prev = c.first
    mut i = 0
    loop {
        if i >= c.rest.len { break }
        let term = c.rest[i]
        let op = match cmpop_c(term.op) { str as s => s; error as err => return err }
        if i > 0 { out = cb(out, " && ") }
        // str equality/inequality lowers to tk_str_eq (a tk_str is a {ptr,len} struct — C `==`
        // is invalid on it). `a == b` → tk_str_eq(a,b); `a != b` → !tk_str_eq(a,b).
        let prev_str = match prev.type { checker::Str => true; _ => false }
        let opnd_str = match term.operand.type { checker::Str => true; _ => false }
        let is_eq = term.op == lexer::TokenKind::EqEq || term.op == lexer::TokenKind::Ne
        if (prev_str || opnd_str) && is_eq {
            out = cb(out, "(")
            if term.op == lexer::TokenKind::Ne { out = cb(out, "!") }
            out = cb(out, "tk_str_eq(")
            out = match emit_expr_ctx(out, prog, checker::Void { }, prev, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, ", ")
            out = match emit_expr_ctx(out, prog, checker::Void { }, term.operand, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, "))")
        } else {
            out = cb(out, "(")
            out = match emit_expr_ctx(out, prog, checker::Void { }, prev, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, " ")
            out = cb(out, op)
            out = cb(out, " ")
            out = match emit_expr_ctx(out, prog, checker::Void { }, term.operand, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, ")")
        }
        prev = term.operand
        i++
    }
    cb(out, ")")
}

// emit_cast — a TCast. F3 (M.1): a narrowing `x to T` is range-checked at runtime via
// tk_to_<dst>_<carrier> and PANICS if the value doesn't fit T. Widening / same-type
// casts where no loss is possible emit the plain C cast (no needless guard). Single-eval:
// the operand is emitted once. The carrier is picked by SOURCE signedness so it holds
// the source losslessly: signed -> int64_t carrier ("_s"); unsigned -> uint64_t ("_u").
// (C: TK_TEXPR_CAST branch.)
fn emit_cast(buf: []byte, prog: checker::TProgram, e: checker::TExpr, c: checker::TCast, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let inner = c.expr
    // Extract source/dest prims when both sides are primitive (else: a plain C cast).
    let dst_opt = match e.type     { checker::Prim as p => p.kind; _ => checker::PrimKind::Bool }
    let src_opt = match inner.type { checker::Prim as p => p.kind; _ => checker::PrimKind::Bool }
    let prim_both = match e.type {
        checker::Prim => match inner.type { checker::Prim => true; _ => false }
        _    => false
    }
    let dst = dst_opt
    let src = src_opt

    // (UTF-8 increment 1) `char to u32`/u64/i64 — DECODE the codepoint via the runtime
    // tk_char_to_u32, then a plain C cast to the (possibly wider/signed) target. The checker
    // already restricted the target; the decoded value always fits. (C: emit_expr CAST char branch.)
    match inner.type {
        checker::Char => {
            mut out = cb(buf, "((")
            out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }   // target rides the node's .type
            out = cb(out, ")tk_char_to_u32(")
            out = match emit_expr_ctx(out, prog, checker::Void { }, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            return cb(out, "))")
        }
        _ => {}
    }

    // float -> int: ALWAYS guarded (ruling §5: truncate toward zero; panic on
    // NaN/inf/out-of-range). Helper: tk_to_<dst>_from_<fsrc>. Single-eval.
    // (C1.7-CAST) When the cast node carries a position, wrap in a GNU statement-expression
    // that sets _tk_cast_loc_line/_tk_cast_loc_col before the call so tk_panic_cast prints it.
    if prim_both && cg_prim_is_float(src) && cg_prim_is_int(dst) {
        let dtag = match prim_int_tag(dst)   { str as t => t; error as err => return err }
        let fsrc = match prim_float_tag(src) { str as t => t; error as err => return err }
        if e.line != 0 {
            mut out = cb(buf, "({ _tk_cast_loc_line = ")
            out = cb(out, teko::u64_to_str(e.line to u64))
            out = cb(out, "; _tk_cast_loc_col = ")
            out = cb(out, teko::u64_to_str(e.col to u64))
            out = cb(out, "; tk_to_")
            out = cb(out, dtag)
            out = cb(out, "_from_")
            out = cb(out, fsrc)
            out = cb(out, "(")
            out = match emit_expr_ctx(out, prog, checker::Void { }, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            return cb(out, "); })")
        }
        mut out = cb(buf, "tk_to_")
        out = cb(out, dtag)
        out = cb(out, "_from_")
        out = cb(out, fsrc)
        out = cb(out, "(")
        out = match emit_expr_ctx(out, prog, checker::Void { }, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        return cb(out, ")")
    }
    // int -> int: range-checked IFF it may narrow. The carrier is picked by SOURCE
    // signedness so it holds the source losslessly: signed -> i128 carrier ("_s");
    // unsigned -> u128 carrier ("_u"). Single-eval.
    // (C1.7-CAST) Same positioned-wrapper pattern as float->int above.
    if prim_both && cg_prim_is_int(src) && cg_prim_is_int(dst) && cast_may_lose(src, dst) {
        let dtag = match prim_int_tag(dst) { str as t => t; error as err => return err }
        if e.line != 0 {
            mut out = cb(buf, "({ _tk_cast_loc_line = ")
            out = cb(out, teko::u64_to_str(e.line to u64))
            out = cb(out, "; _tk_cast_loc_col = ")
            out = cb(out, teko::u64_to_str(e.col to u64))
            out = cb(out, "; tk_to_")
            out = cb(out, dtag)
            if cg_prim_is_signed_int(src) { out = cb(out, "_s(") } else { out = cb(out, "_u(") }
            out = match emit_expr_ctx(out, prog, checker::Void { }, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            return cb(out, "); })")
        }
        mut out = cb(buf, "tk_to_")
        out = cb(out, dtag)
        if cg_prim_is_signed_int(src) { out = cb(out, "_s(") } else { out = cb(out, "_u(") }
        out = match emit_expr_ctx(out, prog, checker::Void { }, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        return cb(out, ")")
    }
    // Everything else (int->float widen, float->float narrow, widening int->int,
    // same-type) is a lossless-or-precision-allowed plain C cast.
    mut out = cb(buf, "((")
    out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }   // target rides the node's .type
    out = cb(out, ")(")
    out = match emit_expr_ctx(out, prog, checker::Void { }, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, "))")
}

// emit_list_empty — `teko::list::empty()`. If the call's OWN type is a concrete slice, emit the
// empty literal `(tk_slice_<elem>){ .ptr = 0, .len = 0 }`; else an honest error (it should have
// been wrapped to a slot type by emit_as). (C: the `empty` arm of the teko::list branch.)
fn emit_list_empty(buf: []byte, e: checker::TExpr) -> []byte | error {
    match e.type {
        checker::Slice as sl => match sl.element {
            checker::Void => error { message = "codegen: teko::list::empty() needs a known slice type from context (annotate the binding)" }
            _ => {
                mut o = cb(buf, "(")
                o = match cg_slice_typename(o, sl.element) { []byte as r => r; error as err => return err }
                cb(o, "){ .ptr = 0, .len = 0 }")
            }
        }
        _ => error { message = "codegen: teko::list::empty() needs a known slice type from context (annotate the binding)" }
    }
}

// get_push_elem — resolve the concrete element type of a push call, handling the
// case where type_assign overwrote the call's `.type` to the sentinel. Tries e.type
// first; falls back to args[0] (concretized base slice), then args[1] (item). (C: inline.)
fn get_push_elem(e: checker::TExpr, c: checker::TCall) -> checker::Type | error {
    match e.type {
        checker::Slice as sl => {
            match sl.element { checker::Void => { }; _ => return sl.element }
        }
        _ => return error { message = "codegen: teko::list::push result is not a slice (internal)" }
    }
    if c.args.len != 2 { return error { message = "codegen: teko::list::push result is not a concrete slice (internal)" } }
    match c.args[0].type {
        checker::Slice as base_sl => match base_sl.element { checker::Void => { }; _ => return base_sl.element }
        _ => { }
    }
    let it = c.args[1].type
    match it {
        checker::Slice as is_sl => match is_sl.element { checker::Void => return error { message = "codegen: teko::list::push result is not a concrete slice (internal)" }; _ => { } }
        _ => { }
    }
    it
}

// emit_list_push — `teko::list::push(base, item)`. The push result type (the node's `.type`) is
// `[]elem`. type_assign may overwrite the call's type to the sentinel when assigning push(xs,i)
// back to a sentinel-typed xs; get_push_elem recovers the element. Lower to an inline
// copy-append GNU stmt-expr. (C: the `push` arm.)
fn emit_list_push(buf: []byte, prog: checker::TProgram, e: checker::TExpr, c: checker::TCall, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let elem = match get_push_elem(e, c) { checker::Type as t => t; error as err => return err }
    let bN = $"_sb{buf.len}"
    let iN = $"_si{buf.len + 1}"
    let pN = $"_sp{buf.len + 2}"
    let lN = $"_sl{buf.len + 3}"
    // `teko::list::push(base, item)` → the AMORTIZED runtime grow (tk_slice_push): geometric growth
    // with an alias-safe live-tail cache so a linear `b = push(b, x)` chain is O(1) amortized (value
    // semantics preserved). Replaces the old malloc+copy-every-push (O(n) per push → O(n²) on a buffer).
    mut out = cb(buf, "({ ")
    out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, " "); out = cb(out, bN); out = cb(out, " = ")
    // Use emit_as so a sentinel empty() base-arg is lowered to the concrete empty literal.
    out = match emit_as(out, prog, checker::Slice { element = elem }, c.args[0], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "; ")
    out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, " "); out = cb(out, iN); out = cb(out, " = ")
    out = match emit_as(out, prog, elem, c.args[1], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "; uint64_t "); out = cb(out, lN); out = cb(out, "; ")
    out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, " *"); out = cb(out, pN); out = cb(out, " = (")
    out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, " *)tk_slice_push("); out = cb(out, bN); out = cb(out, ".ptr, "); out = cb(out, bN); out = cb(out, ".len, &"); out = cb(out, iN)
    out = cb(out, ", sizeof(")
    out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, "), &"); out = cb(out, lN); out = cb(out, "); (")
    out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, "){ .ptr = "); out = cb(out, pN); out = cb(out, ", .len = "); out = cb(out, lN); out = cb(out, " }; })")
    out
}

// emit_call — a TCall. The callee path -> a C identifier joined by "__" (single-segment
// in M0). Non-shadowable built-ins `print`/`println` (bare, or under `teko`) map to
// tk_print/tk_println. (C: TK_TEXPR_CALL branch.)
fn emit_call(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, e: checker::TExpr, c: checker::TCall, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let p = c.callee
    // teko::list::empty / push — the SLICE (collection) builtins, FIXED+COPY. `empty()`
    // (sentinel) is normally wrapped by emit_as into a concrete slot literal; reaching here
    // directly means a context-less empty (honest error). `push(base, item)` lowers to an
    // inline copy-append GNU stmt-expr (alloc len+1 via malloc/abort — M.1 — copy the old
    // elements, append a COPY of item, yield the fresh tk_slice_<elem>). (C: the teko::list branch.)
    if p.segments.len >= 2 && p.segments[0].name == "teko" &&
       p.segments[p.segments.len - 2].name == "list" {
        let llast = p.segments[p.segments.len - 1].name
        if llast == "empty" {
            return emit_list_empty(buf, e)
        }
        if llast == "push" {
            return emit_list_push(buf, prog, e, c, escaping, regions, fn_body, dctx)
        }
        return error { message = "codegen: this teko::list builtin not yet supported (only empty/push — fixed+copy)" }
    }
    // E2 (native): err_loc/err_typed adorn an error VALUE with diagnostic position/types.
    // `error` is now the full tk_error struct (E2-NATIVE), so these call tk_error_loc /
    // tk_error_types (teko_rt.h) which return a modified copy — native parity with the VM.
    if p.segments.len >= 1 {
        let pe = p.segments[p.segments.len - 1].name
        if pe == "err_loc" {
            // tk_error_loc(e, line, col) — returns a copy with line/col set.
            mut oe = cb(buf, "tk_error_loc(")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            oe = cb(oe, ", (uint32_t)(")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, c.args[1], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            oe = cb(oe, "), (uint32_t)(")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, c.args[2], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            return cb(oe, "))")
        }
        if pe == "err_typed" {
            // tk_error_types(e, expected, actual) — returns a copy with expected/actual set.
            mut oe = cb(buf, "tk_error_types(")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            oe = cb(oe, ", ")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, c.args[1], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            oe = cb(oe, ", ")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, c.args[2], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            return cb(oe, ")")
        }
        // Phase 3 — `str`/`str_of_bytes` (([]byte) -> str). A []byte lowers to the generated struct
        // tk_slice_byte {uint8_t*,uint64_t}, a DISTINCT C type from tk_str — BRIDGE the slice to a
        // tk_str at the call site (single-eval via a temp), then tk_str_of_bytes COPIES it. Mirrors codegen.c.
        let addr = (p.segments.len == 1) || (p.segments[0].name == "teko")
        if addr && (pe == "str" || pe == "str_of_bytes") && c.args.len == 1 {
            let sb = $"_sb{buf.len}"
            mut o = cb(buf, "({ ")
            o = match emit_type(o, c.args[0].type) { []byte as r => r; error as err => return err }
            o = cb(o, " ")
            o = cb(o, sb)
            o = cb(o, " = ")
            o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            o = cb(o, "; tk_str_of_bytes((tk_str){ (const tk_byte *)")
            o = cb(o, sb)
            o = cb(o, ".ptr, ")
            o = cb(o, sb)
            return cb(o, ".len }); })")
        }
        // `concat(params pieces: []str) -> str` (== teko::string::concat, the LEGISLATED "+"
        // never concatenates" primitive) — after the checker's params desugar, the call always
        // arrives here with EXACTLY ONE arg (a []str, whether packed from N pieces or passed
        // through). BRIDGE: fold the tk_slice_str via the existing 2-arg tk_str_concat primitive
        // in an inline C loop (avoids needing a slice-taking runtime C signature — teko_rt.h
        // can't reference tk_slice_str, a per-program generated typedef). Mirrors codegen.c.
        if addr && pe == "concat" && c.args.len == 1 {
            let cs = $"_cs{buf.len}"
            let ci = $"_ci{buf.len}"
            let ca = $"_ca{buf.len}"
            mut o = cb(buf, "({ ")
            o = match emit_type(o, c.args[0].type) { []byte as r => r; error as err => return err }
            o = cb(o, $" {cs} = ")
            o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            o = cb(o, $"; tk_str {ca} = (tk_str){{0,0}}; for (uint64_t {ci} = 0; {ci} < {cs}.len; {ci}++) {{ {ca} = tk_str_concat({ca}, {cs}.ptr[{ci}]); }} {ca}; }})")
            return o
        }
    }
    // Host-FFI bottoms with a VARIANT/OPTIONAL or argv return: lifted from a fixed-ABI runtime
    // result into the program's result type (the runtime can't name the generated sum/optional
    // structs — teko_rt.h). Intercepted BY NAME (these names are not user-shadowed: the only
    // definitions are pure FFI forwarders), ahead of the plain map. (C: emit_host_ffi dispatch.)
    if p.segments.len >= 1 {
        let l = p.segments[p.segments.len - 1].name
        let addr2 = (p.segments.len == 1) || (p.segments[0].name == "teko")
        if addr2 {
            if l == "read_file"     { return emit_host_ffi(buf, prog, e, c, "sres",   "tk_rt_read_file", escaping, regions, fn_body, dctx) }
            if l == "var"           { return emit_host_ffi(buf, prog, e, c, "sres",   "tk_rt_getenv", escaping, regions, fn_body, dctx) }
            if l == "write_file"       { return emit_host_ffi(buf, prog, e, c, "ures",           "tk_rt_write_file", escaping, regions, fn_body, dctx) }
            if l == "write_file_bytes" { return emit_host_ffi(buf, prog, e, c, "ures_byteslice", "tk_rt_write_file_bytes", escaping, regions, fn_body, dctx) }   // C7.12: []byte → file
            if l == "chdir"         { return emit_host_ffi(buf, prog, e, c, "ures",   "tk_rt_chdir", escaping, regions, fn_body, dctx) }
            if l == "mkdir"         { return emit_host_ffi(buf, prog, e, c, "ures",   "tk_rt_mkdir", escaping, regions, fn_body, dctx) }
            if l == "cwd"           { return emit_host_ffi(buf, prog, e, c, "sres",   "tk_rt_getcwd", escaping, regions, fn_body, dctx) }
            if l == "set_var"       { return emit_host_ffi(buf, prog, e, c, "ures",   "tk_rt_setenv", escaping, regions, fn_body, dctx) }
            if l == "list_dir"      { return emit_host_ffi(buf, prog, e, c, "slres",  "tk_rt_list_dir", escaping, regions, fn_body, dctx) }
            if l == "last_index_of" { return emit_host_ffi(buf, prog, e, c, "u64res", "tk_rt_last_index_of", escaping, regions, fn_body, dctx) }
            if l == "args"          { return emit_host_ffi(buf, prog, e, c, "args",   "tk_rt_args", escaping, regions, fn_body, dctx) }
            if l == "run"           { return emit_host_ffi(buf, prog, e, c, "run",    "tk_rt_run", escaping, regions, fn_body, dctx) }
            if l == "bytes_from_ptr" { return emit_host_ffi(buf, prog, e, c, "bytes", "tk_bytes_from_ptr", escaping, regions, fn_body, dctx) }   // (C7.1a) ptr+len -> []byte (slice-lift)
            if l == "str_from_utf8" { return emit_host_ffi(buf, prog, e, c, "sres_byteslice", "tk_rt_str_from_utf8", escaping, regions, fn_body, dctx) }   // ROUND 0: ([]byte) -> str | error
        }
    }
    // Non-shadowable built-ins: `print`/`println`, either bare or under `teko`.
    mut builtin = ""
    mut has_builtin = false
    if p.segments.len >= 1 {
        let last = p.segments[p.segments.len - 1].name
        let addressable = (p.segments.len == 1) || (p.segments[0].name == "teko")
        if addressable {
            if      last == "print"   { builtin = "tk_print";   has_builtin = true }
            else if last == "println" { builtin = "tk_println"; has_builtin = true }
            else if last == "panic"   { builtin = "tk_panic_str"; has_builtin = true }   // panic(str) — diverges (no `never` type)
            else if last == "exit"    { builtin = "tk_exit";      has_builtin = true }   // exit(<int>) — diverges
            // host output FFI bottoms (scope.c) — (str) -> void. write=stdout; e*=stderr.
            else if last == "write"    { builtin = "tk_write";       has_builtin = true }   // (str) -> void (stdout)
            else if last == "ewrite"   { builtin = "tk_ewrite";      has_builtin = true }   // (str) -> void (stderr)
            else if last == "eprint"   { builtin = "tk_eprint";      has_builtin = true }   // (str) -> void (stderr)
            else if last == "eprintln" { builtin = "tk_eprintln";    has_builtin = true }   // (str) -> void (stderr + '\n')
            else if last == "parse"    { builtin = "tk_float_parse"; has_builtin = true }   // teko::float::parse(str) -> f64
            // arithmetic FFI over the i128 carrier (sign-aware) + float bit-patterns. (`div`/`rem`
            // mangle to tk_* so they never clash with libc's div/rem.)
            else if last == "div"          { builtin = "tk_div";          has_builtin = true }   // (i128,i128,bool) -> i128
            else if last == "rem"          { builtin = "tk_rem";          has_builtin = true }   // (i128,i128,bool) -> i128
            else if last == "fdiv"         { builtin = "tk_fdiv";         has_builtin = true }   // (f64,f64) -> f64
            else if last == "int_to_float" { builtin = "tk_int_to_float"; has_builtin = true }   // (i128,bool) -> f64
            else if last == "f64_bits"     { builtin = "tk_f64_bits";     has_builtin = true }   // (f64) -> u64
            else if last == "f64_from_bits" { builtin = "tk_f64_from_bits"; has_builtin = true } // (u64) -> f64
            // D3 — test-coverage sink (host side-channel): the VM marks executed production fns.
            else if last == "cov_reset"    { builtin = "tk_cov_reset";    has_builtin = true }   // () -> void
            else if last == "cov_mark"     { builtin = "tk_cov_mark";     has_builtin = true }   // (u64) -> void
            else if last == "cov_distinct" { builtin = "tk_cov_distinct"; has_builtin = true }   // () -> u64
            else if last == "cov_is_marked"  { builtin = "tk_cov_is_marked";  has_builtin = true }   // (u64) -> bool
            // D3-branch — branch-coverage sink (only records when ON; off by default).
            else if last == "cov_branches_on" { builtin = "tk_cov_branches_on"; has_builtin = true }   // (bool) -> void
            else if last == "cov_branch_reset"{ builtin = "tk_cov_branch_reset";has_builtin = true }   // () -> void
            else if last == "cov_enter"       { builtin = "tk_cov_enter";       has_builtin = true }   // (u64) -> void
            else if last == "cov_leave"       { builtin = "tk_cov_leave";       has_builtin = true }   // () -> void
            else if last == "cov_branch"      { builtin = "tk_cov_branch";      has_builtin = true }   // (u32,u32,u64) -> void
            else if last == "cov_branch_hit"  { builtin = "tk_cov_branch_hit";  has_builtin = true }   // (u64,u32,u32,u64) -> bool
            else if last == "cov_lines_on"    { builtin = "tk_cov_lines_on";    has_builtin = true }   // (bool) -> void
            else if last == "cov_line_reset"  { builtin = "tk_cov_line_reset";  has_builtin = true }   // () -> void
            else if last == "cov_line"        { builtin = "tk_cov_line";        has_builtin = true }   // (u32) -> void
            else if last == "cov_line_hit"    { builtin = "tk_cov_line_hit";    has_builtin = true }   // (u64,u32) -> bool
            // diverging runtime panic helpers (the corpus calls these by bare name)
            else if last == "panic_div0"     { builtin = "tk_panic_div0";     has_builtin = true }
            else if last == "panic_oob"      { builtin = "tk_panic_oob";      has_builtin = true }
            else if last == "panic_cast"     { builtin = "tk_panic_cast";     has_builtin = true }
            else if last == "panic_overflow" { builtin = "tk_panic_overflow"; has_builtin = true }
            // str/byte STDLIB surface (Phase 3) — the unqualified helpers the corpus calls, recognized
            // by the checker and lowered to their tk_ runtime twins (a fresh tk_str; OOM-panics, M.1).
            // (`str`/`str_of_bytes` are bridged specially ABOVE — a []byte lowers to tk_slice_byte, a
            // DISTINCT C type from tk_str. In a CALL `str` is this builtin, not the str TYPE.)
            else if last == "one_byte"     { builtin = "tk_one_byte";     has_builtin = true }   // (byte) -> str
            else if last == "str_concat"   { builtin = "tk_str_concat";   has_builtin = true }   // (str, str) -> str — internal 2-arg primitive, unchanged
            // "concat"/"concat3" are NOT here — `concat3` REMOVED (2026-07-01); the PUBLIC
            // variadic `concat(params pieces: []str)` (== `teko::string::concat`, the LEGISLATED
            // "+` never concatenates" primitive — TEKO_LEGISLATION.md) is bridged specially
            // ABOVE (folds a packed []str slice via tk_str_concat), since a builtin-dispatch
            // name-substitution can't accept a slice argument directly.
            else if last == "slice"        { builtin = "tk_str_slice";    has_builtin = true }   // str::slice(str,u64,u64) -> str
            else if last == "slice_to"     { builtin = "tk_str_slice_to"; has_builtin = true }   // (str,u64) -> str
            else if last == "slice_from"   { builtin = "tk_str_slice_from"; has_builtin = true } // (str,u64) -> str
            else if last == "len"          { builtin = "tk_str_len";      has_builtin = true }   // (str) -> u64
            else if last == "bytes_of_str"      { builtin = "tk_bytes_of_str";    has_builtin = true }   // (str) -> []byte
            else if last == "chars"             { builtin = "tk_str_chars";       has_builtin = true }   // (str) -> []char
            else if last == "len_chars"         { builtin = "tk_str_len_chars";   has_builtin = true }   // (str) -> i64
            // ROUND 0: UTF-8 codepoint operations
            else if last == "char_at"           { builtin = "tk_char_at";         has_builtin = true }   // (str, i64) -> char
            else if last == "str_slice_chars"   { builtin = "tk_str_slice_chars"; has_builtin = true }   // (str, i64, i64) -> str
            // Guard with call_ns.len==0 so lexer.tks private is_alpha/is_digit (which take
            // byte not char) are NOT lowered to the tk_ builtin (mirrors codegen.c guard).
            else if last == "is_alpha" && c.call_ns.len == 0   { builtin = "tk_is_alpha";    has_builtin = true }   // (char) -> bool
            else if last == "is_digit" && c.call_ns.len == 0   { builtin = "tk_is_digit";    has_builtin = true }   // (char) -> bool
            else if last == "is_space" && c.call_ns.len == 0   { builtin = "tk_is_space";    has_builtin = true }   // (char) -> bool
            else if last == "to_lower" && c.call_ns.len == 0   { builtin = "tk_to_lower";    has_builtin = true }   // (char) -> char
            else if last == "to_upper" && c.call_ns.len == 0   { builtin = "tk_to_upper";    has_builtin = true }   // (char) -> char
            else if last == "ends_with"         { builtin = "tk_str_ends_with";   has_builtin = true }   // (str,str) -> bool
            else if last == "contains"     { builtin = "tk_str_contains"; has_builtin = true }   // (str,str) -> bool
            // (last_index_of returns u64|error → lifted by emit_host_ffi above, not here)
            else if last == "i64_to_str"   { builtin = "tk_i64_to_str";   has_builtin = true }   // (i64) -> str
            else if last == "u64_to_str"   { builtin = "tk_u64_to_str";   has_builtin = true }   // (u64) -> str
            else if last == "ftoa"         { builtin = "tk_ftoa";         has_builtin = true }   // (f64) -> str
            else if last == "fmt_f"        { builtin = "tk_fmt_f";        has_builtin = true }   // (f64, i64) -> str
            else if last == "fmt_e"        { builtin = "tk_fmt_e";        has_builtin = true }   // (f64, i64) -> str
            else if last == "fmt_g"        { builtin = "tk_fmt_g";        has_builtin = true }   // (f64, i64) -> str
            else if last == "fmt_p"        { builtin = "tk_fmt_p";        has_builtin = true }   // (f64, i64) -> str
            else if last == "fmt_n_f"      { builtin = "tk_fmt_n_f";      has_builtin = true }   // (f64, i64) -> str
            else if last == "fmt_d"        { builtin = "tk_fmt_d";        has_builtin = true }   // (i64, i64) -> str
            else if last == "fmt_x_upper"  { builtin = "tk_fmt_x_upper";  has_builtin = true }   // (u64) -> str
            else if last == "fmt_x_lower"  { builtin = "tk_fmt_x_lower";  has_builtin = true }   // (u64) -> str
            else if last == "fmt_b"        { builtin = "tk_fmt_b";        has_builtin = true }   // (u64) -> str
            else if last == "fmt_n_i"      { builtin = "tk_fmt_n_i";      has_builtin = true }   // (i64) -> str
            else if last == "fmt_dyn_f64"  { builtin = "tk_fmt_dyn_f64";  has_builtin = true }   // (f64, str) -> str
            else if last == "fmt_dyn_i64"  { builtin = "tk_fmt_dyn_i64";  has_builtin = true }   // (i64, str) -> str
            else if last == "fmt_dyn_u64"  { builtin = "tk_fmt_dyn_u64";  has_builtin = true }   // (u64, str) -> str
            else if last == "f64_g17"      { builtin = "tk_f64_g17";      has_builtin = true }   // (f64) -> str (host float renderer)
            // (C7.1a) marshalling primitives — teko::mem: move aggregates across the FFI boundary.
            else if last == "as_ptr"        { builtin = "tk_as_ptr";        has_builtin = true }   // (str) -> ptr (raw bytes; borrows, pair with `.len`)
            else if last == "as_cstr"       { builtin = "tk_cstr_dup";      has_builtin = true }   // (str) -> ptr (fresh NUL-terminated copy)
            else if last == "str_from_cstr" { builtin = "tk_str_from_cstr"; has_builtin = true }   // (ptr) -> str (copy a C string back)
            else if last == "os"            { builtin = "tk_rt_os";         has_builtin = true }   // () -> str (host OS — C7.1f)
            // (err_loc/err_typed handled at the top of this fn — they call tk_error_loc /
            //  tk_error_types on the full tk_error struct — E2-NATIVE. Mirrors codegen.c.)
        }
    }
    mut out = buf
    // Resolve the callee FIRST (when a namespaced user call) so we know its C name AND whether it
    // is an `extern` (C7.1a): an extern lowers to its raw C symbol, with NO namespace mangling.
    let cf_res = if c.call_ns.len != 0 {
        cg_find_function(prog, c.call_ns, p.segments[p.segments.len - 1].name)
    } else { error { message = "codegen: no resolved namespace" } }
    if has_builtin {
        out = cb(out, builtin)
    } else if c.call_ns.len != 0 {
        mut is_extern_call = false
        mut ext_symbol = ""
        match cf_res {
            checker::TFunction as cf => { if cf.is_extern { is_extern_call = true; ext_symbol = cf.c_symbol } }
            error => { }
        }
        if is_extern_call {
            out = cb(out, ext_symbol)   // C7.1a: the raw foreign C symbol
        } else {
            // (#49) a resolved USER call -> the SAME namespace-mangled C name emit_function_sig gives
            // the definition (teko::checker::type_eq -> teko__checker__type_eq), so def + call agree
            // and same-named functions across namespaces never collide.
            out = cb_fn_name(out, c.call_ns, p.segments[p.segments.len - 1].name)
        }
    } else if c.is_closure_call {
        // (W10) call THROUGH a tk_closure VALUE — a single-eval statement-expression that dispatches on
        // `env` (no-env ABI for a named-fn/non-capturing closure; env-first ABI for a capturing one).
        return emit_closure_call(out, prog, ret_type, c, escaping, regions, fn_body, dctx)
    } else {
        // No resolved namespace (a builtin, or a name not carried) -> the bare
        // (keyword-escaped) last segment.
        out = cb_ident(out, p.segments[p.segments.len - 1].name)
    }
    // A resolved USER call: wrap each arg into its parameter type (emit_as) so a bare case value
    // (e.g. `Prim{…}` passed where a `Type` variant is expected) lands in the variant rep — the arg
    // keeps its case type (type_call no longer clobbers widened args). For a NAMED param only
    // (variant/struct/enum); other param shapes emit plainly, as before. When there's no resolved
    // function (builtins / call_ns empty), emit all args plainly.
    out = cb(out, "(")
    mut j = 0
    loop {
        if j >= c.args.len { break }
        if j > 0 { out = cb(out, ", ") }
        mut wrapped = false
        match cf_res {
            checker::TFunction as cf => {
                if j < cf.params.len {
                    match cf.params[j].type_ann {
                        parser::NamedType as nt => {
                            let pn = nt.path.segments[nt.path.segments.len - 1].name
                            // (MEM-1b-ii) a `Ref<T>` param: AUTO-REF a non-reference arg of the pointed
                            // type (`&x`); forward an already-reference arg plainly. NOT emit_as_r (Ref
                            // is not a user variant). `&` takes the address of the `mut` lvalue (the
                            // checker proved it's a `mut` variable).
                            if pn == "Ref" {
                                let arg_is_ref = match c.args[j].type { checker::Reference => true; _ => false }
                                if !arg_is_ref { out = cb(out, "&") }
                                out = match emit_expr_ctx(out, prog, ret_type, c.args[j], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            } else {
                                out = match emit_as_r(out, prog, ret_type, checker::Named { name = pn }, c.args[j], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            }
                            wrapped = true
                        }
                        // A `T?` param: present-wrap a bare `T` arg (uniform with field/return). The
                        // checker kept the arg's NARROW type for a bare→optional widen, so emit_as wraps
                        // it; an already-optional / null arg passes through emit_as unchanged. The inner
                        // expected type is NAMED from the param's inner type_ann (so a NAMED inner mangles
                        // to the param's opt struct); any other inner shape (prim, …) uses the arg's own
                        // type, which mangles identically to the param's inner (exact-match widen).
                        parser::OptionalType as ot => {
                            let inner_t = match ot.inner {
                                parser::NamedType as int_nt => checker::Named { name = int_nt.path.segments[int_nt.path.segments.len - 1].name }
                                _ => c.args[j].type
                            }
                            out = match emit_as_r(out, prog, ret_type, checker::Optional { inner = inner_t }, c.args[j], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            wrapped = true
                        }
                        _ => { }
                    }
                }
            }
            error => { }
        }
        if !wrapped {
            out = match emit_expr_ctx(out, prog, ret_type, c.args[j], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        }
        j++
    }
    cb(out, ")")
}

// emit_field_access — a TFieldAccess -> `(recv.field)`. (C: TK_TEXPR_FIELD_ACCESS branch.)
// W5-idx — `.len`: a `str` lowers to the runtime tk_str's `.len` member (`(recv).len`); a
// slice's `.len` reads its tk_slice_<elem> `.len` member (same {ptr,len} shape as tk_str -> u64).
fn emit_field_access(buf: []byte, prog: checker::TProgram, fa: checker::TFieldAccess, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let is_slice = match fa.receiver.type { checker::Slice => true; _ => false }
    if is_slice && fa.field == "len" {
        mut o = cb(buf, "(")   // `.len` of a tk_slice_<elem> — same {ptr,len} shape as tk_str -> u64
        o = match emit_expr_ctx(o, prog, checker::Void { }, fa.receiver, escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        return cb(o, ".len)")
    }
    // E2 (native): error values are now the full tk_error struct (E2-NATIVE), so
    // field access reads the real struct fields — native parity with the VM. Mirrors codegen.c.
    let is_error = match fa.receiver.type { checker::Error => true; _ => false }
    if is_error {
        mut oe = cb(buf, "((")
        oe = match emit_expr_ctx(oe, prog, checker::Void { }, fa.receiver, escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        oe = cb(oe, ").")
        oe = cb_str(oe, fa.field)
        return cb(oe, ")")
    }
    // (MEM-1b-ii) `Ref<T>.value` deref — the reference lowers to a bare `<T> *`, so `.value` reads
    // `(*recv)`. (The receiver `r` is itself the pointer; `.value` is its dereference.)
    let is_ref = match fa.receiver.type { checker::Reference => true; _ => false }
    if is_ref && fa.field == "value" {
        mut or = cb(buf, "(*(")
        or = match emit_expr_ctx(or, prog, checker::Void { }, fa.receiver, escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        return cb(or, "))")
    }
    // auto-box: reading a recursive back-edge field derefs the heap pointer.
    let fa_boxed = match fa.receiver.type {
        checker::Named as nm => match cg_find_struct_field_type(prog, nm.name, fa.field) {
            parser::TypeExpr as fte => cg_field_boxed(prog, nm.name, fte)
            null => false
        }
        _ => false
    }
    mut out = cb(buf, "(")
    if fa_boxed { out = cb(out, "*") }
    out = cb(out, "(")
    out = match emit_expr_ctx(out, prog, checker::Void { }, fa.receiver, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, ".")
    out = cb_str(out, fa.field)
    cb(out, "))")
}

// emit_safe_field_access — `recv?.field` (REBOOT §203). ({ <optTy> _oN = (recv); _oN.present
//   ? (<resTy>){ .present = true, .value = _oN.value.<field> } : (<resTy>){ .present = false }; })
// The node's `.type` is the result optional `(field)?`; the receiver type is `T?`. (C: TK_TEXPR_SAFE_FIELD_ACCESS.)
fn emit_safe_field_access(buf: []byte, prog: checker::TProgram, e: checker::TExpr, sfa: checker::TSafeFieldAccess, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let tmp = fresh_named("_o", buf.len to i64)
    mut out = cb(buf, "({ ")
    out = match emit_type(out, sfa.receiver.type) { []byte as o => o; error as err => return err }
    out = cb(out, " "); out = cb(out, tmp); out = cb(out, " = (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, sfa.receiver, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "); "); out = cb(out, tmp); out = cb(out, ".present ? (")
    out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }
    out = cb(out, "){ .present = true, .value = "); out = cb(out, tmp); out = cb(out, ".value.")
    out = cb_str(out, sfa.field)
    out = cb(out, " } : (")
    out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }
    out = cb(out, "){ .present = false }; })")
    out
}

// emit_coalesce — `a ?? b` (REBOOT §203). ({ <optTy> _cN = (a); _cN.present ? <a.value as result>
//   : <b as result>; }). Short-circuits b (only evaluated on NONE). The result type (node `.type`)
// is `T` (unwrap) or `T?` (b itself optional); both arms wrapped to it. (C: TK_TEXPR_COALESCE.)
// a diverging call (the global `panic`/`exit`) — unqualified; mirrors the checker's texpr_diverges.
// In a VALUE position it lowers to `(<call>, (T){0})`: the call is _Noreturn (tk_panic_str/tk_exit),
// so the zero-of-T is unreachable but keeps the C `?:`/expr well-typed.
fn cg_expr_diverges(e: checker::TExpr) -> bool {
    match e.kind {
        checker::TCall as c => c.callee.segments.len == 1 && (c.callee.segments[0].name == "panic" || c.callee.segments[0].name == "exit")
        _ => false
    }
}

fn emit_coalesce(buf: []byte, prog: checker::TProgram, e: checker::TExpr, co: checker::TCoalesce, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let tmp = fresh_named("_c", buf.len to i64)
    mut out = cb(buf, "({ ")
    out = match emit_type(out, co.left.type) { []byte as o => o; error as err => return err }
    out = cb(out, " "); out = cb(out, tmp); out = cb(out, " = (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, co.left, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "); "); out = cb(out, tmp); out = cb(out, ".present ? ")
    // a's inner `_cN.value` into the result: plain if result is `T`, PRESENT-wrapped if `T?`.
    match e.type {
        checker::Optional as ropt => {
            match ropt.inner {
                checker::Void => { out = cb(out, tmp); out = cb(out, ".value") }
                _ => {
                    out = cb(out, "(")
                    out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }
                    out = cb(out, "){ .present = true, .value = "); out = cb(out, tmp); out = cb(out, ".value }")
                }
            }
        }
        _ => { out = cb(out, tmp); out = cb(out, ".value") }
    }
    out = cb(out, " : ")
    if cg_expr_diverges(co.right) {
        // a diverging fallback (panic/exit) yields no value — emit the _Noreturn call then a
        // zero-of-result so the C `?:` type-checks (the zero is unreachable).
        out = cb(out, "(")
        out = match emit_expr_ctx(out, prog, checker::Void { }, co.right, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        out = cb(out, ", (")
        out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }
        out = cb(out, "){0})")
    } else {
        out = match emit_as(out, prog, e.type, co.right, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    }
    out = cb(out, "; })")
    out
}

// emit_index — W5-idx `recv[index]`. A `str` receiver lowers to a BOUNDS-CHECKED byte access
// as a GNU statement-expression (single-eval of recv + idx, then the guard):
//   ({ tk_str _sN = <recv>; uint64_t _iN = <idx>; _iN < _sN.len ? _sN.ptr[_iN]
//                                              : (tk_panic_oob(), (tk_byte)0); })
// tk_panic_oob is declared in teko_rt.h (the generated TU's runtime header) — an out-of-bounds
// index PANICS with the SAME message as the VM's eval_index (M.1). A slice receiver uses the
// SAME bounds-checked shape, with the element C type substituted for tk_byte and reading
// `(recv).ptr[i]` with a `(tk_panic_oob(), (<elem>){0})` fallback. (C: the TK_TEXPR_INDEX branch.)
fn emit_index(buf: []byte, prog: checker::TProgram, e: checker::TExpr, ix: checker::TIndex, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    // slice subscript: the SAME bounds-checked stmt-expr as str, with the element type
    // substituted for tk_byte and a 0-of-element fallback after the panic.
    match ix.receiver.type {
        checker::Slice as srt => {
            let elem = match srt.element {
                checker::Void => return error { message = "codegen: indexing an untyped empty slice (internal: checker should reject)" }
                _ => srt.element
            }
            let lstmp = $"_ls{buf.len}"
            let litmp = $"_li{buf.len + 1}"
            mut so = cb(buf, "({ ")
            so = match emit_type(so, elem) { []byte as o => o; error as err => return err }
            so = cb(so, " const *")
            so = cb(so, lstmp)
            so = cb(so, " = (")
            so = match emit_expr_ctx(so, prog, checker::Void { }, ix.receiver, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            so = cb(so, ").ptr; uint64_t ")
            so = cb(so, litmp)
            so = cb(so, " = (uint64_t)(")
            so = match emit_expr_ctx(so, prog, checker::Void { }, ix.index, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            so = cb(so, "); ")
            so = cb(so, litmp)
            so = cb(so, " < (")
            so = match emit_expr_ctx(so, prog, checker::Void { }, ix.receiver, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            so = cb(so, ").len ? ")
            so = cb(so, lstmp)
            so = cb(so, "[")
            so = cb(so, litmp)
            so = cb(so, "]")
            so = cb(so, " : (tk_panic_oob_at(")                      // (C1.7) positioned OOB — node line:col
            so = cb(so, teko::u64_to_str(e.line to u64))
            so = cb(so, ", ")
            so = cb(so, teko::u64_to_str(e.col to u64))
            so = cb(so, "), (")
            so = match emit_type(so, elem) { []byte as o => o; error as err => return err }
            return cb(so, "){0}); })")
        }
        checker::Str   => { }
        _              => return error { message = "codegen: indexing a non-string value not yet supported" }
    }
    // Unique temp names (the buffer length is the functional uniquifier — see emit_if_value).
    let stmp = $"_s{buf.len}"
    let itmp = $"_i{buf.len + 1}"   // +1 so it differs from stmp
    mut out = cb(buf, "({ tk_str ")
    out = cb(out, stmp)
    out = cb(out, " = ")
    out = match emit_expr_ctx(out, prog, checker::Void { }, ix.receiver, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "; uint64_t ")
    out = cb(out, itmp)
    out = cb(out, " = (uint64_t)(")
    out = match emit_expr_ctx(out, prog, checker::Void { }, ix.index, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "); ")
    out = cb(out, itmp)
    out = cb(out, " < ")
    out = cb(out, stmp)
    out = cb(out, ".len ? ")
    out = cb(out, stmp)
    out = cb(out, ".ptr[")
    out = cb(out, itmp)
    out = cb(out, "]")
    mut z = cb(out, " : (tk_panic_oob_at(")                          // (C1.7) positioned OOB — node line:col
    z = cb(z, teko::u64_to_str(e.line to u64))
    z = cb(z, ", ")
    z = cb(z, teko::u64_to_str(e.col to u64))
    cb(z, "), (tk_byte)0); })")
}

// emit_in — Phase 2: `<lhs> in [ e0, e1, … ]` -> bool. The lhs is EVALUATED ONCE (single-eval),
// bound to a temp via a GNU statement-expression, then compared to each element with `==` OR'd
// together (true iff the lhs equals any element). The node's `.type` is bool.
//   ({ <CtypeOfLhs> _invN = <lhs>; (_invN == <e0>) || (_invN == <e1>) || …; })
// The temp `_inv<buf.len>` uses the buffer length as the functional uniquifier (see emit_index).
// The EMPTY set `x in []` still EVALUATES the lhs once (single-eval), then yields false — so a
// side-effecting lhs runs identically in the VM (which evaluates the lhs before its zero-iteration
// loop). VM==native even for `[]`. (C: the TK_TEXPR_IN branch of emit_expr.)
fn emit_in(buf: []byte, prog: checker::TProgram, ie: checker::TInExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    if ie.elems.len == 0 {
        mut z = cb(buf, "({ (void)(")
        z = match emit_expr_ctx(z, prog, checker::Void { }, ie.lhs, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        return cb(z, "); 0; })")
    }
    let tmp = $"_inv{buf.len}"
    mut out = cb(buf, "({ ")
    out = match emit_type(out, ie.lhs.type) { []byte as o => o; error as err => return err }   // the lhs's resolved C type
    out = cb(out, " ")
    out = cb(out, tmp)
    out = cb(out, " = ")
    out = match emit_expr_ctx(out, prog, checker::Void { }, ie.lhs, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "; ")
    mut i = 0
    loop {
        if i >= ie.elems.len { break }
        if i > 0 { out = cb(out, " || ") }
        out = cb(out, "(")
        out = cb(out, tmp)
        out = cb(out, " == ")
        out = match emit_expr_ctx(out, prog, checker::Void { }, ie.elems[i], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        out = cb(out, ")")
        i++
    }
    cb(out, "; })")
}

// emit_array_lit — `[ e0, e1, … ]` (Increment B+) -> a `tk_slice_<elem>` value. Empty `[]` is the
// concrete empty literal. Plain elements: allocate N slots, fill by index via emit_as.
// Spread elements (`..xs`): when present, build via tk_slice_push into a dynamic accumulator
// (mirrors the slow path in the C twin codegen.c — see its TK_TEXPR_ARRAY / has_spread branch).
fn emit_array_lit(buf: []byte, prog: checker::TProgram, e: checker::TExpr, a: checker::TArrayLit, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let elem = match e.type { checker::Slice as s => s.element; _ => return error { message = "codegen: array literal is not a slice type (internal)" } }
    if a.elements.len == 0 {
        mut z = cb(buf, "(")
        z = match cg_slice_typename(z, elem) { []byte as o => o; error as err => return err }
        return cb(z, "){ .ptr = 0, .len = 0 }")
    }
    // detect any spread element
    mut has_spread = false
    mut si: u64 = 0
    loop {
        if si >= a.elements.len { break }
        if a.elements[si].is_spread { has_spread = true; break }
        si++
    }
    if !has_spread {
        // fast path: all plain elements — allocate once, fill by index
        let pN = $"_arr{buf.len}"
        mut out = cb(buf, "({ ")
        out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
        out = cb(out, " *"); out = cb(out, pN); out = cb(out, " = malloc(")
        out = cb_u128_digits(out, a.elements.len to u128)
        out = cb(out, " * sizeof(")
        out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
        out = cb(out, ")); if (!"); out = cb(out, pN); out = cb(out, ") abort(); ")
        mut i: u64 = 0
        loop {
            if i >= a.elements.len { break }
            out = cb(out, pN); out = cb(out, "["); out = cb_u128_digits(out, i to u128); out = cb(out, "] = ")
            out = match emit_as(out, prog, elem, a.elements[i].expr, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, "; ")
            i++
        }
        out = cb(out, "(")
        out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
        out = cb(out, "){ .ptr = "); out = cb(out, pN); out = cb(out, ", .len = ")
        out = cb_u128_digits(out, a.elements.len to u128)
        return cb(out, " }; })")
    }
    // slow path: has spread — build incrementally via tk_slice_push
    // acc = accumulator slice; cap = capacity passed to tk_slice_push by reference
    let tag = buf.len
    let accN = $"_sarr{tag}"
    let capN = $"_scap{tag}"
    mut out = cb(buf, "({ ")
    out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
    out = cb(out, " "); out = cb(out, accN); out = cb(out, " = { .ptr = 0, .len = 0 }; uint64_t "); out = cb(out, capN); out = cb(out, " = 0; ")
    mut i: u64 = 0
    loop {
        if i >= a.elements.len { break }
        let ae = a.elements[i]
        let spN = $"_spp{tag}_{i}"
        if ae.is_spread {
            // spread: evaluate sub-slice, loop and push each item
            let subN = $"_ssub{tag}_{i}"
            let jN   = $"_sj{tag}_{i}"
            out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, " "); out = cb(out, subN); out = cb(out, " = ")
            out = match emit_expr_ctx(out, prog, checker::Void { }, ae.expr, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, "; ")
            out = cb(out, "for (uint64_t "); out = cb(out, jN); out = cb(out, " = 0; ")
            out = cb(out, jN); out = cb(out, " < "); out = cb(out, subN); out = cb(out, ".len; ")
            out = cb(out, jN); out = cb(out, "++) { ")
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, " *"); out = cb(out, spN); out = cb(out, " = (")
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, "*)tk_slice_push("); out = cb(out, accN); out = cb(out, ".ptr, "); out = cb(out, accN); out = cb(out, ".len, &")
            out = cb(out, subN); out = cb(out, ".ptr["); out = cb(out, jN); out = cb(out, "], sizeof(")
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, "), &"); out = cb(out, capN); out = cb(out, "); if (!"); out = cb(out, spN); out = cb(out, ") abort(); ")
            out = cb(out, accN); out = cb(out, " = (")
            out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, "){ .ptr = "); out = cb(out, spN); out = cb(out, ", .len = "); out = cb(out, capN); out = cb(out, " }; } ")
        } else {
            // plain element: evaluate into a temp, push
            let tmpN = $"_sitm{tag}_{i}"
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, " "); out = cb(out, tmpN); out = cb(out, " = ")
            out = match emit_as(out, prog, elem, ae.expr, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, "; ")
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, " *"); out = cb(out, spN); out = cb(out, " = (")
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, "*)tk_slice_push("); out = cb(out, accN); out = cb(out, ".ptr, "); out = cb(out, accN); out = cb(out, ".len, &")
            out = cb(out, tmpN); out = cb(out, ", sizeof(")
            out = match emit_type(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, "), &"); out = cb(out, capN); out = cb(out, "); if (!"); out = cb(out, spN); out = cb(out, ") abort(); ")
            out = cb(out, accN); out = cb(out, " = (")
            out = match cg_slice_typename(out, elem) { []byte as o => o; error as err => return err }
            out = cb(out, "){ .ptr = "); out = cb(out, spN); out = cb(out, ", .len = "); out = cb(out, capN); out = cb(out, " }; ")
        }
        i++
    }
    mut z = cb(out, accN)
    cb(z, "; })")
}

// emit_interp — $"…{expr}…" (self-host parity). Lower to nested tk_str_concat over the piece
// literals and the holes: pieces[0] ++ str(holes[0]) ++ pieces[1] ++ … . A piece literal is the
// SAME (tk_str){…} emission as TStrLit. A `str` hole is the str expr directly; an INTEGER hole is
// wrapped in i64_to_str/u64_to_str (by the hole's signedness) — the SAME runtime builders the VM
// calls, so VM==codegen byte-for-byte. Concats nest left-to-right (matching the VM's accumulator).
fn emit_piece_lit(buf: []byte, piece: str) -> []byte {
    mut out = cb(buf, "(tk_str){ (const tk_byte *)\"")
    out = cb_cstr_escaped(out, piece)
    out = cb(out, "\", ")
    out = cb_i64(out, piece.len to i64)
    cb(out, " }")
}
fn emit_interp(buf: []byte, prog: checker::TProgram, in: checker::TInterp, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let nsegs = in.pieces.len + in.holes.len
    mut out = buf
    mut s = 1
    loop { if s >= nsegs { break }; out = cb(out, "tk_str_concat("); s++ }
    mut k = 0
    loop {
        if k >= nsegs { break }
        if k >= 1 { out = cb(out, ", ") }
        if k % 2 == 0 {
            out = emit_piece_lit(out, in.pieces[k / 2])
        } else {
            let hi = k / 2
            let h = in.holes[hi]
            if hi < in.specs.len {
                let sp = in.specs[hi]
                match sp.kind {
                    checker::TFSpecStatic as fs => {
                        let spec = fs.s
                        let fc0 = if spec.len > 0 { spec[0] } else { 102 to byte }
                        let fc_low = if fc0 >= 65 && fc0 <= 90 { (fc0 to u64 + 32) to byte } else { fc0 }
                        mut prec = 0 to i64
                        mut has_prec = false
                        mut si = 1 to u64
                        loop {
                            if si >= spec.len { break }
                            let ch = spec[si]
                            if ch >= 48 && ch <= 57 { prec = prec * 10 + (ch to i64 - 48); has_prec = true }
                            si++
                        }
                        if !has_prec { prec = if fc_low == 100 { 1 to i64 } else { 6 to i64 } }
                        let is_flt = match h.type { checker::Prim as p => p.kind == checker::PrimKind::F32 || p.kind == checker::PrimKind::F64; _ => false }
                        let prec_str = teko::i64_to_str(prec)
                        if      fc_low == 102 { out = cb(out, "tk_fmt_f((double)(") }
                        else if fc_low == 101 { out = cb(out, "tk_fmt_e((double)(") }
                        else if fc_low == 103 { out = cb(out, "tk_fmt_g((double)(") }
                        else if fc_low == 112 { out = cb(out, "tk_fmt_p((double)(") }
                        else if fc_low == 100 { out = cb(out, "tk_fmt_d((int64_t)(") }
                        else if fc_low == 120 && spec.len > 0 && spec[0] == 88 { out = cb(out, "tk_fmt_x_upper((uint64_t)(") }
                        else if fc_low == 120 { out = cb(out, "tk_fmt_x_lower((uint64_t)(") }
                        else if fc_low == 98  { out = cb(out, "tk_fmt_b((uint64_t)(") }
                        else if fc_low == 110 && is_flt { out = cb(out, "tk_fmt_n_f((double)(") }
                        else if fc_low == 110 { out = cb(out, "tk_fmt_n_i((int64_t)(") }
                        else { return error { message = "codegen: unrecognized format spec" } }
                        out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                        out = cb(out, "), ")
                        out = cb(out, prec_str)
                        out = cb(out, ")")
                    }
                    checker::TFSpecDynamic as fd => {
                        let is_flt = match h.type { checker::Prim as p => p.kind == checker::PrimKind::F32 || p.kind == checker::PrimKind::F64; _ => false }
                        let is_sint = match h.type { checker::Prim as p => cg_prim_is_signed_int(p.kind); _ => false }
                        if is_flt { out = cb(out, "tk_fmt_dyn_f64((double)(") }
                        else if is_sint { out = cb(out, "tk_fmt_dyn_i64((int64_t)(") }
                        else { out = cb(out, "tk_fmt_dyn_u64((uint64_t)(") }
                        out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                        out = cb(out, "), ")
                        out = match emit_expr_ctx(out, prog, checker::Void { }, fd.args[0], escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                        out = cb(out, ")")
                    }
                    _ => {   // FSpecNone (explicit) — natural form
                        match h.type {
                            checker::Str  => { out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err } }
                            checker::Char => { out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err } }
                            checker::Prim as p => {
                                if p.kind == checker::PrimKind::Bool {
                                    out = cb(out, "(")
                                    out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                                    out = cb(out, " ? (tk_str){ (const tk_byte *)\"true\", 4 } : (tk_str){ (const tk_byte *)\"false\", 5 })")
                                } else if p.kind == checker::PrimKind::F32 || p.kind == checker::PrimKind::F64 {
                                    out = cb(out, "tk_ftoa((double)(")
                                    out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                                    out = cb(out, "))")
                                } else if cg_prim_is_signed_int(p.kind) {
                                    out = cb(out, "tk_i64_to_str((int64_t)(")
                                    out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                                    out = cb(out, "))")
                                } else {
                                    out = cb(out, "tk_u64_to_str((uint64_t)(")
                                    out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                                    out = cb(out, "))")
                                }
                            }
                            checker::Byte => {
                                out = cb(out, "tk_u64_to_str((uint64_t)(")
                                out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                                out = cb(out, "))")
                            }
                            checker::Error => {
                                out = cb(out, "(")
                                out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                                out = cb(out, ").message")
                            }
                            _ => return error { message = "codegen: interpolation hole type not supported" }
                        }
                    }
                }
            } else {   // no spec at all — natural form
                match h.type {
                    checker::Str  => { out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err } }
                    checker::Char => { out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err } }
                    checker::Prim as p => {
                        if p.kind == checker::PrimKind::Bool {
                            out = cb(out, "(")
                            out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            out = cb(out, " ? (tk_str){ (const tk_byte *)\"true\", 4 } : (tk_str){ (const tk_byte *)\"false\", 5 })")
                        } else if p.kind == checker::PrimKind::F32 || p.kind == checker::PrimKind::F64 {
                            out = cb(out, "tk_ftoa((double)(")
                            out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            out = cb(out, "))")
                        } else if cg_prim_is_signed_int(p.kind) {
                            out = cb(out, "tk_i64_to_str((int64_t)(")
                            out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            out = cb(out, "))")
                        } else {
                            out = cb(out, "tk_u64_to_str((uint64_t)(")
                            out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            out = cb(out, "))")
                        }
                    }
                    checker::Byte => {
                        out = cb(out, "tk_u64_to_str((uint64_t)(")
                        out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                        out = cb(out, "))")
                    }
                    checker::Error => {
                        out = cb(out, "(")
                        out = match emit_expr_ctx(out, prog, checker::Void { }, h, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                        out = cb(out, ").message")
                    }
                    _ => return error { message = "codegen: interpolation hole type not supported" }
                }
            }
        }
        if k >= 1 { out = cb(out, ")") }
        k++
    }
    out
}

// cg_find_struct_field_type — look up the declared TypeExpr of field `fname` in the struct
// named `sname` from the program's type declarations. Returns the TypeExpr? (null if absent).
// (C: cg_find_struct_field_type.)
fn cg_find_struct_field_type(prog: checker::TProgram, sname: str, fname: str) -> parser::TypeExpr? {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => {
                match d.body {
                    parser::StructBody as sb => {
                        if d.name == sname {
                            mut j = 0
                            loop {
                                if j >= sb.fields.len { break }
                                if sb.fields[j].name == fname { return sb.fields[j].type_ann }
                                j++
                            }
                        }
                    }
                    _ => { }
                }
            }
            _ => { }
        }
        i++
    }
    null
}

// emit_struct_init — W4c `Name { f = v, … }` -> a C compound literal in DECLARED field
// order:  (tk_t_<MANGLE>){ .<field> = <val>, … }. The checker already reordered
// field_names/field_vals into the struct's declared order (expr.tks), so both backends
// lower identically (differential equivalence with the VM, which stores fields in the
// same order). The node's `.type` is Named (a user struct -> mangle its name) or Error
// (`error { message = … }`). E2-NATIVE: `error` is now the runtime tk_error struct
// (teko_rt.h); `error { message = s }` emits tk_error_make(s) which fills the other
// diagnostic fields with zero defaults (C1.3 additive). (C: TK_TEXPR_STRUCT_INIT branch.)
fn emit_struct_init(buf: []byte, prog: checker::TProgram, e: checker::TExpr, si: checker::TStructInit, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    return emit_struct_init_framed(buf, prog, e, si, "", escaping, regions, fn_body, dctx)
}

// emit_struct_init_framed — emit_struct_init with the auto-box ALLOCATOR parameterized (MEM Step
// 1). `frame` is the per-function frame-region variable name, or "" for the process root. When
// `frame` is "" the DIRECT box of a recursive back-edge rides `tk_alloc` (root → leaked, the safe
// default, byte-identical to the pre-MEM-Step-1 output). When `frame` is a region var the direct
// box rides `tk_region_alloc(<frame>, …)` so it is BULK-FREED when the frame region drops at the
// function's exit edge — used ONLY for a binding the escape check PROVED frame-local (escape.tks).
// NESTED struct-inits (field values via emit_expr) stay on root: mixing frame + root in one value
// is SAFE (root cells just leak), so soundness holds while the frame frees the provable subset.
fn emit_struct_init_framed(buf: []byte, prog: checker::TProgram, e: checker::TExpr, si: checker::TStructInit, frame: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let name = match e.type {
        checker::Named as nm => nm.name
        // E2-NATIVE: `error { message = s }` → tk_error_make(s); the checker ensures exactly
        // one `message` field. The other diagnostic fields default to zero (C1.3 additive).
        checker::Error       => {
            if si.field_vals.len != 1 { return error { message = "codegen: error value must have exactly the `message` field (internal)" } }
            mut oe = cb(buf, "tk_error_make(")
            oe = match emit_expr_ctx(oe, prog, checker::Void { }, si.field_vals[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
            return cb(oe, ")")
        }
        _           => return error { message = "codegen: struct literal with a non-named type not yet supported" }
    }
    mut out = cb(buf, "(")
    out = mangle_type_name(out, "", name)
    out = cb(out, "){ ")
    mut i = 0
    loop {
        if i >= si.field_names.len { break }
        if i > 0 { out = cb(out, ", ") }
        out = cb(out, ".")
        out = cb_str(out, si.field_names[i])
        out = cb(out, " = ")
        // Look up the declared field type once: it drives both the sentinel/null literal forms
        // AND auto-boxing of a recursive back-edge field. (C: emit_struct_init.)
        let fv = si.field_vals[i]
        let fte_opt = cg_find_struct_field_type(prog, name, si.field_names[i])
        // auto-box: a recursive back-edge field stores a heap pointer — malloc + copy the child
        // value into it (`({ T *_bxN = tk_alloc(sizeof *_bxN); *_bxN = (val); _bxN; })`). The
        // unique id is the buffer length (the functional uniquifier).
        let boxed = match fte_opt {
            parser::TypeExpr as fte => cg_field_boxed(prog, name, fte)
            null => false
        }
        let bxid = out.len to i64
        let bxN = fresh_named("_bx", bxid)
        if boxed {
            out = cb(out, "({ ")
            match fte_opt { parser::TypeExpr as fte => { out = match emit_type_expr(out, prog, fte) { []byte as o => o; error as err => return err } }; null => { } }
            out = cb(out, " *"); out = cb(out, bxN)
            // MEM Step 1: frame-local boxes ride the frame region (`tk_region_alloc(<frame>, …)`),
            // freed at the function's exit edge; everything else rides root `tk_alloc` (safe leak).
            if frame.len > 0 {
                out = cb(out, " = tk_region_alloc("); out = cb(out, frame); out = cb(out, ", sizeof *"); out = cb(out, bxN); out = cb(out, "); *"); out = cb(out, bxN); out = cb(out, " = ")
            } else {
                out = cb(out, " = tk_alloc(sizeof *"); out = cb(out, bxN); out = cb(out, "); *"); out = cb(out, bxN); out = cb(out, " = ")
            }
        }
        // Sentinel fields emit a concrete literal directly (emit_expr can't, the type being unknown):
        //   * a bare `null` into a `T?` field → (tk_opt_<inner>){ .present = false }   (C: TEXPR_NULL branch)
        //   * an empty() into a `[]T` field   → (tk_slice_<elem>){ .ptr = 0, .len = 0 }
        let emitted: bool = match fv.kind {
            checker::TNullLit => match fte_opt {
                parser::TypeExpr as fte => match fte {
                    parser::OptionalType => {
                        out = cb(out, "(")
                        out = match emit_type_expr(out, prog, fte) { []byte as o => o; error as err => return err }
                        out = cb(out, "){ .present = false }")
                        true
                    }
                    _ => false
                }
                null => false
            }
            _ => match fv.type {
                checker::Slice as sl => match sl.element {
                    checker::Void => {
                        match fte_opt {
                            parser::TypeExpr as fte => match fte {
                                parser::SliceType as st => {
                                    out = cb(out, "(")
                                    out = match emit_type_expr(out, prog, fte) { []byte as o => o; error as err => return err }
                                    out = cb(out, "){ .ptr = 0, .len = 0 }")
                                    true
                                }
                                _ => false
                            }
                            null => false
                        }
                    }
                    _ => false
                }
                _ => false
            }
        }
        if !emitted {
            // Build the expected resolved type from the field's type-expr and route through emit_as so a
            // bare case value WRAPS into a variant field (`.kind = <wrap>`), and a `[]case` slice REBUILDS
            // into a `[]variant` field (covariant). emit_as passes a non-variant slot (struct/enum/alias,
            // matching slice) straight through.
            //   * NAMED field          → expected = Named{last segment}
            //   * SLICE-of-user-named  → expected = Slice{element = Named{elem last segment}} (NOT a prim)
            // Other field shapes keep the plain emit.
            // `Void` is the "no expected slot" sentinel (mirrors the C `tk_type exp = {.tag = VOID}`):
            // emit plainly when nothing was built.
            // Build the expected slot type IMPERATIVELY (mut + statement-matches assigning the full
            // `Type`), mirroring the C twin's if/else. A nested match-VALUE would yield sub-unions
            // (`Void|Slice`, `Optional|Void`) that codegen can't widen into this union; each
            // `exp_t = <case>` instead wraps the case into `Type` at the assignment (assign-wrap).
            mut exp_t: checker::Type = checker::Void { }
            match fte_opt {
                parser::TypeExpr as fte => match fte {
                    parser::NamedType as nt => { exp_t = checker::Named { name = nt.path.segments[nt.path.segments.len - 1].name } }
                    parser::SliceType as st => match st.element {
                        parser::NamedType as ent => {
                            let elem = ent.path.segments[ent.path.segments.len - 1].name
                            if !cg_is_prim_name(elem) { exp_t = checker::Slice { element = checker::Named { name = elem } } }
                        }
                        _ => { }
                    }
                    // a present value into a `T?` field (T named) → emit_as wraps T → T?
                    // ({ .present = true, .value = … }). (A bare `null` is the sentinel branch above.)
                    parser::OptionalType as ot => match ot.inner {
                        parser::NamedType as inner_nt => { exp_t = checker::Optional { inner = checker::Named { name = inner_nt.path.segments[inner_nt.path.segments.len - 1].name } } }
                        _ => { }
                    }
                    _ => { }
                }
                null => { }
            }
            match exp_t {
                checker::Void => { out = match emit_expr_ctx(out, prog, checker::Void { }, fv, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err } }
                _ => { out = match emit_as(out, prog, exp_t, fv, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err } }
            }
        }
        if boxed { out = cb(out, "; "); out = cb(out, bxN); out = cb(out, "; })") }
        i++
    }
    cb(out, " }")
}

// emit_strlit — a TStrLit -> a tk_str compound literal with an EXPLICIT length. The
// decoded bytes may contain NUL, so we never lean on strlen/sizeof (M.1). (C: TK_TEXPR_STR.)
fn emit_strlit(buf: []byte, s: checker::TStrLit) -> []byte | error {
    mut out = cb(buf, "(tk_str){ (const tk_byte *)\"")
    out = cb_cstr_escaped(out, s.text)
    out = cb(out, "\", ")
    out = cb_i64(out, s.text.len to i64)
    cb(out, " }")
}

// emit_charlit — a TCharLit -> a tk_char {ptr,len} compound literal over the codepoint's static
// UTF-8 bytes (same explicit-length form as TStrLit; the bytes are read-only). (C: TK_TEXPR_CHAR.)
fn emit_charlit(buf: []byte, ch: checker::TCharLit) -> []byte | error {
    mut out = cb(buf, "(tk_char){ (uint8_t *)\"")
    out = cb_cstr_escaped(out, ch.bytes)
    out = cb(out, "\", ")
    out = cb_i64(out, ch.bytes.len to i64)
    cb(out, " }")
}

// ---------------------------------------------------------------------------
// W5a — `if`-as-a-VALUE + IMPLICIT trailing-return (differential parity with the VM).
// ---------------------------------------------------------------------------

// is_void_type — true iff a resolved Type is `void`. (C: `e->type.tag == TK_TYPE_VOID`.)
fn is_void_type(t: checker::Type) -> bool {
    match t { checker::Void => true; _ => false }
}

// fresh_tmp_name — a fresh, UNIQUE temp name `_tk<len>` as its OWN bytes, where `len` is the
// CURRENT length of the C-source buffer. Using the buffer length as the uniquifier is purely
// functional (no global counter) and guaranteed distinct: every append grows the buffer, and
// a NESTED statement-expr is emitted only after the outer one has appended bytes, so its name
// strictly differs. The name is returned standalone (not appended) so it can be spelled at
// BOTH the declaration and the trailing read. (C: `snprintf(tmp, "_tk%zu", b->len)`.)
fn fresh_tmp_name(buf_len: i64) -> str {
    mut nm = cb(teko::list::empty(), "_tk")
    nm = cb_i64(nm, buf_len)
    str(nm)
}

// emit_stmt_value — emit ONE branch statement in VALUE position: its trailing value is
// assigned to `sink`. A RETURN/break/continue inside a branch DIVERGES, but an `if` used as a
// SUB-expression cannot express that as a value, so it is an honest barrier here — EXACTLY
// matching the VM (eval_expr's TIfExpr stops on a divergent branch). A value-carrying expr
// statement -> `<sink> = <expr>;`. Anything else (void expr-stmt, loop, binding, assign) ->
// emitted normally (no value). (C: `emit_stmt_value`.)
// `escaping`/`regions`/`fn_body` thread the enclosing block-region context: a non-tail statement
// that is itself a value-position sub-expression (or a nested if/match) gets the live context so it
// can open its own arm region — and a TBinding non-tail block-local routes to the arm region opened
// by emit_branch_value. The TAIL value (the `sink =` line) is emitted with cur_block_is_value=TRUE
// so a binding flowing into it is NOT block-local (routes to the enclosing region — the W9 trap).
fn emit_stmt_value(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, s: checker::TStatement, slot: checker::Type, sink: str, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx, cur_block: []checker::TStatement) -> []byte | error {
    match s {
        checker::TReturn       => error { message = "codegen: control flow inside an `if` used as a sub-expression not yet supported" }
        checker::TBreakStmt    => error { message = "codegen: control flow inside an `if` used as a sub-expression not yet supported" }
        checker::TContinueStmt => error { message = "codegen: control flow inside an `if` used as a sub-expression not yet supported" }
        checker::TExprStmt as es => {
            if is_void_type(es.expr.type) {
                // A non-value statement in an if-value branch: thread ret_type so an embedded return wraps.
                // Frameless (frame="") but the block-region context rides so a nested value-if opens a region.
                return emit_stmt(buf, s, false, prog, ret_type, indent, "", escaping, regions, fn_body, dctx, cur_block, true)
            }
            mut out = cb(buf, indent)
            out = cb(out, sink)
            out = cb(out, " = ")
            // wrap the branch value into the if's RESULT type (`slot`) — a bare case / `[]case` / null
            // lands in the variant/optional/slice result; emit_as_r threads ret_type so a diverging
            // value-form-match arm inside the branch (`… => return e`) wraps into the FUNCTION's slot.
            // The tail value rides the ENCLOSING region context (regions threaded) so a value-if nested
            // in the tail can open its own region; a binding flowing in here is excluded by is_value=true.
            out = match emit_as_r(out, prog, ret_type, slot, es.expr, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            cb(out, ";\n")
        }
        _ => emit_stmt(buf, s, false, prog, ret_type, indent, "", escaping, regions, fn_body, dctx, cur_block, true)
    }
}

// emit_branch_value — emit a BRANCH block (the `if`-value then/else): all but the last
// statement normally, the LAST via emit_stmt_value (its trailing value -> `sink`). An empty
// branch yields nothing (the checker forbids a value-typed empty branch). (C: `emit_branch_value`.)
// S2/W9: when the branch has a provably BLOCK-LOCAL binding (queried with is_value=TRUE — the
// predicate EXCLUDES any binding flowing into the tail value / used as an assign-RHS), open the
// branch's OWN `_tkbr<len>` region for those NON-tail block-locals and drop it at the branch's exit.
// CRITICAL ORDERING (the W9 trap): the tail value flows to `sink` (an ENCLOSING temp) via
// emit_stmt_value FIRST, THEN the region drops — so the yielded value is fully materialized into the
// enclosing region before its non-tail siblings are freed (never a UAF). No block-local binding ⇒ no
// region ⇒ byte-identical to the pre-W9 value-branch output. (C: `emit_branch_value`.)
fn emit_branch_value(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, body: []checker::TStatement, slot: checker::Type, sink: str, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let want_block = cg_block_has_block_local(escaping, fn_body, body, true) && regions.len < 64
    if !want_block {
        // No block-local binding: emit exactly as the pre-W9 path (no region), but with live context.
        // (W9.3) If the branch has its OWN top-level `defer`, register it and fire it AFTER the tail is
        // captured into `sink`, then drop the base so nothing leaks into later branches/functions.
        let base = dctx.defers.len
        mut cur = dctx
        mut out = buf
        mut i = 0
        loop {
            if i + 1 >= body.len { break }
            match body[i] {
                checker::TDeferStmt => { cur = dctx_register(cur, body[i]) }
                _ => { out = match emit_stmt(out, body[i], false, prog, ret_type, indent, "", escaping, regions, fn_body, cur, teko::list::empty(), false) { []byte as o => o; error as err => return err } }
            }
            i++
        }
        if body.len > 0 {
            out = match emit_stmt_value(out, prog, ret_type, body[body.len - 1], slot, sink, indent, escaping, regions, fn_body, cur, teko::list::empty()) { []byte as o => o; error as err => return err }
        }
        if cur.defers.len > base {
            out = match emit_defers(out, cur.defers, base, prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
        }
        return out
    }
    // Open the value-arm region (named `_tkbr<len>` — the deterministic out.len uniquifier).
    let base = dctx.defers.len   // (W9.3) defer scope base for this value-arm
    let fall = cg_append_direct_defers(dctx.defers, body)
    let region = fresh_named("_tkbr", buf.len to i64)
    mut out = cb(buf, indent); out = cb(out, "tk_region *"); out = cb(out, region); out = cb(out, " = tk_region_new();\n")
    let regs2 = teko::list::push(regions, RegionFrame { name = region; label = ""; is_loop = false; defer_base = base })
    mut cur = dctx
    mut i = 0
    loop {
        if i + 1 >= body.len { break }
        // Non-tail statements: cur_block=body + is_value=true so block-locals route. Accumulate the
        // branch's direct defers incrementally (a defer emits nothing inline).
        match body[i] {
            checker::TDeferStmt => { cur = dctx_register(cur, body[i]) }
            _ => { out = match emit_stmt(out, body[i], false, prog, ret_type, indent, "", escaping, regs2, fn_body, cur, body, true) { []byte as o => o; error as err => return err } }
        }
        i++
    }
    if body.len > 0 {
        // Materialize the TAIL value into `sink` (enclosing) BEFORE the region drop (W9 ordering).
        out = match emit_stmt_value(out, prog, ret_type, body[body.len - 1], slot, sink, indent, escaping, regs2, fn_body, cur, body) { []byte as o => o; error as err => return err }
    }
    // (W9.3) Tail is in the enclosing `sink`; fire THIS value-arm's defers (LIFO) BEFORE dropping its
    // region (idempotent + nulled for overlap safety).
    out = match emit_defers(out, fall, base, prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
    out = cb(out, indent); out = cb(out, "tk_region_drop("); out = cb(out, region); out = cb(out, "); "); out = cb(out, region); out = cb(out, " = NULL;\n")
    out
}

// emit_if_value — lower an `if` USED AS A SUB-VALUE to a GNU statement-expression:
//   ({ <Ctype> _tkN; if (<cond>) { <then…> } else { <else…> } _tkN; })
// Each branch assigns its trailing value to `_tkN`; `<Ctype>` is the if-node's resolved
// branch type. clang/gcc accept stmt-exprs under the host cc (the codebase already targets
// cc -std=c23). (VM parity: eval_expr's TIfExpr runs exec_if and yields the taken branch's
// trailing NORMAL value; a divergent branch is an honest stop — see emit_stmt_value.)
// (C: `emit_if_value`.)
fn emit_if_value(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, e: checker::TExpr, f: checker::TIfExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    if !f.has_else { return error { message = "codegen: if-without-else used as a value not yet supported" } }
    // The temp name is `_tk<buflen>` frozen at the CURRENT length (the buffer is about to
    // grow). Capture it once and reuse it for the declaration AND the trailing read, so both
    // spell the same identifier.
    // S2/W9: `escaping`/`regions`/`fn_body` thread the enclosing block-region context so each branch
    // can open its OWN arm region for its block-local NON-tail bindings (emit_branch_value). The C
    // twin reads the same from its live globals (g_cg_escaping/g_cg_block_stack/g_cg_fn_body).
    let tmp = fresh_tmp_name(buf.len to i64)
    mut out = cb(buf, "({ ")
    out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb(out, tmp)
    out = cb(out, "; if (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, f.cond, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, ") {\n")
    out = match emit_branch_value(out, prog, ret_type, f.then_blk, e.type, tmp, "    ", escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "} else {\n")
    out = match emit_branch_value(out, prog, ret_type, f.else_blk, e.type, tmp, "    ", escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "} ")
    out = cb(out, tmp)
    cb(out, "; })")
}

// ---------------------------------------------------------------------------
// W5b — VARIANT-VALUE WRAPPING + MATCH lowering (differential parity with the VM).
// ---------------------------------------------------------------------------

// fresh_named — a fresh temp `<prefix><len>` (a sibling of fresh_tmp_name for the match
// subject/result temps `_s<len>` / `_r<len>`). (C: `snprintf(subj, "_s%zu", b->len)`.)
fn fresh_named(prefix: str, n: i64) -> str {
    mut nm = cb(teko::list::empty(), prefix)
    nm = cb_i64(nm, n)
    str(nm)
}

// ---- variant-wrap helpers (uniform over an INLINE `tk_u_…` and a NAMED variant decl) ----
// cg_var_nmem — member COUNT of a variant slot (inline Variant OR a named variant decl).
// (C: `cg_var_nmem`.)
fn cg_var_nmem(prog: checker::TProgram, v: checker::Type) -> i64 {
    match v {
        checker::Variant as va => va.members.len to i64
        checker::Named as nm => match cg_find_variant_decl(prog, nm.name) {
            parser::TypeDecl as d => match d.body {
                parser::VariantBody as vb => match vb.type_expr {
                    parser::UnionType as u => u.members.len to i64
                    _ => 0
                }
                _ => 0
            }
            error => 0
        }
        _ => 0
    }
}

// cg_var_mkey — member i's KEY (str). Inline → cg_member_key_str; named → cg_member_key_texpr_str.
// (C: `cg_var_mkey`.)
fn cg_var_mkey(prog: checker::TProgram, v: checker::Type, i: i64) -> str | error {
    match v {
        checker::Variant as va => cg_member_key_str(va.members[i])
        checker::Named as nm => {
            let vd = match cg_find_variant_decl(prog, nm.name) { parser::TypeDecl as d => d; error as e => return e }
            let members = match vd.body {
                parser::VariantBody as vb => match vb.type_expr { parser::UnionType as u => u.members; _ => return error { message = "codegen: cg_var_mkey on a non-union variant body (internal)" } }
                _ => return error { message = "codegen: cg_var_mkey on a non-variant decl (internal)" }
            }
            cg_member_key_texpr_str(members[i])
        }
        _ => error { message = "codegen: cg_var_mkey on a non-variant type (internal)" }
    }
}

// cg_var_mtype — member i AS a Type for recursion: an inline member passes through; a NAMED
// member → a Named type (its last path segment); anything else → a Void sentinel (not a
// recursable variant). (C: `cg_var_mtype`.)
fn cg_var_mtype(prog: checker::TProgram, v: checker::Type, i: i64) -> checker::Type {
    match v {
        checker::Variant as va => va.members[i]
        checker::Named as nm => {
            let vd = match cg_find_variant_decl(prog, nm.name) { parser::TypeDecl as d => d; error => return checker::Void { } }
            let members = match vd.body {
                parser::VariantBody as vb => match vb.type_expr { parser::UnionType as u => u.members; _ => return checker::Void { } }
                _ => return checker::Void { }
            }
            match members[i] {
                parser::NamedType as nt => checker::Named { name = nt.path.segments[nt.path.segments.len - 1].name }
                _ => checker::Void { }
            }
        }
        _ => checker::Void { }
    }
}

// cg_is_variant_type — is `mt` a (named or inline) variant? (C: `cg_is_variant_type`.)
fn cg_is_variant_type(prog: checker::TProgram, mt: checker::Type) -> bool {
    match mt {
        checker::Variant => true
        checker::Named as nm => cg_named_is_variant(prog, nm.name)
        _ => false
    }
}

// cg_var_reaches — does variant `v` (TRANSITIVELY, depth bound 16) contain a member whose key
// == vkey? (C: `cg_var_reaches`.)
fn cg_var_reaches(prog: checker::TProgram, v: checker::Type, vkey: str, depth: i64) -> bool {
    if depth <= 0 { return false }
    let n = cg_var_nmem(prog, v)
    mut i = 0
    loop {
        if i >= n { break }
        let k = match cg_var_mkey(prog, v, i) { str as s => s; error => "" }
        if k == vkey { return true }
        let mt = cg_var_mtype(prog, v, i)
        if cg_is_variant_type(prog, mt) {
            if cg_var_reaches(prog, mt, vkey, depth - 1) { return true }
        }
        i++
    }
    false
}

// cg_wrap_open — emit `(<variantCType>){ .tag = <TAG for member key `mkey`>, .as.<mkey> = `
// (no closing `}`). Inline `tk_u_…` vs named-decl tag spelling. (C: `cg_wrap_open`.)
fn cg_wrap_open(buf: []byte, v: checker::Type, mkey: str) -> []byte | error {
    match v {
        checker::Variant as va => {
            mut out = cb(buf, "(")
            out = match cg_variant_typename(out, va) { []byte as o => o; error as err => return err }
            out = cb(out, "){ .tag = TK_TAG_U")
            mut j = 0
            loop {
                if j >= va.members.len { break }
                out = cb(out, "_")
                let kj = match cg_member_key_str(va.members[j]) { str as s => s; error as err => return err }
                out = cb_upper(out, kj)
                j++
            }
            out = cb(out, "_")
            out = cb_upper(out, mkey)
            out = cb(out, ", .as.")
            out = cb_str(out, mkey)
            return cb(out, " = ")
        }
        checker::Named as nm => {
            mut out = cb(buf, "(")
            out = mangle_type_name(out, "", nm.name)
            out = cb(out, "){ .tag = TK_TAG_")
            out = cb_upper(out, nm.name)
            out = cb(out, "_")
            out = cb_upper(out, mkey)
            out = cb(out, ", .as.")
            out = cb_str(out, mkey)
            return cb(out, " = ")
        }
        _ => error { message = "codegen: cg_wrap_open on a non-variant type (internal)" }
    }
}

// emit_variant_wrap — wrap `value` (a bare case) into the variant `expected`, DIRECTLY or
// TRANSITIVELY. A value that is a case of a NESTED variant member is routed through that member
// (Named → (Type){…} → (Type|error){…}), recursing. PRECONDITION: value's key is reachable in
// `expected` (the caller guards with cg_var_reaches and otherwise emits plainly); `T? | error`
// is an illegal type here, so reachability is a separate predicate rather than a `null` result.
// (C: `emit_variant_wrap`.)
fn emit_variant_wrap(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, expected: checker::Type, value: checker::TExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let vkey = match cg_member_key_str(value.type) { str as s => s; error => "" }
    let n = cg_var_nmem(prog, expected)
    // pass 1 — DIRECT: value's key matches a member of `expected`.
    mut i = 0
    loop {
        if i >= n { break }
        let mk = match cg_var_mkey(prog, expected, i) { str as s => s; error => "" }
        if mk == vkey {
            mut out = match cg_wrap_open(buf, expected, vkey) { []byte as o => o; error as err => return err }
            out = match emit_expr_ret(out, prog, ret_type, value) { []byte as o => o; error as err => return err }
            return cb(out, " }")
        }
        i++
    }
    // pass 2 — TRANSITIVE: route through a member variant that reaches vkey.
    mut j = 0
    loop {
        if j >= n { break }
        let mt = cg_var_mtype(prog, expected, j)
        if cg_is_variant_type(prog, mt) {
            if cg_var_reaches(prog, mt, vkey, 16) {
                let mk = match cg_var_mkey(prog, expected, j) { str as s => s; error => "" }
                mut out = match cg_wrap_open(buf, expected, mk) { []byte as o => o; error as err => return err }
                out = match emit_variant_wrap(out, prog, ret_type, mt, value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }   // recurse into the member variant
                return cb(out, " }")
            }
        }
        j++
    }
    // unreachable given the caller's cg_var_reaches guard.
    error { message = "codegen: emit_variant_wrap on an unreachable case (internal — caller must guard with cg_var_reaches)" }
}

// emit_variant_wrap_str — like emit_variant_wrap but wraps a C-EXPRESSION STRING `cexpr` of
// resolved type `vtype` (the []U→[]T element-wise slice rebuild wraps each element, a C lvalue,
// not an AST node). IDENTICAL pass-1-direct / pass-2-transitive structure; where emit_variant_wrap
// emits the value AST node, this emits the literal string `cexpr`. PRECONDITION: vtype's key is
// reachable in `expected` (caller guards with cg_var_reaches, otherwise emits the bare element —
// `T? | error` is illegal here, so reachability is a separate predicate). (C: `emit_variant_wrap_str`.)
fn emit_variant_wrap_str(buf: []byte, prog: checker::TProgram, expected: checker::Type, vtype: checker::Type, cexpr: str) -> []byte | error {
    let vkey = match cg_member_key_str(vtype) { str as s => s; error => "" }
    let n = cg_var_nmem(prog, expected)
    // pass 1 — DIRECT: vtype's key matches a member of `expected`.
    mut i = 0
    loop {
        if i >= n { break }
        let mk = match cg_var_mkey(prog, expected, i) { str as s => s; error => "" }
        if mk == vkey {
            mut out = match cg_wrap_open(buf, expected, vkey) { []byte as o => o; error as err => return err }
            out = cb(out, cexpr)
            return cb(out, " }")
        }
        i++
    }
    // pass 2 — TRANSITIVE: route through a member variant that reaches vkey.
    mut j = 0
    loop {
        if j >= n { break }
        let mt = cg_var_mtype(prog, expected, j)
        if cg_is_variant_type(prog, mt) {
            if cg_var_reaches(prog, mt, vkey, 16) {
                let mk = match cg_var_mkey(prog, expected, j) { str as s => s; error => "" }
                mut out = match cg_wrap_open(buf, expected, mk) { []byte as o => o; error as err => return err }
                out = match emit_variant_wrap_str(out, prog, mt, vtype, cexpr) { []byte as o => o; error as err => return err }   // recurse into the member variant
                return cb(out, " }")
            }
        }
        j++
    }
    // unreachable given the caller's cg_var_reaches guard.
    error { message = "codegen: emit_variant_wrap_str on an unreachable case (internal — caller must guard with cg_var_reaches)" }
}

// cg_wrap_elem_str — wrap a C-EXPRESSION STRING `cexpr` (a `[]U` element of static type `vtype`)
// into the slice element target `T` (= `expected`), for the emit_as slice-covariance rebuild. Uniform
// with emit_as's value-position wrapping:
//   * T is OPTIONAL  → present-wrap: (tk_opt_<inner>){ .present = true, .value = <recurse into inner> }
//   * T is a VARIANT the element's key reaches → variant-wrap (emit_variant_wrap_str)
//   * otherwise (same type) → emit `cexpr` bare.
// (C: `cg_wrap_elem_str`.)
fn cg_wrap_elem_str(buf: []byte, prog: checker::TProgram, expected: checker::Type, vtype: checker::Type, cexpr: str) -> []byte | error {
    match expected {
        checker::Optional as opt => {
            match opt.inner {
                checker::Void => return cb(buf, cexpr)   // sentinel inner — bare (should not occur)
                _ => {
                    mut o = cb(buf, "(")
                    o = match cg_opt_typename(o, opt.inner) { []byte as r => r; error as err => return err }
                    o = cb(o, "){ .present = true, .value = ")
                    o = match cg_wrap_elem_str(o, prog, opt.inner, vtype, cexpr) { []byte as r => r; error as err => return err }   // the inner may need its own wrap
                    return cb(o, " }")
                }
            }
        }
        _ => { }
    }
    // not optional → variant-wrap when the element's key reaches T, else emit it bare (the same
    // reachability guard the C caller applies before emit_variant_wrap_str).
    let ukey = match cg_member_key_str(vtype) { str as s => s; error => "" }
    let wrappable = match expected {
        checker::Variant => ukey != "" && cg_var_reaches(prog, expected, ukey, 16)
        checker::Named => ukey != "" && cg_var_reaches(prog, expected, ukey, 16)
        _ => false
    }
    if wrappable {
        emit_variant_wrap_str(buf, prog, expected, vtype, cexpr)
    } else {
        cb(buf, cexpr)   // not wrapped — bare element
    }
}

// emit_host_ffi — lift a host-FFI primitive's fixed-ABI result (teko_rt.h) into the program's
// result type. The runtime can't name the generated sum/optional/slice structs (its header is
// included before them), so codegen builds them here: call the primitive, then construct
// `e.type` from the result's header-knowable fields (`error` is its message str). Single-eval —
// the result struct is bound to one temp, then both arms read it. `kind` selects the shape:
// "sres"(str|error) "ures"(error?) "slres"([]str|error) "u64res"(u64|error) "args" "run".
// (C: `emit_host_ffi`.)
fn emit_host_ffi(buf: []byte, prog: checker::TProgram, e: checker::TExpr, c: checker::TCall, kind: str, rtfn: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let t = $"_h{buf.len}"                  // unique temp per call site
    let str_t = checker::Str { }
    let err_t = checker::Error { }

    // args() -> []str : ({ uint64_t _hNn; tk_str *_hNp = tk_rt_args(&_hNn); (tk_slice_str){…}; })
    if kind == "args" {
        mut o = cb(buf, "({ uint64_t ")
        o = cb(o, t)
        o = cb(o, "n; tk_str *")
        o = cb(o, t)
        o = cb(o, "p = ")
        o = cb(o, rtfn)
        o = cb(o, "(&")
        o = cb(o, t)
        o = cb(o, "n); (")
        o = match cg_slice_typename(o, str_t) { []byte as r => r; error as err => return err }
        o = cb(o, "){ .ptr = ")
        o = cb(o, t)
        o = cb(o, "p, .len = ")
        o = cb(o, t)
        return cb(o, "n }; })")
    }
    // (C7.1a) bytes_from_ptr(ptr,u64) -> []byte : a fixed-ABI tk_ffi_bytes {ptr,len} lifted to the
    // generated tk_slice_byte (same {ptr,len} layout; the runtime can't name the generated slice).
    if kind == "bytes" {
        let byte_t = checker::Byte { }
        mut o = cb(buf, "({ tk_ffi_bytes ")
        o = cb(o, t)
        o = cb(o, " = ")
        o = cb(o, rtfn)
        o = cb(o, "(")
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        o = cb(o, ", ")
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[1], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        o = cb(o, "); (")
        o = match cg_slice_typename(o, byte_t) { []byte as r => r; error as err => return err }
        o = cb(o, "){ .ptr = ")
        o = cb(o, t)
        o = cb(o, ".ptr, .len = ")
        o = cb(o, t)
        return cb(o, ".len }; })")
    }
    // run([]str) -> i32 : the primitive takes ptr+len (no generated slice type). Single-eval argv.
    if kind == "run" {
        mut o = cb(buf, "({ ")
        o = match cg_slice_typename(o, str_t) { []byte as r => r; error as err => return err }
        o = cb(o, " ")
        o = cb(o, t)
        o = cb(o, " = ")
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        o = cb(o, "; ")
        o = cb(o, rtfn)
        o = cb(o, "(")
        o = cb(o, t)
        o = cb(o, ".ptr, ")
        o = cb(o, t)
        return cb(o, ".len); })")
    }

    // C7.12 — ures_byteslice: write_file_bytes(path: str, data: []byte) -> error?.
    // The C function takes (path, ptr, len); the Teko []byte slice carries both in a struct,
    // so we bind the slice to a temp and pass .ptr + .len separately.
    if kind == "ures_byteslice" {
        let byte_t = checker::Byte { }
        mut o = cb(buf, "({ ")
        o = match cg_slice_typename(o, byte_t) { []byte as r => r; error as err => return err }
        o = cb(o, " ")
        o = cb(o, t)
        o = cb(o, "s = ")
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[1], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        o = cb(o, "; tk_ffi_ures ")
        o = cb(o, t)
        o = cb(o, "r = ")
        o = cb(o, rtfn)
        o = cb(o, "(")
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        o = cb(o, ", ")
        o = cb(o, t)
        o = cb(o, "s.ptr, (uint64_t)")
        o = cb(o, t)
        o = cb(o, "s.len); ")
        o = cb(o, t)
        o = cb(o, "r.ok ? (")
        o = match emit_type(o, e.type) { []byte as r => r; error as err => return err }
        o = cb(o, "){ .present = false } : (")
        o = match emit_type(o, e.type) { []byte as r => r; error as err => return err }
        // E2-NATIVE: .value is now tk_error; wrap the tk_str .err message via tk_error_make.
        o = cb(o, "){ .present = true, .value = tk_error_make(")
        o = cb(o, t)
        return cb(o, "r.err) }; })")
    }

    // ROUND 0 — sres_byteslice: str_from_utf8(bytes: []byte) -> str | error. The C function
    // takes (ptr, len); the Teko []byte slice carries both in a struct. Same VARIANT-wrap shape
    // as the generic "sres" branch below, but the single arg is a []byte split into ptr+len
    // (mirrors "ures_byteslice"'s arg handling, wrapping a str|error result instead of error?).
    if kind == "sres_byteslice" {
        let byte_t = checker::Byte { }
        mut o = cb(buf, "({ ")
        o = match cg_slice_typename(o, byte_t) { []byte as r => r; error as err => return err }
        o = cb(o, " ")
        o = cb(o, t)
        o = cb(o, "s = ")
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[0], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        o = cb(o, "; tk_ffi_sres ")
        o = cb(o, t)
        o = cb(o, "r = ")
        o = cb(o, rtfn)
        o = cb(o, "(")
        o = cb(o, t)
        o = cb(o, "s.ptr, (uint64_t)")
        o = cb(o, t)
        o = cb(o, "s.len); ")
        o = cb(o, t)
        o = cb(o, "r.ok ? ")
        o = match emit_variant_wrap_str(o, prog, e.type, str_t, $"{t}r.value") { []byte as r => r; error as err => return err }
        o = cb(o, " : ")
        o = match emit_variant_wrap_str(o, prog, e.type, err_t, teko::str::concat("tk_error_make(", $"{t}r", ".err)")) { []byte as r => r; error as err => return err }
        return cb(o, "; })")
    }

    // The struct-returning host FFI: bind the fixed-ABI result, then lift per result shape.
    let resty = if kind == "sres" { "tk_ffi_sres" } else if kind == "ures" { "tk_ffi_ures" } else if kind == "slres" { "tk_ffi_slres" } else { "tk_ffi_u64res" }
    mut o = cb(buf, "({ ")
    o = cb(o, resty)
    o = cb(o, " ")
    o = cb(o, t)
    o = cb(o, " = ")
    o = cb(o, rtfn)
    o = cb(o, "(")
    mut i: u64 = 0
    loop {
        if i >= c.args.len { break }
        if i > 0 { o = cb(o, ", ") }
        o = match emit_expr_ctx(o, prog, checker::Void { }, c.args[i], escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
        i++
    }
    o = cb(o, "); ")

    // error? : ok → present=false (success) ; !ok → present=true, value=<tk_error>.
    // E2-NATIVE: .value is now tk_error; wrap the tk_str .err message via tk_error_make.
    if kind == "ures" {
        o = cb(o, t)
        o = cb(o, ".ok ? (")
        o = match emit_type(o, e.type) { []byte as r => r; error as err => return err }
        o = cb(o, "){ .present = false } : (")
        o = match emit_type(o, e.type) { []byte as r => r; error as err => return err }
        o = cb(o, "){ .present = true, .value = tk_error_make(")
        o = cb(o, t)
        return cb(o, ".err) }; })")
    }

    // VARIANT results: ok → wrap the value arm ; !ok → wrap the error arm (a tk_error).
    o = cb(o, t)
    o = cb(o, ".ok ? ")
    if kind == "sres" {
        o = match emit_variant_wrap_str(o, prog, e.type, str_t, $"{t}.value") { []byte as r => r; error as err => return err }
    } else if kind == "u64res" {
        o = match emit_variant_wrap_str(o, prog, e.type, checker::Prim { kind = checker::PrimKind::U64 }, $"{t}.value") { []byte as r => r; error as err => return err }
    } else {
        let slice_t = checker::Slice { element = checker::Str { } }
        // cexpr has literal braces → built via concat ($-interpolation has no brace escape).
        let sx = teko::str::concat("(tk_slice_str){ .ptr = ", t, teko::str::concat(".ptr, .len = ", t, ".len }"))
        o = match emit_variant_wrap_str(o, prog, e.type, slice_t, sx) { []byte as r => r; error as err => return err }
    }
    o = cb(o, " : ")
    // E2-NATIVE: wrap the runtime's `.err` tk_str (message) into a full tk_error via tk_error_make.
    // u64res carries no message (not-found is the only failure) → empty message tk_error_make.
    let eexpr = if kind == "u64res" { "tk_error_make((tk_str){0})" } else { teko::str::concat("tk_error_make(", t, ".err)") }
    o = match emit_variant_wrap_str(o, prog, e.type, err_t, eexpr) { []byte as r => r; error as err => return err }
    return cb(o, "; })")
}

// cg_type_mangle_eq — do two resolved types mangle to the SAME generated C type name (→ same
// C struct/typedef)? Renders both via the optional-mangle to scratch strings and compares.
// (C: `cg_type_mangle_eq`.)
fn cg_type_mangle_eq(a: checker::Type, c: checker::Type) -> bool {
    cg_opt_key(a) == cg_opt_key(c)
}

// emit_as — emit `value` into a slot whose EXPECTED type is `expected`. When `expected` is
// a (named) variant and `value`'s type is one of its case members, WRAP the value into the
// variant's `tag + union` representation:
//   (tk_t_<Variant>){ .tag = TK_TAG_<UPPER Variant>_<UPPER member>, .as.<member> = <value> }
// else emit the value plainly. The tag suffix + union field are spelled EXACTLY as
// emit_type_decl spells them (cb_upper tag; the member's bare name field), so wrap + decl
// agree. The VM needs no wrap (its struct value already carries the case name); this
// synthesizes the C equivalent — the W4c-deferred variant-value layer. (C: `emit_as`.)
// emit_as — wrap `value` into `expected` (the ret_type-less convenience form: most callers are not
// in a return context, so a diverging value-form-match arm inside `value` cannot occur). The C uses
// a `g_cg_ret_type` STATIC for that; here ret_type is THREADED (Teko has no module-mutable), so a
// return-context caller (binding/assign/return/tail/arm sink) uses emit_as_r to pass it down.
fn emit_as(buf: []byte, prog: checker::TProgram, expected: checker::Type, value: checker::TExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    emit_as_r(buf, prog, checker::Void { }, expected, value, escaping, regions, fn_body, dctx)
}

fn emit_as_r(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, expected: checker::Type, value: checker::TExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    // OPTIONAL slot (REBOOT_PLAN §202): wrap the value into the slot's tk_opt_<inner> struct.
    //   * a bare `null`           → (tk_opt_<inner>){ .present = false }
    //   * an already-optional val → emitted plainly (it IS a tk_opt_<inner>)
    //   * a plain `T`             → (tk_opt_<inner>){ .present = true, .value = <v> }  (present-wrap)
    match expected {
        checker::Optional as opt => {
            match opt.inner {
                checker::Void => { }   // sentinel — fall through (should not occur at a real slot)
                _ => {
                    match value.kind {
                        checker::TNullLit => {
                            mut o0 = cb(buf, "(")
                            o0 = match cg_opt_typename(o0, opt.inner) { []byte as o => o; error as err => return err }
                            return cb(o0, "){ .present = false }")
                        }
                        _ => { }
                    }
                    match value.type {
                        checker::Optional => return emit_expr_ctx(buf, prog, ret_type, value, escaping, regions, fn_body, dctx)   // already optional → pass through
                        _ => {
                            mut o1 = cb(buf, "(")
                            o1 = match cg_opt_typename(o1, opt.inner) { []byte as o => o; error as err => return err }
                            o1 = cb(o1, "){ .present = true, .value = ")
                            o1 = match emit_as_r(o1, prog, ret_type, opt.inner, value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                            return cb(o1, " }")
                        }
                    }
                }
            }
        }
        _ => { }
    }
    // SLICE slot: the sentinel/untyped empty slice (teko::list::empty(), element = Void) becomes
    // this slot's concrete empty literal; a concrete slice value passes through.
    match expected {
        checker::Slice as sexp => {
            match sexp.element {
                checker::Void => { }   // sentinel expected — fall through (should not occur at a real slot)
                _ => {
                    let val_sentinel = match value.type {
                        checker::Slice as svt => match svt.element { checker::Void => true; _ => false }
                        _ => false
                    }
                    if val_sentinel {
                        mut so = cb(buf, "(")
                        so = match cg_slice_typename(so, sexp.element) { []byte as o => o; error as err => return err }
                        return cb(so, "){ .ptr = 0, .len = 0 }")
                    }
                    // COVARIANT `[]U` → `[]T` (e.g. `push(empty(), Prim)` = []Prim flowing into a []Type
                    // slot): tk_slice_U and tk_slice_T are DISTINCT C structs, so REBUILD element-wise,
                    // wrapping each U into T (the same case→variant wrap emit_variant_wrap_str does, on
                    // each C element lvalue). A same-mangle element passes straight through.
                    let concrete_diff = match value.type {
                        checker::Slice as svt => match svt.element {
                            checker::Void => false   // sentinel handled above
                            _ => !cg_type_mangle_eq(sexp.element, svt.element)
                        }
                        _ => false
                    }
                    if concrete_diff {
                        let elemU = match value.type { checker::Slice as svt => svt.element; _ => checker::Void { } }
                        let T = sexp.element
                        let U = elemU
                        // unique temp names from the buffer length (the functional uniquifier).
                        let baseN = buf.len to i64
                        let sv = fresh_named("_cv", baseN)
                        let rp = fresh_named("_cp", baseN + 1)
                        let ri = fresh_named("_ci", baseN + 2)
                        mut o = cb(buf, "({ ")
                        o = match cg_slice_typename(o, U) { []byte as r => r; error as err => return err }
                        o = cb(o, " "); o = cb(o, sv); o = cb(o, " = ")
                        o = match emit_expr_ctx(o, prog, ret_type, value, escaping, regions, fn_body, dctx) { []byte as r => r; error as err => return err }
                        o = cb(o, "; ")
                        o = match emit_type(o, T) { []byte as r => r; error as err => return err }
                        o = cb(o, " *"); o = cb(o, rp); o = cb(o, " = (")
                        o = match emit_type(o, T) { []byte as r => r; error as err => return err }
                        o = cb(o, " *)malloc("); o = cb(o, sv); o = cb(o, ".len * sizeof(")
                        o = match emit_type(o, T) { []byte as r => r; error as err => return err }
                        o = cb(o, ")); if ("); o = cb(o, rp); o = cb(o, " == 0 && "); o = cb(o, sv); o = cb(o, ".len) abort(); ")
                        o = cb(o, "for (uint64_t "); o = cb(o, ri); o = cb(o, " = 0; "); o = cb(o, ri); o = cb(o, " < "); o = cb(o, sv); o = cb(o, ".len; "); o = cb(o, ri); o = cb(o, " += 1) { ")
                        o = cb(o, rp); o = cb(o, "["); o = cb(o, ri); o = cb(o, "] = ")
                        let elem = teko::str::concat(sv, teko::str::concat(".ptr[", teko::str::concat(ri, "]")))
                        // wrap each U-element into T: present-wrap when T is OPTIONAL, variant-wrap when
                        // U's key reaches the T variant, else the bare element (cg_wrap_elem_str — the
                        // twin of the C helper; mirrors emit_as's value-position wrapping per element).
                        o = match cg_wrap_elem_str(o, prog, T, U, elem) { []byte as r => r; error as err => return err }
                        o = cb(o, "; } (")
                        o = match cg_slice_typename(o, T) { []byte as r => r; error as err => return err }
                        o = cb(o, "){ .ptr = "); o = cb(o, rp); o = cb(o, ", .len = "); o = cb(o, sv); o = cb(o, ".len }; })")
                        return o
                    }
                    return emit_expr_ctx(buf, prog, ret_type, value, escaping, regions, fn_body, dctx)
                }
            }
        }
        _ => { }
    }
    // VARIANT slot wrap (B-cg2) — DIRECT or TRANSITIVE (case→variant→variant). The member is
    // identified by RESOLVED-TYPE equality (the value's KEY == a reachable member's key), so a
    // non-named member (error/prim/slice) wraps too. When the value's key isn't reachable in
    // `expected` (it IS the whole variant, or `expected` isn't a variant), the value is emitted
    // plainly. (C: the variant arm of emit_as via emit_variant_wrap.)
    let vkey = match cg_member_key_str(value.type) { str as s => s; error => "" }
    if vkey == "" { return emit_expr_ctx(buf, prog, ret_type, value, escaping, regions, fn_body, dctx) }
    let is_variant_slot = match expected { checker::Variant => true; checker::Named => true; _ => false }
    if is_variant_slot {
        if cg_var_reaches(prog, expected, vkey, 16) {
            return emit_variant_wrap(buf, prog, ret_type, expected, value, escaping, regions, fn_body, dctx)
        }
    }
    emit_expr_ctx(buf, prog, ret_type, value, escaping, regions, fn_body, dctx)
}

// cg_emit_lit_pattern — emit an AST LITERAL pattern bound as a C constant comparable to the
// subject temp `_s` (which already has the subject's C type, so a bare C literal compares
// correctly — the VM's lit_as borrows the subject's width/sign for the same reason). A
// str-literal pattern has NO C value-comparison helper in the runtime (no tk_str eq), so it
// is an honest barrier — the VM DOES support str patterns (name_eq), so this is a true
// codegen-only gap (M.3). (C: `cg_emit_lit_pattern`.)
fn cg_emit_lit_pattern(buf: []byte, lit: parser::Expr) -> []byte | error {
    // descend to the variant `.kind` — `Expr` is `struct { kind: ExprKind }` in the .tks model
    // (the C twin's tk_expr is a tagged union, so its cg_emit_lit_pattern matches `lit` directly —
    // a known parser-AST model divergence between the C bootstrap and the self-host corpus).
    match lit.kind {
        parser::Number as n => {
            if n.is_float { return cb_f64_literal(buf, n.fval) }
            cb_i128(buf, n.value)
        }
        parser::ByteLit as b => cb_i64(buf, b.value to i64)
        parser::StrLit       => error { message = "codegen: string-literal patterns not yet supported (no tk_str equality helper in the runtime)" }
        _                    => error { message = "codegen: unsupported literal in a pattern (parser emits only number/byte/str)" }
    }
}

// cg_emit_tag_prefix — emit a variant tag-constant PREFIX up to and including the second `_`
// (`TK_TAG_<NAME>_` for a named variant, `TK_TAG_U_<UPPER keys…>_` for an inline union), so a
// case suffix can be appended. `variantT` is the subject's variant type. (C: `cg_emit_tag_prefix`.)
fn cg_emit_tag_prefix(buf: []byte, variantT: checker::Type) -> []byte | error {
    mut out = cb(buf, "TK_TAG_")
    match variantT {
        checker::Variant as va => {
            out = cb(out, "U")
            mut j = 0
            loop {
                if j >= va.members.len { break }
                out = cb(out, "_")
                let kj = match cg_member_key_str(va.members[j]) { str as s => s; error as err => return err }
                out = cb_upper(out, kj)
                j++
            }
            cb(out, "_")
        }
        checker::Named as nm => { out = cb_upper(out, nm.name); cb(out, "_") }
        _ => error { message = "codegen: tag prefix over a non-variant subject (internal)" }
    }
}

// cg_emit_case_key_str — a BIND/FIELD pattern's CASE KEY (the union field name + the UPPERCASE
// tag-suffix source). A non-slice case uses its path-last identifier (== the member key for
// named/error/prim); a slice case (`[]T as x`) uses `slice_<elem>`. (C: `cg_emit_case_key`.)
fn cg_emit_case_key_str(pat: parser::Pattern) -> str | error {
    match pat {
        parser::BindPattern as bp => {
            if bp.is_slice {
                match bp.slice_type {
                    null => error { message = "codegen: slice pattern without a slice type (internal)" }
                    parser::TypeExpr as st => cg_member_key_texpr_str(st)
                }
            } else if bp.type_args.len > 0 {
                // (W9.4) `Gen<i64> as x` — the case is the STAMPED instance `Gen__g__i64`, matching the
                // variant typedef's member key (the decl was normalized to the bare stamped name).
                cg_case_name_escaped(cg_texpr_inst_name(cg_path_last(bp.type_name), bp.type_args))
            } else { cg_case_name_escaped(cg_path_last(bp.type_name)) }
        }
        parser::FieldPattern as fp => cg_case_name_escaped(cg_path_last(fp.type_name))
        _ => error { message = "codegen: case key over a non-bind/field pattern (internal)" }
    }
}

// cg_case_name_escaped — keyword-escape a case name (the union FIELD identifier + tag-suffix
// source): a `bool` case → `bool_`, so the destructure `.as.bool_` and tag `TK_TAG_..._BOOL_`
// match the field/tag definitions (cg_member_key escapes the field+tag; the pattern side must
// agree). Mirrors the C `cb_ident` keyword-escape applied in `cg_emit_case_key`.
fn cg_case_name_escaped(name: str) -> str {
    if cg_is_c_keyword(name) { teko::str::concat(name, "_") } else { name }
}

// emit_pat_test — emit the boolean TEST that `_s` (`subj`) matches `pat`. `variantT` is the
// subject's variant type (a Named variant decl or an inline Variant), needed to spell a case's
// tag constant; it is a scalar/void type for a non-variant subject. Mirrors pat_match's
// decisions (binds are separate). (C: `emit_pat_test`.)
fn emit_pat_test(buf: []byte, prog: checker::TProgram, pat: parser::Pattern, subj: str, variantT: checker::Type) -> []byte | error {
    match pat {
        parser::WildcardPattern => cb(buf, "1")
        parser::LiteralPattern as lp => {
            mut out = cb(buf, "(")
            out = cb(out, subj)
            out = cb(out, " == ")
            out = match cg_emit_lit_pattern(out, lp.value) { []byte as o => o; error as err => return err }
            cb(out, ")")
        }
        parser::RangePattern as rp => {
            mut out = cb(buf, "(")
            out = cb(out, subj)
            out = cb(out, " >= ")
            out = match cg_emit_lit_pattern(out, rp.lo) { []byte as o => o; error as err => return err }
            out = cb(out, " && ")
            out = cb(out, subj)
            out = cb(out, " <= ")
            out = match cg_emit_lit_pattern(out, rp.hi) { []byte as o => o; error as err => return err }
            cb(out, ")")
        }
        parser::AltPattern as ap => {
            mut out = cb(buf, "(")
            mut i = 0
            loop {
                if i >= ap.options.len { break }
                if i > 0 { out = cb(out, " || ") }
                out = match emit_pat_test(out, prog, ap.options[i], subj, variantT) { []byte as o => o; error as err => return err }
                i++
            }
            cb(out, ")")
        }
        parser::BindPattern as bp0 => {
            // Binding the WHOLE variant value (`TypeExpr as t` where the subject IS the TypeExpr
            // variant — common over an optional `TypeExpr?`): NOT a case-select. The value already
            // IS that variant, so the test is unconditionally true (any gating .present check is
            // upstream); the bind copies the whole value (cg_emit_pat_binds).
            let bind_whole = match variantT {
                checker::Named as nm => (!bp0.is_slice) && (cg_path_last(bp0.type_name) == nm.name)
                _ => false
            }
            if bind_whole { return cb(buf, "1") }
            // An ENUM subject has no tag+union: a member pattern tests value equality against the
            // enum constant `TK_E_<ENUM>_<MEMBER>` (matches emit_type_decl's enum emission).
            let is_enum = match variantT { checker::Named as nm => cg_named_is_enum(prog, nm.name); _ => false }
            if is_enum {
                let ename = match variantT { checker::Named as nm => nm.name; _ => "" }
                mut oe = cb(buf, "(")
                oe = cb(oe, subj)
                oe = cb(oe, " == TK_E_")
                oe = cb_upper(oe, ename)
                oe = cb(oe, "_")
                let cke = match cg_emit_case_key_str(pat) { str as s => s; error as err => return err }
                oe = cb_upper(oe, cke)
                return cb(oe, ")")
            }
            mut out = cb(buf, "(")
            out = cb(out, subj)
            out = cb(out, ".tag == ")
            out = match cg_emit_tag_prefix(out, variantT) { []byte as o => o; error as err => return err }
            let ck = match cg_emit_case_key_str(pat) { str as s => s; error as err => return err }
            out = cb_upper(out, ck)
            cb(out, ")")
        }
        parser::FieldPattern => {
            mut out = cb(buf, "(")
            out = cb(out, subj)
            out = cb(out, ".tag == ")
            out = match cg_emit_tag_prefix(out, variantT) { []byte as o => o; error as err => return err }
            let ck = match cg_emit_case_key_str(pat) { str as s => s; error as err => return err }
            out = cb_upper(out, ck)
            cb(out, ")")
        }
        // A `null` pattern reaches here only over a NON-optional subject (the optional case is
        // handled by cg_emit_pat_test's `.present` test) — the checker rejects that.
        parser::NullPattern => error { message = "codegen: `null` pattern over a non-optional subject (internal)" }
    }
}

// AST struct-vs-kind DESCEND. The .tks parser/typed AST models `Expr`/`TExpr`/… as
// `struct { kind: <variant>; … }`, but the corpus matches such a value DIRECTLY against the
// variant's cases (`match e { Number => … }`). If `subjT` is a NAMED struct with a `kind` field
// of a VARIANT type and `pat` selects a CASE of that variant, return the variant type V and
// whether the kind field is boxed, so the match lowers on `<subj>.kind` (deref if boxed). The C
// twin uses out-params + a bool; here we return `CgKindDescend?` — `null` means "do not descend".
// (C: `cg_kind_descend`.)
type CgKindDescend = struct { var_type: checker::Type; boxed: bool }

fn cg_kind_descend(prog: checker::TProgram, subjT: checker::Type, pat: parser::Pattern) -> CgKindDescend? {
    let sname = match subjT { checker::Named as nm => nm.name; _ => return null }
    match pat {
        parser::BindPattern => { }
        parser::FieldPattern => { }
        _ => return null
    }
    let d = match cg_find_decl(prog, sname) { parser::TypeDecl as dd => dd; error => return null }
    let sb = match d.body { parser::StructBody as s => s; _ => return null }
    // find a field named `kind` whose type-ann is a NAMED type.
    mut kfte: parser::TypeExpr? = null
    mut i = 0
    loop {
        if i >= sb.fields.len { break }
        if sb.fields[i].name == "kind" { kfte = sb.fields[i].type_ann; break }
        i++
    }
    let fte = match kfte { null => return null; parser::TypeExpr as t => t }
    let vname = match fte { parser::NamedType as nt => cg_path_last(nt.path); _ => return null }
    if !cg_named_is_variant(prog, vname) { return null }
    let v = checker::Named { name = vname }
    // the pattern must select a CASE of V (not a field-destructure of the struct itself).
    let key = match cg_emit_case_key_str(pat) { str as s => s; error => return null }
    if !cg_var_reaches(prog, v, key, 2) { return null }
    CgKindDescend { var_type = v; boxed = cg_field_boxed(prog, sname, fte) }
}

// cg_kind_derived_subj — the descended subject string: boxed → `(*(SUBJ).kind)`, unboxed →
// `(SUBJ).kind`. Mirrors the C snprintf `%s(%s).kind%s` with `(*`/`)` around when boxed.
fn cg_kind_derived_subj(subj: str, boxed: bool) -> str {
    mut o: []byte = teko::list::empty()
    if boxed { o = cb(o, "(*") }
    o = cb(o, "(")
    o = cb(o, subj)
    o = cb(o, ").kind")
    if boxed { o = cb(o, ")") }
    str(o)
}

// cg_emit_pat_test — TOP-LEVEL pattern test (handles an OPTIONAL subject — REBOOT_PLAN §202).
// `subjT` is the subject's resolved type; `subj` is the subject temp name (a tk_opt_<inner>
// struct when optional). For an optional subject: `null` ⇒ `(!_s.present)`; a bare bind/wildcard
// over a NON-variant present value ⇒ `(_s.present)`; otherwise ⇒ `(_s.present && <inner test>)`.
// For a non-optional subject it delegates to emit_pat_test. (C: `cg_emit_pat_test`.)
fn cg_emit_pat_test(buf: []byte, prog: checker::TProgram, pat: parser::Pattern, subj: str, subjT: checker::Type) -> []byte | error {
    // AST descend: `match e { Number => }` over `e: Expr = struct{kind: ExprKind}` lowers on e.kind.
    match cg_kind_descend(prog, subjT, pat) {
        CgKindDescend as kd => {
            let ds = cg_kind_derived_subj(subj, kd.boxed)
            return cg_emit_pat_test(buf, prog, pat, ds, kd.var_type)
        }
        null => { }
    }
    match subjT {
        checker::Optional as opt => {
            match opt.inner {
                checker::Void => { }   // sentinel — never a real match subject; fall through
                _ => {
                    match pat {
                        parser::NullPattern => { mut o = cb(buf, "(!"); o = cb(o, subj); return cb(o, ".present)") }
                        _ => { }
                    }
                    let inner_is_variant = match opt.inner {
                        checker::Variant => true
                        checker::Named as nm => cg_named_is_variant(prog, nm.name)
                        _ => false
                    }
                    // bare bind/wildcard over a NON-variant present value matches whenever present.
                    match pat {
                        parser::WildcardPattern => { if !inner_is_variant { mut o = cb(buf, "("); o = cb(o, subj); return cb(o, ".present)") } }
                        parser::BindPattern     => { if !inner_is_variant { mut o = cb(buf, "("); o = cb(o, subj); return cb(o, ".present)") } }
                        _ => { }
                    }
                    let val = cb_to_str(subj, ".value")
                    mut o2 = cb(buf, "(")
                    o2 = cb(o2, subj)
                    o2 = cb(o2, ".present && ")
                    o2 = match emit_pat_test(o2, prog, pat, val, opt.inner) { []byte as o => o; error as err => return err }
                    return cb(o2, ")")
                }
            }
        }
        _ => { }
    }
    emit_pat_test(buf, prog, pat, subj, subjT)
}

// cb_to_str — `<a><b>` as a fresh str (the `_s.value` accessor for an optional present subject).
fn cb_to_str(a: str, b: str) -> str { str(cb(cb(teko::list::empty(), a), b)) }

// emit_pat_binds — emit the BINDINGS a pattern introduces (BIND `as x`, FIELD fields), at
// the top of the arm block (in scope for the guard and the body). Mirrors pat_match's
// env_define calls; scalar/Alt/Wildcard patterns bind nothing. C23 `auto` gives each binding
// the exact C type without a field-type lookup (`_s.as.<Type>.f` already carries it).
// (C: `emit_pat_binds`.)
fn emit_pat_binds(buf: []byte, pat: parser::Pattern, subj: str, indent: str) -> []byte | error {
    match pat {
        parser::BindPattern as bp => {
            if bp.has_binding {
                // `Foo as x` binds the WHOLE case value (the union member, named by its KEY:
                // bare name for named/error/prim, `slice_<elem>` for `[]T as x`).
                mut out = cb(buf, indent)
                out = cb(out, "auto ")
                out = cb_str(out, bp.binding)
                out = cb(out, " = ")
                out = cb(out, subj)
                out = cb(out, ".as.")
                let ck = match cg_emit_case_key_str(pat) { str as s => s; error as err => return err }
                out = cb_str(out, ck)
                cb(out, ";\n")
            } else { buf }
        }
        parser::FieldPattern as fp => {
            mut out = buf
            mut i = 0
            loop {
                if i >= fp.fields.len { break }
                out = cb(out, indent)
                out = cb(out, "auto ")
                out = cb_str(out, fp.fields[i])
                out = cb(out, " = ")
                out = cb(out, subj)
                out = cb(out, ".as.")
                let ck = match cg_emit_case_key_str(pat) { str as s => s; error as err => return err }
                out = cb_str(out, ck)
                out = cb(out, ".")
                out = cb_str(out, fp.fields[i])
                out = cb(out, ";\n")
                i++
            }
            out
        }
        _ => buf   // WILDCARD/LITERAL/RANGE/ALT/NULL bind nothing
    }
}

// cg_emit_pat_binds — TOP-LEVEL pattern binds (handles an OPTIONAL subject — REBOOT_PLAN §202).
// For an optional present pattern the inner value is `_s.value`: a bare `T as x` binds it
// directly (any non-variant inner); a FIELD destructure reads fields off it directly; a variant
// inner binds via the variant union. For a non-optional subject it delegates to emit_pat_binds.
// (C: `cg_emit_pat_binds`.)
fn cg_emit_pat_binds(buf: []byte, prog: checker::TProgram, pat: parser::Pattern, subj: str, subjT: checker::Type, indent: str) -> []byte | error {
    // AST descend (mirror cg_emit_pat_test): a case pattern over `Expr`/`TExpr` binds off `.kind`.
    match cg_kind_descend(prog, subjT, pat) {
        CgKindDescend as kd => {
            let ds = cg_kind_derived_subj(subj, kd.boxed)
            return cg_emit_pat_binds(buf, prog, pat, ds, kd.var_type, indent)
        }
        null => { }
    }
    match subjT {
        checker::Optional as opt => {
            match opt.inner {
                checker::Void => { }
                _ => {
                    match pat { parser::NullPattern => return buf; _ => { } }   // NONE binds nothing
                    let inner_is_variant = match opt.inner {
                        checker::Variant => true
                        checker::Named as nm => cg_named_is_variant(prog, nm.name)
                        _ => false
                    }
                    let val = cb_to_str(subj, ".value")
                    // bare `T as x` over a non-variant present value binds the inner directly.
                    match pat {
                        parser::BindPattern as bp => {
                            if !inner_is_variant {
                                if bp.has_binding {
                                    mut o = cb(buf, indent); o = cb(o, "auto "); o = cb_str(o, bp.binding)
                                    o = cb(o, " = "); o = cb(o, val); return cb(o, ";\n")
                                }
                                return buf
                            }
                            // A bind whose type IS the inner variant itself (`TypeExpr as t` over
                            // `TypeExpr?`) binds the WHOLE present value, not a `.as.<case>` member.
                            let bind_whole = match opt.inner {
                                checker::Named as nm => (!bp.is_slice) && (cg_path_last(bp.type_name) == nm.name)
                                _ => false
                            }
                            if bind_whole {
                                if bp.has_binding {
                                    mut o = cb(buf, indent); o = cb(o, "auto "); o = cb_str(o, bp.binding)
                                    o = cb(o, " = "); o = cb(o, val); return cb(o, ";\n")
                                }
                                return buf
                            }
                        }
                        parser::FieldPattern as fp => {
                            if !inner_is_variant {
                                mut o = buf
                                mut i = 0
                                loop {
                                    if i >= fp.fields.len { break }
                                    o = cb(o, indent); o = cb(o, "auto "); o = cb_str(o, fp.fields[i])
                                    o = cb(o, " = "); o = cb(o, val); o = cb(o, "."); o = cb_str(o, fp.fields[i]); o = cb(o, ";\n")
                                    i++
                                }
                                return o
                            }
                        }
                        _ => { }
                    }
                    return emit_pat_binds(buf, pat, val, indent)   // variant inner: bind via the union over _s.value
                }
            }
        }
        _ => { }
    }
    // Non-optional bind-WHOLE-variant (`TypeExpr as t` where the subject IS the TypeExpr variant)
    // binds the whole value, not a `.as.<case>`.
    match pat {
        parser::BindPattern as bp => {
            let bind_whole = match subjT {
                checker::Named as nm => (!bp.is_slice) && (cg_path_last(bp.type_name) == nm.name)
                _ => false
            }
            if bind_whole {
                if bp.has_binding {
                    mut o = cb(buf, indent); o = cb(o, "auto "); o = cb_str(o, bp.binding)
                    o = cb(o, " = "); o = cb(o, subj); return cb(o, ";\n")
                }
                return buf
            }
        }
        _ => { }
    }
    emit_pat_binds(buf, pat, subj, indent)
}

// cg_block_diverges — does a typed block DIVERGE (exit via return/break/continue on every
// path)? True when its trailing statement is a return/break/continue, or a trailing if-with-
// else / match whose every branch / arm diverges. Mirrors the checker's tblock_diverges so a
// diverging arm body lowers as real control flow, not a value commit. (C: `cg_block_diverges`.)
fn cg_block_diverges(stmts: []checker::TStatement) -> bool {
    if stmts.len == 0 { return false }
    match stmts[stmts.len - 1] {
        checker::TReturn        => true
        checker::TBreakStmt     => true
        checker::TContinueStmt  => true
        checker::TExprStmt as es => match es.expr.kind {
            checker::TIfExpr as f    => f.has_else && cg_block_diverges(f.then_blk) && cg_block_diverges(f.else_blk)
            checker::TMatchExpr as m => {
                if m.arms.len == 0 { return false }
                mut i = 0
                loop {
                    if i >= m.arms.len { break }
                    if !cg_block_diverges(m.arms[i].body) { return false }
                    i++
                }
                true
            }
            _ => false
        }
        _ => false
    }
}

// cg_block_diverges_jump — does a block diverge via a `break`/`continue` (NOT a `return`)? Such
// a jump can't escape a GNU stmt-expr, so a match used as a SUB-expression honest-stops on it —
// the same frontier the VM enforces (eval_match). A `return` divergence is fine. (C: `cg_block_diverges_jump`.)
fn cg_block_diverges_jump(stmts: []checker::TStatement) -> bool {
    if stmts.len == 0 { return false }
    match stmts[stmts.len - 1] {
        checker::TBreakStmt     => true
        checker::TContinueStmt  => true
        checker::TExprStmt as es => match es.expr.kind {
            checker::TIfExpr as f    => f.has_else && (cg_block_diverges_jump(f.then_blk) || cg_block_diverges_jump(f.else_blk))
            checker::TMatchExpr as m => {
                mut i = 0
                loop {
                    if i >= m.arms.len { break }
                    if cg_block_diverges_jump(m.arms[i].body) { return true }
                    i++
                }
                false
            }
            _ => false
        }
        _ => false
    }
}

// emit_arm_value — emit an arm body BLOCK in VALUE position. All-but-last statements emit
// normally; the trailing value flows into `sink`, wrapped to the match result type via emit_as,
// then `break` commits. A `return`-DIVERGING arm (`=> return e` — THE dominant idiom) emits real
// control flow (a `return …;` leaves the whole function) and never commits to `sink`. A break/
// continue divergence is an HONEST STOP (it can't escape a stmt-expr), the same frontier the VM
// enforces (eval_match). (C: `emit_arm_value`.)
fn emit_arm_value(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, match_e: checker::TExpr, body: []checker::TStatement, sink: str, ci: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    if cg_block_diverges_jump(body) {
        return error { message = "codegen: break/continue inside a `match` used as a sub-expression not yet supported" }
    }
    if cg_block_diverges(body) {
        // `return`-divergence: emit every statement as-is; the trailing `return e` (or a diverging
        // trailing if/match) leaves the ENCLOSING FUNCTION — so its value wraps into the FUNCTION's
        // return type (ret_type, the C's g_cg_ret_type), NOT the match result type. No `sink =` /
        // `break`. No arm region here (the arm never commits to `sink`; a `return` inside drops all
        // active regions via the region-stack helpers). (C: emit_arm_value's diverging branch.)
        mut out = buf
        mut cur = dctx   // (W9.3) accumulate this arm's direct defers so the trailing `return e` fires [0, …) correctly
        mut i = 0
        loop {
            if i + 1 >= body.len { break }
            match body[i] {
                checker::TDeferStmt => { cur = dctx_register(cur, body[i]) }
                _ => { out = match emit_stmt(out, body[i], false, prog, ret_type, ci, "", escaping, regions, fn_body, cur, teko::list::empty(), false) { []byte as o => o; error as err => return err } }
            }
            i++
        }
        let last = body[body.len - 1]
        return match last {
            checker::TExprStmt as es => match es.expr.kind {
                checker::TIfExpr as _    => emit_exprstmt_tail(out, es.expr, false, prog, ret_type, ci, "", escaping, fn_body, cur)
                checker::TMatchExpr as _ => emit_exprstmt_tail(out, es.expr, false, prog, ret_type, ci, "", escaping, fn_body, cur)
                _              => emit_stmt(out, last, false, prog, ret_type, ci, "", escaping, regions, fn_body, cur, teko::list::empty(), false)
            }
            _ => emit_stmt(out, last, false, prog, ret_type, ci, "", escaping, regions, fn_body, cur, teko::list::empty(), false)
        }
    }
    // Value form: all-but-last normally; the trailing value → `sink` (wrapped), then `break`.
    // ret_type is the FUNCTION's return type (not Void): a non-last statement may itself be a
    // `return e` (e.g. `_ => { if cond { return error{…} }; v }`), and that `return` must wrap its
    // value into the fn's return slot — a Void slot left an error returned bare.
    // S2/W9: when the arm body has a provably BLOCK-LOCAL binding (is_value=TRUE → the predicate
    // EXCLUDES any binding flowing into the tail value / assign-RHS), open the arm's OWN `_tkbr<len>`
    // region for those NON-tail block-locals. ORDERING (W9 trap): the tail value is materialized into
    // `sink` (enclosing) FIRST, then the region drops BEFORE the `break`. No block-local ⇒ no region ⇒
    // byte-identical to the pre-W9 value-arm output. (C: emit_arm_value.)
    let base = dctx.defers.len   // (W9.3) defer scope base for this value-arm
    let want_block = cg_block_has_block_local(escaping, fn_body, body, true) && regions.len < 64
    let region = if want_block { fresh_named("_tkbr", buf.len to i64) } else { "" }
    let regs2 = if want_block { teko::list::push(regions, RegionFrame { name = region; label = ""; is_loop = false; defer_base = base }) } else { regions }
    let cur_blk = if want_block { body } else { teko::list::empty() }
    mut out = buf
    if want_block {
        out = cb(out, ci); out = cb(out, "tk_region *"); out = cb(out, region); out = cb(out, " = tk_region_new();\n")
    }
    mut cur = dctx
    mut i = 0
    loop {
        if i + 1 >= body.len { break }
        match body[i] {
            checker::TDeferStmt => { cur = dctx_register(cur, body[i]) }
            _ => { out = match emit_stmt(out, body[i], false, prog, ret_type, ci, "", escaping, regs2, fn_body, cur, cur_blk, want_block) { []byte as o => o; error as err => return err } }
        }
        i++
    }
    if body.len == 0 { return error { message = "codegen: empty match arm body in value position" } }
    let fall = cg_append_direct_defers(dctx.defers, body)   // (W9.3) this value-arm's direct defers
    let last = body[body.len - 1]
    match last {
        checker::TExprStmt as es => {
            out = cb(out, ci)
            out = cb(out, sink)
            out = cb(out, " = (")
            // A trailing diverging expr (`=> panic(…)` / `exit(…)` — _Noreturn void, not a `return`)
            // can't be assigned to the sink. Emit `(panic(…), (T){0})`: the call diverges, the
            // zero-of-T makes the assignment type-check (unreachable). Mirrors the `??` fallback.
            // The tail rides the ENCLOSING region context (regs2 is is_value=true → block-locals
            // excluded, so a binding read here routes to the enclosing region, never `_tkbr<len>`).
            if cg_expr_diverges(es.expr) {
                out = match emit_expr_ctx(out, prog, checker::Void { }, es.expr, escaping, regs2, fn_body, cur) { []byte as o => o; error as err => return err }
                out = cb(out, ", (")
                out = match emit_type(out, match_e.type) { []byte as o => o; error as err => return err }
                out = cb(out, "){0}")             // sink's `( … )` closes it
            } else {
                out = match emit_as_r(out, prog, ret_type, match_e.type, es.expr, escaping, regs2, fn_body, cur) { []byte as o => o; error as err => return err }
            }
            out = cb(out, ");")
            if want_block {
                // (W9.3) Tail is materialized into `sink`. Fire THIS value-arm's defers (LIFO) if any —
                // on their own lines (only when present, so the no-defer output stays byte-identical to
                // the pre-W9.3 inline form) — BEFORE dropping the arm region on `break`.
                if fall.len > base {
                    out = cb(out, "\n")
                    out = match emit_defers(out, fall, base, prog, ci, escaping, fn_body) { []byte as o => o; error as err => return err }
                    out = cb(out, ci); out = cb(out, "tk_region_drop("); out = cb(out, region); out = cb(out, "); "); out = cb(out, region); out = cb(out, " = NULL;")
                } else {
                    // No defers: keep the original inline ` tk_region_drop(…)` form (byte-identical to pre-W9.3).
                    out = cb(out, " tk_region_drop("); out = cb(out, region); out = cb(out, "); "); out = cb(out, region); out = cb(out, " = NULL;")
                }
                cb(out, " break;\n")
            } else if fall.len > base {
                // (W9.3) No region, but this value-arm registered defers: the tail is now in `sink`, so fire
                // the arm's defers (LIFO) INSIDE the arm's `{ … }` scope (where the arm-locals are still
                // declared), BEFORE the `break`, then the base resets when this arm's frame unwinds.
                out = cb(out, "\n")
                out = match emit_defers(out, fall, base, prog, ci, escaping, fn_body) { []byte as o => o; error as err => return err }
                out = cb(out, ci); out = cb(out, "break;\n")
                out
            } else {
                cb(out, " break;\n")
            }
        }
        _ => error { message = "codegen: non-value trailing statement in a match arm used as a value" }
    }
}

// emit_match_value — VALUE form: a GNU statement-expression yielding the matched arm's body
// value (the SAME selection structure as the tail/stmt forms, but committing the trailing value
// with `_r = <body>; break;` inside a `do {…} while (0)`):
//   ({ <SubjCType> _sN = (<subject>); <ResultCType> _rN; do {
//        if (<test0>) { <binds0> [if (<guard0>)] { <arm body → _rN; break;> } } … } while (0); _rN; })
// The non-`else` `if` chain gives the VM's first-match-with-guard order; a failed guard
// falls through to the next arm. Exhaustiveness (checker-guaranteed) means the chain always
// commits before the `while (0)` exits. (C: `emit_match_value`.)
fn emit_match_value(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, e: checker::TExpr, m: checker::TMatchExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    // S2/W9: `escaping`/`regions`/`fn_body` thread the enclosing block-region context so each value-arm
    // can open its OWN arm region for its block-local NON-tail bindings (emit_arm_value). The subject
    // and guards are emitted in the SAME enclosing context (the C twin reads its live globals there).
    let subj = fresh_named("_s", buf.len to i64)
    let res  = fresh_named("_r", buf.len to i64 + 1)   // +1 so it differs from subj
    let subjT = m.subject.type   // for optional / variant pattern lowering
    mut out = cb(buf, "({ ")
    out = match emit_type(out, m.subject.type) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb(out, subj)
    out = cb(out, " = (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, m.subject, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, "); ")
    out = match emit_type(out, e.type) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb(out, res)
    out = cb(out, "; do {\n")
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        let arm = m.arms[i]
        out = cb(out, "    if (")
        out = match cg_emit_pat_test(out, prog, arm.pattern, subj, subjT) { []byte as o => o; error as err => return err }
        out = cb(out, ") {\n")
        out = match cg_emit_pat_binds(out, prog, arm.pattern, subj, subjT, "        ") { []byte as o => o; error as err => return err }
        mut ci = "        "
        if arm.has_when {
            out = cb(out, "        if (")
            out = match emit_expr_ctx(out, prog, checker::Void { }, arm.guard, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, ") {\n")
            ci = "            "
        }
        // the arm body is a BLOCK (B.20): its trailing value flows into _r (wrapped to the
        // match result type), or a diverging arm (`=> return e`) emits real control flow.
        out = match emit_arm_value(out, prog, ret_type, e, arm.body, res, ci, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        if arm.has_when { out = cb(out, "        }\n") }
        out = cb(out, "    }\n")
        i++
    }
    out = cb(out, "    } while (0); ")
    out = cb(out, res)
    cb(out, "; })")
}

// emit_match_tail — TAIL form: each winning arm `return`s its body, as an `if` chain inside a
// brace block holding the subject temp. The FIRST winning arm runs its block and then `goto`s a
// unique commit label past the chain (so the search stops at the first match — mirrors the VM).
// The `goto` is essential: a tail match in a `-> void` fn has arm bodies that do NOT diverge
// (no implicit `return`), so without the commit jump MULTIPLE arms would fall through and all
// fire. A failed `when` guard naturally falls through to the next arm (the goto is INSIDE the
// guard block). `ret_type` threads the fn return type so a tail arm body that yields a case value
// into a variant return slot is wrapped (emit_as). (C: `emit_match_tail`.)
fn emit_match_tail(buf: []byte, prog: checker::TProgram, e: checker::TExpr, m: checker::TMatchExpr, in_main: bool, ret_type: checker::Type, indent: str, escaping: []str, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let subj = fresh_named("_s", buf.len to i64)
    let done = teko::str::concat(fresh_named("tk_mt", buf.len to i64 + 1), "_done")   // unique commit label (str concat — no `+` on str)
    let subjT = m.subject.type   // for optional / variant pattern lowering
    let inner = cb_indent_deeper(indent)
    let inner2 = cb_indent_deeper(inner)
    mut out = cb(buf, indent)
    out = cb(out, "{\n")
    out = cb(out, inner)
    out = match emit_type(out, m.subject.type) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb(out, subj)
    out = cb(out, " = (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, m.subject, escaping, teko::list::empty(), fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, ");\n")
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        let arm = m.arms[i]
        out = cb(out, inner)
        out = cb(out, "if (")
        out = match cg_emit_pat_test(out, prog, arm.pattern, subj, subjT) { []byte as o => o; error as err => return err }
        out = cb(out, ") {\n")
        out = match cg_emit_pat_binds(out, prog, arm.pattern, subj, subjT, inner2) { []byte as o => o; error as err => return err }
        mut ci = inner2
        if arm.has_when {
            out = cb(out, inner2)
            out = cb(out, "if (")
            out = match emit_expr_ctx(out, prog, checker::Void { }, arm.guard, escaping, teko::list::empty(), fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, ") {\n")
            ci = cb_indent_deeper(inner2)
        }
        // the arm body is a BLOCK in TAIL position (B.20): emit it as a tail block — its
        // trailing value becomes a `return`, and an explicit return/break/continue inside it
        // emits real C control flow (mirrors the VM running the arm block flow-aware).
        // (Frameless: a return inside an arm leaks the frame region — SAFE, M.5.) S2 — the REAL
        // `escaping` is threaded (NOT empty) so a statement-arm inside this match arm gets correct
        // block-locality (matches the C twin's global g_cg_escaping; empty would false-positive).
        // (W9.3) The arm is a DEFER SCOPE: record the defer base, emit the body, then fire `[base, …)`
        // LIFO BEFORE the commit `goto` — UNLESS the arm's tail already C-terminated (a return inside
        // already drained base 0 on its edge; a void fall-through arm fires here).
        let tarm_base = dctx.defers.len
        out = match emit_block_tail(out, arm.body, in_main, prog, ret_type, ci, "", escaping, fn_body, dctx) { []byte as o => o; error as err => return err }
        let tarm_term = if arm.body.len > 0 { cg_stmt_c_terminates(arm.body[arm.body.len - 1]) } else { false }
        if !tarm_term { out = match emit_defers(out, cg_append_direct_defers(dctx.defers, arm.body), tarm_base, prog, ci, escaping, fn_body) { []byte as o => o; error as err => return err } }
        // FIRST match wins → jump past the remaining arms. After a diverging body (return/exit/
        // panic) this is dead code (cc sees the generated C with `-w`); after a non-diverging
        // void body it is the line that stops later arms from also firing.
        out = cb(out, ci)
        out = cb(out, "goto ")
        out = cb(out, done)
        out = cb(out, ";\n")
        if arm.has_when { out = cb(out, inner2); out = cb(out, "}\n") }
        out = cb(out, inner)
        out = cb(out, "}\n")
        i++
    }
    out = cb(out, inner)
    out = cb(out, done)
    out = cb(out, ": ;\n")
    out = cb(out, indent)
    cb(out, "}\n")
}

// emit_match_stmt — STATEMENT form: a match whose result is DISCARDED (run each winning arm
// body for effect). An `if` chain inside a brace block; the FIRST winning arm runs its block and
// then `goto`s a unique commit label past the chain. The commit uses a GOTO (not a `do {…}
// while(0)` + break) precisely because an arm body is a BLOCK that may contain `break`/`continue`
// targeting an ENCLOSING loop — those must be real C break/continue, never swallowed by a wrapper
// (mirrors the VM propagating the arm's flow). (C: `emit_match_stmt`.)
fn emit_match_stmt(buf: []byte, prog: checker::TProgram, e: checker::TExpr, m: checker::TMatchExpr, in_main: bool, ret_type: checker::Type, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx, cur_block: []checker::TStatement, cur_block_is_value: bool) -> []byte | error {
    let subj = fresh_named("_s", buf.len to i64)
    let done = teko::str::concat(fresh_named("tk_m", buf.len to i64 + 1), "_done")   // unique commit label (str concat — no `+` on str)
    let subjT = m.subject.type   // for optional / variant pattern lowering
    let inner = cb_indent_deeper(indent)
    let inner2 = cb_indent_deeper(inner)
    mut out = cb(buf, indent)
    out = cb(out, "{\n")
    out = cb(out, inner)
    out = match emit_type(out, m.subject.type) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb(out, subj)
    out = cb(out, " = (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, m.subject, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, ");\n")
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        let arm = m.arms[i]
        out = cb(out, inner)
        out = cb(out, "if (")
        out = match cg_emit_pat_test(out, prog, arm.pattern, subj, subjT) { []byte as o => o; error as err => return err }
        out = cb(out, ") {\n")
        out = match cg_emit_pat_binds(out, prog, arm.pattern, subj, subjT, inner2) { []byte as o => o; error as err => return err }
        mut ci = inner2
        if arm.has_when {
            out = cb(out, inner2)
            out = cb(out, "if (")
            out = match emit_expr_ctx(out, prog, checker::Void { }, arm.guard, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, ") {\n")
            ci = cb_indent_deeper(inner2)
        }
        // run the arm body BLOCK for effect (value discarded); break/continue/return inside it
        // propagate via C's own semantics. Thread ret_type so `return null` inside an arm
        // wraps null correctly into the enclosing function's return slot.
        // S2 — the arm body gets its OWN arm region for its block-local bindings (emit_block_region),
        // dropped at the arm's fall-through / via the region stack on break/continue/return.
        out = match emit_block_region(out, arm.body, in_main, prog, ret_type, ci, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        out = cb(out, ci)
        out = cb(out, "goto ")
        out = cb(out, done)
        out = cb(out, ";\n")
        if arm.has_when { out = cb(out, inner2); out = cb(out, "}\n") }
        out = cb(out, inner)
        out = cb(out, "}\n")
        i++
    }
    out = cb(out, inner)
    out = cb(out, done)
    out = cb(out, ": ;\n")
    out = cb(out, indent)
    cb(out, "}\n")
}

// emit_expr — the expression dispatch (the C's emit_expr switch). Unsupported value
// nodes fail with an honest message (M.3). (C: `emit_expr`.)
// emit_number — a TNumber literal. The node's resolved prim (e.type) decides width and
// float-kind (N1/N2). Float literals emit a round-trippable double, cast to the right C
// float type (f64 plain; f32 `(float)`; f16 `(_Float16)`). Integer literals emit the
// decimal value cast to the prim's C type, so the literal carries the right width — a
// u128/i128 literal is wider than any C integer literal can spell on its own.
// (C: the TK_TEXPR_NUMBER branch of emit_expr.)
fn emit_number(buf: []byte, e: checker::TExpr, n: checker::TNumber) -> []byte | error {
    // A numeric literal adopted to `byte` via literal-adoption (e.g. `c < 0x20` where c: byte).
    match e.type {
        checker::Byte => {
            mut o = cb(buf, "((uint8_t)")
            o = cb_i128(o, n.value)
            return cb(o, ")")
        }
        _ => { }
    }
    let k = match e.type {
        checker::Prim as p => p.kind
        _         => return error { message = "codegen: numeric literal with a non-primitive type not yet supported" }
    }
    if n.is_float {
        match k {
            checker::PrimKind::F64 => return cb_f64_literal(buf, n.fval)
            checker::PrimKind::F32 => {
                mut o = cb(buf, "(float)(")
                o = cb_f64_literal(o, n.fval)
                return cb(o, ")")
            }
            checker::PrimKind::F16 => {
                mut o = cb(buf, "(_Float16)(")
                o = cb_f64_literal(o, n.fval)
                return cb(o, ")")
            }
            _ => return error { message = "codegen: float literal with a non-float type not yet supported" }
        }
    }
    // integer literal: `((Ctype)<decimal>)`.
    mut out = cb(buf, "((")
    out = match emit_prim(out, k) { []byte as o => o; error as err => return err }
    out = cb(out, ")")
    out = cb_i128(out, n.value)
    cb(out, ")")
}

// emit_expr — a TExpr -> C expression text. `ret_type` threads the ENCLOSING FUNCTION's return
// type (the functional twin of the C's `g_cg_ret_type` static): a value-form `match` whose arm
// DIVERGES via `return e` wraps that value into the FUNCTION return type, not the match-result
// type (emit_arm_value). Every other expr ignores it. (C: `emit_expr`.)
fn emit_expr(buf: []byte, prog: checker::TProgram, e: checker::TExpr) -> []byte | error {
    emit_expr_ctx(buf, prog, checker::Void { }, e, teko::list::empty(), teko::list::empty(), teko::list::empty(), dctx_empty())
}
// emit_expr_ret — emit_expr carrying the enclosing function return type for value-form match
// diverging arms. (S2/W9: the region/escape context defaults empty — a caller with NO enclosing
// block region, e.g. a sub-expression of a frameless construct, gets no value-arm region.)
fn emit_expr_ret(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, e: checker::TExpr) -> []byte | error {
    emit_expr_ctx(buf, prog, ret_type, e, teko::list::empty(), teko::list::empty(), teko::list::empty(), dctx_empty())
}
// emit_expr_ctx — the real dispatch. S2/W9: `escaping`/`regions`/`fn_body` thread the enclosing
// block-region context (the functional twin of the C's g_cg_escaping/g_cg_block_stack/g_cg_fn_body
// globals) so a value-position `if`/`match` REACHED FROM HERE can open its OWN arm region for its
// block-local NON-tail bindings (emit_if_value/emit_match_value → emit_branch_value/emit_arm_value).
// Every other expr just forwards the context unchanged. (C: `emit_expr` — globals, no threading.)
fn emit_expr_ctx(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, e: checker::TExpr, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    match e.kind {
        checker::TNumber as n      => emit_number(buf, e, n)
        // (W10a) a bare top-level-fn reference used as a VALUE → a `tk_closure` literal carrying the
        // C function's address (env = NULL; named fns capture nothing). A plain local emits its name.
        checker::TVar as v         => if v.is_func {
            cb(cb_fn_name(cb(buf, "(tk_closure){ (void*)&"), v.func_ns, v.name), ", (void*)0 }")
        } else {
            cb_ident(buf, v.name)
        }
        checker::TBinary as b      => emit_binary(buf, prog, e, b, escaping, regions, fn_body, dctx)
        checker::TUnary as u       => emit_unary(buf, prog, u, escaping, regions, fn_body, dctx)
        checker::TCompare as c     => emit_compare(buf, prog, c, escaping, regions, fn_body, dctx)
        checker::TCast as c        => emit_cast(buf, prog, e, c, escaping, regions, fn_body, dctx)
        checker::TCall as cl       => emit_call(buf, prog, ret_type, e, cl, escaping, regions, fn_body, dctx)
        checker::TFieldAccess as fa => emit_field_access(buf, prog, fa, escaping, regions, fn_body, dctx)
        checker::TStructInit as si  => emit_struct_init(buf, prog, e, si, escaping, regions, fn_body, dctx)
        checker::TStrLit as s      => emit_strlit(buf, s)
        checker::TByteLit as by    => cb_i64(buf, by.value to i64)   // byte == uint8_t; emit its decimal value (0..255)
        checker::TCharLit as ch    => emit_charlit(buf, ch)         // char — a tk_char {ptr,len} compound literal over its static UTF-8 bytes
        // bool literal (W2) — FULL support: bool already flows through both backends, so
        // emit the C `true`/`false` keyword (C type is `bool`). (C: TK_TEXPR_BOOL branch.)
        checker::TBoolLit as bl    => cb(buf, if bl.value { "true" } else { "false" })
        checker::TIfExpr as f      => emit_if_value(buf, prog, ret_type, e, f, escaping, regions, fn_body, dctx)   // W5a — `if` as a value (GNU stmt-expr)
        checker::TMatchExpr as m   => emit_match_value(buf, prog, ret_type, e, m, escaping, regions, fn_body, dctx)   // W5b — `match` as a value (GNU stmt-expr)
        // null / ?. / ?? — the OPTIONAL value model (REBOOT_PLAN §202/§203; tk_opt_<inner>).
        // A bare `null` in raw expression position has the SENTINEL optional type: it cannot be
        // emitted alone — its concrete type comes from the destination slot via emit_as.
        checker::TNullLit          => error { message = "codegen: a bare `null` needs a known optional type from context (use it where a `T?` is expected)" }
        checker::TSafeFieldAccess as sfa => emit_safe_field_access(buf, prog, e, sfa, escaping, regions, fn_body, dctx)
        checker::TCoalesce as co   => emit_coalesce(buf, prog, e, co, escaping, regions, fn_body, dctx)
        checker::TIndex as ix      => emit_index(buf, prog, e, ix, escaping, regions, fn_body, dctx)   // W5-idx — subscript recv[index] (str + slice, bounds-checked)
        checker::TInterp as in     => emit_interp(buf, prog, in, escaping, regions, fn_body, dctx)     // $"…{expr}…" — nested tk_str_concat over pieces + holes
        checker::TInExpr as ie     => emit_in(buf, prog, ie, escaping, regions, fn_body, dctx)         // Phase 2 — `<lhs> in [ … ]` membership (single-eval, OR of `==`)
        checker::TArrayLit as a    => emit_array_lit(buf, prog, e, a, escaping, regions, fn_body, dctx)   // [ e0, e1, … ] (Increment B+) — build a tk_slice_<elem>
        checker::TPathExpr as pe   => {
            // Enum::Member → C enum constant `TK_E_<UPPER enum>_<UPPER member>`.
            // Flags::Member → pre-emitted C constant `tk_t_<Name>_<UPPER member>` (power-of-2).
            if cg_named_is_flags(prog, pe.enum_name) {
                // (C8.4) flags member: reference the pre-emitted constant tk_t_<Name>_<UPPER member>
                mut out = mangle_type_name(buf, "", pe.enum_name)
                out = cb(out, "_")
                cb_upper(out, pe.member)
            } else {
                mut out = cb(buf, "TK_E_")
                out = cb_upper(out, pe.enum_name)
                out = cb(out, "_")
                cb_upper(out, pe.member)
            }
        }
        // (W10) a closure LITERAL → a `tk_closure` value. The body was lifted to a top-level C
        // function `__tkclo_<lift_id>` by the cg_stamp_lambdas pre-pass. A NON-capturing lambda has
        // env = NULL and the lifted fn is `R(params)` (W10a-compatible call cast). A CAPTURING lambda
        // allocates its env struct and uses the env-first ABI (handled below).
        checker::TLambda as lam => emit_lambda(buf, prog, e, lam, escaping, regions, fn_body, dctx)
    }
}

// (W10) the lifted C function name for a lambda with the given stamp id: `__tkclo_<id>`.
fn lam_fn_name(id: u64) -> str { teko::str::concat("__tkclo_", teko::u64_to_str(id)) }

// (W10) emit a closure literal. Non-capturing → `(tk_closure){ &__tkclo_<id>, (void*)0 }`. Capturing
// → allocate + fill the env struct, then `(tk_closure){ &__tkclo_<id>, env }` (env-first ABI).
fn emit_lambda(buf: []byte, prog: checker::TProgram, e: checker::TExpr, lam: checker::TLambda, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    if lam.captures.len == 0 {
        mut out = cb(buf, "(tk_closure){ (void*)&")
        out = cb_fn_name(out, "", lam_fn_name(lam.lift_id))
        return cb(out, ", (void*)0 }")
    }
    // CAPTURING: allocate the env (`__tkenv_<id>`), fill each capture (by-copy value, or the Ref cell
    // for a by_ref capture), and build the closure. Uses a GNU statement-expression so the env pointer
    // is materialized once. The env is region-allocated (root region — sound; escape promotes it).
    mut out = cb(buf, "({ __tkenv_")
    out = cb(out, teko::u64_to_str(lam.lift_id))
    out = cb(out, " *_tke = tk_region_alloc(tk_region_root(), sizeof(__tkenv_")
    out = cb(out, teko::u64_to_str(lam.lift_id))
    out = cb(out, ")); ")
    mut i = 0
    loop {
        if i >= lam.captures.len { break }
        out = cb(out, "_tke->")
        out = cb_ident(out, lam.captures[i].name)
        out = cb(out, " = ")
        out = cb_ident(out, lam.captures[i].name)   // by-copy snapshot, or the Ref pointer for a by_ref capture
        out = cb(out, "; ")
        i++
    }
    out = cb(out, "(tk_closure){ (void*)&")
    out = cb_fn_name(out, "", lam_fn_name(lam.lift_id))
    cb(out, ", (void*)_tke }; })")
}

// ---------------------------------------------------------------------------
// Statements -> C. `in_main` selects the return lowering:
//   * in main : `return n` -> `return (int)(n);`  (early process exit)
//   * in a fn : `return n` -> `return n;`
// ---------------------------------------------------------------------------

// ── S2 — PER-BLOCK arena regions (codegen twin of codegen.c). Each scope-introducing LOOP body
// opens its OWN region `_tkbr<len>` for its provably-block-local allocations, dropped at every exit
// edge. `RegionFrame` is one active loop-body region on the stack (innermost LAST); `label` ties it
// to its loop so a labeled break/continue drops exactly the regions it crosses. The per-block escape
// query is checker::binding_is_block_local. SAFETY IS ABSOLUTE — a binding is block-routed ONLY when
// proven block-local; otherwise it falls back to the frame/root (W8 = a leak, never a UAF).
// `is_loop` distinguishes a LOOP-body region (a valid break/continue target) from an ARM-body region
// (an if-then/if-else/match-arm block region — S2 arms): a break/continue CROSSES an arm region (drops
// it) but STOPS only AT the innermost matching loop region, never at an arm region.
// (W9.3) `defer_base` is the count of in-scope defers (dctx.defers.len) at this scope-block's entry —
// the boundary below which defers belong to ENCLOSING scopes. Kept on the frame for structural parity
// with the C twin (cg_block_region.defer_base); the Teko twin tracks the live count via `dctx.defers`.
type RegionFrame = struct { name: str; label: str; is_loop: bool; defer_base: u64 }

// (W9.3) LoopDeferFrame — one active LOOP scope's defer base (dctx.defers.len at the loop's body entry).
// A break/continue fires every defer registered at index ≥ the TARGET loop's base (the scopes it
// crosses), LIFO. The Teko twin opens a RegionFrame only when a loop has a block-local, so loop defer
// bases ride this SEPARATE stack (the C twin records defer_base on EVERY block-stack entry, incl.
// region-less ones; this parallel stack is the region-less-aware twin). `label` ties it to its loop.
type LoopDeferFrame = struct { label: str; defer_base: u64 }

// (W9.3) DeferCtx — the threaded defer state (the functional twin of the C's g_cg_defers/g_cg_ndefers
// statics). `defers` is the live stack of registered TDeferStmt nodes (push order; `.len` == ndefers);
// `loops` is the active loop-scope defer-base stack (for break/continue target firing). One bundle so
// the whole emit path threads a SINGLE extra param. A TDeferStmt appends to `defers` (emits nothing);
// a scope-block fires `[base, len)` LIFO at its exit edge (fall-through / break / continue / return).
type DeferCtx = struct { defers: []checker::TStatement; loops: []LoopDeferFrame }

// dctx_empty — the no-defers context (function entry / frameless sub-expression with no enclosing defers).
fn dctx_empty() -> DeferCtx {
    DeferCtx { defers = teko::list::empty(); loops = teko::list::empty() }
}

// (W9.3) emit_defers — emit the deferred blocks at index ≥ `base` in LIFO order (innermost / most-recent
// first), each body statement via emit_stmt at the exit edge's `indent`. The functional twin of the C's
// emit_defers (which walks g_cg_defers[base..ndefers) backwards). A defer body never contains a return/
// break/continue/defer (checker-enforced), so each body statement emits with NO active region/defer
// scope of its own (regions/dctx empty) — exactly matching the C twin's emit_stmt at base context.
fn emit_defers(buf: []byte, defers: []checker::TStatement, base: u64, prog: checker::TProgram, indent: str, escaping: []str, fn_body: []checker::TStatement) -> []byte | error {
    mut out = buf
    mut i = defers.len
    loop {
        if i <= base { break }
        i = i - 1
        match defers[i] {
            checker::TDeferStmt as d => {
                mut j: u64 = 0
                loop {
                    if j >= d.body.len { break }
                    out = match emit_stmt(out, d.body[j], false, prog, checker::Void { }, indent, "", escaping, teko::list::empty(), fn_body, dctx_empty(), teko::list::empty(), false) { []byte as o => o; error as err => return err }
                    j++
                }
            }
            _ => { }
        }
    }
    out
}

// (W9.3) dctx_register — return `dctx` with statement `s` pushed onto the defer stack (used when a
// TDeferStmt is reached). Mirrors the C `g_cg_defers[g_cg_ndefers++] = s` registration (emits nothing).
fn dctx_register(dctx: DeferCtx, s: checker::TStatement) -> DeferCtx {
    DeferCtx { defers = teko::list::push(dctx.defers, s); loops = dctx.loops }
}

// (W9.3) cg_append_direct_defers — append every TOP-LEVEL TDeferStmt in `body` (source order) onto
// `defers`. A block's fall-through fires its OWN direct defers `[base, base+count)` — reached only
// after the whole block ran, so ALL its direct defers are registered. The caller (emit_function /
// emit_exprstmt_tail tail-if branch / emit_match_tail arm) builds the full list with this, then fires
// `emit_defers([base, len))`. Same defer NODES as emit_block_tail's incremental accumulation, so the
// fired bytes match the C twin's emit_defers exactly. (C: g_cg_ndefers after the block emits.)
fn cg_append_direct_defers(defers: []checker::TStatement, body: []checker::TStatement) -> []checker::TStatement {
    mut out = defers
    mut i: u64 = 0
    loop {
        if i >= body.len { break }
        match body[i] {
            checker::TDeferStmt => { out = teko::list::push(out, body[i]) }
            _ => { }
        }
        i++
    }
    out
}

// (W9.3) cg_target_defer_base — the defer base of the break/continue TARGET loop (innermost matching
// `label`; bare label → innermost loop). Defers at index ≥ this base belong to the scopes the jump
// crosses (the target loop body inclusive + any arms inside it). Falls back to 0 if no match (the
// checker guarantees a break/continue is inside a loop — defensive). (C: cg_target_defer_base.)
fn cg_target_defer_base(loops: []LoopDeferFrame, label: str) -> u64 {
    mut k = loops.len
    loop {
        if k == 0 { break }
        let lf = loops[k - 1]
        let is_target = if label.len == 0 { true } else { lf.label == label }
        if is_target { return lf.defer_base }
        k = k - 1
    }
    0
}

// cg_drop_regions_to — drop (innermost-first) every loop-body region from the top of the stack DOWN
// TO & INCLUDING the loop whose label matches `label` (empty = innermost loop). For break/continue:
// the jump exits/continues that loop, so every region it crosses must drop. Each handle is nulled
// after the drop so an overlapping edge re-drop is a no-op (tk_region_drop is NULL-tolerant).
fn cg_drop_regions_to(buf: []byte, indent: str, regions: []RegionFrame, label: str) -> []byte {
    mut out = buf
    mut k = regions.len
    loop {
        if k == 0 { break }
        let r = regions[k - 1]
        out = cb(out, indent); out = cb(out, "tk_region_drop("); out = cb(out, r.name); out = cb(out, "); "); out = cb(out, r.name); out = cb(out, " = NULL;\n")
        // Stop only AT a LOOP region (arm regions are always crossed): bare label → the innermost
        // loop; a named label → that loop. An arm region is dropped but never the break/continue target.
        let is_target = r.is_loop && (if label.len == 0 { true } else { r.label == label })
        if is_target { return out }
        k = k - 1
    }
    out
}

// cg_drop_all_regions — drop EVERY active loop-body region (innermost-first). For a `return` edge
// (which leaves all enclosing loops) before the frame-region drop + the return value.
fn cg_drop_all_regions(buf: []byte, indent: str, regions: []RegionFrame) -> []byte {
    mut out = buf
    mut k = regions.len
    loop {
        if k == 0 { break }
        let r = regions[k - 1]
        out = cb(out, indent); out = cb(out, "tk_region_drop("); out = cb(out, r.name); out = cb(out, "); "); out = cb(out, r.name); out = cb(out, " = NULL;\n")
        k = k - 1
    }
    out
}

// cg_block_has_block_local — does loop body B have any TOP-LEVEL binding proven BLOCK-local (no-wrap,
// block-routable)? Drives whether emit_loop opens a region — none ⇒ no region ⇒ byte-identical to
// the pre-S2 output for that loop. `is_value` = whether B yields a value (loop bodies do NOT).
fn cg_block_has_block_local(escaping: []str, fn_body: []checker::TStatement, block: []checker::TStatement, is_value: bool) -> bool {
    mut i: u64 = 0
    loop {
        if i >= block.len { break }
        match block[i] {
            checker::TBinding as b => {
                if cg_same_named_struct(b.bound, b.value.type) && checker::binding_is_block_local(escaping, fn_body, block, is_value, b) { return true }
            }
            _ => { }
        }
        i++
    }
    false
}

// emit_block — emit each statement in order; the first error short-circuits. `prog`/`ret_type`
// are threaded so a binding/return/match inside can wrap a case value into a variant slot
// (emit_as). S2: `regions`/`fn_body`/`cur_block`/`cur_block_is_value` thread the active loop-body
// region stack + the per-block escape context so a block-local binding routes to its region and
// break/continue/return drop the right regions. (C: `emit_block`.)
fn emit_block(buf: []byte, body: []checker::TStatement, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx, cur_block: []checker::TStatement, cur_block_is_value: bool) -> []byte | error {
    mut out = buf
    // (W9.3) Accumulate THIS block's direct defers incrementally (a `return`/`break`/`continue` at
    // statement i then sees only the defers registered at 0..i-1). emit_block does NOT fire its own
    // fall-through — the CALLER (emit_loop / emit_block_region) fires `[base, base+direct)` after.
    mut cur = dctx
    mut i: u64 = 0
    loop {
        if i >= body.len { break }
        let s = body[i]
        match s {
            checker::TDeferStmt => { cur = dctx_register(cur, s) }   // register; emits nothing inline
            _ => {
                // emit_block is reached from SUB-SCOPE bodies. The FRAME region is leaked here (frame="" —
                // SAFE), but the S2 block-region stack IS carried so a loop body's block-locals are freed.
                out = match emit_stmt(out, s, in_main, prog, ret_type, indent, "", escaping, regions, fn_body, cur, cur_block, cur_block_is_value) { []byte as o => o; error as err => return err }
            }
        }
        i++
    }
    out
}

// emit_block_region — S2: emit an ARM block (if-then / if-else / match-arm body) in STATEMENT
// position. Treated EXACTLY like a loop body except the region is an ARM region (is_loop=false): it
// is opened at block entry when the block has a provably block-local binding (is_value=false — a
// statement-arm yields no consumed value), block-locals route to it, and it is dropped on the normal
// fall-through past the arm. break/continue/return inside the arm drop it via the region-stack
// helpers (break/continue CROSS it down to the target loop; return drops everything). No block-local
// binding ⇒ no region ⇒ byte-identical to emit_block (the pre-S2 statement-arm path). (C: emit_block_region.)
fn emit_block_region(buf: []byte, body: []checker::TStatement, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    // (W9.3) EVERY statement-arm is a DEFER SCOPE — even with no S2 region — so a defer inside the arm
    // fires at the arm's fall-through (before the arm's region, if any, drops). `base` = the in-scope
    // defer count at arm entry; the fall-through fires `[base, base+direct)` LIFO.
    let base = dctx.defers.len
    let fall = cg_append_direct_defers(dctx.defers, body)   // all of THIS arm's direct defers, in scope at fall-through
    let want_block = cg_block_has_block_local(escaping, fn_body, body, false) && regions.len < 64
    if !want_block {
        // No S2 region — region-less defer-only scope: emit the body, then fire the arm's defers at fall-through.
        mut out = match emit_block(buf, body, in_main, prog, ret_type, indent, escaping, regions, fn_body, dctx, teko::list::empty(), false) { []byte as o => o; error as err => return err }
        return emit_defers(out, fall, base, prog, indent, escaping, fn_body)
    }
    // Open the arm region. Name by the buffer length at the creation point (the deterministic
    // `_tkbr<len>` uniquifier — matches the C twin's b->len read without a counter).
    let region = fresh_named("_tkbr", buf.len to i64)
    mut out = cb(buf, indent); out = cb(out, "tk_region *"); out = cb(out, region); out = cb(out, " = tk_region_new();\n")
    let regs2 = teko::list::push(regions, RegionFrame { name = region; label = ""; is_loop = false; defer_base = base })
    // Emit the body with THIS block as the current block context (so block-local bindings route to
    // `region`) and the augmented region stack.
    out = match emit_block(out, body, in_main, prog, ret_type, indent, escaping, regs2, fn_body, dctx, body, false) { []byte as o => o; error as err => return err }
    // (W9.3) Normal fall-through exit edge: fire THIS arm's defers (LIFO) FIRST (so a defer body can
    // still read the arm's block-locals), THEN drop the arm region (idempotent + nulled for overlap).
    out = match emit_defers(out, fall, base, prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
    out = cb(out, indent); out = cb(out, "tk_region_drop("); out = cb(out, region); out = cb(out, "); "); out = cb(out, region); out = cb(out, " = NULL;\n")
    out
}

// emit_exprstmt_tail — W5a: emit a TRAILING expr-statement (a block's last statement) as an
// IMPLICIT RETURN of its value (mirrors the VM: a block's trailing NORMAL value is the
// function's/main's value — B.20). A trailing `if` is lowered as DIRECT control flow (each
// branch recursively tail-emitted), so `return`/`break`/`continue` inside a branch propagate
// via C's own semantics — exactly like the VM's exec_if. This direct form works whether the
// trailing `if` is typed as a value (a function-body tail) or as `void` (a virtual-main tail,
// which the checker types as a statement but the VM still drains for its branch value). A void
// expr-statement, or any non-expr trailing statement, emits normally (no value).
// (C: `emit_exprstmt_tail`.)
fn emit_exprstmt_tail(buf: []byte, x: checker::TExpr, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, frame: str, escaping: []str, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    match x.kind {
        checker::TIfExpr as f => {
            // A trailing if/else returns on each branch; the frame region is NOT threaded into the
            // branch tails (frame="" → those returns simply LEAK the region — SAFE, M.5), keeping
            // this first cut's drop-routing confined to the linear top-level path. S2 — the REAL
            // `escaping` set IS threaded so a statement-arm inside a tail branch (emit_block_region via
            // emit_if_stmt/emit_match_stmt) gets the correct block-locality (matches the C twin's global
            // g_cg_escaping — without it the predicate sees an empty set and false-positives a region).
            // No else branch: emit as a control-flow statement; fall-through handled by caller's default return.
            if !f.has_else { return emit_if_stmt(buf, f, in_main, prog, ret_type, indent, escaping, teko::list::empty(), fn_body, dctx, teko::list::empty(), false) }
            mut out = cb(buf, indent)
            out = cb(out, "if (")
            out = match emit_expr_ctx(out, prog, checker::Void { }, f.cond, escaping, teko::list::empty(), fn_body, dctx) { []byte as o => o; error as err => return err }
            out = cb(out, ") {\n")
            let inner = cb_indent_deeper(indent)
            // (W9.3) each tail branch is a DEFER SCOPE: fire its defers at the branch's fall-through exit
            // (before the closing `}`), UNLESS its tail already C-terminated (drained on that edge).
            let then_base = dctx.defers.len
            out = match emit_block_tail(out, f.then_blk, in_main, prog, ret_type, inner, "", escaping, fn_body, dctx) { []byte as o => o; error as err => return err }
            let then_term = if f.then_blk.len > 0 { cg_stmt_c_terminates(f.then_blk[f.then_blk.len - 1]) } else { false }
            if !then_term { out = match emit_defers(out, cg_append_direct_defers(dctx.defers, f.then_blk), then_base, prog, inner, escaping, fn_body) { []byte as o => o; error as err => return err } }
            out = cb(out, indent)
            out = cb(out, "} else {\n")
            let else_base = dctx.defers.len
            out = match emit_block_tail(out, f.else_blk, in_main, prog, ret_type, inner, "", escaping, fn_body, dctx) { []byte as o => o; error as err => return err }
            let else_term = if f.else_blk.len > 0 { cg_stmt_c_terminates(f.else_blk[f.else_blk.len - 1]) } else { false }
            if !else_term { out = match emit_defers(out, cg_append_direct_defers(dctx.defers, f.else_blk), else_base, prog, inner, escaping, fn_body) { []byte as o => o; error as err => return err } }
            out = cb(out, indent)
            cb(out, "}\n")
        }
        // W5b — a trailing `match` lowers as a control-flow `if` chain whose arms `return`
        // (mirrors the trailing `if`); each arm body is wrapped to the return slot via emit_as.
        checker::TMatchExpr as m => emit_match_tail(buf, prog, x, m, in_main, ret_type, indent, escaping, fn_body, dctx)
        _ => {
            if is_void_type(x.type) {   // a void expr-statement carries no value → run for effect
                mut out = cb(buf, indent)
                out = match emit_expr_ctx(out, prog, checker::Void { }, x, escaping, teko::list::empty(), fn_body, dctx) { []byte as o => o; error as err => return err }
                out = cb(out, ";\n")
                // (W9.3) Drain the FUNCTION-BODY defers (base 0) at the end of a void-returning body.
                // Inner-scope defers already fired+popped at their own scope exits, so dctx.defers here
                // is only the function-body-level defers.
                return emit_defers(out, dctx.defers, 0, prog, indent, escaping, fn_body)
            }
            // (W9.3) Drain function-body defers (base 0) before the implicit trailing-value return.
            mut out = match emit_defers(buf, dctx.defers, 0, prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
            // MEM Step 1: the tail value-return EDGE — drop the frame region before the implicit
            // `return` (a return value is escaping, so it never references a frame-local cell).
            if frame.len > 0 && !in_main { out = cb(out, indent); out = cb(out, "tk_region_drop("); out = cb(out, frame); out = cb(out, ");\n") }
            out = cb(out, indent)
            if in_main {
                out = cb(out, "return (int)(")
                out = match emit_expr_ctx(out, prog, checker::Void { }, x, escaping, teko::list::empty(), fn_body, dctx) { []byte as o => o; error as err => return err }
                return cb(out, ");\n")
            }
            out = cb(out, "return ")
            out = match emit_as_r(out, prog, ret_type, ret_type, x, escaping, teko::list::empty(), fn_body, dctx) { []byte as o => o; error as err => return err }   // W5b — wrap a case value into a variant return slot (ret_type threaded for diverging arms)
            cb(out, ";\n")
        }
    }
}

// emit_block_tail — W5a: emit a FUNCTION/MAIN/branch body where the LAST statement, if it is
// an expr-statement carrying a value, `return`s that value (via emit_exprstmt_tail). All but
// the last statement emit normally. (C: `emit_block_tail`.)
fn emit_block_tail(buf: []byte, body: []checker::TStatement, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, frame: str, escaping: []str, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    mut out = buf
    // (W9.3) Accumulate THIS block's own direct defers incrementally as we iterate, so a `return` at
    // statement i fires only the defers registered at statements 0..i-1 (LIFO, all enclosing scopes).
    // emit_block_tail does NOT fire its OWN fall-through defers — the CALLER does (emit_function fires
    // base 0 for a non-expr/non-terminating tail; emit_exprstmt_tail's if-branch and emit_match_tail's
    // arm fire `[branch_base, …)`). (C: emit_block_tail accumulates via g_cg_ndefers; firing is external.)
    mut cur = dctx
    mut i: u64 = 0
    loop {
        if i + 1 >= body.len { break }
        let s = body[i]
        match s {
            checker::TDeferStmt => { cur = dctx_register(cur, s) }   // register; emits nothing inline
            _ => {
                // S2: tail-level statements have NO active loop-body region (regions empty) and NO block
                // routing context (cur_block empty) — a LOOP among them opens its own region via emit_loop
                // (which gets fn_body, cur for the per-block escape read counts). Frame routing rides `frame`.
                out = match emit_stmt(out, s, in_main, prog, ret_type, indent, frame, escaping, teko::list::empty(), fn_body, cur, teko::list::empty(), false) { []byte as o => o; error as err => return err }
            }
        }
        i++
    }
    if body.len == 0 { return out }
    let last = body[body.len - 1]
    match last {
        checker::TDeferStmt => out   // a trailing defer registers nothing observable (its fire is the caller's fall-through)
        checker::TExprStmt as es => emit_exprstmt_tail(out, es.expr, in_main, prog, ret_type, indent, frame, escaping, fn_body, cur)
        _ => emit_stmt(out, last, in_main, prog, ret_type, indent, frame, escaping, teko::list::empty(), fn_body, cur, teko::list::empty(), false)
    }
}

// emit_if_stmt — W5a: emit an `if` in STATEMENT position as plain C control flow:
//   if (<cond>) { <then…> } [else { <else…> }]
// Each branch is emitted via emit_block (NON-tail, value discarded), so `break`/`continue`/
// `return` inside a branch propagate via C's own semantics. This mirrors the VM, which routes
// a statement-position `if` (an expr-statement whose expr is an `if`) to exec_if as CONTROL
// FLOW — never to the value path. (The TAIL `if` takes emit_exprstmt_tail; a SUB-expression
// `if` takes emit_if_value; this is the INTERIOR statement case.) (C: `emit_if_stmt`.)
fn emit_if_stmt(buf: []byte, f: checker::TIfExpr, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx, cur_block: []checker::TStatement, cur_block_is_value: bool) -> []byte | error {
    mut out = cb(buf, indent)
    out = cb(out, "if (")
    out = match emit_expr_ctx(out, prog, checker::Void { }, f.cond, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    out = cb(out, ") {\n")
    let inner = cb_indent_deeper(indent)
    // S2 — each statement-position branch gets its OWN arm region (emit_block_region) for its provably
    // block-local bindings, dropped at the branch's fall-through / via the region stack on break/
    // continue/return. A branch with no block-local binding opens none → byte-identical. (The enclosing
    // `regions`/`fn_body` are threaded so a break/continue/return inside a branch drops the right regions.)
    out = match emit_block_region(out, f.then_blk, in_main, prog, ret_type, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    if f.has_else {
        out = cb(out, indent)
        out = cb(out, "} else {\n")
        out = match emit_block_region(out, f.else_blk, in_main, prog, ret_type, inner, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    }
    out = cb(out, indent)
    cb(out, "}\n")
}

// emit_binding — a TBinding. BindTarget: only SimpleName is lowered for M0 (destructuring
// is the honest barrier). `const` prefix for a const binding; the type rides `.bound`.
// (C: TK_TSTMT_BINDING branch.)
fn emit_binding(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, b: checker::TBinding, indent: str, frame: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx, cur_block: []checker::TStatement, cur_block_is_value: bool) -> []byte | error {
    let name = match b.target {
        parser::SimpleName as sn   => sn.name
        parser::DestructurePattern => return error { message = "codegen: destructuring binding not yet supported" }
    }
    // `let _ = expr` — DISCARD: evaluate for effect, no C variable (so repeated `let _`
    // never collide). A `return`/divergence inside the value still propagates via C.
    if name == "_" {
        mut dout = cb(buf, indent)
        dout = cb(dout, "(void)(")
        dout = match emit_as_r(dout, prog, ret_type, b.bound, b.value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        return cb(dout, ");\n")
    }
    mut out = cb(buf, indent)
    if b.kind == parser::BindKind::Const { out = cb(out, "const ") }
    out = match emit_type(out, b.bound) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    out = cb_ident(out, name)
    out = cb(out, " = ")
    // MEM Step 1 — FRAME-LOCAL routing. When a frame region is active AND the escape check proved
    // this binding frame-local (a `let`/`mut` SimpleName, NOT escaping, value = a struct-init), emit
    // the struct-init with its DIRECT auto-box routed to the frame region (freed at the exit edge),
    // bypassing emit_as_r. We take this bypass ONLY when NO variant/optional wrapping is needed —
    // the declared type `b.bound` is the SAME named STRUCT as the value's type (e.g. `let n = Node{…}`,
    // not `let p: Pattern = LiteralPattern{…}`). When a wrap is needed we fall through to the generic
    // emit_as_r path (root alloc — a SAFE leak), so a variant-typed binding is never mis-emitted.
    // The value never escapes, so freeing it at function exit is safe.
    // S2 — BLOCK-LOCAL routing TAKES PRECEDENCE: when this binding sits in a loop body that opened
    // its own region AND the per-block escape check proved it block-local, route its auto-box to the
    // INNERMOST block region (`_tkbr<len>`, freed per-iteration) instead of the frame. The block
    // region is tighter ⇒ freed sooner; soundness holds because binding_is_block_local is a subset.
    if regions.len > 0 && cur_block.len > 0 && cg_same_named_struct(b.bound, b.value.type) && checker::binding_is_block_local(escaping, fn_body, cur_block, cur_block_is_value, b) {
        match b.value.kind {
            checker::TStructInit as si => {
                out = match emit_struct_init_framed(out, prog, b.value, si, regions[regions.len - 1].name, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                return cb(out, ";\n")
            }
            _ => { }
        }
    }
    if frame.len > 0 && checker::binding_is_frame_local(escaping, b) && cg_same_named_struct(b.bound, b.value.type) {
        match b.value.kind {
            checker::TStructInit as si => {
                out = match emit_struct_init_framed(out, prog, b.value, si, frame, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                return cb(out, ";\n")
            }
            _ => { }
        }
    }
    // W5b — if the binding's declared type is a variant and the value is a case member, WRAP it into
    // the variant repr (`let s: Shape = Circle { … }`). emit_as_r threads ret_type so a value-form
    // `match`/`if` value with a diverging `return` arm wraps that return into the FUNCTION's slot.
    out = match emit_as_r(out, prog, ret_type, b.bound, b.value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ";\n")
}

// emit_assign — a TAssign -> `x op= v;`. (C: TK_TSTMT_ASSIGN branch.)
fn emit_assign(buf: []byte, prog: checker::TProgram, ret_type: checker::Type, a: checker::TAssign, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let op = match assignop_c(a.op) { str as s => s; error as err => return err }
    mut out = cb(buf, indent)
    // (MEM-1b-ii) `r.value op= v` — write THROUGH the reference: the handle `r` IS the pointer, so the
    // lvalue is `(*r)`. (`Ref<T>` lowers to a bare `<T> *`; deref-assign is a plain C pointer store.)
    if a.deref {
        out = cb(out, "(*")
        out = cb_ident(out, a.name)
        out = cb(out, ")")
    } else {
        out = cb_ident(out, a.name)
    }
    out = cb(out, " ")
    out = cb(out, op)
    out = cb(out, " ")
    // Wrap the value into the target's declared type (`bound`) — a case → its variant, a `T` →
    // `T?`, a fitting literal — exactly like a binding (emit_as_r threads ret_type for a diverging
    // value-form arm). Without this, `node = OptionalType { … }` (node: TypeExpr, a variant)
    // emitted the case's fields under the variant's C type → a field-designator error.
    out = match emit_as_r(out, prog, ret_type, a.bound, a.value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ";\n")
}

// emit_return — a TReturn. In main, `return n` -> `return (int)(n);` (early process
// exit) and a bare `return` -> `return 0;`; in a fn, the plain `return [v];`.
// (C: TK_TSTMT_RETURN branch.)
fn emit_return(buf: []byte, prog: checker::TProgram, r: checker::TReturn, in_main: bool, ret_type: checker::Type, indent: str, frame: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    // (W9.3) A `return` leaves EVERY enclosing scope: fire ALL in-scope defers (base 0) LIFO — one
    // sweep, innermost-block-first across all nesting — BEFORE dropping any region, so a defer body can
    // still read any block-local. THEN drop all block regions (innermost-first), THEN the frame region.
    mut out = match emit_defers(buf, dctx.defers, 0, prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
    // S2 — a `return` leaves EVERY enclosing loop, so drop all active block regions (innermost-first),
    // THEN the frame region. The return value is escaping ⇒ in root ⇒ safe to read post-drop.
    out = cg_drop_all_regions(out, indent, regions)
    // MEM Step 1: drop the frame region on the return EDGE (before evaluating the value — a return
    // value is an ESCAPING position, so by the escape check it never references a frame-local cell;
    // dropping first is therefore safe). tk_region_drop is idempotent + NULL-tolerant, so overlap
    // with a later/other-edge drop frees nothing twice. No frame region ⇒ nothing emitted.
    if frame.len > 0 { out = cb(out, indent); out = cb(out, "tk_region_drop("); out = cb(out, frame); out = cb(out, ");\n") }
    out = cb(out, indent)
    if !r.has_value {
        if in_main { return cb(out, "return 0;\n") }
        return cb(out, "return;\n")
    }
    if in_main {
        out = cb(out, "return (int)(")
        out = match emit_expr_ctx(out, prog, checker::Void { }, r.value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
        return cb(out, ");\n")
    }
    out = cb(out, "return ")
    // W5b — wrap a case value into a variant return slot.
    out = match emit_as_r(out, prog, ret_type, ret_type, r.value, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
    cb(out, ";\n")
}

// emit_loop — a TLoopStmt -> `while (1) { … }`, nesting one indent level deeper. A LABELED loop
// (M.5) gets a continue-target `tk_lbl_<NAME>_cont: ;` at the TOP of its body (so `continue L`
// lowers to `goto tk_lbl_<NAME>_cont;`, re-running the body == the next while(1) iteration) and a
// break-target `tk_lbl_<NAME>_break: ;` AFTER the loop (so `break L` lowers to `goto …_break;`).
// A bare loop is unchanged. (C: TK_TSTMT_LOOP branch; C grew the inner indent with snprintf.)
fn emit_loop(buf: []byte, l: checker::TLoopStmt, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx) -> []byte | error {
    let labeled = l.label.len > 0
    mut out = cb(buf, indent)
    out = cb(out, "while (1) {\n")
    let inner = cb_indent_deeper(indent)
    // a labeled loop gets a continue-target at the TOP of its body.
    if labeled { out = cb(out, inner); out = cb(out, "tk_lbl_"); out = cb_str(out, l.label); out = cb(out, "_cont: ;\n") }
    // S2 — open this loop body's OWN region when it has a provably block-local binding. The region var
    // is created AT THE TOP OF THE BODY (after the continue-target, so a labeled `continue L`'s goto
    // re-runs tk_region_new — a fresh region every iteration) and dropped at every exit edge. The name
    // rides out.len at the creation point (the `_bx<len>` uniquifier) so it matches the C twin exactly.
    // A loop with NO block-local binding opens no region → byte-identical to the pre-S2 output.
    // Cap nesting at 64 active block regions to match the C twin's fixed stack (beyond that the
    // region is not opened — a safe leak). Not reachable in real code (64 nested recursive-struct loops).
    // (W9.3) The loop body is ALWAYS a DEFER SCOPE (and a break/continue target) — even with no S2
    // region — so a defer inside the loop fires at EACH iteration's end (fall-through), on break/
    // continue, and on return. `base` = the in-scope defer count at the loop body's entry; push a
    // LoopDeferFrame so break/continue can fire `[this loop's base, …)` for the scopes they cross.
    let base = dctx.defers.len
    let fall = cg_append_direct_defers(dctx.defers, l.body)   // all of this iteration's direct defers
    let dctx2 = DeferCtx { defers = dctx.defers; loops = teko::list::push(dctx.loops, LoopDeferFrame { label = l.label; defer_base = base }) }
    let want_block = cg_block_has_block_local(escaping, fn_body, l.body, false) && regions.len < 64
    let region = if want_block { fresh_named("_tkbr", out.len to i64) } else { "" }
    mut regs2 = regions
    if want_block {
        out = cb(out, inner); out = cb(out, "tk_region *"); out = cb(out, region); out = cb(out, " = tk_region_new();\n")
        regs2 = teko::list::push(regions, RegionFrame { name = region; label = l.label; is_loop = true; defer_base = base })
    }
    // emit the body with THIS block as the current block context (so a block-local binding routes to
    // `region`) and the augmented region stack (so break/continue/return drop the right regions).
    let cur_blk = if want_block { l.body } else { teko::list::empty() }
    out = match emit_block(out, l.body, in_main, prog, ret_type, inner, escaping, regs2, fn_body, dctx2, cur_blk, false) { []byte as o => o; error as err => return err }
    // (W9.3) Fall-through exit edge (end of an iteration): fire THIS iteration's defers (LIFO) FIRST
    // (so a defer body can still read this iteration's block-locals), THEN drop the loop body's region.
    out = match emit_defers(out, fall, base, prog, inner, escaping, fn_body) { []byte as o => o; error as err => return err }
    // S2 — fall-through: drop this loop body's region (the next iteration's tk_region_new opens a fresh
    // one). Idempotent + nulled for overlap safety.
    if want_block { out = cb(out, inner); out = cb(out, "tk_region_drop("); out = cb(out, region); out = cb(out, "); "); out = cb(out, region); out = cb(out, " = NULL;\n") }
    out = cb(out, indent)
    out = cb(out, "}\n")
    // …and a break-target AFTER the loop.
    if labeled { out = cb(out, indent); out = cb(out, "tk_lbl_"); out = cb_str(out, l.label); out = cb(out, "_break: ;\n") }
    out
}

// cb_indent_deeper — `indent` + four spaces (the C did `snprintf(inner, "%s    ", indent)`).
fn cb_indent_deeper(indent: str) -> str {
    mut xs: []byte = teko::list::empty()
    mut i = 0
    loop {
        if i >= indent.len { break }
        xs = teko::list::push(xs, indent[i])
        i++
    }
    xs = teko::list::push(xs, b' ')
    xs = teko::list::push(xs, b' ')
    xs = teko::list::push(xs, b' ')
    xs = teko::list::push(xs, b' ')
    str(xs)
}

// emit_stmt — the statement dispatch (the C's emit_stmt switch). (C: `emit_stmt`.)
// MEM Step 1: `frame`/`escaping` ride the LINEAR top-level path — a TBinding may frame-route its
// allocation, a TReturn drops the region on its edge. Statements that open a SUB-SCOPE (if/match/
// loop bodies) are emitted FRAMELESS in this first cut: any return inside them simply leaks the
// region (SAFE, M.5), and a frame-local binding only inside a branch falls back to root.
fn emit_stmt(buf: []byte, s: checker::TStatement, in_main: bool, prog: checker::TProgram, ret_type: checker::Type, indent: str, frame: str, escaping: []str, regions: []RegionFrame, fn_body: []checker::TStatement, dctx: DeferCtx, cur_block: []checker::TStatement, cur_block_is_value: bool) -> []byte | error {
    match s {
        checker::TBinding as b      => emit_binding(buf, prog, ret_type, b, indent, frame, escaping, regions, fn_body, dctx, cur_block, cur_block_is_value)
        checker::TAssign as a       => emit_assign(buf, prog, ret_type, a, indent, escaping, regions, fn_body, dctx)
        checker::TReturn as r       => emit_return(buf, prog, r, in_main, ret_type, indent, frame, escaping, regions, fn_body, dctx)
        checker::TExprStmt as es    => {
            // W5a — an `if` in statement position runs as CONTROL FLOW (mirrors the VM's
            // exec_stmt → exec_if), so break/continue/return inside a branch propagate. W5b —
            // a `match` in statement position runs each winning arm body for effect.
            match es.expr.kind {
                checker::TIfExpr as f    => emit_if_stmt(buf, f, in_main, prog, ret_type, indent, escaping, regions, fn_body, dctx, cur_block, cur_block_is_value)
                checker::TMatchExpr as m => emit_match_stmt(buf, prog, es.expr, m, in_main, ret_type, indent, escaping, regions, fn_body, dctx, cur_block, cur_block_is_value)
                _ => {
                    mut out = cb(buf, indent)
                    out = match emit_expr_ctx(out, prog, checker::Void { }, es.expr, escaping, regions, fn_body, dctx) { []byte as o => o; error as err => return err }
                    cb(out, ";\n")
                }
            }
        }
        checker::TLoopStmt as l     => emit_loop(buf, l, in_main, prog, ret_type, indent, escaping, regions, fn_body, dctx)
        checker::TBreakStmt as b    => {
            // (W9.3) `break` crosses every scope from here down to & including its target loop body:
            // fire those scopes' defers (base = the target loop's defer_base) LIFO — one sweep,
            // innermost-block-first — BEFORE dropping their regions. S2 — then drop every block region
            // from the top down to & including that loop's region. NOT the frame, NOT outer regions.
            // `break NAME` -> `goto tk_lbl_<NAME>_break;`; bare `break` -> `break;` (M.5).
            mut out = match emit_defers(buf, dctx.defers, cg_target_defer_base(dctx.loops, b.label), prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
            out = cg_drop_regions_to(out, indent, regions, b.label)
            out = cb(out, indent)
            if b.label.len > 0 { out = cb(out, "goto tk_lbl_"); out = cb_str(out, b.label); cb(out, "_break;\n") }
            else { cb(out, "break;\n") }
        }
        checker::TContinueStmt as c => {
            // (W9.3) `continue` ends THIS iteration of its target loop: fire every crossed scope's
            // defers (base = the target loop's defer_base) LIFO BEFORE dropping their regions, so a
            // loop-body defer fires at each iteration end (incl. on `continue`). S2 — then drop every
            // block region from the top down to & including that loop's region (next iter opens fresh).
            // `continue NAME` -> `goto tk_lbl_<NAME>_cont;`; bare `continue` -> `continue;` (M.5).
            mut out = match emit_defers(buf, dctx.defers, cg_target_defer_base(dctx.loops, c.label), prog, indent, escaping, fn_body) { []byte as o => o; error as err => return err }
            out = cg_drop_regions_to(out, indent, regions, c.label)
            out = cb(out, indent)
            if c.label.len > 0 { out = cb(out, "goto tk_lbl_"); out = cb_str(out, c.label); cb(out, "_cont;\n") }
            else { cb(out, "continue;\n") }
        }
        // (W9.3) defer { stmts } — registers the cleanup block on the threaded DeferCtx (the block
        // emitters do the actual registration via dctx_register before reaching emit_stmt for siblings);
        // emit_stmt itself emits NOTHING inline for a defer. It fires LIFO at its scope's exit edge.
        // (C: TK_TSTMT_DEFER — g_cg_defers[g_cg_ndefers++] = s, emits nothing.)
        checker::TDeferStmt => buf
    }
}

// ---------------------------------------------------------------------------
// A top-level function -> a C function.
// ---------------------------------------------------------------------------

// emit_function — a TFunction -> a C function definition.
// (C: `emit_function`.)
// emit_function_sig — the return type + name + params up to the `)` (no body). Shared by the
// definition AND the PROTOTYPE pass in tk_emit_c, so a forward declaration and its definition
// spell the same signature. Parameter names ride cb_ident (a C-keyword param → trailing `_`).
// (C: `emit_function_sig`.)
fn emit_function_sig(buf: []byte, prog: checker::TProgram, f: checker::TFunction) -> []byte | error {
    mut out = buf
    if f.is_extern { out = cb(out, "extern ") }   // C7.1a: a foreign prototype (no body)
    out = match emit_type(out, f.return_type) { []byte as o => o; error as err => return err }
    out = cb(out, " ")
    if f.is_extern {
        out = cb(out, f.c_symbol)                 // C7.1a: the raw foreign C symbol (NO namespace mangling)
    } else {
        out = cb_fn_name(out, f.namespace, f.name)   // (#49) namespace-mangled C name (def + prototype agree)
    }
    out = cb(out, "(")
    if f.params.len == 0 {
        out = cb(out, "void")
    } else {
        mut i: u64 = 0
        loop {
            if i >= f.params.len { break }
            if i > 0 { out = cb(out, ", ") }
            out = match emit_type_expr(out, prog, f.params[i].type_ann) { []byte as o => o; error as err => return err }
            out = cb(out, " ")
            out = cb_ident(out, f.params[i].name)
            i++
        }
    }
    cb(out, ")")
}

// cg_stmt_c_terminates — does this statement, AS LOWERED, guarantee C control doesn't fall through
// past it? A `return`/break/continue does; a trailing value-expr lowers to `return <v>;` so it does
// too — EXCEPT a `match`/`if` value tail, whose exhaustiveness C cannot see. (C: cg_stmt_c_terminates.)
fn cg_stmt_c_terminates(s: checker::TStatement) -> bool {
    match s {
        checker::TReturn => true
        checker::TBreakStmt => true
        checker::TContinueStmt => true
        checker::TExprStmt as es => match es.expr.kind {
            checker::TMatchExpr => false
            checker::TIfExpr => false
            _ => true
        }
        _ => false
    }
}


// cg_same_named_struct — are `a` and `b` the SAME Named type? Used to gate the frame-local binding
// bypass to the no-wrapping case (declared type == the struct-init's own type), so a variant/
// optional-typed binding (which emit_as_r must wrap) is never emitted via the direct framed path.
fn cg_same_named_struct(a: checker::Type, b: checker::Type) -> bool {
    match a {
        checker::Named as na => match b {
            checker::Named as nb => teko::runtime::str_eq(na.name, nb.name)
            _ => false
        }
        _ => false
    }
}

// fn_body_has_frame_local — does this body have any TOP-LEVEL binding the escape check proved
// frame-local AND routable (no-wrap, same-named-struct)? (MEM Step 1 routes only top-level
// bindings; sub-scope bindings stay on root in this first cut.) Drives whether emit_function opens
// a frame region at all — none ⇒ no region ⇒ zero output change (the fixpoint-preserving default).
fn fn_body_has_frame_local(escaping: []str, body: []checker::TStatement) -> bool {
    mut i: u64 = 0
    loop {
        if i >= body.len { break }
        match body[i] {
            checker::TBinding as b => { if checker::binding_is_frame_local(escaping, b) && cg_same_named_struct(b.bound, b.value.type) { return true } }
            _ => { }
        }
        i++
    }
    false
}

fn emit_function(buf: []byte, prog: checker::TProgram, f: checker::TFunction) -> []byte | error {
    mut out = match emit_function_sig(buf, prog, f) { []byte as o => o; error as err => return err }
    out = cb(out, " {\n")
    // (W9.3) PER-SCOPE defer. The TAST body is emitted UNCHANGED; defers are tracked via the threaded
    // DeferCtx (the functional twin of the C's g_cg_defers/g_cg_ndefers statics, reset per function).
    // A TDeferStmt appends to dctx.defers (emits nothing inline); every scope-block fires `[base, len)`
    // LIFO at its exit edge (fall-through / break / continue / return), BEFORE that block's region drop.
    // No defers ⇒ dctx stays empty ⇒ byte-identical to the pre-W9.3 output. (C: emit_function / emit_defers.)
    let fbody = f.body
    let dctx = dctx_empty()
    // MEM Step 1 — THE FRAME REGION. Run the escape check (escape.tks). When a TOP-LEVEL binding is
    // provably frame-local, open a per-function frame region `_tkfr` (a deterministic, per-fn-constant
    // name → fixpoint-safe, NOT buf.len) at entry; its frame-local allocations are bulk-freed on the
    // return edges (emit_return / emit_exprstmt_tail) and at the fall-through end. A function with NO
    // frame-local binding gets NO region — zero bytes, byte-identical to the pre-Step-1 output.
    let escaping = checker::fn_escaping_vars(f)
    let want_frame = fn_body_has_frame_local(escaping, fbody)
    let frame: str = if want_frame { "_tkfr" } else { "" }
    if want_frame { out = cb(out, "    tk_region *_tkfr = tk_region_new();\n") }
    // W5a — a fn body's trailing expr-statement carrying a value implicitly returns it.
    // W5b — thread the fn's return type so a tail/return case value is wrapped into a variant
    // return slot (emit_as).
    out = match emit_block_tail(out, fbody, false, prog, f.return_type, "    ", frame, escaping, fbody, dctx) { []byte as o => o; error as err => return err }
    // (W9.3) FN-BODY FALL-THROUGH defers. When control can fall off the function's end and the tail is
    // NOT an expr-statement (a binding/assign/loop tail — an expr-stmt tail already drained via
    // emit_exprstmt_tail; a return/break/continue tail already drained on its edge), fire the remaining
    // fn-body-level defers (base 0) here, BEFORE the frame-region drop. (C: emit_function fn-fall-through.)
    let tail_is_expr = if fbody.len > 0 { match fbody[fbody.len - 1] { checker::TExprStmt => true; _ => false } } else { false }
    let tail_term = if fbody.len > 0 { cg_stmt_c_terminates(fbody[fbody.len - 1]) } else { false }
    if !tail_is_expr && !tail_term {
        // The fn-body fall-through fires ALL fn-body-level defers (base 0). Recompute the full list of
        // this body's direct defers (the same NODES emit_block_tail accumulated) and fire them LIFO.
        let fn_defers = cg_append_direct_defers(dctx.defers, fbody)
        out = match emit_defers(out, fn_defers, 0, prog, "    ", escaping, fbody) { []byte as o => o; error as err => return err }
    }
    // MEM Step 1 — the FALL-THROUGH exit edge. If control can reach the function's end (the tail did
    // not C-terminate), drop the frame region there too. tk_region_drop is idempotent, so this never
    // double-frees relative to a return-edge drop on another path.
    if want_frame {
        let tail_terminates = if fbody.len > 0 { cg_stmt_c_terminates(fbody[fbody.len - 1]) } else { false }
        if !tail_terminates { out = cb(out, "    tk_region_drop(_tkfr);\n") }
    }
    // A non-void function whose tail is a value-form `match`/`if` (or a loop) returns on every path
    // the CHECKER proved exhaustive — but C can't see that, so without a terminator it warns
    // -Wreturn-type and the fall-through is UB. The checker guarantees it is never reached: emit
    // `__builtin_unreachable()`. (Skip when the tail already C-terminates, and for void functions.)
    let needs_unreachable = match f.return_type {
        checker::Void => false
        _ => if fbody.len > 0 { !cg_stmt_c_terminates(fbody[fbody.len - 1]) } else { true }
    }
    if needs_unreachable { out = cb(out, "    __builtin_unreachable();\n") }
    cb(out, "}\n\n")
}

// ---------------------------------------------------------------------------
// W4c — TYPE DECLARATIONS -> C type declarations.
//   struct { f: T; … }    -> typedef struct tk_t_<M> { <Ctype> <f>; … } tk_t_<M>;
//   variant A | B | …     -> a tag enum tk_tag_<M> (one TK_TAG_<M>_<memberM> per member),
//                            then typedef struct tk_t_<M> { tk_tag_<M> tag;
//                            union { <memberCtype> <memberField>; … } as; } tk_t_<M>;
//   enum { A; B }         -> a C enum (typedef enum tk_t_<M> { TK_E_<M>_A, … } tk_t_<M>;)
// The `tag + union as` idiom is exactly what the bootstrap C itself uses (Type/TExpr).
// ---------------------------------------------------------------------------

// cb_upper — append the UPPERCASE form of a name's bytes (for enum/tag constants). Non
// lowercase bytes pass through verbatim (identifiers are alnum/underscore). (C: `cb_upper`.)
fn cb_upper(buf: []byte, s: str) -> []byte {
    mut out = buf
    mut i = 0
    loop {
        if i >= s.len { break }
        let c = s[i]
        if c >= b'a' && c <= b'z' {
            out = cb_byte(out, (c to i64 - b'a' to i64 + b'A' to i64) to byte)
        } else {
            out = cb_byte(out, c)
        }
        i++
    }
    out
}

// variant_member_name — a variant member's bare last path segment (the union field name for a
// NAMED member). Kept for the cg_variant_has_member scan. (C: `variant_member_name`.)
fn variant_member_name(m: parser::TypeExpr) -> str | error {
    match m {
        parser::NamedType as nt => nt.path.segments[nt.path.segments.len - 1].name
        _              => error { message = "codegen: a variant member must be a named type" }
    }
}

// emit_type_decl — emit ONE type declaration. `d.name` is the bare name; the namespace is
// empty (the typed item carries no provenance) so decl + ref mangle identically.
// (C: `emit_type_decl`.)
fn emit_type_decl(buf: []byte, prog: checker::TProgram, d: parser::TypeDecl) -> []byte | error {
    match d.body {
        parser::StructBody as sb => {
            mut out = cb(buf, "typedef struct ")
            out = mangle_type_name(out, "", d.name)
            out = cb(out, " {\n")
            mut i = 0
            loop {
                if i >= sb.fields.len { break }
                out = cb(out, "    ")
                out = match emit_type_expr(out, prog, sb.fields[i].type_ann) { []byte as o => o; error as err => return err }
                out = cb(out, " ")
                // auto-box: a recursive back-edge field is a heap pointer (finite C struct).
                if cg_field_boxed(prog, d.name, sb.fields[i].type_ann) { out = cb(out, "*") }
                out = cb_str(out, sb.fields[i].name)
                out = cb(out, ";\n")
                i++
            }
            out = cb(out, "} ")
            out = mangle_type_name(out, "", d.name)
            cb(out, ";\n\n")
        }
        parser::VariantBody as vb => {
            // A variant body is a UnionType (A | B | …). Members may be ANY type (B-cg2):
            // named cases, `error`, prims, slices — each mapped to a C-safe member KEY.
            let members = match vb.type_expr {
                parser::UnionType as u => u.members
                _             => return error { message = "codegen: a variant body must be a union of members" }
            }
            // 1) the tag enum: TK_TAG_<UPPER Name>_<UPPER memberKey> per member.
            mut out = cb(buf, "typedef enum tk_tag_")
            out = cb_str(out, d.name)
            out = cb(out, " {\n")
            mut i = 0
            loop {
                if i >= members.len { break }
                let mk = match cg_member_key_texpr_str(members[i]) { str as s => s; error as err => return err }
                out = cb(out, "    TK_TAG_")
                out = cb_upper(out, d.name)
                out = cb(out, "_")
                out = cb_upper(out, mk)
                if i + 1 < members.len { out = cb(out, ",") }
                out = cb(out, "\n")
                i++
            }
            out = cb(out, "} tk_tag_")
            out = cb_str(out, d.name)
            out = cb(out, ";\n\n")
            // 2) the value: tag + union as. Each union field is named by the member KEY and
            //    typed via emit_type_expr (covers named/error/prim/slice/optional members).
            out = cb(out, "typedef struct ")
            out = mangle_type_name(out, "", d.name)
            out = cb(out, " {\n    tk_tag_")
            out = cb_str(out, d.name)
            out = cb(out, " tag;\n    union {\n")
            mut j = 0
            loop {
                if j >= members.len { break }
                let mem = members[j]
                let mk = match cg_member_key_texpr_str(mem) { str as s => s; error as err => return err }
                out = cb(out, "        ")
                out = match emit_type_expr(out, prog, mem) { []byte as o => o; error as err => return err }
                out = cb(out, " ")
                out = cb_str(out, mk)   // union field == the member key
                out = cb(out, ";\n")
                j++
            }
            out = cb(out, "    } as;\n} ")
            out = mangle_type_name(out, "", d.name)
            cb(out, ";\n\n")
        }
        parser::EnumBody as eb => {
            mut out = cb(buf, "typedef enum ")
            out = mangle_type_name(out, "", d.name)
            out = cb(out, " {\n")
            mut i = 0
            loop {
                if i >= eb.members.len { break }
                out = cb(out, "    TK_E_")
                out = cb_upper(out, d.name)
                out = cb(out, "_")
                out = cb_upper(out, eb.members[i])
                if i + 1 < eb.members.len { out = cb(out, ",") }
                out = cb(out, "\n")
                i++
            }
            out = cb(out, "} ")
            out = mangle_type_name(out, "", d.name)
            cb(out, ";\n\n")
        }
        parser::AliasBody => {
            // A TRANSPARENT alias emits NO C type — references resolve through to the aliased
            // type at the checker, and codegen emits that resolved type at every use site.
            buf
        }
        parser::FlagsBody as fb => {
            // (C8.4) A `flags Name { A; B; C; }` emits:
            //   typedef <uint_type> tk_t_<Name>;
            //   static const tk_t_<Name> tk_t_<Name>_<A> = (tk_t_<Name>)(((unsigned __int128)1) << 0);
            //   …
            // uint_type by member count: 1–8 → uint8_t, 9–16 → uint16_t,
            //   17–32 → uint32_t, 33–64 → uint64_t, 65–128 → unsigned __int128.
            let n = fb.members.len
            let uint_type = if n <= 8 { "uint8_t" } else if n <= 16 { "uint16_t" } else if n <= 32 { "uint32_t" } else if n <= 64 { "uint64_t" } else { "unsigned __int128" }
            mut out = cb(buf, "typedef ")
            out = cb(out, uint_type)
            out = cb(out, " ")
            out = mangle_type_name(out, "", d.name)
            out = cb(out, ";\n")
            mut mi: u64 = 0
            loop {
                if mi >= n { break }
                out = cb(out, "static const ")
                out = mangle_type_name(out, "", d.name)
                out = cb(out, " ")
                out = mangle_type_name(out, "", d.name)
                out = cb(out, "_")
                out = cb_upper(out, fb.members[mi])
                out = cb(out, " = (")
                out = mangle_type_name(out, "", d.name)
                out = cb(out, ")(((unsigned __int128)1) << ")
                out = cb_i64(out, mi to i64)
                out = cb(out, ");\n")
                mi++
            }
            cb(out, "\n")
        }
        parser::ExternBody => {
            // (C7.1a) an OPAQUE foreign handle → a C `void *` typedef, so the existing
            // Named → tk_t_<Name> mangle resolves to it (distinct in Teko, plain `void *` in C).
            mut o = cb(buf, "typedef void *")
            o = mangle_type_name(o, "", d.name)
            cb(o, ";\n\n")
        }
    }
}

// ---------------------------------------------------------------------------
// OPTIONAL TYPEDEF COLLECTION (REBOOT_PLAN §202). Every distinct optional inner type used in
// the typed program needs its `typedef struct { bool present; <inner> value; } tk_opt_<inner>;`
// emitted once in the prelude. We walk every type that flows through emit_type (function sigs,
// bindings, every TExpr `.type`), collecting distinct inners (deduped by mangled name). Nested
// optionals register the inner first so its typedef precedes the outer's reference. (C: the
// cg_opt_set / cg_collect_* family.)
// ---------------------------------------------------------------------------
// The per-type generated typedefs collected in ONE walk: optional inners (tk_opt_<i>) AND slice
// element types (tk_slice_<e>). Mirrors the C's `cg_opt_set` struct (two parallel lists threaded
// by pointer); here it is a value threaded by return (the functional `.tks` idiom). One walk feeds
// both — cg_collect_type_opts registers a slice's element in the same traversal as optionals.
type CgTypeSet = struct { inners: []checker::Type; slices: []checker::Type; variants: []checker::Type }   // B-cg2 — inline tk_u_<keys>

// the mangled-name key for a type (dedup key); "" for an unsupported type (skipped). Used for
// both optional inners and slice elements (same mangle). (C: `cg_opt_mangle` render-to-scratch.)
fn cg_opt_key(t: checker::Type) -> str {
    match cg_opt_mangle(teko::list::empty(), t) { []byte as o => str(o); error => "" }
}
// register an optional inner (dedup by mangle). (C: `cg_opt_set_add`.)
fn cg_opt_set_add(set: CgTypeSet, inner: checker::Type) -> CgTypeSet {
    let key = cg_opt_key(inner)
    if key == "" { return set }
    mut i = 0
    loop {
        if i >= set.inners.len { break }
        if cg_opt_key(set.inners[i]) == key { return set }   // already present
        i++
    }
    CgTypeSet { inners = teko::list::push(set.inners, inner); slices = set.slices; variants = set.variants }
}
// register a slice element type (dedup by mangle), parallel to cg_opt_set_add. (C: `cg_slice_add`.)
fn cg_slice_add(set: CgTypeSet, elem: checker::Type) -> CgTypeSet {
    let key = cg_opt_key(elem)
    if key == "" { return set }   // unsupported element → skip (emit_type errors honestly)
    mut i = 0
    loop {
        if i >= set.slices.len { break }
        if cg_opt_key(set.slices[i]) == key { return set }   // already present
        i++
    }
    CgTypeSet { inners = set.inners; slices = teko::list::push(set.slices, elem); variants = set.variants }
}
// B-cg2 — the dedup key for an INLINE variant TYPE (its tk_u_<keys> name); "" for unsupported. (C: `cg_variant_typename` render-to-scratch.)
fn cg_variant_key(t: checker::Type) -> str {
    match t {
        checker::Variant as v => match cg_variant_typename(teko::list::empty(), v) { []byte as o => str(o); error => "" }
        _ => ""
    }
}
// B-cg2 — register an INLINE variant TYPE (dedup by its tk_u_<keys> name). A Named variant has
// its own decl typedef and is NOT registered here. (C: `cg_variant_add`.)
fn cg_variant_add(set: CgTypeSet, t: checker::Type) -> CgTypeSet {
    let key = cg_variant_key(t)
    if key == "" { return set }   // unsupported member → skip (emit_type errors honestly)
    mut i = 0
    loop {
        if i >= set.variants.len { break }
        if cg_variant_key(set.variants[i]) == key { return set }   // already present
        i++
    }
    CgTypeSet { inners = set.inners; slices = set.slices; variants = teko::list::push(set.variants, t) }
}
// register every optional in a type AND every slice's element (nested inners/elements first, so
// `T??` and `[][]T`/`[]T?` order right). (C: `cg_collect_type_opts`.)
fn cg_collect_type_opts(set: CgTypeSet, t: checker::Type) -> CgTypeSet {
    match t {
        checker::Optional as opt => {
            match opt.inner {
                checker::Void => set
                _ => cg_opt_set_add(cg_collect_type_opts(set, opt.inner), opt.inner)
            }
        }
        checker::Slice as sl => match sl.element {
            checker::Void => set
            _ => cg_slice_add(cg_collect_type_opts(set, sl.element), sl.element)   // recurse (covers [][]T, []T?), then register THIS slice's element
        }
        // B-cg2 — an INLINE `A | B | …`. Recurse into each member FIRST (so a member that is a
        // slice/optional gets its typedef before this tk_u_ references it), then register THIS
        // variant's tk_u_<keys> typedef. (C: the VARIANT arm of cg_collect_type_opts.)
        checker::Variant as va => {
            mut s = set
            mut i = 0
            loop {
                if i >= va.members.len { break }
                s = cg_collect_type_opts(s, va.members[i])
                i++
            }
            cg_variant_add(s, t)
        }
        _ => set
    }
}
fn cg_collect_expr_opts(set: CgTypeSet, e: checker::TExpr) -> CgTypeSet {
    mut s = cg_collect_type_opts(set, e.type)   // the node's own resolved type may be `T?` / `[]T`
    match e.kind {
        checker::TBinary as b  => { s = cg_collect_expr_opts(s, b.left); s = cg_collect_expr_opts(s, b.right) }
        checker::TUnary as u   => { s = cg_collect_expr_opts(s, u.operand) }
        checker::TCompare as c => {
            s = cg_collect_expr_opts(s, c.first)
            mut i = 0
            loop { if i >= c.rest.len { break }; s = cg_collect_expr_opts(s, c.rest[i].operand); i++ }
        }
        checker::TCall as cl => { mut i = 0; loop { if i >= cl.args.len { break }; s = cg_collect_expr_opts(s, cl.args[i]); i++ } }
        checker::TIfExpr as f => {
            s = cg_collect_expr_opts(s, f.cond)
            s = cg_collect_block_opts(s, f.then_blk)
            s = cg_collect_block_opts(s, f.else_blk)
        }
        checker::TMatchExpr as m => {
            s = cg_collect_expr_opts(s, m.subject)
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                if m.arms[i].has_when { s = cg_collect_expr_opts(s, m.arms[i].guard) }
                s = cg_collect_block_opts(s, m.arms[i].body)
                i++
            }
        }
        checker::TCast as c => { s = cg_collect_expr_opts(s, c.expr) }
        checker::TFieldAccess as fa => { s = cg_collect_expr_opts(s, fa.receiver) }
        checker::TSafeFieldAccess as sfa => { s = cg_collect_expr_opts(s, sfa.receiver) }
        checker::TCoalesce as co => { s = cg_collect_expr_opts(s, co.left); s = cg_collect_expr_opts(s, co.right) }
        checker::TStructInit as si => { mut i = 0; loop { if i >= si.field_vals.len { break }; s = cg_collect_expr_opts(s, si.field_vals[i]); i++ } }
        checker::TIndex as ix => { s = cg_collect_expr_opts(s, ix.receiver); s = cg_collect_expr_opts(s, ix.index) }
        checker::TInterp as in => {
            mut i = 0
            loop {
                if i >= in.holes.len { break }
                s = cg_collect_expr_opts(s, in.holes[i])
                if i < in.specs.len {
                    match in.specs[i].kind {
                        checker::TFSpecDynamic as fd => {
                            mut k = 0
                            loop { if k >= fd.args.len { break }; s = cg_collect_expr_opts(s, fd.args[k]); k++ }
                        }
                        _ => { }
                    }
                }
                i++
            }
        }
        checker::TInExpr as ie => { s = cg_collect_expr_opts(s, ie.lhs); mut i = 0; loop { if i >= ie.elems.len { break }; s = cg_collect_expr_opts(s, ie.elems[i]); i++ } }
        _ => { }   // leaves: type already registered above
    }
    s
}
fn cg_collect_block_opts(set: CgTypeSet, stmts: []checker::TStatement) -> CgTypeSet {
    mut s = set
    mut i = 0
    loop {
        if i >= stmts.len { break }
        match stmts[i] {
            checker::TBinding as b => { s = cg_collect_type_opts(s, b.bound); s = cg_collect_expr_opts(s, b.value) }
            // collect a.bound too (the target's declared type — the SAME present-wrap target as the
            // VM's coerce_to(a.bound)): a deref-assign `r.value = v` through a `Ref<T?>` has bound=`T?`,
            // and that optional's tk_opt_<T> typedef must be emitted even when the value's own type is a
            // bare `T` (widened) — mirrors the TBinding arm collecting b.bound.
            checker::TAssign as a  => { s = cg_collect_type_opts(s, a.bound); s = cg_collect_expr_opts(s, a.value) }
            checker::TReturn as r  => { if r.has_value { s = cg_collect_expr_opts(s, r.value) } }
            checker::TLoopStmt as l => { s = cg_collect_block_opts(s, l.body) }
            checker::TExprStmt as es => { s = cg_collect_expr_opts(s, es.expr) }
            checker::TDeferStmt as d => { s = cg_collect_block_opts(s, d.body) }
            _ => { }
        }
        i++
    }
    s
}
// (bugfix) Convert a SYNTACTIC type-expr to a resolved Type ONLY as far as the typedef collector
// needs it (cg_collect_type_opts walks Optional/Slice/Variant; everything else is a no-op leaf). A
// struct/variant FIELD's optional/slice/variant whose type surfaces NOWHERE in any expression (only
// in the declaration) would otherwise never feed the collector, so its tk_opt_/tk_slice_/tk_u_
// typedef is never emitted → `cc` fails with "unknown type name". This lets cg_emit_types_ordered's
// second pass register those.
//   Invariant: cg_opt_mangle(cg_te_to_type(te)) == cg_opt_mangle_texpr(te) for NAMED/OPTIONAL/SLICE
//   — the typedef NAME (mangle of the resolved type) must agree byte-for-byte with the syntactic
//   mangle used when the field is emitted. The prim mapping mirrors emit_type_expr exactly, so a
//   primitive `i64?` inner yields `int64_t value;` (NOT `tk_t_i64 value;`).
// (C: `cg_te_to_type`.)
fn cg_te_to_type(te: parser::TypeExpr) -> checker::Type {
    match te {
        parser::NamedType as nt => {
            let last = nt.path.segments[nt.path.segments.len - 1].name
            if      last == "u8"    { checker::Prim { kind = checker::PrimKind::U8 } }
            else if last == "u16"   { checker::Prim { kind = checker::PrimKind::U16 } }
            else if last == "u32"   { checker::Prim { kind = checker::PrimKind::U32 } }
            else if last == "u64"   { checker::Prim { kind = checker::PrimKind::U64 } }
            else if last == "u128"  { checker::Prim { kind = checker::PrimKind::U128 } }
            else if last == "i8"    { checker::Prim { kind = checker::PrimKind::I8 } }
            else if last == "i16"   { checker::Prim { kind = checker::PrimKind::I16 } }
            else if last == "i32"   { checker::Prim { kind = checker::PrimKind::I32 } }
            else if last == "i64"   { checker::Prim { kind = checker::PrimKind::I64 } }
            else if last == "i128"  { checker::Prim { kind = checker::PrimKind::I128 } }
            else if last == "f16"   { checker::Prim { kind = checker::PrimKind::F16 } }
            else if last == "f32"   { checker::Prim { kind = checker::PrimKind::F32 } }
            else if last == "f64"   { checker::Prim { kind = checker::PrimKind::F64 } }
            else if last == "bool"  { checker::Prim { kind = checker::PrimKind::Bool } }
            else if last == "byte"  { checker::Byte { } }
            else if last == "str"   { checker::Str { } }
            else if last == "error" { checker::Error { } }
            else if last == "void"  { checker::Void { } }
            // otherwise a user-defined named aggregate (generic args ignored for collection).
            else { checker::Named { name = last } }
        }
        parser::SliceType as st => checker::Slice { element = cg_te_to_type(st.element) }
        parser::OptionalType as ot => checker::Optional { inner = cg_te_to_type(ot.inner) }
        parser::UnionType as ut => {
            mut mem: []checker::Type = teko::list::empty()
            mut i = 0
            loop {
                if i >= ut.members.len { break }
                mem = teko::list::push(mem, cg_te_to_type(ut.members[i]))
                i++
            }
            checker::Variant { members = mem }
        }
        // func-optionals aren't supported; a Func whose mangle fails so cg_opt_set_add/cg_slice_add
        // skip it (correct — same honest-stop as elsewhere).
        parser::FunctionType => checker::Func { params = teko::list::empty(); ret = checker::Void { } ; variadic = false ; param_names = []; n_required = 0; defaults = [] }
    }
}

// B-cg2 — emit ONE inline-variant typedef tk_u_<keys> (the SAME tag-enum + tag/union-struct
// shape as a named variant decl, but keyed off the resolved member types). Members' typedefs
// (slice/opt) precede it by registration order. (C: `cg_emit_inline_variant_typedef`.)
fn cg_emit_inline_variant_typedef(buf: []byte, v: checker::Variant) -> []byte | error {
    // tag enum: typedef enum tk_tag_<keys> { TK_TAG_U_<UPPER keys…>_<UPPER key>, … } tk_tag_<keys>;
    mut out = cb(buf, "typedef enum tk_tag")
    mut a = 0
    loop {
        if a >= v.members.len { break }
        out = cb(out, "_")
        out = match cg_member_key(out, v.members[a]) { []byte as o => o; error as err => return err }
        a++
    }
    out = cb(out, " {\n")
    mut i = 0
    loop {
        if i >= v.members.len { break }
        out = cb(out, "    TK_TAG_U")
        mut j = 0
        loop {
            if j >= v.members.len { break }
            out = cb(out, "_")
            let kj = match cg_member_key_str(v.members[j]) { str as s => s; error as err => return err }
            out = cb_upper(out, kj)
            j++
        }
        out = cb(out, "_")
        let ki = match cg_member_key_str(v.members[i]) { str as s => s; error as err => return err }
        out = cb_upper(out, ki)
        if i + 1 < v.members.len { out = cb(out, ",") }
        out = cb(out, "\n")
        i++
    }
    out = cb(out, "} tk_tag")
    mut b = 0
    loop {
        if b >= v.members.len { break }
        out = cb(out, "_")
        out = match cg_member_key(out, v.members[b]) { []byte as o => o; error as err => return err }
        b++
    }
    out = cb(out, ";\n")
    // value struct: typedef struct tk_u_<keys> { tk_tag_<keys> tag; union { … } as; } tk_u_<keys>;
    out = cb(out, "typedef struct ")
    out = match cg_variant_typename(out, v) { []byte as o => o; error as err => return err }
    out = cb(out, " {\n    tk_tag")
    mut c = 0
    loop {
        if c >= v.members.len { break }
        out = cb(out, "_")
        out = match cg_member_key(out, v.members[c]) { []byte as o => o; error as err => return err }
        c++
    }
    out = cb(out, " tag;\n    union {\n")
    mut m = 0
    loop {
        if m >= v.members.len { break }
        out = cb(out, "        ")
        out = match emit_type(out, v.members[m]) { []byte as o => o; error as err => return err }
        out = cb(out, " ")
        out = match cg_member_key(out, v.members[m]) { []byte as o => o; error as err => return err }
        out = cb(out, ";\n")
        m++
    }
    out = cb(out, "    } as;\n} ")
    out = match cg_variant_typename(out, v) { []byte as o => o; error as err => return err }
    cb(out, ";\n")
}

// =========================================================================
// SELF-HOST — TOPOLOGICAL type-declaration emission. A struct/variant body embeds named
// aggregates, optionals (tk_opt_) and inline variants (tk_u_) BY VALUE, so each must be FULLY
// defined BEFORE the body that embeds it. Slices (tk_slice_) are pointer-only (their named
// elements have forward typedefs), so they are emitted up front. The remaining {named, opt,
// inline-variant} typedefs are emitted in DEPENDENCY order by a fixpoint: each pass emits every
// not-yet-emitted node whose by-value dependencies are already emitted, until none remain. The
// value-type graph is a DAG (every Teko recursion passes through a slice = pointer), so the
// fixpoint terminates; a residue means a genuine cyclic value type (an internal error).
// (C: the cg_typenodes / cg_*_ready / cg_emit_types_ordered family.)
// =========================================================================
// The "already-emitted" tracking. C uses parallel bool arrays keyed by index; the functional
// `.tks` idiom tracks the emitted KEYS in lists and checks membership (named decls by name,
// optionals by inner mangle key, inline variants by tk_u_<keys> key).
type CgEmitted = struct { names: []str; opt_keys: []str; uvar_keys: []str }

fn cg_str_in(xs: []str, s: str) -> bool {
    mut i = 0
    loop { if i >= xs.len { break }; if xs[i] == s { return true }; i++ }
    false
}
// Has the named decl `name` been emitted? (a builtin/scalar not in our set has no edge → ready.)
fn cg_named_emitted(em: CgEmitted, name: str) -> bool { cg_str_in(em.names, name) }
// Has the optional whose inner mangles to `key` been emitted? (no matching node → no edge.)
fn cg_opt_emitted_key(em: CgEmitted, set: CgTypeSet, key: str) -> bool {
    // an optional inner not present in the program's collected set carries no edge → ready.
    mut i = 0
    mut present = false
    loop {
        if i >= set.inners.len { break }
        if cg_opt_key(set.inners[i]) == key { present = true; break }
        i++
    }
    if !present { return true }
    cg_str_in(em.opt_keys, key)
}
// Has the inline variant whose typename is `key` been emitted? (no matching node → no edge.)
fn cg_uvar_emitted_key(em: CgEmitted, set: CgTypeSet, key: str) -> bool {
    mut i = 0
    mut present = false
    loop {
        if i >= set.variants.len { break }
        if cg_variant_key(set.variants[i]) == key { present = true; break }
        i++
    }
    if !present { return true }
    cg_str_in(em.uvar_keys, key)
}
// By-value readiness of a resolved type (an opt inner / a variant member tk_type).
fn cg_type_ready(em: CgEmitted, set: CgTypeSet, t: checker::Type) -> bool {
    match t {
        checker::Named as nm => cg_named_emitted(em, nm.name)
        checker::Optional as opt => match opt.inner {
            checker::Void => true
            _ => cg_opt_emitted_key(em, set, cg_opt_key(opt.inner))
        }
        checker::Variant as va => cg_uvar_emitted_key(em, set, cg_variant_key(t))
        checker::Slice => true   // pointer (slice typedef pre-emitted)
        _ => true                // prim/byte/str/error/void/func — no aggregate edge
    }
}
// is `last` a builtin scalar name (no aggregate edge → ready)?
fn cg_is_builtin_scalar(last: str) -> bool {
    last == "u8" || last == "u16" || last == "u32" || last == "u64" || last == "u128" ||
    last == "i8" || last == "i16" || last == "i32" || last == "i64" || last == "i128" ||
    last == "f16" || last == "f32" || last == "f64" || last == "bool" || last == "byte" ||
    last == "str" || last == "error" || last == "ptr" || last == "uptr" ||   // (C7.1a) opaque FFI transport types
    last == "Ref"   // (MEM-1b) Ref<T> lowers to a pointer → no by-value aggregate edge
}
// By-value readiness of a field/member SYNTACTIC type-expr (struct field / variant member).
fn cg_texpr_ready(em: CgEmitted, set: CgTypeSet, te: parser::TypeExpr) -> bool {
    match te {
        parser::NamedType as nt => {
            let base = nt.path.segments[nt.path.segments.len - 1].name
            if cg_is_builtin_scalar(base) { return true }   // builtin scalar → ready
            // (S4) a generic-type USE `Box<i64>` depends on the concrete instance `Box__g__i64`, not
            // the (dropped) template `Box` — gate on the instance name.
            let last = if nt.args.len == 0 { base } else { cg_texpr_inst_name(base, nt.args) }
            cg_named_emitted(em, last)
        }
        parser::OptionalType as ot => cg_opt_emitted_key(em, set, match cg_opt_mangle_texpr_str(ot.inner) { str as s => s; error => "" })
        parser::SliceType => true   // pointer (slice typedef pre-emitted)
        parser::UnionType as ut => cg_uvar_emitted_key(em, set, match cg_variant_typename_texpr(teko::list::empty(), ut) { []byte as o => str(o); error => "" })
        parser::FunctionType => true   // (W10a) tk_closure is a runtime type — always ready
    }
}
// Is a named decl's body emittable now (all its by-value field/member deps already emitted)?
fn cg_named_ready(prog: checker::TProgram, em: CgEmitted, set: CgTypeSet, d: parser::TypeDecl) -> bool {
    match d.body {
        parser::StructBody as sb => {
            mut i = 0
            loop {
                if i >= sb.fields.len { break }
                // a boxed (recursive back-edge) field is a POINTER — needs only a forward typedef,
                // so it is NOT a by-value dependency (this is what breaks the cycle for the fixpoint).
                if cg_field_boxed(prog, d.name, sb.fields[i].type_ann) { i++ } else {
                    if !cg_texpr_ready(em, set, sb.fields[i].type_ann) { return false }
                    i++
                }
            }
            true
        }
        parser::VariantBody as vb => match vb.type_expr {
            parser::UnionType as u => {
                mut i = 0
                loop {
                    if i >= u.members.len { break }
                    if !cg_texpr_ready(em, set, u.members[i]) { return false }
                    i++
                }
                true
            }
            _ => true
        }
        _ => true   // enum / alias — no by-value dependency
    }
}

// gather the named TYPE_DECL nodes (struct/variant/enum; alias emits nothing but is harmless).
fn cg_named_decls(prog: checker::TProgram) -> []parser::TypeDecl {
    mut named: []parser::TypeDecl = teko::list::empty()
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => { named = teko::list::push(named, d) }
            _ => { }
        }
        i++
    }
    named
}

// Replaces the old program-order body emission + cg_emit_optional_typedefs: emit slices first
// (pointers), then the named/opt/inline-variant typedefs in by-value dependency order.
fn cg_emit_types_ordered(buf: []byte, prog: checker::TProgram) -> []byte | error {
    // 1) collect every optional inner / slice element / inline variant used in the program.
    mut set = CgTypeSet { inners = teko::list::empty(); slices = teko::list::empty(); variants = teko::list::empty() }
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                set = cg_collect_type_opts(set, f.return_type)
                set = cg_collect_block_opts(set, f.body)
            }
            checker::TStatement as st => { set = cg_collect_block_opts(set, teko::list::push(teko::list::empty(), st)) }
            _ => { }
        }
        i++
    }
    // (bugfix) SECOND pass over TypeDecls — register the generated typedefs a struct/variant/alias
    // FIELD's type annotation needs (tk_opt_/tk_slice_/tk_u_). Placed AFTER the function/statement
    // loop so the dedup makes it a STRICT NO-OP for the existing corpus (which already surfaces all
    // its field types via expressions) — this preserves byte-identity. Without it, a field whose
    // optional/slice/variant type appears ONLY in the declaration (never in any expression) loses
    // its typedef and `cc` fails with "unknown type name".
    mut td = 0
    loop {
        if td >= prog.items.len { break }
        match prog.items[td] {
            parser::TypeDecl as d => match d.body {
                parser::StructBody as sb => {
                    mut fi2 = 0
                    loop {
                        if fi2 >= sb.fields.len { break }
                        set = cg_collect_type_opts(set, cg_te_to_type(sb.fields[fi2].type_ann))
                        fi2++
                    }
                }
                parser::VariantBody as vb => match vb.type_expr {
                    // A NAMED variant decl gets its own `tk_t_<Name>` typedef via the named-decl
                    // path — do NOT register the whole union as an inline `tk_u_<keys>` (that would
                    // emit an UNUSED typedef and break corpus byte-identity). Only its MEMBERS'
                    // generated typedefs need registering, so recurse per-member.
                    parser::UnionType as ut => {
                        mut mi = 0
                        loop {
                            if mi >= ut.members.len { break }
                            set = cg_collect_type_opts(set, cg_te_to_type(ut.members[mi]))
                            mi++
                        }
                    }
                    _ => { set = cg_collect_type_opts(set, cg_te_to_type(vb.type_expr)) }
                }
                parser::AliasBody as alb => { set = cg_collect_type_opts(set, cg_te_to_type(alb.alias)) }
                _ => { }   // enum / flags / extern — no generated typedef to register
            }
            _ => { }
        }
        td++
    }
    let named = cg_named_decls(prog)

    mut out = buf
    // 1a) ENUMS + FLAGS FIRST — full typedefs. An enum or flags carries NO by-value type dependency
    //     (members are plain int constants / uint constants), so they lead. Emitting before slice
    //     typedefs lets `[]<enum>`/`[]<flags>` element type (`tk_t_<T> *ptr`) resolve — a
    //     struct/variant gets a forward `typedef struct` instead, but a C enum can't be forward-
    //     declared as a struct, so we emit it complete here. Mark each emitted (em0) so the step-3
    //     fixpoint SKIPS it (no duplicate typedef) and any struct embedding an enum/flags is ready.
    //     (C8.4) flags typedef is a `typedef <uint_type> tk_t_<Name>` — same no-dependency
    //     property as enum, so it joins this pass.
    mut em0 = CgEmitted { names = teko::list::empty(); opt_keys = teko::list::empty(); uvar_keys = teko::list::empty() }
    mut enum_count: u64 = 0
    mut ei = 0
    loop {
        if ei >= named.len { break }
        let is_enum_or_flags = match named[ei].body {
            parser::EnumBody  => true
            parser::FlagsBody => true
            _                 => false
        }
        if is_enum_or_flags {
            out = match emit_type_decl(out, prog, named[ei]) { []byte as o => o; error as err => return err }
            em0 = CgEmitted { names = teko::list::push(em0.names, named[ei].name); opt_keys = em0.opt_keys; uvar_keys = em0.uvar_keys }
            enum_count = enum_count + 1
        }
        ei++
    }
    if enum_count > 0 { out = cb(out, "\n") }
    // 1b) FORWARD typedefs for optionals + inline variants (named struct tags), so a boxed
    //     back-edge field (a POINTER to tk_opt_/tk_u_) and slices-of-opt/-uvar resolve before the
    //     bodies are emitted. A pointer needs a named, forward-declarable tag — an anonymous-struct
    //     typedef can't be forward-declared. (Same redef-to-same-type idiom as the named decls.)
    mut fi = 0
    loop {
        if fi >= set.inners.len { break }
        out = cb(out, "typedef struct ")
        out = match cg_opt_typename(out, set.inners[fi]) { []byte as o => o; error as err => return err }
        out = cb(out, " ")
        out = match cg_opt_typename(out, set.inners[fi]) { []byte as o => o; error as err => return err }
        out = cb(out, ";\n")
        fi++
    }
    mut fv = 0
    loop {
        if fv >= set.variants.len { break }
        match set.variants[fv] {
            checker::Variant as va => {
                out = cb(out, "typedef struct ")
                out = match cg_variant_typename(out, va) { []byte as o => o; error as err => return err }
                out = cb(out, " ")
                out = match cg_variant_typename(out, va) { []byte as o => o; error as err => return err }
                out = cb(out, ";\n")
            }
            _ => { }
        }
        fv++
    }
    if set.inners.len + set.variants.len > 0 { out = cb(out, "\n") }

    // 2) SLICE typedefs first (pointer-only; their named elements already have forward typedefs).
    // tk_slice_char is pre-declared in teko_rt.h (the `chars` builtin return type) — skip it to
    // avoid a duplicate-typedef compile error in generated programs that use chars().
    mut k = 0
    loop {
        if k >= set.slices.len { break }
        match set.slices[k] { Char => { k++; continue }; _ => { } }                  // pre-declared in teko_rt.h as tk_slice_char
        match set.slices[k] { Byte => { k++; continue }; _ => { } }                   // tk_slice_byte pre-declared in teko_rt.h
        out = cb(out, "typedef struct { ")
        out = match emit_type(out, set.slices[k]) { []byte as o => o; error as err => return err }
        out = cb(out, " *ptr; uint64_t len; } ")
        out = match cg_slice_typename(out, set.slices[k]) { []byte as o => o; error as err => return err }
        out = cb(out, ";\n")
        k++
    }
    if set.slices.len > 0 { out = cb(out, "\n") }

    // 3) fixpoint: emit named bodies + optionals + inline variants in by-value dependency order.
    //    Enums and flags were ALREADY emitted in step 1a (tracked in em0), so seed `em` with them
    //    and exclude them from `remaining` — the fixpoint then skips them (cg_named_emitted is true)
    //    and any struct embedding an enum/flags is immediately ready.
    mut em = em0
    mut remaining = named.len + set.inners.len + set.variants.len - enum_count
    mut progress = true
    loop {
        if remaining == 0 { break }
        if !progress { break }
        progress = false
        // named decls
        mut ni = 0
        loop {
            if ni >= named.len { break }
            let d = named[ni]
            if cg_named_emitted(em, d.name) { ni++ } else {
                if !cg_named_ready(prog, em, set, d) { ni++ } else {
                    out = match emit_type_decl(out, prog, d) { []byte as o => o; error as err => return err }
                    em = CgEmitted { names = teko::list::push(em.names, d.name); opt_keys = em.opt_keys; uvar_keys = em.uvar_keys }
                    remaining = remaining - 1
                    progress = true
                    ni++
                }
            }
        }
        // optionals
        mut oi = 0
        loop {
            if oi >= set.inners.len { break }
            let inner = set.inners[oi]
            let okey = cg_opt_key(inner)
            if cg_str_in(em.opt_keys, okey) { oi++ } else {
                if !cg_type_ready(em, set, inner) { oi++ } else {
                    out = cb(out, "typedef struct ")   // named tag (matches the forward decl) so a pointer to it resolves
                    out = match cg_opt_typename(out, inner) { []byte as o => o; error as err => return err }
                    out = cb(out, " { bool present; ")
                    out = match emit_type(out, inner) { []byte as o => o; error as err => return err }
                    out = cb(out, " value; } ")
                    out = match cg_opt_typename(out, inner) { []byte as o => o; error as err => return err }
                    out = cb(out, ";\n")
                    em = CgEmitted { names = em.names; opt_keys = teko::list::push(em.opt_keys, okey); uvar_keys = em.uvar_keys }
                    remaining = remaining - 1
                    progress = true
                    oi++
                }
            }
        }
        // inline variants
        mut vi = 0
        loop {
            if vi >= set.variants.len { break }
            let vt = set.variants[vi]
            let vkey = cg_variant_key(vt)
            if cg_str_in(em.uvar_keys, vkey) { vi++ } else {
                // a tk_u_ embeds its members by value — all must be ready.
                mut ready = true
                match vt {
                    checker::Variant as va => {
                        mut m = 0
                        loop {
                            if m >= va.members.len { break }
                            if !cg_type_ready(em, set, va.members[m]) { ready = false; break }
                            m++
                        }
                    }
                    _ => { }
                }
                if !ready { vi++ } else {
                    match vt {
                        checker::Variant as va => { out = match cg_emit_inline_variant_typedef(out, va) { []byte as o => o; error as err => return err } }
                        _ => { }
                    }
                    em = CgEmitted { names = em.names; opt_keys = em.opt_keys; uvar_keys = teko::list::push(em.uvar_keys, vkey) }
                    remaining = remaining - 1
                    progress = true
                    vi++
                }
            }
        }
    }
    if remaining > 0 { return error { message = "codegen: cyclic value-type dependency (a recursive type must pass through a slice or a boxed reference)" } }
    out
}

// ---------------------------------------------------------------------------
// The program -> a full C translation unit. Passes:
//   0. (W4c) every TYPE DECL -> a C type declaration, BEFORE the functions (forward
//      order): first a forward `typedef struct tk_t_<M> tk_t_<M>;` for each struct/variant
//      (so recursive/out-of-order aggregate references compile), then the full decls.
//   1. every top-level TFunction -> a C function (use-decls no-op; type-decls done above).
//   2. the loose top-level statements (the VIRTUAL-MAIN) -> int main(void){ … return 0; }.
// The C's `cg_err` (build a tk_cstr_result error) folds away: here the function simply
// `return error { … }`, since `str | error` IS the C's TK_RESULT. (C: `tk_emit_c` + `cg_err`.)
// ---------------------------------------------------------------------------
// fmt_indent — append `depth` levels of 4-space indent.
fn fmt_indent(buf: []byte, depth: u64) -> []byte {
    mut b = buf
    mut k: u64 = 0
    loop {
        if k >= depth { break }
        b = cb(b, "    ")
        k = k + 1
    }
    b
}

// cg_format_c — re-flow the generated C into readable, brace-indented form (mirror of codegen.c's
// cg_format_c). It is STRUCTURAL: STRING/CHAR literals, `//` line comments and `#` preprocessor
// lines are copied verbatim; a `;` inside `(…)` (a `for` header) does NOT break; whitespace runs
// collapse to one space; a top-level function body close gets a blank line. The bracket stack is a
// str whose chars encode each open bracket — 'B'/'b' = block/non-block brace, '(' / '[' = paren/
// bracket — pushed via concat, popped via slice_to (no in-place mutation needed). The result is
// recompiled by cc on every build, so any corruption fails loudly.
fn cg_format_c(src: str) -> []byte {
    mut out: []byte = teko::list::empty()
    mut depth: u64 = 0
    mut stk = ""
    mut line_start = true
    mut i: u64 = 0
    loop {
        if i >= src.len { break }
        let c = src[i]
        if c == b'#' && line_start {
            loop {
                if i >= src.len { break }
                if src[i] == b'\n' { break }
                out = cb_byte(out, src[i])
                i = i + 1
            }
            out = cb(out, "\n")
            if i < src.len { i = i + 1 }
            line_start = true
        } else if c == b'/' && i + 1 < src.len && src[i + 1] == b'/' {
            if line_start { out = fmt_indent(out, depth); line_start = false }
            loop {
                if i >= src.len { break }
                if src[i] == b'\n' { break }
                out = cb_byte(out, src[i])
                i = i + 1
            }
            out = cb(out, "\n")
            if i < src.len { i = i + 1 }
            line_start = true
        } else if c == b'"' || c == b'\'' {
            if line_start { out = fmt_indent(out, depth); line_start = false }
            let q = c
            out = cb_byte(out, c)
            i = i + 1
            loop {
                if i >= src.len { break }
                if src[i] == q { break }
                if src[i] == b'\\' && i + 1 < src.len {
                    out = cb_byte(out, src[i])
                    out = cb_byte(out, src[i + 1])
                    i = i + 2
                } else {
                    out = cb_byte(out, src[i])
                    i = i + 1
                }
            }
            if i < src.len && src[i] == q {
                out = cb_byte(out, q)
                i = i + 1
            }
        } else if c == b' ' || c == b'\t' || c == b'\n' || c == b'\r' {
            loop {
                if i >= src.len { break }
                let w = src[i]
                if w != b' ' && w != b'\t' && w != b'\n' && w != b'\r' { break }
                i = i + 1
            }
            // suppress the collapsed space before a `{`/`}` (the brace handler spaces it) and before
            // a `;` (so a label `done:` → `done:;`, matching the C twin's trim — no `x ;`).
            let suppress = i < src.len && (src[i] == b'}' || src[i] == b'{' || src[i] == b';')
            if !line_start && !suppress && out.len > 0 && out[out.len - 1] != b' ' { out = cb(out, " ") }
        } else if c == b'{' {
            let is_block = out.len > 0 && out[out.len - 1] == b')'
            if line_start { out = fmt_indent(out, depth) } else { out = cb(out, " ") }
            out = cb(out, "{\n")
            stk = teko::str::concat(stk, if is_block { "B" } else { "b" })
            depth = depth + 1
            line_start = true
            i = i + 1
        } else if c == b'}' {
            let was_block = stk.len > 0 && stk[stk.len - 1] == b'B'
            if depth > 0 { depth = depth - 1 }
            if stk.len > 0 { stk = teko::str::slice_to(stk, stk.len - 1) }
            if !line_start { out = cb(out, "\n") }
            out = fmt_indent(out, depth)
            out = cb(out, "}")
            if depth == 0 && was_block { out = cb(out, "\n\n"); line_start = true }
            else { line_start = false }
            i = i + 1
        } else if c == b';' {
            out = cb(out, ";")
            // break after `;` at top level (empty stack — a declaration) OR inside a `{` block;
            // NOT inside `(…)` (a `for` header). Mirrors codegen.c's `sp == 0 || top == '{'`.
            let brace_top = stk.len == 0 || stk[stk.len - 1] == b'B' || stk[stk.len - 1] == b'b'
            if brace_top { out = cb(out, "\n"); line_start = true }
            else {
                if out.len > 0 && out[out.len - 1] != b' ' { out = cb(out, " ") }
                line_start = false
            }
            i = i + 1
        } else if c == b'(' || c == b'[' {
            if line_start { out = fmt_indent(out, depth); line_start = false }
            stk = teko::str::concat(stk, if c == b'(' { "(" } else { "[" })
            out = cb_byte(out, c)
            i = i + 1
        } else if c == b')' || c == b']' {
            if stk.len > 0 { stk = teko::str::slice_to(stk, stk.len - 1) }
            out = cb_byte(out, c)
            i = i + 1
        } else {
            if line_start { out = fmt_indent(out, depth); line_start = false }
            out = cb_byte(out, c)
            i = i + 1
        }
    }
    cb(out, "\n")
}

// (W10) LAMBDA LIFTING — walk the program, STAMP each closure literal with a unique `lift_id`, and
// SYNTHESIZE a top-level function `__tkclo_<id>` for each NON-capturing lambda (its params/body are
// a plain function — emitted by the normal fn-emission, called via the W10a closure cast). Capturing
// lambdas are stamped here too; their env-struct + env-first lifted fn are emitted by the capture
// path (cg_emit_lambda_decls). The accumulator threads the id counter + the synthesized functions.
type StampAcc = struct { next: u64; fns: []checker::TFunction; lams: []checker::TLambda }
type LiftResult = struct { prog: checker::TProgram; lams: []checker::TLambda }

fn cg_lift_lambdas(prog: checker::TProgram) -> LiftResult {
    mut acc = StampAcc { next = 0; fns = teko::list::empty(); lams = teko::list::empty() }
    mut items: []checker::TItem = teko::list::empty()
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                let nb = cg_lift_block(f.body, acc)
                items = teko::list::push(items, checker::TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = f.params; return_type = f.return_type; body = nb; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = f.namespace; file = f.file; line = f.line; col = f.col; is_test = f.is_test; is_extern = f.is_extern; c_symbol = f.c_symbol; from_lib = f.from_lib })
            }
            checker::TStatement as ts => {
                let ns = cg_lift_stmt(ts, acc)
                items = teko::list::push(items, ns)
            }
            _ => items = teko::list::push(items, prog.items[i])
        }
        i++
    }
    // append the synthesized lifted functions (non-capturing → a plain top-level fn).
    mut j = 0
    loop { if j >= acc.fns.len { break }; items = teko::list::push(items, acc.fns[j]); j++ }
    LiftResult { prog = checker::TProgram { items = items }; lams = acc.lams }
}
fn cg_lift_block(stmts: []checker::TStatement, acc: Ref<StampAcc>) -> []checker::TStatement {
    mut out: []checker::TStatement = teko::list::empty()
    mut i = 0
    loop { if i >= stmts.len { break }; out = teko::list::push(out, cg_lift_stmt(stmts[i], acc)); i++ }
    out
}
fn cg_lift_stmt(s: checker::TStatement, acc: Ref<StampAcc>) -> checker::TStatement {
    match s {
        checker::TBinding as b   => checker::TBinding { kind = b.kind; target = b.target; bound = b.bound; value = cg_lift_expr(b.value, acc) }
        checker::TAssign as a    => checker::TAssign { name = a.name; op = a.op; bound = a.bound; value = cg_lift_expr(a.value, acc); deref = a.deref }
        checker::TReturn as r     => checker::TReturn { has_value = r.has_value; value = if r.has_value { cg_lift_expr(r.value, acc) } else { r.value } }
        checker::TLoopStmt as l   => checker::TLoopStmt { label = l.label; body = cg_lift_block(l.body, acc) }
        checker::TExprStmt as es  => checker::TExprStmt { expr = cg_lift_expr(es.expr, acc) }
        checker::TDeferStmt as d  => checker::TDeferStmt { body = cg_lift_block(d.body, acc) }
        checker::TBreakStmt       => s
        checker::TContinueStmt    => s
    }
}
fn cg_lift_expr(e: checker::TExpr, acc: Ref<StampAcc>) -> checker::TExpr {
    match e.kind {
        checker::TLambda as lam => {
            let id = acc.value.next
            let nbody = cg_lift_block(lam.body, acc)   // stamp nested lambdas first
            // synthesize a plain top-level fn for a NON-capturing lambda; capturing → emitted by the
            // capture path (recorded in `lams`).
            mut newfns = acc.value.fns
            mut newlams = acc.value.lams
            let stamped = checker::TLambda { params = lam.params; body = nbody; captures = lam.captures; ret = lam.ret; lift_id = id }
            if lam.captures.len == 0 {
                mut ps: []parser::Param = teko::list::empty()
                mut pi = 0
                loop { if pi >= lam.params.len { break }; ps = teko::list::push(ps, parser::Param { name = lam.params[pi].name; has_type = true; type_ann = checker::type_to_texpr(lam.params[pi].type); is_params = false ; has_default = false; default_expr = parser::no_expr() }); pi++ }
                newfns = teko::list::push(newfns, checker::TFunction { name = lam_fn_name(id); type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = ps; return_type = lam.ret; body = nbody; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" })
            } else {
                newlams = teko::list::push(newlams, stamped)
            }
            acc.value = StampAcc { next = id + 1; fns = newfns; lams = newlams }
            checker::TExpr { kind = stamped; type = e.type; line = e.line; col = e.col }
        }
        checker::TBinary as b      => checker::TExpr { kind = checker::TBinary { op = b.op; left = cg_lift_expr(b.left, acc); right = cg_lift_expr(b.right, acc) }; type = e.type; line = e.line; col = e.col }
        checker::TUnary as u       => checker::TExpr { kind = checker::TUnary { op = u.op; operand = cg_lift_expr(u.operand, acc) }; type = e.type; line = e.line; col = e.col }
        checker::TCompare as c     => {
            mut terms: []checker::TCmpTerm = teko::list::empty()
            mut i = 0
            loop { if i >= c.rest.len { break }; terms = teko::list::push(terms, checker::TCmpTerm { op = c.rest[i].op; operand = cg_lift_expr(c.rest[i].operand, acc) }); i++ }
            checker::TExpr { kind = checker::TCompare { first = cg_lift_expr(c.first, acc); rest = terms }; type = e.type; line = e.line; col = e.col }
        }
        checker::TCall as cl       => {
            mut args: []checker::TExpr = teko::list::empty()
            mut i = 0
            loop { if i >= cl.args.len { break }; args = teko::list::push(args, cg_lift_expr(cl.args[i], acc)); i++ }
            checker::TExpr { kind = checker::TCall { callee = cl.callee; args = args; call_ns = cl.call_ns; is_closure_call = cl.is_closure_call; callee_type = cl.callee_type }; type = e.type; line = e.line; col = e.col }
        }
        checker::TIfExpr as f      => checker::TExpr { kind = checker::TIfExpr { cond = cg_lift_expr(f.cond, acc); then_blk = cg_lift_block(f.then_blk, acc); has_else = f.has_else; else_blk = cg_lift_block(f.else_blk, acc) }; type = e.type; line = e.line; col = e.col }
        checker::TMatchExpr as m   => {
            mut arms: []checker::TArm = teko::list::empty()
            mut i = 0
            loop { if i >= m.arms.len { break }; let a = m.arms[i]; arms = teko::list::push(arms, checker::TArm { pattern = a.pattern; has_when = a.has_when; guard = if a.has_when { cg_lift_expr(a.guard, acc) } else { a.guard }; body = cg_lift_block(a.body, acc) }); i++ }
            checker::TExpr { kind = checker::TMatchExpr { subject = cg_lift_expr(m.subject, acc); arms = arms }; type = e.type; line = e.line; col = e.col }
        }
        checker::TCast as ct       => checker::TExpr { kind = checker::TCast { expr = cg_lift_expr(ct.expr, acc) }; type = e.type; line = e.line; col = e.col }
        checker::TFieldAccess as fa => checker::TExpr { kind = checker::TFieldAccess { receiver = cg_lift_expr(fa.receiver, acc); field = fa.field }; type = e.type; line = e.line; col = e.col }
        checker::TSafeFieldAccess as sfa => checker::TExpr { kind = checker::TSafeFieldAccess { receiver = cg_lift_expr(sfa.receiver, acc); field = sfa.field }; type = e.type; line = e.line; col = e.col }
        checker::TCoalesce as co   => checker::TExpr { kind = checker::TCoalesce { left = cg_lift_expr(co.left, acc); right = cg_lift_expr(co.right, acc) }; type = e.type; line = e.line; col = e.col }
        checker::TStructInit as si => {
            mut vals: []checker::TExpr = teko::list::empty()
            mut i = 0
            loop { if i >= si.field_vals.len { break }; vals = teko::list::push(vals, cg_lift_expr(si.field_vals[i], acc)); i++ }
            checker::TExpr { kind = checker::TStructInit { field_names = si.field_names; field_vals = vals }; type = e.type; line = e.line; col = e.col }
        }
        checker::TIndex as ix      => checker::TExpr { kind = checker::TIndex { receiver = cg_lift_expr(ix.receiver, acc); index = cg_lift_expr(ix.index, acc) }; type = e.type; line = e.line; col = e.col }
        checker::TInterp as in     => {
            mut holes: []checker::TExpr = teko::list::empty()
            mut specs: []checker::TFSpec = teko::list::empty()
            mut i = 0
            loop {
                if i >= in.holes.len { break }
                holes = teko::list::push(holes, cg_lift_expr(in.holes[i], acc))
                if i < in.specs.len {
                    let sp = in.specs[i]
                    let lifted_sp = match sp.kind {
                        checker::TFSpecDynamic as fd => {
                            mut args: []checker::TExpr = teko::list::empty()
                            mut k = 0
                            loop { if k >= fd.args.len { break }; args = teko::list::push(args, cg_lift_expr(fd.args[k], acc)); k++ }
                            checker::TFSpec { kind = checker::TFSpecDynamic { args = args } }
                        }
                        _ => sp
                    }
                    specs = teko::list::push(specs, lifted_sp)
                }
                i++
            }
            checker::TExpr { kind = checker::TInterp { pieces = in.pieces; holes = holes; specs = specs }; type = e.type; line = e.line; col = e.col }
        }
        checker::TInExpr as ie     => {
            mut elems: []checker::TExpr = teko::list::empty()
            mut i = 0
            loop { if i >= ie.elems.len { break }; elems = teko::list::push(elems, cg_lift_expr(ie.elems[i], acc)); i++ }
            checker::TExpr { kind = checker::TInExpr { lhs = cg_lift_expr(ie.lhs, acc); elems = elems }; type = e.type; line = e.line; col = e.col }
        }
        checker::TArrayLit as a    => {
            mut elems: []checker::TArrayElem = teko::list::empty()
            mut i = 0
            loop { if i >= a.elements.len { break }; elems = teko::list::push(elems, checker::TArrayElem { is_spread = a.elements[i].is_spread; expr = cg_lift_expr(a.elements[i].expr, acc) }); i++ }
            checker::TExpr { kind = checker::TArrayLit { elements = elems }; type = e.type; line = e.line; col = e.col }
        }
        _ => e   // leaves (TNumber/TVar/TStrLit/TByteLit/TBoolLit/TNullLit/TPathExpr) — no nested lambdas
    }
}

// (W10) emit the env struct + lifted function for each CAPTURING lambda. The env struct holds one
// field per capture (by-copy value, or the `T*` Ref for a by_ref capture). The lifted fn unpacks the
// env into locals of the SAME names (so the body references captures with no rewrite) then runs the
// body. ABI = env-first `R(void *envp, params)`. `protos_only` emits just the env typedefs + fn
// forward declarations (prelude); else the full definitions.
fn cg_emit_lambda_decls(buf: []byte, prog: checker::TProgram, lams: []checker::TLambda, protos_only: bool) -> []byte | error {
    mut out = buf
    mut li = 0
    loop {
        if li >= lams.len { break }
        let lam = lams[li]
        let ids = teko::u64_to_str(lam.lift_id)
        // env struct typedef — emitted ONCE, in the protos pass only (re-emitting it in the defs pass
        // is a typedef redefinition error).
        if protos_only {
            out = cb(out, "typedef struct { ")
            mut ci = 0
            loop {
                if ci >= lam.captures.len { break }
                out = match emit_type(out, lam.captures[ci].type) { []byte as o => o; error as e => return e }
                out = cb(out, " ")
                out = cb_ident(out, lam.captures[ci].name)
                out = cb(out, "; ")
                ci++
            }
            out = cb(out, teko::str::concat("} __tkenv_", ids, ";\n"))
        }
        // lifted fn signature: R __tkclo_<id>(void *envp, params)
        out = match emit_type(out, lam.ret) { []byte as o => o; error as e => return e }
        out = cb(out, teko::str::concat(" __tkclo_", ids, "(void *envp"))
        mut pi = 0
        loop {
            if pi >= lam.params.len { break }
            out = cb(out, ", ")
            out = match emit_type(out, lam.params[pi].type) { []byte as o => o; error as e => return e }
            out = cb(out, " ")
            out = cb_ident(out, lam.params[pi].name)
            pi++
        }
        out = cb(out, ")")
        if protos_only {
            out = cb(out, ";\n")
        } else {
            out = cb(out, " {\n")
            out = cb(out, teko::str::concat("    __tkenv_", ids, " *_e = envp;\n"))
            mut ui = 0
            loop {
                if ui >= lam.captures.len { break }
                out = cb(out, "    ")
                out = match emit_type(out, lam.captures[ui].type) { []byte as o => o; error as e => return e }
                out = cb(out, " ")
                out = cb_ident(out, lam.captures[ui].name)
                out = cb(out, " = _e->")
                out = cb_ident(out, lam.captures[ui].name)
                out = cb(out, ";\n")
                ui++
            }
            // the body (reuse emit_block_tail; lifted fns route allocations to root — no frame region).
            out = match emit_block_tail(out, lam.body, false, prog, lam.ret, "    ", "", teko::list::empty(), lam.body, dctx_empty()) { []byte as o => o; error as e => return e }
            out = cb(out, "}\n")
        }
        li++
    }
    out
}

fn tk_emit_c(prog0: checker::TProgram) -> str | error {
    let _lr = cg_lift_lambdas(prog0)   // (W10) stamp lambdas + synthesize lifted functions before emission
    let prog = _lr.prog
    let cap_lams = _lr.lams
    mut b: []byte = teko::list::empty()
    b = cb(b, "// generated by teko (F2 backend) — do not edit\n")
    b = cb(b, "#include <stdint.h>\n")
    b = cb(b, "#include <stdbool.h>\n")
    b = cb(b, "#include <stdlib.h>\n")   // malloc/abort — slice copy-append (fixed+copy)
    b = cb(b, "#include <math.h>\n")      // floor/… — float ops the corpus lowers inline (link -lm)
    b = cb(b, "#include \"teko_rt.h\"\n")
    b = cb(b, "#include \"assert.h\"\n\n")   // teko::assert seed decls (driver adds its -I)

    // W4c — TYPE DECLS come FIRST (before any function that uses them). Two sub-passes:
    //   a) a forward `typedef struct tk_t_<M> tk_t_<M>;` for every struct/variant decl, so
    //      a field/member that references a not-yet-defined aggregate (recursive or
    //      out-of-order types) still compiles.
    //   b) the full type declarations (struct bodies, variant tag+union, enums).
    // (enums need no forward typedef — they carry no aggregate self-reference.)
    mut fw = 0
    loop {
        if fw >= prog.items.len { break }
        match prog.items[fw] {
            parser::TypeDecl as d => {
                // only STRUCT/VARIANT decls need a forward `typedef struct …;` (an aggregate
                // self-reference). enums carry none; a TRANSPARENT alias emits no C type at all.
                match d.body {
                    parser::StructBody => {
                        b = cb(b, "typedef struct ")
                        b = mangle_type_name(b, "", d.name)
                        b = cb(b, " ")
                        b = mangle_type_name(b, "", d.name)
                        b = cb(b, ";\n")
                    }
                    parser::VariantBody => {
                        b = cb(b, "typedef struct ")
                        b = mangle_type_name(b, "", d.name)
                        b = cb(b, " ")
                        b = mangle_type_name(b, "", d.name)
                        b = cb(b, ";\n")
                    }
                    _ => { }   // enum / alias: no forward typedef
                }
            }
            _ => { }
        }
        fw++
    }
    b = cb(b, "\n")
    // Full type declarations IN DEPENDENCY ORDER (self-host): slice typedefs first (pointers),
    // then named bodies + optionals (REBOOT_PLAN §202) + inline variants topologically, so every
    // by-value embed (`tk_t_Y`, `tk_opt_T`, `tk_u_…`) is fully defined before the body using it.
    // This is also before any function (so `T?`/`[]T`/variant signatures resolve).
    b = match cg_emit_types_ordered(b, prog) { []byte as o => o; error as err => return err }

    // Function PROTOTYPES — a forward declaration for every function, so a call to a function
    // defined LATER in the unit (mutual recursion / forward reference across the merged corpus)
    // resolves. C23 makes an undeclared call an error, so without these the whole self-host corpus
    // (which freely forward-references) fails to compile. (C: the prototype pass in tk_emit_c.)
    // (C7.2) Skip `from "teko_rt"` externs — they are already declared in teko_rt.h with the
    // correct FFI struct types (tk_ffi_ures/tk_ffi_sres/etc.); emitting them again would conflict.
    mut pi = 0
    loop {
        if pi >= prog.items.len { break }
        match prog.items[pi] {
            checker::TFunction as f => {
                if !(f.is_extern && f.from_lib == "teko_rt") {
                    b = match emit_function_sig(b, prog, f) { []byte as o => o; error as err => return err }
                    b = cb(b, ";\n")
                }
            }
            _ => { }
        }
        pi++
    }
    b = cb(b, "\n")
    // (W10) CAPTURING lambdas: env-struct typedefs + lifted-fn forward declarations (so a closure
    // literal `&__tkclo_<id>` + `sizeof(__tkenv_<id>)` resolve before the user functions).
    b = match cg_emit_lambda_decls(b, prog, cap_lams, true) { []byte as o => o; error as err => return err }
    b = cb(b, "\n")

    // First pass: emit every top-level function. Type-decls are handled above; use-decls
    // are a no-op at the C level (imports); loose statements are the second pass.
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => { if !f.is_extern { b = match emit_function(b, prog, f) { []byte as o => o; error as err => return err } } }   // C7.1a: extern fns have no body (prototype only)
            parser::TypeDecl       => { }   // emitted in the type-decl passes above
            parser::UseDecl        => { }   // imports are a no-op at the C level (M0)
            checker::TStatement     => { }   // a loose Statement → virtual-main, second pass
        }
        i++
    }
    // (W10) CAPTURING lambdas: the lifted-function DEFINITIONS (env unpack + body).
    b = match cg_emit_lambda_decls(b, prog, cap_lams, false) { []byte as o => o; error as err => return err }

    // Second pass: the VIRTUAL-MAIN — the loose top-level statements, in order, become the
    // body of C main(); falling off the end -> `return 0;` (default exit 0).
    // W5a — the LAST loose statement, if it is a value-carrying expr-statement, becomes the
    // process exit code via `return (int)(…)` (mirrors tk_vm_run: the virtual-main's trailing
    // value is the exit code — B.20). emit_block_tail (with in_main=true) lowers a tail `if`'s
    // branch returns to `return (int)(…)`.
    // Find the LAST loose statement's index (the tail); prog.items.len means "no loose stmt".
    mut last_stmt = prog.items.len
    mut li: u64 = 0                    // u64 index (so `last_stmt = li` matches last_stmt's u64 type)
    loop {
        if li >= prog.items.len { break }
        match prog.items[li] {
            checker::TStatement => { last_stmt = li }
            _ => { }
        }
        li++
    }
    // main captures argv so teko::env::args() (tk_rt_args) can return it; tk_set_args first.
    b = cb(b, "int main(int argc, char **argv) {\n")
    b = cb(b, "    tk_set_args(argc, argv);\n")
    mut j = 0
    loop {
        if j >= prog.items.len { break }
        match prog.items[j] {
            checker::TFunction => { }   // handled in pass 1
            parser::TypeDecl  => { }   // handled in the type-decl passes
            parser::UseDecl   => { }   // no-op
            checker::TStatement as s    => {
                // The virtual-main has no variant return slot (its tail value is the int exit
                // code), so ret_type is void — emit_as never wraps for void.
                if j == last_stmt {
                    // the tail loose statement → implicit-return path (a one-statement block).
                    // The virtual-main is FRAMELESS: its allocations live for the whole process (M.5).
                    let tail = teko::list::push(teko::list::empty(), s)
                    b = match emit_block_tail(b, tail, true, prog, checker::Void { }, "    ", "", teko::list::empty(), teko::list::empty(), dctx_empty()) { []byte as o => o; error as err => return err }
                } else {
                    b = match emit_stmt(b, s, true, prog, checker::Void { }, "    ", "", teko::list::empty(), teko::list::empty(), teko::list::empty(), dctx_empty(), teko::list::empty(), false) { []byte as o => o; error as err => return err }
                }
            }
        }
        j++
    }
    b = cb(b, "    return 0;\n")
    b = cb(b, "}\n")

    // Re-flow into readable, brace-indented C (the raw emission packs each `({…})` on one line).
    str(cg_format_c(str(b)))
}

// E3 — the `.tsym` symbol map (mirror of codegen.c tk_emit_tsym): one line per function mapping its
// mangled C symbol to the Teko qualified name + source `file:line`, for the native stack-trace (E4).
fn tk_emit_tsym(prog: checker::TProgram) -> str {
    mut b: []byte = teko::list::empty()
    b = cb(b, "# teko symbol map (.tsym v1): <c-symbol>\\t<teko-name>\\t<file>:<line>\n")
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                b = cb_fn_name(b, f.namespace, f.name)   // the mangled C symbol (matches the definition)
                b = cb(b, "\t")
                if f.namespace.len != 0 {
                    b = cb(b, f.namespace)
                    b = cb(b, "::")
                }
                b = cb(b, f.name)                        // the Teko qualified name
                b = cb(b, "\t")
                b = cb(b, f.file)
                b = cb(b, ":")
                b = cb_u128_digits(b, f.line to u128)
                b = cb(b, "\n")
            }
            _ => { }
        }
        i = i + 1
    }
    str(b)
}
