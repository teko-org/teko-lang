// src/regex/regex_test.tkt — tests for teko::regex (ROUND 0 minimal engine).
// Covers: literal match, `.`, `*`/`+`/`?`, character classes, alternation, grouping,
// anchors — both matching AND non-matching cases, plus a couple of bad-pattern cases.

// helper (not a test): unwrap `bool | error` from is_match_pattern — a bad pattern in
// these matching tests is itself a test failure (the pattern is meant to compile).
fn matched(pattern: str, input: str) -> bool {
    match teko::regex::is_match_pattern(pattern, input) {
        bool as b => b
        error => { teko::assert::is_true(false); false }
    }
}

// --- `?` (zero or one) ---

#test
fn opt_matches_zero_or_one() {
    teko::assert::is_true(matched("colou?r", "color"))
    teko::assert::is_true(matched("colou?r", "colour"))
}

// --- character classes ---

#test
fn class_negation_matches() {
    teko::assert::is_true(matched("[^0-9]", "x"))
    teko::assert::is_false(matched("^[^0-9]+$", "abc123"))
}

// --- full_match (both ends anchored regardless of literal ^/$) ---

#test
fn full_match_requires_the_whole_input() {
    let re = match teko::regex::compile("ab*c") {
        teko::regex::Regex as r => r
        error => { teko::assert::is_true(false); teko::regex::Regex { pattern = ""; ast = teko::regex::REmpty { } } }
    }
    teko::assert::is_true(teko::regex::full_match(re, "abbc"))
    teko::assert::is_false(teko::regex::full_match(re, "xabbc"))
}
