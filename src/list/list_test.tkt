#test fn grow_monomorphizes_per_width() {
    mut xs: []str = ["a"]
    teko::list::grow(&xs, "b")
    teko::assert::is_true(xs.len == 2)
    teko::assert::is_true(xs[0] == "a")
    teko::assert::is_true(xs[1] == "b")
}

/**
 * Sum a parameter `[]u64` with the slice for-each read form `loop x in ids` — proving `x` binds the
 * ELEMENT (a value copy) of a by-value parameter slice, not the index. Used by the read-form test to
 * exercise the parameter (read-only) path distinct from a local container.
 *
 * @param ids  the parameter slice whose elements are summed
 * @return     the sum of every element (0 for an empty slice)
 */
fn sum_u64(ids: []u64) -> u64 {
    mut s: u64 = 0
    loop x in ids { s = s + x }
    s
}

/**
 * Accumulate `element - index` over a parameter `[]u64` with the enumerate for-each `loop (x, i) in
 * ids` — pinning the owner-ratified binding ORDER (element FIRST, index SECOND, index typed `u64`).
 * Chosen data keeps every `x - i` non-negative; a swapped order (index into `x`, element into `i`)
 * would compute `0 - first_element`, underflowing `u64` to a huge value — so a correct total is a
 * guard against a reversed binding.
 *
 * @param ids  the parameter slice enumerated as `(element, index)`
 * @return     the sum of `element - index` across the slice
 */
fn weighted_u64(ids: []u64) -> u64 {
    mut a: u64 = 0
    loop (x, i) in ids { a = a + x - i }
    a
}

/**
 * The slice for-each read form `loop x in ids` over a by-value parameter slice binds each ELEMENT in
 * turn (a value copy), so the accumulator sees the element values.
 */
#test
fn foreach_reads_param_slice() {
    let xs: []u64 = [3, 4, 5]
    teko::assert::is_true(sum_u64(xs) == 12)
}

/**
 * The enumerate for-each `loop (x, i) in ids` binds the element FIRST and the index SECOND (a `u64`).
 * The chosen data makes a reversed binding underflow `u64`, so the exact total pins the order.
 */
#test
fn foreach_enumerate_element_first_index_u64() {
    let xs: []u64 = [10, 20, 30]
    teko::assert::is_true(weighted_u64(xs) == 57)
}
