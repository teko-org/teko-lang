/**
 * Assert two `i64` slices hold the same length and element-wise-equal values — the equality check
 * `teko::assert` lacks natively, kept local so `grow`'s effect can be asserted as a whole array.
 *
 * @param got   the slice produced by the operation under test
 * @param want  the expected slice contents
 */
fn assert_i64_slice_eq(got: []i64, want: []i64) {
    teko::assert::is_true(got.len == want.len)
    mut i: u64 = 0
    loop {
        if i >= want.len { break }
        teko::assert::is_true(got[i] == want[i])
        i++
    }
}

#test fn grow_appends_i64_in_place() {
    mut x: []i64 = [1, 2]
    teko::list::grow(&x, 3)
    assert_i64_slice_eq(x, [1, 2, 3])
}

#test fn grow_appends_onto_empty() {
    mut x: []i64 = teko::list::empty()
    teko::list::grow(&x, 7)
    assert_i64_slice_eq(x, [7])
}

#test fn grow_monomorphizes_per_width() {
    mut xs: []str = ["a"]
    teko::list::grow(&xs, "b")
    teko::assert::is_true(xs.len == 2)
    teko::assert::is_true(xs[0] == "a")
    teko::assert::is_true(xs[1] == "b")
}
