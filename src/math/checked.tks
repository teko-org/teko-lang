}

/**
 * Subtract `a - b` as `u32`, erroring instead of wrapping on unsigned underflow.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `u32`, or an `error` if `b > a`
 * @throws      when `b > a` (the difference would be negative, impossible for `u32`)
 */
pub fn checked_sub_u32(a: u32, b: u32) -> u32 | error {
    if b > a { return checked_error("math::checked_sub_u32: underflow") }
