/**
 * Remainder `a % b` as `u32`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `u32`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_u32(a: u32, b: u32) -> u32 | error {
    if b == U32_MIN { return checked_error("math::checked_rem_u32: divide by zero") }
    a % b
}

/**
 * Negate `a` as `u32`. Only `0` negates within an unsigned type; any nonzero value has no representable negative.
 *
 * @param a  the value to negate
 * @return      `0` when `a == 0`, otherwise an `error`
 * @throws      when `a != 0` (an unsigned type has no negative values)
 */
pub fn checked_neg_u32(a: u32) -> u32 | error {
    if a == U32_MIN { return U32_MIN }
    checked_error("math::checked_neg_u32: unsigned negation of a nonzero value")
}

/**
 * Raise `base` to `exp` as `u32` by squaring, erroring instead of wrapping on overflow. `base^0 == 1` (the empty product).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `u32`, or an `error` if any intermediate overflows
 * @throws      when a partial product exceeds `u32::MAX`
 */
pub fn checked_pow_u32(base: u32, power: u32) -> u32 | error {
    mut result: u32 = (1 to u32)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_u32(result, b) {
                u32 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_u32(b, b) {
                u32 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `u32`, erroring when `count >= 32` (distinct from `wrapping_shl`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a << count` as `u32`, or an `error` if `count >= 32`
 * @throws      when `count >= 32`
 */
pub fn checked_shl_u32(a: u32, count: u32) -> u32 | error {
    if count >= 32 { return checked_error("math::checked_shl_u32: shift out of range") }
    a << (count to u32)
}

/**
 * Shift `a` right by `count` bits as `u32` (logical), erroring when `count >= 32` (distinct from `wrapping_shr`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a >> count` as `u32`, or an `error` if `count >= 32`
 * @throws      when `count >= 32`
 */
pub fn checked_shr_u32(a: u32, count: u32) -> u32 | error {
    if count >= 32 { return checked_error("math::checked_shr_u32: shift out of range") }
    a >> (count to u32)
}

/**
 * Wrapping `a + b` as `u32` â€” the sum modulo 2^32. The unsigned `+` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a + b) mod 2^32` as `u32`
 */
pub fn wrapping_add_u32(a: u32, b: u32) -> u32 { a + b }

/**
 * Wrapping `a - b` as `u32` â€” the difference modulo 2^32. The unsigned `-` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a - b) mod 2^32` as `u32`
 */
pub fn wrapping_sub_u32(a: u32, b: u32) -> u32 { a - b }

/**
 * Wrapping `a * b` as `u32` â€” the product modulo 2^32. The unsigned `*` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a * b) mod 2^32` as `u32`
 */
pub fn wrapping_mul_u32(a: u32, b: u32) -> u32 { a * b }

/**
 * Wrapping negation of `a` as `u32` â€” `(0 - a) mod 2^32` (`0` maps to `0`). Total; the unsigned subtraction is defined modular.
 *
 * @param a  the value to negate
 * @return      `(0 - a) mod 2^32` as `u32`
 */
pub fn wrapping_neg_u32(a: u32) -> u32 { U32_MIN - a }

/**
 * Wrapping left shift of `a` by `count` bits as `u32`; the count is masked to `count mod 32` (the #49/#61 shift semantics), so it never traps. Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 32`)
 * @return      `a << (count mod 32)` as `u32`
 */
pub fn wrapping_shl_u32(a: u32, count: u32) -> u32 { a << ((count % 32) to u32) }

/**
 * Wrapping right shift of `a` by `count` bits as `u32` (logical); the count is masked to `count mod 32` (the #49/#61 shift semantics). Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 32`)
 * @return      `a >> (count mod 32)` as `u32`
 */
pub fn wrapping_shr_u32(a: u32, count: u32) -> u32 { a >> ((count % 32) to u32) }

/**
 * Saturating `a + b` as `u32` â€” clamps to `u32::MAX` on overflow instead of wrapping or erroring. Total.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b`, or `u32::MAX` if the sum would overflow
 */
pub fn saturating_add_u32(a: u32, b: u32) -> u32 {
    if a > U32_MAX - b { return U32_MAX }
    a + b
}

/**
 * Saturating `a - b` as `u32` â€” clamps to `0` on underflow instead of wrapping or erroring. Total.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b`, or `0` if `b > a`
 */
pub fn saturating_sub_u32(a: u32, b: u32) -> u32 {
    if b > a { return U32_MIN }
    a - b
}

/**
 * Saturating `a * b` as `u32` â€” clamps to `u32::MAX` on overflow. Total.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b`, or `u32::MAX` if the product would overflow
 */
pub fn saturating_mul_u32(a: u32, b: u32) -> u32 {
    if a == U32_MIN || b == U32_MIN { return U32_MIN }
    if b > U32_MAX / a { return U32_MAX }
    a * b
}

/**
 * `u64::MIN` â€” zero (every unsigned type's floor).
 */
pub const U64_MIN: u64 = 0 to u64

/**
 * `u64::MAX` (2^64 - 1), constructed as `~0` (all bits set) â€” one uniform,
 * width-agnostic form for every unsigned ceiling.
 */
pub const U64_MAX: u64 = ~(0 to u64)

/**
 * Add `a + b` as `u64`, erroring instead of wrapping on overflow.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b` as `u64`, or an `error` if the sum exceeds `u64::MAX`
 * @throws      when `a > u64::MAX - b`
 */
pub fn checked_add_u64(a: u64, b: u64) -> u64 | error {
    if a > U64_MAX - b { return checked_error("math::checked_add_u64: overflow") }
    a + b
}

/**
 * Subtract `a - b` as `u64`, erroring instead of wrapping on unsigned underflow.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `u64`, or an `error` if `b > a`
 * @throws      when `b > a` (the difference would be negative, impossible for `u64`)
 */
pub fn checked_sub_u64(a: u64, b: u64) -> u64 | error {
    if b > a { return checked_error("math::checked_sub_u64: underflow") }
    a - b
}

/**
 * Multiply `a * b` as `u64`, erroring instead of wrapping on overflow.
 *
 * Zero operands never overflow; otherwise the product overflows iff `b > u64::MAX / a`.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b` as `u64`, or an `error` if the product exceeds `u64::MAX`
 * @throws      when `a != 0` and `b > u64::MAX / a`
 */
pub fn checked_mul_u64(a: u64, b: u64) -> u64 | error {
    if a == U64_MIN || b == U64_MIN { return U64_MIN }
    if b > U64_MAX / a { return checked_error("math::checked_mul_u64: overflow") }
    a * b
}

/**
 * Divide `a / b` as `u64`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `u64`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_div_u64(a: u64, b: u64) -> u64 | error {
    if b == U64_MIN { return checked_error("math::checked_div_u64: divide by zero") }
    a / b
}

/**
 * Remainder `a % b` as `u64`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `u64`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_u64(a: u64, b: u64) -> u64 | error {
    if b == U64_MIN { return checked_error("math::checked_rem_u64: divide by zero") }
    a % b
}

/**
 * Negate `a` as `u64`. Only `0` negates within an unsigned type; any nonzero value has no representable negative.
 *
 * @param a  the value to negate
 * @return      `0` when `a == 0`, otherwise an `error`
 * @throws      when `a != 0` (an unsigned type has no negative values)
 */
pub fn checked_neg_u64(a: u64) -> u64 | error {
    if a == U64_MIN { return U64_MIN }
    checked_error("math::checked_neg_u64: unsigned negation of a nonzero value")
}

/**
 * Raise `base` to `exp` as `u64` by squaring, erroring instead of wrapping on overflow. `base^0 == 1` (the empty product).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `u64`, or an `error` if any intermediate overflows
 * @throws      when a partial product exceeds `u64::MAX`
 */
pub fn checked_pow_u64(base: u64, power: u32) -> u64 | error {
    mut result: u64 = (1 to u64)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_u64(result, b) {
                u64 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_u64(b, b) {
                u64 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `u64`, erroring when `count >= 64` (distinct from `wrapping_shl`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a << count` as `u64`, or an `error` if `count >= 64`
 * @throws      when `count >= 64`
 */
pub fn checked_shl_u64(a: u64, count: u32) -> u64 | error {
    if count >= 64 { return checked_error("math::checked_shl_u64: shift out of range") }
    a << (count to u64)
}

/**
 * Shift `a` right by `count` bits as `u64` (logical), erroring when `count >= 64` (distinct from `wrapping_shr`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a >> count` as `u64`, or an `error` if `count >= 64`
 * @throws      when `count >= 64`
 */
pub fn checked_shr_u64(a: u64, count: u32) -> u64 | error {
    if count >= 64 { return checked_error("math::checked_shr_u64: shift out of range") }
    a >> (count to u64)
}

/**
 * Wrapping `a + b` as `u64` â€” the sum modulo 2^64. The unsigned `+` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a + b) mod 2^64` as `u64`
 */
pub fn wrapping_add_u64(a: u64, b: u64) -> u64 { a + b }

/**
 * Wrapping `a - b` as `u64` â€” the difference modulo 2^64. The unsigned `-` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a - b) mod 2^64` as `u64`
 */
pub fn wrapping_sub_u64(a: u64, b: u64) -> u64 { a - b }

/**
 * Wrapping `a * b` as `u64` â€” the product modulo 2^64. The unsigned `*` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a * b) mod 2^64` as `u64`
 */
pub fn wrapping_mul_u64(a: u64, b: u64) -> u64 { a * b }

/**
 * Wrapping negation of `a` as `u64` â€” `(0 - a) mod 2^64` (`0` maps to `0`). Total; the unsigned subtraction is defined modular.
 *
 * @param a  the value to negate
 * @return      `(0 - a) mod 2^64` as `u64`
 */
pub fn wrapping_neg_u64(a: u64) -> u64 { U64_MIN - a }

/**
 * Wrapping left shift of `a` by `count` bits as `u64`; the count is masked to `count mod 64` (the #49/#61 shift semantics), so it never traps. Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 64`)
 * @return      `a << (count mod 64)` as `u64`
 */
pub fn wrapping_shl_u64(a: u64, count: u32) -> u64 { a << ((count % 64) to u64) }

/**
 * Wrapping right shift of `a` by `count` bits as `u64` (logical); the count is masked to `count mod 64` (the #49/#61 shift semantics). Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 64`)
 * @return      `a >> (count mod 64)` as `u64`
 */
pub fn wrapping_shr_u64(a: u64, count: u32) -> u64 { a >> ((count % 64) to u64) }

/**
 * Saturating `a + b` as `u64` â€” clamps to `u64::MAX` on overflow instead of wrapping or erroring. Total.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b`, or `u64::MAX` if the sum would overflow
 */
pub fn saturating_add_u64(a: u64, b: u64) -> u64 {
    if a > U64_MAX - b { return U64_MAX }
    a + b
}

/**
 * Saturating `a - b` as `u64` â€” clamps to `0` on underflow instead of wrapping or erroring. Total.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b`, or `0` if `b > a`
 */
pub fn saturating_sub_u64(a: u64, b: u64) -> u64 {
    if b > a { return U64_MIN }
    a - b
}

/**
 * Saturating `a * b` as `u64` â€” clamps to `u64::MAX` on overflow. Total.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b`, or `u64::MAX` if the product would overflow
 */
pub fn saturating_mul_u64(a: u64, b: u64) -> u64 {
    if a == U64_MIN || b == U64_MIN { return U64_MIN }
    if b > U64_MAX / a { return U64_MAX }
    a * b
}

/**
 * `i8::MAX` (2^7 - 1).
 */
pub const I8_MAX: i8 = 127

/**
 * The minimum value of `i8` (-2^7). Written as `-MAX - 1` via an annotated intermediate, since `-2^7` has no positive counterpart to negate.
 *
 * @return      `i8::MIN`
 */
pub fn i8_min() -> i8 {
    let m: i8 = -127
    m - 1
}

/**
 * Reinterpret `a: i8` as its two's-complement bit pattern typed `u8`.
 *
 * Non-negative `a` maps directly. For negative `a`, `a - i8::MIN` lands in
 * `[0, 2^7 - 1]` (in range â€” no trapping cast, no signed overflow); adding the
 * sign bit `2^7` in the `u8` domain reconstructs `a + 2^8`, the two's-complement
 * pattern. Mirrors the VM's `norm_int`, so both engines agree bit-for-bit.
 *
 * @param a  the signed value to reinterpret
 * @return      the `u8` whose bits equal `a`'s two's-complement encoding
 */
fn u8_bits_of_i8(a: i8) -> u8 {
    if a >= 0 { return a to u8 }
    (a - i8_min()) to u8 + ((1 to u8) << 7)
}

/**
 * Reinterpret a `u8` bit pattern `u` as the `i8` it two's-complement encodes â€” the inverse of `u8_bits_of_i8`.
 *
 * Sign bit clear (`u < 2^7`) maps directly. Otherwise `u - 2^7` is in
 * `[0, 2^7 - 1]` (in range), and adding `i8::MIN` yields `u - 2^8`, the signed
 * interpretation of a set sign bit.
 *
 * @param u  the `u8` bit pattern to reinterpret
 * @return      the `i8` two's-complement-encoded by `u`
 */
fn i8_from_u8_bits(u: u8) -> i8 {
    if u < ((1 to u8) << 7) { return u to i8 }
    (u - ((1 to u8) << 7)) to i8 + i8_min()
}

/**
 * Add `a + b` as `i8`, erroring instead of overflowing (signed overflow is UB in the emitted C â€” never performed here). Overflow is caught by in-range boundary comparisons.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b` as `i8`, or an `error` on signed overflow
 * @throws      when the sum leaves `[i8::MIN, i8::MAX]`
 */
pub fn checked_add_i8(a: i8, b: i8) -> i8 | error {
    if b > 0 && a > I8_MAX - b { return checked_error("math::checked_add_i8: overflow") }
    if b < 0 && a < i8_min() - b { return checked_error("math::checked_add_i8: overflow") }
    a + b
}

/**
 * Subtract `a - b` as `i8`, erroring instead of overflowing. The boundary comparisons (`i8::MAX + b` for `b < 0`, `i8::MIN + b` for `b > 0`) stay in range.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `i8`, or an `error` on signed overflow
 * @throws      when the difference leaves `[i8::MIN, i8::MAX]`
 */
pub fn checked_sub_i8(a: i8, b: i8) -> i8 | error {
    if b < 0 && a > I8_MAX + b { return checked_error("math::checked_sub_i8: overflow") }
    if b > 0 && a < i8_min() + b { return checked_error("math::checked_sub_i8: overflow") }
    a - b
}

/**
 * Multiply `a * b` as `i8`, erroring instead of overflowing. The `i8::MIN` corners (`a == -1 && b == MIN`, and its mirror) are handled before the division-bound checks, since `MIN / -1` itself overflows.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b` as `i8`, or an `error` on signed overflow
 * @throws      when the product leaves `[i8::MIN, i8::MAX]`
 */
pub fn checked_mul_i8(a: i8, b: i8) -> i8 | error {
    if a == 0 || b == 0 { return (0 to i8) }
    if a == -1 {
        if b == i8_min() { return checked_error("math::checked_mul_i8: overflow") }
        return -b
    }
    if b == -1 {
        if a == i8_min() { return checked_error("math::checked_mul_i8: overflow") }
        return -a
    }
    if a > 0 {
        if b > 0 && a > I8_MAX / b { return checked_error("math::checked_mul_i8: overflow") }
        if b < 0 && b < i8_min() / a { return checked_error("math::checked_mul_i8: overflow") }
    } else {
        if b > 0 && a < i8_min() / b { return checked_error("math::checked_mul_i8: overflow") }
        if b < 0 && a < I8_MAX / b { return checked_error("math::checked_mul_i8: overflow") }
    }
    a * b
}

/**
 * Divide `a / b` as `i8`, erroring on a zero divisor and on `i8::MIN / -1` (whose true quotient `i8::MAX + 1` is unrepresentable).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `i8`, or an `error` on divide-by-zero or `MIN / -1`
 * @throws      when `b == 0`, or `a == i8::MIN && b == -1`
 */
pub fn checked_div_i8(a: i8, b: i8) -> i8 | error {
    if b == 0 { return checked_error("math::checked_div_i8: divide by zero") }
    if a == i8_min() && b == -1 { return checked_error("math::checked_div_i8: overflow") }
    a / b
}

/**
 * Remainder `a % b` as `i8`, erroring on a zero divisor. `i8::MIN % -1` is defined `0` (returned directly; the bare `%` would be UB there).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `i8`, `0` for `MIN % -1`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_i8(a: i8, b: i8) -> i8 | error {
    if b == 0 { return checked_error("math::checked_rem_i8: divide by zero") }
    if a == i8_min() && b == -1 { return (0 to i8) }
    a % b
}

/**
 * Negate `a` as `i8`, erroring only on `i8::MIN` (which has no representable positive counterpart in two's complement).
 *
 * @param a  the value to negate
 * @return      `-a` as `i8`, or an `error` if `a == i8::MIN`
 * @throws      when `a == i8::MIN`
 */
pub fn checked_neg_i8(a: i8) -> i8 | error {
    if a == i8_min() { return checked_error("math::checked_neg_i8: overflow") }
    -a
}

/**
 * Raise `base` to `exp` as `i8` by squaring, erroring instead of overflowing. `base^0 == 1`; a negative base is fine (its sign follows the exponent's parity).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `i8`, or an `error` if any step overflows
 * @throws      when a partial product leaves `[i8::MIN, i8::MAX]`
 */
pub fn checked_pow_i8(base: i8, power: u32) -> i8 | error {
    mut result: i8 = (1 to i8)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_i8(result, b) {
                i8 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_i8(b, b) {
                i8 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `i8`, erroring when `count >= 8`. The shift itself rides the runtime's masked, UB-free signed shift.
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a << count` as `i8`, or an `error` if `count >= 8`
 * @throws      when `count >= 8`
 */
pub fn checked_shl_i8(a: i8, count: u32) -> i8 | error {
    if count >= 8 { return checked_error("math::checked_shl_i8: shift out of range") }
    a << (count to i8)
}

/**
 * Shift `a` right by `count` bits as `i8` (arithmetic â€” sign-preserving), erroring when `count >= 8`.
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a >> count` as `i8`, or an `error` if `count >= 8`
 * @throws      when `count >= 8`
 */
pub fn checked_shr_i8(a: i8, count: u32) -> i8 | error {
    if count >= 8 { return checked_error("math::checked_shr_i8: shift out of range") }
    a >> (count to i8)
}

/**
 * Wrapping `a + b` as `i8` â€” the sum modulo 2^8. Routed through the `u8` domain (where `+` is defined modular in C) and reinterpreted back, so no signed overflow UB is emitted. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a + b) mod 2^8` as `i8` (two's-complement wraparound)
 */
pub fn wrapping_add_i8(a: i8, b: i8) -> i8 {
    i8_from_u8_bits(u8_bits_of_i8(a) + u8_bits_of_i8(b))
}

/**
 * Wrapping `a - b` as `i8` â€” the difference modulo 2^8. Routed through the `u8` domain (where `-` is defined modular in C) and reinterpreted back, so no signed overflow UB is emitted. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a - b) mod 2^8` as `i8` (two's-complement wraparound)
 */
pub fn wrapping_sub_i8(a: i8, b: i8) -> i8 {
    i8_from_u8_bits(u8_bits_of_i8(a) - u8_bits_of_i8(b))
}

/**
 * Wrapping `a * b` as `i8` â€” the product modulo 2^8. Routed through the `u8` domain (where `*` is defined modular in C) and reinterpreted back, so no signed overflow UB is emitted. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a * b) mod 2^8` as `i8` (two's-complement wraparound)
 */
pub fn wrapping_mul_i8(a: i8, b: i8) -> i8 {
    i8_from_u8_bits(u8_bits_of_i8(a) * u8_bits_of_i8(b))
}

/**
 * Wrapping negation of `a` as `i8` â€” `i8::MIN` maps to itself (defining the UB corner). Routed through the `u8` domain, so no signed overflow is emitted. Total.
 *
 * @param a  the value to negate
 * @return      `-a mod 2^8` as `i8` (with `i8::MIN -> i8::MIN`)
 */
pub fn wrapping_neg_i8(a: i8) -> i8 {
    i8_from_u8_bits((0 to u8) - u8_bits_of_i8(a))
}

/**
 * Wrapping left shift of `a` by `count` bits as `i8`; the count is masked to `count mod 8` (the #49/#61 semantics); the runtime's signed `<<` is UB-free. Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 8`)
 * @return      `a << (count mod 8)` as `i8`
 */
pub fn wrapping_shl_i8(a: i8, count: u32) -> i8 { a << ((count % 8) to i8) }

/**
 * Wrapping right shift of `a` by `count` bits as `i8` (arithmetic); the count is masked to `count mod 8` (the #49/#61 semantics). Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 8`)
 * @return      `a >> (count mod 8)` as `i8`
 */
pub fn wrapping_shr_i8(a: i8, count: u32) -> i8 { a >> ((count % 8) to i8) }

/**
 * Saturating `a + b` as `i8` â€” clamps to `i8::MAX` on positive overflow and `i8::MIN` on negative overflow. Total.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b`, or the sign-appropriate bound on overflow
 */
pub fn saturating_add_i8(a: i8, b: i8) -> i8 {
    match checked_add_i8(a, b) {
        i8 as v => v
        error => { if b > 0 { return I8_MAX }; i8_min() }
    }
}

/**
 * Saturating `a - b` as `i8` â€” clamps to `i8::MAX` on positive overflow and `i8::MIN` on negative overflow. Total.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b`, or the sign-appropriate bound on overflow
 */
pub fn saturating_sub_i8(a: i8, b: i8) -> i8 {
    match checked_sub_i8(a, b) {
        i8 as v => v
        error => { if b < 0 { return I8_MAX }; i8_min() }
    }
}

/**
 * Saturating `a * b` as `i8` â€” clamps to `i8::MAX` when the product's sign is positive, `i8::MIN` when negative. Total.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b`, or the sign-appropriate bound on overflow
 */
pub fn saturating_mul_i8(a: i8, b: i8) -> i8 {
    match checked_mul_i8(a, b) {
        i8 as v => v
        error => { if (a > 0) == (b > 0) { return I8_MAX }; i8_min() }
    }
}

/**
 * `i16::MAX` (2^15 - 1).
 */
pub const I16_MAX: i16 = 32767

/**
 * The minimum value of `i16` (-2^15). Written as `-MAX - 1` via an annotated intermediate, since `-2^15` has no positive counterpart to negate.
 *
 * @return      `i16::MIN`
 */
pub fn i16_min() -> i16 {
    let m: i16 = -32767
    m - 1
}

/**
 * Reinterpret `a: i16` as its two's-complement bit pattern typed `u16`.
 *
 * Non-negative `a` maps directly. For negative `a`, `a - i16::MIN` lands in
 * `[0, 2^15 - 1]` (in range â€” no trapping cast, no signed overflow); adding the
 * sign bit `2^15` in the `u16` domain reconstructs `a + 2^16`, the two's-complement
 * pattern. Mirrors the VM's `norm_int`, so both engines agree bit-for-bit.
 *
 * @param a  the signed value to reinterpret
 * @return      the `u16` whose bits equal `a`'s two's-complement encoding
 */
fn u16_bits_of_i16(a: i16) -> u16 {
    if a >= 0 { return a to u16 }
    (a - i16_min()) to u16 + ((1 to u16) << 15)
}

/**
 * Reinterpret a `u16` bit pattern `u` as the `i16` it two's-complement encodes â€” the inverse of `u16_bits_of_i16`.
 *
 * Sign bit clear (`u < 2^15`) maps directly. Otherwise `u - 2^15` is in
 * `[0, 2^15 - 1]` (in range), and adding `i16::MIN` yields `u - 2^16`, the signed
 * interpretation of a set sign bit.
 *
 * @param u  the `u16` bit pattern to reinterpret
 * @return      the `i16` two's-complement-encoded by `u`
 */
fn i16_from_u16_bits(u: u16) -> i16 {
    if u < ((1 to u16) << 15) { return u to i16 }
    (u - ((1 to u16) << 15)) to i16 + i16_min()
}

/**
 * Add `a + b` as `i16`, erroring instead of overflowing (signed overflow is UB in the emitted C â€” never performed here). Overflow is caught by in-range boundary comparisons.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b` as `i16`, or an `error` on signed overflow
 * @throws      when the sum leaves `[i16::MIN, i16::MAX]`
 */
pub fn checked_add_i16(a: i16, b: i16) -> i16 | error {
    if b > 0 && a > I16_MAX - b { return checked_error("math::checked_add_i16: overflow") }
    if b < 0 && a < i16_min() - b { return checked_error("math::checked_add_i16: overflow") }
    a + b
}

/**
 * Subtract `a - b` as `i16`, erroring instead of overflowing. The boundary comparisons (`i16::MAX + b` for `b < 0`, `i16::MIN + b` for `b > 0`) stay in range.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `i16`, or an `error` on signed overflow
 * @throws      when the difference leaves `[i16::MIN, i16::MAX]`
 */
pub fn checked_sub_i16(a: i16, b: i16) -> i16 | error {
    if b < 0 && a > I16_MAX + b { return checked_error("math::checked_sub_i16: overflow") }
    if b > 0 && a < i16_min() + b { return checked_error("math::checked_sub_i16: overflow") }
    a - b
}

/**
 * Multiply `a * b` as `i16`, erroring instead of overflowing. The `i16::MIN` corners (`a == -1 && b == MIN`, and its mirror) are handled before the division-bound checks, since `MIN / -1` itself overflows.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b` as `i16`, or an `error` on signed overflow
 * @throws      when the product leaves `[i16::MIN, i16::MAX]`
 */
pub fn checked_mul_i16(a: i16, b: i16) -> i16 | error {
    if a == 0 || b == 0 { return (0 to i16) }
    if a == -1 {
        if b == i16_min() { return checked_error("math::checked_mul_i16: overflow") }
        return -b
    }
    if b == -1 {
        if a == i16_min() { return checked_error("math::checked_mul_i16: overflow") }
        return -a
    }
    if a > 0 {
        if b > 0 && a > I16_MAX / b { return checked_error("math::checked_mul_i16: overflow") }
        if b < 0 && b < i16_min() / a { return checked_error("math::checked_mul_i16: overflow") }
    } else {
        if b > 0 && a < i16_min() / b { return checked_error("math::checked_mul_i16: overflow") }
        if b < 0 && a < I16_MAX / b { return checked_error("math::checked_mul_i16: overflow") }
    }
    a * b
}

/**
 * Divide `a / b` as `i16`, erroring on a zero divisor and on `i16::MIN / -1` (whose true quotient `i16::MAX + 1` is unrepresentable).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `i16`, or an `error` on divide-by-zero or `MIN / -1`
 * @throws      when `b == 0`, or `a == i16::MIN && b == -1`
 */
pub fn checked_div_i16(a: i16, b: i16) -> i16 | error {
    if b == 0 { return checked_error("math::checked_div_i16: divide by zero") }
    if a == i16_min() && b == -1 { return checked_error("math::checked_div_i16: overflow") }
    a / b
}

/**
 * Remainder `a % b` as `i16`, erroring on a zero divisor. `i16::MIN % -1` is defined `0` (returned directly; the bare `%` would be UB there).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `i16`, `0` for `MIN % -1`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_i16(a: i16, b: i16) -> i16 | error {
    if b == 0 { return checked_error("math::checked_rem_i16: divide by zero") }
    if a == i16_min() && b == -1 { return (0 to i16) }
    a % b
}

/**
 * Negate `a` as `i16`, erroring only on `i16::MIN` (which has no representable positive counterpart in two's complement).
 *
 * @param a  the value to negate
 * @return      `-a` as `i16`, or an `error` if `a == i16::MIN`
 * @throws      when `a == i16::MIN`
 */
pub fn checked_neg_i16(a: i16) -> i16 | error {
    if a == i16_min() { return checked_error("math::checked_neg_i16: overflow") }
    -a
}

/**
 * Raise `base` to `exp` as `i16` by squaring, erroring instead of overflowing. `base^0 == 1`; a negative base is fine (its sign follows the exponent's parity).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `i16`, or an `error` if any step overflows
 * @throws      when a partial product leaves `[i16::MIN, i16::MAX]`
 */
pub fn checked_pow_i16(base: i16, power: u32) -> i16 | error {
    mut result: i16 = (1 to i16)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_i16(result, b) {
                i16 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_i16(b, b) {
                i16 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `i16`, erroring when `count >= 16`. The shift itself rides the runtime's masked, UB-free signed shift.
