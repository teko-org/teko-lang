/**
 * `math::checked` (M1) â€” the integer-arithmetic-mode unit of `teko::math`. Per
 * TEKO_ROADMAP_MATH.md Â§M1 and issue #185: three families, for each integer width this unit
 * ships (u8/u16/u32/u64, i8/i16/i32/i64). `checked_*` -> `T | error` (overflow / divide-by-zero
 * / shift-out-of-range is a RETURNED error, never a panic, independent of the TEKO_OVERFLOW_DEBUG
 * build knob). `wrapping_*` -> `T` (two's-complement modular wraparound, total). `saturating_*`
 * -> `T` (clamp to the type's MIN / MAX, total).
 *
 * WHOLE-UNIT GROUND RULE (roadmap Â§0): named functions, no operators; errors are values;
 * domain / edge failures return `T | error`, never panic. `checked_*` is `T | error` (a variant
 * carrying the CAUSE), not `T?` â€” the error domain, not the absence domain (disjoint-domain
 * law). `wrapping_*` / `saturating_*` are total and return `T` bare (no `match`, no error
 * branch); that total branchless shape is what constant-time crypto math (#194) and the bigint
 * limb-carry paths (#187) consume.
 *
 * PURE TEKO, ZERO COMPILER SURFACE, ZERO UNDEFINED BEHAVIOR. Two facts shape every function:
 * (1) the `to` cast TRAPS out of range in BOTH engines, so `wrapping_*` cannot compute-wide-
 * then-cast-down (it would panic on the very overflow it absorbs) â€” wrap is done by bit
 * operations at the target width. (2) Signed `+`/`-`/`*` in the emitted C is UB on overflow, so
 * signed wrapping is routed through the same-width UNSIGNED domain (where `+`/`-`/`*` is defined
 * modular in C) and the bit pattern reinterpreted back via `uN_bits_of_iN` / `iN_from_uN_bits`,
 * which use in-range subtractions only (mirroring the VM's `norm_int`, so both engines agree
 * bit-for-bit).
 *
 * WIDTH SCOPE (128-bit deferred). The 8 widths here are exactly the set issue #185 enumerates.
 * The 128-bit widths (u128/i128) are intentionally NOT shipped yet: the released VM's `norm_int`
 * (src/vm/vm.tks) reinterprets a `u128` value via a trapping `raw to u128`, which PANICS for any
 * `u128` whose high bit is set (e.g. `u128::MAX`, `2^127`), so a `u128` family cannot pass the VM
 * side of the test gate. The native engine handles it correctly; the divergence is a VM defect,
 * reported for a separate fix. Once the VM reinterpret is corrected, u128/i128 are a mechanical
 * extension of this same file (the signed reinterpret pair below already generalizes to 128).
 *
 * PER-WIDTH FAMILY (not generic). Operating on a generic `T` with `+`/`<`/`/` needs S6
 * (constraint-gated operators), designed but not implemented â€” the same reason `teko::math`'s
 * min/max/clamp ship per-type. A single generic entry point is a mechanical follow-up once S6
 * lands; this is flagged, not silently narrowed.
 *
 * This first declaration, `checked_error`, is the single home for the three failure causes this
 * unit reports (overflow, divide-by-zero, shift-out-of-range) so every `checked_*` function names
 * the barrier the same way (M.3 â€” name the barrier; M.5 â€” one source of truth).
 *
 * @param reason  the human-readable cause of the checked failure
 * @return        an `error` whose `message` is `reason`
 */
fn checked_error(reason: str) -> error { error { message = reason } }

/**
 * `u8::MIN` â€” zero (every unsigned type's floor).
 */
pub const U8_MIN: u8 = 0 to u8

/**
 * `u8::MAX` (2^8 - 1), constructed as `~0` (all bits set) â€” one uniform,
 * width-agnostic form for every unsigned ceiling.
 */
pub const U8_MAX: u8 = ~(0 to u8)

/**
 * Add `a + b` as `u8`, erroring instead of wrapping on overflow.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b` as `u8`, or an `error` if the sum exceeds `u8::MAX`
 * @throws      when `a > u8::MAX - b`
 */
pub fn checked_add_u8(a: u8, b: u8) -> u8 | error {
    if a > U8_MAX - b { return checked_error("math::checked_add_u8: overflow") }
    a + b
}

/**
 * Subtract `a - b` as `u8`, erroring instead of wrapping on unsigned underflow.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `u8`, or an `error` if `b > a`
 * @throws      when `b > a` (the difference would be negative, impossible for `u8`)
 */
pub fn checked_sub_u8(a: u8, b: u8) -> u8 | error {
    if b > a { return checked_error("math::checked_sub_u8: underflow") }
    a - b
}

/**
 * Multiply `a * b` as `u8`, erroring instead of wrapping on overflow.
 *
 * Zero operands never overflow; otherwise the product overflows iff `b > u8::MAX / a`.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b` as `u8`, or an `error` if the product exceeds `u8::MAX`
 * @throws      when `a != 0` and `b > u8::MAX / a`
 */
pub fn checked_mul_u8(a: u8, b: u8) -> u8 | error {
    if a == U8_MIN || b == U8_MIN { return U8_MIN }
    if b > U8_MAX / a { return checked_error("math::checked_mul_u8: overflow") }
    a * b
}

/**
 * Divide `a / b` as `u8`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `u8`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_div_u8(a: u8, b: u8) -> u8 | error {
    if b == U8_MIN { return checked_error("math::checked_div_u8: divide by zero") }
    a / b
}

/**
 * Remainder `a % b` as `u8`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `u8`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_u8(a: u8, b: u8) -> u8 | error {
    if b == U8_MIN { return checked_error("math::checked_rem_u8: divide by zero") }
    a % b
}

/**
 * Negate `a` as `u8`. Only `0` negates within an unsigned type; any nonzero value has no representable negative.
 *
 * @param a  the value to negate
 * @return      `0` when `a == 0`, otherwise an `error`
 * @throws      when `a != 0` (an unsigned type has no negative values)
 */
pub fn checked_neg_u8(a: u8) -> u8 | error {
    if a == U8_MIN { return U8_MIN }
    checked_error("math::checked_neg_u8: unsigned negation of a nonzero value")
}

/**
 * Raise `base` to `exp` as `u8` by squaring, erroring instead of wrapping on overflow. `base^0 == 1` (the empty product).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `u8`, or an `error` if any intermediate overflows
 * @throws      when a partial product exceeds `u8::MAX`
 */
pub fn checked_pow_u8(base: u8, power: u32) -> u8 | error {
    mut result: u8 = (1 to u8)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_u8(result, b) {
                u8 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_u8(b, b) {
                u8 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `u8`, erroring when `count >= 8` (distinct from `wrapping_shl`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a << count` as `u8`, or an `error` if `count >= 8`
 * @throws      when `count >= 8`
 */
pub fn checked_shl_u8(a: u8, count: u32) -> u8 | error {
    if count >= 8 { return checked_error("math::checked_shl_u8: shift out of range") }
    a << (count to u8)
}

/**
 * Shift `a` right by `count` bits as `u8` (logical), erroring when `count >= 8` (distinct from `wrapping_shr`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a >> count` as `u8`, or an `error` if `count >= 8`
 * @throws      when `count >= 8`
 */
pub fn checked_shr_u8(a: u8, count: u32) -> u8 | error {
    if count >= 8 { return checked_error("math::checked_shr_u8: shift out of range") }
    a >> (count to u8)
}

/**
 * Wrapping `a + b` as `u8` â€” the sum modulo 2^8. The unsigned `+` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a + b) mod 2^8` as `u8`
 */
pub fn wrapping_add_u8(a: u8, b: u8) -> u8 { a + b }

/**
 * Wrapping `a - b` as `u8` â€” the difference modulo 2^8. The unsigned `-` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a - b) mod 2^8` as `u8`
 */
pub fn wrapping_sub_u8(a: u8, b: u8) -> u8 { a - b }

/**
 * Wrapping `a * b` as `u8` â€” the product modulo 2^8. The unsigned `*` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a * b) mod 2^8` as `u8`
 */
pub fn wrapping_mul_u8(a: u8, b: u8) -> u8 { a * b }

/**
 * Wrapping negation of `a` as `u8` â€” `(0 - a) mod 2^8` (`0` maps to `0`). Total; the unsigned subtraction is defined modular.
 *
 * @param a  the value to negate
 * @return      `(0 - a) mod 2^8` as `u8`
 */
pub fn wrapping_neg_u8(a: u8) -> u8 { U8_MIN - a }

/**
 * Wrapping left shift of `a` by `count` bits as `u8`; the count is masked to `count mod 8` (the #49/#61 shift semantics), so it never traps. Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 8`)
 * @return      `a << (count mod 8)` as `u8`
 */
pub fn wrapping_shl_u8(a: u8, count: u32) -> u8 { a << ((count % 8) to u8) }

/**
 * Wrapping right shift of `a` by `count` bits as `u8` (logical); the count is masked to `count mod 8` (the #49/#61 shift semantics). Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 8`)
 * @return      `a >> (count mod 8)` as `u8`
 */
pub fn wrapping_shr_u8(a: u8, count: u32) -> u8 { a >> ((count % 8) to u8) }

/**
 * Saturating `a + b` as `u8` â€” clamps to `u8::MAX` on overflow instead of wrapping or erroring. Total.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b`, or `u8::MAX` if the sum would overflow
 */
pub fn saturating_add_u8(a: u8, b: u8) -> u8 {
    if a > U8_MAX - b { return U8_MAX }
    a + b
}

/**
 * Saturating `a - b` as `u8` â€” clamps to `0` on underflow instead of wrapping or erroring. Total.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b`, or `0` if `b > a`
 */
pub fn saturating_sub_u8(a: u8, b: u8) -> u8 {
    if b > a { return U8_MIN }
    a - b
}

/**
 * Saturating `a * b` as `u8` â€” clamps to `u8::MAX` on overflow. Total.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b`, or `u8::MAX` if the product would overflow
 */
pub fn saturating_mul_u8(a: u8, b: u8) -> u8 {
    if a == U8_MIN || b == U8_MIN { return U8_MIN }
    if b > U8_MAX / a { return U8_MAX }
    a * b
}

/**
 * `u16::MIN` â€” zero (every unsigned type's floor).
 */
pub const U16_MIN: u16 = 0 to u16

/**
 * `u16::MAX` (2^16 - 1), constructed as `~0` (all bits set) â€” one uniform,
 * width-agnostic form for every unsigned ceiling.
 */
pub const U16_MAX: u16 = ~(0 to u16)

/**
 * Add `a + b` as `u16`, erroring instead of wrapping on overflow.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b` as `u16`, or an `error` if the sum exceeds `u16::MAX`
 * @throws      when `a > u16::MAX - b`
 */
pub fn checked_add_u16(a: u16, b: u16) -> u16 | error {
    if a > U16_MAX - b { return checked_error("math::checked_add_u16: overflow") }
    a + b
}

/**
 * Subtract `a - b` as `u16`, erroring instead of wrapping on unsigned underflow.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `u16`, or an `error` if `b > a`
 * @throws      when `b > a` (the difference would be negative, impossible for `u16`)
 */
pub fn checked_sub_u16(a: u16, b: u16) -> u16 | error {
    if b > a { return checked_error("math::checked_sub_u16: underflow") }
    a - b
}

/**
 * Multiply `a * b` as `u16`, erroring instead of wrapping on overflow.
 *
 * Zero operands never overflow; otherwise the product overflows iff `b > u16::MAX / a`.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b` as `u16`, or an `error` if the product exceeds `u16::MAX`
 * @throws      when `a != 0` and `b > u16::MAX / a`
 */
pub fn checked_mul_u16(a: u16, b: u16) -> u16 | error {
    if a == U16_MIN || b == U16_MIN { return U16_MIN }
    if b > U16_MAX / a { return checked_error("math::checked_mul_u16: overflow") }
    a * b
}

/**
 * Divide `a / b` as `u16`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `u16`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_div_u16(a: u16, b: u16) -> u16 | error {
    if b == U16_MIN { return checked_error("math::checked_div_u16: divide by zero") }
    a / b
}

/**
 * Remainder `a % b` as `u16`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `u16`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_u16(a: u16, b: u16) -> u16 | error {
    if b == U16_MIN { return checked_error("math::checked_rem_u16: divide by zero") }
    a % b
}

/**
 * Negate `a` as `u16`. Only `0` negates within an unsigned type; any nonzero value has no representable negative.
 *
 * @param a  the value to negate
 * @return      `0` when `a == 0`, otherwise an `error`
 * @throws      when `a != 0` (an unsigned type has no negative values)
 */
pub fn checked_neg_u16(a: u16) -> u16 | error {
    if a == U16_MIN { return U16_MIN }
    checked_error("math::checked_neg_u16: unsigned negation of a nonzero value")
}

/**
 * Raise `base` to `exp` as `u16` by squaring, erroring instead of wrapping on overflow. `base^0 == 1` (the empty product).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `u16`, or an `error` if any intermediate overflows
 * @throws      when a partial product exceeds `u16::MAX`
 */
pub fn checked_pow_u16(base: u16, power: u32) -> u16 | error {
    mut result: u16 = (1 to u16)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_u16(result, b) {
                u16 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_u16(b, b) {
                u16 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `u16`, erroring when `count >= 16` (distinct from `wrapping_shl`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a << count` as `u16`, or an `error` if `count >= 16`
 * @throws      when `count >= 16`
 */
pub fn checked_shl_u16(a: u16, count: u32) -> u16 | error {
    if count >= 16 { return checked_error("math::checked_shl_u16: shift out of range") }
    a << (count to u16)
}

/**
 * Shift `a` right by `count` bits as `u16` (logical), erroring when `count >= 16` (distinct from `wrapping_shr`, which masks the count).
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a >> count` as `u16`, or an `error` if `count >= 16`
 * @throws      when `count >= 16`
 */
pub fn checked_shr_u16(a: u16, count: u32) -> u16 | error {
    if count >= 16 { return checked_error("math::checked_shr_u16: shift out of range") }
    a >> (count to u16)
}

/**
 * Wrapping `a + b` as `u16` â€” the sum modulo 2^16. The unsigned `+` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a + b) mod 2^16` as `u16`
 */
pub fn wrapping_add_u16(a: u16, b: u16) -> u16 { a + b }

/**
 * Wrapping `a - b` as `u16` â€” the difference modulo 2^16. The unsigned `-` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a - b) mod 2^16` as `u16`
 */
pub fn wrapping_sub_u16(a: u16, b: u16) -> u16 { a - b }

/**
 * Wrapping `a * b` as `u16` â€” the product modulo 2^16. The unsigned `*` in the emitted C is already defined modular, so this is a bare operation. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a * b) mod 2^16` as `u16`
 */
pub fn wrapping_mul_u16(a: u16, b: u16) -> u16 { a * b }

/**
 * Wrapping negation of `a` as `u16` â€” `(0 - a) mod 2^16` (`0` maps to `0`). Total; the unsigned subtraction is defined modular.
 *
 * @param a  the value to negate
 * @return      `(0 - a) mod 2^16` as `u16`
 */
pub fn wrapping_neg_u16(a: u16) -> u16 { U16_MIN - a }

/**
 * Wrapping left shift of `a` by `count` bits as `u16`; the count is masked to `count mod 16` (the #49/#61 shift semantics), so it never traps. Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 16`)
 * @return      `a << (count mod 16)` as `u16`
 */
pub fn wrapping_shl_u16(a: u16, count: u32) -> u16 { a << ((count % 16) to u16) }

/**
 * Wrapping right shift of `a` by `count` bits as `u16` (logical); the count is masked to `count mod 16` (the #49/#61 shift semantics). Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 16`)
 * @return      `a >> (count mod 16)` as `u16`
 */
pub fn wrapping_shr_u16(a: u16, count: u32) -> u16 { a >> ((count % 16) to u16) }

/**
 * Saturating `a + b` as `u16` â€” clamps to `u16::MAX` on overflow instead of wrapping or erroring. Total.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b`, or `u16::MAX` if the sum would overflow
 */
pub fn saturating_add_u16(a: u16, b: u16) -> u16 {
    if a > U16_MAX - b { return U16_MAX }
    a + b
}

/**
 * Saturating `a - b` as `u16` â€” clamps to `0` on underflow instead of wrapping or erroring. Total.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b`, or `0` if `b > a`
 */
pub fn saturating_sub_u16(a: u16, b: u16) -> u16 {
    if b > a { return U16_MIN }
    a - b
}

/**
 * Saturating `a * b` as `u16` â€” clamps to `u16::MAX` on overflow. Total.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b`, or `u16::MAX` if the product would overflow
 */
pub fn saturating_mul_u16(a: u16, b: u16) -> u16 {
    if a == U16_MIN || b == U16_MIN { return U16_MIN }
    if b > U16_MAX / a { return U16_MAX }
    a * b
}

