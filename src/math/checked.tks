}

/**
 * Raise `base` to `exp` as `i32` by squaring, erroring instead of overflowing. `base^0 == 1`; a negative base is fine (its sign follows the exponent's parity).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `i32`, or an `error` if any step overflows
 * @throws      when a partial product leaves `[i32::MIN, i32::MAX]`
 */
pub fn checked_pow_i32(base: i32, power: u32) -> i32 | error {
    mut result: i32 = (1 to i32)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_i32(result, b) {
                i32 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_i32(b, b) {
                i32 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

/**
 * Shift `a` left by `count` bits as `i32`, erroring when `count >= 32`. The shift itself rides the runtime's masked, UB-free signed shift.
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a << count` as `i32`, or an `error` if `count >= 32`
 * @throws      when `count >= 32`
 */
pub fn checked_shl_i32(a: i32, count: u32) -> i32 | error {
    if count >= 32 { return checked_error("math::checked_shl_i32: shift out of range") }
    a << (count to i32)
}

/**
 * Shift `a` right by `count` bits as `i32` (arithmetic â€” sign-preserving), erroring when `count >= 32`.
 *
 * @param a  the value to shift
 * @param count  the shift amount in bits
 * @return      `a >> count` as `i32`, or an `error` if `count >= 32`
 * @throws      when `count >= 32`
 */
pub fn checked_shr_i32(a: i32, count: u32) -> i32 | error {
    if count >= 32 { return checked_error("math::checked_shr_i32: shift out of range") }
    a >> (count to i32)
}

/**
 * Wrapping `a + b` as `i32` â€” the sum modulo 2^32. Routed through the `u32` domain (where `+` is defined modular in C) and reinterpreted back, so no signed overflow UB is emitted. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a + b) mod 2^32` as `i32` (two's-complement wraparound)
 */
pub fn wrapping_add_i32(a: i32, b: i32) -> i32 {
    i32_from_u32_bits(u32_bits_of_i32(a) + u32_bits_of_i32(b))
}

/**
 * Wrapping `a - b` as `i32` â€” the difference modulo 2^32. Routed through the `u32` domain (where `-` is defined modular in C) and reinterpreted back, so no signed overflow UB is emitted. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a - b) mod 2^32` as `i32` (two's-complement wraparound)
 */
pub fn wrapping_sub_i32(a: i32, b: i32) -> i32 {
    i32_from_u32_bits(u32_bits_of_i32(a) - u32_bits_of_i32(b))
}

/**
 * Wrapping `a * b` as `i32` â€” the product modulo 2^32. Routed through the `u32` domain (where `*` is defined modular in C) and reinterpreted back, so no signed overflow UB is emitted. Total.
 *
 * @param a  the left operand
 * @param b  the right operand
 * @return      `(a * b) mod 2^32` as `i32` (two's-complement wraparound)
 */
pub fn wrapping_mul_i32(a: i32, b: i32) -> i32 {
    i32_from_u32_bits(u32_bits_of_i32(a) * u32_bits_of_i32(b))
}

/**
 * Wrapping negation of `a` as `i32` â€” `i32::MIN` maps to itself (defining the UB corner). Routed through the `u32` domain, so no signed overflow is emitted. Total.
 *
 * @param a  the value to negate
 * @return      `-a mod 2^32` as `i32` (with `i32::MIN -> i32::MIN`)
 */
pub fn wrapping_neg_i32(a: i32) -> i32 {
    i32_from_u32_bits((0 to u32) - u32_bits_of_i32(a))
}

/**
 * Wrapping left shift of `a` by `count` bits as `i32`; the count is masked to `count mod 32` (the #49/#61 semantics); the runtime's signed `<<` is UB-free. Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 32`)
 * @return      `a << (count mod 32)` as `i32`
 */
pub fn wrapping_shl_i32(a: i32, count: u32) -> i32 { a << ((count % 32) to i32) }

/**
 * Wrapping right shift of `a` by `count` bits as `i32` (arithmetic); the count is masked to `count mod 32` (the #49/#61 semantics). Total.
 *
 * @param a  the value to shift
 * @param count  the shift amount (masked to `mod 32`)
 * @return      `a >> (count mod 32)` as `i32`
 */
pub fn wrapping_shr_i32(a: i32, count: u32) -> i32 { a >> ((count % 32) to i32) }

/**
 * Saturating `a + b` as `i32` â€” clamps to `i32::MAX` on positive overflow and `i32::MIN` on negative overflow. Total.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b`, or the sign-appropriate bound on overflow
 */
pub fn saturating_add_i32(a: i32, b: i32) -> i32 {
    match checked_add_i32(a, b) {
        i32 as v => v
        error => { if b > 0 { return I32_MAX }; i32_min() }
    }
}

/**
 * Saturating `a - b` as `i32` â€” clamps to `i32::MAX` on positive overflow and `i32::MIN` on negative overflow. Total.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b`, or the sign-appropriate bound on overflow
 */
pub fn saturating_sub_i32(a: i32, b: i32) -> i32 {
    match checked_sub_i32(a, b) {
        i32 as v => v
        error => { if b < 0 { return I32_MAX }; i32_min() }
    }
}

/**
 * Saturating `a * b` as `i32` â€” clamps to `i32::MAX` when the product's sign is positive, `i32::MIN` when negative. Total.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b`, or the sign-appropriate bound on overflow
 */
pub fn saturating_mul_i32(a: i32, b: i32) -> i32 {
    match checked_mul_i32(a, b) {
        i32 as v => v
        error => { if (a > 0) == (b > 0) { return I32_MAX }; i32_min() }
    }
}

/**
 * `i64::MAX` (2^63 - 1).
 */
pub const I64_MAX: i64 = 9223372036854775807

/**
 * The minimum value of `i64` (-2^63). Written as `-MAX - 1` via an annotated intermediate, since `-2^63` has no positive counterpart to negate.
 *
 * @return      `i64::MIN`
 */
pub fn i64_min() -> i64 {
    let m: i64 = -9223372036854775807
    m - 1
}

/**
 * Reinterpret `a: i64` as its two's-complement bit pattern typed `u64`.
 *
 * Non-negative `a` maps directly. For negative `a`, `a - i64::MIN` lands in
 * `[0, 2^63 - 1]` (in range â€” no trapping cast, no signed overflow); adding the
 * sign bit `2^63` in the `u64` domain reconstructs `a + 2^64`, the two's-complement
 * pattern. Mirrors the VM's `norm_int`, so both engines agree bit-for-bit.
 *
 * @param a  the signed value to reinterpret
 * @return      the `u64` whose bits equal `a`'s two's-complement encoding
 */
fn u64_bits_of_i64(a: i64) -> u64 {
    if a >= 0 { return a to u64 }
    (a - i64_min()) to u64 + ((1 to u64) << 63)
}

/**
 * Reinterpret a `u64` bit pattern `u` as the `i64` it two's-complement encodes â€” the inverse of `u64_bits_of_i64`.
 *
 * Sign bit clear (`u < 2^63`) maps directly. Otherwise `u - 2^63` is in
 * `[0, 2^63 - 1]` (in range), and adding `i64::MIN` yields `u - 2^64`, the signed
 * interpretation of a set sign bit.
 *
 * @param u  the `u64` bit pattern to reinterpret
 * @return      the `i64` two's-complement-encoded by `u`
 */
fn i64_from_u64_bits(u: u64) -> i64 {
    if u < ((1 to u64) << 63) { return u to i64 }
    (u - ((1 to u64) << 63)) to i64 + i64_min()
}

/**
 * Add `a + b` as `i64`, erroring instead of overflowing (signed overflow is UB in the emitted C â€” never performed here). Overflow is caught by in-range boundary comparisons.
 *
 * @param a  the augend
 * @param b  the addend
 * @return      `a + b` as `i64`, or an `error` on signed overflow
 * @throws      when the sum leaves `[i64::MIN, i64::MAX]`
 */
pub fn checked_add_i64(a: i64, b: i64) -> i64 | error {
    if b > 0 && a > I64_MAX - b { return checked_error("math::checked_add_i64: overflow") }
    if b < 0 && a < i64_min() - b { return checked_error("math::checked_add_i64: overflow") }
    a + b
}

/**
 * Subtract `a - b` as `i64`, erroring instead of overflowing. The boundary comparisons (`i64::MAX + b` for `b < 0`, `i64::MIN + b` for `b > 0`) stay in range.
 *
 * @param a  the minuend
 * @param b  the subtrahend
 * @return      `a - b` as `i64`, or an `error` on signed overflow
 * @throws      when the difference leaves `[i64::MIN, i64::MAX]`
 */
pub fn checked_sub_i64(a: i64, b: i64) -> i64 | error {
    if b < 0 && a > I64_MAX + b { return checked_error("math::checked_sub_i64: overflow") }
    if b > 0 && a < i64_min() + b { return checked_error("math::checked_sub_i64: overflow") }
    a - b
}

/**
 * Multiply `a * b` as `i64`, erroring instead of overflowing. The `i64::MIN` corners (`a == -1 && b == MIN`, and its mirror) are handled before the division-bound checks, since `MIN / -1` itself overflows.
 *
 * @param a  the multiplicand
 * @param b  the multiplier
 * @return      `a * b` as `i64`, or an `error` on signed overflow
 * @throws      when the product leaves `[i64::MIN, i64::MAX]`
 */
pub fn checked_mul_i64(a: i64, b: i64) -> i64 | error {
    if a == 0 || b == 0 { return (0 to i64) }
    if a == -1 {
        if b == i64_min() { return checked_error("math::checked_mul_i64: overflow") }
        return -b
    }
    if b == -1 {
        if a == i64_min() { return checked_error("math::checked_mul_i64: overflow") }
        return -a
    }
    if a > 0 {
        if b > 0 && a > I64_MAX / b { return checked_error("math::checked_mul_i64: overflow") }
        if b < 0 && b < i64_min() / a { return checked_error("math::checked_mul_i64: overflow") }
    } else {
        if b > 0 && a < i64_min() / b { return checked_error("math::checked_mul_i64: overflow") }
        if b < 0 && a < I64_MAX / b { return checked_error("math::checked_mul_i64: overflow") }
    }
    a * b
}

/**
 * Divide `a / b` as `i64`, erroring on a zero divisor and on `i64::MIN / -1` (whose true quotient `i64::MAX + 1` is unrepresentable).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `i64`, or an `error` on divide-by-zero or `MIN / -1`
 * @throws      when `b == 0`, or `a == i64::MIN && b == -1`
 */
pub fn checked_div_i64(a: i64, b: i64) -> i64 | error {
    if b == 0 { return checked_error("math::checked_div_i64: divide by zero") }
    if a == i64_min() && b == -1 { return checked_error("math::checked_div_i64: overflow") }
    a / b
}

/**
 * Remainder `a % b` as `i64`, erroring on a zero divisor. `i64::MIN % -1` is defined `0` (returned directly; the bare `%` would be UB there).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a % b` as `i64`, `0` for `MIN % -1`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_rem_i64(a: i64, b: i64) -> i64 | error {
    if b == 0 { return checked_error("math::checked_rem_i64: divide by zero") }
    if a == i64_min() && b == -1 { return (0 to i64) }
    a % b
}

/**
 * Negate `a` as `i64`, erroring only on `i64::MIN` (which has no representable positive counterpart in two's complement).
 *
 * @param a  the value to negate
 * @return      `-a` as `i64`, or an `error` if `a == i64::MIN`
 * @throws      when `a == i64::MIN`
 */
pub fn checked_neg_i64(a: i64) -> i64 | error {
    if a == i64_min() { return checked_error("math::checked_neg_i64: overflow") }
    -a
}

/**
 * Raise `base` to `exp` as `i64` by squaring, erroring instead of overflowing. `base^0 == 1`; a negative base is fine (its sign follows the exponent's parity).
 *
 * @param base  the base
 * @param power  the exponent (non-negative by `u32` type)
 * @return      `base^exp` as `i64`, or an `error` if any step overflows
 * @throws      when a partial product leaves `[i64::MIN, i64::MAX]`
 */
pub fn checked_pow_i64(base: i64, power: u32) -> i64 | error {
    mut result: i64 = (1 to i64)
    mut b = base
    mut e = power
    loop {
        if e == 0 { break }
        if e % 2 == 1 {
            match checked_mul_i64(result, b) {
                i64 as v => { result = v }
                error as err => return err
            }
        }
        e = e / 2
        if e != 0 {
            match checked_mul_i64(b, b) {
                i64 as v => { b = v }
                error as err => return err
            }
        }
    }
    result
}

