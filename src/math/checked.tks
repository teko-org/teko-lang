/**
 * Divide `a / b` as `u32`, erroring on a zero divisor (never a panic).
 *
 * @param a  the dividend
 * @param b  the divisor
 * @return      `a / b` as `u32`, or an `error` if `b == 0`
 * @throws      when `b == 0` (division by zero)
 */
pub fn checked_div_u32(a: u32, b: u32) -> u32 | error {
