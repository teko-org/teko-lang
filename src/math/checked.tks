 * `u32::MIN` â€” zero (every unsigned type's floor).
 */
pub const U32_MIN: u32 = 0 to u32

/**
 * `u32::MAX` (2^32 - 1), constructed as `~0` (all bits set) â€” one uniform,
 * width-agnostic form for every unsigned ceiling.
 */
pub const U32_MAX: u32 = ~(0 to u32)

