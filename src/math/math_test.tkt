// src/math/math_test.tkt — tests for teko::math (M0 root unit). Covers: constants
// (sanity bounds), float classification (is_nan/is_inf/is_finite/is_normal), abs/sign/
// copysign, min/max/clamp (i64 + f64 families), and the checked integer helpers
// gcd/lcm/isqrt/ipow (including their documented error edges). Pure Teko, VM-runnable
// (no `extern`, no libm) — every case here gates BOTH engines.

// --- helpers (not tests): unwrap a `T | error` for the happy-path assertions; the
// error-path tests call the function directly and match on `error` instead. ---

fn unwrap_i64(r: i64 | error) -> i64 {
    match r {
        i64 as v => v
        error => { teko::assert::is_true(false); 0 }
    }
}

fn unwrap_f64(r: f64 | error) -> f64 {
    match r {
        f64 as v => v
        error => { teko::assert::is_true(false); 0.0 }
    }
}

fn is_err_i64(r: i64 | error) -> bool {
    match r { i64 => false; error => true }
}

fn is_err_f64(r: f64 | error) -> bool {
    match r { f64 => false; error => true }
}

// --- abs / sign / copysign ---

#test
fn abs_i64_happy_path() {
    teko::assert::is_true(unwrap_i64(abs_i64(5)) == 5)
    teko::assert::is_true(unwrap_i64(abs_i64(-5)) == 5)
    teko::assert::is_true(unwrap_i64(abs_i64(0)) == 0)
}

#test
fn abs_i64_min_is_a_checked_error() {
    // i64::MIN has no positive two's-complement counterpart — must error, not wrap.
    teko::assert::is_true(is_err_i64(abs_i64(-9223372036854775807 - 1)))
}

#test
fn sign_i64_covers_all_three_cases() {
    teko::assert::is_true(sign_i64(42) == 1)
    teko::assert::is_true(sign_i64(-42) == -1)
    teko::assert::is_true(sign_i64(0) == 0)
}

#test
fn sign_f64_covers_all_three_cases() {
    teko::assert::is_true(sign_f64(3.5) == 1.0)
    teko::assert::is_true(sign_f64(-3.5) == -1.0)
    teko::assert::is_true(sign_f64(0.0) == 0.0)
    teko::assert::is_true(is_nan(sign_f64(nan())))
}

#test
fn copysign_transfers_the_sign_bit() {
    teko::assert::is_true(copysign_f64(3.0, -1.0) == -3.0)
    teko::assert::is_true(copysign_f64(-3.0, -1.0) == -3.0)
    teko::assert::is_true(copysign_f64(3.0, 1.0) == 3.0)
    teko::assert::is_true(copysign_f64(-3.0, 1.0) == 3.0)
}

// --- min / max / clamp ---

#test
fn min_max_i64() {
    teko::assert::is_true(min_i64(3, 7) == 3)
    teko::assert::is_true(min_i64(7, 3) == 3)
    teko::assert::is_true(max_i64(3, 7) == 7)
    teko::assert::is_true(max_i64(7, 3) == 7)
    teko::assert::is_true(min_i64(-5, -1) == -5)
    teko::assert::is_true(max_i64(-5, -1) == -1)
}

#test
fn min_max_f64() {
    teko::assert::is_true(min_f64(3.5, 7.5) == 3.5)
    teko::assert::is_true(max_f64(3.5, 7.5) == 7.5)
}

#test
fn min_max_f64_avoid_nan_when_possible() {
    // NaN-avoiding semantics: if exactly one operand is NaN, the OTHER wins.
    teko::assert::is_true(min_f64(nan(), 5.0) == 5.0)
    teko::assert::is_true(min_f64(5.0, nan()) == 5.0)
    teko::assert::is_true(max_f64(nan(), 5.0) == 5.0)
    teko::assert::is_true(max_f64(5.0, nan()) == 5.0)
}

#test
fn clamp_i64_within_and_outside_range() {
    teko::assert::is_true(unwrap_i64(clamp_i64(5, 0, 10)) == 5)
    teko::assert::is_true(unwrap_i64(clamp_i64(-5, 0, 10)) == 0)
    teko::assert::is_true(unwrap_i64(clamp_i64(50, 0, 10)) == 10)
}

#test
fn clamp_f64_within_and_outside_range() {
    teko::assert::is_true(unwrap_f64(clamp_f64(5.0, 0.0, 10.0)) == 5.0)
    teko::assert::is_true(unwrap_f64(clamp_f64(-5.0, 0.0, 10.0)) == 0.0)
    teko::assert::is_true(unwrap_f64(clamp_f64(50.0, 0.0, 10.0)) == 10.0)
}

#test
fn clamp_f64_inverted_range_is_an_error() {
    teko::assert::is_true(is_err_f64(clamp_f64(5.0, 10.0, 0.0)))
}

// --- gcd / lcm ---

#test
fn lcm_basic_cases() {
    teko::assert::is_true(unwrap_i64(lcm(4, 6)) == 12)
    teko::assert::is_true(unwrap_i64(lcm(21, 6)) == 42)
    teko::assert::is_true(unwrap_i64(lcm(5, 5)) == 5)
}

// --- ipow ---

#test
fn ipow_basic_cases() {
    teko::assert::is_true(unwrap_i64(ipow(2, 10)) == 1024)
    teko::assert::is_true(unwrap_i64(ipow(3, 0)) == 1)   // x^0 == 1
    teko::assert::is_true(unwrap_i64(ipow(0, 0)) == 1)   // 0^0 == 1 by convention here
    teko::assert::is_true(unwrap_i64(ipow(5, 1)) == 5)
    teko::assert::is_true(unwrap_i64(ipow(-2, 3)) == -8)
    teko::assert::is_true(unwrap_i64(ipow(-2, 2)) == 4)
}

#test
fn ipow_detects_overflow() {
    // 2^63 overflows i64 (max is 2^63 - 1).
    teko::assert::is_true(is_err_i64(ipow(2, 63)))
    // A large base to a modest power also overflows.
    teko::assert::is_true(is_err_i64(ipow(1000000000000, 3)))
}
