    teko::assert::is_true(wrapping_shl_u64((1 to u64), 1) == (2 to u64))
}

/**
 * `checked_pow` on `u64`: exact powers, `x^0 == 1`, and overflow -> error.
 */
#test
fn pow_u64_cases() {
    teko::assert::is_true(chk_unwrap_u64(checked_pow_u64((2 to u64), 3)) == (8 to u64))
    teko::assert::is_true(chk_unwrap_u64(checked_pow_u64((5 to u64), 0)) == (1 to u64))
    teko::assert::is_true(chk_is_err_u64(checked_pow_u64(U64_MAX, 2)))
}

/**
 * `checked_*` on `i8` reports overflow / div-by-zero / MIN-neg / MIN-over--1 as errors; happy paths (incl. negatives) return the value.
 */
#test
fn checked_i8_edges() {
    teko::assert::is_true(chk_is_err_i8(checked_add_i8(I8_MAX, (1 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_sub_i8(i8_min(), (1 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_mul_i8(I8_MAX, (2 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_mul_i8(i8_min(), (-1 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_div_i8((1 to i8), (0 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_div_i8(i8_min(), (-1 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_rem_i8((1 to i8), (0 to i8))))
    teko::assert::is_true(chk_is_err_i8(checked_neg_i8(i8_min())))
    teko::assert::is_true(chk_unwrap_i8(checked_rem_i8(i8_min(), (-1 to i8))) == (0 to i8))
    teko::assert::is_true(chk_unwrap_i8(checked_add_i8(i8_min(), I8_MAX)) == (-1 to i8))
    teko::assert::is_true(chk_unwrap_i8(checked_mul_i8((-1 to i8), (10 to i8))) == (-10 to i8))
    teko::assert::is_true(chk_unwrap_i8(checked_div_i8(i8_min(), (2 to i8))) == i8_min() / (2 to i8))
    teko::assert::is_true(chk_unwrap_i8(checked_neg_i8(I8_MAX)) == i8_min() + (1 to i8))
}

/**
 * `wrapping_*` on `i8` wraps two's-complement: MAX+1 -> MIN, MIN-1 -> MAX, MAX*2 -> -2, neg(MIN) -> MIN; happy paths total.
 */
#test
fn wrapping_i8_wraps() {
    teko::assert::is_true(wrapping_add_i8(I8_MAX, (1 to i8)) == i8_min())
    teko::assert::is_true(wrapping_sub_i8(i8_min(), (1 to i8)) == I8_MAX)
    teko::assert::is_true(wrapping_mul_i8(I8_MAX, (2 to i8)) == (-2 to i8))
    teko::assert::is_true(wrapping_neg_i8(i8_min()) == i8_min())
    teko::assert::is_true(wrapping_neg_i8((5 to i8)) == (-5 to i8))
    teko::assert::is_true(wrapping_add_i8((100 to i8), (23 to i8)) == (123 to i8))
    teko::assert::is_true(wrapping_mul_i8((-1 to i8), (-1 to i8)) == (1 to i8))
    teko::assert::is_true(wrapping_sub_i8((10 to i8), (30 to i8)) == (-20 to i8))
}

/**
 * `saturating_*` on `i8` clamps to MAX on positive overflow and MIN on negative overflow (sign-directed); happy inputs pass through.
 */
#test
fn saturating_i8_clamps() {
    teko::assert::is_true(saturating_add_i8(I8_MAX, (1 to i8)) == I8_MAX)
    teko::assert::is_true(saturating_add_i8(i8_min(), (-1 to i8)) == i8_min())
    teko::assert::is_true(saturating_sub_i8(i8_min(), (1 to i8)) == i8_min())
    teko::assert::is_true(saturating_sub_i8(I8_MAX, (-1 to i8)) == I8_MAX)
    teko::assert::is_true(saturating_mul_i8(I8_MAX, (2 to i8)) == I8_MAX)
    teko::assert::is_true(saturating_mul_i8(i8_min(), (2 to i8)) == i8_min())
    teko::assert::is_true(saturating_mul_i8(i8_min(), (-1 to i8)) == I8_MAX)
    teko::assert::is_true(saturating_add_i8((2 to i8), (3 to i8)) == (5 to i8))
}

/**
 * Shift edges on `i8`: `checked_shl/shr` error at count = width; `wrapping_shl/shr` mask the count `mod 8` (the #49/#61 regression).
 */
#test
fn shift_i8_edges() {
    teko::assert::is_true(chk_is_err_i8(checked_shl_i8((1 to i8), 8)))
    teko::assert::is_true(chk_is_err_i8(checked_shr_i8((1 to i8), 8)))
    teko::assert::is_true(chk_unwrap_i8(checked_shl_i8((1 to i8), 1)) == (2 to i8))
    teko::assert::is_true(chk_unwrap_i8(checked_shr_i8((4 to i8), 1)) == (2 to i8))
    teko::assert::is_true(wrapping_shl_i8((1 to i8), 8) == wrapping_shl_i8((1 to i8), 0))
    teko::assert::is_true(wrapping_shr_i8((4 to i8), 8) == wrapping_shr_i8((4 to i8), 0))
    teko::assert::is_true(wrapping_shl_i8((1 to i8), 2) == (4 to i8))
}

/**
 * `checked_pow` on `i8`: exact powers (incl. a negative base), `x^0 == 1`, overflow -> error.
 */
#test
fn pow_i8_cases() {
    teko::assert::is_true(chk_unwrap_i8(checked_pow_i8((2 to i8), 3)) == (8 to i8))
    teko::assert::is_true(chk_unwrap_i8(checked_pow_i8((-2 to i8), 3)) == (-8 to i8))
