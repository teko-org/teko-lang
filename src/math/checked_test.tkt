 * Unwrap a `u32 | error` for a happy-path assertion; a surprise `error` fails the test.
 */
fn chk_unwrap_u32(r: u32 | error) -> u32 {
    match r {
        u32 as v => v
        error => { teko::assert::is_true(false); (0 to u32) }
    }
}

/**
