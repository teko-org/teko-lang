/**
 * src/math/checked_test.tkt — boundary tests for teko::math::checked (M1, issue #185).
 * Pure Teko, VM-runnable (no extern), so every case gates BOTH engines. Exit 0 = all asserts
 * pass. Per width (u8/u16/u32/u64, i8/i16/i32/i64 — the widths #185 enumerates): checked
 * overflow/underflow/div0 -> error, signed MIN/-1 + MIN-neg edges, wraparound at MIN/MAX,
 * saturation clamps, shift out-of-range -> error, wrapping shift count masking (#49/#61), and
 * happy-path totality.
 *
 * The module and this test both live under `teko::math` (namespace = directory), so the
 * functions under test are called bare: `checked_add_u8(...)`, like math_test.tkt calls abs_i64.
 */
/**
 * Unwrap a `u8 | error` for a happy-path assertion; a surprise `error` fails the test.
 */
fn chk_unwrap_u8(r: u8 | error) -> u8 {
    match r {
        u8 as v => v
        error => { teko::assert::is_true(false); (0 to u8) }
    }
}

/**
 * True iff a `u8 | error` carries the error arm — the error-path predicate.
 */
fn chk_is_err_u8(r: u8 | error) -> bool {
    match r { u8 => false; error => true }
}

/**
 * Unwrap a `u16 | error` for a happy-path assertion; a surprise `error` fails the test.
 */
fn chk_unwrap_u16(r: u16 | error) -> u16 {
    match r {
        u16 as v => v
        error => { teko::assert::is_true(false); (0 to u16) }
    }
}

/**
 * True iff a `u16 | error` carries the error arm — the error-path predicate.
 */
fn chk_is_err_u16(r: u16 | error) -> bool {
    match r { u16 => false; error => true }
}

