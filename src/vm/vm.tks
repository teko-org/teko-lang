// src/vm/vm.tks   (namespace 'teko::vm')
//
// D1 — THE CANONICAL ORIGINAL of the typed-tree VM / interpreter (Stage-1: the
// test/debug execution engine). It tree-walks the CHECKED typed tree (TProgram from
// src/checker/tast) DIRECTLY: no .tkb serialization, no codegen, no native binary.
// Tests run on THIS engine over the typed tree, BEFORE emit/codegen, then are discarded
// — they never become .tkb/binary. This is the Teko pair of src/vm/vm.{c,h}.
//
// ARCHITECTURE: the VM and the C codegen (codegen.tks / codegen_c.c) are TWO execution
// paths over the SAME checked tast. This VM MIRRORS codegen's semantics node-for-node —
// the same coverage frontier, the same ÷0 / cast guards (F3), the same
// print/println/assert builtin recognition, the same VIRTUAL-MAIN return rules. That
// makes it the DIFFERENTIAL-CORRECTNESS anchor against the native path. If a node's
// interpreter semantics would diverge from codegen, that is a HALT (report), not a
// silent choice.
//
// LAWS: M.0 (metal — a value model that is the legal `variant` of concrete types, no
// boxing tower); M.1 (fail loud — every panic routes through the runtime panics so the
// MESSAGE matches the native path); M.3 (honest — any node not yet interpreted is a named
// error, never wrong-silently; the frontier matches codegen's: if/match-as-value,
// destructuring, fn params are deferred).
//
// HOW THIS DIFFERS FROM THE C (faithful, not literal — Teko is cleaner):
//   * The C tagged union `tk_value` (a `tag` + a hand-rolled `union`) IS the native
//     `variant` here (B.14). Per the legislator's ruling (LEGISLATION §109; variant =
//     sum of COMPLETE declared types, NO constructors, NO `void`/`Unit`/anulable member),
//     the value model is the union of the concrete types a runtime value can take:
//     `Value = u8 | u16 | u32 | u64 | i8 | i16 | i32 | i64 | bool | byte | str | []Value`.
//     The integer width/signedness IS the member's type — no `Int(payload)` constructor.
//   * A `-> void` call PRODUCES NO Value (it is a statement, run for effect). There is no
//     `Unit` value — void exprs only ever appear in statement position (the result is
//     discarded). The C side keeps a never-consumed placeholder so its tk_value-returning
//     evaluator stays well-typed; the legal `.tks` simply does not produce a Value.
//   * The C `_Noreturn vm_unsupported(msg)` + `abort()` honesty barrier is `teko::panic`
//     here — the same loud stop (M.1/M.3), no boolean error plumbing to thread.
//   * The C chained-frame env (a malloc'd `tk_slot` list with a `head`) is an `Venv`
//     holding a `[]Slot`; `define` pushes, `find` scans newest-first (shadowing).
//   * The C `tk_flow` struct (W5a: kind + has_value + value) is a `Flow` variant carrying the
//     exits a block can produce: Normal | VmReturn | Break | Continue. W5a — a flow now carries
//     an OPTIONAL value (`Value?`): Normal's value is the STATEMENT's value (so a block's
//     TRAILING expr is the block's value — B.20); VmReturn's value is the return value; both use
//     null == "no value" (a void statement / bare `return` / a void fn). Break/Continue carry
//     an optional loop LABEL (M.5 — empty = innermost; a labeled jump bubbles through inner loops
//     until the loop whose label matches catches it). The C's in-place env mutation is the
//     functional env threaded via `Stepped` here, so
//     a NORMAL step is `Stepped { env; value }` (env-advanced + the statement's trailing value).
//   * The F3 numeric guards (tk_div_*/tk_to_*) the C re-derives inline (they are static
//     inline in teko_rt.h, not linkable) are just calls to the runtime's checked div/cast
//     here — same single check, same panic message.

use teko::checker
use teko::parser
use teko::lexer

// ---------------------------------------------------------------------------
// The VALUE model (M.0). The legal variant = the sum of the CONCRETE types a runtime
// value can be (no constructors, no `Unit`). The integer width/signedness IS the member
// type (u8…u128 / i8…i128); a float is one of f16/f32/f64 (its width IS the member), so
// the engine reads a value's width/kind from WHICH member it is — exactly what codegen's
// F3 width/range checks need. `byte` is the native byte; `str` the native string;
// `[]Value` a list. (Tier-1 numerics — plan §5 [N1/N2] — are all in now; `dec`/`bigint`
// and `error`-as-value enter when the VM grows.)
// ---------------------------------------------------------------------------
// W4b — a STRUCT value: nominal type name + fields in DECLARED order (mirrors the C
// TK_VAL_STRUCT carrier). `error` is also a struct value (type_name "error", field "message").
// A variant value is just a member-struct value (the case = its type_name); match (W5) reads it.
type StructVal = struct { type_name: str; field_names: []str; field_vals: []Value }

// OptVal (REBOOT_PLAN §202) — an optional `T?` value: NONE (present=false) or PRESENT
// (present=true, `inner` set). Distinguishable from any payload value, so null/?./??/match-
// over-`T?` read it unambiguously (the C twin is the TK_VAL_OPT tag).
type OptVal = struct { present: bool; inner: Value? }

// RefVal (MEM Step 2/3) — a `Ref<T>` VALUE: the index into the env's CELL STORE where the
// referenced scalar lives. `Ref<T>` is escape-gated to a PARAM-ONLY, SCALAR-only borrow that
// cannot escape (MEM Step 0), so a RefVal only ever aliases a `mut` scalar local of an ancestor
// call frame: a `mut` lvalue arg is PROMOTED to a cell at the auto-ref site (cell_alloc), the
// origin slot is rebound to that cell (slot.cell_id), and this RefVal carries the cell index.
// `.value` read/write goes through `cell_get`/`cell_set`; the C twin is the TK_VAL_REF tag.
type RefVal = struct { cell: u64 }

// ClassRef (W10b.CLASS residual — VM reference semantics) — a CLASS instance value: the index
// into the env's CELL STORE where its StructVal lives. STRUCTURALLY identical to RefVal (both
// are just a cell index) but semantically DISTINCT: RefVal is MEM-1b's escape-gated, param-only,
// scalar-only borrow (a function may NOT return one — R3), whereas a ClassRef is exactly the
// opposite — a class is a REFERENCE type (increment 3's native pointer semantics), meant to be
// constructed, returned, stored, and shared freely. Reusing RefVal's OWN type would either
// require relaxing R3 for it (unsound for Ref<T>) or smuggling class instances through a type
// whose entire contract is "cannot escape" — so this is a new, unrestricted variant over the
// SAME cell-store mechanism (cell_alloc/cell_get), giving a class construction shared identity
// exactly like a native `tk_region_alloc`'d pointer: `let b = a` copies only the cell index.
type ClassRef = struct { cell: u64 }

// FuncVal (W10a) — a function/closure VALUE: the (namespace, name) of the target function. A named
// fn used as a value carries no captured environment (the W10b capture env will extend this). A
// closure call evaluates its callee to a FuncVal and invokes that function with the call's args.
// The C twin is the TK_VAL_FUNC tag.
// FuncVal (W10) — a function/closure VALUE. A NAMED fn used as a value carries (ns, name) and
// is_lambda=false. A closure LITERAL carries is_lambda=true + its typed params/body + a SNAPSHOT of
// its captured variables (cap_names/cap_vals): a by-copy capture snapshots the value; a `Ref<T>`
// capture snapshots the RefVal (the cell index — so the closure shares the cell → mutation works).
type FuncVal = struct { is_lambda: bool; ns: str; name: str; params: []checker::TLambdaParam; body: []checker::TStatement; cap_names: []str; cap_vals: []Value }

type Value = variant u8 | u16 | u32 | u64 | u128
           | i8 | i16 | i32 | i64 | i128
           | f16 | f32 | f64
           | bool | byte | str | []Value | StructVal | OptVal | RefVal | FuncVal | ClassRef

// ---------------------------------------------------------------------------
// CONTROL FLOW. The exits a block can produce — mirrors the C `tk_flow`
// `{ kind; has_value; value }`. W5a: a flow now carries an OPTIONAL value (`Value?`),
// faithful to the C carrier:
//   * Normal's value is the STATEMENT's value (an expr-statement's result) — so a block's
//     TRAILING expression becomes the block's value (B.20 — implicit return / if-as-value);
//     `null` == no value (a void statement, or an `if`-without-`else` taken false).
//   * VmReturn's value is the RETURN value; `null` == bare `return` / a `-> void` fn.
//   * Break/Continue carry an optional loop LABEL (empty = innermost): a labeled break/continue
//     bubbles through inner loops until the loop whose label matches catches it (mirrors the C
//     `tk_flow.label`). They carry no value (their `value` is always null).
// (The C uses ONE struct with a `kind` discriminant; here each kind is a variant member,
// and Normal+VmReturn each carry the optional value just like the C `value` field.)
// ---------------------------------------------------------------------------
pub type Normal   = struct { value: Value? }   // W5a — the NORMAL flow's trailing/statement value (null == none)
pub type VmReturn   = struct { value: Value? }   // null == return with no value (void / bare `return`)
pub type Break    = struct { label: str }      // break [NAME] — label empty = innermost loop (M.5)
pub type Continue = struct { label: str }      // continue [NAME] — label empty = innermost loop (M.5)
type Flow = variant Normal | VmReturn | Break | Continue

// str equality (loop labels) — mirrors the C `vm_str_eq`. The empty label matches empty.
fn vm_str_eq(a: str, b: str) -> bool { a == b }

// ---------------------------------------------------------------------------
// C1.6 — RUNTIME PANICS CARRY file:line:col. A runtime panic (÷0, bad cast, index-out-of-
// bounds) is raised AS the VM evaluates a typed node, so the node's {line,col} (TExpr, copied
// from the untyped Expr at C1-POS) locates the offence. We print "<line>:<col>: " to stderr
// FIRST (via the runtime's stderr writer), then call the canonical runtime panic, which prints
// "teko: panic: <msg>\n" (M.1 — the message stays byte-for-byte identical to the native path;
// we only PREFIX a locator). A 0 line means "unknown" — we then skip the locator and the panic
// reads as before. FILE is NOT included: the typed tree (TProgram/TItem/TExpr) carries no
// `.file` and tk_vm_run(TProgram) receives no filename, so the file is not reachable at a panic
// site WITHOUT a new field threaded through tast + the checker + the VM entry (out of this
// crumb's scope — vm.c/vm.tks only). File-threading is DEFERRED; we emit the honest "line:col:".
fn vm_panic_pos(line: u32, col: u32) {
    if line == 0 { return }   // no position recorded — fall through to the bare runtime panic
    teko::io::ewrite(teko::str::concat(teko::u64_to_str(line to u64), ":", teko::u64_to_str(col to u64)))
    teko::io::ewrite(": ")
}
fn vm_panic_div0_at(line: u32, col: u32) { vm_panic_pos(line, col); teko::panic_div0() }
fn vm_panic_cast_at(line: u32, col: u32) { vm_panic_pos(line, col); teko::panic_cast() }
fn vm_panic_oob_at (line: u32, col: u32) { vm_panic_pos(line, col); teko::panic_oob()  }

// C1.6 — width range bounds (mirror the C `i_min_of`/`i_max_of`/`u_max_of`). The .tks cast
// guard delegated its range check to the runtime `teko::cast`/`teko::float_to_int`, which take
// NO position; to PREFIX the offending node's line:col before the canonical "impossible
// conversion" panic, the positioned cast wrappers below re-derive that same check inline (the C
// twin always checked inline) and call vm_panic_cast_at on failure. Bounds in the i128 carrier.
fn i_min_of(width: u8) -> i128 { if width >= 128 { return (1 to i128) << 127 }; -((1 to i128) << (width - 1)) }
fn i_max_of(width: u8) -> i128 { if width >= 128 { return ~((1 to i128) << 127) }; ((1 to i128) << (width - 1)) - 1 }
fn u_max_of(width: u8) -> u128 { if width >= 128 { return ~(0 to u128) }; ((1 to u128) << width) - 1 }

// vm_cast — positioned int->int checked conversion (mirrors the C eval_cast INT->INT guard:
// the same i_min/i_max/u_max bounds, the same panic). Only called when cast_may_lose(src,dst).
fn vm_cast(v: i128, src: checker::PrimKind, dst: checker::PrimKind, line: u32, col: u32) -> i128 {
    let dwidth = prim_width(dst)
    if prim_signed(src) {
        if prim_signed(dst) {
            if v < i_min_of(dwidth) || v > i_max_of(dwidth) { vm_panic_cast_at(line, col) }
            return v
        }
        // signed source -> unsigned dst: negatives never fit; upper bound is 2^w-1.
        if v < 0 { vm_panic_cast_at(line, col) }
        if (v to u128) > u_max_of(dwidth) { vm_panic_cast_at(line, col) }
        return v
    }
    let uv = v to u128
    if prim_signed(dst) {
        if uv > (i_max_of(dwidth) to u128) { vm_panic_cast_at(line, col) }   // unsigned src -> signed dst: signed max
        return v
    }
    if uv > u_max_of(dwidth) { vm_panic_cast_at(line, col) }                 // unsigned src -> unsigned dst: 2^w-1
    v
}

// vm_float_to_int — positioned float->int truncate (mirrors the C eval_cast FLOAT->INT guard:
// NaN / ±∞ / out-of-range -> positioned "impossible conversion"). Truncates toward zero.
fn vm_float_to_int(f: f64, dst: checker::PrimKind, line: u32, col: u32) -> i128 {
    if f != f { vm_panic_cast_at(line, col) }                                // NaN never converts
    let t = if f < 0.0 { -teko::floor(-f) } else { teko::floor(f) }          // trunc toward zero
    let dwidth = prim_width(dst)
    if prim_signed(dst) {
        if t < (i_min_of(dwidth) to f64) || t > (i_max_of(dwidth) to f64) { vm_panic_cast_at(line, col) }   // also catches ±∞
        return t to i128
    }
    if t < 0.0 || t > (u_max_of(dwidth) to f64) { vm_panic_cast_at(line, col) }   // negatives never fit; also ±∞
    t to i128
}

// ---------------------------------------------------------------------------
// ENV — a simple lexical frame: name -> Value. Mirrors the checker's scoping: a binding
// pushes onto the current frame; assign mutates the nearest existing slot; a function
// call runs in a FRESH root frame (no closure capture — M0 functions are flat, matching
// codegen's C functions).
// ---------------------------------------------------------------------------
// (MEM Step 2/3) `cell_id` — when a slot is a `Ref<T>` aliasing TARGET (its `mut` value was
// PROMOTED to the env cell store by an auto-ref at a call), the BINDING value lives at
// `cells[cell_id]`, not in `val`. null == a plain by-value slot (today's behaviour). A
// cell-backed slot's reads/writes route through the cell so the origin var and every RefVal
// aliasing it observe the SAME storage (the C twin's `has_cell`+`cell_id`).
type Slot = struct { name: str; val: Value; cell_id: u64? }
// `prog` carries the typed program so `find_function` can resolve user calls. The C twin uses a
// file-global `g_prog`; Teko has NO mutable globals (M.0), so the program rides the env (threaded
// through every frame, exactly like codegen threads its emit context).
// (C7.18) A deferred block body (list of TStatements). Used in the defer stack below.
pub type DeferBody = struct { body: []checker::TStatement }
// (C7.18) Per-call-frame defer accumulator. Pushed as exec_stmt encounters TDeferStmt;
// drained LIFO in eval_call after exec_block completes. Panic does NOT drain.
// (MEM Step 2/3) `cells` — the program-wide CELL STORE of aliased scalars (a flat, grow-and-
// mutate value array, threaded through the env exactly like `slots`). A `Ref<T>` value is a cell
// INDEX into this store; a cell-backed slot (slot.cell_id) reads/writes here too. In the C twin
// this is a global growable array shared by pointer (in-place set, O(1)); here a write is a
// FUNCTIONAL REBUILD (copy the list with one element replaced, exactly like mutate_slot) — O(n),
// fine for a test VM, and behaviourally identical. The store only GROWS (cell_alloc appends) and
// MUTATES (cell_set), never shrinks/reorders, so a callee that inherits the caller's cells and
// returns its own can merge back by REPLACEMENT.
pub type Venv  = struct { slots: []Slot; prog: checker::TProgram; defers: []DeferBody; cells: []Value }

// find — newest-first scan so a later binding SHADOWS an earlier one (the checker's rule). The
// checker guarantees every read binds, so a miss is an internal invariant break → panic (M.1),
// matching the C env_find + caller's vm_unsupported. Returns the Slot directly (callers read .val).
fn find(env: Venv, name: str) -> Slot {
    mut i = env.slots.len
    loop {
        if i == 0 { break }
        i--
        if env.slots[i].name == name { return env.slots[i] }
    }
    panic("vm: unbound variable (internal: checker should reject)")
}

// (MEM Step 2/3) read_var — read a binding's CURRENT value: a plain slot yields slot.val; a
// CELL-BACKED slot (a `Ref<T>` aliasing target whose `mut` value was promoted to the cell store)
// yields cell_get(cells, cell_id), so the origin var observes writes made through any RefVal that
// aliases it. The C twin reads `slot->has_cell ? cell_get(slot->cell_id) : slot->val`.
fn read_var(env: Venv, name: str) -> Value {
    let slot = find(env, name)
    match slot.cell_id { u64 as cid => cell_get(env.cells, cid); null => slot.val }
}

// define — push a fresh slot (shadowing). Returns the grown env (functional, like emit/*).
// A freshly-defined slot is plain (cell_id= null); only an auto-ref PROMOTION (promote_to_cell)
// rebinds a slot to a cell. `cells` threads through unchanged.
pub fn define(env: Venv, name: str, val: Value) -> Venv {
    Venv { slots= teko::list::push(env.slots, Slot { name= name; val= val; cell_id= null }); prog= env.prog; defers= env.defers; cells= env.cells }
}

// (C7.18) push_defer — register a deferred body onto the env's defer stack.
fn push_defer(env: Venv, body: []checker::TStatement) -> Venv {
    Venv { slots= env.slots; prog= env.prog; defers= teko::list::push(env.defers, DeferBody { body= body }); cells= env.cells }
}

// (W9.3) with_defers — replace an env's defer stack (used to pop a scope's defers back to its base
// after that scope's defers have fired). Mirrors with_cells.
fn with_defers(env: Venv, defers: []DeferBody) -> Venv {
    Venv { slots= env.slots; prog= env.prog; defers= defers; cells= env.cells }
}

// (W9.3) defers_up_to — the first `base` deferred bodies of `ds` (rebuilt, since the list has no
// truncate op). Used to pop a scope's own defers (those at index ≥ base) after they have fired.
fn defers_up_to(ds: []DeferBody, base: u64) -> []DeferBody {
    mut out: []DeferBody = teko::list::empty()
    // (W9.3 part 2) Cap at the list length: a `return` may have ALREADY drained this scope's defers
    // (emptied the list) before the unwinding exec_block reaches here with its higher `base` mark —
    // "already drained below my mark" is a safe no-op, so never index past the end.
    mut stop: u64 = base
    if stop > ds.len { stop = ds.len }
    mut i: u64 = 0
    loop {
        if i >= stop { break }
        out = teko::list::push(out, ds[i])
        i++
    }
    out
}

// (W9.3) drain_defers_to — fire every deferred body registered on top of `base` (i.e. at index ≥
// base) in LIFO order (most-recent / innermost first), executing each via exec_block, then pop them
// off the stack (defers truncated back to `base`). This is THE scope-defer drain: exec_block calls it
// at every exit edge so a block's defers run before control leaves the block. A defer body is itself a
// no-defer scope (the checker forbids nested defer), so running it via exec_block pushes nothing and
// cannot re-enter. Panic does NOT reach here (it aborts).
fn drain_defers_to(env: Venv, base: u64) -> Venv {
    mut e = env
    mut di: u64 = e.defers.len
    loop {
        if di <= base { break }
        di--
        e = exec_block(e.defers[di].body, e).env
    }
    with_defers(e, defers_up_to(e.defers, base))
}

// (C7.18) fresh_env — a fresh call-frame env (no slots, no defers, same prog).
// (MEM Step 2/3) `cells` is supplied by the CALLER so a `RefVal`'s cell index stays valid in the
// callee frame (the cell store is program-wide, not per-frame); the caller passes its own cells in.
fn fresh_env(prog: checker::TProgram, cells: []Value) -> Venv {
    Venv { slots= teko::list::empty(); prog= prog; defers= teko::list::empty(); cells= cells }
}

// ---------------------------------------------------------------------------
// (MEM Step 2/3) CELL STORE helpers — the program-wide aliasing store. cell_alloc appends a value
// and returns the grown store + the new cell's index; cell_get reads; cell_set writes (a FUNCTIONAL
// REBUILD here — copy with one element replaced, exactly like mutate_slot; the C twin sets in place,
// O(1)). The escape-gate keeps cells scalar and bounded, so the O(n) rebuild is fine for a test VM.
// ---------------------------------------------------------------------------
type CellAlloc = struct { cells: []Value; id: u64 }
fn cell_alloc(cells: []Value, v: Value) -> CellAlloc {
    CellAlloc { cells= teko::list::push(cells, v); id= cells.len }
}
fn cell_get(cells: []Value, id: u64) -> Value {
    if id >= cells.len { panic("vm: cell index out of range (internal: Ref<T> aliasing invariant break)") }
    cells[id]
}
fn cell_set(cells: []Value, id: u64, v: Value) -> []Value {
    if id >= cells.len { panic("vm: cell index out of range (internal: Ref<T> aliasing invariant break)") }
    mut rebuilt: []Value = teko::list::empty()
    mut j = 0
    loop {
        if j >= cells.len { break }
        if j == id { rebuilt = teko::list::push(rebuilt, v) }
        else       { rebuilt = teko::list::push(rebuilt, cells[j]) }
        j++
    }
    rebuilt
}

// promote_to_cell — AUTO-REF a `mut` scalar lvalue named `name`: if its slot is already cell-backed
// (a forwarded/re-referenced var), reuse that cell; otherwise cell_alloc its current value and rebind
// the slot to the new cell (so the ORIGIN var's future reads/writes ALSO route through the cell). The
// returned env carries the grown cells + the rebound slot; `id` is the cell to put in the RefVal.
// The checker (auto-ref rule) guarantees `name` is a `mut` scalar binding, so this never fails.
type Promotion = struct { env: Venv; id: u64 }
fn promote_to_cell(env: Venv, name: str) -> Promotion {
    // newest-first scan (shadowing), like find/mutate_slot.
    mut idx = env.slots.len
    mut found = false
    loop {
        if idx == 0 { break }
        idx--
        if env.slots[idx].name == name { found = true; break }
    }
    if !found { panic("vm: auto-ref of an unbound variable (internal: checker should reject)") }
    let slot = env.slots[idx]
    match slot.cell_id {
        u64 as existing => return Promotion { env= env; id= existing }   // already aliased — reuse the cell
        null            => {}
    }
    let alloc = cell_alloc(env.cells, slot.val)
    // rebuild the slots, rebinding `idx` to the new cell (its value now lives in cells[alloc.id]).
    mut rebuilt: []Slot = teko::list::empty()
    mut j = 0
    loop {
        if j >= env.slots.len { break }
        if j == idx { rebuilt = teko::list::push(rebuilt, Slot { name= name; val= slot.val; cell_id= alloc.id }) }
        else        { rebuilt = teko::list::push(rebuilt, env.slots[j]) }
        j++
    }
    Promotion { env= Venv { slots= rebuilt; prog= env.prog; defers= env.defers; cells= alloc.cells }; id= alloc.id }
}

// with_cells — replace an env's cell store (used to MERGE a callee's final cells back into the
// caller after a call: the callee inherited the caller's cells and only grew/mutated them, so the
// callee's final store is a superset-with-mutations and replaces the caller's wholesale).
fn with_cells(env: Venv, cells: []Value) -> Venv {
    Venv { slots= env.slots; prog= env.prog; defers= env.defers; cells= cells }
}

// ---------------------------------------------------------------------------
// prim helpers — the VM's copy of codegen's prim_is_signed / prim_width / cast_may_lose
// (verbatim semantics; this IS the mirror). Integer prims only.
// ---------------------------------------------------------------------------
fn prim_signed(k: checker::PrimKind) -> bool {
    match k { I8 | I16 | I32 | I64 | I128 => true; _ => false }
}
fn prim_float(k: checker::PrimKind) -> bool {
    match k { F16 | F32 | F64 => true; _ => false }
}
fn prim_int(k: checker::PrimKind) -> bool {
    match k {
        U8 | U16 | U32 | U64 | U128 | I8 | I16 | I32 | I64 | I128 => true
        _ => false
    }
}
pub fn prim_width(k: checker::PrimKind) -> u8 {
    match k {
        U8   | I8         => 8
        U16  | I16  | F16 => 16
        U32  | I32  | F32 => 32
        U64  | I64  | F64 => 64
        U128 | I128       => 128
        Bool              => 1
    }
}
// A cast src->dst may LOSE data (needs a runtime guard) when some source value falls
// outside the dest range. VERBATIM from codegen's cast_may_lose.
pub fn cast_may_lose(src: checker::PrimKind, dst: checker::PrimKind) -> bool {
    let ss = prim_signed(src); let ds = prim_signed(dst)
    let sw = prim_width(src);  let dw = prim_width(dst)
    if ss == ds  { return sw > dw }      // same signedness: only true narrowing loses
    if !ss && ds { return sw >= dw }     // u->i: loses one bit of magnitude at equal width
    true                                 // i->u: negatives never fit
}

// ---------------------------------------------------------------------------
// BUILTIN call recognition — VERBATIM mirror of codegen's CALL lowering: print/println
// and teko::assert::* are non-shadowable, recognized by the path's LAST segment when the
// path is single-segment OR rooted at `teko`. Each assert FAILS LOUD on a false predicate
// (the runtime panics with "assertion failed: <name>" — M.1).
//
// These builtins are all `-> void`: they run for EFFECT and produce NO Value. So this
// helper returns `bool | error` — `true` == "it was a builtin (and was run)", and the
// statement context (a void call is a statement) expects no value back. A non-builtin
// path returns an `error` so `eval_call` falls through to a user fn.
// ---------------------------------------------------------------------------
fn try_builtin(callee: parser::Path, args: []checker::TExpr, env: Venv) -> bool | error {
    let last = callee.segments[callee.segments.len - 1].name
    let addressable = callee.segments.len == 1 || callee.segments[0].name == "teko"
    if !addressable { return error { message = "not a builtin" } }

    if last == "print" || last == "println" || last == "write" {
        let a = ev_val(args[0], env)
        match a {
            str as s => { if last == "println" { teko::io::println(s) } else { teko::io::print(s) }; return true }
            _        => return error { message = "vm: print/println/write on a non-str value not yet supported" }
        }
    }
    if last == "ewrite" || last == "eprint" || last == "eprintln" {
        let a = ev_val(args[0], env)
        match a {
            str as s => { if last == "eprintln" { teko::io::eprintln(s) } else { teko::io::ewrite(s) }; return true }
            _        => return error { message = "vm: ewrite/eprint/eprintln on a non-str value not yet supported" }
        }
    }

    let assert_ns = callee.segments.len >= 2 && callee.segments[0].name == "teko" &&
                 callee.segments[callee.segments.len - 2].name == "assert"
    if assert_ns {
        if last == "is_true"  { teko::assert::is_true(as_bool(ev_val(args[0], env)));  return true }
        if last == "is_false" { teko::assert::is_false(as_bool(ev_val(args[0], env))); return true }
        if last == "str_contains" {
            teko::assert::str_contains(as_str(ev_val(args[0], env)), as_str(ev_val(args[1], env)))
            return true
        }
        // equals/is_ok/... need generics — DEFERRED (matches the seed). Honest stop (M.3).
        panic("vm: this teko::assert builtin not yet supported (needs generics)")
    }
    error { message = "not a builtin" }
}

// teko::list::empty / push — the SLICE (collection) builtins, FIXED+COPY semantics (no
// dynamic push; copy-append only — TEKO_CORRECTION_PLAN §16). `empty()` is the sentinel/
// untyped empty slice; `push(xs, item)` returns a FRESH list (copy-on-push) so
// `xs = teko::list::push(xs, item)` never mutates a captured `xs`. These PRODUCE A VALUE,
// so — unlike the `-> void` builtins in `try_builtin` — they are recognized here in value
// position (the C twin sets `*out` in try_builtin_call; the `.tks` try_builtin carries no
// value, so the value-producing list builtins live on the value-call path instead). They
// resolve to the language's own `teko::list::empty`/`push` intrinsics (the same calls the
// engine itself uses above), keeping VM==native copy-on-push semantics.
fn try_list_builtin(callee: parser::Path, args: []checker::TExpr, env: Venv) -> Value? {
    let last = callee.segments[callee.segments.len - 1].name
    let list_ns = callee.segments.len >= 2 && callee.segments[0].name == "teko" &&
               callee.segments[callee.segments.len - 2].name == "list"
    if !list_ns { return null }
    if last == "empty" {
        let xs: []Value = teko::list::empty()
        return xs
    }
    if last == "push" {
        let base = ev_val(args[0], env)
        let item = ev_val(args[1], env)
        match base {
            []Value as xs => return teko::list::push(xs, item)
            _             => panic("vm: teko::list::push on a non-list value (internal: checker should reject)")
        }
    }
    // other teko::list::* (len/get/…) are deferred — only empty/push in the fixed+copy seed.
    panic("vm: this teko::list builtin not yet supported (only empty/push — fixed+copy)")
}

// E2 — err_loc / err_typed: the error-adornment builtins. Recognized by the LAST path segment
// when single-segment OR teko-rooted (the `addressable` gate, like print/println). Both PRODUCE
// A VALUE (a fresh error with the diagnostic fields set; the source error is preserved —
// err_set is copy-on-set), so they live on the value-call path (like try_list_builtin), not the
// `-> void` try_builtin. They mirror C's tk_error_loc(e,line,col) / tk_error_types(e,exp,act).
// `null` == not an err builtin → fall through.
fn try_err_builtin(callee: parser::Path, args: []checker::TExpr, env: Venv) -> Value? {
    let last = callee.segments[callee.segments.len - 1].name
    let addressable = callee.segments.len == 1 || callee.segments[0].name == "teko"
    if !addressable { return null }
    if last == "err_loc" {
        match ev_val(args[0], env) {
            // line/col are u32 (the contract's field types) — re-normalize the carriers to width 32.
            StructVal as e => {
                let e1 = err_set(e, "line", as_int(ev_val(args[1], env)) to u32)
                match e1 {
                    StructVal as e1s => return err_set(e1s, "col", as_int(ev_val(args[2], env)) to u32)
                    _                => panic("vm: err_loc internal (err_set must yield an error struct)")
                }
            }
            _ => panic("vm: err_loc on a non-error value (internal: checker should reject)")
        }
    }
    if last == "err_typed" {
        match ev_val(args[0], env) {
            StructVal as e => {
                let e1 = err_set(e, "expected", as_str(ev_val(args[1], env)))
                match e1 {
                    StructVal as e1s => return err_set(e1s, "actual", as_str(ev_val(args[2], env)))
                    _                => panic("vm: err_typed internal (err_set must yield an error struct)")
                }
            }
            _ => panic("vm: err_typed on a non-error value (internal: checker should reject)")
        }
    }
    null   // not an err builtin — fall through to user-fn resolution
}

// str/byte STDLIB builtins (Phase 3) — the unqualified str-returning helpers the corpus calls
// (str / str_of_bytes / one_byte / str_concat3 / ftoa). Recognized by the LAST path segment
// when single-segment OR teko-rooted (the `addressable` gate, like print/println). All PRODUCE
// A VALUE (a fresh str), so — like try_list_builtin / try_err_builtin — they live on the
// value-call path, not the `-> void` try_builtin. Each calls the SAME tk_* runtime symbol
// codegen emits, so VM==native byte-for-byte; a str Value IS the `str` member of Value (no
// constructor). `null` == not a str builtin → fall through to user-fn resolution.
//
// str / str_of_bytes — ([]byte) -> str. A []byte is a []Value of byte members. The runtime
// teko::str_of_bytes takes a `str` (a []byte has the same {ptr,len} shape; the form codegen
// passes directly). The VM's []Value is not a contiguous byte buffer, so we MATERIALIZE the
// bytes into a `str` first (each byte → teko::one_byte, concatenated — M.1), then call
// teko::str_of_bytes (which COPIES into the fresh owned result), mirroring the C twin.
fn try_str_builtin(callee: parser::Path, args: []checker::TExpr, env: Venv) -> Value? {
    let last = callee.segments[callee.segments.len - 1].name
    let addressable = callee.segments.len == 1 || callee.segments[0].name == "teko"
    if !addressable { return null }
    if last == "str" || last == "str_of_bytes" {
        match ev_val(args[0], env) {
            []Value as xs => {
                mut view = ""
                mut i = 0
                loop {
                    if i >= xs.len { break }
                    let elem = xs[i]
                    // byte == u8 rep (vm.c): a []byte element may be a byte Value OR a u8 int (e.g. an
                    // arithmetic/cast result the checker typed as an int) — read it numerically either way.
                    if val_is_byte(elem) || val_is_int(elem) {
                        view = teko::str_concat(view, teko::one_byte(as_int(elem) to byte))
                    } else {
                        panic("vm: str/str_of_bytes element is not a byte (internal: checker should reject)")
                    }
                    i++
                }
                return view   // `view` is already the fresh str built from the bytes (str_concat copies); it IS the result
            }
            _ => panic("vm: str/str_of_bytes on a non-[]byte value (internal: checker should reject)")
        }
    }
    // bytes_of_str — (str) -> []byte. Emit a []Value of byte values (one per UTF-8 byte),
    // mirroring the inverse path of str_of_bytes (there: []Value of bytes → str).
    if last == "bytes_of_str" {
        match ev_val(args[0], env) {
            str as s => {
                let slen = teko::len(s)
                mut out: []Value = teko::list::empty()
                mut i: u64 = 0
                loop {
                    if i >= slen { break }
                    out = teko::list::push(out, s[i])
                    i++
                }
                return out
            }
            _ => panic("vm: bytes_of_str on a non-str value (internal: checker should reject)")
        }
    }
    if last == "one_byte" {
        let a = ev_val(args[0], env)
        // byte == u8 rep (vm.c): accept a byte Value OR a u8 int.
        if val_is_byte(a) || val_is_int(a) { return teko::one_byte(as_int(a) to byte) }
        panic("vm: one_byte on a non-byte value (internal: checker should reject)")
    }
    // str_concat3 REMOVED (2026-07-01) — superseded by the variadic "concat" below.
    if last == "parse"        { return teko::float::parse(as_str(ev_val(args[0], env))) }
    if last == "ftoa"         { return teko::ftoa(as_float(ev_val(args[0], env))) }
    if last == "f64_bits"     { return teko::f64_bits(as_float(ev_val(args[0], env))) }
    if last == "f64_from_bits" { return teko::f64_from_bits(as_int(ev_val(args[0], env)) to u64) }
    // str STDLIB surface — the SAME runtime functions native codegen lowers to (tk_str_*), so the
    // VM matches the compiled output. (str, u64, …) args; a u64/bool result widens into Value.
    if last == "str_concat"  { return teko::str_concat(as_str(ev_val(args[0], env)), as_str(ev_val(args[1], env))) }
    // "concat" (== the LEGISLATED string::concat, TEKO_LEGISLATION.md "`+` never concatenates")
    // is the ONE public variadic form (2026-07-01, `concat3` removed). After the checker's params
    // call-site desugar, the call always arrives here with EXACTLY ONE arg — a []str, whether
    // packed from N pieces or passed through. Fold it via str_concat.
    if last == "concat" {
        match ev_val(args[0], env) {
            []Value as xs => {
                mut acc = ""
                mut i: u64 = 0
                loop { if i >= xs.len { break }; acc = teko::str_concat(acc, as_str(xs[i])); i++ }
                return acc
            }
            _ => panic("vm: concat on a non-[]str value (internal: checker should reject)")
        }
    }
    if last == "slice"       { return teko::slice(as_str(ev_val(args[0], env)), as_int(ev_val(args[1], env)) to u64, as_int(ev_val(args[2], env)) to u64) }
    if last == "slice_to"    { return teko::slice_to(as_str(ev_val(args[0], env)), as_int(ev_val(args[1], env)) to u64) }
    if last == "slice_from"  { return teko::slice_from(as_str(ev_val(args[0], env)), as_int(ev_val(args[1], env)) to u64) }
    if last == "len"         { return teko::len(as_str(ev_val(args[0], env))) }
    // len_chars — (str) -> i64. Count UTF-8 codepoints. Computed inline (avoids a recursive
    // builtin call; teko::len_chars is registered in scope.c but calling it here is circular
    // in the .tks engine). Uses the same lead-byte heuristic as tk_str_len_chars.
    if last == "len_chars" {
        let lcs = as_str(ev_val(args[0], env))
        let lc_slen = teko::len(lcs)
        mut lc_count: u64 = 0
        mut lc_i: u64 = 0
        loop {
            if lc_i >= lc_slen { break }
            let lc_bb = lcs[lc_i] to u64
            let lc_bw: u64 = if lc_bb < 0x80 to u64 { 1 to u64 } else if lc_bb < 0xC0 to u64 { 1 to u64 } else if lc_bb < 0xE0 to u64 { 2 to u64 } else if lc_bb < 0xF0 to u64 { 3 to u64 } else { 4 to u64 }
            lc_i = if lc_i + lc_bw > lc_slen { lc_slen } else { lc_i + lc_bw }
            lc_count = lc_count + 1
        }
        return lc_count to i64
    }
    // chars — (str) -> []char. Build a []Value of str (one per UTF-8 codepoint).
    // Char values are represented as str in the VM (TK_TEXPR_CHAR → v_str in vm.c).
    // We split inline on codepoint boundaries using the same lead-byte heuristic as
    // tk_str_chars in the runtime. VM caveat: multibyte literals may arrive split;
    // this degrades gracefully (each raw byte becomes a 1-element codepoint slice).
    if last == "chars" {
        let s = as_str(ev_val(args[0], env))
        let slen = teko::len(s)
        mut char_list: []Value = teko::list::empty()
        mut ci: u64 = 0
        loop {
            if ci >= slen { break }
            // determine lead-byte width
            let b0 = s[ci] to u64
            let w: u64 = if b0 < 0x80 to u64 { 1 to u64 }
                         else if b0 < 0xC0 to u64 { 1 to u64 }   // continuation — degrade
                         else if b0 < 0xE0 to u64 { 2 to u64 }
                         else if b0 < 0xF0 to u64 { 3 to u64 }
                         else { 4 to u64 }
            let end = if ci + w > slen { slen } else { ci + w }
            let cp_str: str = teko::slice(s, ci, end)
            char_list = teko::list::push(char_list, cp_str)
            ci = end
        }
        return char_list
    }
    // --- ROUND 0: UTF-8 codepoint operations ---
    // char_at — (str, i64) -> char. Walk codepoints to index i, return the UTF-8 slice as a str
    // (VM char representation). Panics if out of range (mirrors tk_char_at).
    if last == "char_at" {
        let s = as_str(ev_val(args[0], env))
        let idx = as_int(ev_val(args[1], env)) to u64
        let slen = teko::len(s)
        mut pos: u64 = 0
        mut ci: u64 = 0
        mut found: str = ""
        mut ok = false
        loop {
            if pos >= slen { break }
            let b0 = s[pos] to u64
            let w: u64 = if b0 < 0x80 to u64 { 1 to u64 }
                         else if b0 < 0xC0 to u64 { 1 to u64 }
                         else if b0 < 0xE0 to u64 { 2 to u64 }
                         else if b0 < 0xF0 to u64 { 3 to u64 }
                         else { 4 to u64 }
            let end = if pos + w > slen { slen } else { pos + w }
            if ci == idx { found = teko::slice(s, pos, end); ok = true; break }
            ci = ci + 1
            pos = end
        }
        if !ok { panic("char_at: codepoint index out of range") }
        return found
    }
    // str_slice_chars — (str, i64, i64) -> str. Walk to byte offsets for `from`/`to` codepoints,
    // return a fresh substring str. Mirrors tk_str_slice_chars.
    if last == "str_slice_chars" {
        let s = as_str(ev_val(args[0], env))
        let from = as_int(ev_val(args[1], env)) to u64
        let to   = as_int(ev_val(args[2], env)) to u64
        let slen = teko::len(s)
        mut pos: u64 = 0
        mut ci: u64 = 0
        mut byte_from: u64 = 0
        mut byte_to: u64 = 0
        mut found_from = false
        mut found_to   = false
        loop {
            if ci == from { byte_from = pos; found_from = true }
            if ci == to   { byte_to   = pos; found_to   = true; break }
            if pos >= slen { break }
            let b0 = s[pos] to u64
            let w: u64 = if b0 < 0x80 to u64 { 1 to u64 }
                         else if b0 < 0xC0 to u64 { 1 to u64 }
                         else if b0 < 0xE0 to u64 { 2 to u64 }
                         else if b0 < 0xF0 to u64 { 3 to u64 }
                         else { 4 to u64 }
            let end = if pos + w > slen { slen } else { pos + w }
            ci = ci + 1
            pos = end
        }
        // handle the case where `to` == codepoint count (end of string)
        if !found_to { if ci == to { byte_to = pos; found_to = true } }
        if !found_from || !found_to { panic("str_slice_chars: codepoint index out of range") }
        return teko::slice(s, byte_from, byte_to)
    }
    // is_alpha — (char) -> bool. char in VM is a str. Extract first byte; non-ASCII → true.
    // GUARD: if the first argument evaluates to a non-str value (e.g., byte/int from a user
    // function named is_alpha), return null so the caller falls through to user fn resolution.
    if last == "is_alpha" {
        let arg0 = ev_val(args[0], env)
        match arg0 { str => { } ; _ => return null }   // non-str arg → fall through to user fn
        let s = as_str(arg0)
        let slen = teko::len(s)
        if slen == 0 to u64 { return false }
        let b = s[0 to u64] to u64
        if b >= 0x80 to u64 { return true }   // non-ASCII → letter (ROUND 0 simplification)
        return (b >= 0x41 to u64 && b <= 0x5A to u64) || (b >= 0x61 to u64 && b <= 0x7A to u64)
    }
    // is_digit — (char) -> bool. ASCII '0'–'9' only; multibyte → false. Same guard.
    if last == "is_digit" {
        let arg0 = ev_val(args[0], env)
        match arg0 { str => { } ; _ => return null }   // non-str arg → fall through to user fn
        let s = as_str(arg0)
        let slen = teko::len(s)
        if slen == 0 to u64 { return false }
        let b = s[0 to u64] to u64
        return b >= 0x30 to u64 && b <= 0x39 to u64
    }
    // is_space — (char) -> bool. ASCII whitespace only; multibyte → false. Same guard.
    if last == "is_space" {
        let arg0 = ev_val(args[0], env)
        match arg0 { str => { } ; _ => return null }   // non-str arg → fall through to user fn
        let s = as_str(arg0)
        let slen = teko::len(s)
        if slen == 0 to u64 { return false }
        let b = s[0 to u64] to u64
        return b == 0x20 to u64 || b == 0x09 to u64 || b == 0x0A to u64 || b == 0x0D to u64 || b == 0x0C to u64 || b == 0x0B to u64
    }
    // to_lower — (char) -> char. ASCII 'A'–'Z' → 'a'–'z'; non-ASCII unchanged. Same guard.
    if last == "to_lower" {
        let arg0 = ev_val(args[0], env)
        match arg0 { str => { } ; _ => return null }   // non-str arg → fall through to user fn
        let s = as_str(arg0)
        let slen = teko::len(s)
        if slen == 0 to u64 { return s }
        let b = s[0 to u64] to u64
        if b >= 0x41 to u64 && b <= 0x5A to u64 { return teko::one_byte((b + 0x20 to u64) to byte) }
        return s
    }
    // to_upper — (char) -> char. ASCII 'a'–'z' → 'A'–'Z'; non-ASCII unchanged. Same guard.
    if last == "to_upper" {
        let arg0 = ev_val(args[0], env)
        match arg0 { str => { } ; _ => return null }   // non-str arg → fall through to user fn
        let s = as_str(arg0)
        let slen = teko::len(s)
        if slen == 0 to u64 { return s }
        let b = s[0 to u64] to u64
        if b >= 0x61 to u64 && b <= 0x7A to u64 { return teko::one_byte((b - 0x20 to u64) to byte) }
        return s
    }
    if last == "ends_with"   { return teko::ends_with(as_str(ev_val(args[0], env)), as_str(ev_val(args[1], env))) }
    if last == "contains"    { return teko::contains(as_str(ev_val(args[0], env)), as_str(ev_val(args[1], env))) }
    // str_* prefixed aliases — teko::runtime::str_* forms (last segment = "str_eq", "str_len", etc.).
    // Must be builtins so the self-hosted VM matches vm.c parity (SUPREME RULE).
    if last == "str_eq" {
        let a = as_str(ev_val(args[0], env))
        let b = as_str(ev_val(args[1], env))
        return a == b
    }
    if last == "str_len"       { return teko::len(as_str(ev_val(args[0], env))) }
    if last == "str_slice"     { return teko::slice(as_str(ev_val(args[0], env)), as_int(ev_val(args[1], env)) to u64, as_int(ev_val(args[2], env)) to u64) }
    if last == "str_slice_to"  { return teko::slice_to(as_str(ev_val(args[0], env)), as_int(ev_val(args[1], env)) to u64) }
    if last == "str_slice_from" { return teko::slice_from(as_str(ev_val(args[0], env)), as_int(ev_val(args[1], env)) to u64) }
    if last == "str_ends_with" { return teko::ends_with(as_str(ev_val(args[0], env)), as_str(ev_val(args[1], env))) }
    if last == "str_contains"  { return teko::contains(as_str(ev_val(args[0], env)), as_str(ev_val(args[1], env))) }
    if last == "i64_to_str"  { return teko::i64_to_str(as_int(ev_val(args[0], env)) to i64) }
    if last == "u64_to_str"  { return teko::u64_to_str(as_int(ev_val(args[0], env)) to u64) }
    null   // not a str builtin — fall through to user-fn resolution
}

// teko::fs::* host surface builtins — value-producing (like try_list/str/err_builtin). In the
// native vm.tks binary, `teko::fs::list_dir(path)` is lowered by codegen to `tk_rt_list_dir`,
// so calling it here goes directly to the POSIX opendir/readdir runtime (C2* host surface).
// `null` == not a fs/io builtin → fall through to user-fn resolution. (Mirrors vm.c handlers.)
fn try_fs_builtin(callee: parser::Path, args: []checker::TExpr, env: Venv) -> Value? {
    let last = callee.segments[callee.segments.len - 1].name
    let addressable = callee.segments.len == 1 || callee.segments[0].name == "teko"
    if !addressable { return null }
    // teko::io::read_file — slurp a file as UTF-8. Handled here to prevent infinite recursion:
    // the last-segment lookup for "read_file" would otherwise match driver.tks's local wrapper
    // which calls teko::io::read_file again (→ same wrapper → stack overflow).
    if last == "read_file" {
        let path = as_str(ev_val(args[0], env))
        match teko::io::read_file(path) {
            str as s => return s
            error as e => {
                let base = StructVal { type_name = "error"; field_names = teko::list::empty(); field_vals = teko::list::empty() }
                return err_set(base, "message", e.message)
            }
        }
    }
    if last == "list_dir" {
        let path = as_str(ev_val(args[0], env))
        match teko::fs::list_dir(path) {
            []str as entries => {
                mut result: []Value = teko::list::empty()
                mut i = 0
                loop {
                    if i >= entries.len { break }
                    result = teko::list::push(result, entries[i])
                    i++
                }
                return result
            }
            error as e => {
                let base = StructVal { type_name = "error"; field_names = teko::list::empty(); field_vals = teko::list::empty() }
                return err_set(base, "message", e.message)
            }
        }
    }
    // C7.12: write_file_bytes(path: str, data: []byte) -> error?
    // The VM represents []byte as []Value (each element is a byte or int). Build a str from the
    // byte values (same approach as str_of_bytes), then call the existing write_file runtime fn.
    if last == "write_file_bytes" {
        let path = as_str(ev_val(args[0], env))
        let data_val = ev_val(args[1], env)
        let xs = match data_val { []Value as b => b; _ => teko::list::empty() }
        mut content = ""
        mut i = 0
        loop {
            if i >= xs.len { break }
            let elem = xs[i]
            if val_is_byte(elem) || val_is_int(elem) {
                content = teko::str_concat(content, teko::one_byte(as_int(elem) to byte))
            }
            i++
        }
        let base = StructVal { type_name = "error"; field_names = teko::list::empty(); field_vals = teko::list::empty() }
        match teko::io::write_file(path, content) {
            error as e => return err_set(base, "message", e.message)
            null => return null
        }
    }
    // ROUND 0: str_from_utf8(bytes: []byte) -> str | error — the validated bytes -> str door
    // (B.36). The VM represents []byte as []Value (each element a byte or int). Gather into a
    // []byte (for validation) AND materialize the str (same one_byte-concat approach as
    // try_str_builtin's str/str_of_bytes case), then validate with teko::text::valid_utf8 (the
    // SAME RFC-3629 walk the lexer/parser use internally) before returning it.
    if last == "str_from_utf8" {
        let data_val = ev_val(args[0], env)
        let xs = match data_val { []Value as b => b; _ => teko::list::empty() }
        mut raw: []byte = teko::list::empty()
        mut view = ""
        mut i = 0
        loop {
            if i >= xs.len { break }
            let elem = xs[i]
            if val_is_byte(elem) || val_is_int(elem) {
                let b = as_int(elem) to byte
                raw = teko::list::push(raw, b)
                view = teko::str_concat(view, teko::one_byte(b))
            } else {
                panic("vm: str_from_utf8 element is not a byte (internal: checker should reject)")
            }
            i++
        }
        if !teko::text::valid_utf8(raw) {
            let base = StructVal { type_name = "error"; field_names = teko::list::empty(); field_vals = teko::list::empty() }
            return err_set(base, "message", "invalid UTF-8")
        }
        return view
    }
    null
}

// ---------------------------------------------------------------------------
// EXPRESSIONS -> Value. Coverage MIRRORS codegen's emit_expr: Number, Var, Str, Byte,
// Binary, Unary, Compare, Cast, Call, FieldAccess. IfExpr/MatchExpr AS A VALUE are the
// honest frontier (same as codegen).
//
// A value-position expression is NEVER `void` (void is return-only; the checker rejects
// it as a value) and `T?` optionals are a later wave (the parser does not emit them yet):
// either tag on a node's type is an honest stop (M.3), never a wrong-silent value.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// E2 — the ERROR value carries compiler-diagnostic adornments. An error value is a
// StructVal (type_name "error"); its fields mirror tk_error (core.h): message:str,
// file:str, line:u32, col:u32, expected:str, actual:str. A message-only literal
// `error { message = … }` carries ONLY the "message" field; the other adornments default
// (empty str / 0) — set by the err_loc / err_typed builtins, read by error field access.
// We re-use the generic StructVal carrier (parallel name/value lists) — no new Value member.
// ---------------------------------------------------------------------------

// Build a FRESH error value from `base`, with the named field set to `val` (overwriting if
// `base` already holds it, appending otherwise). FUNCTIONAL (copy-on-set, mirroring
// teko::list::push / env extend): `base` is never mutated, so err_loc(e,…) / err_typed(e,…)
// leave the source error intact. The VM twin of core.h's tk_error_loc / tk_error_types
// (which return a modified copy).
fn err_set(base: StructVal, field: str, val: Value) -> Value {
    mut names: []str = teko::list::empty()
    mut vals: []Value = teko::list::empty()
    mut present = false
    mut i = 0
    loop {                                  // copy the existing fields (overwriting the target)
        if i >= base.field_names.len { break }
        names = teko::list::push(names, base.field_names[i])
        if base.field_names[i] == field {
            vals = teko::list::push(vals, val)
            present = true
        } else {
            vals = teko::list::push(vals, base.field_vals[i])
        }
        i++
    }
    if !present {                           // append the new field
        names = teko::list::push(names, field)
        vals = teko::list::push(vals, val)
    }
    StructVal { type_name = "error"; field_names = names; field_vals = vals }
}

// Is `f` one of the error's STR adornment fields (vs the u32 line/col)?
fn err_field_is_str(f: str) -> bool {
    f == "message" || f == "file" || f == "expected" || f == "actual"
}

// Read an error value's field by name; if absent (never set), return the adornment DEFAULT:
// empty str for the str fields, 0:u32 for line/col (mirrors tk_error's zero/NULL defaults —
// C1.3). So `e.line` on a message-only error reads 0, never an honest stop.
fn err_field(e: StructVal, field: str) -> Value {
    mut i = 0
    loop {
        if i >= e.field_names.len { break }
        if e.field_names[i] == field { return e.field_vals[i] }
        i++
    }
    if field == "line" || field == "col" { return 0 to u32 }   // unset numeric adornment → 0:u32
    if err_field_is_str(field) { return "" }                    // unset str adornment → empty str
    ""                                                          // any other field on an error → empty str (honest)
}

// vm_struct_field_type — the declared TypeExpr of field `fname` in struct `sname`, looked up in
// the program's type declarations (the SAME table native's cg_find_struct_field_type reads). The
// generic-stamped case is identical: monomorph rewrites the stamped decl's field annotations into
// the program (e.g. `Box__g__opt_i64` carries `value: i64?`), so a stamped name resolves here too.
// Returns the field's parser TypeExpr, or null when the struct/field is absent. (C: parity helper.)
fn vm_struct_field_type(prog: checker::TProgram, sname: str, fname: str) -> parser::TypeExpr? {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as d => {
                match d.body {
                    parser::StructBody as sb => {
                        if d.name == sname {
                            mut j = 0
                            loop {
                                if j >= sb.fields.len { break }
                                if sb.fields[j].name == fname { return sb.fields[j].type_ann }
                                j++
                            }
                        }
                    }
                    _ => { }
                }
            }
            _ => { }
        }
        i++
    }
    null
}

// vm_field_coerce_type — the resolved Type to COERCE a field value into at struct construction,
// derived from the field's declared TypeExpr. An OptionalType field yields `Optional` so coerce_to
// PRESENT-wraps a bare value (the same thing native's emit_as does for a `T?` field — see
// emit_struct_init_framed). Every other shape yields `Void` (coerce_to's no-op): a bare CASE into a
// variant field needs no VM wrapper (a case value IS its variant value here, discriminated by
// type_name at match — vm_case_in_variant), and a `[]T?` field is an array literal whose elements
// are already coerced by eval_array. (C: mirrors native's per-field emit_as expected-slot.)
fn vm_field_coerce_type(prog: checker::TProgram, sname: str, fname: str) -> checker::Type {
    match vm_struct_field_type(prog, sname, fname) {
        // OptionalType field → present-wrap; SliceType field → element-wise rebuild (a `[]T?` field
        // present-wraps each element); every other shape → no-op. Shared with vm_param_coerce_type so
        // field and call-arg slots wrap uniformly. (Native parity with emit_struct_init's emit_as.)
        parser::TypeExpr as fte => vm_param_coerce_type(fte)
        null => checker::Void { }
    }
}

// vm_param_coerce_type — the coerce-slot type for a call PARAMETER, from its declared TypeExpr (the
// param twin of vm_field_coerce_type, but RECURSIVE so a `[]T?` param rebuilds its elements). An
// OptionalType yields `Optional` so coerce_to PRESENT-wraps a bare `T` arg into `T?`; a SliceType
// yields `Slice` whose element is the recursively-built coerce type so coerce_to rebuilds element-wise
// (a `[]T?` present-wraps each element); a `[]T` whose element needs no wrap collapses to `Void` (the
// no-op, so it stays IDENTICAL to the C path). Every other shape yields `Void`. The `-> checker::Type`
// return widens each arm into the Type variant rep. (Native parity with emit_as's call-arg wrap.)
fn vm_param_coerce_type(ann: parser::TypeExpr) -> checker::Type {
    match ann {
        parser::OptionalType => checker::Optional { inner = checker::Void { } }
        parser::SliceType as st => {
            let elt = vm_param_coerce_type(st.element)
            match elt {
                checker::Void => checker::Void { }                 // []T with no element wrap → no-op
                _             => checker::Slice { element = elt }
            }
        }
        _ => checker::Void { }
    }
}

// W4b — build a struct value `Name { f = v, … }` (declared field order). The nominal name
// is the node's type (a named type, or "error"); a non-named/non-error type is unreachable.
// Each field value is COERCED into its declared field type (vm_field_coerce_type → coerce_to), so a
// bare `T` supplied to a `T?` field PRESENT-wraps — native parity with emit_struct_init's per-field
// emit_as. Without this a later `?? / ?.` over that field found a non-optional and stopped (a VM-only
// divergence: native present-wraps at construction). The error-value (`tn == "error"`) path has no
// declared-field table; its fields ride as stored (E2 adornments are read with defaults, never ??).
fn eval_struct_init(si: checker::TStructInit, ty: checker::Type, env: Venv) -> EvalRes {
    let tn = match ty { Named as n => n.name; Error => "error"; _ => "" }
    mut cur = env                       // (MEM Step 4) thread the env across each field-value eval
    mut names: []str = teko::list::empty()
    mut vals: []Value = teko::list::empty()
    mut i = 0
    loop {
        if i >= si.field_names.len { break }
        let fr = eval_expr(si.field_vals[i], cur)
        cur = fr.env
        names = teko::list::push(names, si.field_names[i])
        vals = teko::list::push(vals, coerce_to(fr.value, vm_field_coerce_type(cur.prog, tn, si.field_names[i])))
        i++
    }
    let sv = StructVal { type_name = tn; field_names = names; field_vals = vals }
    // (W10b.CLASS residual — VM reference semantics) a class instance is a REFERENCE type
    // (increment 3, native side): construction allocates a cell (the SAME cell-store MEM-1b
    // already threads through eval_expr — see EvalRes) and yields a ClassRef, so passing/
    // binding/returning it is a cheap cell-index COPY (shared identity), matching the native
    // engine's arena-per-object pointer semantics — NOT a struct's by-value copy.
    let table = checker::type_table_of(cur.prog)
    match checker::find_class_body(tn, table) {
        parser::ClassBody => {
            let alloc = cell_alloc(cur.cells, sv)
            return EvalRes { value= ClassRef { cell= alloc.id }; env= with_cells(cur, alloc.cells) }
        }
        error => {}
    }
    EvalRes { value= sv; env= cur }
}

// W4b — read field `fa.field` from a struct value (the checker guarantees it exists).
// W5-idx — `.len`: a `str` value yields its byte length as a u64; a list value (slice) yields
// its element count as a u64 (the SLICE value layer — fixed+copy). Checker types `.len` as u64.
fn eval_field_access(fa: checker::TFieldAccess, env: Venv) -> EvalRes {
    let re = eval_expr(fa.receiver, env)   // (MEM Step 4) thread the receiver's env (a ref call there grows cells)
    let renv = re.env
    match re.value {
        // (MEM Step 2/3) `r.value` on a `Ref<T>` — the deref READ: the receiver evaluates to a
        // RefVal (a cell index); `.value` reads the aliased storage (cell_get). The checker (typer)
        // restricts a Reference receiver to ONLY the `.value` field, so any other field is impossible.
        RefVal as rv => {
            if fa.field == "value" { return EvalRes { value= cell_get(renv.cells, rv.cell); env= renv } }
            panic("vm: a reference (`Ref<T>`) exposes only `.value` (internal: checker should reject)")
        }
        // (W10b.CLASS residual — VM reference semantics) a class receiver is a ClassRef (a cell
        // index) — deref through the cell to its StructVal, then read the field exactly like an
        // ordinary struct value (same lookup loop, just below).
        ClassRef as cr => {
            match cell_get(renv.cells, cr.cell) {
                StructVal as s => {
                    mut i = 0
                    loop {
                        if i >= s.field_names.len { break }
                        if s.field_names[i] == fa.field { return EvalRes { value= s.field_vals[i]; env= renv } }
                        i++
                    }
                    panic("vm: field not found in class instance (internal: the checker guarantees the field)")
                }
                _ => panic("vm: a ClassRef cell must hold a StructVal (internal invariant)")
            }
        }
        str as s => {
            if fa.field == "len" { return EvalRes { value= s.len to u64; env= renv } }
            panic("vm: only `.len` is defined on a str (internal: checker should reject)")
        }
        []Value as xs => {
            if fa.field == "len" { return EvalRes { value= xs.len to u64; env= renv } }
            panic("vm: field access on a slice value (internal: checker should reject)")
        }
        StructVal as s => {
            // E2 — an ERROR value's adornment field (message/file/line/col/expected/actual):
            // a present field rides as stored; an UNSET adornment reads its default (empty str /
            // 0:u32) rather than an honest stop, so `e.line` on a message-only error is 0 (C1.3).
            if s.type_name == "error" { return EvalRes { value= err_field(s, fa.field); env= renv } }
            mut i = 0
            loop {
                if i >= s.field_names.len { break }
                if s.field_names[i] == fa.field { return EvalRes { value= s.field_vals[i]; env= renv } }
                i++
            }
            panic("vm: field not found in struct value (internal: the checker guarantees the field)")
        }
        _ => panic("vm: field access on a non-struct value (internal: checker should reject)")
    }
}

// W5-idx — subscript `recv[index]`. A `str` receiver yields the byte at `index`, BOUNDS-
// CHECKED: an index >= len routes through the SAME out-of-bounds panic the runtime uses
// ("index out of bounds" — M.1), else a `byte` Value. A list value (slice) yields the element
// at `index`, bounds-checked through the SAME panic (the SLICE value layer — fixed+copy).
// Mirrors codegen's stmt-expr guard.
fn eval_index(ix: checker::TIndex, line: u32, col: u32, env: Venv) -> EvalRes {
    let re = eval_expr(ix.receiver, env)   // (MEM Step 4) thread receiver then index
    let ie2 = eval_expr(ix.index, re.env)
    let cur = ie2.env
    let i = as_int(ie2.value)
    match re.value {
        str as s => {
            if i >= s.len { vm_panic_oob_at(line, col) }   // C1.6 — positioned at the subscript node
            EvalRes { value= s[i] to byte; env= cur }
        }
        []Value as xs => {
            if i >= xs.len { vm_panic_oob_at(line, col) }   // C1.6 — positioned at the subscript node
            EvalRes { value= xs[i]; env= cur }
        }
        _            => panic("vm: subscript on a non-indexable value (internal: checker should reject)")
    }
}

// $"…{expr}…" (self-host parity) — build the result str by concatenating each piece and each
// hole's value: a str value passes through; an INT value → its decimal text via the SAME runtime
// builders codegen emits (i64_to_str / u64_to_str, selected by the value's own signedness), so
// VM==codegen byte-for-byte. The result is pieces[0] ++ str(holes[0]) ++ … ++ pieces[nholes]
// (pieces.len == holes.len + 1). The checker restricted hole types to str/integer.
fn eval_interp_hole_no_spec(h: Value) -> str {
    match h {
        str as s   => s
        bool as b  => if b { "true" } else { "false" }
        _          => if val_is_float(h) { teko::ftoa(as_float(h)) }
                      else if int_sign_of(h) { teko::i64_to_str(as_int(h) to i64) }
                      else { teko::u64_to_str(as_int(h) to u64) }
    }
}

fn eval_interp_static_spec(h: Value, spec: str) -> str {
    // lowercase first byte to normalize 'F'→'f' (ASCII: 0x20 = lowercase flag for A-Z)
    let fc0 = if spec.len > 0 { spec[0] } else { 102 to byte }  // 102 = 'f'
    let fc_low = if fc0 >= 65 && fc0 <= 90 { (fc0 to u64 + 32) to byte } else { fc0 }
    mut prec = 0 to i64
    mut has_prec = false
    mut si = 1 to u64
    loop {
        if si >= spec.len { break }
        let ch = spec[si]
        if ch >= 48 && ch <= 57 { prec = prec * 10 + (ch to i64 - 48); has_prec = true }
        si++
    }
    if !has_prec { prec = if fc_low == 100 { 1 to i64 } else { 6 to i64 } }  // 100='d'
    let is_flt = val_is_float(h)
    let dval = if is_flt { as_float(h) }
               else if int_sign_of(h) { as_int(h) to i64 to f64 }
               else { as_int(h) to u64 to f64 }
    let ival = if int_sign_of(h) { as_int(h) to i64 } else { 0 to i64 }
    let uval = if !int_sign_of(h) && !is_flt { as_int(h) to u64 } else { 0 to u64 }
    if      fc_low == 102 { teko::fmt_f(dval, prec) }             // 'f'
    else if fc_low == 101 { teko::fmt_e(dval, prec) }             // 'e'
    else if fc_low == 103 { teko::fmt_g(dval, prec) }             // 'g'
    else if fc_low == 112 { teko::fmt_p(dval, prec) }             // 'p'
    else if fc_low == 100 { teko::fmt_d(ival, prec) }             // 'd'
    else if fc_low == 120 && spec.len > 0 && spec[0] == 88 { teko::fmt_x_upper(uval) }  // 'X'
    else if fc_low == 120 { teko::fmt_x_lower(uval) }             // 'x'
    else if fc_low == 98  { teko::fmt_b(uval) }                   // 'b'
    else if fc_low == 110 && is_flt { teko::fmt_n_f(dval, prec) } // 'n' float
    else if fc_low == 110 { teko::fmt_n_i(ival) }                 // 'n' int
    else { teko::fmt_f(dval, prec) }
}

fn eval_interp(in: checker::TInterp, env: Venv) -> EvalRes {
    mut cur = env
    mut acc = ""
    mut i = 0
    loop {
        if i >= in.pieces.len { break }
        acc = teko::str_concat(acc, in.pieces[i])
        if i < in.holes.len {
            let he = eval_expr(in.holes[i], cur)
            cur = he.env
            let h = he.value
            let fk = if i < in.specs.len { in.specs[i].kind } else { checker::TFSpecNone { } }
            let hs = match fk {
                checker::TFSpecStatic as fs => eval_interp_static_spec(h, fs.s)
                checker::TFSpecDynamic as fd => {
                    let se = eval_expr(fd.args[0], cur)
                    cur = se.env
                    let spec_str = match se.value { str as s => s; _ => "" }
                    if val_is_float(h) { teko::fmt_dyn_f64(as_float(h), spec_str) }
                    else if int_sign_of(h) { teko::fmt_dyn_i64(as_int(h) to i64, spec_str) }
                    else { teko::fmt_dyn_u64(as_int(h) to u64, spec_str) }
                }
                _ => eval_interp_hole_no_spec(h)
            }
            acc = teko::str_concat(acc, hs)
        }
        i++
    }
    EvalRes { value= acc; env= cur }
}

// Phase 2 — `<lhs> in [ e0, e1, … ]` -> bool. The LHS is EVALUATED ONCE; then each element is
// evaluated and compared to that SAME value with value_eq (the SAME value-equality the VM uses for
// scalar `==` / literal patterns — int/float/bool/str). Returns true iff any element equals the lhs;
// the empty set `x in []` -> false (the loop runs zero times). value_eq returns false for struct/list
// operands, but the checker restricts `in` to scalar-comparable element types, so the honest frontier
// matches `==`. Mirrors the C `eval_in` and codegen's fold of value_eq (single-eval lhs).
fn eval_in(ie: checker::TInExpr, env: Venv) -> EvalRes {
    let le = eval_expr(ie.lhs, env)   // single-eval: the LHS once
    let lhs = le.value
    mut cur = le.env                  // (MEM Step 4) thread the env across each element eval
    mut i = 0
    loop {
        if i >= ie.elems.len { break }
        let ee = eval_expr(ie.elems[i], cur)
        cur = ee.env
        if value_eq(lhs, ee.value) { return EvalRes { value= true; env= cur } }
        i++
    }
    EvalRes { value= false; env= cur }   // empty set, or no element matched
}

// ---------------------------------------------------------------------------
// W5b — MATCH execution. The typed arm keeps the SYNTACTIC pattern (literal/range bounds are
// AST literal exprs; BIND/FIELD name a case by its path's LAST segment — a variant value is a
// StructVal whose type_name IS the case). Exhaustiveness is guaranteed by the checker; a
// fall-through is an honest stop (M.3). Mirrors codegen's match lowering and the C `pat_match`/
// `eval_match`.
//
// HOW THIS DIFFERS FROM THE C (faithful, not literal):
//   * The C `tk_value` carries a runtime `tag`; here a Value's MEMBER is its tag, so the C's
//     `a.tag` switch becomes a `match` over the Value variant (the val_is_*/int_*_of classifiers).
//   * The C represents `byte` as an INT (u8 carrier); here `byte` is its OWN Value member, so
//     `value_eq`/`lit_as` carry a `byte` literal as a `byte` Value (not an int) — same compare,
//     distinct member.
//   * The C `env_pop_to(armenv, env->head)` pops an arm's bindings between arms. The Venv here is
//     FUNCTIONAL (a `[]Slot`), so there is nothing to pop: a non-matching / guard-failing arm
//     simply does NOT thread its grown env (`pm.env`) forward — the next arm starts from the
//     parent `env`. Same scoping semantics, expressed immutably (as check_pattern/type_arm do).
//   * The C reads u128 via a separate unsigned accessor for the range compare; the .tks value
//     model exposes ONE signed int accessor (`as_int`) — the width/sign live in the member — so
//     the C's signed/unsigned branch collapses onto `as_int` (faithful for the in-range prims the
//     checker admits; the branch is preserved for clarity).
// ---------------------------------------------------------------------------

// last path segment name (cases/types match by their final identifier, like find_function).
fn path_last(p: parser::Path) -> str {
    if p.segments.len == 0 { "" } else { p.segments[p.segments.len - 1].name }
}

// (W9.4) a SYNTACTIC type-expr → its mangle fragment, mirroring checker::type_mangle (prim/str/byte/
// named → the segment name, slice_/opt_ prefixes, a nested generic use → its own instance name). So a
// bind pattern's stamped case name agrees byte-for-byte with the value's stamped type_name. (vm.c: vm_texpr_mangle.)
fn vm_texpr_mangle(te: parser::TypeExpr) -> str {
    match te {
        parser::NamedType as nt => {
            let last = nt.path.segments[nt.path.segments.len - 1].name
            if nt.args.len == 0 { last } else { vm_texpr_inst_name(last, nt.args) }
        }
        parser::SliceType as st    => teko::str::concat("slice_", vm_texpr_mangle(st.element))
        parser::OptionalType as ot => teko::str::concat("opt_", vm_texpr_mangle(ot.inner))
        parser::UnionType          => "variant"
        parser::FunctionType       => "func"   // (W10a) matches checker type_mangle's Func fragment
    }
}
fn vm_texpr_inst_name(base: str, args: []parser::TypeExpr) -> str {
    mut out = teko::str::concat(base, "__g__")
    mut i = 0
    loop {
        if i >= args.len { break }
        if i > 0 { out = teko::str::concat(out, "__") }
        out = teko::str::concat(out, vm_texpr_mangle(args[i]))
        i++
    }
    out
}

// (W9.4) a bind pattern's CASE NAME: the STAMPED instance `Gen__g__i64` when it carries explicit
// type-args (`Gen<i64> as x`), else the plain path-last identifier. Matches a stamped value's type_name.
fn bind_case_name(bp: parser::BindPattern) -> str {
    if bp.type_args.len > 0 { vm_texpr_inst_name(path_last(bp.type_name), bp.type_args) } else { path_last(bp.type_name) }
}

// Value classifiers — the .tks stand-in for the C `tag` switch (the member IS the tag).
fn val_is_int(v: Value) -> bool {
    match v { u8 | u16 | u32 | u64 | u128 | i8 | i16 | i32 | i64 | i128 => true; _ => false }
}
fn val_is_float(v: Value) -> bool { match v { f16 | f32 | f64 => true; _ => false } }
fn val_is_byte(v: Value)  -> bool { match v { byte => true; _ => false } }   // byte == u8 rep (compares as int)
// signedness/width of an INT Value (the member encodes both) — mirrors the C `subj.as.i.{is_signed,width}`.
fn int_sign_of(v: Value)  -> bool { match v { i8 | i16 | i32 | i64 | i128 => true; _ => false } }
fn int_width_of(v: Value) -> u8 {
    match v { u8 | i8 => 8; u16 | i16 => 16; u32 | i32 => 32; u64 | i64 => 64; u128 | i128 => 128; _ => 64 }
}
fn float_width_of(v: Value) -> u8 { match v { f16 => 16; f32 => 32; f64 => 64; _ => 64 } }

// val_type_matches — does a value's TYPE match a bare type-pattern name (a union member named by
// its type)? A prim member matches by its exact prim type; bool/byte/str by kind; a named case or
// `error` by the StructVal's type_name. This is what lets a `match` arm name a member by TYPE with
// NO destructure and NO alias — `match x { i64 => …; error => … }` — in the VM, mirroring the
// native tagged-union discrimination. (Slices are handled by the is_slice branch; `null` above.)
fn val_type_matches(subj: Value, name: str) -> bool {
    match subj {
        u8   => name == "u8"
        u16  => name == "u16"
        u32  => name == "u32"
        u64  => name == "u64"
        u128 => name == "u128"
        i8   => name == "i8"
        i16  => name == "i16"
        i32  => name == "i32"
        i64  => name == "i64"
        i128 => name == "i128"
        f16  => name == "f16"
        f32  => name == "f32"
        f64  => name == "f64"
        bool => name == "bool"
        byte => name == "byte"
        str  => name == "str"
        []Value => false                          // a slice member is matched by the is_slice branch
        StructVal as sv => sv.type_name == name    // a named case / `error`
        OptVal => false
        RefVal => false                            // (MEM Step 2/3) a `Ref<T>` value is never pattern-matched (escape-gated, param-only)
        FuncVal => false                           // (W10a) a function value is never pattern-matched
        ClassRef => false                          // (W10b.CLASS residual) a class instance is nominal, never a variant-case pattern subject
    }
}

// Value accessors — extract the carried scalar (the .tks stand-in for the C `.as.*` union read).
// as_int: any INT member (incl byte=u8) → the i128 carrier (the C exposes ONE signed accessor;
// the width/sign live in the member). as_float: any FLOAT → f64. as_bool/as_str: the lone member.
// A wrong-kind access is an internal invariant break (the checker guarantees the kind) — panic (M.1).
fn as_int(v: Value) -> i128 {
    match v {
        u8 as x   => x to i128
        u16 as x  => x to i128
        u32 as x  => x to i128
        u64 as x  => x to i128
        u128 as x => x to i128
        i8 as x   => x to i128
        i16 as x  => x to i128
        i32 as x  => x to i128
        i64 as x  => x to i128
        i128 as x => x
        byte as x => x to i128
        _ => panic("vm: as_int on a non-int value (checker should reject)")
    }
}
fn as_float(v: Value) -> f64 {
    match v {
        f16 as x => x to f64
        f32 as x => x to f64
        f64 as x => x
        _ => panic("vm: as_float on a non-float value (checker should reject)")
    }
}
fn as_bool(v: Value) -> bool {
    match v { bool as x => x; _ => panic("vm: as_bool on a non-bool value (checker should reject)") }
}
fn as_str(v: Value) -> str {
    match v { str as x => x; _ => panic("vm: as_str on a non-str value (checker should reject)") }
}

// Value CONSTRUCTORS — the .tks stand-in for the C v_int / v_float (+ norm_int). A `u32` Value IS
// the `u32` case (the member carries the scalar), so we build by MASKING the low `width` bits with
// bitwise `&` (never panics, unlike a checked `to`) and then sign-extending for signed widths — the
// masked/extended value fits its prim, so the final `to` is in range. Mirrors mask_to_width /
// sext_to_width + v_int in vm.c (the 128-bit case is the i128 carrier itself).
fn norm_int(raw: i128, signed: bool, width: u8) -> Value {
    if signed {
        if width == 8        { let m = raw & 0xFF;                  if m >= 0x80 { (m - 0x100) to i8 } else { m to i8 } }
        else if width == 16  { let m = raw & 0xFFFF;               if m >= 0x8000 { (m - 0x10000) to i16 } else { m to i16 } }
        else if width == 32  { let m = raw & 0xFFFFFFFF;           if m >= 0x80000000 { (m - 0x100000000) to i32 } else { m to i32 } }
        else if width == 64  { let m = raw & 0xFFFFFFFFFFFFFFFF;   if m >= 0x8000000000000000 { (m - 0x10000000000000000) to i64 } else { m to i64 } }
        else                 { raw to i128 }                       // 128: raw IS the full-width carrier
    } else {
        if width == 8        { (raw & 0xFF) to u8 }
        else if width == 16  { (raw & 0xFFFF) to u16 }
        else if width == 32  { (raw & 0xFFFFFFFF) to u32 }
        else if width == 64  { (raw & 0xFFFFFFFFFFFFFFFF) to u64 }
        else                 { raw to u128 }                       // 128: reinterpret the carrier's bits
    }
}

// float_val — a FLOAT Value at the IEEE width (16/32/64), mirror of v_float. f16/f32 round via the cast.
fn float_val(f: f64, width: u8) -> Value {
    if width == 16 { f to f16 }
    else if width == 32 { f to f32 }
    else { f }   // 64 (default): f IS an f64 Value
}

// num_of_prim — a literal NUMBER node → a concrete Value at the node's prim (mirror of vm.c's
// TK_TEXPR_NUMBER case): a float literal → float_val at the prim width; a bool prim → a bool Value;
// an int literal → norm_int (width/sign-correct, incl 128). The checker guarantees the kind.
fn num_of_prim(n: checker::TNumber, t: checker::Type) -> Value {
    let k = match t {
        checker::Prim as p => p.kind
        checker::Byte      => checker::PrimKind::U8   // `byte` literal → u8
        _                  => panic("vm: number literal with a non-primitive type not yet supported")
    }
    if n.is_float {
        if !prim_float(k) { panic("vm: float literal with a non-float type (internal: checker should reject)") }
        float_val(n.fval, prim_width(k))
    } else {
        match k {
            checker::PrimKind::Bool => n.value != 0                       // a bool Value
            _                       => norm_int(n.value, prim_signed(k), prim_width(k))
        }
    }
}

// value equality (literal patterns) — same-kind scalar compare. Mirrors the C `value_eq`; struct/
// list are not literal-comparable (false). Ints compare via the i128 carrier (`as_int`); the
// distinct `byte` member compares as a byte.
fn value_eq(a: Value, b: Value) -> bool {
    if val_is_int(a)   && val_is_int(b)   { return as_int(a) == as_int(b) }
    if val_is_float(a) && val_is_float(b) { return as_float(a) == as_float(b) }
    match a {
        bool as ab => match b { bool as bb => return ab == bb; _ => return false }
        byte as ay => match b { byte as by => return ay == by; _ => return false }
        str as az  => match b { str as bz  => return az == bz; _ => return false }
        _          => return false
    }
}

// Mint an AST literal pattern bound as a Value comparable to the subject. The checker guarantees
// the literal's type == the subject's, so an int literal borrows the subject's width/sign and a
// float literal the subject's width (the AST literal carries no resolved prim). Mirrors the C
// `lit_as`; a BYTE literal mints a `byte` Value (the C's u8), a STR literal a `str` Value.
fn lit_as(lit: parser::Expr, subj: Value) -> Value {
    match lit {
        parser::Number as n => {
            if n.is_float {
                float_val(n.fval, if val_is_float(subj) { float_width_of(subj) } else { 64 })
            } else {
                norm_int(n.value,
                         if val_is_int(subj) { int_sign_of(subj) } else { false },
                         if val_is_int(subj) { int_width_of(subj) } else { 64 })
            }
        }
        parser::ByteLit as b => b.value      // a `byte` Value (the C carries u8; here byte is its own member)
        parser::StrLit as s  => s.text       // a `str` Value
        _                    => panic("vm: unsupported literal in a pattern (parser emits only number/byte/str)")
    }
}

// pat_match — does `subj` match `pat`? On match, returns the env extended with the pattern's
// bindings (`matched = true`); on no match, `matched = false` and the env is irrelevant (the caller
// discards it). The FUNCTIONAL stand-in for the C `pat_match(pat, subj, env)` that mutates `env` in
// place and is unwound by `env_pop_to`.
type PatMatch = struct { matched: bool; env: Venv }

// vm_case_in_variant — is `cname` a MEMBER of the variant type `vname`? A match arm may name a
// VARIANT (e.g. `Type`) and the value's case is one of its members (e.g. `Prim`): the VM has no
// wrapper (the value IS the member struct), so resolve the variant decl in the program and check
// membership. (Mirrors vm.c case_in_variant; native codegen discriminates the tagged union.)
// vm_match_as_enum_int — does `name` match an integer `ordinal` when the subject is an enum value?
// Case A: `name` is an ENUM TYPE NAME (e.g., `PrimKind as k`) — any integer is a valid enum value
//   of that type (the checker guarantees the subject came from a union like `PrimKind | error`).
// Case B: `name` is an ENUM MEMBER NAME (e.g., `U8 =>`, `I64 =>`) — matches only at the right ordinal.
// Mirrors vm.c match_as_enum_int.
fn vm_match_as_enum_int(prog: checker::TProgram, name: str, ordinal: i128) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as td => {
                match td.body {
                    parser::EnumBody as eb => {
                        if td.name == name { return true }
                        mut j = 0
                        loop {
                            if j >= eb.members.len { break }
                            if eb.members[j] == name && (j to i128) == ordinal { return true }
                            j++
                        }
                    }
                    _ => {}
                }
            }
            _ => {}
        }
        i++
    }
    false
}

fn vm_case_in_variant(prog: checker::TProgram, vname: str, cname: str) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            parser::TypeDecl as td => {
                if td.name == vname {
                    match td.body {
                        parser::VariantBody as vb => match vb.type_expr {
                            parser::UnionType as u => {
                                mut j = 0
                                loop {
                                    if j >= u.members.len { break }
                                    match u.members[j] {
                                        parser::NamedType as nt => { if nt.path.segments[nt.path.segments.len - 1].name == cname { return true } }
                                        _ => {}
                                    }
                                    j = j + 1
                                }
                                return false
                            }
                            _ => return false
                        }
                        _ => return false
                    }
                }
            }
            _ => {}
        }
        i = i + 1
    }
    false
}

fn pat_match(pat: parser::Pattern, subj: Value, env: Venv) -> PatMatch {
    // OPTIONAL subject (REBOOT_PLAN §202): `null` matches NONE; any other pattern matches the
    // PRESENT case. A bare bind/wildcard over a present NON-struct inner binds the inner directly;
    // a struct/variant inner recurses (the variant tag check / field destructure still applies).
    match subj {
        OptVal as o => {
            match pat {
                parser::NullPattern => return PatMatch { matched = !o.present; env = env }
                _ => {
                    if !o.present { return PatMatch { matched = false; env = env } }
                    let inner = match o.inner { Value as iv => iv; null => return PatMatch { matched = false; env = env } }
                    match inner {
                        StructVal => return pat_match(pat, inner, env)   // variant/struct inner — recurse
                        _ => {
                            match pat {
                                parser::WildcardPattern   => return PatMatch { matched = true; env = env }
                                parser::BindPattern as bp => {
                                    if bp.has_binding { return PatMatch { matched = true; env = define(env, bp.binding, inner) } }
                                    return PatMatch { matched = true; env = env }
                                }
                                _ => return pat_match(pat, inner, env)
                            }
                        }
                    }
                }
            }
        }
        _ => {}
    }
    match pat {
        parser::NullPattern      => PatMatch { matched = false; env = env }   // `null` over a non-optional never matches
        parser::WildcardPattern  => PatMatch { matched = true; env = env }
        parser::LiteralPattern as lp => PatMatch { matched = value_eq(subj, lit_as(lp.value, subj)); env = env }
        parser::RangePattern as rp => {
            if !val_is_int(subj) { return PatMatch { matched = false; env = env } }
            let lo = lit_as(rp.lo, subj); let hi = lit_as(rp.hi, subj)
            // signed/unsigned compare — the .tks single signed accessor carries both (see header note).
            let v = as_int(subj)
            PatMatch { matched = as_int(lo) <= v && v <= as_int(hi); env = env }
        }
        parser::AltPattern as ap => {
            // any option matches; options bind NOTHING (the checker forbids binding in an Alt).
            mut i = 0
            loop {
                if i >= ap.options.len { break }
                if pat_match(ap.options[i], subj, env).matched { return PatMatch { matched = true; env = env } }
                i++
            }
            PatMatch { matched = false; env = env }
        }
        parser::BindPattern as bp => {
            if bp.is_slice {
                // `[]T as x` — the slice case of a `[]T | error`: a slice value is a list.
                match subj {
                    []Value as _ => {
                        if bp.has_binding {
                            PatMatch { matched = true; env = define(env, bp.binding, subj) }
                        } else {
                            PatMatch { matched = true; env = env }
                        }
                    }
                    _ => PatMatch { matched = false; env = env }
                }
            } else {
                // a member matched by TYPE: a named case is a StructVal whose type_name IS the case;
                // a PRIM/bool/byte/str member matches by the value's kind (val_type_matches); AND a
                // pattern that names a VARIANT (`Type`) matches a value whose case is one of its
                // members (vm_case_in_variant). Supports `Type =>` with NO destructure and NO alias.
                let bname = bind_case_name(bp)   // (W9.4) `Gen<i64> as x` → `Gen__g__i64`
                mut hit = val_type_matches(subj, bname)
                if !hit {
                    match subj {
                        StructVal as sv => { if vm_case_in_variant(env.prog, bname, sv.type_name) { hit = true } }
                        _ => { if val_is_int(subj) { if vm_match_as_enum_int(env.prog, bname, as_int(subj)) { hit = true } } }
                    }
                }
                if hit {
                    if bp.has_binding {
                        return PatMatch { matched = true; env = define(env, bp.binding, subj) }
                    }
                    return PatMatch { matched = true; env = env }
                }
                // Transparent field descent: when the subject is a struct with no direct match,
                // check each STRUCT field for a value that matches the pattern name (e.g. `Number as nn`
                // on `Expr { kind = Number{…}; line; col }`). Bind to the first matching field.
                // Only struct fields are eligible — int fields are excluded because vm_match_as_enum_int
                // could match enum member names that coincidentally share the same ordinal value as an
                // unrelated enum (e.g. TyShape::Variant=2 vs PrimKind::U32=2 causing false descent).
                // Mirrors vm.c TK_PAT_BIND transparent-field-descent block.
                match subj {
                    StructVal as sv => {
                        mut fi = 0
                        loop {
                            if fi >= sv.field_vals.len { break }
                            let fv = sv.field_vals[fi]
                            match fv {
                                StructVal as fsv => {
                                    mut fhit = val_type_matches(fv, bname)
                                    if !fhit { if vm_case_in_variant(env.prog, bname, fsv.type_name) { fhit = true } }
                                    if fhit {
                                        if bp.has_binding {
                                            return PatMatch { matched = true; env = define(env, bp.binding, fv) }
                                        }
                                        return PatMatch { matched = true; env = env }
                                    }
                                }
                                _ => {}
                            }
                            fi++
                        }
                    }
                    _ => {}
                }
                PatMatch { matched = false; env = env }
            }
        }
        parser::FieldPattern as fp => {
            match subj {
                StructVal as sv => {
                    if sv.type_name != path_last(fp.type_name) { return PatMatch { matched = false; env = env } }
                    mut e2 = env
                    mut i = 0
                    loop {
                        if i >= fp.fields.len { break }
                        // bind each named field from the subject's fields (the checker guarantees it exists).
                        mut found = false
                        mut j = 0
                        loop {
                            if j >= sv.field_names.len { break }
                            if sv.field_names[j] == fp.fields[i] {
                                e2 = define(e2, fp.fields[i], sv.field_vals[j])
                                found = true
                                break
                            }
                            j++
                        }
                        if !found { return PatMatch { matched = false; env = env } }   // the checker guarantees the field
                        i++
                    }
                    PatMatch { matched = true; env = e2 }
                }
                _ => PatMatch { matched = false; env = env }
            }
        }
    }
}

// match as a VALUE (a match used as a SUB-expression): the first arm whose pattern matches AND
// whose `when` holds; run its body BLOCK; a NORMAL trailing value is the match's value. A
// `return`/`break`/`continue` inside the arm CANNOT be a value here — honest stop, IDENTICAL to
// eval_expr's TIfExpr sub-expr rule (flow-aware positions take exec_match). A matching arm's
// bindings ride its grown env (`pm.env`); a non-matching / guard-failing arm is discarded by NOT
// threading that env forward (the functional stand-in for the C `env_pop_to`). Mirrors the C
// `eval_match`.
fn eval_match(m: checker::TMatchExpr, line: u32, col: u32, env: Venv) -> EvalRes {
    let se = eval_expr(m.subject, env)   // (MEM Step 4) thread the subject's env (a ref call there grows cells)
    let subj = se.value
    let senv = se.env
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        let arm = m.arms[i]
        let pm = pat_match(arm.pattern, subj, senv)   // pattern bindings ride senv
        if pm.matched {
            // A `when` guard may itself evaluate a ref call; thread its env into the body's env.
            let ge = if arm.has_when { eval_expr(arm.guard, pm.env) } else { EvalRes { value= true; env= pm.env } }
            let guard_ok = as_bool(ge.value)
            if guard_ok {
                teko::cov_branch(line, col, i to u64)   // D3-branch: value-position arm `i` taken
                let bo = exec_block(arm.body, ge.env)
                match bo.flow {
                    // thread the arm body's final env out: an outer-`mut`/cell write inside the arm survives
                    Normal as nm => return EvalRes { value= nm.value ?? panic("vm: a `match` used as a value produced no value (internal: checker requires a value arm)"); env= with_cells(senv, bo.env.cells) }
                    _            => panic("vm: control flow inside a `match` used as a sub-expression not yet supported")
                }
            }
        }
        i++   // discard this arm's bindings (don't thread pm.env forward) and try the next
    }
    panic("vm: non-exhaustive match at runtime (internal: the checker guarantees exhaustiveness)")
}

// run a `match` as CONTROL FLOW (the FLOW form, mirroring exec_if): eval the subject, find the
// FIRST arm whose pattern matches AND whose `when` holds, run its body BLOCK and RETURN that flow.
// A `return`/`break`/`continue` inside the arm propagates out; a NORMAL trailing value rides the
// flow (the match's value). Routed from a binding/return/loose-statement RHS, exactly as `if` RHS
// routes through exec_if. Mirrors the C `exec_match`.
fn exec_match(e: checker::TExpr, env: Venv) -> FlowEnv {
    match e {
        checker::TMatchExpr as m => {
            let base = env.slots.len      // outer scope size: the arm's pattern bindings + body locals sit above it
            let se = eval_expr(m.subject, env)   // (MEM Step 4) thread the subject's env
            let subj = se.value
            let senv = se.env
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                let arm = m.arms[i]
                let pm = pat_match(arm.pattern, subj, senv)
                if pm.matched {
                    let ge = if arm.has_when { eval_expr(arm.guard, pm.env) } else { EvalRes { value= true; env= pm.env } }
                    let guard_ok = as_bool(ge.value)
                    if guard_ok {
                        teko::cov_branch(e.line, e.col, i to u64)   // D3-branch: arm `i` taken (no-op unless coverage on)
                        // run the arm body; POP its bindings/locals back to the outer scope (keeping
                        // outer-`mut` mutations, which mutate_slot writes at their index in [0, base)).
                        let bo = exec_block(arm.body, ge.env)
                        return FlowEnv { flow= bo.flow; env= Venv { slots= loop_outer(bo.env.slots, base); prog= bo.env.prog; defers= bo.env.defers; cells= bo.env.cells } }
                    }
                }
                i++   // discard this arm's bindings and try the next
            }
            panic("vm: non-exhaustive match at runtime (internal: the checker guarantees exhaustiveness)")
        }
        _ => panic("vm: exec_match on a non-match expression (internal: checker should reject)")
    }
}

// (MEM Step 4) EvalRes — the value AND the (possibly cell-mutated) env produced by evaluating an
// expression. eval_expr is value-functional: its only env-changing case is a `Ref<T>` call in VALUE
// position (e.g. `let y = bump(x)`, `f(bump(x))`, `bump(x) + 1`), which auto-refs the caller's `mut`
// lvalue to a cell and writes through it. That cell write must thread BACK to the caller — but
// eval_expr returns only a Value, so before MEM Step 4 a value-position ref call had no env-return
// channel (it honest-stopped). EvalRes IS that channel. For EVERY non-ref expression the returned
// env is the input env UNCHANGED (`env= env`), so the result is byte-identical to the old Value-only
// path: the threading is pure plumbing. (The C twin needs no analogue — its cell store is a global
// shared by pointer, so the write is already visible; this is the value-functional twin of that.)
type EvalRes = struct { value: Value; env: Venv }

// ev_val — evaluate an expression for its VALUE only, DISCARDING the threaded env. Sound ONLY where
// the expression cannot be (or contain, in an env-mutating position) a `Ref<T>` value-position call:
// the stdlib builtin arg slots (print/assert/str::*/fs::* — the checker forbids a `Ref<T>` there) and
// other pure-leaf reads. For non-ref code the env is unchanged anyway, so discarding it is a no-op
// (byte-identical). Never use this for a general operand that may carry a ref call — thread instead.
fn ev_val(e: checker::TExpr, env: Venv) -> Value {
    eval_expr(e, env).value
}

fn eval_expr(e: checker::TExpr, env: Venv) -> EvalRes {
    teko::cov_line(e.line)   // D3-line — mark this source line executed (no-op unless line recording is on)
    match e.type {
        // Optional `T?` values ARE supported now (OptVal — REBOOT_PLAN §202): null / ?. / ?? and
        // the present-wrap (coerce_to) produce them; they flow through the value model like any tag.
        checker::Void          => panic("vm: void expression has no value (internal: checker should reject in value position)")
        _             => {}   // a real value type — evaluate below
    }
    match e.kind {
        // Leaf reads — pure, env unchanged. (MEM Step 4: every non-call leaf threads `env` back as-is.)
        checker::TNumber as n   => EvalRes { value= num_of_prim(n, e.type); env= env }   // a concrete u8…i128 / f16…f64 from the node's type (float iff n.is_float)
        // (W10a) a bare top-level-fn reference used as a VALUE → a FuncVal (no captured env). A plain
        // local/param reads its bound value (cell-backed reads thread through the cell).
        checker::TVar as v      => if v.is_func { EvalRes { value= FuncVal { is_lambda= false; ns= v.func_ns; name= v.name; params= teko::list::empty(); body= teko::list::empty(); cap_names= teko::list::empty(); cap_vals= teko::list::empty() }; env= env } } else { EvalRes { value= read_var(env, v.name); env= env } }
        // (W10) a closure LITERAL → a FuncVal carrying its params/body + a SNAPSHOT of its captures
        // (read NOW from the enclosing scope; a RefVal snapshot shares the cell → by-ref mutation).
        checker::TLambda as lam => {
            mut cnames: []str = teko::list::empty()
            mut cvals: []Value = teko::list::empty()
            mut i = 0
            loop {
                if i >= lam.captures.len { break }
                cnames = teko::list::push(cnames, lam.captures[i].name)
                cvals = teko::list::push(cvals, read_var(env, lam.captures[i].name))
                i++
            }
            EvalRes { value= FuncVal { is_lambda= true; ns= ""; name= ""; params= lam.params; body= lam.body; cap_names= cnames; cap_vals= cvals }; env= env }
        }
        checker::TStrLit as s   => EvalRes { value= s.text; env= env }            // a `str` member of Value
        checker::TByteLit as b  => EvalRes { value= b.value; env= env }           // a `byte` member of Value
        checker::TCharLit as ch => EvalRes { value= ch.bytes; env= env }          // char — its UTF-8 bytes ride the `str` member (distinct by tag; VM==native)
        checker::TBoolLit as bl => EvalRes { value= bl.value; env= env }                  // bool literal (W2) — FULL: a `bool` member of Value
        checker::TBinary as b   => eval_binary(b, e.type, e.line, e.col, env)
        checker::TUnary as u    => eval_unary(u, e.type, env)
        checker::TCompare as c  => eval_compare(c, env)
        checker::TCast as c     => eval_cast(c, e.type, e.line, e.col, env)          // F3 narrowing guard inside (positioned — C1.6)
        checker::TCall as c     => eval_call(c, env)                                 // (MEM Step 4) value-position call — threads the callee's cells back
        checker::TStructInit as si  => eval_struct_init(si, e.type, env)   // W4b — build a struct value (declared field order)
        checker::TFieldAccess as fa => eval_field_access(fa, env)          // W4b — read a field by name from a struct value

        // W5a — `if` as a VALUE (nested in an expression): run it as control flow; yield the
        // taken branch's trailing value (NORMAL). A branch that DIVERGES (return/break/continue)
        // inside an `if` used as a SUB-expression can't be expressed as a value here — honest
        // stop (M.3); statement/tail position handles divergence via exec_if directly.
        checker::TIfExpr as _ => {
            let fe = exec_if(e, env)   // FlowEnv — the taken branch's cell writes ride fe.env
            match fe.flow {
                Normal as nm => EvalRes { value= nm.value ?? panic("vm: an `if` used as a value produced no value (internal: checker requires an `else` with a value)"); env= fe.env }
                _            => panic("vm: control flow inside an `if` used as a sub-expression not yet supported")
            }
        }
        // W5b — `match` as a VALUE: pattern matching (literal/range/Alt/variant-case/destructure + `when`).
        checker::TMatchExpr as m => eval_match(m, e.line, e.col, env)
        // W5-idx — subscript `recv[index]` (str→byte; slice→element, bounds-checked — SLICE layer).
        checker::TIndex as ix => eval_index(ix, e.line, e.col, env)
        // $"…{expr}…" — string interpolation: pieces ++ str(holes) (self-host parity).
        checker::TInterp as in => eval_interp(in, env)
        // Phase 2 — `<lhs> in [ … ]`: true iff lhs (single-eval) value_eq's any element.
        checker::TInExpr as ie => eval_in(ie, env)
        // Enum::Member as a VALUE → its ordinal (u64); the C twin's C enum auto-numbers identically.
        checker::TPathExpr as pe => EvalRes { value= pe.ordinal; env= env }
        // null / ?. / ?? — the OPTIONAL value model (OptVal — REBOOT_PLAN §202/§203).
        // null is NONE; the destination's wrap (coerce_to) makes it a concrete `T?`.
        checker::TNullLit            => EvalRes { value= OptVal { present = false; inner = null }; env= env }
        checker::TSafeFieldAccess as sfa => {
            // `recv?.field`: NONE → NONE; PRESENT → the inner's field, re-wrapped PRESENT.
            let re = eval_expr(sfa.receiver, env)   // thread the receiver's env (a ref call there grows cells)
            match re.value {
                OptVal as o => {
                    if !o.present { return EvalRes { value= OptVal { present = false; inner = null }; env= re.env } }
                    let inner = match o.inner { Value as iv => iv; null => return EvalRes { value= OptVal { present = false; inner = null }; env= re.env } }
                    // (W10b.CLASS residual — VM reference semantics) a class-typed optional's
                    // inner is a ClassRef (not a StructVal) — deref through the cell first.
                    let sv = match inner {
                        StructVal as s => s
                        ClassRef as cr => match cell_get(re.env.cells, cr.cell) {
                            StructVal as s => s
                            _ => panic("vm: a ClassRef cell must hold a StructVal (internal invariant)")
                        }
                        _ => panic("vm: safe field access on a non-struct optional (internal: checker should reject)")
                    }
                    mut i = 0
                    loop {
                        if i >= sv.field_names.len { break }
                        if sv.field_names[i] == sfa.field {
                            // result is `(field)?` — an already-optional field stays as-is.
                            match sv.field_vals[i] { OptVal as fo => return EvalRes { value= fo; env= re.env }; _ => return EvalRes { value= OptVal { present = true; inner = sv.field_vals[i] }; env= re.env } }
                        }
                        i++
                    }
                    panic("vm: field not found in safe field access (internal: the checker guarantees the field)")
                }
                _ => panic("vm: safe field access on a non-optional value (internal: checker should reject)")
            }
        }
        checker::TCoalesce as co  => {
            // `a ?? b`: a's inner if PRESENT, else b (short-circuit b). Both arms coerced to the
            // result type (the node's `.type`): `T? ?? T` unwraps, `T? ?? T?` stays optional.
            let le = eval_expr(co.left, env)   // thread the left operand's env
            match le.value {
                OptVal as o => {
                    if o.present {
                        let inner = match o.inner { Value as iv => iv; null => panic("vm: present optional with no inner (internal)") }
                        EvalRes { value= coerce_to(inner, e.type); env= le.env }
                    } else {
                        let re = eval_expr(co.right, le.env)   // short-circuit: only evaluated when absent; threads from le.env
                        EvalRes { value= coerce_to(re.value, e.type); env= re.env }
                    }
                }
                _ => panic("vm: coalesce left operand is not optional (internal: checker should reject)")
            }
        }
        // [ e0, e1, … ] (Increment B+) — build a `[]Value` (in a dedicated fn, like eval_in).
        checker::TArrayLit as a => eval_array_lit(a, e.type, env)
    }
}

// eval_array_lit — `[ e0, e1, … ]` -> a `[]Value`; each plain element is coerced into the slice's
// element type; each spread element (`..xs`) evaluates to a `[]Value` sub-slice and its items are
// individually appended (flattening the spread into the result slice at runtime).
fn eval_array_lit(a: checker::TArrayLit, slot: checker::Type, env: Venv) -> EvalRes {
    let elem_t = match slot { checker::Slice as s => s.element; _ => checker::Void { } }
    mut cur = env                       // (MEM Step 4) thread the env across each element's eval
    mut xs: []Value = teko::list::empty()
    mut i = 0
    loop {
        if i >= a.elements.len { break }
        let ae = a.elements[i]
        if ae.is_spread {
            // spread: ae.expr evaluates to a []Value; flatten its items individually into xs
            let se = eval_expr(ae.expr, cur)
            cur = se.env
            let sub_list = match se.value { []Value as lv => lv; _ => teko::list::empty() }
            mut j = 0
            loop {
                if j >= sub_list.len { break }
                xs = teko::list::push(xs, coerce_to(sub_list[j], elem_t))
                j = j + 1
            }
        } else {
            let ee = eval_expr(ae.expr, cur)
            cur = ee.env
            xs = teko::list::push(xs, coerce_to(ee.value, elem_t))
        }
        i = i + 1
    }
    EvalRes { value= xs; env= cur }
}

// coerce a Value into the declared slot type `t`: if `t` is `T?` and the value is NOT already an
// optional, wrap it PRESENT (the present-wrap — mirrors codegen's emit_as). A value that is
// already optional (NONE / PRESENT) passes through; a non-optional slot is a no-op. The VM twin
// of codegen's emit_as optional wrapping (REBOOT_PLAN §202).
fn coerce_to(v: Value, t: checker::Type) -> Value {
    match t {
        checker::Optional => {
            match v { OptVal => v; _ => OptVal { present = true; inner = v } }
        }
        // SLICE slot covariance (the VM twin of codegen's emit_as slice rebuild): a `[]U` value
        // flowing into a `[]T` slot REBUILDS element-wise, coerce_to-ing each element into T. The
        // recursion composes (an OPTIONAL element → present-wrap each element; same-type element → a
        // no-op copy). A sentinel element (`Void`) leaves the value untouched (no per-element type).
        checker::Slice as sl => match sl.element {
            checker::Void => v
            _ => match v {
                []Value as xs => {
                    mut out: []Value = teko::list::empty()
                    mut i = 0
                    loop {
                        if i >= xs.len { break }
                        out = teko::list::push(out, coerce_to(xs[i], sl.element))
                        i++
                    }
                    out
                }
                _ => v
            }
        }
        _ => v
    }
}

// num_prim_of — the EFFECTIVE numeric prim of a type endpoint: a Prim is itself; a `byte` is U8
// (B.36 — byte is a u8 newtype, the same effective kind the checker's cast_kind uses). Any other
// type (str/named/…) is the honest non-numeric frontier — a loud internal stop (M.3). Mirrors
// vm.c's `cast_prim_of` (which returns false there; here a non-numeric reaching arithmetic/cast
// is an invariant break the checker should have rejected, so we panic).
fn num_prim_of(t: checker::Type) -> checker::PrimKind {
    match t {
        checker::Prim as p => p.kind
        checker::Byte      => checker::PrimKind::U8
        checker::Named     => checker::PrimKind::U64  // E7: enum ordinal — checker validated; stored as u64
        _                  => panic("vm: arithmetic/cast on a non-numeric type not yet supported")
    }
}

// apply_int_op — the plain fixed-width integer ops (+,-,*,&,|,^,<<,>>) on the i128 carriers, the
// .tks twin of the +,-,*,&,|,^,<<,>> arm of vm.c's eval_binary (div/mod are handled by the caller
// through the CHECKED runtime helpers). Everything computes on the i128 carrier and the caller
// truncates via norm_int, so the carrier's extension is irrelevant for +,-,*,&,|,^,<< (only the
// low `width` bits survive). For `>>`, `as_int` already sign/zero-extended the operand to i128, so
// an arithmetic shift on that carrier reproduces both the signed (arithmetic) and unsigned
// (logical) C shift. Shift counts are masked `& 127` exactly like the C twin.
fn apply_int_op(op: lexer::TokenKind, l: i128, r: i128, sgn: bool, w: u8) -> i128 {
    match op {
        Plus  => l + r
        Minus => l - r
        Star  => l * r
        Amp   => l & r
        Pipe  => l | r
        Caret => l ^ r
        Shl   => l << (r & 127)
        Shr   => l >> (r & 127)
        _     => panic("vm: binary operator not yet supported")
    }
}

// eval_unary — `!x` / `-x` / `~x`, the .tks twin of vm.c's eval_unary. `!` negates a bool; `-`
// negates a numeric (float in the f64 carrier, int via norm_int at the node's prim); `~` flips an
// integer's bits (norm_int re-truncates). The node's `.type` (passed as `t`) selects the result
// prim, exactly as codegen's fixed-width C unary ops do.
fn eval_unary(u: checker::TUnary, t: checker::Type, env: Venv) -> EvalRes {
    let xe = eval_expr(u.operand, env)   // (MEM Step 4) thread the operand's env
    let x = xe.value
    let cur = xe.env
    let v = match u.op {
        Bang  => !as_bool(x)
        Minus => {
            let prim = num_prim_of(t)
            if prim_float(prim) {
                float_val(-as_float(x), prim_width(prim))
            } else {
                norm_int(-as_int(x), prim_signed(prim), prim_width(prim))
            }
        }
        Tilde => {
            let prim = num_prim_of(t)
            norm_int(~as_int(x), prim_signed(prim), prim_width(prim))
        }
        _ => panic("vm: unary operator not yet supported")
    }
    EvalRes { value= v; env= cur }
}

// cmp_pair — one adjacent comparison `l <op> r`, the .tks twin of vm.c's cmp_pair. INT compares on
// the i128 carriers (sign comes from the operand's member — checker-typed, operands share sign);
// FLOAT compares in f64 (IEEE, matching codegen's double ops); BOOL compares ==/!= only. Codegen
// lowers a chain to `&&` of these pairs (see eval_compare).
fn cmp_pair(l: Value, op: lexer::TokenKind, r: Value) -> bool {
    // `byte` IS the u8 representation (vm.c: "byte == u8 rep") — it compares NUMERICALLY with bytes
    // AND ints. Fold byte into the integer path: e.g. an out-of-bounds `at()` returns the int literal
    // `0` (not coerced to byte by the checker), which then compares against a byte literal — both must
    // be read as numbers (as_int handles byte). Without this a byte-vs-int compare fell to as_bool.
    let l_num = val_is_int(l) || val_is_byte(l)
    let r_num = val_is_int(r) || val_is_byte(r)
    if l_num && r_num {
        let a = as_int(l); let b = as_int(r)
        match op {
            EqEq => a == b
            Ne   => a != b
            Lt   => a < b
            Le   => a <= b
            Gt   => a > b
            Ge   => a >= b
            _    => panic("vm: comparison operator not yet supported")
        }
    } else if val_is_float(l) && val_is_float(r) {
        let a = as_float(l); let b = as_float(r)
        match op {
            EqEq => a == b
            Ne   => a != b
            Lt   => a < b
            Le   => a <= b
            Gt   => a > b
            Ge   => a >= b
            _    => panic("vm: comparison operator not yet supported")
        }
    } else {
        // str (byte-equality, the lexer/parser tests compare token text), else bool (==/!= only).
        match l {
            str as ls => match r {
                str as rs => match op {
                    EqEq => ls == rs
                    Ne   => !(ls == rs)
                    _    => panic("vm: ordered comparison on str not supported")
                }
                _ => panic("vm: comparing a str to a non-str (checker should reject)")
            }
            _ => {
                let a = as_bool(l); let b = as_bool(r)
                match op {
                    EqEq => a == b
                    Ne   => a != b
                    _    => panic("vm: ordered comparison on bool not yet supported")
                }
            }
        }
    }
}

// eval_compare — a comparison chain `first (op operand)*`, the .tks twin of vm.c's eval_compare.
// A degenerate chain (no rest terms) is just `first` (matches codegen). Otherwise codegen lowers
// `a<b<c` to AND over adjacent pairs; we fold left, re-using each operand's value once (operands
// are checker-pure leaves in M0, so the value-equivalence to codegen's twice-emitted form holds).
fn eval_compare(c: checker::TCompare, env: Venv) -> EvalRes {
    if c.rest.len == 0 { return eval_expr(c.first, env) }   // degenerate (matches codegen) — threads its own env
    let fe = eval_expr(c.first, env)   // (MEM Step 4) thread the env left-to-right across operands
    mut prev = fe.value
    mut cur = fe.env
    mut acc = true
    mut i = 0
    loop {
        if i >= c.rest.len { break }
        let term = c.rest[i]
        let re = eval_expr(term.operand, cur)
        cur = re.env
        acc = acc && cmp_pair(prev, term.op, re.value)
        prev = re.value
        i++
    }
    EvalRes { value= acc; env= cur }
}

// find_function — resolve a user call by its callee Path, the .tks twin of vm.c's find_function.
// The C twin scans a file-global `g_prog`; here the typed program rides the env (M.0 — no mutable
// globals), so we scan `env.prog.items`. Match by the LAST path segment (a cross-namespace call
// `ns::fn` qualifies; the seed resolves names by last segment, like resolve_named for types).
//
// A miss is the HOST-FFI FRONTIER, not a checker bug. The checker accepts host-FFI/builtin calls
// (scope.tks builtin_fn — read_file/list_dir/run/env::*/…) because the NATIVE backend lowers them
// to runtime primitives; the VM has no host surface (that is Phase 7's C2* work). So a callee that
// is neither a VM builtin (try_builtin/try_list_builtin) nor a user function is a host call the VM
// cannot run. Stop HONESTLY, naming it and pointing at `teko build` — never the misleading
// "internal: checker should reject" (M.1 fail-loud, M.3 honest frontier).
// FnHit — a resolved function PLUS its `prog.items` index (a globally-unique coverage ID). The C
// twin returns the index via an out-param (`find_function(p, &fn_idx)`); Teko has no out-params, so
// the pair rides a struct. Using the ITEM INDEX (not f.line) for cov_mark avoids cross-FILE line
// collisions (two functions at the same line in different files would otherwise share one ID).
//
// BUGFIX (VM name-resolution / cross-namespace collision — mirrors vm.c's find_function_ns): a
// bare last-segment match, with NO namespace disambiguation, silently resolves to the WRONG
// function whenever two DIFFERENT namespaces declare a same-named fn (e.g. two modules each
// define their own `parse_atom`, with different arities/signatures) — the FIRST same-named fn
// anywhere in program-item order wins, corrupting the call regardless of which module the caller
// actually meant; this bled into completely unrelated tests once such a collision entered the
// corpus. The checker already resolves the call-site's target namespace (TCall.call_ns) — honor
// it: when `call_ns` is non-empty, prefer an exact (namespace, name) match, falling back to the
// old last-segment-anywhere scan when call_ns is empty (a local/unqualified/builtin call has no
// namespace to disambiguate) or no such namespaced function exists (defensive — never turns a
// previously-resolvable call into a failure).
type FnHit = struct { func: checker::TFunction; idx: u64 }
fn find_function_ns(env: Venv, callee: parser::Path, call_ns: str) -> FnHit {
    let name = callee.segments[callee.segments.len - 1].name
    if call_ns.len > 0 {
        mut j: u64 = 0
        loop {
            if j >= env.prog.items.len { break }
            match env.prog.items[j] {
                checker::TFunction as f => { if f.namespace == call_ns && f.name == name { return FnHit { func = f; idx = j } } }
                _              => {}
            }
            j++
        }
    }
    mut i = 0
    loop {
        if i >= env.prog.items.len { break }
        match env.prog.items[i] {
            checker::TFunction as f => { if f.name == name { return FnHit { func = f; idx = i to u64 } } }
            _              => {}
        }
        i++
    }
    panic(teko::str::concat("vm: `", name, "` is a host function the VM cannot run (use `teko build` to compile natively)"))
}
// find_function — the no-namespace-hint convenience form (call_ns unknown/inapplicable): behaves
// exactly like the OLD last-segment-anywhere scan.
fn find_function(env: Venv, callee: parser::Path) -> FnHit {
    find_function_ns(env, callee, "")
}

// mutate_slot — a compound/plain assignment to the NEWEST slot named `name`, the .tks twin of
// vm.c's TK_TSTMT_ASSIGN compound-assign body. The C twin mutates the slot in place; the .tks env
// is IMMUTABLE, so this rebuilds `env.slots` with that one slot replaced and returns the grown
// env (functional, like define). A plain `=` stores the rhs; a compound `+=`/…/`>>=` applies the
// int op at the slot's own width/signedness via apply_int_op + norm_int (div/mod route through the
// CHECKED runtime so ÷0 panics, mirroring the C; the caller already positioned the ÷0 locator).
fn mutate_slot(env: Venv, name: str, op: lexer::TokenKind, rhs: Value) -> Venv {
    // find the NEWEST slot named `name` (newest-first, like `find`); the checker guarantees it binds.
    mut idx = env.slots.len
    mut found = false
    loop {
        if idx == 0 { break }
        idx--
        if env.slots[idx].name == name { found = true; break }
    }
    if !found { panic("vm: assignment to an unbound variable (internal: checker should reject)") }
    // (MEM Step 2/3) a cell-backed slot's value lives in the cell store, not in slot.val — read the
    // OLD value from the cell so a compound op operates on the aliased storage, and write the result
    // BACK to the cell (the slot stays cell-backed). A plain slot reads/writes slot.val as before.
    let backing = env.slots[idx].cell_id
    let old = match backing { u64 as cid => cell_get(env.cells, cid); null => env.slots[idx].val }
    let newval = compound_apply(old, op, rhs)
    match backing {
        u64 as cid => {
            // write through the cell; the slot list is unchanged (it still points at the cell).
            return Venv { slots= env.slots; prog= env.prog; defers= env.defers; cells= cell_set(env.cells, cid, newval) }
        }
        null => {}
    }
    // rebuild the slots, replacing the one at `idx` with the new value (functional update).
    mut rebuilt: []Slot = teko::list::empty()
    mut j = 0
    loop {
        if j >= env.slots.len { break }
        if j == idx { rebuilt = teko::list::push(rebuilt, Slot { name= name; val= newval; cell_id= null }) }
        else        { rebuilt = teko::list::push(rebuilt, env.slots[j]) }
        j++
    }
    Venv { slots= rebuilt; prog= env.prog; defers= env.defers; cells= env.cells }
}

// compound_apply — apply an assignment operator to `old` with `rhs`: a plain `=` stores rhs; a
// compound op applies the int op at `old`'s own width/signedness (M0 — ints only; div/mod route
// through the CHECKED runtime so ÷0 panics). Factored out so both a plain-slot and a cell-backed
// assignment (and the `.value op= …` deref path) share the SAME arithmetic.
fn compound_apply(old: Value, op: lexer::TokenKind, rhs: Value) -> Value {
    match op {
        Assign => rhs
        _      => {
            let sgn = int_sign_of(old); let w = int_width_of(old)
            let a = as_int(old); let b = as_int(rhs)
            match op {
                SlashEq   => norm_int(teko::div(a, b, sgn), sgn, w)   // CHECKED: ÷0 panics
                PercentEq => norm_int(teko::rem(a, b, sgn), sgn, w)   // CHECKED: %0 panics
                PlusEq    => norm_int(apply_int_op(lexer::TokenKind::Plus,  a, b, sgn, w), sgn, w)
                MinusEq   => norm_int(apply_int_op(lexer::TokenKind::Minus, a, b, sgn, w), sgn, w)
                StarEq    => norm_int(apply_int_op(lexer::TokenKind::Star,  a, b, sgn, w), sgn, w)
                AmpEq     => norm_int(apply_int_op(lexer::TokenKind::Amp,   a, b, sgn, w), sgn, w)
                PipeEq    => norm_int(apply_int_op(lexer::TokenKind::Pipe,  a, b, sgn, w), sgn, w)
                CaretEq   => norm_int(apply_int_op(lexer::TokenKind::Caret, a, b, sgn, w), sgn, w)
                ShlEq     => norm_int(apply_int_op(lexer::TokenKind::Shl,   a, b, sgn, w), sgn, w)
                ShrEq     => norm_int(apply_int_op(lexer::TokenKind::Shr,   a, b, sgn, w), sgn, w)
                _         => panic("vm: assignment operator not yet supported")
            }
        }
    }
}

// exit_code_of — the process exit code from the virtual-main's final value, the .tks twin of
// vm.c's run-tail extraction: an int Value -> its value as i32 (mask the low 32 bits then cast,
// matching the C `(int)(int64_t)`); a bool -> 1/0; anything else (incl null) -> 0.
fn exit_code_of(v: Value?) -> i32 {
    match v {
        Value as val => {
            if val_is_int(val) {
                let raw = as_int(val) & 0xFFFFFFFF
                if raw >= 0x80000000 { (raw - 0x100000000) to i32 } else { raw to i32 }
            } else {
                match val { bool as b => if b { 1 to i32 } else { 0 to i32 }; _ => 0 to i32 }
            }
        }
        null => 0 to i32
    }
}

// eval_binary — numeric arithmetic at the node's result prim (width/signedness/float-kind
// from the node's type, exactly as codegen selects tk_div_<width> / fixed-width C ops).
// Logical &&/|| short-circuit on bool. INT `/` and `%` route through the runtime's CHECKED
// div/mod so a zero divisor PANICS "division by zero" (M.1). FLOAT + - * / honestly in
// `f64` (the VM-debug carrier for all float widths); float ÷0 PANICS too (plan §5, same as
// int). `%` / bitwise / shift on a float is honest-unsupported (the checker rejects them).
fn eval_binary(b: checker::TBinary, ty: checker::Type, line: u32, col: u32, env: Venv) -> EvalRes {
    if b.op == lexer::TokenKind::AndAnd || b.op == lexer::TokenKind::OrOr {
        let le = eval_expr(b.left, env)   // (MEM Step 4) thread left, then SHORT-CIRCUIT right
        let l = as_bool(le.value)
        if b.op == lexer::TokenKind::AndAnd && !l { return EvalRes { value= false; env= le.env } }
        if b.op == lexer::TokenKind::OrOr  &&  l { return EvalRes { value= true; env= le.env } }
        let re = eval_expr(b.right, le.env)
        return EvalRes { value= as_bool(re.value); env= re.env }
    }
    let prim = num_prim_of(ty)                 // honest stop if non-numeric (mirrors codegen)
    if prim_float(prim) {
        let w  = prim_width(prim)
        let le = eval_expr(b.left, env); let re = eval_expr(b.right, le.env)   // thread left→right
        let lf = as_float(le.value); let rf = as_float(re.value)
        let cur = re.env
        let fv = match b.op {
            Plus    => float_val(lf + rf, w)
            Minus   => float_val(lf - rf, w)
            Star    => float_val(lf * rf, w)
            // C1.6 — POSITION the float ÷0 panic at THIS node before the runtime helper fires.
            Slash   => { if rf == 0.0 { vm_panic_div0_at(line, col) }; float_val(teko::fdiv(lf, rf), w) }   // CHECKED: float ÷0 PANICS (M.1)
            Percent => panic("vm: '%' on a float value not supported (checker should reject)")
            _       => panic("vm: bitwise/shift on a float value not supported (checker should reject)")
        }
        return EvalRes { value= fv; env= cur }
    }
    let sgn  = prim_signed(prim); let w = prim_width(prim)
    let le = eval_expr(b.left, env); let re = eval_expr(b.right, le.env)   // thread left→right
    let l = as_int(le.value); let r = as_int(re.value)
    let cur = re.env
    // C1.6 — POSITION the int ÷0 / %0 panic at THIS node before the runtime helper fires (the
    // runtime div/rem still panic as the canonical message — M.1).
    let iv = match b.op {
        Slash   => { if r == 0 { vm_panic_div0_at(line, col) }; norm_int(teko::div(l, r, sgn), sgn, w) }   // CHECKED: panics on /0
        Percent => { if r == 0 { vm_panic_div0_at(line, col) }; norm_int(teko::rem(l, r, sgn), sgn, w) }   // CHECKED: panics on %0
        // +,-,*,&,|,^,<<,>>: plain fixed-width arithmetic. Overflow guarding for +,-,* is
        // DEFERRED to build profiles (panic-debug / wrap-release) — exactly as codegen
        // leaves +,-,* as plain C. norm_int truncates to the prim's width.
        _       => norm_int(apply_int_op(b.op, l, r, sgn, w), sgn, w)
    }
    EvalRes { value= iv; env= cur }
}

// vm_char_to_u32 — decode a char Value (its UTF-8 bytes ride the `str` member) to its scalar
// codepoint. Mirrors the native runtime tk_char_to_u32 (a lead+continuation decode; the bytes are
// valid UTF-8 by construction — the lexer validated the literal). A 0-length char never occurs.
fn vm_char_to_u32(v: Value) -> u32 {
    match v {
        str as s => {
            if s.len == 0 { return 0 }
            let b0 = s[0]
            let u0 = b0 to u32
            if b0 <= 0x7F { return u0 }
            if s.len == 2 {
                let u1 = s[1] to u32
                return ((u0 & 0x1F) << 6) | (u1 & 0x3F)
            }
            if s.len == 3 {
                let u1 = s[1] to u32
                let u2 = s[2] to u32
                return ((u0 & 0x0F) << 12) | ((u1 & 0x3F) << 6) | (u2 & 0x3F)
            }
            let u1 = s[1] to u32
            let u2 = s[2] to u32
            let u3 = s[3] to u32
            ((u0 & 0x07) << 18) | ((u1 & 0x3F) << 12) | ((u2 & 0x3F) << 6) | (u3 & 0x3F)
        }
        _ => panic("vm: char-decode on a non-str value (internal: char rides the str carrier)")
    }
}

// eval_cast — `x to T` over the Tier-1 numeric set (plan §5). Four cases:
//   * float->float: a plain reinterpret at the dest width (rounding noted).
//   * int->float:   every in-range int is representable in the VM-debug `f64` carrier.
//   * float->int:   TRUNCATE toward zero; NaN / ±∞ / out-of-range -> PANIC "impossible
//                   conversion" (plan §5, parity with the integer cast guard, M.1).
//   * int->int:     codegen's guard predicate — cast_may_lose -> CHECKED conversion
//                   (PANIC out of range); else a plain reinterpret to the target width.
fn eval_cast(c: checker::TCast, ty: checker::Type, line: u32, col: u32, env: Venv) -> EvalRes {
    // num_prim_of maps a cast endpoint to its effective numeric prim: a Prim is itself, a
    // `byte` is U8 (B.36 — byte is a u8 newtype), so `s[i] to i32` (a byte source — W5-idx)
    // casts as u8->i32. Any other type (str/named/…) is the honest non-numeric cast frontier.
    let xe = eval_expr(c.expr, env)   // (MEM Step 4) thread the operand's env once
    let cur = xe.env
    // (W10b.CLASS residual — VM reference semantics) the base-binding's synthetic `self to Base`
    // cast (typer.tks::type_method, the `class Base(binding) { … }` feature) is a same-storage
    // REINTERPRET, not a numeric conversion — mirrors the native engine's plain C pointer cast
    // (`(tk_t_Base *)(self)`), which is a no-op at the value level (field-flattening already lays
    // the base's fields out as a PREFIX of the derived struct, so field-by-NAME lookup on the SAME
    // StructVal/cell already resolves correctly under either type). Any Named-to-Named cast is
    // this identity pass-through — the checker only ever builds one for this exact feature.
    match c.expr.type {
        Named => match ty { Named => return EvalRes { value= xe.value; env= cur }; _ => {} }
        _ => {}
    }
    // (UTF-8 increment 1) `char to u32`/u64/i64 — DECODE the codepoint (its UTF-8 bytes, carried as
    // the `str` Value) to its scalar value, normalized to the target int. Mirrors tk_char_to_u32 (the
    // native runtime helper) and codegen's char-cast branch (VM==native). The checker restricted the
    // target, so the decoded codepoint always fits.
    match c.expr.type {
        checker::Char => {
            let dtgt = num_prim_of(ty)
            let cp = vm_char_to_u32(xe.value)
            return EvalRes { value= norm_int(cp to i128, prim_signed(dtgt), prim_width(dtgt)); env= cur }
        }
        _ => {}
    }
    let dst = num_prim_of(ty); let src = num_prim_of(c.expr.type)
    let sflt = prim_float(src); let dflt = prim_float(dst)
    if sflt && dflt {
        return EvalRes { value= float_val(as_float(xe.value), prim_width(dst)); env= cur }
    }
    if !sflt && dflt {
        return EvalRes { value= float_val(teko::int_to_float(as_int(xe.value), prim_signed(src)), prim_width(dst)); env= cur }
    }
    if sflt && !dflt {
        // C1.6 — truncate toward zero; NaN / ±∞ / out-of-range PANIC "impossible conversion",
        // POSITIONED at this node (vm_float_to_int re-derives the runtime check inline so it can
        // prefix line:col before the canonical panic — M.1).
        return EvalRes { value= norm_int(vm_float_to_int(as_float(xe.value), dst, line, col), prim_signed(dst), prim_width(dst)); env= cur }
    }
    let v = as_int(xe.value)
    // C1.6 — int->int narrowing PANIC positioned at this node (vm_cast re-derives the runtime
    // range check inline so it can prefix line:col before the canonical panic — M.1).
    if cast_may_lose(src, dst) { return EvalRes { value= norm_int(vm_cast(v, src, dst, line, col), prim_signed(dst), prim_width(dst)); env= cur } }
    EvalRes { value= norm_int(v, prim_signed(dst), prim_width(dst)); env= cur }
}

// eval_call — builtins first (print/println/assert — all `-> void`, run for effect, no
// Value). If it WAS a builtin, the call is a void statement and produces no Value here
// (the caller is the statement context). Else a user fn resolved by its path's LAST segment
// (W5a — a cross-namespace `ns::fn` resolves). M0 fns take NO params (codegen rejects params)
// -> honest frontier. A fresh root env (no capture). W5a — the call's value comes from an
// explicit `return e` OR (NORMAL) the body's TRAILING value (B.20 — implicit return); a
// `-> void` fn (or one that falls off the end without a value) produces NO Value: the call is
// a statement whose result is discarded — there is no `Unit`.
// (MEM Step 2/3) param_is_ref — does parameter `i` of `f` have a `Ref<T>` annotation (last path
// segment "Ref")? The same surface-syntax detection codegen and the escape-gate use; `Ref<T>` is the
// user surface for a Reference. Used to drive auto-ref at a call and to gate the value-position path.
fn param_is_ref(f: checker::TFunction, i: u64) -> bool {
    match f.params[i].type_ann {
        parser::NamedType as nt => nt.path.segments[nt.path.segments.len - 1].name == "Ref"
        _                       => false
    }
}
fn fn_has_ref_param(f: checker::TFunction) -> bool {
    mut i: u64 = 0
    loop {
        if i >= f.params.len { break }
        if param_is_ref(f, i) { return true }
        i = i + 1
    }
    false
}

// (MEM Step 2/3) BoundArgs — the result of binding a call's arguments: the callee frame `fenv`
// (args bound positionally, the callee inheriting the caller's cells so RefVal indices stay valid)
// AND the (possibly mutated) CALLER env — auto-ref PROMOTES a `mut` lvalue arg to a cell, growing
// the caller's cell store and rebinding the origin slot, so that env must thread back to the caller.
type BoundArgs = struct { fenv: Venv; caller: Venv }

// bind_call_args — bind `f`'s parameters to `c`'s arguments in a fresh callee frame. For a `Ref<T>`
// parameter the checker guarantees the argument is either a `mut` scalar lvalue (a TVar — AUTO-REF:
// promote it to a cell, pass RefVal{cell}) or a value already of reference type (FORWARD: a RefVal
// from a ref param read — pass it through). All other params bind by value (eval_expr). The caller
// env is threaded through promotion (cell store grows + origin slot rebinds), so it is returned too.
fn bind_call_args(f: checker::TFunction, c: checker::TCall, env: Venv) -> BoundArgs {
    mut caller = env
    mut fenv = fresh_env(env.prog, env.cells)
    mut ai: u64 = 0
    loop {
        if ai >= f.params.len { break }
        mut argval: Value? = null
        if param_is_ref(f, ai) {
            // a `Ref<T>` param: AUTO-REF a `mut` lvalue (TVar) — promote it to a cell and pass the
            // RefVal; FORWARD an arg that already evaluates to a RefVal (a forwarded ref param).
            match c.args[ai].kind {
                checker::TVar as v => {
                    // could be the origin var (auto-ref) OR a `Ref<T>` param being forwarded. The
                    // checker types a Ref-typed arg as Reference, an auto-ref arg as the pointed T.
                    match c.args[ai].type {
                        checker::Reference => argval = read_var(caller, v.name)   // forward the existing RefVal
                        _                  => {
                            let p = promote_to_cell(caller, v.name)              // auto-ref: promote the origin var
                            caller = p.env
                            fenv = with_cells(fenv, caller.cells)                // keep the callee's cells in sync with the grown store
                            argval = RefVal { cell= p.id }
                        }
                    }
                }
                _ => panic("vm: a `Ref<T>` argument must be a mutable variable (internal: checker should reject)")
            }
        } else {
            // (MEM Step 4) a non-ref arg may ITSELF be a value-position ref call (`f(bump(x))`);
            // thread the caller env across it so that nested ref write survives into the caller.
            let ae = eval_expr(c.args[ai], caller)
            caller = ae.env
            fenv = with_cells(fenv, caller.cells)   // keep the callee frame's cells in sync with the grown store
            argval = ae.value
        }
        // Present-wrap a bare `T` arg into a `T?` param (uniform with field/return — the VM twin of
        // codegen's call-arg emit_as). coerce_to reads only the type tag: an OptionalType param →
        // Optional triggers the present-wrap; coerce_to no-ops on an already-optional value (no
        // double-wrap) and on every non-optional param. (Mirrors vm_field_coerce_type's shape.)
        let pcoerce = vm_param_coerce_type(f.params[ai].type_ann)
        fenv = define(fenv, f.params[ai].name, coerce_to(argval ?? panic("vm: argument produced no value (internal)"), pcoerce))
        ai = ai + 1
    }
    BoundArgs { fenv= fenv; caller= caller }
}

// (W10) invoke a closure LITERAL value: bind its params to the evaluated args in a fresh frame, bind
// its captured snapshot, exec the body, and yield the trailing/returned value. A captured RefVal
// shares its cell, so a `Ref<T>` capture's writes are visible at the caller (cells threaded back).
fn eval_lambda_call(fv: FuncVal, c: checker::TCall, env: Venv) -> EvalRes {
    mut caller = env
    mut fenv = fresh_env(env.prog, env.cells)
    mut ai: u64 = 0
    loop {
        if ai >= fv.params.len { break }
        let ae = eval_expr(c.args[ai], caller)
        caller = ae.env
        fenv = with_cells(fenv, caller.cells)
        fenv = define(fenv, fv.params[ai].name, ae.value)
        ai = ai + 1
    }
    mut ci: u64 = 0
    loop {
        if ci >= fv.cap_names.len { break }
        fenv = define(fenv, fv.cap_names[ci], fv.cap_vals[ci])
        ci = ci + 1
    }
    let fe = exec_block_ex(fv.body, fenv, true)
    caller = with_cells(caller, fe.env.cells)
    let rv = match fe.flow {
        VmReturn as ret => ret.value ?? panic("vm: void closure call used as a value (internal: checker should reject)")
        Normal as nm    => nm.value ?? panic("vm: void closure call used as a value (internal: checker should reject)")
        _               => panic("vm: void closure call used as a value (internal: checker should reject)")
    }
    EvalRes { value= rv; env= caller }
}

fn eval_call(c: checker::TCall, env: Venv) -> EvalRes {
    // A builtin that RAN (`true`) is `-> void`, so there is no Value to yield: a void call
    // only appears in statement position, and reaching here in value position is an honest
    // stop (M.3), never a synthesized Unit. A `false`/`error` result == "not a builtin" —
    // fall through to a user fn. Builtins take no `Ref<T>` args → the env is unchanged.
    match try_builtin(c.callee, c.args, env) {
        bool as ran => if ran { panic("vm: void builtin call used as a value (internal: checker should reject)") }
        error       => {}                  // not a builtin — fall through to a user fn
    }
    // teko::list::empty / push — value-producing SLICE builtins (FIXED+COPY). Recognized
    // before user-fn resolution; null == not a list builtin, fall through.
    match try_list_builtin(c.callee, c.args, env) { Value as v => return EvalRes { value= v; env= env }; null => {} }
    // E2 — err_loc / err_typed — value-producing error-adornment builtins. Recognized before
    // user-fn resolution; null == not an err builtin, fall through.
    match try_err_builtin(c.callee, c.args, env) { Value as v => return EvalRes { value= v; env= env }; null => {} }
    // str/byte STDLIB — value-producing str-returning builtins (str/str_of_bytes/one_byte/
    // str_concat3/ftoa). Recognized before user-fn resolution; null == not a str builtin, fall through.
    match try_str_builtin(c.callee, c.args, env) { Value as v => return EvalRes { value= v; env= env }; null => {} }
    // teko::fs::* host-surface builtins (list_dir). Recognized before user-fn resolution;
    // null == not a fs builtin, fall through. (Mirrors vm.c's list_dir handler.)
    match try_fs_builtin(c.callee, c.args, env) { Value as v => return EvalRes { value= v; env= env }; null => {} }
    // (W10) a CLOSURE call: the callee is a LOCAL bound to a FuncVal. A LAMBDA value executes its own
    // body+captures (eval_lambda_call); a NAMED-fn value resolves THAT function and invokes it (W10a).
    if c.is_closure_call {
        match read_var(env, c.callee.segments[c.callee.segments.len - 1].name) {
            FuncVal as fv => if fv.is_lambda { return eval_lambda_call(fv, c, env) } else { }
            _ => { }
        }
    }
    let h = if c.is_closure_call {
        match read_var(env, c.callee.segments[c.callee.segments.len - 1].name) {
            FuncVal as fv => find_function_ns(env, parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = fv.name }) }, fv.ns)
            _ => panic("vm: closure call on a non-function value (internal: checker should reject)")
        }
    } else {
        find_function_ns(env, c.callee, c.call_ns)   // namespace-disambiguated (BUGFIX); honest stop if unknown
    }
    let f = h.func
    // C7.1a — an `extern` is a foreign C function with NO Teko body; the tree-walking VM has no
    // FFI surface (the same deferred host edge as the io/fs bottoms). Stop HONESTLY (M.3), never
    // synthesize a value, and point at the native path.
    if f.is_extern { panic("vm: an `extern` function cannot run in the VM (foreign C call) — use `teko build` to compile it natively (C7.1a)") }
    // (MEM Step 4) A `Ref<T>` call in VALUE position mutates an ALIASED caller cell; that mutation
    // threads BACK into the caller env via EvalRes.env (the env-return channel eval_expr now carries):
    // bind_call_args auto-refs the caller's `mut` lvalue (growing/rebinding the caller env) and the
    // callee inherits + grows the cell store; we MERGE the callee's final cells back into the caller
    // (with_cells), exactly as call_value does in statement position. So a value-position ref call runs
    // == native — no honest stop. (The C twin needs no merge: its cell store is a global shared by
    // pointer, so the write is already visible; this is the value-functional twin of that effect.)
    if !f.is_test { teko::cov_mark(h.idx) }   // D3 — globally-unique items index (not line) avoids cross-file collisions
    // Bind each parameter to its evaluated argument in a FRESH root frame (no closure capture —
    // flat M0 functions, like codegen's C). Args evaluate in the CALLER's env (auto-ref promotion may
    // grow it), then enter the callee's frame by the param's name (positional). (B-vm — VM params.)
    let bound = bind_call_args(f, c, env)
    let fenv = bound.fenv
    mut caller = bound.caller   // post-binding caller env (auto-ref promotion may have grown its cells)
    // Coerce the returned value into the declared return type: a `T` from a `-> T?` fn
    // present-wraps (REBOOT §202), mirroring codegen's emit_as on the return slot.
    // D3-branch: push h.idx so branches inside f.body attribute to THIS fn (no-op unless coverage on).
    teko::cov_enter(h.idx)
    // (W9.3 part 2) is_fn_body=true: the body's trailing value-expr fires the body's defers BEFORE it
    // is evaluated, mirroring native (emit_block_tail -> emit_exprstmt_tail drains base-0 defers first).
    let fe = exec_block_ex(f.body, fenv, true)
    teko::cov_leave()
    // (W9.3) The fn-body exec_block is itself a defer scope and already drained the body's own defers
    // at its exit; the caller's defers live in the caller env (not threaded into fenv), so they stay
    // isolated. No separate drain here. Panic still does NOT drain (it aborts).
    // (MEM Step 4) MERGE the callee's final cells back into the caller — a `r.value = …` write in the
    // callee (through an auto-ref'd arg) is then visible at the caller's aliased var. For a non-ref call
    // the callee only inherited the caller's cells unchanged, so this is a no-op (byte-identical).
    caller = with_cells(caller, fe.env.cells)
    let fl = fe.flow
    let rv = match fl {
        VmReturn as ret => coerce_to(ret.value ?? panic("vm: void fn call used as a value (internal: checker should reject)"), f.return_type)
        Normal as nm  => coerce_to(nm.value ?? panic("vm: void fn call used as a value (internal: checker should reject)"), f.return_type)  // W5a — implicit trailing value (B.20)
        _             => panic("vm: void fn call used as a value (internal: checker should reject)")
    }
    EvalRes { value= rv; env= caller }
}

// ---------------------------------------------------------------------------
// STATEMENTS / BLOCKS. Coverage MIRRORS codegen's emit_stmt: Binding, Assign, VmReturn,
// ExprStmt, Loop, Break, Continue. A non-local Flow short-circuits the block.
// ---------------------------------------------------------------------------
// W5a — exec_block now YIELDS THE TRAILING VALUE: it returns the LAST statement's NORMAL flow
// (keeping its value), so a block's last expression becomes the block's value (B.20). Mirrors
// the C `tk_vm_exec_block` returning the last statement's flow. A non-local exit short-circuits.
// (W9.3) exec_block is a SCOPE-DEFER frame: defers registered inside it fire at the block's exit
// (LIFO), BEFORE control leaves it — per-iteration for a loop body, per-arm for an if/match arm,
// per-call for a fn body. `base` is this scope's defer base; on EVERY exit edge (fall-through OR a
// non-local Exit) we drain the defers pushed on top of `base` (innermost first) and pop them. A
// non-local flow still fires THIS block's defers first, then propagates outward where each crossed
// exec_block fires its own — innermost-block-first unwind.
fn exec_block(body: []checker::TStatement, env: Venv) -> FlowEnv {
    exec_block_ex(body, env, false)
}

// (W9.3 part 2) `is_fn_body` marks the FUNCTION-BODY scope: its trailing value-carrying expr-statement
// is treated like `return <expr>` for ordering — the body's defers fire BEFORE the trailing expr is
// evaluated (mirroring codegen's emit_block_tail -> emit_exprstmt_tail: emit_defers(base 0) BEFORE the
// implicit trailing `return`). Inner scopes (loop body, statement-position arm) discard their trailing
// value, so they keep the original "run all statements, THEN drain" order — unchanged, already matches.
fn exec_block_ex(body: []checker::TStatement, env: Venv, is_fn_body: bool) -> FlowEnv {
    let base = env.defers.len     // (W9.3) this scope's defer base
    mut e = env
    mut last: Value? = null      // the last NORMAL step's value — the block's trailing value (B.20)
    mut i = 0
    loop {
        if i >= body.len { break }
        // (W9.3 part 2) Function-body TRAILING value: if the last statement is a value-carrying
        // expr-statement (not an `if`/`match` taken as control flow — those self-route), fire this
        // body's defers FIRST, then evaluate it as the return value. Matches native ordering.
        let is_last = i + 1 == body.len
        mut is_fn_tail = false
        if is_fn_body { if is_last { if is_plain_expr_stmt(body[i]) { is_fn_tail = true } } }
        if is_fn_tail {
            let de = drain_defers_to(e, base)   // fire the body's defers BEFORE the trailing expr
            match exec_stmt(body[i], de) {
                Stepped as st => return FlowEnv { flow= Normal { value= st.value }; env= st.env }
                Exit as ex    => return FlowEnv { flow= ex.flow; env= drain_defers_to(ex.env, base) }
            }
        }
        match exec_stmt(body[i], e) {
            // A NORMAL step threads the env forward AND keeps its value as the block's trailing value.
            Stepped as st => { e = st.env; last = st.value }
            // VmReturn / Break / Continue escape — carry the env AT THE EXIT so mutations before it
            // survive. (W9.3) Fire THIS block's defers FIRST, then propagate the flow outward.
            Exit as ex    => return FlowEnv { flow= ex.flow; env= drain_defers_to(ex.env, base) }
        }
        i++
    }
    // (W9.3) normal fall-through: fire THIS block's defers LIFO, then thread the drained env out.
    FlowEnv { flow= Normal { value= last }; env= drain_defers_to(e, base) }
}

// (W9.3 part 2) Is this statement a plain value-carrying expr-statement (NOT an `if`/`match`, which
// run as control flow and self-route their own scope defers)? Used to detect a fn-body trailing value.
fn is_plain_expr_stmt(s: checker::TStatement) -> bool {
    match s {
        checker::TExprStmt as x => {
            match x.expr {
                checker::TIfExpr as _    => false
                checker::TMatchExpr as _ => false
                _              => true
            }
        }
        _ => false
    }
}

// One statement. Returns either Stepped(env', value) — a NORMAL step that threads the env
// forward AND carries the statement's value (an expr-statement's result; `null` == none) —
// or a Flow exit (VmReturn/Break/Continue). W5a: Stepped's `value` is how a NORMAL flow
// carries its trailing value (the C `tk_flow.value` for a NORMAL kind); a block keeps the
// LAST Stepped's value as its trailing value (B.20). The functional env (threaded via
// Stepped) is the faithful Teko stand-in for the C's in-place env mutation.
type Stepped = struct { env: Venv; value: Value? }
type Exit    = struct { flow: Flow; env: Venv }   // env at the exit point: outer-`mut` mutations made
                                                  // BEFORE a return/break/continue must survive the exit
type Step    = variant Stepped | Exit
// FlowEnv — a Flow paired with the env AFTER running a block/if/match (block-locals already popped to
// the enclosing scope; outer-`mut` mutations kept). The functional stand-in for the C's in-place env:
// exec_block/exec_if/exec_match return it so a mutation INSIDE the block PROPAGATES to the caller (the
// C twin mutates the shared env in place; here we thread the updated env back out). Without this an
// `if cond { i = i + 1 }` would silently drop the mutation — and a `loop { if … { i++ } }` would spin
// forever (the OOM cause for `bin/teko test`).
type FlowEnv = struct { flow: Flow; env: Venv }

fn exec_stmt(s: checker::TStatement, env: Venv) -> Step {
    match s {
        checker::TBinding as b  => {
            // Only SimpleName is lowered for M0 (destructuring is the honest frontier).
            // The RHS may be an `if`/`match` whose arm/branch DIVERGES (`error as e => return e`):
            // run it FLOW-AWARE so a return/break/continue propagates instead of binding.
            match b.target {
                parser::SimpleName as sn => {
                    let fe = eval_rhs_flow(b.value, env)   // FlowEnv: RHS if/match mutations rode .env
                    match fe.flow {
                        // present-wrap into a `T?` slot (REBOOT §202) via coerce_to(b.bound). Define on
                        // fe.env so any mutation the RHS made to an outer `mut` is kept, then bind on top.
                        Normal as nm => Stepped { env= define(fe.env, sn.name, coerce_to(nm.value ?? panic("vm: binding RHS produced no value (internal: checker should reject)"), b.bound)); value= null }
                        // diverged (return/break/continue inside the RHS) → propagate WITH the env, no bind.
                        VmReturn as f => Exit { flow= f; env= fe.env }
                        Break as f    => Exit { flow= f; env= fe.env }
                        Continue as f => Exit { flow= f; env= fe.env }
                    }
                }
                _                => { panic("vm: destructuring binding not yet supported") }
            }
        }
        // An assign is a NORMAL step with NO trailing value (value: null) — it keeps the env.
        // C1.6 — a compound `/=` / `%=` PANICS on a zero divisor through mutate_slot's checked
        // div/rem; POSITION it at the RHS expr (the only positioned node in a compound assign —
        // TAssign carries no line/col, but its `value` TExpr does), mirroring the C twin which
        // panics at `&s->as.assign.value`. The runtime div/rem still panic as the canonical
        // message (M.1); we only prefix line:col first.
        checker::TAssign as a   => {
            let re = eval_expr(a.value, env)   // (MEM Step 4) thread the RHS env (a value-position ref call there grows cells)
            let rhs = re.value
            let renv = re.env
            if (a.op == lexer::TokenKind::SlashEq || a.op == lexer::TokenKind::PercentEq) && val_is_int(rhs) && as_int(rhs) == 0 {
                vm_panic_div0_at(a.value.line, a.value.col)
            }
            // (MEM Step 2/3) `r.value op= x` writes THROUGH a reference: `a.name` names the `Ref<T>`
            // binding (a RefVal cell index); a deref-assign reads the cell, applies the op, and writes
            // BACK to the cell (cell_set) — so the caller's aliased var observes the write. A plain
            // assign goes through mutate_slot (which itself routes a cell-backed origin slot to its cell).
            if a.deref {
                let rv = match read_var(renv, a.name) { RefVal as r => r; _ => panic("vm: deref-assign target is not a reference (internal: checker should reject)") }
                let cur = cell_get(renv.cells, rv.cell)
                // present-wrap the FINAL value into the ref's inner type (`a.bound`) before the cell
                // write — same coercion the binding path uses (REBOOT §202). For a `Ref<T?>` this makes
                // a deref-WRITE store a PRESENT optional, so a later `?? / ?.` read does not see a bare
                // value (the VM==native divergence: native's deref-assign emit_as already wraps).
                let newval = coerce_to(compound_apply(cur, a.op, rhs), a.bound)
                let env2 = with_cells(renv, cell_set(renv.cells, rv.cell, newval))
                Stepped { env= env2; value= null }
            } else {
                let env2 = mutate_slot(renv, a.name, a.op, rhs); Stepped { env= env2; value= null }
            }
        }
        // `return e` rides a present value; a bare `return` carries null. The value may itself be
        // an `if`/`match` whose arm DIVERGES — run it flow-aware so an inner return propagates.
        checker::TReturn as r   => {
            // (W9.3 part 2) A `return` leaves EVERY enclosing scope: fire ALL in-scope frame defers
            // (down to base 0) LIFO — innermost-block-first — BEFORE evaluating the return value, so a
            // defer that mutates the variable being returned is observed. Mirrors codegen's
            // emit_defers(base 0) emitted BEFORE the `return <expr>`. The unwinding exec_blocks then
            // drain to their (≥0) marks over an EMPTY defer list → safe no-op (no re-fire).
            let denv = drain_defers_to(env, 0)
            if r.has_value {
                let fe = eval_rhs_flow(r.value, denv)
                match fe.flow {
                    Normal as nm => Exit { flow= VmReturn { value= nm.value }; env= fe.env }
                    // inner return/break/continue inside the returned value → propagate.
                    VmReturn as f => Exit { flow= f; env= fe.env }
                    Break as f    => Exit { flow= f; env= fe.env }
                    Continue as f => Exit { flow= f; env= fe.env }
                }
            } else {
                Exit { flow= VmReturn { value= null }; env= denv }
            }
        }
        // W5a — an `if`/`match` in statement/tail position runs as CONTROL FLOW (exec_if/exec_match),
        // so a `return`/`break`/`continue` inside a branch/arm PROPAGATES, and the branch's trailing
        // value becomes this statement's value (B.20). Other expr-statements carry their value
        // (a `-> void` call carries null — it produces no Value, run for effect).
        checker::TExprStmt as x => {
            match x.expr {
                checker::TIfExpr as _    => step_of_flow(exec_if(x.expr, env))
                checker::TMatchExpr as _ => step_of_flow(exec_match(x.expr, env))
                // (MEM Step 2/3) thread the env out of eval_stmt_value: a statement-position call may
                // write through a `Ref<T>` arg, growing/mutating the caller's cell store — keep it.
                _              => { let sv = eval_stmt_value(x.expr, env); Stepped { env= sv.env; value= sv.value } }
            }
        }
        checker::TLoopStmt as l     => {
            // while(1){…} with break/continue. run_loop returns the OUTER env after the last
            // iteration (so outer-`mut` updates survive the loop — the functional twin of the C's
            // in-place env). A NORMAL completion CONTINUES the block (Stepped); a return / labeled
            // break-or-continue to an enclosing loop EXITS (Exit, carrying the loop's outer env).
            let lo = run_loop(l.label, l.body, env)
            match lo.flow {
                Normal => Stepped { env= lo.env; value= null }
                _      => Exit { flow= lo.flow; env= lo.env }
            }
        }
        checker::TBreakStmt as b    => Exit { flow= Break { label= b.label }; env= env }
        checker::TContinueStmt as c => Exit { flow= Continue { label= c.label }; env= env }
        // (C7.18) A defer statement registers the block; it executes LIFO at function exit.
        // The VM drains the defer list in eval_call after exec_block completes.
        // Panic does NOT drain deferred blocks.
        checker::TDeferStmt as d    => Stepped { env= push_defer(env, d.body); value= null }
    }
}

// Evaluate an RHS that may be an `if`/`match` FLOW-AWARE: route it through exec_if/exec_match so a
// `return`/`break`/`continue` inside a branch/arm propagates out (the dominant idiom
// `let v = match r { i64 as x => x ; error as e => return e }`). Any other expr evaluates plainly
// and rides a NORMAL flow carrying its value. Mirrors the C `eval_rhs_flow`.
fn eval_rhs_flow(e: checker::TExpr, env: Venv) -> FlowEnv {
    match e {
        checker::TIfExpr as _    => exec_if(e, env)        // FlowEnv — mutations inside the RHS branch propagate
        checker::TMatchExpr as _ => exec_match(e, env)     // FlowEnv — same for a match RHS
        // (MEM Step 4) a plain RHS may be a value-position ref call (`let y = bump(x)`): thread its
        // env out so the auto-ref'd cell write survives into the binding's env (then the bind defines on it).
        _              => { let re = eval_expr(e, env); FlowEnv { flow= Normal { value= re.value }; env= re.env } }
    }
}

// step_of_flow — adapt a Flow (from exec_if) back into the Step the statement loop expects:
// a NORMAL flow keeps stepping (Stepped, env threaded, carrying the branch's trailing value);
// a VmReturn/Break/Continue escapes (Exit). Mirrors the C `exec_stmt` for a tail `if` directly
// returning the `exec_if` flow (whose NORMAL value is the statement's value).
fn step_of_flow(fe: FlowEnv) -> Step {
    match fe.flow {
        Normal as nm => Stepped { env= fe.env; value= nm.value }   // thread the branch's (mutated) env + value
        _            => Exit { flow= fe.flow; env= fe.env }         // return/break/continue propagate WITH the env
    }
}

// eval_stmt_value — evaluate an expression in STATEMENT position, yielding its VALUE (B.20 — W5a)
// AND the (possibly mutated) env: a statement-position call may write through a `Ref<T>` argument,
// so the caller's cell store can change (MEM Step 2/3) — that env must thread back. Mirrors the C
// `tk_vm_eval_expr` in exec_stmt's EXPR case (where the C env mutates in place). A `-> void` call
// runs for effect and yields NO Value (`null`); any value-typed expression yields its value.
type StmtVal = struct { value: Value?; env: Venv }
fn eval_stmt_value(e: checker::TExpr, env: Venv) -> StmtVal {
    teko::cov_line(e.line)   // D3-line — a statement-position CALL goes to call_value (bypassing eval_expr), so mark its line here (matches vm.c, which routes stmt calls through eval_expr)
    match e {
        checker::TCall as c => call_value(c, env)                          // threads the caller env out (Ref<T> writes)
        _          => { let re = eval_expr(e, env); StmtVal { value= re.value; env= re.env } }   // (MEM Step 4) thread env (a nested ref call grows cells)
    }
}

// call_value — a call in STATEMENT position. Builtins are `-> void`: run for effect, yield `null`
// (no Value). A user fn runs; an explicit `return e` yields its value, an implicit trailing value
// (NORMAL) yields that (W5a), else `null` (a `-> void` fn). (MEM Step 2/3) This is the path that
// SUPPORTS `Ref<T>` aliasing: it threads the caller env (auto-ref PROMOTION grows the caller's cell
// store + rebinds the origin slot) AND merges the callee's final cells back into the caller (the
// callee inherited the caller's cells and only grew/mutated them — so a write through `r.value` in
// the callee is visible at the caller after return). Returns the value AND the updated caller env.
// (The C twin folds this into eval_call, where the cell store is a global shared by pointer.)
fn call_value(c: checker::TCall, env: Venv) -> StmtVal {
    // A builtin that RAN (`true`) is `-> void` — yield null. A `false`/`error` result ==
    // "not a builtin": run the user fn. (Builtins do not take `Ref<T>` params — env unchanged.)
    match try_builtin(c.callee, c.args, env) {
        bool as ran => if ran { return StmtVal { value= null; env= env } }
        error       => {}
    }
    // VALUE-producing builtins — a statement-position call can be a function's TRAILING expression
    // (B.20), e.g. `fn empty_table() -> TypeTable { teko::list::empty() }`. Route them exactly like
    // eval_call (list/err/str/fs) BEFORE user-fn resolution; without this a trailing `teko::list::empty()`
    // fell through to find_function("empty") → "host function the VM cannot run". (No ref args.)
    match try_list_builtin(c.callee, c.args, env) { Value as v => return StmtVal { value= v; env= env }; null => {} }
    match try_err_builtin(c.callee, c.args, env)  { Value as v => return StmtVal { value= v; env= env }; null => {} }
    match try_str_builtin(c.callee, c.args, env)  { Value as v => return StmtVal { value= v; env= env }; null => {} }
    match try_fs_builtin(c.callee, c.args, env)   { Value as v => return StmtVal { value= v; env= env }; null => {} }
    // (W10) a CLOSURE call in statement position: a LAMBDA value executes its own body+captures; a
    // NAMED-fn value resolves THAT function (W10a). Otherwise resolve the callee path.
    if c.is_closure_call {
        match read_var(env, c.callee.segments[c.callee.segments.len - 1].name) {
            FuncVal as fv => if fv.is_lambda { let r = eval_lambda_call(fv, c, env); return StmtVal { value= r.value; env= r.env } } else { }
            _ => { }
        }
    }
    let h = if c.is_closure_call {
        match read_var(env, c.callee.segments[c.callee.segments.len - 1].name) {
            FuncVal as fv => find_function_ns(env, parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = fv.name }) }, fv.ns)
            _ => panic("vm: closure call on a non-function value (internal: checker should reject)")
        }
    } else {
        find_function_ns(env, c.callee, c.call_ns)   // namespace-disambiguated (BUGFIX)
    }
    let f = h.func
    // C7.1a — extern has no Teko body; the VM has no FFI surface. Honest stop (M.3), same as
    // eval_call (this is the STATEMENT-position call path vm.c folds into its single eval_call).
    if f.is_extern { panic("vm: an `extern` function cannot run in the VM (foreign C call) — use `teko build` to compile it natively (C7.1a)") }
    if !f.is_test { teko::cov_mark(h.idx) }   // D3 — globally-unique items index (parity with eval_call)
    // Bind args in a fresh callee frame; a `Ref<T>` arg AUTO-REFs (promotes the caller's `mut` lvalue
    // to a cell) so the caller env may grow — bind_call_args returns BOTH the callee frame and the
    // updated caller env. (Mirrors the C eval_call arg-binding + auto-ref, sharing cells by pointer.)
    let bound = bind_call_args(f, c, env)
    let fenv = bound.fenv
    mut caller = bound.caller
    teko::cov_enter(h.idx)   // D3-branch — attribute body branches to this fn (no-op unless coverage on)
    // (W9.3 part 2) is_fn_body=true — trailing value-expr fires the body's defers before it is evaluated.
    let fe2 = exec_block_ex(f.body, fenv, true)
    teko::cov_leave()
    // (W9.3) The fn-body exec_block already drained the body's own defers at its exit (scope-defer);
    // fe2.env is the post-drain callee env (defers popped, cells reflecting any defer-body writes).
    // (MEM Step 2/3) MERGE the callee's final cells back into the caller: the callee inherited the
    // caller's cell store and only appended/mutated it, so its final store is a superset-with-writes
    // and replaces the caller's wholesale — making a `r.value = …` write in the callee visible at the
    // caller's aliased var (whose slot is cell-backed). (In the C twin the cells array is global, so
    // the write is already visible; this is the value-functional twin of that shared-pointer effect.)
    caller = with_cells(caller, fe2.env.cells)
    match fe2.flow {
        VmReturn as ret => StmtVal { value= ret.value; env= caller }      // explicit `return e` (or bare return -> null)
        Normal as nm  => StmtVal { value= nm.value; env= caller }       // W5a — implicit trailing value (B.20); null if none
        _             => StmtVal { value= null; env= caller }            // break/continue can't escape a fn body
    }
}

// run_loop — while(1){…}; `mylabel` is THIS loop's label (empty = unlabeled). A BREAK whose
// label is empty OR equals `mylabel` stops THIS loop; otherwise the flow is RE-RETURNED so it
// propagates to the enclosing loop. A CONTINUE whose label is empty OR matches re-iterates THIS
// loop; otherwise it propagates. VmReturn propagates. Normal re-iterates. A loop completing (via a
// matching Break) produces NO trailing value — it yields a valueless NORMAL flow. (Mirrors the C
// `TK_TSTMT_LOOP` exec.)
// keep the first `n` slots of an env (the OUTER scope) — drops per-iteration block-locals while
// preserving outer-`mut` MUTATIONS (mutate_slot rebuilds an outer slot AT ITS INDEX, so it stays
// in [0, n)). The functional twin of the C's env_pop_to after a loop-body block.
fn loop_outer(slots: []Slot, n: u64) -> []Slot {
    mut out: []Slot = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= n { break }
        out = teko::list::push(out, slots[i])
        i = i + 1
    }
    out
}

// run_loop yields the loop's terminating FLOW plus the OUTER env after the last iteration (so an
// outer-`mut` updated inside the loop survives it — the functional twin of the C's in-place env).
type LoopOut = struct { flow: Flow; env: Venv }

fn run_loop(mylabel: str, body: []checker::TStatement, env: Venv) -> LoopOut {
    let base = env.slots.len     // outer scope size: per-iteration locals are appended ABOVE this
    mut cur = env
    loop {
        // Run the body with PER-STATEMENT env threading (like exec_block), but CARRY the resulting
        // env to the next iteration so an outer `mut i` updated by `i++` is seen (the functional VM
        // has no in-place mutation — the C twin mutates env directly). Drop this iteration's locals.
        // (W9.3) The loop body is a defer SCOPE: defers registered this iteration fire at the
        // iteration's exit (fall-through OR break/continue/return), innermost-first, BEFORE the
        // iteration's locals are dropped — mirroring the C twin, where the loop body is a
        // tk_vm_exec_block (a scope-defer frame). `dbase` is this iteration's defer base.
        let dbase = cur.defers.len
        mut e = cur
        mut exited = false
        mut exflow: Flow = Normal { value = null }
        mut i: u64 = 0
        loop {
            if i >= body.len { break }
            match exec_stmt(body[i], e) {
                Stepped as st => { e = st.env }                 // thread the env forward
                Exit as ex    => { exflow = ex.flow; e = ex.env; exited = true; break }   // keep mutations made before the exit
            }
            i = i + 1
        }
        e = drain_defers_to(e, dbase)   // (W9.3) fire this iteration's defers LIFO, then pop them
        cur = Venv { slots = loop_outer(e.slots, base); prog = e.prog; defers= cur.defers; cells= e.cells }   // keep outer mutations (incl cell writes); drop locals
        if exited {
            match exflow {
                VmReturn as ret => return LoopOut { flow = ret; env = cur }
                Break as b    => {
                    if b.label.len == 0 || vm_str_eq(b.label, mylabel) { break }   // this loop → done
                    return LoopOut { flow = b; env = cur }                          // propagate to outer
                }
                Continue as c => {
                    if c.label.len > 0 && !vm_str_eq(c.label, mylabel) { return LoopOut { flow = c; env = cur } }   // not ours → propagate
                    // ours → fall through to re-iterate (outer mutations up to the `continue` are kept)
                }
                _ => {}
            }
        }
    }
    LoopOut { flow = Normal { value = null }; env = cur }
}

// W5a — `if` as CONTROL FLOW (+ value): eval the cond (a bool), run the TAKEN branch's block,
// and return its flow. The branch's trailing value rides the NORMAL flow (the `if`'s value);
// a `return`/`break`/`continue` inside the branch propagates out. An `if`-without-`else` taken
// false yields a valueless NORMAL flow (no value). Mirrors the C `exec_if`.
fn exec_if(e: checker::TExpr, env: Venv) -> FlowEnv {
    match e {
        checker::TIfExpr as f => {
            let base = env.slots.len      // outer scope size: the branch's block-locals sit above it
            let ce = eval_expr(f.cond, env)   // (MEM Step 4) thread the cond env (a ref call in the cond grows cells)
            let c = as_bool(ce.value)
            let cenv = ce.env
            // run the taken branch; POP its locals back to the outer scope (keeping outer-`mut`
            // mutations, which mutate_slot writes at their index in [0, base)). This is what makes
            // `if cond { x = 5 }` propagate x to the caller (the C twin mutates the env in place).
            // D3-branch: outcome 0 = then taken, 1 = else/skip taken (no-op unless coverage on).
            if c {
                teko::cov_branch(e.line, e.col, 0)
                let bo = exec_block(f.then_blk, cenv)
                return FlowEnv { flow= bo.flow; env= Venv { slots= loop_outer(bo.env.slots, base); prog= bo.env.prog; defers= bo.env.defers; cells= bo.env.cells } }
            }
            teko::cov_branch(e.line, e.col, 1)
            if f.has_else {
                let bo = exec_block(f.else_blk, cenv)
                return FlowEnv { flow= bo.flow; env= Venv { slots= loop_outer(bo.env.slots, base); prog= bo.env.prog; defers= bo.env.defers; cells= bo.env.cells } }
            }
            FlowEnv { flow= Normal { value= null }; env= cenv }    // if-without-else taken false: no value, cells may have grown
        }
        _ => panic("vm: exec_if on a non-if expression (internal: checker should reject)")
    }
}

// ---------------------------------------------------------------------------
// PUBLIC ENTRY — run the VIRTUAL-MAIN. MIRRORS codegen's main(): the loose top-level
// statements run in order; a `return n` is an early process exit with (int)n; falling off
// the end -> 0. Top-level functions are callable (run only when called, never on their own).
// ---------------------------------------------------------------------------
exp fn run(prog: checker::TProgram) -> i32 {
    mut env = fresh_env(prog, teko::list::empty())   // (MEM Step 2/3) the root frame starts with an empty cell store
    mut last: Value? = null      // W5a — the last NORMAL top-level statement's trailing value (B.20)
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        // Functions/types/uses are not run here — only a loose top-level statement steps.
        match prog.items[i] {
            checker::TStatement as s => {
                match exec_stmt(s, env) {
                    // Binding/Assign/expr-stmt thread the env forward AND keep the statement's
                    // trailing value (the virtual-main's value if it's the last one — B.20).
                    Stepped as st => { env = st.env; last = st.value }
                    // A top-level VmReturn is an early process exit (like main's `return (int)n`).
                    // Break/Continue can't escape the virtual-main — the checker rejects them.
                    Exit as ex    => {
                        match ex.flow {
                            VmReturn as ret => return exit_code_of(ret.value)
                            Normal as nm  => { last = nm.value }   // a tail `if` routed via exec_if rides NORMAL
                            _             => {}   // break/continue: unreachable at top level
                        }
                    }
                }
            }
            _ => {}                                  // functions/types/uses: not run here
        }
        i++
    }
    // W5a — the exit code comes from the virtual-main's TRAILING value (an int/bool) when it
    // fell off the end without an explicit `return` (B.20); else 0. Same extraction as a
    // `return n` (int -> (int)n, bool -> 1/0, otherwise 0).
    exit_code_of(last)
}

// ---------------------------------------------------------------------------
// D3-branch — BRANCH COVERAGE report (`--coverage` → Cobertura XML). A branch SITE is one `if`
// (2 outcomes: then/else) or `match` (arms.len outcomes). The VM marks the taken outcome of each
// site during the run (cov_branch); here we STATICALLY enumerate every site (walk each production
// fn body) and query cov_branch_hit per outcome to get taken/total. Function-level line coverage
// reuses cov_is_marked (the same per-fn mark the % summary uses).
// ---------------------------------------------------------------------------
type BranchSite = struct { line: u32; col: u32; n: u64 }            // n = number of outcomes
type CovWalk    = struct { sites: []BranchSite; lines: []u32 }      // branch sites + DISTINCT executable lines

fn cov_walk_empty() -> CovWalk { CovWalk { sites = teko::list::empty(); lines = teko::list::empty() } }
// add e.line to the distinct-line set (skip 0 = unpositioned; a fn has few lines, so linear dedup is fine).
fn cov_addline(w: CovWalk, line: u32) -> CovWalk {
    if line == 0 { return w }
    mut i = 0
    loop { if i >= w.lines.len { break }; if w.lines[i] == line { return w }; i = i + 1 }
    CovWalk { sites = w.sites; lines = teko::list::push(w.lines, line) }
}
fn cov_addsite(w: CovWalk, line: u32, col: u32, n: u64) -> CovWalk {
    CovWalk { sites = teko::list::push(w.sites, BranchSite { line = line; col = col; n = n }); lines = w.lines }
}

// recurse an EXPR, collecting its source line (line coverage) + every nested if/match site (branch
// coverage) into `w`. ONE walk feeds both the line and branch metrics + the cobertura report.
fn cov_walk_expr(e: checker::TExpr, w: CovWalk) -> CovWalk {
    let w0 = cov_addline(w, e.line)
    match e.kind {
        checker::TIfExpr as f => {
            let a1 = cov_addsite(w0, e.line, e.col, 2)
            let a2 = cov_walk_expr(f.cond, a1)
            let a3 = cov_walk_block(f.then_blk, a2)
            if f.has_else { cov_walk_block(f.else_blk, a3) } else { a3 }
        }
        checker::TMatchExpr as m => {
            let a1 = cov_addsite(w0, e.line, e.col, m.arms.len)
            mut a = cov_walk_expr(m.subject, a1)
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                if m.arms[i].has_when { a = cov_walk_expr(m.arms[i].guard, a) }
                a = cov_walk_block(m.arms[i].body, a)
                i++
            }
            a
        }
        checker::TBinary as b => cov_walk_expr(b.right, cov_walk_expr(b.left, w0))
        checker::TUnary as u => cov_walk_expr(u.operand, w0)
        checker::TCompare as c => {
            mut a = cov_walk_expr(c.first, w0)
            mut i = 0
            loop { if i >= c.rest.len { break }; a = cov_walk_expr(c.rest[i].operand, a); i++ }
            a
        }
        checker::TCall as c => {
            mut a = w0
            mut i = 0
            loop { if i >= c.args.len { break }; a = cov_walk_expr(c.args[i], a); i++ }
            a
        }
        checker::TCast as c => cov_walk_expr(c.expr, w0)
        checker::TFieldAccess as fa => cov_walk_expr(fa.receiver, w0)
        checker::TSafeFieldAccess as sfa => cov_walk_expr(sfa.receiver, w0)
        checker::TCoalesce as co => cov_walk_expr(co.right, cov_walk_expr(co.left, w0))
        checker::TIndex as ix => cov_walk_expr(ix.index, cov_walk_expr(ix.receiver, w0))
        checker::TStructInit as si => {
            mut a = w0
            mut i = 0
            loop { if i >= si.field_vals.len { break }; a = cov_walk_expr(si.field_vals[i], a); i++ }
            a
        }
        checker::TInterp as in => {
            mut a = w0
            mut i = 0
            loop {
                if i >= in.holes.len { break }
                a = cov_walk_expr(in.holes[i], a)
                if i < in.specs.len {
                    match in.specs[i].kind {
                        checker::TFSpecDynamic as fd => {
                            mut k = 0
                            loop { if k >= fd.args.len { break }; a = cov_walk_expr(fd.args[k], a); k++ }
                        }
                        _ => { }
                    }
                }
                i++
            }
            a
        }
        checker::TInExpr as ie => {
            mut a = cov_walk_expr(ie.lhs, w0)
            mut i = 0
            loop { if i >= ie.elems.len { break }; a = cov_walk_expr(ie.elems[i], a); i++ }
            a
        }
        checker::TArrayLit as al => {
            mut a = w0
            mut i = 0
            loop { if i >= al.elements.len { break }; a = cov_walk_expr(al.elements[i].expr, a); i++ }
            a
        }
        _ => w0   // leaves (number/var/strlit/bytelit/boollit/nulllit/pathexpr) — line already added
    }
}

fn cov_walk_stmt(s: checker::TStatement, w: CovWalk) -> CovWalk {
    match s {
        checker::TBinding as b  => cov_walk_expr(b.value, w)
        checker::TAssign as a   => cov_walk_expr(a.value, w)
        checker::TReturn as r   => if r.has_value { cov_walk_expr(r.value, w) } else { w }
        checker::TLoopStmt as l => cov_walk_block(l.body, w)
        checker::TExprStmt as x => cov_walk_expr(x.expr, w)
        _ => w   // break/continue — no expr
    }
}

fn cov_walk_block(stmts: []checker::TStatement, w: CovWalk) -> CovWalk {
    mut a = w
    mut i = 0
    loop { if i >= stmts.len { break }; a = cov_walk_stmt(stmts[i], a); i++ }
    a
}

// a Cobertura rate decimal "0.000".."1.0" from covered/total (val==0 → vacuously "1.0").
fn cov_rate_str(cov: u64, val: u64) -> str {
    if val == 0 { return "1.0" }
    let m = cov * 1000 / val
    if m >= 1000 { return "1.0" }
    mut fs = teko::str::u64_to_str(m)
    loop { if fs.len >= 3 { break }; fs = teko::str::concat("0", fs) }
    teko::str::concat("0.", fs)
}

// branch taken/total over the sites that sit on source line `ln` (a line may host >1 if/match).
type LineBr = struct { taken: u64; total: u64 }
fn cov_line_branch(sites: []BranchSite, fn_idx: u64, ln: u32) -> LineBr {
    mut taken: u64 = 0; mut total: u64 = 0
    mut s = 0
    loop {
        if s >= sites.len { break }
        if sites[s].line == ln {
            mut o: u64 = 0
            loop { if o >= sites[s].n { break }; if teko::cov_branch_hit(fn_idx, sites[s].line, sites[s].col, o) { taken = taken + 1 }; o = o + 1 }
            total = total + sites[s].n
        }
        s = s + 1
    }
    LineBr { taken = taken; total = total }
}

// cov_cobertura — build a Cobertura XML report from the LAST run's marks. ONE <class> per production
// function (filename = its source file). The class <lines> are the REAL executable lines (every line
// with an evaluated expression, hit via cov_line_hit); a line that hosts an if/match also carries the
// branch condition-coverage. Single-quoted attributes (valid XML) so no `"`-escaping is needed.
exp fn cov_cobertura(prog: checker::TProgram) -> str {
    mut body = ""
    mut lines_cov: u64 = 0; mut lines_val: u64 = 0
    mut br_cov: u64 = 0;    mut br_val: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                if !f.is_test && f.namespace != "teko::vm" {
                    let fnhit: u64 = if teko::cov_is_marked(i to u64) { 1 to u64 } else { 0 to u64 }
                    let w = cov_walk_block(f.body, cov_walk_empty())
                    // LINE coverage — one <line> per distinct executable body line.
                    mut llines = ""
                    mut flc: u64 = 0; mut flv: u64 = 0
                    mut k = 0
                    loop {
                        if k >= w.lines.len { break }
                        let ln = w.lines[k]
                        let lhit: u64 = if teko::cov_line_hit(i to u64, ln) { 1 to u64 } else { 0 to u64 }
                        flv = flv + 1; flc = flc + lhit
                        let lb = cov_line_branch(w.sites, i to u64, ln)
                        if lb.total > 0 {
                            let pct = lb.taken * 100 / lb.total
                            llines = teko::str::concat(llines, $"          <line number='{ln}' hits='{lhit}' branch='true' condition-coverage='{pct}% ({lb.taken}/{lb.total})'/>\n")
                        } else {
                            llines = teko::str::concat(llines, $"          <line number='{ln}' hits='{lhit}'/>\n")
                        }
                        k = k + 1
                    }
                    lines_cov = lines_cov + flc; lines_val = lines_val + flv
                    // BRANCH coverage — taken/total over every site.
                    mut fbc: u64 = 0; mut fbv: u64 = 0
                    mut s = 0
                    loop {
                        if s >= w.sites.len { break }
                        mut o: u64 = 0
                        loop { if o >= w.sites[s].n { break }; if teko::cov_branch_hit(i to u64, w.sites[s].line, w.sites[s].col, o) { fbc = fbc + 1 }; o = o + 1 }
                        fbv = fbv + w.sites[s].n
                        s = s + 1
                    }
                    br_cov = br_cov + fbc; br_val = br_val + fbv
                    let cname = if f.namespace.len != 0 { teko::str::concat(f.namespace, "::", f.name) } else { f.name }
                    let lrate = cov_rate_str(flc, flv)
                    let brate = cov_rate_str(fbc, fbv)
                    body = teko::str::concat(body, $"      <class name='{cname}' filename='{f.file}' line-rate='{lrate}' branch-rate='{brate}' complexity='0'>\n")
                    body = teko::str::concat(body, $"        <methods><method name='{f.name}' signature='()V' line-rate='{lrate}' branch-rate='{brate}'><lines><line number='{f.line}' hits='{fnhit}'/></lines></method></methods>\n")
                    body = teko::str::concat(body, "        <lines>\n")
                    body = teko::str::concat(body, llines)
                    body = teko::str::concat(body, "        </lines>\n      </class>\n")
                }
            }
            _ => {}
        }
        i++
    }
    let lrate = cov_rate_str(lines_cov, lines_val)
    let brate = cov_rate_str(br_cov, br_val)
    mut out = "<?xml version='1.0' ?>\n"
    out = teko::str::concat(out, $"<coverage line-rate='{lrate}' branch-rate='{brate}' lines-covered='{lines_cov}' lines-valid='{lines_val}' branches-covered='{br_cov}' branches-valid='{br_val}' complexity='0' version='teko' timestamp='0'>\n")
    out = teko::str::concat(out, "  <sources><source>.</source></sources>\n  <packages>\n")
    out = teko::str::concat(out, $"    <package name='teko' line-rate='{lrate}' branch-rate='{brate}' complexity='0'>\n      <classes>\n")
    out = teko::str::concat(out, body)
    out = teko::str::concat(out, "      </classes>\n    </package>\n  </packages>\n</coverage>\n")
    out
}

// ---------------------------------------------------------------------------
// run_tests — the D2 TEST RUNNER (`teko test`). Execute every `#test` function (zero-arg,
// void) in the merged program, fail-fast: a failed assertion PANICS (M.1) — aborting from
// inside the VM with its "assertion failed: …" message, AFTER the running test's name was
// printed (so the user sees which test failed). All pass → print the count, return 0. An
// empty suite (no `#test`) is NOT a failure — the build gate skips when absent.
// ---------------------------------------------------------------------------
exp fn run_tests(prog: checker::TProgram) -> i32 { run_tests_cov(prog, false, false, "") }

// run_tests_cov — run_tests + optional Cobertura report. `gen_cov` enables BRANCH recording for the
// run (off by default — a plain run pays only one flag-check per branch); afterward it writes the
// XML to `cov_path` (the caller picks `<out>/cobertura.xml`). Mirrors vm.c's run_tests_cov.
exp fn run_tests_cov(prog: checker::TProgram, record_branches: bool, write_xml: bool, cov_path: str) -> i32 {
    teko::cov_reset()        // D3 — start a fresh coverage run; eval_call marks each production fn it enters
    // the GATE records lines+branches even without --coverage (for the floors).
    if record_branches { teko::cov_branch_reset(); teko::cov_branches_on(true); teko::cov_line_reset(); teko::cov_lines_on(true) }
    mut passed: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                if f.is_test {
                    let label = if f.namespace.len != 0 { teko::str::concat(f.namespace, "::", f.name) } else { f.name }
                    teko::io::print(teko::str::concat("test ", label, " ... "))
                    let fenv = fresh_env(prog, teko::list::empty())   // (MEM Step 2/3) each test frame starts with an empty cell store
                    teko::cov_enter(i to u64)   // attribute the test body's own lines/branches to the test (NOT prod fn 0)
                    let _ = exec_block(f.body, fenv)   // a failed assert panics here (fail-fast); normal completion = pass
                    teko::cov_leave()
                    teko::io::println("ok")
                    passed = passed + 1
                }
            }
            _ => {}
        }
        i++
    }
    if record_branches { teko::cov_branches_on(false); teko::cov_lines_on(false) }
    if passed == 0 {
        teko::io::println("teko: no tests (no `#test` functions)")
    } else {
        teko::io::println(teko::str::concat("teko: ", teko::str::u64_to_str(passed), " test(s) passed"))
        // D3 — three coverage metrics: functions / lines / branches (lines+branches need recording).
        let fc = functions_coverage(prog)
        teko::io::println($"teko: coverage {cov_pct(fc)}% ({fc.cov}/{fc.val} functions)")
        if record_branches {
            let lc = line_coverage(prog)
            let bc = branch_coverage(prog)
            teko::io::println($"teko: coverage {cov_pct(lc)}% ({lc.cov}/{lc.val} lines)")
            teko::io::println($"teko: coverage {cov_pct(bc)}% ({bc.cov}/{bc.val} branches)")
        }
    }
    if write_xml {
        let xml = cov_cobertura(prog)
        let _ = teko::io::write_file(cov_path, xml)
        teko::io::println(teko::str::concat("teko: wrote coverage report ", cov_path))
    }
    0
}

// CovCount — covered / valid (numerator / denominator) for a metric. cov_pct rounds DOWN; an empty
// denominator is vacuously 100% (no code → nothing to cover).
type CovCount = struct { cov: u64; val: u64 }
fn cov_pct(c: CovCount) -> u64 { if c.val == 0 { 100 } else { c.cov * 100 / c.val } }

// FUNCTIONS metric — distinct production fns executed / total production fns (the cov-mark sink).
exp fn functions_coverage(prog: checker::TProgram) -> CovCount {
    CovCount { cov = teko::cov_distinct(); val = count_prod_fns(prog) }
}
// LINES metric — distinct executable lines hit / total executable lines, over every production fn.
exp fn line_coverage(prog: checker::TProgram) -> CovCount {
    mut cov: u64 = 0; mut val: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                if !f.is_test && f.namespace != "teko::vm" {
                    let w = cov_walk_block(f.body, cov_walk_empty())
                    mut k = 0
                    loop {
                        if k >= w.lines.len { break }
                        val = val + 1
                        if teko::cov_line_hit(i to u64, w.lines[k]) { cov = cov + 1 }
                        k = k + 1
                    }
                }
            }
            _ => {}
        }
        i++
    }
    CovCount { cov = cov; val = val }
}
// BRANCHES metric — taken outcomes / total outcomes over every production fn's if/match sites.
exp fn branch_coverage(prog: checker::TProgram) -> CovCount {
    mut cov: u64 = 0; mut val: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            checker::TFunction as f => {
                if !f.is_test && f.namespace != "teko::vm" {
                    let w = cov_walk_block(f.body, cov_walk_empty())
                    mut s = 0
                    loop {
                        if s >= w.sites.len { break }
                        mut o: u64 = 0
                        loop {
                            if o >= w.sites[s].n { break }
                            if teko::cov_branch_hit(i to u64, w.sites[s].line, w.sites[s].col, o) { cov = cov + 1 }
                            o = o + 1
                        }
                        val = val + w.sites[s].n
                        s = s + 1
                    }
                }
            }
            _ => {}
        }
        i++
    }
    CovCount { cov = cov; val = val }
}
// %-only wrappers — the D4 gate floors read these (function / line / branch).
exp fn branch_coverage_pct(prog: checker::TProgram) -> u64 { cov_pct(branch_coverage(prog)) }
exp fn line_coverage_pct(prog: checker::TProgram) -> u64 { cov_pct(line_coverage(prog)) }

// count_prod_fns — the coverage DENOMINATOR: production (non-`#test`) functions in the program.
fn count_prod_fns(prog: checker::TProgram) -> u64 {
    mut n: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            // exclude `#test` fns AND the vm.tks functions (namespace "teko::vm"): those implement the
            // NATIVE VM and are never reached via find_function during interpretation, so counting them
            // would permanently depress coverage. Mirrors vm.c's count_prod_fns (the vm_ns skip).
            checker::TFunction as f => { if !f.is_test && f.namespace != "teko::vm" { n = n + 1 } }
            _ => {}
        }
        i++
    }
    n
}

// coverage_pct — the FUNCTION-coverage % (the D4 `functions` floor reads this). 100 when there are
// no production functions (vacuously covered).
exp fn coverage_pct(prog: checker::TProgram) -> u64 { cov_pct(functions_coverage(prog)) }
