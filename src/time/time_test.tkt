/**
 * date_to_string honors the token WIDTH: yy is the two-digit year, single M/d are unpadded, and
 * an alternate separator (`/`) passes through.
 */
#test
fn date_to_string_token_widths() {
    let d = teko::time::Date { days = 20000 to i32 }
    teko::assert::is_true(teko::time::date_to_string(d, "yy/M/d") == "24/10/4")
}

/**
 * time_to_string fills the HH/mm/ss tokens from a nanoseconds-since-midnight tick count,
 * zero-padding each two-digit field.
 */
#test
fn time_to_string_clock_pattern() {
    let noon = teko::time::Time { ticks = 43200000000000 to u64 }
    teko::assert::is_true(teko::time::time_to_string(noon, "HH:mm:ss") == "12:00:00")

    let odd = teko::time::Time { ticks = 3661000000000 to u64 }
    teko::assert::is_true(teko::time::time_to_string(odd, "HH:mm:ss") == "01:01:01")
}
