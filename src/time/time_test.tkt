/**
 * civil_from_days reproduces the Gregorian year/month/day for the epoch and known offsets,
 * including a negative (pre-1970) day count. Together with the sibling tests this exercises the
 * pure-Teko teko::time calendar formatters (no extern host clock), so they run on BOTH the VM
 * gate and the native build gate (verify-both mandate) and must agree byte-for-byte (#166 item 3).
 */
#test
fn civil_from_days_known_dates() {
    let epoch = teko::time::civil_from_days(0)
    teko::assert::is_true(epoch.year == 1970 && epoch.month == 1 && epoch.day == 1)

    let y2021 = teko::time::civil_from_days(18628)
    teko::assert::is_true(y2021.year == 2021 && y2021.month == 1 && y2021.day == 1)

    let mixed = teko::time::civil_from_days(20000)
    teko::assert::is_true(mixed.year == 2024 && mixed.month == 10 && mixed.day == 4)

    let pre = teko::time::civil_from_days(-1)
    teko::assert::is_true(pre.year == 1969 && pre.month == 12 && pre.day == 31)
}

/**
 * date_to_string fills the yyyy/MM/dd tokens, zero-padding the two-digit fields and passing the
 * `-` separators through literally.
 */
#test
fn date_to_string_iso_pattern() {
    let d = teko::time::Date { days = 20000 to i32 }
    teko::assert::is_true(teko::time::date_to_string(d, "yyyy-MM-dd") == "2024-10-04")

    let epoch = teko::time::Date { days = 0 to i32 }
    teko::assert::is_true(teko::time::date_to_string(epoch, "yyyy-MM-dd") == "1970-01-01")
}

/**
 * date_to_string honors the token WIDTH: yy is the two-digit year, single M/d are unpadded, and
 * an alternate separator (`/`) passes through.
 */
#test
fn date_to_string_token_widths() {
    let d = teko::time::Date { days = 20000 to i32 }
    teko::assert::is_true(teko::time::date_to_string(d, "yy/M/d") == "24/10/4")
}

/**
 * time_to_string fills the HH/mm/ss tokens from a nanoseconds-since-midnight tick count,
 * zero-padding each two-digit field.
 */
#test
fn time_to_string_clock_pattern() {
    let noon = teko::time::Time { ticks = 43200000000000 to u64 }
    teko::assert::is_true(teko::time::time_to_string(noon, "HH:mm:ss") == "12:00:00")

    let odd = teko::time::Time { ticks = 3661000000000 to u64 }
    teko::assert::is_true(teko::time::time_to_string(odd, "HH:mm:ss") == "01:01:01")
}
