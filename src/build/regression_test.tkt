/**
 * FIXTURE_PASS_SOURCE — the fixture `[tests] regression` source holding only PASSING regressives
 * (`regressions/exit_ok`); a gated run over it returns 0.
 */
const FIXTURE_PASS_SOURCE: str = "examples/regression-fixture/regressions"

/**
 * FIXTURE_FAIL_SOURCE — the out-of-harness source holding the deliberately-FAILING regressive
 * (`regressions-fail/exit_bad`); a gated run over it returns 1, an advisory run 0.
 */
const FIXTURE_FAIL_SOURCE: str = "examples/regression-fixture/regressions-fail"

/**
 * FIXTURE_PASS_REGRESSIVE — the single passing regressive directory driven by `run_one_regressive`.
 */
const FIXTURE_PASS_REGRESSIVE: str = "examples/regression-fixture/regressions/exit_ok"

/**
 * FIXTURE_FAIL_REGRESSIVE — the single failing regressive directory driven by `run_one_regressive`.
 */
const FIXTURE_FAIL_REGRESSIVE: str = "examples/regression-fixture/regressions-fail/exit_bad"

/**
 * TKR_BASENAME — the `.tkr` spec basename inside every fixture regressive directory.
 */
const TKR_BASENAME: str = "test.tkr"

/**
 * regr_have_teko — is a built `bin/teko` present in the current project (the gen1 self-build CI
 * always produces one before `teko test .`)? The end-to-end regression tests drive that binary to
 * compile the fixture regressives; when it is absent (a bare `teko test .` with no prior build) they
 * honest-skip rather than hard-fail.
 *
 * @return true when `bin/teko` exists
 */
fn regr_have_teko() -> bool {
    match teko::fs::list_dir("bin") {
        []str as e => {
            mut k: u64 = 0
            loop {
                if k >= e.len { break }
                if e[k] == "teko" { return true }
                k = k + 1
            }
            false
        }
        error => false
    }
}

/**
 * regr_exe — the absolute path to this project's built `bin/teko`, used as the compiler that builds
 * each fixture regressive during the end-to-end tests.
 *
 * @return the absolute `bin/teko` path
 */
fn regr_exe() -> str {
    let cwd = match teko::env::cwd() { str as c => c; error => "" }
    cwd ~ "/bin/teko"
}

/**
 * regr_manifest_for — a synthetic `Manifest` whose `[tests] regression` names a single `source`, for
 * driving `run_regression_sources` directly in a test.
 *
 * @param source  the regression source path
 * @param gate    whether a failing regressive gates (`[tests] gate`)
 * @return        the parsed manifest
 */
fn regr_manifest_for(source: str, gate: bool) -> Manifest {
    let g = if gate { "true" } else { "false" }
    let src = teko::str::concat("name = \"h\"\nsource = \"src\"\n[tests]\ngate = ", teko::str::concat(g, teko::str::concat("\nregression = [\"", teko::str::concat(source, "\"]\n"))))
    match parse_manifest(src) { Manifest as m => m; error => parse_manifest_or_die() }
}

/**
 * parse_manifest_or_die — the unreachable fallback for `regr_manifest_for` (the literal source it
 * builds always parses); returns a trivially-valid manifest so the helper stays total.
 *
 * @return a minimal valid manifest
 */
fn parse_manifest_or_die() -> Manifest {
    match parse_manifest("name = \"h\"\nsource = \"src\"\n") { Manifest as m => m; error => parse_manifest_or_die() }
}

#test
/**
 * windows_path_to_sh_rewrites_every_backslash — the first `to_sh_path` rewrite: every `\` becomes
 * `/`, and a path that already carries no backslash (the POSIX shape) passes through unchanged.
 *
 * @return void
 */
fn windows_path_to_sh_rewrites_every_backslash() {
    teko::assert::is_true(windows_path_to_sh("D:\\a\\teko-lang\\bin\\teko.exe") == "D:/a/teko-lang/bin/teko.exe")
    teko::assert::is_true(windows_path_to_sh("/home/user/teko-lang/bin/teko") == "/home/user/teko-lang/bin/teko")
}

#test
/**
 * windows_drive_to_mount_folds_the_drive_letter — the second `to_sh_path` rewrite: a forward-slashed
 * drive-letter path folds into the git-bash POSIX mount form (`D:/a/b` -> `/d/a/b`, lowercased), and a
 * path with no `<letter>:` prefix (already POSIX, or a bare relative path) passes through unchanged.
 *
 * @return void
 */
fn windows_drive_to_mount_folds_the_drive_letter() {
    teko::assert::is_true(windows_drive_to_mount("D:/a/teko-lang/bin/teko.exe") == "/d/a/teko-lang/bin/teko.exe")
    teko::assert::is_true(windows_drive_to_mount("c:/") == "/c/")
    teko::assert::is_true(windows_drive_to_mount("examples/regressions/rt_behavior") == "examples/regressions/rt_behavior")
    teko::assert::is_true(windows_drive_to_mount("/home/user/teko-lang/bin/teko") == "/home/user/teko-lang/bin/teko")
}

#test
/**
 * to_sh_path_gates_on_host_os — `to_sh_path` applies the full backslash + mount-letter rewrite ONLY
 * on a Windows host: a Windows-shaped path converts to its git-bash mount form there and passes
 * through unchanged on every other host, so the same assertion holds whichever platform this test
 * itself runs under (linux/macos/windows CI).
 *
 * @return void
 */
fn to_sh_path_gates_on_host_os() {
    let raw = "D:\\a\\teko-lang\\bin\\teko.exe"
    let converted = to_sh_path(raw)
    if teko::os() == "windows" { teko::assert::is_true(converted == "/d/a/teko-lang/bin/teko.exe"); return }
    teko::assert::is_true(converted == raw)
}

#test
/**
 * regression_runs_and_passes_a_good_regressive — the end-to-end proof (passing case): the runner
 * discovers, compiles, runs, and CHECKS the `exit_ok` fixture regressive, which prints "ok" and
 * exits 3 (the `.tkr` checks both stdout and exit, and passes three argv operands through the
 * runner's plumbing). Honest-skips when `bin/teko` is absent.
 *
 * @return void
 */
fn regression_runs_and_passes_a_good_regressive() {
    if !regr_have_teko() { teko::assert::is_true(true); return }
    let oc = run_one_regressive(regr_exe(), FIXTURE_PASS_REGRESSIVE, TKR_BASENAME, "bin/.regr-test/pass")
    teko::assert::is_true(oc.ok)
}

#test
/**
 * regression_reports_a_bad_regressive_as_failure — the end-to-end proof (failing case): the
 * `exit_bad` fixture exits 3 but its `.tkr` expects 99, so the runner must report a NON-skipped
 * failure. Honest-skips when `bin/teko` is absent.
 *
 * @return void
 */
fn regression_reports_a_bad_regressive_as_failure() {
    if !regr_have_teko() { teko::assert::is_true(true); return }
    let oc = run_one_regressive(regr_exe(), FIXTURE_FAIL_REGRESSIVE, TKR_BASENAME, "bin/.regr-test/fail")
    teko::assert::is_false(oc.ok)
    teko::assert::is_false(oc.skipped)
}

#test
/**
 * regression_source_discovery_gates — driving `run_regression_sources` over the fixture: the passing
 * `regressions/` source returns 0 (green), and the failing `regressions-fail/` source with gating on
 * returns 1 (the failure gates the run). Honest-skips when `bin/teko` is absent.
 *
 * @return void
 */
fn regression_source_discovery_gates() {
    if !regr_have_teko() { teko::assert::is_true(true); return }
    let exe = regr_exe()
    let good = regr_manifest_for(FIXTURE_PASS_SOURCE, true)
    teko::assert::is_true(run_regression_sources(exe, good) == 0)
    let bad = regr_manifest_for(FIXTURE_FAIL_SOURCE, true)
    teko::assert::is_true(run_regression_sources(exe, bad) == 1)
}

#test
/**
 * regression_gate_false_is_advisory — with `[tests] gate = false` a failing regressive does NOT gate
 * the run (returns 0), proving the advisory mode. Honest-skips when `bin/teko` is absent.
 *
 * @return void
 */
fn regression_gate_false_is_advisory() {
    if !regr_have_teko() { teko::assert::is_true(true); return }
    let advisory = regr_manifest_for(FIXTURE_FAIL_SOURCE, false)
    teko::assert::is_true(run_regression_sources(regr_exe(), advisory) == 0)
}

#test
/**
 * regression_phase_is_anti_recursive — with `TEKO_IN_REGRESSION` already set, `run_regression_phase`
 * REFUSES to start a phase and returns 0 EVEN for a gating failing source (which would otherwise
 * return 1) — the backstop against a regressive re-entering discovery. Honest-skips when `bin/teko`
 * is absent. Defined last: it leaves the sentinel set for the rest of the process, which only
 * affects `run_regression_phase` (the other tests call the sentinel-free core).
 *
 * @return void
 */
fn regression_phase_is_anti_recursive() {
    if !regr_have_teko() { teko::assert::is_true(true); return }
    match teko::env::set_var(TEKO_IN_REGRESSION_VAR, "1") { error => { }; null => { } }
    let bad = regr_manifest_for(FIXTURE_FAIL_SOURCE, true)
    teko::assert::is_true(run_regression_phase(regr_exe(), bad) == 0)
}
