/**
 * args_of — build a `[]str` CLI argument vector from up to three tokens, dropping any
 * that is "" so a test can pass fewer than three. Mirrors project_test.tkt's own
 * `args_of` fixture, scoped to this file's help-flag tests.
 *
 * @param a  the first token (dropped when "")
 * @param b  the second token (dropped when "")
 * @param c  the third token (dropped when "")
 * @return   the assembled argument vector
 */
fn help_args_of(a: str, b: str, c: str) -> []str {
    mut v: []str = teko::list::empty()
    if a != "" { v = teko::list::push(v, a) }
    if b != "" { v = teko::list::push(v, b) }
    if c != "" { v = teko::list::push(v, c) }
    v
}

/**
 * wants_help_false_without_the_flag — neither a bare project argument nor an unrelated
 * flag is mistaken for `--help`/`-h`.
 *
 * @return void
 */
#test
fn wants_help_false_without_the_flag() {
    teko::assert::is_false(wants_help(help_args_of("teko", "build", ".")))
    teko::assert::is_false(wants_help(help_args_of("teko", "--version", "")))
    teko::assert::is_false(wants_help(help_args_of("teko", "", "")))
}

/**
 * help_cmd_of_falls_back_to_general — a bare `--help` (not a known command) and an
 * unrecognized first positional both yield "" — the general-banner sentinel.
 *
 * @return void
 */
#test
fn help_cmd_of_falls_back_to_general() {
    teko::assert::is_true(help_cmd_of(help_args_of("teko", "--help", "")) == "")
    teko::assert::is_true(help_cmd_of(help_args_of("teko", "-h", "")) == "")
    teko::assert::is_true(help_cmd_of(help_args_of("teko", "bogus", "--help")) == "")
    teko::assert::is_true(help_cmd_of(help_args_of("teko", "", "")) == "")
}
