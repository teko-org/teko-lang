use teko::parser
use teko::checker

/**
 * priv_fn — a void-returning TFunction with a hand-built body, PRIVATE visibility (the common
 * case; reachability never treats a private fn as a root by itself).
 *
 * (Tests for teko::build reachability, C7.20; #test collected.) Every test below builds a typed
 * program BY HAND (checker::TFunction/TProgram literals, like checker_test.tkt's monomorphize
 * group K) so the call-graph closure and the roots (loose statements + `exp` functions) are
 * exercised directly, without a full front-end pass.
 */
fn priv_fn(name: str, body: []checker::TStatement) -> checker::TFunction {
    checker::TFunction { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); return_type = checker::Void { }; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}

/** exp_fn — an `exp`-visibility TFunction: a library's public surface, one reachability ROOT. */
fn exp_fn(name: str, body: []checker::TStatement) -> checker::TFunction {
    checker::TFunction { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); return_type = checker::Void { }; body = body; vis = parser::Visibility::Exp; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}

/** extern_fn — an extern TFunction (no body) bound to `lib` via `from_lib`. */
fn extern_fn(name: str, lib: str) -> checker::TFunction {
    let no_body: []checker::TStatement = teko::list::empty()
    checker::TFunction { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); return_type = checker::Void { }; body = no_body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = true; c_symbol = "sym"; from_lib = lib }
}

/** call_stmt — a typed no-arg call `NAME()` (void result — reachability only reads the name). */
fn call_stmt(name: str) -> checker::TStatement {
    let callee = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }
    let ce = checker::TExpr { kind = checker::TCall { callee = callee; args = teko::list::empty(); call_ns = ""; is_closure_call = false; callee_type = checker::Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = checker::Void { }; line = 0; col = 0 }
    checker::TExprStmt { expr = ce }
}

/** one_stmt — a single-statement body. */
fn one_stmt(s: checker::TStatement) -> []checker::TStatement { teko::list::push(teko::list::empty(), s) }

/** one_item — a single-function item list, the seed for building up a TProgram by hand. */
fn one_item(f: checker::TFunction) -> []checker::TItem { teko::list::push(teko::list::empty(), f) }

/** push_item — append one more TFunction item to an item list. */
fn push_item(items: []checker::TItem, f: checker::TFunction) -> []checker::TItem { teko::list::push(items, f) }

#test
/** A call inside a loop's run-once `init` preamble is reachable — the reachability walker descends
    into `l.init` (and `l.body`) of a `TLoopStmt` (#517). */
fn call_inside_loop_init_is_reachable() {
    let loop_init = one_stmt(call_stmt("raw_write"))
    let loop_s: checker::TStatement = checker::TLoopStmt { label = ""; init = loop_init; body = one_stmt(checker::TBreakStmt { label = "" }) }
    let helper = priv_fn("helper", one_stmt(loop_s))
    let items0 = one_item(extern_fn("raw_write", "libc"))
    let items1 = push_item(items0, helper)
    let items2 = teko::list::push(items1, call_stmt("helper"))
    let prog = checker::TProgram { items = items2 }
    teko::assert::is_true(name_in(reachable_libs(prog), "libc"))
}

#test
/**
 * A library artifact has NO virtual-main; its `exp` surface is the entry point a caller
 * outside this program reaches — so an exp fn's own calls must count as reachable even when
 * nothing IN this program calls the exp fn itself.
 */
fn exp_function_is_its_own_root_even_when_uncalled_locally() {
    let pubapi = exp_fn("pubapi", one_stmt(call_stmt("crypto_init")))
    let items0 = one_item(extern_fn("crypto_init", "crypto"))
    let items1 = push_item(items0, pubapi)
    let prog = checker::TProgram { items = items1 }
    teko::assert::is_true(name_in(reachable_libs(prog), "crypto"))
}

#test
/**
 * `let f = extern_fn` (TVar{is_func=true}) is a first-class reference, not a TCall — the walk
 * must still count it as reaching the extern's lib (W10a closures-over-fns shape).
 */
fn function_taken_as_a_value_counts_as_a_use() {
    let fref = checker::TExpr { kind = checker::TVar { name = "raw_read"; is_func = true; func_ns = "" }; type = checker::Void { }; line = 0; col = 0 }
    let bound = checker::TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "f" }; bound = checker::Void { }; value = fref }
    let items0 = one_item(extern_fn("raw_read", "libc"))
    let items1 = teko::list::push(items0, bound)
    let prog = checker::TProgram { items = items1 }
    teko::assert::is_true(name_in(reachable_libs(prog), "libc"))
}
