use teko::parser
use teko::checker

/**
 * dirname_of splits a POSIX path at the last '/' and returns "." for a separator-less name —
 * byte-identical to the '/'-only original.
 */
#test
fn pt_dirname_posix_is_byte_identical() {
    teko::assert::is_true(dirname_of("/a/b/c") == "/a/b")
    teko::assert::is_true(dirname_of("file") == ".")
}

/**
 * target_matches — is `target_from_name(name)`'s own result `want`? The
 * shared assertion body every `target_from_name` golden below reduces to
 * (`NativeTarget` has no `Eq`-by-value assert helper, so this compares by
 * hand via `match`).
 *
 * @param str name  the raw `TEKO_TARGET` value to map
 * @param NativeTarget want  the expected mapped target
 * @return bool  `true` iff `target_from_name(name) == want`
 */
fn target_matches(name: str, want: NativeTarget) -> bool {
    match target_from_name(name) {
        NativeTarget::Arm64Macho => want == NativeTarget::Arm64Macho
        NativeTarget::X8664Linux => want == NativeTarget::X8664Linux
        NativeTarget::Riscv64Linux => want == NativeTarget::Riscv64Linux
        NativeTarget::X8664Windows => want == NativeTarget::X8664Windows
        NativeTarget::Wasm32Wasi => want == NativeTarget::Wasm32Wasi
        NativeTarget::Wasm64Wasi => want == NativeTarget::Wasm64Wasi
        NativeTarget::Wasm32Browser => want == NativeTarget::Wasm32Browser
    }
}

#test
/**
 * target_from_name_still_maps_the_pre_existing_targets — a non-regression
 * check on the ENUM extension (#389 C1-5 adds two arms to `NativeTarget`):
 * the pre-existing `x86_64-linux`/`x86_64-elf` mappings, an unrecognized
 * string, and the empty string all still resolve exactly as before.
 *
 * @return void
 */
fn target_from_name_still_maps_the_pre_existing_targets() {
    teko::assert::is_true(target_matches("x86_64-linux", NativeTarget::X8664Linux))
    teko::assert::is_true(target_matches("x86_64-elf", NativeTarget::X8664Linux))
    teko::assert::is_true(target_matches("arm64-macos", NativeTarget::Arm64Macho))
    teko::assert::is_true(target_matches("", NativeTarget::Arm64Macho))
    teko::assert::is_true(target_matches("bogus-target", NativeTarget::Arm64Macho))
}

#test
/**
 * target_from_name_maps_every_wasi_alias — `wasm32-wasi`/`wasm32`/`wasm`/
 * `wasi` all select `Wasm32Wasi` (#389 C1-5).
 *
 * @return void
 */
fn target_from_name_maps_every_wasi_alias() {
    teko::assert::is_true(target_matches("wasm32-wasi", NativeTarget::Wasm32Wasi))
    teko::assert::is_true(target_matches("wasm32", NativeTarget::Wasm32Wasi))
    teko::assert::is_true(target_matches("wasm", NativeTarget::Wasm32Wasi))
    teko::assert::is_true(target_matches("wasi", NativeTarget::Wasm32Wasi))
}

#test
/**
 * target_from_name_maps_every_wasm64_alias — `wasm64-wasi`/`wasm64` both
 * select `Wasm64Wasi` (#389 C1-7, the wasm64 switch, §6) — distinct from
 * every wasm32 alias above.
 *
 * @return void
 */
fn target_from_name_maps_every_wasm64_alias() {
    teko::assert::is_true(target_matches("wasm64-wasi", NativeTarget::Wasm64Wasi))
    teko::assert::is_true(target_matches("wasm64", NativeTarget::Wasm64Wasi))
}

#test
/**
 * target_from_name_maps_every_browser_alias — `wasm32-browser`/`wasm-
 * browser`/`browser` all select `Wasm32Browser` (#389 C1-5; its own JS-
 * import runtime binding is N6b territory, a later slice).
 *
 * @return void
 */
fn target_from_name_maps_every_browser_alias() {
    teko::assert::is_true(target_matches("wasm32-browser", NativeTarget::Wasm32Browser))
    teko::assert::is_true(target_matches("wasm-browser", NativeTarget::Wasm32Browser))
    teko::assert::is_true(target_matches("browser", NativeTarget::Wasm32Browser))
}

/**
 * args_of — build a `[]str` CLI argument vector from up to three tokens, dropping any that is "" so
 * a test can pass fewer than three. The shared fixture for the optimization-flag parse tests below.
 *
 * @param a  the first token (dropped when "")
 * @param b  the second token (dropped when "")
 * @param c  the third token (dropped when "")
 * @return   the assembled argument vector
 */
fn args_of(a: str, b: str, c: str) -> []str {
    mut v: []str = teko::list::empty()
    if a != "" { v = teko::list::push(v, a) }
    if b != "" { v = teko::list::push(v, b) }
    if c != "" { v = teko::list::push(v, c) }
    v
}

#test
/**
 * opt_cc_flag_maps_levels_to_flags — level 0 emits NO flag (""), level 1 `-O1`, level 2 `-O2`, and
 * an out-of-range level clamps to `-O2` — the exact strings `build_cc_argv` appends to the cc line.
 *
 * @return void
 */
fn opt_cc_flag_maps_levels_to_flags() {
    teko::assert::is_true(opt_cc_flag(0) == "")
    teko::assert::is_true(opt_cc_flag(1) == "-O1")
    teko::assert::is_true(opt_cc_flag(2) == "-O2")
    teko::assert::is_true(opt_cc_flag(3) == "-O2")
}

#test
/**
 * project_arg_of_skips_optimization_flags — `--release` and `--opt=<n>` are recognized build flags,
 * so `project_arg_of` steps over them and still finds the project positional after them.
 *
 * @return void
 */
fn project_arg_of_skips_optimization_flags() {
    teko::assert::is_true(project_arg_of(args_of("--release", ".", ""), 0) == ".")
    teko::assert::is_true(project_arg_of(args_of("--opt=2", ".", ""), 0) == ".")
    teko::assert::is_true(project_arg_of(args_of(".", "--release", ""), 0) == ".")
}

#test
/**
 * project_arg_of_skips_backend_flag — `project_arg_of` skips `--backend` and its value in BOTH
 * spellings, so the project positional is still found, not the flag or its argument. D1/#390.
 *
 * @return void
 */
fn project_arg_of_skips_backend_flag() {
    teko::assert::is_true(project_arg_of(args_of("--backend=native", "proj", ""), 0) == "proj")
    teko::assert::is_true(project_arg_of(args_of("--backend", "native", "proj"), 0) == "proj")
}

/** pt_push_u64le — append `v` as 8 little-endian bytes (the `.tkcov` wire form) to `b`. */
fn pt_push_u64le(b: []byte, v: u64) -> []byte {
    mut out = b
    mut x = v
    mut i: u64 = 0
    loop {
        if i >= 8 { break }
        out = teko::list::push(out, (x & 255) to byte)
        x = x >> 8
        i++
    }
    out
}

/** pt_tkcov_section — append a `.tkcov` id section (u64 count then the ids) to `b`. */
fn pt_tkcov_section(b: []byte, ids: []u64) -> []byte {
    mut out = pt_push_u64le(b, ids.len)
    mut i: u64 = 0
    loop {
        if i >= ids.len { break }
        out = pt_push_u64le(out, ids[i])
        i++
    }
    out
}

/** pt_tkcov — a well-formed `.tkcov` byte buffer (as a `str`) with the given fn/branch/line sections. */
fn pt_tkcov(fns: []u64, branches: []u64, lines: []u64) -> str {
    mut b: []byte = teko::list::empty()
    b = teko::list::push(b, b'T'); b = teko::list::push(b, b'K'); b = teko::list::push(b, b'C')
    b = teko::list::push(b, b'O'); b = teko::list::push(b, b'V'); b = teko::list::push(b, b'1')
    b = teko::list::push(b, 0 to byte); b = teko::list::push(b, 0 to byte)
    b = pt_tkcov_section(b, fns)
    b = pt_tkcov_section(b, branches)
    b = pt_tkcov_section(b, lines)
    str(b)
}

/** pt_ids — a `[]u64` from three ids (a small fixture helper). */
fn pt_ids3(a: u64, b: u64, c: u64) -> []u64 {
    teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), a), b), c)
}

/** pt_ids1 — a single-id `[]u64` fixture (the `u64` parameter forces the literal's width). */
fn pt_ids1(a: u64) -> []u64 { teko::list::push(teko::list::empty(), a) }

/** pt_ids2 — a two-id `[]u64` fixture. */
fn pt_ids2(a: u64, b: u64) -> []u64 { teko::list::push(pt_ids1(a), b) }

/** analyzer_of recognizes `--analyzer` and ignores its absence. */
#test
fn pt_analyzer_of_flag() {
    let with = teko::list::push(teko::list::push(teko::list::empty(), "test"), "--analyzer")
    teko::assert::is_true(analyzer_of(with))
    let without = teko::list::push(teko::list::empty(), "test")
    teko::assert::is_false(analyzer_of(without))
}

/** tkcov_ids merges the three sections and dedups shared ids; a bad magic yields no ids. */
#test
fn pt_tkcov_ids_merges_and_dedups() {
    let fns = pt_ids2(1, 2)
    let branches = pt_ids1(3)
    let lines = pt_ids1(1)
    let ids = tkcov_ids(pt_tkcov(fns, branches, lines))
    teko::assert::is_true(ids.len == 3)
    teko::assert::is_true(tkcov_ids("bad").len == 0)
}

/** dedup_ids keeps each id once in first-seen order; ids_contains backs it. */
#test
fn pt_dedup_ids() {
    let dup = pt_ids3(7, 7, 9)
    let uniq = dedup_ids(dup)
    teko::assert::is_true(uniq.len == 2)
    teko::assert::is_true(ids_contains(uniq, 9))
    teko::assert::is_false(ids_contains(uniq, 4))
}

/** classify_test: no ids ⇒ STALE, all shared ⇒ REDUNDANT, a unique id ⇒ LIVE. */
#test
fn pt_classify_test_axes() {
    let unique = pt_ids1(1)
    let shared_a = pt_ids1(2)
    let shared_b = pt_ids1(2)
    let all = concat_ids(concat_ids(unique, shared_a), shared_b)
    teko::assert::is_true(verdict_text(classify_test(teko::list::empty(), all)) == "STALE")
    teko::assert::is_true(verdict_text(classify_test(shared_a, all)) == "REDUNDANT")
    teko::assert::is_true(verdict_text(classify_test(unique, all)) == "LIVE")
}

/** combined_status crosses the coverage axis with the assertion-fold axis, most-severe first. */
#test
fn pt_combined_status_precedence() {
    teko::assert::is_true(status_text(combined_status(Verdict::Live, 2, 1)) == "MISLEADING")
    teko::assert::is_true(status_text(combined_status(Verdict::Stale, 2, 2)) == "FOUNDATIONAL")
    teko::assert::is_true(status_text(combined_status(Verdict::Stale, 1, 0)) == "DEAD")
    teko::assert::is_true(status_text(combined_status(Verdict::Redundant, 1, 0)) == "REDUNDANT")
    teko::assert::is_true(status_text(combined_status(Verdict::Live, 1, 0)) == "LIVE")
}

/** analyzer_report renders header, per-test lines with asserts=, and a per-status summary. */
#test
fn pt_analyzer_report_shape() {
    let unique = pt_ids1(1)
    let shared_a = pt_ids1(2)
    let shared_b = pt_ids1(2)
    mut recs: []TestRecord = teko::list::push(teko::list::empty(), TestRecord { label = "a::live"; ids = concat_ids(unique, shared_a); asserts_total = 1; asserts_folded = 0 })
    recs = teko::list::push(recs, TestRecord { label = "a::red"; ids = shared_b; asserts_total = 1; asserts_folded = 0 })
    recs = teko::list::push(recs, TestRecord { label = "a::found"; ids = teko::list::empty(); asserts_total = 1; asserts_folded = 1 })
    let report = analyzer_report(recs)
    teko::assert::is_true(teko::str::contains(report, "ADVISORY"))
    teko::assert::is_true(teko::str::contains(report, "analyzer a::live ids=2 asserts=1/0 status=LIVE"))
    teko::assert::is_true(teko::str::contains(report, "status=REDUNDANT"))
    teko::assert::is_true(teko::str::contains(report, "status=FOUNDATIONAL"))
    teko::assert::is_true(teko::str::contains(report, "1 FOUNDATIONAL"))
}
/**
 * cov_validation_of detects `--cov-validation` anywhere on the line and is absent otherwise — the
 * opt-in that flips the D4 coverage floors from a warning to a hard failure (owner ruling 0.3.0.29).
 */
#test
fn pt_cov_validation_of_detects_the_flag() {
    teko::assert::is_true(cov_validation_of(args_of("build", "--cov-validation", ".")))
    teko::assert::is_true(cov_validation_of(args_of("--cov-validation", "build", ".")))
    teko::assert::is_false(cov_validation_of(args_of("build", ".", "-o")))
    teko::assert::is_false(cov_validation_of(args_of("test", ".", "")))
}

/**
 * per_test_cov_of detects `--per-test-cov` anywhere on the line and is absent otherwise — the
 * dev-time per-test attribution knob (owner ruling 0.3.0.29 — the T2 lever), off by default.
 */
#test
fn pt_per_test_cov_of_detects_the_flag() {
    teko::assert::is_true(per_test_cov_of(args_of("test", "--per-test-cov", ".")))
    teko::assert::is_true(per_test_cov_of(args_of("--per-test-cov", "test", ".")))
    teko::assert::is_false(per_test_cov_of(args_of("test", ".", "--coverage")))
    teko::assert::is_false(per_test_cov_of(args_of("build", ".", "")))
}

/**
 * project_arg_of skips the two 0.3.0.29 coverage knobs (`--cov-validation`, `--per-test-cov`) — both
 * value-less flags — so neither is ever mistaken for the project positional.
 */
#test
fn pt_project_arg_of_skips_the_coverage_knobs() {
    teko::assert::is_true(project_arg_of(args_of("--cov-validation", ".", ""), 0) == ".")
    teko::assert::is_true(project_arg_of(args_of("--per-test-cov", ".", ""), 0) == ".")
    teko::assert::is_true(project_arg_of(args_of(".", "--cov-validation", "--per-test-cov"), 0) == ".")
}

/**
 * coverage_floor_blocks encodes the whole `--cov-validation` policy: a run BELOW a floor is a
 * non-blocking pass by default (validation off → never blocks) and a hard failure only when
 * validation is opted in; a run that MEETS every floor never blocks regardless of the flag.
 */
#test
fn pt_coverage_floor_blocks_is_opt_in() {
    let below = unmet_coverage_floors(10, 10, 10, 50, 50, 49)
    let met = unmet_coverage_floors(90, 90, 90, 50, 50, 49)
    teko::assert::is_false(coverage_floor_blocks(below, false))
    teko::assert::is_true(coverage_floor_blocks(below, true))
    teko::assert::is_false(coverage_floor_blocks(met, false))
    teko::assert::is_false(coverage_floor_blocks(met, true))
}

/**
 * per_test_cov_report_str prints the fixed header then one newline-terminated row per test, in order.
 * An empty row set yields the header alone — the report shape the `--per-test-cov` fixture asserts.
 */
#test
fn pt_per_test_cov_report_str_shape() {
    teko::assert::is_true(per_test_cov_report_str(teko::list::empty()) == "teko: per-test coverage attribution\n")
    mut rows: []PerTestCoverage = teko::list::empty()
    rows = teko::list::push(rows, PerTestCoverage { label = "a"; functions = 10; lines = 20; branches = 30 })
    rows = teko::list::push(rows, PerTestCoverage { label = "b"; functions = 1; lines = 2; branches = 3 })
    let out = per_test_cov_report_str(rows)
    teko::assert::str_contains(out, "teko: per-test coverage attribution\n")
    teko::assert::str_contains(out, "per-test-cov a functions=10% lines=20% branches=30%\n")
    teko::assert::str_contains(out, "per-test-cov b functions=1% lines=2% branches=3%\n")
}

/**
 * per_commit_base_of reads the value FOLLOWING `--per-commit-test` (the git base for the delta gate),
 * is "" when the flag is absent, and is "" when the flag is the last token with no value after it.
 */
#test
fn pt_per_commit_base_of_reads_the_value() {
    teko::assert::is_true(per_commit_base_of(args_of("test", "--per-commit-test", "abc123")) == "abc123")
    teko::assert::is_true(per_commit_base_of(args_of("--per-commit-test", "main", "test")) == "main")
    teko::assert::is_true(per_commit_base_of(args_of("test", ".", "--coverage")) == "")
    teko::assert::is_true(per_commit_base_of(args_of("test", ".", "--per-commit-test")) == "")
}

/**
 * project_arg_of skips `--per-commit-test` AND its base value (a two-token value flag), so neither the
 * flag nor the git ref that follows it is ever mistaken for the project positional.
 */
#test
fn pt_project_arg_of_skips_the_per_commit_flag() {
    teko::assert::is_true(project_arg_of(args_of("--per-commit-test", "main", "."), 0) == ".")
    teko::assert::is_true(project_arg_of(args_of(".", "--per-commit-test", "main"), 0) == ".")
}

/**
 * changed_line_set parses a unified diff into the added/replaced NEW-side line numbers per `.tks`
 * file: a context line advances the new-side counter, a `+` line records the current number and
 * advances, and the `@@` header (re)seeds it — so `changed_contains` answers membership tolerant of a
 * repo-relative vs project-relative path (a `/`-boundary suffix match).
 */
#test
fn pt_changed_line_set_parses_added_lines() {
    let diff = "diff --git a/src/x.tks b/src/x.tks\n--- a/src/x.tks\n+++ b/src/x.tks\n@@ -1,3 +1,4 @@\n ctx\n+added2\n+added3\n ctx4\n"
    let cls = changed_line_set(diff)
    teko::assert::is_true(changed_contains(cls, "src/x.tks", 2))
    teko::assert::is_true(changed_contains(cls, "src/x.tks", 3))
    teko::assert::is_false(changed_contains(cls, "src/x.tks", 1))
    teko::assert::is_false(changed_contains(cls, "src/x.tks", 4))
    teko::assert::is_true(changed_contains(cls, "x.tks", 2))
    teko::assert::is_false(changed_contains(cls, "other.tks", 2))
}

/**
 * cov_lines_from_cobertura reads one CovLine per BODY `<line>` element, taking the file from the
 * enclosing `<class filename=…>` and hit from `hits > 0`, and SKIPS the per-method summary `<line>`
 * (on the `<methods>` line) so a function's declaration line is not double-counted.
 */
#test
fn pt_cov_lines_from_cobertura_reads_body_lines() {
    let xml = "      <class name='ns::f' filename='src/x.tks' line-rate='0.5' branch-rate='1.0' complexity='0'>\n        <methods><method name='f' signature='()V' line-rate='0.5' branch-rate='1.0'><lines><line number='10' hits='1'/></lines></method></methods>\n        <lines>\n          <line number='11' hits='1'/>\n          <line number='12' hits='0'/>\n        </lines>\n      </class>\n"
    let cov = cov_lines_from_cobertura(xml)
    teko::assert::is_true(cov.len == 2)
    teko::assert::is_true(cov[0].file == "src/x.tks")
    teko::assert::is_true(cov[0].line == 11)
    teko::assert::is_true(cov[0].hit)
    teko::assert::is_true(cov[1].line == 12)
    teko::assert::is_false(cov[1].hit)
}

/**
 * A synthetic changed-line set + coverage map fully exercise delta_line_coverage: only lines that are
 * BOTH executable and changed count toward the denominator, and only the covered ones toward the
 * numerator (unchanged lines and other-file lines are excluded) — here 1 of 2 changed lines is hit.
 */
#test
fn pt_delta_line_coverage_attributes_only_changed_lines() {
    mut files: []ChangedFile = teko::list::empty()
    files = teko::list::push(files, ChangedFile { path = "src/x.tks"; lines = teko::list::push(teko::list::push(teko::list::empty(), 2 to u32), 3 to u32) })
    let cls = ChangedLines { files = files }
    mut cov: []CovLine = teko::list::empty()
    cov = teko::list::push(cov, CovLine { file = "src/x.tks"; line = 2 to u32; hit = true })
    cov = teko::list::push(cov, CovLine { file = "src/x.tks"; line = 3 to u32; hit = false })
    cov = teko::list::push(cov, CovLine { file = "src/x.tks"; line = 9 to u32; hit = true })
    cov = teko::list::push(cov, CovLine { file = "other.tks"; line = 2 to u32; hit = true })
    let d = delta_line_coverage(cov, cls)
    teko::assert::is_true(d.cov == 1)
    teko::assert::is_true(d.val == 2)
    teko::assert::is_true(delta_pct(d) == 50)
}

/**
 * delta_pct is vacuously 100% when nothing executable changed (an empty denominator) — a commit that
 * touched no measurable code has nothing to prove, so the gate must never block it.
 */
#test
fn pt_delta_pct_empty_is_vacuously_full() {
    teko::assert::is_true(delta_pct(DeltaCoverage { cov = 0; val = 0 }) == 100)
    teko::assert::is_true(delta_pct(DeltaCoverage { cov = 3; val = 4 }) == 75)
}

/**
 * delta_floor_blocks encodes the whole per-commit warn-vs-fail policy: a below-floor delta is a
 * non-blocking pass by default (validation off) and a hard failure only under `--cov-validation`; a
 * delta at or above the floor never blocks regardless of the flag (owner ruling 0.3.0.29 / #19).
 */
#test
fn pt_delta_floor_blocks_is_opt_in() {
    teko::assert::is_false(delta_floor_blocks(50, 80, false))
    teko::assert::is_true(delta_floor_blocks(50, 80, true))
    teko::assert::is_false(delta_floor_blocks(80, 80, true))
    teko::assert::is_false(delta_floor_blocks(100, 50, true))
}

/**
 * per_commit_report_str renders the stable, greppable one-line delta report the CI log parses:
 * the base ref, the delta percentage, and the covered/total changed-line counts.
 */
#test
fn pt_per_commit_report_str_shape() {
    let line = per_commit_report_str("origin/main", DeltaCoverage { cov = 3; val = 4 })
    teko::assert::is_true(line == "teko: per-commit delta coverage (base origin/main): 75% (3/4) of changed executable lines covered")
}
