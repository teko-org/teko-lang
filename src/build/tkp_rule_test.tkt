// src/build/tkp_rule_test.tkt — tests for teko::build. #test collected.

// does the rule hold for (artifact, has_main)?
fn rule_ok(artifact: Artifact, has_main: bool) -> bool {
    match check_main_file_rule(artifact, has_main) { Artifact => true; error => false }
}

#test
fn enforces_main_file_rule() {
    // (C7.1m) a Binary REQUIRES a main; the library kinds (Static/Shared/Package) FORBID one.
    teko::assert::is_true(rule_ok(Artifact::Binary, true))   // binary + main → ok
    teko::assert::is_false(rule_ok(Artifact::Binary, false))   // binary + no main → error
    teko::assert::is_true(rule_ok(Artifact::Static, false))   // static lib + no main → ok
    teko::assert::is_false(rule_ok(Artifact::Static, true))   // static lib + main → error
    teko::assert::is_true(rule_ok(Artifact::Shared, false))   // shared lib + no main → ok
    teko::assert::is_true(rule_ok(Artifact::Package, false))   // package + no main → ok
    teko::assert::is_false(rule_ok(Artifact::Package, true))   // package + main → error
}

// C7.9: verify the has_main detection logic — a file path ending in "main.tks" triggers the
// rule. This mirrors the loop in frontend_body (project.tks) and driver.c::frontend_body.
#test
fn has_main_detection_matches_ends_with_main_tks() {
    // a path ending in "main.tks" (bare or with a leading dir component) → detected as main
    teko::assert::is_true(teko::str::ends_with("main.tks", "main.tks"))
    teko::assert::is_true(teko::str::ends_with("src/main.tks", "main.tks"))
    // a path that does NOT end in "main.tks" → not detected
    teko::assert::is_false(teko::str::ends_with("src/lexer/lexer.tks", "main.tks"))
    teko::assert::is_false(teko::str::ends_with("main.tkt", "main.tks"))
    // the rule is consistent: Binary + detected main → ok; without main → error
    teko::assert::is_true(rule_ok(Artifact::Binary, teko::str::ends_with("main.tks", "main.tks")))
    teko::assert::is_false(rule_ok(Artifact::Binary, teko::str::ends_with("lexer.tks", "main.tks")))
}
