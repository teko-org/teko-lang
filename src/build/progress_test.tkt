/**
 * Build a `[]str` CLI argument vector from up to three tokens, dropping any that is
 * "" so a test can pass fewer than three. Mirrors `project_test.tkt`/`help_test.tkt`'s
 * own `args_of` fixtures, scoped to this file's observability-flag tests.
 *
 * @param a  the first token (dropped when "")
 * @param b  the second token (dropped when "")
 * @param c  the third token (dropped when "")
 * @return   the assembled argument vector
 */
fn progress_args_of(a: str, b: str, c: str) -> []str {
    mut v: []str = teko::list::empty()
    if a != "" { v = teko::list::push(v, a) }
    if b != "" { v = teko::list::push(v, b) }
    if c != "" { v = teko::list::push(v, c) }
    v
}

/**
 * `no_tty_of` detects `--no-tty` anywhere on the line, and does not mistake an
 * unrelated flag or a bare project argument for it.
 */
#test
fn no_tty_of_detects_the_flag() {
    teko::assert::is_true(no_tty_of(progress_args_of("teko", "build", "--no-tty")))
    teko::assert::is_true(no_tty_of(progress_args_of("teko", "--no-tty", "build")))
    teko::assert::is_false(no_tty_of(progress_args_of("teko", "build", ".")))
    teko::assert::is_false(no_tty_of(progress_args_of("teko", "", "")))
}

/**
 * `--no-tty` is a manual OVERRIDE that always forces the plain, non-interactive
 * output — regardless of what the env-based heuristic would otherwise decide. This
 * is the cheap, environment-independent half of the contract (the CI/TERM-reading
 * half depends on the process environment and is exercised manually, not here).
 */
#test
fn output_is_tty_no_tty_override_forces_plain() {
    teko::assert::is_false(output_is_tty(true))
}

/**
 * `project_arg_of` skips a `--no-tty` flag (wherever it sits) rather than mistaking
 * it for the project positional argument.
 */
#test
fn project_arg_of_skips_no_tty() {
    teko::assert::is_true(project_arg_of(progress_args_of("teko", "--no-tty", "."), 1) == ".")
    teko::assert::is_true(project_arg_of(progress_args_of("teko", ".", "--no-tty"), 1) == ".")
}

/**
 * `count_unit_text`/`count_only_text`/`size_text` render the exact shapes the
 * observability phases compose their lines from.
 */
#test
fn counter_and_size_text_render_expected_shapes() {
    teko::assert::is_true(count_unit_text(122, 122, "files") == "122/122 files")
    teko::assert::is_true(count_only_text(1204, "instances") == "1204 instances")
    teko::assert::is_true(size_text(8800000) == "(8.3 MB)")
}

/**
 * `report_mode` resolves the three phase-render states from the (quiet, tty) axes:
 * `quiet` always wins as `Quiet` (regardless of `tty`); otherwise a terminal is
 * `Tty` and a non-interactive destination (CI/pipe/redirect) is `Plain` — the state
 * that makes a phase announce at its START, closing the silent inter-phase gap.
 */
#test
fn report_mode_resolves_the_three_states() {
    teko::assert::is_true(report_mode(true, true) == Report::Quiet)
    teko::assert::is_true(report_mode(true, false) == Report::Quiet)
    teko::assert::is_true(report_mode(false, true) == Report::Tty)
    teko::assert::is_true(report_mode(false, false) == Report::Plain)
}
