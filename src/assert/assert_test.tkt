// src/assert/assert_test.tkt — tests for teko::assert. #test collected (no `main`).
//
// Uses the universal `teko::assert::is_true` convention (like every other `.tkt` in the
// corpus), so the D2 runner (`teko test`) executes these on the VM. The bare-`assert`
// keyword form was retired here: only this file used it, and a dedicated `assert` statement
// is not part of the seed grammar (the test surface is `teko::assert::*`).
//
// NOTE (M.3): the barrier (panic) cases are asserted via their NEGATION here — a failed
// `is_true` PANICS (fail-fast), which the runner reports as the failing test. The fail-path
// is also verified end-to-end through the native pipeline.

// is_true(c) must hold exactly when c is true.
#test
fn is_true_holds_on_true() {
    teko::assert::is_true(1 < 2)   // the predicate accepts a true condition
    teko::assert::is_true(!(2 < 1))   // ...and its negation is also true
}

// is_false(c) must hold exactly when c is false.
#test
fn is_false_holds_on_false() {
    teko::assert::is_false(2 < 1)   // is_false accepts (2 < 1) — it is false
    teko::assert::is_false(!(1 < 2))   // ...and !(1 < 2) is false too
}

// str_contains(hay, needle): needle ⊆ hay (byte substring); empty needle always holds.
#test
fn str_contains_finds_substring() {
    teko::assert::is_true(teko::str::contains("hello", "ell"))   // present
    teko::assert::is_true(teko::str::contains("hello", ""))   // empty needle ⊆ any
    teko::assert::is_true(!teko::str::contains("hello", "xyz"))   // absent
}
