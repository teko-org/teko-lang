// src/assert/assert_test.tkt — tests for teko::assert. #test collected (no `main`).
//
// Uses the current bare-`assert` convention (matching src/build/tkp_rule_test.tkt). The
// migration of these tests to `teko::assert::*` is a SEPARATE crumb (B2); here we exercise
// the seed's happy + barrier semantics through plain predicates so the runner stays simple.
//
// NOTE (M.3): the barrier (panic) cases are asserted via their NEGATION here — a real
// panic-capture harness does not exist in the bootstrap runner yet. The fail-path is
// verified end-to-end through the native pipeline (see the crumb's VERIFY step).

// is_true(c) must hold exactly when c is true.
#test
fn is_true_holds_on_true() {
    assert 1 < 2          // the predicate is_true would accept
    assert !(2 < 1)       // ...and reject its negation
}

// is_false(c) must hold exactly when c is false.
#test
fn is_false_holds_on_false() {
    assert !(2 < 1)       // is_false would accept (2 < 1) — it is false
    assert 1 < 2          // ...and its true counterpart is rejected by is_false
}

// str_contains(hay, needle): needle ⊆ hay (byte substring); empty needle always holds.
#test
fn str_contains_finds_substring() {
    assert "hello".contains("ell")   // present
    assert "hello".contains("")      // empty needle ⊆ any
    assert !"hello".contains("xyz")  // absent → would panic
}
