/**
 * Tests for `teko::crypto::hash` (C1, issue #194): SHA-256 and SHA-512 against the FIPS 180-4
 * / NIST known-answer vectors. Pure Teko, VM-runnable (no extern), so every case gates BOTH
 * engines. This file lives under `teko::crypto` (namespace = directory), so the functions
 * under test are called bare, mirroring `teko::math::checked_test.tkt`'s convention.
 *
 * SHA-256 of the empty message — the canonical "hash of nothing" vector every implementation
 * is checked against first.
 */
#test
fn sha256_of_empty_message() {
    teko::assert::is_true(sha256_hex_of(bytes_of_str("")) == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")
}

/**
 * SHA-256("abc") — the single most-cited SHA-2 test vector (FIPS 180-4 Appendix B.1), a
 * one-block message (3 bytes, well under the 64-byte block size).
 */
#test
fn sha256_of_abc() {
    teko::assert::is_true(sha256_hex_of(bytes_of_str("abc")) == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
}

/**
 * SHA-256 of the FIPS 180-4 Appendix B.2 two-block message (56 bytes) — exercises the padding
 * edge where the `0x80` marker + zero pad + 8-byte length suffix must spill into a SECOND
 * 64-byte block (56 + 1 leaves only 7 bytes, one short of the 8-byte length field).
 */
#test
fn sha256_of_two_block_message() {
    let msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    teko::assert::is_true(sha256_hex_of(bytes_of_str(msg)) == "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1")
}

/**
 * SHA-256 of a 200-byte message — several WHOLE blocks (3 full 64-byte blocks plus an 8-byte
 * remainder) followed by its own padding block, exercising `sha256_update`'s multi-block
 * absorption loop directly (not just the single-shot `sha2_pad` edge above).
 */
#test
fn sha256_of_multi_block_message() {
    mut msg = ""
    mut i = 0
    loop {
        if i >= 200 { break }
        msg = teko::str::concat(msg, "a")
        i++
    }
    teko::assert::is_true(sha256_hex_of(bytes_of_str(msg)) == "c2a908d98f5df987ade41b5fce213067efbcc21ef2240212a41e54b5e7c28ae5")
}

/**
 * Streaming `sha256_update` in several separate calls produces the SAME digest as the
 * one-shot `sha256_of` over the concatenated message — the incremental API's core contract.
 */
#test
fn sha256_incremental_matches_one_shot() {
    let incremental = sha256_finalize(sha256_update(sha256_update(sha256_init(), bytes_of_str("a")), bytes_of_str("bc")))
    teko::assert::is_true(to_hex(incremental) == sha256_hex_of(bytes_of_str("abc")))
}

/**
 * Streaming `sha256_update` fed ONE BYTE AT A TIME still matches the one-shot digest — the
 * strictest incremental-vs-one-shot exercise (every buffered-tail/block-boundary transition
 * the streaming state machine can hit on this message length).
 */
#test
fn sha256_incremental_byte_at_a_time_matches_one_shot() {
    let msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    let bytes = bytes_of_str(msg)
    mut state = sha256_init()
    mut i: u64 = 0
    loop {
        if i >= bytes.len { break }
        let one = teko::list::push(teko::list::empty(), bytes[i])
        state = sha256_update(state, one)
        i++
    }
    teko::assert::is_true(to_hex(sha256_finalize(state)) == sha256_hex_of(bytes))
}

/**
 * SHA-512 of the empty message.
 */
#test
fn sha512_of_empty_message() {
    teko::assert::is_true(sha512_hex_of(bytes_of_str("")) == "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")
}

/**
 * SHA-512("abc") — FIPS 180-4 Appendix C.1, a one-block message (3 bytes, well under the
 * 128-byte SHA-512 block size).
 */
#test
fn sha512_of_abc() {
    teko::assert::is_true(sha512_hex_of(bytes_of_str("abc")) == "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f")
}

/**
 * SHA-512 of a 200-byte message — exceeds one 128-byte block, exercising `sha512_update`'s
 * multi-block absorption loop and the 128-bit length suffix's zero high-64-bits invariant.
 */
#test
fn sha512_of_multi_block_message() {
    mut msg = ""
    mut i = 0
    loop {
        if i >= 200 { break }
        msg = teko::str::concat(msg, "a")
        i++
    }
    teko::assert::is_true(sha512_hex_of(bytes_of_str(msg)) == "4b11459c33f52a22ee8236782714c150a3b2c60994e9acee17fe68947a3e6789f31e7668394592da7bef827cddca88c4e6f86e4df7ed1ae6cba71f3e98faee9f")
}

/**
 * Streaming `sha512_update` in several separate calls produces the SAME digest as the
 * one-shot `sha512_of` over the concatenated message.
 */
#test
fn sha512_incremental_matches_one_shot() {
    let incremental = sha512_finalize(sha512_update(sha512_update(sha512_init(), bytes_of_str("a")), bytes_of_str("bc")))
    teko::assert::is_true(to_hex(incremental) == sha512_hex_of(bytes_of_str("abc")))
}
