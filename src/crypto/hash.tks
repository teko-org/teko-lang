/**
 * Creates a fresh SHA-512 state (the FIPS 180-4 initial hash values, no buffered input,
 * zero total length) ‚Äî the starting point for a streaming `sha512_update`/`sha512_finalize`
 * sequence.
 *
 * @return  a fresh `Sha512State` ready to accept message bytes
 */
pub fn sha512_init() -> Sha512State {
    Sha512State { h = sha512_iv(); pending = teko::list::empty(); total_len = 0 }
}

/**
 * Compresses one 128-byte block into `h` (FIPS 180-4 ¬ß6.4.2) ‚Äî builds the 80-word message
 * schedule, then runs the 80 compression rounds, then feeds the working variables back
 * into `h` via modular addition.
 *
 * @param h      the eight current state words `h0..h7`
 * @param block  the 128-byte block to absorb
 * @return       the updated eight state words after this block
 */
fn sha512_compress(h: []u64, block: []byte) -> []u64 {
    mut w: []u64 = teko::list::empty()
    mut t: u64 = 0
    loop {
        if t >= 16 { break }
        w = teko::list::push(w, be_u64_at(block, t * 8))
        t++
    }
    loop {
        if t >= 80 { break }
        let w15 = w[t - 15]
        let w2 = w[t - 2]
        let s0 = rotr64(w15, 1) ^ rotr64(w15, 8) ^ (w15 >> 7)
        let s1 = rotr64(w2, 19) ^ rotr64(w2, 61) ^ (w2 >> 6)
        let sum = teko::math::wrapping_add_u64(teko::math::wrapping_add_u64(w[t - 16], s0), teko::math::wrapping_add_u64(w[t - 7], s1))
        w = teko::list::push(w, sum)
        t++
    }
    let k = sha512_k()
    mut a = h[0]
    mut b = h[1]
    mut c = h[2]
    mut d = h[3]
    mut e = h[4]
    mut f = h[5]
    mut g = h[6]
    mut hh = h[7]
    mut i: u64 = 0
    loop {
        if i >= 80 { break }
        let s1 = rotr64(e, 14) ^ rotr64(e, 18) ^ rotr64(e, 41)
        let ch = (e & f) ^ ((~e) & g)
        let temp1 = teko::math::wrapping_add_u64(teko::math::wrapping_add_u64(teko::math::wrapping_add_u64(hh, s1), ch), teko::math::wrapping_add_u64(k[i], w[i]))
        let s0 = rotr64(a, 28) ^ rotr64(a, 34) ^ rotr64(a, 39)
        let maj = (a & b) ^ (a & c) ^ (b & c)
        let temp2 = teko::math::wrapping_add_u64(s0, maj)
        hh = g
        g = f
        f = e
        e = teko::math::wrapping_add_u64(d, temp1)
        d = c
        c = b
        b = a
        a = teko::math::wrapping_add_u64(temp1, temp2)
        i++
    }
    mut out: []u64 = teko::list::empty()
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[0], a))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[1], b))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[2], c))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[3], d))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[4], e))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[5], f))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[6], g))
    out = teko::list::push(out, teko::math::wrapping_add_u64(h[7], hh))
    out
}

/**
 * Feeds `data` into an in-progress SHA-512 computation: joins it with any buffered tail,
 * compresses every complete 128-byte block, and buffers the shorter remainder for the next
 * call (or `sha512_finalize`). May be called any number of times before finalizing ‚Äî
 * `sha512_of(m)` is equivalent to `sha512_finalize(sha512_update(sha512_init(), m))`.
 *
 * @param state  the state to advance
 * @param data   the next chunk of message bytes
 * @return       the updated state after absorbing every complete block in `data`
 */
pub fn sha512_update(state: Sha512State, data: []byte) -> Sha512State {
    let joined = bytes_concat(state.pending, data)
    mut h = state.h
    mut off: u64 = 0
    loop {
        if joined.len - off < 128 { break }
        h = sha512_compress(h, bytes_slice(joined, off, off + 128))
        off = off + 128
    }
    Sha512State { h = h; pending = bytes_slice(joined, off, joined.len); total_len = state.total_len + data.len }
}

/**
 * Completes a SHA-512 computation: pads the buffered tail (a 128-bit length suffix, per
 * FIPS 180-4 ¬ß5.1.2 ‚Äî the top 64 bits are always zero since a `u64` byte count times 8
 * bits never overflows 64 bits), compresses the resulting final block(s), and renders the
 * eight state words as 64 big-endian bytes (the 512-bit digest).
 *
 * @param state  the state after every `sha512_update` call for this message
 * @return       the 64-byte SHA-512 digest
 */
pub fn sha512_finalize(state: Sha512State) -> []byte {
    let padded = sha2_pad(state.pending, state.total_len, true)
    mut h = state.h
    mut off: u64 = 0
    loop {
        if off >= padded.len { break }
        h = sha512_compress(h, bytes_slice(padded, off, off + 128))
        off = off + 128
    }
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= h.len { break }
        out = push_be_u64(out, h[i])
        i++
    }
    out
}

/**
 * One-shot SHA-512: hashes the whole of `data` in a single call. Equivalent to
 * `sha512_finalize(sha512_update(sha512_init(), data))`.
 *
 * @param data  the complete message to hash
 * @return      the 64-byte SHA-512 digest
 */
pub fn sha512_of(data: []byte) -> []byte {
    sha512_finalize(sha512_update(sha512_init(), data))
}

/**
 * `sha512_of`, rendered as a lowercase hex string ‚Äî the form every published known-answer
 * vector uses.
 *
 * @param data  the complete message to hash
 * @return      the SHA-512 digest of `data` as 128 lowercase hex characters
 */
pub fn sha512_hex_of(data: []byte) -> str {
    teko::crypto::to_hex(sha512_of(data))
}
