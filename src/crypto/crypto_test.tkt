/**
 * Tests for `teko::crypto` core (C0, issue #194): `crypto_error`, `ct_eq`, and `to_hex`. Pure
 * Teko, VM-runnable (no extern), so every case gates BOTH engines. This file lives under
 * `teko::crypto` (namespace = directory), so the functions under test are called bare,
 * mirroring `teko::math::checked_test.tkt`'s convention.
 *
 * `crypto_error` wraps its `reason` string verbatim into the `message` field.
 */
#test
fn crypto_error_carries_message() {
    let e = crypto_error("bad key length")
    teko::assert::is_true(e.message == "bad key length")
}
