/**
 * Tests for `teko::crypto` core (C0, issue #194): `crypto_error`, `ct_eq`, and `to_hex`. Pure
 * Teko, VM-runnable (no extern), so every case gates BOTH engines. This file lives under
 * `teko::crypto` (namespace = directory), so the functions under test are called bare,
 * mirroring `teko::math::checked_test.tkt`'s convention.
 *
 * `crypto_error` wraps its `reason` string verbatim into the `message` field.
 */
#test
fn crypto_error_carries_message() {
    let e = crypto_error("bad key length")
    teko::assert::is_true(e.message == "bad key length")
}

/**
 * `ct_eq` reports equal for identical byte content, including the empty slice, and rejects
 * both a length mismatch and a single differing byte anywhere in the slice (not just the
 * first or last position — the whole-slice scan must not short-circuit).
 */
#test
fn ct_eq_matches_identical_and_empty() {
    teko::assert::is_true(ct_eq(bytes_of_str(""), bytes_of_str("")))
    teko::assert::is_true(ct_eq(bytes_of_str("secret"), bytes_of_str("secret")))
}

/**
 * `ct_eq` rejects a length mismatch immediately (the lengths are not secret).
 */
#test
fn ct_eq_rejects_length_mismatch() {
    teko::assert::is_false(ct_eq(bytes_of_str("short"), bytes_of_str("longer")))
}

/**
 * `ct_eq` rejects a single differing byte at the FIRST position, the LAST position, and the
 * MIDDLE — the whole-slice OR-fold must catch a mismatch anywhere, not just where a naive
 * short-circuit compare would stop first.
 */
#test
fn ct_eq_rejects_any_single_byte_difference() {
    teko::assert::is_false(ct_eq(bytes_of_str("Aecret"), bytes_of_str("secret")))
    teko::assert::is_false(ct_eq(bytes_of_str("secreA"), bytes_of_str("secret")))
    teko::assert::is_false(ct_eq(bytes_of_str("seAret"), bytes_of_str("secret")))
}

/**
 * `to_hex` renders the empty slice as the empty string, and a known byte sequence as its
 * lowercase two-digit-per-byte hex form (including a leading-zero nibble, which a naive
 * single-digit renderer would drop).
 */
#test
fn to_hex_renders_known_bytes() {
    teko::assert::is_true(to_hex(bytes_of_str("")) == "")
    teko::assert::is_true(to_hex(bytes_of_str("abc")) == "616263")
}

/**
 * `to_hex` renders a byte with its high nibble zero (e.g. `0x0f`) as `"0f"`, not `"f"` — the
 * two-digit-per-byte invariant every KAT vector depends on.
 */
#test
fn to_hex_pads_leading_zero_nibble() {
    let one_byte = teko::list::push(teko::list::empty(), 0x0f to byte)
    teko::assert::is_true(to_hex(one_byte) == "0f")
    let hi_byte = teko::list::push(teko::list::empty(), 0xf0 to byte)
    teko::assert::is_true(to_hex(hi_byte) == "f0")
}
