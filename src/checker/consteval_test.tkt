use teko::parser
use teko::lexer

/**
 * f64t — the `f64` primitive type, the result type of the Tier-5 `f64_from_bits` fixture.
 *
 * @return the `f64` primitive type
 */
fn f64t() -> Type { Prim { kind = PrimKind::F64 } }

/**
 * te — wrap a typed-expression kind and its resolved type into a positioned `TExpr` at line 1.
 *
 * @param k  the typed expression kind
 * @param t  the resolved type
 * @return   the positioned `TExpr`
 */
fn te(k: TExprKind, t: Type) -> TExpr { TExpr { kind = k; type = t; line = 1; col = 1 } }

/**
 * c_num — an `i64` number-literal typed expression (Tier 0).
 *
 * @param v  the integer value (i128 carrier, like the parser's Number)
 * @return   the typed number literal
 */
fn c_num(v: i128) -> TExpr { te(TNumber { is_float = false; value = v; fval = 0.0 }, i64t()) }

/**
 * seg — a single path segment naming `name`.
 *
 * @param name  the segment identifier
 * @return      the segment
 */
fn seg(name: str) -> parser::Segment { parser::Segment { name = name } }

/**
 * path2 — a two-segment `a::b` path.
 *
 * @param a  the first segment's name
 * @param b  the last segment's name
 * @return   the two-segment path
 */
fn path2(a: str, b: str) -> parser::Path {
    mut segs: []parser::Segment = teko::list::push(teko::list::empty(), seg(a))
    segs = teko::list::push(segs, seg(b))
    parser::Path { segments = segs }
}

/**
 * path3 — a three-segment `a::b::c` path.
 *
 * @param a  the first segment's name
 * @param b  the middle segment's name
 * @param c  the last segment's name
 * @return   the three-segment path
 */
fn path3(a: str, b: str, c: str) -> parser::Path {
    mut segs: []parser::Segment = teko::list::push(teko::list::empty(), seg(a))
    segs = teko::list::push(segs, seg(b))
    segs = teko::list::push(segs, seg(c))
    parser::Path { segments = segs }
}

/**
 * a_call — a typed call expression with the given callee and argument list, defaulting the fields
 * irrelevant to the const-expr gate.
 *
 * @param callee  the callee path
 * @param args    the typed arguments
 * @param t       the call's result type
 * @return        the typed call expression
 */
fn a_call(callee: parser::Path, args: []TExpr, t: Type) -> TExpr {
    te(TCall { callee = callee; args = args; call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }, t)
}

/**
 * accepts — assert that `is_const_expr` accepts `e` (returns null) in the empty environment.
 *
 * @param e  the typed expression that must be a legal const initializer
 */
fn accepts(e: TExpr) {
    match is_const_expr(e, empty_table(), empty_env()) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

/**
 * rejects — assert that `is_const_expr` rejects `e` (returns an error) in the empty environment.
 *
 * @param e  the typed expression that must NOT be a legal const initializer
 */
fn rejects(e: TExpr) {
    match is_const_expr(e, empty_table(), empty_env()) { error => teko::assert::is_true(true); null => teko::assert::is_true(false) }
}

/**
 * const_expr_tier0_literals — Tier 0: int / bool literals are legal const initializers.
 */
#test
fn const_expr_tier0_literals() {
    accepts(c_num(127))
    accepts(te(TBoolLit { value = true }, boolt()))
    accepts(te(TStrLit { text = "hi" }, Str { }))
    accepts(te(TByteLit { value = b'A' }, Byte { }))
}

/**
 * const_expr_tier1_cast — Tier 1: `<const-expr> to T` is a legal const initializer.
 */
#test
fn const_expr_tier1_cast() {
    accepts(te(TCast { expr = c_num(0) }, u8t()))
}

/**
 * const_expr_tier2_ops — Tier 2: `~`, unary `-`, and a binary bitwise/arithmetic op over
 * const-exprs are legal; a comparison operator is rejected.
 */
#test
fn const_expr_tier2_ops() {
    accepts(te(TUnary { op = lexer::TokenKind::Tilde; operand = c_num(0) }, i64t()))
    accepts(te(TUnary { op = lexer::TokenKind::Minus; operand = c_num(1) }, i64t()))
    accepts(te(TBinary { op = lexer::TokenKind::Plus; left = c_num(1); right = c_num(2) }, i64t()))
    accepts(te(TBinary { op = lexer::TokenKind::Shl; left = c_num(1); right = c_num(8) }, i64t()))
    rejects(te(TBinary { op = lexer::TokenKind::AndAnd; left = c_num(1); right = c_num(0) }, boolt()))
}

/**
 * const_expr_tier3_const_ref — Tier 3: a bare name resolving to a module-level const is legal; a
 * reference to an enum/flags member (a `TPathExpr`) is legal.
 */
#test
fn const_expr_tier3_const_ref() {
    let env = define_const(empty_env(), "MAX", i64t(), "teko::checker", parser::Visibility::Pub)
    let v = te(TVar { name = "MAX"; is_func = false; func_ns = "" }, i64t())
    match is_const_expr(v, empty_table(), env) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    accepts(te(TPathExpr { enum_name = "Color"; member = "Red"; ordinal = 0; value = 0 }, Named { name = "Color" }))
}

/**
 * const_expr_tier4_aggregates — Tier 4: an array literal and a struct literal of const-exprs are
 * legal; a struct literal with a non-const field is rejected.
 */
#test
fn const_expr_tier4_aggregates() {
    mut elems: []TArrayElem = teko::list::push(teko::list::empty(), TArrayElem { is_spread = false; expr = c_num(31) })
    elems = teko::list::push(elems, TArrayElem { is_spread = false; expr = c_num(139) })
    accepts(te(TArrayLit { elements = elems }, Slice { element = i64t() }))

    mut names: []str = teko::list::push(teko::list::empty(), "a")
    names = teko::list::push(names, "b")
    mut vals: []TExpr = teko::list::push(teko::list::empty(), c_num(1))
    vals = teko::list::push(vals, c_num(2))
    accepts(te(TStructInit { field_names = names; field_vals = vals }, Named { name = "P" }))
}

/**
 * const_expr_tier5_allowlisted_call — Tier 5: a call to an allowlisted pure constructor
 * (`preg`, `teko::f64_from_bits`) over const-expr args is legal.
 */
#test
fn const_expr_tier5_allowlisted_call() {
    mut pregs: []TExpr = teko::list::push(teko::list::empty(), c_num(0))
    pregs = teko::list::push(pregs, c_num(0))
    accepts(a_call(path1("preg"), pregs, Named { name = "MReg" }))

    let bits: []TExpr = teko::list::push(teko::list::empty(), c_num(0))
    accepts(a_call(path2("teko", "f64_from_bits"), bits, f64t()))
}

/**
 * const_expr_rejects_non_allowlisted_call — a call to a callee NOT on the allowlist is rejected.
 */
#test
fn const_expr_rejects_non_allowlisted_call() {
    let none: []TExpr = teko::list::empty()
    rejects(a_call(path1("foo"), none, i64t()))
}

/**
 * const_expr_rejects_io_form — an I/O call (`teko::io::println`) is rejected: not allowlisted.
 */
#test
fn const_expr_rejects_io_form() {
    let arg: []TExpr = teko::list::push(teko::list::empty(), te(TStrLit { text = "x" }, Str { }))
    rejects(a_call(path3("teko", "io", "println"), arg, Void { }))
}

/**
 * const_expr_rejects_non_const_ref — a reference to a non-const (`mut`) value is rejected.
 */
#test
fn const_expr_rejects_non_const_ref() {
    let env = define(empty_env(), "x", i64t(), true)
    let v = te(TVar { name = "x"; is_func = false; func_ns = "" }, i64t())
    match is_const_expr(v, empty_table(), env) { error => teko::assert::is_true(true); null => teko::assert::is_true(false) }
}

/**
 * const_expr_rejects_control_flow — a `null` literal (no Tier admits it) is rejected.
 */
#test
fn const_expr_rejects_control_flow() {
    rejects(te(TNullLit { }, i64t()))
}

/**
 * allowlist_accepts_the_three — `is_const_allowlisted_callee` accepts exactly the closed set.
 */
#test
fn allowlist_accepts_the_three() {
    teko::assert::is_true(is_const_allowlisted_callee(path2("teko", "f64_from_bits")))
    teko::assert::is_true(is_const_allowlisted_callee(path2("teko", "f32_from_bits")))
    teko::assert::is_true(is_const_allowlisted_callee(path1("preg")))
}

/**
 * allowlist_rejects_other — `is_const_allowlisted_callee` rejects a callee outside the closed set.
 */
#test
fn allowlist_rejects_other() {
    teko::assert::is_false(is_const_allowlisted_callee(path1("foo")))
    teko::assert::is_false(is_const_allowlisted_callee(path2("teko", "malloc")))
}

/**
 * c_ref — an `i64` bare-name reference typed expression (a Tier-3 const reference in a fixture),
 * stamped with `func_ns = ns` — the SAME namespace `type_var` would have resolved the reference to
 * (#594 crumb 8b), so the dependency-graph and inliner fixtures key on a real `(name, ns)` pair
 * rather than an empty sentinel namespace.
 *
 * @param name  the referenced const's name
 * @param ns    the namespace the reference resolves to (the referenced const's declaring namespace)
 * @return      the typed variable reference
 */
fn c_ref(name: str, ns: str) -> TExpr { te(TVar { name = name; is_func = false; func_ns = ns }, i64t()) }

/**
 * c_const — a private `i64` module-level TConstDecl named `name` with initializer `init`, for the
 * dependency-order fixtures.
 *
 * @param name  the constant's name
 * @param init  its typed initializer
 * @return      the typed constant declaration
 */
fn c_const(name: str, init: TExpr) -> TConstDecl {
    TConstDecl { name = name; namespace = "teko::checker"; ty = i64t(); init = init; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
}

/**
 * const_dep_order_orders_dep_before_dependent — `const B = A + 1; const A = 1` orders A ahead of B
 * (a Tier-3 reference makes B depend on A), even though B is declared first.
 */
#test
fn const_dep_order_orders_dep_before_dependent() {
    let a = c_const("A", c_num(1))
    let b = c_const("B", te(TBinary { op = lexer::TokenKind::Plus; left = c_ref("A", "teko::checker"); right = c_num(1) }, i64t()))
    mut consts: []TConstDecl = teko::list::push(teko::list::empty(), b)
    consts = teko::list::push(consts, a)
    match const_dep_order(consts) {
        []TConstDecl as ordered => {
            teko::assert::is_true(ordered.len == 2)
            teko::assert::is_true(ordered[0].name == "A")
            teko::assert::is_true(ordered[1].name == "B")
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * const_dep_order_reports_cycle — `const A = B; const B = A` is a reference cycle: `const_dep_order`
 * returns a located error rather than an order.
 */
#test
fn const_dep_order_reports_cycle() {
    let a = c_const("A", c_ref("B", "teko::checker"))
    let b = c_const("B", c_ref("A", "teko::checker"))
    mut consts: []TConstDecl = teko::list::push(teko::list::empty(), a)
    consts = teko::list::push(consts, b)
    match const_dep_order(consts) {
        []TConstDecl => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

/**
 * ns_const — a module-level `TConstDecl` declared in namespace `ns` (the dep/project dependency-graph
 * collision fixtures, #594 crumb 4/8b, finding 2).
 *
 * @param name  the constant's name
 * @param ns    its declaring namespace
 * @param init  its typed initializer
 * @return      the typed constant declaration
 */
fn ns_const(name: str, ns: str, init: TExpr) -> TConstDecl {
    TConstDecl { name = name; namespace = ns; ty = i64t(); init = init; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1 }
}

/**
 * const_dep_order_keeps_dep_and_project_const_distinct — a dep const `X` (ns "m1", no refs) and a
 * PROJECT const also named `X` (ns "app", referencing the dep's own `X`) are DISTINCT
 * dependency-graph nodes: name-only keying marked the project's `X` "done" the instant the dep's
 * same-named `X` finished, silently DROPPING it from the topological order without ever visiting it
 * (neither ordered nor reported as an error); `(name, namespace)`-keying orders BOTH (#594 crumb
 * 4/8b, finding 2).
 */
#test
fn const_dep_order_keeps_dep_and_project_const_distinct() {
    let dep_x = ns_const("X", "m1", c_num(5))
    let proj_x = ns_const("X", "app", c_ref("X", "m1"))
    mut consts: []TConstDecl = teko::list::push(teko::list::empty(), dep_x)
    consts = teko::list::push(consts, proj_x)
    match const_dep_order(consts) {
        []TConstDecl as ordered => {
            teko::assert::is_true(ordered.len == 2)
            teko::assert::is_true(ordered[0].namespace == "m1")
            teko::assert::is_true(ordered[1].namespace == "app")
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * const_dep_order_rejects_false_cycle_from_conflated_names — the dep/project collision the reviewer
 * flagged: a dep `pub const A = B` + `pub const B = 5` (both ns "m1") and a project `const B = A` (ns
 * "app", falling back to the dep's exported `A`). Name-only keying conflated the dep's `B` and the
 * project's `B` into ONE node, manufacturing a FALSE cycle `B → A → B` out of two edges that in
 * reality point at two DIFFERENT `B` declarations (`project B(app) → dep A(m1) → dep B(m1)`, a plain
 * DAG). `(name, namespace)`-keying orders all three consts with no cycle (#594 crumb 4/8b, finding
 * 2). The project item is listed FIRST here (an ordering `const_dep_order` must handle correctly
 * regardless of the caller's assembly order, not just the dep-first order the real pipeline happens
 * to use).
 */
#test
fn const_dep_order_rejects_false_cycle_from_conflated_names() {
    let dep_a = ns_const("A", "m1", c_ref("B", "m1"))
    let dep_b = ns_const("B", "m1", c_num(5))
    let proj_b = ns_const("B", "app", c_ref("A", "m1"))
    mut consts: []TConstDecl = teko::list::push(teko::list::empty(), proj_b)
    consts = teko::list::push(consts, dep_a)
    consts = teko::list::push(consts, dep_b)
    match const_dep_order(consts) {
        []TConstDecl as ordered => {
            teko::assert::is_true(ordered.len == 3)
            teko::assert::is_true(ordered[0].namespace == "m1" && ordered[0].name == "B")
            teko::assert::is_true(ordered[1].namespace == "m1" && ordered[1].name == "A")
            teko::assert::is_true(ordered[2].namespace == "app" && ordered[2].name == "B")
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * const_dep_order_reports_genuine_cycle_within_dep_namespace — a genuine reference cycle entirely
 * WITHIN one namespace (`m1::A = B; m1::B = A`) is still correctly reported after the `(name,
 * namespace)` keying change — the fix disambiguates cross-namespace name collisions, it does not mask
 * a real same-namespace cycle. Exercises the qualified `ns::name` cycle-message rendering (#594 crumb
 * 4/8b).
 */
#test
fn const_dep_order_reports_genuine_cycle_within_dep_namespace() {
    let a = ns_const("A", "m1", c_ref("B", "m1"))
    let b = ns_const("B", "m1", c_ref("A", "m1"))
    mut consts: []TConstDecl = teko::list::push(teko::list::empty(), a)
    consts = teko::list::push(consts, b)
    match const_dep_order(consts) {
        []TConstDecl => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

/**
 * c_bin — an `i64` binary-operator typed expression over two operands (a Tier-2 const initializer /
 * a use-site arithmetic expression for the inliner fixtures).
 *
 * @param op  the binary operator token kind
 * @param l   the left operand
 * @param r   the right operand
 * @return    the typed binary expression
 */
fn c_bin(op: lexer::TokenKind, l: TExpr, r: TExpr) -> TExpr {
    te(TBinary { op = op; left = l; right = r }, i64t())
}

/**
 * c_ret — a value-returning typed statement (`return e`), the body shape the inliner walks.
 *
 * @param e  the returned typed expression
 * @return   the typed return statement
 */
fn c_ret(e: TExpr) -> TStatement { TReturn { has_value = true; value = e } }

/**
 * c_fn — a private nullary `i64` module-level TFunction named `name` with body `body`, for the
 * inliner fixtures (its body is walked for scalar-const references).
 *
 * @param name  the function's name
 * @param body  its typed statement block
 * @return      the typed function
 */
fn c_fn(name: str, body: []TStatement) -> TFunction {
    TFunction { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); return_type = i64t(); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = "teko::checker"; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}

/**
 * count_const_items — the number of residual module-level TConstDecl items in `prog` (the inliner
 * must drop every SCALAR const; an aggregate const survives).
 *
 * @param prog  the program to scan
 * @return      the count of TConstDecl items remaining
 */
fn count_const_items(prog: TProgram) -> u64 {
    mut n: u64 = 0
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            TConstDecl => n = n + 1
            _ => { }
        }
        i++
    }
    n
}

/**
 * first_fn_return — the value of the first function's first `return` statement in `prog`, or null
 * when there is no such statement (the inliner fixtures inspect a single-return function body).
 *
 * @param prog  the program to scan
 * @return      the returned typed expression, or null
 */
fn first_fn_return(prog: TProgram) -> TExpr? {
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            TFunction as f => if f.body.len > 0 { match f.body[0] { TReturn as r => return r.value; _ => { } } }
            _ => { }
        }
        i++
    }
    null
}

/**
 * inline_return_number_is — assert the first function's returned expression is the integer literal
 * `want` (proving a scalar-const reference collapsed to its literal AND the comptime-fold pass then
 * folded the const-known op-tree down to that single literal).
 *
 * @param prog  the inlined program
 * @param want  the expected folded literal value
 */
fn inline_return_number_is(prog: TProgram, want: i128) {
    match first_fn_return(prog) {
        TExpr as rv => match rv.kind {
            TNumber as num => teko::assert::is_true(num.value == want)
            _ => teko::assert::is_true(false)
        }
        null => teko::assert::is_true(false)
    }
}

/**
 * inline_consts_substitutes_scalar_and_drops_decl — `const K: i64 = 41` used as `K + 1`: the inliner
 * substitutes `K` with the literal `41` and drops the scalar TConstDecl (no residual const item); the
 * comptime-fold pass then collapses the const-known `41 + 1` to the literal `42`.
 */
#test
fn inline_consts_substitutes_scalar_and_drops_decl() {
    let k = c_const("K", c_num(41))
    mut body: []TStatement = teko::list::empty()
    body = teko::list::push(body, c_ret(c_bin(lexer::TokenKind::Plus, c_ref("K", "teko::checker"), c_num(1))))
    mut items: []TItem = teko::list::empty()
    items = teko::list::push(items, k)
    items = teko::list::push(items, c_fn("f", body))
    match inline_consts(TProgram { items = items }) {
        TProgram as out => {
            teko::assert::is_true(count_const_items(out) == 0)
            inline_return_number_is(out, 42)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * inline_consts_collapses_nested_scalar_refs — `const B = A + 1; const A = 1` used as `return B`:
 * dependency-order inlining collapses `B` fully to `1 + 1` (no residual `TVar` for A or B), even
 * though B is declared before A; the comptime-fold pass then folds `1 + 1` to the literal `2`.
 */
#test
fn inline_consts_collapses_nested_scalar_refs() {
    let a = c_const("A", c_num(1))
    let b = c_const("B", c_bin(lexer::TokenKind::Plus, c_ref("A", "teko::checker"), c_num(1)))
    mut body: []TStatement = teko::list::empty()
    body = teko::list::push(body, c_ret(c_ref("B", "teko::checker")))
    mut items: []TItem = teko::list::empty()
    items = teko::list::push(items, b)
    items = teko::list::push(items, a)
    items = teko::list::push(items, c_fn("f", body))
    match inline_consts(TProgram { items = items }) {
        TProgram as out => {
            teko::assert::is_true(count_const_items(out) == 0)
            inline_return_number_is(out, 2)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * inline_consts_keeps_aggregate_const — a `[]byte` const is an AGGREGATE (crumb 6): the inliner does
 * NOT drop it; its TConstDecl survives for lowering.
 */
#test
fn inline_consts_keeps_aggregate_const() {
    let byteslice = Slice { element = Byte { } }
    mut elems: []TArrayElem = teko::list::empty()
    elems = teko::list::push(elems, TArrayElem { is_spread = false; expr = te(TByteLit { value = 31 to byte }, Byte { }) })
    let arr = te(TArrayLit { elements = elems }, byteslice)
    let agg = TConstDecl { name = "MAGIC"; namespace = "teko::checker"; ty = byteslice; init = arr; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    mut items: []TItem = teko::list::empty()
    items = teko::list::push(items, agg)
    match inline_consts(TProgram { items = items }) {
        TProgram as out => teko::assert::is_true(count_const_items(out) == 1)
        error => teko::assert::is_true(false)
    }
}

/**
 * return_is_array_lit — assert the first function's returned expression is an array literal (proving
 * an aggregate-const reference was substituted by its `[]T` initializer, #594 crumb 6, C-backend leg).
 *
 * @param prog  the inlined program
 */
fn return_is_array_lit(prog: TProgram) {
    match first_fn_return(prog) {
        TExpr as rv => match rv.kind { TArrayLit => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
        null => teko::assert::is_true(false)
    }
}

/**
 * inline_aggregate_consts_substitutes_and_keeps_residual_decl — the C-backend leg of crumb 6 (#594): a
 * `[]byte` const used as a bare reference is SUBSTITUTED by a clone of its array-literal initializer;
 * its `TConstDecl` is KEPT as a no-op residual item (#594 c9 finding), not dropped — `tk_emit_c_mode`'s
 * item loop and `emit_program_main` both already treat any `TConstDecl` as a total no-op, and keeping
 * the item preserves the program's per-index identity against the pre-aggregate-inline program
 * `coverage::line_coverage`/`branch_coverage` walk (dropping it shifted every later function's
 * `fn_items_index` out of sync with the coverage walk, corrupting coverage for the rest of the
 * program).
 */
#test
fn inline_aggregate_consts_substitutes_and_keeps_residual_decl() {
    let byteslice = Slice { element = Byte { } }
    mut elems: []TArrayElem = teko::list::empty()
    elems = teko::list::push(elems, TArrayElem { is_spread = false; expr = te(TByteLit { value = 31 to byte }, Byte { }) })
    let arr = te(TArrayLit { elements = elems }, byteslice)
    let agg = TConstDecl { name = "MAGIC"; namespace = "teko::checker"; ty = byteslice; init = arr; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    mut body: []TStatement = teko::list::empty()
    body = teko::list::push(body, c_ret(te(TVar { name = "MAGIC"; is_func = false; func_ns = "teko::checker" }, byteslice)))
    mut items: []TItem = teko::list::empty()
    items = teko::list::push(items, agg)
    items = teko::list::push(items, c_fn("f", body))
    match inline_aggregate_consts(TProgram { items = items }) {
        TProgram as out => {
            teko::assert::is_true(count_const_items(out) == 1)
            return_is_array_lit(out)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * assert_variant_widen — assert the first function's returned expression is the #630 widening node: a
 * `TCast` typed as the reference's VARIANT type (`Op`) whose wrapped child keeps the case-MEMBER type
 * (`RetC`). Proves the const inliner preserved the reference's variant type (so the C backend derives
 * `TK_TAG_OP_*` tags) while the member survives on the child (so codegen still wraps the case).
 *
 * @param prog  the aggregate-inlined program
 */
fn assert_variant_widen(prog: TProgram) {
    match first_fn_return(prog) {
        TExpr as rv => {
            teko::assert::is_true(type_name_is(rv.type, "Op"))
            match rv.kind {
                TCast as ct => teko::assert::is_true(type_name_is(ct.expr.type, "RetC"))
                _ => teko::assert::is_true(false)
            }
        }
        null => teko::assert::is_true(false)
    }
}

/**
 * type_name_is — is `t` the Named type whose name equals `name`? Used by the #630 widen assertion to
 * distinguish the reference's variant type from the initializer's case-member type.
 *
 * @param t     the resolved type to inspect
 * @param name  the Named type name to compare against
 * @return      true iff `t` is a `Named` with that exact name
 */
fn type_name_is(t: Type, name: str) -> bool {
    match t { Named as nm => nm.name == name; _ => false }
}

/**
 * inline_aggregate_consts_widens_variant_const_to_reference_type — the #630 fix: a VARIANT const
 * (`const R: Op = RetC { }`, its checked initializer typed as the case member `RetC`) used as a bare
 * reference is SUBSTITUTED by a widening `TCast` typed as `Op`, wrapping the member construction —
 * NOT by a bare `RetC`-typed node. Without the widen the C backend re-derives the match tags from the
 * member struct (`TK_TAG_RETC_*`, `.tag` on a fieldless struct) and the generated C fails to compile.
 */
#test
fn inline_aggregate_consts_widens_variant_const_to_reference_type() {
    let opty = Named { name = "Op" }
    let retc = Named { name = "RetC" }
    let ctor = te(TStructInit { field_names = teko::list::empty(); field_vals = teko::list::empty() }, retc)
    let agg = TConstDecl { name = "R"; namespace = "teko::checker"; ty = opty; init = ctor; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    mut body: []TStatement = teko::list::empty()
    body = teko::list::push(body, c_ret(te(TVar { name = "R"; is_func = false; func_ns = "teko::checker" }, opty)))
    mut items: []TItem = teko::list::empty()
    items = teko::list::push(items, agg)
    items = teko::list::push(items, c_fn("f", body))
    match inline_aggregate_consts(TProgram { items = items }) {
        TProgram as out => {
            teko::assert::is_true(count_const_items(out) == 1)
            assert_variant_widen(out)
        }
        error => teko::assert::is_true(false)
    }
}
