/**
 * src/checker/spine.tks (namespace `teko::checker`) ‚Äî the bounded points-to / uniqueness FACT
 * (#331 L1), layered BESIDE the untouched `escape.tks` name set (the #330 LAYER verdict).
 *
 * `escape.tks` computes a NAME SET (which locals outlive the frame); this module computes a finer,
 * per-cell POINTS-TO / BORROWED-FROM / UNIQUE-VS-SHARED lattice for one function. The two never
 * interfere: `mark_*` / `fn_escaping_vars` stay byte-identical (a reviewer diffs `escape.tks` and
 * sees zero change), and the spine only ever CERTIFIES a subset of what the name set over-marked.
 *
 * PR-1 SCOPE: this is the PURE query plus its two gate queries. Nothing consumes it for a decision
 * yet (that is PR-2 / PR-3), so it emits no C and relaxes no gate ‚Äî FIXPOINT is preserved by
 * construction. The finite cell universe (bindings + one-hop fields + `Reference` params) and the
 * fixed-height (‚â§ 3) lattice axes make the monotone worklist fixpoint terminate in ‚â§ |cells| √ó 3.
 *
 * @see docs/design/spine-build-plan.md ¬ß1 (L1 ‚Äî the fact)
 * @see docs/design/spine-layer-or-replace.md ¬ß2c.2 (the abstract domain + termination)
 */

use teko::parser

/**
 * A CELL in the spine's abstract domain ‚Äî the unit the points-to / borrowed-from / unique-vs-shared
 * facts attach to. The universe is FINITE per function (bindings + their one-hop fields + `Reference`
 * params), which is what makes the worklist fixpoint terminate. The `name` / `field` pair projects to
 * the `escape.tks` name set by dropping `field` (a one-hop `x.f` cell projects to the name `x`), so
 * `fn_escaping_vars` stays byte-identical.
 *
 * @see docs/design/spine-layer-or-replace.md ¬ß2c.2 (the abstract domain)
 */
pub type Cell = struct {
    /**
     * The binding / parameter name ‚Äî the same key `str_set_*` uses (escape.tks name set).
     */
    name: str
    /**
     * A single field off `name` for a one-hop path (`x.f`), else "" for a bare binding / param.
     * EXACTLY one hop; `a.b.c` is never a cell (it collapses to `‚ä§`).
     */
    field: str
    /**
     * True iff this cell is a `Reference`-typed parameter ‚Äî the referent ANCHOR the outlives proof
     * needs (R5: a ref is parameter-only today).
     */
    is_ref_param: bool
}

/**
 * A `PtParam` payload ‚Äî WHICH parameter slot a cell's value is allocated in (the param index).
 *
 * @field index  the 0-based parameter position that owns the value.
 */
pub type PtParamId = struct { index: u32 }

/**
 * A `PtAdopter` payload ‚Äî WHICH lexical `adopt { }` region a cell's value is allocated in (¬ß5.1, the
 * ADOPT escape fact). `top` marks the safe-fallback `PtAdopter(‚ä§)`: any allocation inside ANY adopter
 * whose precise region id exceeds the one-function budget, rejected on escape.
 *
 * @field region  the lexical adopter region id (valid iff `!top`).
 * @field top     true iff this is the `‚ä§` fallback (region id un-nameable ‚Äî reject on escape).
 */
pub type PtAdopterId = struct { region: u32; top: bool }

/**
 * The value is allocated in the FRAME region ‚Äî it dies with the frame. The bottom of the points-to
 * axis (the climb-floor).
 */
pub type PtFrame = struct { }
/**
 * The value is allocated in the ROOT region ‚Äî it outlives the frame (a safe leak). One of the
 * concrete allocation sites (rank 1).
 */
pub type PtRoot = struct { }
/**
 * The value is owned by a parameter slot (the caller owns it, so it outlives every frame local).
 *
 * @field id  the owning parameter slot.
 */
pub type PtParam = struct { id: PtParamId }
/**
 * The value is allocated lexically inside an `adopt { }` block ‚Äî bulk-dropped at that block's brace.
 *
 * @field id  the lexical adopter region this allocation is confined to.
 */
pub type PtAdopter = struct { id: PtAdopterId }
/**
 * `‚ä§` ‚Äî the allocation site is unknown / joined-over. Treated as `PtRoot` (the safe leak) by every
 * consumer; a borrow of a `PtTop` referent is never provably outlived.
 */
pub type PtTop = struct { }
/**
 * WHERE a cell's value is allocated (the points-to axis). Join = set-union capped at Top; Top ‚áí treat
 * as Root (the safe leak). `PtParam` carries its owning parameter slot; `PtAdopter` carries the
 * lexical `adopt { }` region id (¬ß5.1 ‚Äî the ADOPT escape fact). Fixed height ‚â§ 3
 * (`PtFrame < concrete site < PtTop`).
 */
pub type PointsTo = variant PtFrame | PtRoot | PtParam | PtAdopter | PtTop

/**
 * A `BfParam` payload ‚Äî WHICH parameter a `Reference` cell borrows (its referent's param slot).
 *
 * @field index  the 0-based parameter position of the referent.
 */
pub type BfParamId = struct { index: u32 }

/**
 * A `BfLocal` payload ‚Äî WHICH local name a `Reference` cell borrows (its referent's binding name).
 *
 * @field name  the referent local's binding name.
 */
pub type BfLocalId = struct { name: str }

/**
 * The cell borrows NOTHING ‚Äî it is not a `Reference` (or its referent is un-recorded). The lattice
 * bottom of the borrowed-from axis.
 */
pub type BfNone = struct { }
/**
 * The cell borrows a PARAMETER ‚Äî the caller owns the referent, so it outlives every frame local.
 *
 * @field id  the borrowed parameter slot.
 */
pub type BfParam = struct { id: BfParamId }
/**
 * The cell borrows a LOCAL ‚Äî the outlives proof holds only when the referent's block ENCLOSES the
 * borrow's block.
 *
 * @field id  the borrowed local's binding name.
 */
pub type BfLocal = struct { id: BfLocalId }
/**
 * `‚ä§` ‚Äî the referent is unknown / joined-over. The outlives proof FAILS (REJECT); conservative.
 */
pub type BfTop = struct { }
/**
 * For a `Reference` cell, WHICH referent it borrows (the borrowed-from axis). `‚ä§` (BfTop) ‚áí referent
 * unknown ‚áí the outlives proof FAILS ‚áí REJECT. A ref is parameter-only today, so `bf` is initially
 * `BfParam(i)` or `BfNone`. Fixed height ‚â§ 3 (`BfNone < BfParam / BfLocal < BfTop`).
 */
pub type BorrowedFrom = variant BfNone | BfParam | BfLocal | BfTop

/**
 * The cell is the SOLE live handle to its target ‚Äî safe to `free` / move.
 */
pub type UsUnique = struct { }
/**
 * The cell is aliased ‚Äî another binding still holds its target, so it may NOT be `free`d / moved.
 */
pub type UsShared = struct { }
/**
 * `‚ä§` ‚Äî uniqueness unknown / joined-over. Treated as `Shared` (the safe direction).
 */
pub type UsTop = struct { }
/**
 * Whether a cell is the SOLE live handle to its target (the unique-vs-shared axis). `let y = x` on a
 * non-scalar joins both to `UsShared`. `‚ä§` (UsTop) ‚áí `Shared` (the safe direction: a shared cell may
 * not be `free`d). Fixed height ‚â§ 3 (`UsUnique < UsShared < UsTop`).
 */
pub type Unique = variant UsUnique | UsShared | UsTop

/**
 * The per-cell fact for one function ‚Äî parallel arrays keyed by cell index (Teko has no Map in the
 * compiler corpus; `escape.tks` uses the same parallel-`[]str` idiom). `fn_spine` returns this; the
 * L2 gates (PR-2 / PR-3) query it via `ref_target_outlives` / `is_unique_at`.
 *
 * @field cells  the finite cell universe of the analyzed function.
 * @field pt     the points-to axis, parallel to `cells`.
 * @field bf     the borrowed-from axis, parallel to `cells`.
 * @field us     the unique-vs-shared axis, parallel to `cells`.
 */
pub type Spine = struct {
    cells: []Cell
    pt: []PointsTo
    bf: []BorrowedFrom
    us: []Unique
}

/**
 * Is `t` (a syntactic type annotation) a `Reference` (`Ref<T>`)? A `Reference` param is written
 * `Ref<T>` ‚Äî a `NamedType` whose single leading path segment is `Ref`. Matches the checker's own
 * `Ref` recognition (resolve.tks) so the cell universe agrees with the resolved type.
 *
 * @param t  the parsed parameter type annotation
 * @return   true iff `t` names `Ref<‚Ä¶>`
 */
fn type_ann_is_ref(t: parser::TypeExpr) -> bool {
    match t {
        parser::NamedType as nt => named_head_is_ref(nt)
        parser::SliceType => false
        parser::UnionType => false
        parser::OptionalType => false
        parser::FunctionType => false
    }
}

/**
 * Is this `NamedType`'s leading path segment exactly `Ref` (with a single generic argument)? The
 * `Ref<T>` surface spelling of a `Reference`.
 *
 * @param nt  the named-type annotation
 * @return    true iff its head segment is `Ref` and it carries one type argument
 */
fn named_head_is_ref(nt: parser::NamedType) -> bool {
    if nt.path.segments.len == 0 { return false }
    if nt.args.len != 1 { return false }
    nt.path.segments[0].name == "Ref"
}

/**
 * Look up a cell's index by its `name` / `field` key, or -1 when absent. Linear (cell sets are tiny ‚Äî
 * one function's bindings), mirroring the `str_set_*` idiom in `escape.tks`.
 *
 * @param cells  the cell universe
 * @param name   the binding / parameter name
 * @param field  the one-hop field ("" for a bare cell)
 * @return       the 0-based cell index, or -1 when no such cell exists
 */
fn cell_index(cells: []Cell, name: str, field: str) -> i64 {
    mut i = 0
    loop {
        if i >= cells.len { break }
        if cells[i].name == name {
            if cells[i].field == field { return i to i64 }
        }
        i++
    }
    -1
}

/**
 * Add a cell (keyed by `name` / `field`) to `cells` if absent, returning the possibly-grown set.
 * Keeps the universe deduped so the parallel axis arrays stay index-aligned.
 *
 * @param cells         the cell universe so far
 * @param name          the binding / parameter name
 * @param field         the one-hop field ("" for a bare cell)
 * @param is_ref_param  true iff a `Reference` parameter cell
 * @return              the cell universe including the (possibly new) cell
 */
fn add_cell(cells: []Cell, name: str, field: str, is_ref_param: bool) -> []Cell {
    if cell_index(cells, name, field) >= 0 { return cells }
    teko::list::push(cells, Cell { name = name; field = field; is_ref_param = is_ref_param })
}

/**
 * Add every PARAMETER of `f` to the cell universe: one bare cell per param, marking a `Reference`
 * param as `is_ref_param`. The bare cell anchors the referent an outlives proof reads.
 *
 * @param f      the analyzed function
 * @param cells  the cell universe so far
 * @return       the cell universe including `f`'s parameters
 */
fn add_param_cells(f: TFunction, cells: []Cell) -> []Cell {
    mut acc = cells
    mut i = 0
    loop {
        if i >= f.params.len { break }
        let p = f.params[i]
        let is_ref = if p.has_type { type_ann_is_ref(p.type_ann) } else { false }
        acc = add_cell(acc, p.name, "", is_ref)
        i++
    }
    acc
}

/**
 * Add every BINDING target and one-hop field cell reachable from a statement block to the universe.
 * A `TBinding` to a `SimpleName` yields a bare cell; a one-hop `x.f` field read / write off a bare
 * local yields an `x.f` cell (`a.b.c` is NOT a cell ‚Äî it collapses to `‚ä§`, added nowhere).
 *
 * @param body   the typed statement block
 * @param cells  the cell universe so far
 * @return       the cell universe including this block's binding + one-hop cells
 */
fn add_block_cells(body: []TStatement, cells: []Cell) -> []Cell {
    mut acc = cells
    mut i = 0
    loop {
        if i >= body.len { break }
        acc = add_stmt_cells(body[i], acc)
        i++
    }
    acc
}

/**
 * Add the binding-target + one-hop field cells named by one statement, recursing into nested blocks
 * (loop / defer / adopt bodies + if / match arms reached via expressions). Bounded by `f`'s syntactic
 * size (each node is visited once).
 *
 * @param s      the typed statement
 * @param cells  the cell universe so far
 * @return       the cell universe including this statement's cells
 */
fn add_stmt_cells(s: TStatement, cells: []Cell) -> []Cell {
    match s {
        TBinding as b => add_binding_cell(b, cells)
        TAssign as a => add_expr_cells(a.value, cells)
        TReturn as r => if r.has_value { add_expr_cells(r.value, cells) } else { cells }
        TExprStmt as es => add_expr_cells(es.expr, cells)
        TLoopStmt as l => add_block_cells(l.body, cells)
        TBreakStmt => cells
        TContinueStmt => cells
        TDeferStmt as d => add_block_cells(d.body, cells)
        TAdoptStmt as a => add_block_cells(a.body, cells)
    }
}

/**
 * Add the bare cell named by a binding's `SimpleName` target (a destructure names no single cell),
 * then the one-hop cells of its value.
 *
 * @param b      the typed binding
 * @param cells  the cell universe so far
 * @return       the cell universe including this binding's target cell
 */
fn add_binding_cell(b: TBinding, cells: []Cell) -> []Cell {
    match b.target {
        parser::SimpleName as sn => add_expr_cells(b.value, add_cell(cells, sn.name, "", false))
        parser::DestructurePattern => add_expr_cells(b.value, cells)
    }
}

/**
 * Add a one-hop field cell (`x.f` off a bare local) named by an expression, recursing into control
 * flow so nested blocks contribute their cells. A deeper path (`a.b.c`) contributes no cell (it
 * collapses to `‚ä§`); a non-field expression contributes only its sub-cells.
 *
 * @param e      the typed expression
 * @param cells  the cell universe so far
 * @return       the cell universe including this expression's one-hop cells
 */
fn add_expr_cells(e: TExpr, cells: []Cell) -> []Cell {
    match e.kind {
        TFieldAccess as fa => add_field_cell(fa, cells)
        TIfExpr as f => add_block_cells(f.else_blk, add_block_cells(f.then_blk, cells))
        TMatchExpr as m => add_match_cells(m, cells)
        _ => cells
    }
}

/**
 * Add the `x.f` one-hop cell for a field access whose receiver is a BARE local (`expr_is_bare_var`
 * shape in `escape.tks`); a non-bare receiver contributes no one-hop cell (the path is deeper).
 *
 * @param fa     the typed field access
 * @param cells  the cell universe so far
 * @return       the cell universe including the one-hop cell (or unchanged)
 */
fn add_field_cell(fa: TFieldAccess, cells: []Cell) -> []Cell {
    match fa.receiver.kind {
        TVar as v => add_cell(cells, v.name, fa.field, false)
        _ => add_expr_cells(fa.receiver, cells)
    }
}

/**
 * Add the one-hop cells reachable through a match expression's arm bodies (each arm is a statement
 * block, like an if-branch).
 *
 * @param m      the typed match expression
 * @param cells  the cell universe so far
 * @return       the cell universe including the arm bodies' cells
 */
fn add_match_cells(m: TMatchExpr, cells: []Cell) -> []Cell {
    mut acc = cells
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        acc = add_block_cells(m.arms[i].body, acc)
        i++
    }
    acc
}

/**
 * Seed the points-to axis: a `Reference` param cell starts `PtParam(i)` (the caller owns its slot);
 * every other cell starts `PtFrame` (the climb-floor). Parallel to `cells` by index.
 *
 * @param cells  the cell universe
 * @return       the seeded points-to axis
 */
fn seed_pt(cells: []Cell) -> []PointsTo {
    mut acc: []PointsTo = teko::list::empty()
    mut i = 0
    loop {
        if i >= cells.len { break }
        if cells[i].is_ref_param {
            acc = teko::list::push(acc, PtParam { id = PtParamId { index = i to u32 } })
        } else {
            acc = teko::list::push(acc, PtFrame { })
        }
        i++
    }
    acc
}

/**
 * Seed the borrowed-from axis: a `Reference` param cell starts `BfParam(i)` (it borrows its own
 * slot); every other cell starts `BfNone`. Parallel to `cells` by index.
 *
 * @param cells  the cell universe
 * @return       the seeded borrowed-from axis
 */
fn seed_bf(cells: []Cell) -> []BorrowedFrom {
    mut acc: []BorrowedFrom = teko::list::empty()
    mut i = 0
    loop {
        if i >= cells.len { break }
        if cells[i].is_ref_param {
            acc = teko::list::push(acc, BfParam { id = BfParamId { index = i to u32 } })
        } else {
            acc = teko::list::push(acc, BfNone { })
        }
        i++
    }
    acc
}

/**
 * Seed the unique-vs-shared axis: every cell starts `UsUnique` (the climb-floor ‚Äî aliasing joins it
 * up to `UsShared`). Parallel to `cells` by index.
 *
 * @param cells  the cell universe
 * @return       the seeded unique-vs-shared axis
 */
fn seed_us(cells: []Cell) -> []Unique {
    mut acc: []Unique = teko::list::empty()
    mut i = 0
    loop {
        if i >= cells.len { break }
        acc = teko::list::push(acc, UsUnique { })
        i++
    }
    acc
}

/**
 * The lattice rank of a points-to value (`PtFrame` = 0 < concrete sites = 1 < `PtTop` = 2). The join
 * keeps the higher rank; equal ranks with differing payloads climb to `PtTop` (the safe leak).
 *
 * @param p  the points-to value
 * @return   its lattice rank
 */
fn pt_rank(p: PointsTo) -> u32 {
    match p {
        PtFrame => 0
        PtParam => 1
        PtAdopter => 1
        PtRoot => 1
        PtTop => 2
    }
}

/**
 * Do two points-to values name the SAME concrete site? Two `PtParam` agree iff same slot; two
 * `PtAdopter` agree iff same non-top region; `PtRoot` agrees with `PtRoot`. Used by the join to
 * decide whether equal-rank concrete sites climb to `PtTop`.
 *
 * @param a  the first points-to value
 * @param b  the second points-to value
 * @return   true iff both name the identical concrete allocation site
 */
fn pt_same_site(a: PointsTo, b: PointsTo) -> bool {
    match a {
        PtParam as pa => match b { PtParam as pb => pa.id.index == pb.id.index; _ => false }
        PtAdopter as aa => match b { PtAdopter as ab => adopter_same(aa.id, ab.id); _ => false }
        PtRoot => match b { PtRoot => true; _ => false }
        PtFrame => false
        PtTop => false
    }
}

/**
 * Do two adopter ids name the same lexical region? A `‚ä§` fallback id never agrees (its region is
 * un-nameable), so two `PtAdopter(‚ä§)` still climb to `PtTop` ‚Äî conservative.
 *
 * @param a  the first adopter id
 * @param b  the second adopter id
 * @return   true iff both are concrete and share a region id
 */
fn adopter_same(a: PtAdopterId, b: PtAdopterId) -> bool {
    if a.top { return false }
    if b.top { return false }
    a.region == b.region
}

/**
 * The points-to join (least upper bound). `PtFrame` is bottom; a concrete site joined with the same
 * site is itself; two DIFFERENT concrete sites (or any pair reaching rank 2) climb to `PtTop` (the
 * safe leak ‚Äî treated as Root). Monotone: the result rank is ‚â• both inputs.
 *
 * @param a  the current points-to value
 * @param b  the incoming points-to value
 * @return   the least upper bound of `a` and `b`
 */
fn pt_join(a: PointsTo, b: PointsTo) -> PointsTo {
    let ra = pt_rank(a)
    let rb = pt_rank(b)
    if ra == 2 { return PtTop { } }
    if rb == 2 { return PtTop { } }
    if ra == 0 { return b }
    if rb == 0 { return a }
    if pt_same_site(a, b) { return a }
    PtTop { }
}

/**
 * The lattice rank of a borrowed-from value (`BfNone` = 0 < named referent = 1 < `BfTop` = 2).
 *
 * @param b  the borrowed-from value
 * @return   its lattice rank
 */
fn bf_rank(b: BorrowedFrom) -> u32 {
    match b {
        BfNone => 0
        BfParam => 1
        BfLocal => 1
        BfTop => 2
    }
}

/**
 * Do two borrowed-from values name the SAME referent? Two `BfParam` agree iff same slot; two
 * `BfLocal` agree iff same name.
 *
 * @param a  the first borrowed-from value
 * @param b  the second borrowed-from value
 * @return   true iff both name the identical referent
 */
fn bf_same_referent(a: BorrowedFrom, b: BorrowedFrom) -> bool {
    match a {
        BfParam as pa => match b { BfParam as pb => pa.id.index == pb.id.index; _ => false }
        BfLocal as la => match b { BfLocal as lb => la.id.name == lb.id.name; _ => false }
        BfNone => false
        BfTop => false
    }
}

/**
 * The borrowed-from join (least upper bound). `BfNone` is bottom; a named referent joined with the
 * same referent is itself; two DIFFERENT referents (or any pair reaching rank 2) climb to `BfTop`
 * (referent unknown ‚áí the outlives proof fails). Monotone.
 *
 * @param a  the current borrowed-from value
 * @param b  the incoming borrowed-from value
 * @return   the least upper bound of `a` and `b`
 */
fn bf_join(a: BorrowedFrom, b: BorrowedFrom) -> BorrowedFrom {
    let ra = bf_rank(a)
    let rb = bf_rank(b)
    if ra == 2 { return BfTop { } }
    if rb == 2 { return BfTop { } }
    if ra == 0 { return b }
    if rb == 0 { return a }
    if bf_same_referent(a, b) { return a }
    BfTop { }
}

/**
 * The lattice rank of a unique-vs-shared value (`UsUnique` = 0 < `UsShared` = 1 < `UsTop` = 2).
 *
 * @param u  the unique-vs-shared value
 * @return   its lattice rank
 */
fn us_rank(u: Unique) -> u32 {
    match u {
        UsUnique => 0
        UsShared => 1
        UsTop => 2
    }
}

/**
 * The unique-vs-shared join (least upper bound). `UsUnique` is bottom; any aliasing read climbs a
 * cell to `UsShared`; `‚ä§` is `UsTop` (treated as shared). Monotone ‚Äî the result rank is ‚â• both
 * inputs.
 *
 * @param a  the current unique-vs-shared value
 * @param b  the incoming unique-vs-shared value
 * @return   the least upper bound of `a` and `b`
 */
fn us_join(a: Unique, b: Unique) -> Unique {
    if us_rank(a) >= us_rank(b) { return a }
    b
}

/**
 * Is `e` a bare local read (a `TVar`) ‚Äî the alias source shape? Mirrors `expr_is_bare_var` in
 * `escape.tks`: only a DIRECT variable read (no field / index / call wrapping) is an alias source.
 *
 * @param e  the typed expression
 * @return   true iff `e` is a bare `TVar` read
 */
fn expr_is_bare_local(e: TExpr) -> bool {
    match e.kind {
        TVar => true
        _ => false
    }
}

/**
 * Does binding / assigning to a value at `e` create an ALIAS of a non-scalar local (`let y = x` where
 * `x` is a bare non-scalar local)? An alias joins BOTH cells to `UsShared`. A scalar copy is not an
 * alias (it carries no shared handle).
 *
 * @param e  the typed RHS expression
 * @return   true iff `e` is a bare non-scalar local read (an alias source)
 */
fn rhs_is_alias_source(e: TExpr) -> bool {
    if !expr_is_bare_local(e) { return false }
    !type_is_scalar(e.type)
}

/**
 * Join `UsShared` into the cells of both sides of an alias `dst = src` (both `dst` and the aliased
 * `src` become shared). Reads a `Ref<[]Unique>` so the grown axis is visible in place, mirroring the
 * `escape.tks` `acc.value` accumulator idiom.
 *
 * @param cells  the cell universe
 * @param us     the unique-vs-shared axis (mutated in place through the ref)
 * @param dst    the destination binding name
 * @param src    the aliased source name
 * @return       void ‚Äî `us.value` carries the joined axis
 */
fn mark_alias_shared(cells: []Cell, us: Ref<[]Unique>, dst: str, src: str) -> void {
    us.value = join_us_at(cells, us.value, dst, "")
    us.value = join_us_at(cells, us.value, src, "")
}

/**
 * Join `UsShared` into the cell keyed by `name` / `field`, returning the possibly-updated axis. A
 * missing cell leaves the axis unchanged (the key is not in this function's universe).
 *
 * @param cells  the cell universe
 * @param us     the unique-vs-shared axis
 * @param name   the cell's binding name
 * @param field  the cell's one-hop field ("" for a bare cell)
 * @return       the axis with the named cell joined to `UsShared`
 */
fn join_us_at(cells: []Cell, us: []Unique, name: str, field: str) -> []Unique {
    let idx = cell_index(cells, name, field)
    if idx < 0 { return us }
    set_us(us, idx to u32, us_join(us[idx to u32], UsShared { }))
}

/**
 * Return the unique-vs-shared axis with index `i` replaced by `v` (parallel arrays are rebuilt by
 * copy ‚Äî the compiler corpus has no in-place slice write for a value element).
 *
 * @param us  the unique-vs-shared axis
 * @param i   the cell index to replace
 * @param v   the new unique-vs-shared value
 * @return    the axis with element `i` set to `v`
 */
fn set_us(us: []Unique, i: u32, v: Unique) -> []Unique {
    mut acc: []Unique = teko::list::empty()
    mut k = 0
    loop {
        if k >= us.len { break }
        if k to u32 == i {
            acc = teko::list::push(acc, v)
        } else {
            acc = teko::list::push(acc, us[k])
        }
        k++
    }
    acc
}

/**
 * The alias-transfer sweep over one statement block: every `let y = x` / `y = x` whose RHS is a
 * non-scalar bare-local read joins BOTH cells to `UsShared` (the any-alias-anywhere ‚áí shared reading
 * ‚Äî the conservative over-reject direction). Monotone (only climbs `us` up); recurses into nested
 * blocks so a loop / adopter body's aliases count too.
 *
 * @param body   the typed statement block
 * @param cells  the cell universe
 * @param us     the unique-vs-shared axis (mutated in place through the ref)
 * @return       void ‚Äî `us.value` carries the joined axis
 */
fn transfer_block(body: []TStatement, cells: []Cell, us: Ref<[]Unique>) -> void {
    mut i = 0
    loop {
        if i >= body.len { break }
        transfer_stmt(body[i], cells, us)
        i++
    }
}

/**
 * The alias-transfer for one statement. A `TBinding` / `TAssign` to a `SimpleName` whose RHS aliases
 * a bare non-scalar local joins both cells to `UsShared`; a loop / defer / adopt body recurses.
 *
 * @param s      the typed statement
 * @param cells  the cell universe
 * @param us     the unique-vs-shared axis (mutated in place through the ref)
 * @return       void ‚Äî `us.value` carries the joined axis
 */
fn transfer_stmt(s: TStatement, cells: []Cell, us: Ref<[]Unique>) -> void {
    match s {
        TBinding as b => transfer_binding(b, cells, us)
        TAssign as a => transfer_assign(a, cells, us)
        TLoopStmt as l => transfer_block(l.body, cells, us)
        TDeferStmt as d => transfer_block(d.body, cells, us)
        TAdoptStmt as a => transfer_block(a.body, cells, us)
        TReturn => { }
        TExprStmt => { }
        TBreakStmt => { }
        TContinueStmt => { }
    }
}

/**
 * The alias-transfer for a binding: `let y = x` where `x` is a bare non-scalar local aliases `y` and
 * `x` to `UsShared`.
 *
 * @param b      the typed binding
 * @param cells  the cell universe
 * @param us     the unique-vs-shared axis (mutated in place through the ref)
 * @return       void ‚Äî `us.value` carries the joined axis
 */
fn transfer_binding(b: TBinding, cells: []Cell, us: Ref<[]Unique>) -> void {
    if !rhs_is_alias_source(b.value) { return }
    match b.target {
        parser::SimpleName as sn => mark_alias_shared(cells, us, sn.name, alias_src_name(b.value))
        parser::DestructurePattern => { }
    }
}

/**
 * The alias-transfer for an assignment: `y = x` (a simple-name write) where `x` is a bare non-scalar
 * local aliases `y` and `x` to `UsShared`. A field / deref write names no single alias pair.
 *
 * @param a      the typed assignment
 * @param cells  the cell universe
 * @param us     the unique-vs-shared axis (mutated in place through the ref)
 * @return       void ‚Äî `us.value` carries the joined axis
 */
fn transfer_assign(a: TAssign, cells: []Cell, us: Ref<[]Unique>) -> void {
    if !rhs_is_alias_source(a.value) { return }
    match a.kind {
        parser::AssignKind::Simple => mark_alias_shared(cells, us, a.name, alias_src_name(a.value))
        _ => { }
    }
}

/**
 * The aliased source name of an alias-source RHS (`rhs_is_alias_source` held): the bare `TVar`'s
 * name. The fallback ("") is unreachable on that path.
 *
 * @param e  the typed RHS expression
 * @return   the aliased source variable name
 */
fn alias_src_name(e: TExpr) -> str {
    match e.kind {
        TVar as v => v.name
        _ => ""
    }
}

/**
 * The spine fact for one function ‚Äî a bounded, per-function points-to / uniqueness lattice layered
 * BESIDE `fn_escaping_vars` (the name set stays byte-identical; this only ever CERTIFIES a subset of
 * what the name set over-marked). Builds the finite cell universe of `f`, seeds each axis at its
 * climb-floor, then runs the monotone alias-transfer to a fixpoint. Every transfer only moves a cell
 * UP the fixed-height (‚â§ 3) lattice, so it terminates in ‚â§ |cells| √ó 3 join steps (¬ß2c.2
 * termination). Reads `f.params` + `f.body`; touches NO `mark_*` code.
 *
 * @param f  the typed function to analyze
 * @return   the per-cell points-to / borrowed-from / unique-vs-shared fact for `f`
 * @see      docs/design/spine-layer-or-replace.md ¬ß2c.2
 * @since    0.1.0.0-beta (#331 L1)
 */
pub fn fn_spine(f: TFunction) -> Spine {
    let cells = add_block_cells(f.body, add_param_cells(f, teko::list::empty()))
    mut us = seed_us(cells)
    transfer_block(f.body, cells, us)
    Spine { cells = cells; pt = seed_pt(cells); bf = seed_bf(cells); us = us }
}

/**
 * The cell index of a bare binding / parameter (`field` = "") named `name`, or -1 when un-nameable.
 * The L2 gates (PR-2 / PR-3) call this to key a consumed / borrowed binding into its spine cell.
 *
 * @param s     the function's spine
 * @param name  the binding / parameter name
 * @return      the 0-based cell index, or -1 when the name is not in this function's universe
 */
pub fn cell_of(s: Spine, name: str) -> i64 {
    cell_index(s.cells, name, "")
}

/**
 * Does the referent of a borrow OUTLIVE the borrow ‚Äî i.e. may `borrow` (a `Reference` cell) be
 * stored / bound at its site without dangling? True iff the referent (`bf(borrow)`) is a `BfParam`
 * (a param outlives every local ‚Äî the caller owns it) OR a `BfLocal` whose block encloses the borrow
 * (checked by the gate that calls this), AND the referent is not itself `pt = PtAdopter` escaping its
 * adopter (¬ß5.1). `bf = BfTop` ‚áí referent unknown ‚áí FALSE (REJECT). Conservative: unknown ‚áí
 * does-not-outlive. EXPOSED for PR-2's ref-storability gate; consumed by no gate in PR-1.
 *
 * @param s        the function's spine
 * @param borrow   the cell index of the `Reference` being stored / bound
 * @param referent the cell index of the referent (or a sentinel when un-nameable)
 * @return         true iff the borrow provably does not outlive its referent
 */
pub fn ref_target_outlives(s: Spine, borrow: u32, referent: u32) -> bool {
    if borrow >= s.bf.len { return false }
    match s.bf[borrow] {
        BfParam => referent_not_escaping_adopter(s, referent)
        BfLocal => referent_not_escaping_adopter(s, referent)
        BfNone => false
        BfTop => false
    }
}

/**
 * Is the referent cell NOT an `adopt { }`-confined allocation escaping its brace (¬ß5.1)? A referent
 * whose `pt` is `PtAdopter` is bulk-dropped at the adopter brace, so a borrow surviving it dangles ‚Äî
 * REJECT. A sentinel / out-of-range referent index is treated as escaping (conservative FALSE).
 *
 * @param s        the function's spine
 * @param referent the cell index of the referent
 * @return         true iff the referent is not an adopter-confined allocation
 */
fn referent_not_escaping_adopter(s: Spine, referent: u32) -> bool {
    if referent >= s.pt.len { return false }
    match s.pt[referent] {
        PtAdopter => false
        PtFrame => true
        PtRoot => true
        PtParam => true
        PtTop => true
    }
}

/**
 * Is `binding` the SOLE live handle ‚Äî `us(binding) = UsUnique`? The affine `mem::free` /
 * channel-send-move gate (PR-3, and the L2c consume contract below) consults this: a `UsShared` /
 * `UsTop` cell may NOT be consumed (the aliased-free UAF, remodel ¬ß5 / #336 gap 1). Conservative:
 * `‚ä§` ‚áí shared ‚áí FALSE. Any-alias-anywhere ‚áí shared at the fixpoint (a later increment may add
 * flow-sensitivity; out of scope here). EXPOSED for PR-3; consumed by no gate in PR-1.
 *
 * L2c CONSUME CONTRACT (semantics only ‚Äî spine-build-plan ¬ß4): a future `chan.send(x)` consume site
 * MUST call `is_unique_at(s, cell_of(s, x))` and REJECT a shared / `‚ä§` target, identically to the
 * L2b `mem::free` affine guard ‚Äî one analysis, four guarantees. No channel surface exists yet, so
 * L2c ships this documented primitive with no gate site and no fixture.
 *
 * @param s        the function's spine
 * @param binding  the cell index of the consumed binding
 * @return         true iff `binding` is provably unique (safe to free / move)
 */
pub fn is_unique_at(s: Spine, binding: u32) -> bool {
    if binding >= s.us.len { return false }
    match s.us[binding] {
        UsUnique => true
        UsShared => false
        UsTop => false
    }
}
