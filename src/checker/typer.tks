// src/checker/typer.tks  (namespace 'teko::checker')
// Each check_* (E4/E5) EVOLVES into a type_*: the SAME checks (B.22 regimes, B.20
// `if`, B.15 `match` + exhaustiveness), but the producer BUILDS the typed node
// instead of returning a bare Type. Predicates (is_bool/is_integer/op_is_*),
// resolvers (resolve_type), env (lookup/define) and the pattern + exhaustiveness
// logic (check_pattern/exhaustive) are reused from their stages — re-derivation,
// not duplication (M.5). C1: every node, statement and item re-derived.

use teko::lexer
use teko::parser

// ---- leaves ----
fn type_number(n: parser::Number) -> TExpr {
    // N1/N2 (B.38): the leaf adopts a DEFAULT — i64 for an integer literal, f64 for a float.
    // An annotation/expected type re-adopts a fitting literal at the binding/cast site
    // (annotated_literal_ok / const_range_check), where the full int set (incl u128/i128)
    // and the float set (f16/f32) come into play. [literal typing in annotated context: C6]
    let k = if n.is_float { PrimKind::F64 } else { PrimKind::I64 }
    TExpr { kind = TNumber { is_float = n.is_float; value = n.value; fval = n.fval }; type = Prim { kind = k }; line = 0; col = 0 }
}
fn type_strlit(s: parser::StrLit) -> TExpr {
    TExpr { kind = TStrLit { text = s.text }; type = Str { }; line = 0; col = 0 }
}
fn type_bytelit(b: parser::ByteLit) -> TExpr {
    TExpr { kind = TByteLit { value = b.value }; type = Byte { }; line = 0; col = 0 }
}

// a char literal `c'x'` types as `char` (its OWN tag); the raw UTF-8 bytes ride the node.
fn type_charlit(c: parser::CharLit) -> TExpr {
    TExpr { kind = TCharLit { bytes = c.bytes }; type = Char { }; line = 0; col = 0 }
}
fn type_boollit(b: parser::BoolLit) -> TExpr {   // `true`/`false` — the bool prim (LEGISLATION §75)
    TExpr { kind = TBoolLit { value = b.value }; type = Prim { kind = PrimKind::Bool }; line = 0; col = 0 }
}
// A bare `null` types to the SENTINEL optional (an `Optional` whose inner is the `Void` marker
// — REBOOT_PLAN §202; the C twin uses a NULL inner pointer): it unifies with ANY concrete `T?`
// (type_eq) and is assignable to any optional slot (assignable). The CONCRETE inner is supplied
// by the destination — a binding annotation `: T?`, a return `-> T?`, the other match/`if` arm,
// or `x ?? null` — like a variant case widening into a variant slot. The VM lowers it to NONE
// (untyped); codegen wraps it to the slot's optional type via emit_as.
fn type_nulllit(n: parser::NullLit) -> TExpr | error {
    TExpr { kind = TNullLit { }; type = Optional { inner = Void { } }; line = 0; col = 0 }
}
fn type_var(v: parser::Var, env: Env) -> TExpr | error {
    let b = match lookup_binding(env, v.name) { ValBinding as bb => bb; error as e => return e }
    match lookup_inject(env, v.name) { DiInjectBind as ib => return di_lower_use(ib, b.type); error => { } }
    // (W10a) a bare reference to a top-level FUNCTION used as a VALUE: only `define_fn` sets a
    // non-empty `ns`, so `ns != "" && type is Func` uniquely identifies a fn reference (a local of
    // closure type has ns=""). It lowers to a `tk_closure` literal; a plain local emits its name.
    let is_fn = b.ns.len > 0 && (match b.type { Func => true; _ => false })
    TExpr { kind = TVar { name = v.name; is_func = is_fn; func_ns = b.ns }; type = b.type; line = 0; col = 0 }
}

// ============================================================================
// (W10) CLOSURE LITERALS — type a `(params) => body` lambda, analyse its captures.
// ============================================================================

// collect the NAMES a lambda body READS (`refs`) and the names it BINDS internally (`bound` —
// inner `let`s + nested-lambda params), so the free variables are `refs − bound − <params>`.
fn lam_collect_block(stmts: []parser::Statement, refs: Ref<[]str>, bound: Ref<[]str>) -> void {
    mut i = 0
    loop { if i >= stmts.len { break }; lam_collect_stmt(stmts[i], refs, bound); i++ }
}
fn lam_collect_stmt(s: parser::Statement, refs: Ref<[]str>, bound: Ref<[]str>) -> void {
    match s {
        parser::Binding as b => {
            lam_collect_expr(b.value, refs, bound)
            match b.target {
                parser::SimpleName as sn => bound.value = str_set_add(bound.value, sn.name)
                parser::DestructurePattern as dp => { mut j = 0; loop { if j >= dp.names.len { break }; bound.value = str_set_add(bound.value, dp.names[j]); j++ } }
            }
        }
        parser::Assign as a => { lam_collect_expr(a.value, refs, bound); match a.kind { parser::AssignKind::Field => lam_collect_expr(a.target, refs, bound); _ => { } } }   // (#88) a closure writing `obj.f = …` captures the receiver's free vars
        parser::Return as r => if r.has_value { lam_collect_expr(r.value, refs, bound) } else { }
        parser::LoopStmt as l => { lam_collect_block(l.init, refs, bound); lam_collect_block(l.body, refs, bound) }
        parser::ExprStmt as es => lam_collect_expr(es.expr, refs, bound)
        parser::DeferStmt as d => lam_collect_block(d.body, refs, bound)
        parser::AdoptStmt as a => lam_collect_block(a.body, refs, bound)
        parser::BreakStmt => { }
        parser::ContinueStmt => { }
    }
}
fn lam_collect_expr(e: parser::Expr, refs: Ref<[]str>, bound: Ref<[]str>) -> void {
    match e.kind {
        parser::Var as v => refs.value = str_set_add(refs.value, v.name)
        parser::Binary as b => { lam_collect_expr(b.left, refs, bound); lam_collect_expr(b.right, refs, bound) }
        parser::Unary as u => lam_collect_expr(u.operand, refs, bound)
        parser::Compare as c => { lam_collect_expr(c.first, refs, bound); mut i = 0; loop { if i >= c.rest.len { break }; lam_collect_expr(c.rest[i].operand, refs, bound); i++ } }
        parser::Call as cl => { if cl.callee.segments.len == 1 { refs.value = str_set_add(refs.value, cl.callee.segments[0].name) }; mut i = 0; loop { if i >= cl.args.len { break }; lam_collect_expr(cl.args[i], refs, bound); i++ } }
        parser::IfExpr as f => { lam_collect_expr(f.cond, refs, bound); lam_collect_block(f.then_blk, refs, bound); if f.has_else { lam_collect_block(f.else_blk, refs, bound) } }
        parser::MatchExpr as m => { lam_collect_expr(m.subject, refs, bound); mut i = 0; loop { if i >= m.arms.len { break }; lam_collect_block(m.arms[i].body, refs, bound); i++ } }
        parser::FieldAccess as fa => lam_collect_expr(fa.receiver, refs, bound)
        parser::SafeFieldAccess as sfa => lam_collect_expr(sfa.receiver, refs, bound)
        parser::Coalesce as co => { lam_collect_expr(co.left, refs, bound); lam_collect_expr(co.right, refs, bound) }
        parser::Cast as ct => lam_collect_expr(ct.expr, refs, bound)
        parser::MethodCall as mc => { lam_collect_expr(mc.receiver, refs, bound); mut i = 0; loop { if i >= mc.args.len { break }; lam_collect_expr(mc.args[i], refs, bound); i++ } }
        parser::SafeMethodCall as smc => { lam_collect_expr(smc.receiver, refs, bound); mut i = 0; loop { if i >= smc.args.len { break }; lam_collect_expr(smc.args[i], refs, bound); i++ } }   // (NP-OOP, issue #116)
        parser::StructLit as sl => { mut i = 0; loop { if i >= sl.field_vals.len { break }; lam_collect_expr(sl.field_vals[i], refs, bound); i++ } }
        parser::Index as ix => { lam_collect_expr(ix.receiver, refs, bound); lam_collect_expr(ix.index, refs, bound) }
        parser::Interp as in => { mut i = 0; loop { if i >= in.holes.len { break }; lam_collect_expr(in.holes[i], refs, bound); i++ } }
        parser::InExpr as n => { lam_collect_expr(n.lhs, refs, bound); mut i = 0; loop { if i >= n.elems.len { break }; lam_collect_expr(n.elems[i], refs, bound); i++ } }
        parser::ArrayLit as a => { mut i = 0; loop { if i >= a.elements.len { break }; lam_collect_expr(a.elements[i].expr, refs, bound); i++ } }
        parser::Lambda as lam => { mut i = 0; loop { if i >= lam.params.len { break }; bound.value = str_set_add(bound.value, lam.params[i].name); i++ }; lam_collect_block(lam.body, refs, bound) }   // a NESTED lambda's params are bound; its free reads transit to the outer
        parser::Number => { }
        parser::StrLit => { }
        parser::ByteLit => { }
        parser::CharLit => { }
        parser::BoolLit => { }
        parser::NullLit => { }
        parser::PathExpr => { }
    }
}

// type a closure literal. `expected` is the target type when known (a binding annotation / call-arg
// param) so an un-annotated parameter infers from it (W10 ruling 3); Void = no target. On success the
// TExpr.type is the closure's Func type. Captures = free vars resolving to ENCLOSING LOCALS (ns ""),
// each by-copy unless it is a `Ref<T>` (by_ref — the only path to shared mutation).
// resolve ONE closure parameter's type: its annotation, else the target's param type at `idx`
// (W10 ruling 3 — inference from the target), else an honest error (annotate or give a target type).
fn lam_param_type(p: parser::LambdaParam, idx: u64, exp_params: []Type, table: TypeTable, ref_ns: str) -> Type | error {
    // (#109 W1) ref_ns = the namespace the lambda is written in; unused until W2's R0-R5 rules.
    if p.has_type { return resolve_type(p.type_ann, table, ref_ns) }
    if idx < exp_params.len { return exp_params[idx] }
    error { message = $"cannot infer the type of closure parameter `{p.name}` — annotate it (`{p.name}: T`) or give the closure a target type" }
}
fn type_lambda(lam: parser::Lambda, expected: Type, env: Env, table: TypeTable) -> TExpr | error {
    mut exp_params: []Type = teko::list::empty()
    match expected { Func as ef => exp_params = ef.params; _ => { } }
    // 1. resolve parameter types (annotation, else the target's param type — ruling 3)
    mut tparams: []TLambdaParam = teko::list::empty()
    mut cenv = env
    mut i: u64 = 0
    loop {
        if i >= lam.params.len { break }
        let p = lam.params[i]
        let pt = match lam_param_type(p, i, exp_params, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the lambda's enclosing namespace
        tparams = teko::list::push(tparams, TLambdaParam { name = p.name; type = pt })
        cenv = define(cenv, p.name, pt, false)
        i++
    }
    // 2. type the body in the child scope (params visible). The return type is the TARGET's ret when a
    // target type is present (the annotation is authoritative — and handles a `return`-only body whose
    // trailing value is void); otherwise it is inferred from the body's trailing value.
    let tb = match type_block(lam.body, cenv, table) { TypedBlock as bk => bk; error as e => return e }
    let ret = match expected { Func as ef => ef.ret; _ => tblock_type(tb.stmts) }
    // 3. capture analysis — free vars (refs − bound − params) that resolve to an ENCLOSING LOCAL.
    mut refs: []str = teko::list::empty()
    mut bnd: []str = teko::list::empty()
    mut j = 0
    loop { if j >= lam.params.len { break }; bnd = str_set_add(bnd, lam.params[j].name); j++ }
    lam_collect_block(lam.body, refs, bnd)
    mut captures: []TCapture = teko::list::empty()
    mut k = 0
    loop {
        if k >= refs.len { break }
        let nm = refs[k]
        if !str_set_has(bnd, nm) {
            match lookup_binding(env, nm) {
                ValBinding as b => {
                    if b.ns.len == 0 {   // an enclosing LOCAL (a global/function has ns != "") → a capture
                        let by_ref = match b.type { Reference => true; _ => false }
                        captures = teko::list::push(captures, TCapture { name = nm; type = b.type; by_ref = by_ref })
                    }
                }
                error => { }   // not a local (a global/builtin) or unresolved (body typing already reported it)
            }
        }
        k++
    }
    TExpr { kind = TLambda { params = tparams; body = tb.stmts; captures = captures; ret = ret; lift_id = 0 }; type = Func { params = lam_param_types(tparams); ret = ret; variadic = false; param_names = []; n_required = (lam_param_types(tparams)).len; defaults = [] }; line = 0; col = 0 }
}
fn lam_param_types(ps: []TLambdaParam) -> []Type {
    mut out: []Type = teko::list::empty()
    mut i = 0
    loop { if i >= ps.len { break }; out = teko::list::push(out, ps[i].type); i++ }
    out
}

// ---- operators (the SAME B.22 regimes as check_binary/check_unary/check_compare) ----

// (2026-07-01) `~` — binary string concat, arity-polymorphic with unary `~` (bitwise NOT, see
// type_unary below). Additive precedence, NOT commutative (honest — Governing Law M.3, the same
// reasoning `+` was rejected for concat: TEKO_LEGISLATION.md "`+` never concatenates").
//
// Flattens a LEFT-ASSOCIATIVE `~` chain (`a ~ b ~ c ~ …`, which parses as a left-leaning
// Binary tree) into a flat piece list, so `a ~ b ~ c` desugars to ONE `teko::string::concat(a,
// b, c)` call — NOT nested 2-arg calls — reusing the params-variadic `concat` built for this.
fn flatten_tilde_chain(e: parser::Expr, acc: []parser::Expr) -> []parser::Expr {
    match e.kind {
        parser::Binary as b => {
            if b.op == lexer::TokenKind::Tilde {
                let acc2 = flatten_tilde_chain(b.left, acc)
                return flatten_tilde_chain(b.right, acc2)
            }
            teko::list::push(acc, e)
        }
        _ => teko::list::push(acc, e)
    }
}

fn tilde_str_lit_text(e: parser::Expr) -> str? {
    match e.kind {
        parser::StrLit as s => s.text
        // (2026-07-01) `$"no holes"` / `$@"""no holes"""` — interpolated syntax with ZERO holes
        // (the `verbatim` escaping flag is already resolved into `pieces` by parse time, so a
        // 0-hole Interp is indistinguishable from a plain literal here). Rare in practice (why
        // use `$`/`$@` with nothing to interpolate?), but foldable, so fold it — max compile-time
        // optimization per the user's explicit ask.
        parser::Interp as it => if it.holes.len == 0 && it.pieces.len == 1 { it.pieces[0] } else { null }
        _ => null
    }
}

// Constant-fold adjacent STR-LITERAL pieces at compile time (e.g. `x ~ "a" ~ "b" ~ y` folds
// `"a" ~ "b"` into ONE literal `"ab"` first, so the runtime call becomes `concat(x, "ab", y)` —
// 2 pieces, not 3). If EVERY piece folds into one literal, the whole `~` chain collapses to that
// single literal at compile time — zero runtime concat calls.
fn fold_tilde_pieces(pieces: []parser::Expr) -> []parser::Expr {
    mut out: []parser::Expr = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= pieces.len { break }
        match tilde_str_lit_text(pieces[i]) {
            str as t0 => {
                mut merged = t0
                mut j = i + 1
                loop {
                    if j >= pieces.len { break }
                    match tilde_str_lit_text(pieces[j]) {
                        str as tj => { merged = teko::string::concat(merged, tj); j++ }
                        null => { break }
                    }
                }
                out = teko::list::push(out, parser::Expr { kind = parser::StrLit { text = merged }; line = pieces[i].line; col = pieces[i].col })
                i = j
            }
            null => { out = teko::list::push(out, pieces[i]); i++ }
        }
    }
    out
}

fn type_tilde_chain(b: parser::Binary, env: Env, table: TypeTable) -> TExpr | error {
    let raw = flatten_tilde_chain(parser::Expr { kind = b; line = 0; col = 0 }, teko::list::empty())
    let folded = fold_tilde_pieces(raw)
    if folded.len == 1 { return type_expr(folded[0], env, table) }   // whole chain was literals — a single literal, no runtime call
    let seg_teko = parser::Segment { name = "teko" }
    let seg_string = parser::Segment { name = "string" }
    let seg_concat = parser::Segment { name = "concat" }
    mut segs: []parser::Segment = teko::list::push(teko::list::empty(), seg_teko)
    segs = teko::list::push(segs, seg_string)
    segs = teko::list::push(segs, seg_concat)
    mut pos_names: []str = teko::list::empty()   // DEFARGS (2026-07-01) — this synthetic call is always all-positional
    mut ni: u64 = 0
    loop { if ni >= folded.len { break }; pos_names = teko::list::push(pos_names, ""); ni++ }
    let call = parser::Call { callee = parser::Path { segments = segs }; args = folded; arg_names = pos_names; type_args = teko::list::empty() }
    // `concat`'s own arg-widening (type_call, below) already requires every piece to be `str` —
    // a non-str `~` operand fails there with a clear message, no separate check needed here.
    type_call(call, env, table)
}
/** `~` is desugared WHOLESALE (chain-flattened + literal-folded) BEFORE the generic operand-typing
    below — it never reaches a plain TBinary node (codegen/VM see an ordinary TCall or TStrLit,
    nothing new to handle, mirroring how `params` needed no engine changes).
    (S6, issue #162) operators over a constrained type-param T stay a HONEST STOP, intentionally —
    no operator-trait exists yet to authorize `+`/`-`/… the way an interface constraint authorizes
    a method call. `is_numeric`/`is_integer`/`is_bool` below never match a type-param's `Named{T}`
    (opaque OR interface-mirroring), so every arm below already falls through to its own clear error
    for a `T` operand — NO new logic is needed, and none is added here (avoids gold-plating a
    pre-alpha surface). Real operators on T arrive with an operator-trait constraint (#176+). */
fn type_binary(b: parser::Binary, env: Env, table: TypeTable) -> TExpr | error {
    if b.op == lexer::TokenKind::Tilde { return type_tilde_chain(b, env, table) }
    mut l = match type_expr(b.left, env, table) { TExpr as te => te; error as e => return e }
    mut r = match type_expr(b.right, env, table) { TExpr as te => te; error as e => return e }
    if type_is_void(l.type) || type_is_void(r.type) { return error { message = "a `void` expression cannot be an operand (M.1)" } }
    // C6 — a fitting numeric LITERAL operand adopts the OTHER operand's type (e.g. `line + 1`,
    // `n % 10`): the non-literal operand's type wins; rebuild the literal node with that type.
    if !type_eq(l.type, r.type) {
        if literal_adopts(l, r.type) { l = TExpr { kind = l.kind; type = r.type; line = l.line; col = l.col } }
        else { if literal_adopts(r, l.type) { r = TExpr { kind = r.kind; type = l.type; line = r.line; col = r.col } } }
    }
    if op_is_shift(b.op) {
        if !is_integer(l.type) || !is_integer(r.type) { return error { message = "shift needs integer operands (no float bit-shifts — B.38)" } }
        return TExpr { kind = TBinary { op = b.op; left = l; right = r }; type = l.type; line = 0; col = 0 }
    }
    if op_is_arith(b.op) {
        // + - * / over the native numeric set (B.38): ints AND floats. Same-type only
        // (B.22 — no promotion, no mixed int/float; cross-family needs an explicit `to`).
        if !is_numeric(l.type) { return error { message = "arithmetic needs a numeric operand (int or float)" } }
        // (C1.8/E2) attach expected=type_render(l.type), actual=type_render(r.type) so the driver
        // prints "expected X, found Y" — mirrors expr.c type_binary's tk_error_types wrap.
        if !type_eq(l.type, r.type) { return teko::error::err_typed(error { message = "operands must be the same type (no promotion, no mixed int/float — B.22; use `to`)" }, type_render(l.type), type_render(r.type)) }
        return TExpr { kind = TBinary { op = b.op; left = l; right = r }; type = l.type; line = 0; col = 0 }
    }
    if op_is_arith_bitwise(b.op) {   // %, & | ^ — integer-only
        if !is_integer(l.type) { return error { message = "bitwise/remainder needs an integer (not a float — B.38)" } }
        // (C1.8/E2) attach expected/actual (type_render of l/r) — mirrors expr.c type_binary.
        if !type_eq(l.type, r.type) { return teko::error::err_typed(error { message = "operands must be the same type (no promotion — B.22)" }, type_render(l.type), type_render(r.type)) }
        return TExpr { kind = TBinary { op = b.op; left = l; right = r }; type = l.type; line = 0; col = 0 }
    }
    if b.op == lexer::TokenKind::AndAnd || b.op == lexer::TokenKind::OrOr {   // logical && / || — bool operands, bool result, short-circuit (matches C + the VM)
        if !is_bool(l.type) || !is_bool(r.type) { return error { message = "logical `&&`/`||` need bool operands" } }
        return TExpr { kind = TBinary { op = b.op; left = l; right = r }; type = Prim { kind = PrimKind::Bool }; line = 0; col = 0 }
    }
    error { message = "not a binary operator" }
}

fn type_unary(u: parser::Unary, env: Env, table: TypeTable) -> TExpr | error {
    let o = match type_expr(u.operand, env, table) { TExpr as te => te; error as e => return e }
    if type_is_void(o.type) { return error { message = "a `void` expression cannot be an operand (M.1)" } }
    if u.op == lexer::TokenKind::Minus {   // negation: any numeric (int or float — B.38)
        if !is_numeric(o.type) { return error { message = "unary `-` needs a numeric operand (int or float)" } }
        return TExpr { kind = TUnary { op = u.op; operand = o }; type = o.type; line = 0; col = 0 }
    }
    if u.op == lexer::TokenKind::Tilde {   // bitwise complement: integer-only (no float bit-flip — B.38)
        if !is_integer(o.type) { return error { message = "unary `~` needs an integer (not a float — B.38)" } }
        return TExpr { kind = TUnary { op = u.op; operand = o }; type = o.type; line = 0; col = 0 }
    }
    if u.op == lexer::TokenKind::Bang {
        if !is_bool(o.type) { return error { message = "! needs a bool" } }
        return TExpr { kind = TUnary { op = u.op; operand = o }; type = o.type; line = 0; col = 0 }
    }
    error { message = "not a unary operator" }
}

fn type_compare(c: parser::Compare, env: Env, table: TypeTable) -> TExpr | error {
    mut first = match type_expr(c.first, env, table) { TExpr as te => te; error as e => return e }
    mut prev = first.type
    if type_is_void(prev) { return error { message = "a `void` expression cannot be an operand (M.1)" } }
    mut terms: []TCmpTerm = teko::list::empty()
    mut i = 0
    loop {
        if i >= c.rest.len { break }
        mut cur = match type_expr(c.rest[i].operand, env, table) { TExpr as te => te; error as e => return e }
        if type_is_void(cur.type) { return error { message = "a `void` expression cannot be an operand (M.1)" } }
        // numeric-literal adoption (parity with binary ops): a literal operand adopts the OTHER's
        // numeric type so `c < 0x20` (byte vs int-literal) and `0x20 < c` compare (byte = u8).
        let cur_is_num = match cur.kind { TNumber => true; _ => false }
        let first_is_num = match first.kind { TNumber => true; _ => false }
        if cur_is_num && literal_adopts(cur, prev) {
            cur = TExpr { kind = cur.kind; type = prev; line = cur.line; col = cur.col }
        } else if i == 0 && first_is_num && literal_adopts(first, cur.type) {
            first = TExpr { kind = first.kind; type = cur.type; line = first.line; col = first.col }
            prev = cur.type
        }
        if !is_comparable(prev, cur.type) { return error { message = "operands are not comparable" } }
        terms = teko::list::push(terms, TCmpTerm { op = c.rest[i].op; operand = cur })
        prev = cur.type
        i++
    }
    TExpr { kind = TCompare { first = first; rest = terms }; type = Prim { kind = PrimKind::Bool }; line = 0; col = 0 }
}

/**
 * Marker: the call is not a `teko::list::*` builtin — `type_list_builtin` falls back so its
 * caller resolves the call through the ordinary path.
 */
type NotListBuiltin = struct { }

/**
 * The GENERIC `teko::list::*` builtins that have no `.tks` module of their own (like
 * print/assert): `empty()`, `push(s, x)`, and `with_cap(n)`. Recognized by the LAST-2 path
 * segments (`list::empty` / `list::push` / `list::with_cap`), rooted at `teko` (or bare
 * `list::*`). The element type is INFERRED (B.8/Slice):
 *   - `empty()` -> `[]<sentinel>` (a `Slice` whose element is the `Void` marker, unifying with
 *     any concrete slice);
 *   - `push(s, x)` -> `[]typeof(x)`; `s` must be a slice (sentinel or a matching element);
 *   - `with_cap(n)` -> `[]<sentinel>`, exactly like `empty()`, but the runtime buffer is
 *     pre-sized for `n` elements (an enabling primitive — staged off; no compiler source calls
 *     it yet).
 * The C twin instead uses a `bool handled` out-param; Teko has no out-params, so the tri-state
 * result here is a 3-member variant (`T? | error` is illegal — a variant member may not be
 * nullable).
 *
 * @param c      the raw call node
 * @param env    the typing environment
 * @param table  the folded type table
 * @return       the typed `TExpr` for a recognized `list::*` builtin, `NotListBuiltin` when the
 *               call is not one of these (the caller falls back to ordinary resolution), or
 *               `error` on a malformed call (wrong arity, a non-slice base, or a mismatched item)
 */
fn type_list_builtin(c: parser::Call, env: Env, table: TypeTable) -> TExpr | NotListBuiltin | error {
    if c.callee.segments.len < 2 { return NotListBuiltin { } }
    let last = c.callee.segments[c.callee.segments.len - 1].name
    let prev = c.callee.segments[c.callee.segments.len - 2].name
    // (#148 R3) teko::mem::push_fo — push with FREE-OLD BY DECREE. Same typing/semantics as
    // teko::list::push; the CALLER asserts the base is a linear chain (the old buffer is dead
    // after the grow), so native codegen frees it (tk_slice_push_fo). TEKO_MEM_PARANOID is the
    // fiscal: a wrong decree poisons instead of parking and the gate fails loudly. (Mirror expr.c.)
    let is_pushfo = prev == "mem" && last == "push_fo"
    if prev != "list" && !is_pushfo { return NotListBuiltin { } }
    let rooted = c.callee.segments.len == 2 || c.callee.segments[0].name == "teko"
    if !rooted { return NotListBuiltin { } }

    if last == "empty" {
        if c.args.len != 0 { return error { message = "teko::list::empty expects no arguments" } }
        // SENTINEL slice: element is the Void marker (unifies with any concrete slice — type_eq).
        TExpr { kind = TCall { callee = c.callee; args = teko::list::empty(); call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Slice { element = Void { } }; line = 0; col = 0 }
    } else if last == "push" || is_pushfo {
        if c.args.len != 2 { return error { message = "teko::list::push expects two arguments (slice, item)" } }
        let s = match type_expr(c.args[0], env, table) { TExpr as te => te; error as e => return e }
        let x = match type_expr(c.args[1], env, table) { TExpr as te => te; error as e => return e }
        let elem = match s.type { Slice as sl => sl.element; _ => return error { message = "teko::list::push first argument must be a slice (`[]T`)" } }
        if type_is_void(x.type) { return error { message = "teko::list::push item cannot be a `void` expression (M.1)" } }
        // A SENTINEL base (Void element) is fixed BY the item — the result element is the item's type.
        // A CONCRETE element is preserved; the item must WIDEN into it (a case into a variant element —
        // so a `[]Type` accepts heterogeneous cases: str, u64, …) OR adopt it (literal). (Mirror expr.c.)
        let result_elem = match elem {
            Void => x.type
            _ => {
                if !widens_into(x.type, elem, table) && !literal_adopts(x, elem) { return error { message = "teko::list::push item type does not match the slice element type" } }
                elem
            }
        }
        // (#57) CONCRETIZE a SENTINEL base (bare empty()) to []elem so codegen can EMIT it; the VM
        // ignores a slice's element type but codegen's emit_list_empty REQUIRES it. (Mirror expr.c.)
        let base = match elem { Void => TExpr { kind = s.kind; type = Slice { element = result_elem }; line = s.line; col = s.col }; _ => s }
        mut args = teko::list::push(teko::list::push(teko::list::empty(), base), x)
        TExpr { kind = TCall { callee = c.callee; args = args; call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Slice { element = result_elem }; line = 0; col = 0 }
    } else if last == "with_cap" {
        if c.args.len != 1 { return error { message = "teko::list::with_cap expects one argument (the initial capacity, a `u64`)" } }
        let n = match type_expr(c.args[0], env, table) { TExpr as te => te; error as e => return e }
        let cap_t = Prim { kind = PrimKind::U64 }
        mut n_typed = n
        if !type_eq(n.type, cap_t) {
            if !literal_adopts(n, cap_t) { return error { message = $"teko::list::with_cap's argument must be a `u64` — got `{type_render(n.type)}`" } }
            n_typed = TExpr { kind = n.kind; type = cap_t; line = n.line; col = n.col }
        }
        let wargs = teko::list::push(teko::list::empty(), n_typed)
        TExpr { kind = TCall { callee = c.callee; args = wargs; call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Slice { element = Void { } }; line = 0; col = 0 }
    } else {
        NotListBuiltin { }
    }
}

// (mem::free ruling 2026-07-03) `teko::mem::free<T>(target: []T | Ref<T>) -> void` — MANUAL opt-in
// deallocation, the third lifetime lever ([[teko-mem-free-design]]). ONE builtin whose parameter is a
// SUM of the two heap shapes; the checker dispatches the arm STATICALLY by the argument's resolved
// type (no runtime tag). SAFETY (the "equilíbrio"): the target must be a MUTABLE VARIABLE — the
// lowering scrubs it (slice → empty, class handle → null) at the free site, so a direct
// `free(x); use(x)` reads the scrubbed-empty value, never the parked buffer. But an ALIASED free
// (`y = x; free(x); use(y)`) is NOT caught: not statically (there is no uniqueness/points-to fact
// yet), and NOT by ASan either. `mem::free` never calls libc `free` -- it parks the block on a
// private free-list over the arena (teko_rt.c:856), so a use-after-free reads reused-but-still-mapped
// memory that AddressSanitizer cannot see. Only `TEKO_MEM_PARANOID=1` (poison-and-never-reuse) traps
// it today. The real fix is the inferred-spine affine/uniqueness check
// (docs/design/memory-unsafe-backend-remodel.md); until it lands, aliased free is the caller's razor
// + PARANOID, NOT a static or ASan guarantee. Returns void.
type NotMemFree = struct { }
fn type_mem_free(c: parser::Call, env: Env, table: TypeTable) -> TExpr | NotMemFree | error {
    if c.callee.segments.len < 2 { return NotMemFree { } }
    let last = c.callee.segments[c.callee.segments.len - 1].name
    let prev = c.callee.segments[c.callee.segments.len - 2].name
    if last != "free" || prev != "mem" { return NotMemFree { } }
    let rooted = c.callee.segments.len == 2 || c.callee.segments[0].name == "teko"
    if !rooted { return NotMemFree { } }
    if c.args.len != 1 { return error { message = "teko::mem::free expects one argument (a mutable `[]T` or class variable)" } }
    let arg = match type_expr(c.args[0], env, table) { TExpr as te => te; error as e => return e }
    // the target must be a plain VARIABLE (so the lowering can scrub it) that is `mut` (owned to free).
    let vname = match arg.kind { TVar as v => v.name; _ => return error { message = "teko::mem::free requires a mutable variable — the value must have a binding to invalidate" } }
    let vb = match lookup_binding(env, vname) { ValBinding as b => b; error as e => return e }
    if !vb.is_mut { return error { message = $"cannot free immutable `{vname}` — declare it `mut` (free invalidates the binding)" } }
    let is_heap = match arg.type {
        Slice => true
        Named as nm => is_class_name(nm.name, table) || is_region_handle_name(nm.name, table)
        _ => false
    }
    if !is_heap { return error { message = $"teko::mem::free target must be a `[]T` slice, a class instance, or a manual region handle (`unsafe #must_free type` with a single `uptr` field) — `{type_render(arg.type)}` owns no freeable heap block" } }
    let av = teko::list::push(teko::list::empty(), arg)
    TExpr { kind = TCall { callee = c.callee; args = av; call_ns = "teko::mem"; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Void { }; line = 0; col = 0 }
}

/**
 * The negative sentinel for `type_region_new`/`type_region_alloc` — the call is not one of the
 * manual-region builtins, so `type_call` falls through to ordinary resolution.
 */
type NotRegionOp = struct { }

/**
 * (S3, issue #358) `teko::mem::region_new() -> uptr` — the manual-region CONSTRUCTOR builtin
 * behind `Arena::new()`. Opens a fresh child region under the process root (`tk_region_new`) and
 * hands its raw `tk_region *` back as an opaque `uptr` word — the value an `unsafe #must_free type
 * Arena` stores in its single field and later bulk-frees via `teko::mem::free`. Non-generic,
 * zero-arity; dispatched statically by the (rooted) `teko::mem::region_new` path exactly like
 * `type_mem_free`, BEFORE ordinary name resolution, so it never collides with a user symbol.
 *
 * @param parser::Call c  the raw call node
 * @param Env env  the typing environment
 * @param TypeTable table  the folded type table
 * @return TExpr | NotRegionOp | error  a `uptr`-typed void-namespaced TCall, `NotRegionOp` if the path is not region_new,
 *               or an error on wrong arity
 */
fn type_region_new(c: parser::Call, env: Env, table: TypeTable) -> TExpr | NotRegionOp | error {
    if c.callee.segments.len < 2 { return NotRegionOp { } }
    let last = c.callee.segments[c.callee.segments.len - 1].name
    let prev = c.callee.segments[c.callee.segments.len - 2].name
    if last != "region_new" || prev != "mem" { return NotRegionOp { } }
    let rooted = c.callee.segments.len == 2 || c.callee.segments[0].name == "teko"
    if !rooted { return NotRegionOp { } }
    if c.args.len != 0 { return error { message = "teko::mem::region_new takes no arguments (it opens a fresh region)" } }
    TExpr { kind = TCall { callee = c.callee; args = teko::list::empty(); call_ns = "teko::mem"; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Uptr { }; line = 0; col = 0 }
}

/**
 * (S3, issue #358) `teko::mem::region_alloc(region: uptr, init: T) -> ptr<T>` — bump-allocates a
 * `T` INTO the region named by the `uptr` handle, copies `init` into it, and hands back a raw
 * `ptr<T>` attached to that region's lifetime (dangling after the region is freed — the `unsafe`
 * risk the dev owns). This is the manual, non-lexical complement to `teko::mem::buf_ptr` (which
 * allocates a byte buffer into the ENCLOSING region); here the region is CHOSEN by the caller.
 *
 * The element type `T` is INFERRED from `init`'s resolved type — no method-level/free generic
 * machinery is involved (this is a special checker+codegen builtin, not a Teko-bodied generic fn),
 * so it sidesteps the generic-stack gaps entirely (see the #358 fixture header + DECISION_LOG).
 * `init` may be any concrete non-void value; the returned `ptr<T>` is opaque in Teko, crossing the
 * boundary only via the existing raw-pointer builtins (`bytes_from_ptr`, a raw `extern`).
 *
 * @param parser::Call c  the raw call node
 * @param Env env  the typing environment
 * @param TypeTable table  the folded type table
 * @return TExpr | NotRegionOp | error  a `ptr<T>`-typed TCall (T = init's type), `NotRegionOp` if the path is not
 *               region_alloc, or an error on wrong arity / a non-`uptr` region / a `void` init
 */
fn type_region_alloc(c: parser::Call, env: Env, table: TypeTable) -> TExpr | NotRegionOp | error {
    if c.callee.segments.len < 2 { return NotRegionOp { } }
    let last = c.callee.segments[c.callee.segments.len - 1].name
    let prev = c.callee.segments[c.callee.segments.len - 2].name
    if last != "region_alloc" || prev != "mem" { return NotRegionOp { } }
    let rooted = c.callee.segments.len == 2 || c.callee.segments[0].name == "teko"
    if !rooted { return NotRegionOp { } }
    if c.args.len != 2 { return error { message = "teko::mem::region_alloc expects two arguments (a `uptr` region handle and the value to allocate)" } }
    let region = match type_expr(c.args[0], env, table) { TExpr as te => te; error as e => return e }
    let region_ok = match region.type { Uptr => true; _ => false }
    if !region_ok { return error { message = $"teko::mem::region_alloc's first argument must be a `uptr` region handle — got `{type_render(region.type)}`" } }
    let init = match type_expr(c.args[1], env, table) { TExpr as te => te; error as e => return e }
    if type_is_void(init.type) { return error { message = "teko::mem::region_alloc cannot allocate a `void` value" } }
    mut ra_args = teko::list::push(teko::list::empty(), region)
    ra_args = teko::list::push(ra_args, init)
    TExpr { kind = TCall { callee = c.callee; args = ra_args; call_ns = "teko::mem"; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Ptr { inner = init.type }; line = 0; col = 0 }
}

// (2026-07-01) call-site desugar for a `params`-variadic function `f`. Two shapes:
//   passthrough — exactly `f.params.len` raw args AND the last one is already typed `[]T`
//     (T = the params element type) → pass through unchanged, no re-wrapping.
//   pack — otherwise, the trailing args (0 or more) beyond the fixed prefix are collapsed into
//     ONE synthetic array-literal `parser::Expr` (reusing array-literal codegen — Increment B+),
//     so the rest of `type_call` sees an ordinary `f.params.len`-arity call.
fn pack_variadic_args(f: Func, args: []parser::Expr, env: Env, table: TypeTable) -> []parser::Expr | error {
    let nfixed = f.params.len - 1
    let elem_ty = match f.params[nfixed] { Slice as s => s.element; _ => Void { } }   // parser already enforced the last param is a Slice
    if args.len == f.params.len {
        let last = match type_expr(args[nfixed], env, table) { TExpr as te => te; error as e => return e }
        if type_eq(last.type, Slice { element = elem_ty }) { return args }   // passthrough
    }
    if args.len < nfixed { return error { message = "wrong number of arguments" } }
    mut elems: []parser::ArrayElem = teko::list::empty()
    mut i = nfixed
    loop {
        if i >= args.len { break }
        elems = teko::list::push(elems, parser::ArrayElem { is_spread = false; expr = args[i] })
        i++
    }
    let synth = parser::Expr { kind = parser::ArrayLit { elements = elems }; line = 0; col = 0 }
    mut out: []parser::Expr = teko::list::empty()
    mut j = 0
    loop {
        if j >= nfixed { break }
        out = teko::list::push(out, args[j])
        j++
    }
    teko::list::push(out, synth)
}

// (2026-07-01 DEFARGS) call-site resolution for a NON-variadic function `f`: named-arg-to-index
// lookup + default-fill for omitted trailing params. Produces a positional []parser::Expr of
// EXACTLY f.params.len entries, in declaration order, ready for the ordinary typing loop below.
// NOTE: intentionally NOT composed with `params`/variadic (pack_variadic_args, above) yet — a
// function that is BOTH variadic AND has named/default params is an unsupported combination for
// now (type_call only calls this for `!f.variadic`); Teko has no array index-assignment, so this
// builds the result via a single forward pass (0..params.len), pushing whichever source (a
// positional arg, a matching named arg, or the param's default) applies at each index.
fn resolve_defargs(f: Func, args: []parser::Expr, arg_names: []str) -> []parser::Expr | error {
    mut any_named = false
    mut ai: u64 = 0
    loop { if ai >= arg_names.len { break }; if arg_names[ai] != "" { any_named = true }; ai++ }
    if !any_named && args.len == f.params.len { return args }   // fast identity path — the overwhelmingly common case, zero overhead
    if any_named && f.param_names.len != f.params.len {
        return error { message = "this function cannot be called with named arguments (only a plain, named `fn` declaration supports named-call — not a closure value or builtin)" }
    }
    // the positional PREFIX length (rule D: named-LAST — already enforced at parse time, so the
    // first named arg marks where positional args end).
    mut npos: u64 = 0
    loop { if npos >= arg_names.len { break }; if arg_names[npos] != "" { break }; npos++ }
    if npos > f.params.len { return error { message = "wrong number of arguments" } }
    // validate every named arg targets a REAL, not-already-positionally-filled param.
    mut vk: u64 = npos
    loop {
        if vk >= args.len { break }
        let nm = arg_names[vk]
        mut fidx: u64 = 0
        mut matched = false
        loop { if fidx >= f.param_names.len { break }; if f.param_names[fidx] == nm { matched = true; break }; fidx++ }
        if !matched { return error { message = $"unknown named argument '{nm}'" } }
        if fidx < npos { return error { message = $"named argument '{nm}' was already provided positionally" } }
        vk++
    }
    mut resolved: []parser::Expr = teko::list::empty()
    mut idx: u64 = 0
    loop {
        if idx >= f.params.len { break }
        if idx < npos {
            resolved = teko::list::push(resolved, args[idx])
        } else {
            mut found = false
            mut found_expr = parser::no_expr()
            mut k: u64 = npos
            loop {
                if k >= args.len { break }
                if arg_names[k] == f.param_names[idx] { found = true; found_expr = args[k]; break }
                k++
            }
            if found {
                resolved = teko::list::push(resolved, found_expr)
            } else if idx < f.n_required {
                return error { message = $"missing required argument '{f.param_names[idx]}'" }
            } else {
                resolved = teko::list::push(resolved, f.defaults[idx - f.n_required])
            }
        }
        idx++
    }
    resolved
}

// (C8.3, ported 2026-07-01 to close a self-host gap — see is_flags_method) flags helper method
// calls: recv.has/all/any/none/add/remove(mask). Lowered to synthetic TAST nodes directly (not
// through type_binary/type_unary's normal operator checks — the mask arithmetic is internal):
//   add(mask)    -> recv | mask             (TBinary, flags type)
//   remove(mask) -> recv & ~mask            (TBinary with a nested TUnary)
//   has/all(mask)-> (recv & mask) == mask   (TCompare, bool)
//   any(mask)    -> (recv & mask) != 0_flags
//   none(mask)   -> (recv & mask) == 0_flags
// The C bootstrap (expr.c::type_flags_method) has carried this since C8.3; the self-hosted .tks
// checker never did (is_flags_method was defined, dead — a MethodCall always hit the "deferred"
// error before it could dispatch here). Mirror of expr.c::type_flags_method.
fn type_flags_method(mc: parser::MethodCall, env: Env, table: TypeTable) -> TExpr | error {
    let recv = match type_expr(mc.receiver, env, table) { TExpr as te => te; error as e => return e }
    let rt = recv.type
    if !is_flags_named(rt, table) { return error { message = "method call on a non-flags receiver (flags methods: has/all/any/none/add/remove)" } }
    if mc.args.len != 1 { return error { message = "flags methods take exactly one argument (the mask)" } }
    let mask = match type_expr(mc.args[0], env, table) { TExpr as te => te; error as e => return e }
    if !type_eq(rt, mask.type) {
        return teko::error::err_typed(error { message = "flags method argument must be the same flags type as the receiver" }, type_render(rt), type_render(mask.type))
    }
    let is_has = mc.method == "has"
    let is_all = mc.method == "all"
    let is_any = mc.method == "any"
    let is_none = mc.method == "none"
    let is_add = mc.method == "add"
    let is_rem = mc.method == "remove"
    if !is_has && !is_all && !is_any && !is_none && !is_add && !is_rem {
        return error { message = "unknown flags method (has/all/any/none/add/remove)" }
    }
    if is_add {
        return TExpr { kind = TBinary { op = lexer::TokenKind::Pipe; left = recv; right = mask }; type = rt; line = 0; col = 0 }
    }
    if is_rem {
        let notmask = TExpr { kind = TUnary { op = lexer::TokenKind::Tilde; operand = mask }; type = rt; line = 0; col = 0 }
        return TExpr { kind = TBinary { op = lexer::TokenKind::Amp; left = recv; right = notmask }; type = rt; line = 0; col = 0 }
    }
    let andexpr = TExpr { kind = TBinary { op = lexer::TokenKind::Amp; left = recv; right = mask }; type = rt; line = 0; col = 0 }
    if is_has || is_all {
        let term = TCmpTerm { op = lexer::TokenKind::EqEq; operand = mask }
        return TExpr { kind = TCompare { first = andexpr; rest = teko::list::push(teko::list::empty(), term) }; type = Prim { kind = PrimKind::Bool }; line = 0; col = 0 }
    }
    // any/none: compare (recv & mask) against a zero-valued flags literal (the same pattern as
    // an enum ordinal cast — codegen/VM read the NAMED flags type off the node, not the literal).
    let zero = TExpr { kind = TNumber { is_float = false; value = 0; fval = 0.0 }; type = rt; line = 0; col = 0 }
    let cmp_op = if is_none { lexer::TokenKind::EqEq } else { lexer::TokenKind::Ne }
    let term = TCmpTerm { op = cmp_op; operand = zero }
    TExpr { kind = TCompare { first = andexpr; rest = teko::list::push(teko::list::empty(), term) }; type = Prim { kind = PrimKind::Bool }; line = 0; col = 0 }
}

/** (W10b.D3; generalized S6/issue #162) a resolved interface dot-call: the DECLARING interface
    (the D3 vtable/upcast key), the resolved Function signature, and its vtable SLOT within that
    interface's own effective-methods list. */
type IfaceDispatch = struct { iface: str; method: parser::Function; slot: u32 }

/** (S6) find `method` within `eff` (an interface's own effective methods), returning its slot. */
fn find_method_slot(eff: []parser::Function, method: str) -> IfaceDispatch? {
    mut i: u64 = 0
    loop {
        if i >= eff.len { break }
        if eff[i].name == method { return IfaceDispatch { iface = ""; method = eff[i]; slot = i to u32 } }
        i++
    }
    null
}

/** (W10b.D2, issue #99; generalized S6/issue #162) resolve `method` on an InterfaceBody receiver
    to its DISPATCH interface + slot. A plain interface receiver (methods.len > 0 — it declares its
    OWN methods, so it IS the dispatch interface) resolves against ITSELF (`struct_name`). A body
    with NO own methods (methods.len == 0) is either a genuine `interface X extends A, B {}` OR a
    generic type-param's synthetic InterfaceBody (type_param_table; S6: an `extends` list of N real
    interfaces, the constraint's And-union / Or-intersection surface) — BOTH shapes want the SAME
    resolution: search EACH interface of `extends`, in order, for the first that OWNS the method
    (method_owner_interface — the D3 vtable key), and read the slot from THAT interface's own
    effective-methods list (never a concatenated list — the emitted vtable is per-(class,
    interface), so the slot must agree with it). This subsumes the single-extends #99 case (the
    search trivially finds the one interface). A method owned by no interface of `extends` is the
    S6 "outside the authorized surface" honest stop. */
fn resolve_iface_dispatch(ib: parser::InterfaceBody, struct_name: str, method: str, table: TypeTable) -> IfaceDispatch | error {
    if ib.methods.len > 0 {
        let eff = match iface_methods_by_name(struct_name, table) { []parser::Function as f => f; error as e => return e }
        return match find_method_slot(eff, method) {
            IfaceDispatch as d => IfaceDispatch { iface = struct_name; method = d.method; slot = d.slot }
            null => error { message = $"no such method '{method}' on interface '{struct_name}'" }
        }
    }
    let owner = match method_owner_interface(ib.extends, method, table) {
        str as o => o
        null => return error { message = $"method '{method}' is not guaranteed by the constraint on type parameter '{struct_name}' ({type_param_surface_message(ib.extends, table)})" }
    }
    let eff = match iface_methods_by_name(owner, table) { []parser::Function as f => f; error as e => return e }
    match find_method_slot(eff, method) {
        IfaceDispatch as d => IfaceDispatch { iface = owner; method = d.method; slot = d.slot }
        null => error { message = $"internal: method_owner_interface named '{owner}' as owner of '{method}' but its effective methods do not contain it" }
    }
}

/** (S6, M.1) render the type-param's authorized surface (every method name every constrained
    interface of `extends` contributes) for the "not guaranteed by the constraint" error — so the
    message enumerates what IS available, never just what is missing. */
fn type_param_surface_message(extends: []str, table: TypeTable) -> str {
    mut names = ""
    mut i = 0
    loop {
        if i >= extends.len { break }
        let ms = match iface_methods_by_name(extends[i], table) { []parser::Function as f => f; error => teko::list::empty() }
        mut j = 0
        loop {
            if j >= ms.len { break }
            if names == "" { names = ms[j].name } else { names = $"{names}, {ms[j].name}" }
            j++
        }
        i++
    }
    if names == "" { return "available: none" }
    $"available: {names}"
}

/** (S6, M.1) is `decl` a type-param's OWN synthetic decl (resolve::type_param_table) — never a
    genuine user decl, which the parser's own invariant keeps same-length on `type_params`/
    `type_constraints` (so a real 0-type-param decl always carries 0 constraints, the one shape a
    type-param's synthetic decl never has). */
fn is_type_param_decl(decl: parser::TypeDecl) -> bool {
    decl.type_params.len == 0 && decl.type_constraints.len == 1
}

/** (S6, M.1) when a constrained type-param's `extends` list came back EMPTY not because the
    constraint genuinely authorizes nothing (NoConstraint / a struct-or-variant atom) but because
    resolve::constraint_interfaces ERRORED (a trait atom / an unknown atom / a Risco-3 ambiguity),
    recompute that SAME error here so the honest stop names the real reason instead of the generic
    "method typing is deferred" — resolve::type_param_table has no error channel, so this is where
    the swallowed error re-surfaces, at the first attempted operation on `T` (never silently lost). */
fn type_param_call_error(decl: parser::TypeDecl, table: TypeTable) -> error? {
    if !is_type_param_decl(decl) { return null }
    match constraint_interfaces(decl.type_constraints[0], table) {
        []str => null
        error as e => e
    }
}

/**
 * Build the direct-method-dispatch callee as a TWO-segment path whose qualifier segment carries the
 * receiver's FULL CANONICAL class name (`ns::…::Class`) and whose last segment is the method, so
 * `lookup_call`/`call_ns` key off the exact owning namespace and never collide with a same-bare
 * class in a sibling namespace (#290, #109-family). The receiver's `struct_name` is already
 * canonical (from `recv_t = Named{n.name}`), so it is placed verbatim as the single qualifier
 * segment; `ns_matches_call_qualifier` then compares `b.ns` against that whole canonical string
 * (equals, or ends-with `::<class>`), disambiguating two same-bare classes. Keeping the qualifier in
 * ONE segment — rather than splitting it back to `[..ns.., Class]` — means the callee never starts
 * with `teko`, so it never trips the VM's `teko`-rooted builtin name-sniffer (which would otherwise
 * treat a method named `len`/`str`/`parse`/… on a `teko::…` class as a string builtin). Mirrors how
 * FIELD access already resolves off the canonical `Named` via the type table (why fields never
 * regressed). Both backends read only the LAST segment (the method) plus `TCall.call_ns`, so the
 * qualifier's shape is transparent to codegen and the VM.
 *
 * @param struct_name  the receiver's canonical class name (`ns::…::Class`, or bare at the root ns)
 * @param method       the dispatched method's bare name
 * @return             the `[Class-canonical, method]` callee path
 * @since onda-3 (#290)
 */
fn method_dispatch_callee(struct_name: str, method: str) -> parser::Path {
    mut segs: []parser::Segment = teko::list::push(teko::list::empty(), parser::Segment { name = struct_name })
    segs = teko::list::push(segs, parser::Segment { name = method })
    parser::Path { segments = segs }
}

/** `recv.method(args)` — an INSTANCE struct-method dot-call (OOP A1, 2026-07-01). Desugars into
    an ordinary `StructName::method(recv, ...args)` Call and delegates to `type_call` wholesale
    (reuses arity/defargs/generics/namespace-mangling for free — the same trick `~` used for
    `teko::string::concat`). The receiver is typed ONCE here just to discover which struct/method
    is targeted; `type_call` re-types it (and every arg) as part of its normal argument pass.
    Flags-typed receivers dispatch to type_flags_method (the dispatch's job, mirroring the C
    switch's precedence — see type_dispatch's MethodCall arm), never reaching here. A bare `.` call
    on a nullable receiver stays a compile error (NP-OOP, issue #116) — but names WHY and points at
    the sanctioned null-propagating call (`?.`) instead of the deferral message. The receiver-type
    lookup (`type_table_find`) is a resolved-name probe (#109 W1, no referencing ns); once resolved,
    a type-param's swallowed constraint error (S6, M.1 — a trait atom / an unknown atom / a Risco-3
    ambiguity) re-surfaces here, named, before an INTERFACE-typed receiver's DYNAMIC contract-method
    call resolves against the interface's EFFECTIVE (extends-transitive) signature list; its index
    there is the vtable slot both backends dispatch through. The receiver rides as args[0] (an
    interface value, or a class instance the emitters upcast on the fly). Mirror:
    expr.c::type_method_call. */
fn type_method_call(mc: parser::MethodCall, env: Env, table: TypeTable) -> TExpr | error {
    let recv_t = match type_expr(mc.receiver, env, table) { TExpr as te => te.type; error as e => return e }
    if is_flags_named(recv_t, table) { return error { message = "method typing is deferred (B.29 / M.4)" } }
    match recv_t {
        Optional => return error { message = "cannot call a method with `.` on a nullable value (`T?`) — use `?.` (REBOOT_PLAN §203)" }
        _ => { }
    }
    let struct_name = match recv_t { Named as n => n.name; _ => return error { message = "method typing is deferred (B.29 / M.4)" } }
    let decl = match type_table_find(table, struct_name, "") { parser::TypeDecl as td => td; error => return error { message = "method typing is deferred (B.29 / M.4)" } }
    match type_param_call_error(decl, table) { error as e => return e; null => { } }
    match decl.body {
        parser::InterfaceBody as ib => return type_contract_dispatch(ib, struct_name, mc, env, table)
        parser::TraitBody as tb => return type_contract_dispatch(parser::InterfaceBody { extends = teko::list::empty(); methods = tb.methods }, struct_name, mc, env, table)
        _ => { }
    }
    // (W10b.CLASS increment 1) a class's instance dot-call reuses this SAME desugar — only the
    // methods list's source differs; a class's methods are otherwise typed exactly like a struct's.
    let methods = match decl.body {
        parser::StructBody as sb => sb.methods
        parser::ClassBody as cb => match effective_class_methods(cb, table) { []parser::Function as f => f; error as e => return e }   // (W10b.CLASS increment 2) inherited methods are callable too
        _ => return error { message = "method typing is deferred (B.29 / M.4)" }
    }
    if methods.len == 0 { return error { message = $"no such method '{mc.method}' on struct '{struct_name}'" } }
    mut mi: u64 = 0
    mut found = false
    mut mfn = methods[0]   // placeholder; overwritten below iff `found` (Teko has no uninitialized values)
    loop {
        if mi >= methods.len { break }
        if methods[mi].name == mc.method { found = true; mfn = methods[mi]; break }
        mi++
    }
    if !found { return error { message = $"no such method '{mc.method}' on struct '{struct_name}'" } }
    let is_instance = mfn.params.len > 0 && !mfn.params[0].has_type
    if !is_instance { return error { message = $"'{mc.method}' is a static method — call it as {struct_name}::{mc.method}(…)" } }
    // (W10b.CLASS residual — intern visibility) a private (default) method is reachable only
    // from its OWN declaring class's code, or — if `intern` — a subclass's too. Struct methods
    // stay all-public (W10b.0.A) — this check only fires for a ClassBody receiver.
    match decl.body {
        parser::ClassBody => {
            let owner = match find_method_owner(struct_name, table, mc.method) { MemberOwner as mo => mo; error as e => return e }
            if !member_accessible(owner, env.owner_type, table) {
                return error { message = $"method '{mc.method}' is private to {owner.declaring_class}" }
            }
        }
        _ => { }
    }
    // (#98) VIRTUAL DISPATCH through a POLYMORPHIC-BASE-typed receiver. When the receiver's STATIC
    // type is a `virtual`/`abstract` class, the value may hold a subclass, so the call dispatches
    // dynamically through the base's vtable — exactly the D3 mechanism, keyed on the base class as
    // the "contract". The slot is the method's index in the base's EFFECTIVE method list (the same
    // order codegen's `tk_vt_<Sub>_<Base>` build uses). The receiver rides args[0]; both engines
    // resolve the CONCRETE override (VM by the payload's class name, native via the vtable slot).
    // A `sealed` class is never a base — is_polymorphic_base filters it — so its calls stay direct.
    match decl.body {
        parser::ClassBody as bcb => {
            if is_polymorphic_base(struct_name, table) {
                let slot_res = base_vtable_slot(struct_name, mc.method, table)
                match slot_res {
                    u32 as bslot => {
                        let bft = match method_func_type(mfn, struct_name, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the call's enclosing namespace
                        let bf = match bft { Func as ff => ff; _ => return error { message = "internal: base method signature is not a function type" } }
                        mut bcargs: []parser::Expr = teko::list::push(teko::list::empty(), mc.receiver)
                        mut bai: u64 = 0
                        loop { if bai >= mc.args.len { break }; bcargs = teko::list::push(bcargs, mc.args[bai]); bai++ }
                        mut bcnames: []str = teko::list::empty()
                        mut bni: u64 = 0
                        loop { if bni >= bcargs.len { break }; bcnames = teko::list::push(bcnames, ""); bni++ }
                        let bdargs = match resolve_defargs(bf, bcargs, bcnames) { []parser::Expr as x => x; error as e => return e }
                        if bdargs.len != bf.params.len { return error { message = "wrong number of arguments" } }
                        mut biargs: []TExpr = teko::list::empty()
                        mut bii: u64 = 0
                        loop {
                            if bii >= bdargs.len { break }
                            mut ba = match type_expr(bdargs[bii], env, table) { TExpr as te => te; error as e => return e }
                            if type_is_void(ba.type) { return error { message = "a `void` expression cannot be passed as an argument (M.1)" } }
                            let bpt = bf.params[bii]
                            if !assignable_to(ba.type, bpt, table) {
                                if !literal_adopts(ba, bpt) { return teko::error::err_typed(error { message = "argument type mismatch" }, type_render(bpt), type_render(ba.type)) }
                                ba = TExpr { kind = ba.kind; type = bpt; line = ba.line; col = ba.col }
                            } else {
                                if !arg_keeps_narrow_type(bpt, ba.type, table) {
                                    ba = TExpr { kind = ba.kind; type = bpt; line = ba.line; col = ba.col }
                                }
                            }
                            biargs = teko::list::push(biargs, ba)
                            bii++
                        }
                        let bseg_base = parser::Segment { name = struct_name }   // the base class — the vtable key
                        let bseg_m = parser::Segment { name = mc.method }
                        mut bsegs: []parser::Segment = teko::list::push(teko::list::empty(), bseg_base)
                        bsegs = teko::list::push(bsegs, bseg_m)
                        return TExpr { kind = TCall { callee = parser::Path { segments = bsegs }; args = biargs; call_ns = ""; is_closure_call = false; callee_type = bft; is_iface_dispatch = true; iface_slot = bslot }; type = bf.ret; line = 0; col = 0 }
                    }
                    error => { }   // method not in the base vtable → fall through to the direct desugar (a NEW own method reachable only when receiver is statically the base)
                }
            }
        }
        _ => { }
    }
    let segs = method_dispatch_callee(struct_name, mc.method).segments
    mut cargs: []parser::Expr = teko::list::push(teko::list::empty(), mc.receiver)
    mut ai: u64 = 0
    loop { if ai >= mc.args.len { break }; cargs = teko::list::push(cargs, mc.args[ai]); ai++ }
    mut cnames: []str = teko::list::empty()
    mut ni: u64 = 0
    loop { if ni >= cargs.len { break }; cnames = teko::list::push(cnames, ""); ni++ }
    type_call(parser::Call { callee = parser::Path { segments = segs }; args = cargs; arg_names = cnames; type_args = teko::list::empty() }, env, table)
}

/**
 * (W10b.D2/D3 / TR1) Type a dynamic contract-method dot-call `recv.method(args)` on an INTERFACE or
 * TRAIT receiver: resolve `method` to its dispatch contract + vtable slot, type the receiver + args
 * against the contract's effective signature (defaults live on the contract, DEFARGS rule E), and
 * emit an `is_iface_dispatch` TCall keyed off the real contract name (the vtable/upcast key). A
 * trait passes an InterfaceBody VIEW (`extends = []`, `methods = the trait's own method list`), so
 * this one routine serves both contract kinds (a trait value IS a contract value — W10b.D3 reuse).
 *
 * @param ib          the contract's InterfaceBody (a trait's is a synthesized view)
 * @param struct_name the resolved receiver contract name (the dispatch key)
 * @param mc          the method-call AST node (receiver + method + args)
 * @param env         the typing environment
 * @param table       the folded type table
 * @return the typed dynamic-dispatch TCall
 * @throws when the method is not on the contract, arity/types mismatch, or a signature fails to resolve
 */
fn type_contract_dispatch(ib: parser::InterfaceBody, struct_name: str, mc: parser::MethodCall, env: Env, table: TypeTable) -> TExpr | error {
    let dispatch = match resolve_iface_dispatch(ib, struct_name, mc.method, table) { IfaceDispatch as d => d; error as e => return e }
    let iface_canon = dispatch.iface
    let imfn = dispatch.method
    let slot = dispatch.slot
    let ift = match method_func_type(imfn, struct_name, table, env.cur_ns) { Type as t => t; error as e => return e }
    let f = match ift { Func as ff => ff; _ => return error { message = "internal: interface method signature is not a function type" } }
    mut icargs: []parser::Expr = teko::list::push(teko::list::empty(), mc.receiver)
    mut ica: u64 = 0
    loop { if ica >= mc.args.len { break }; icargs = teko::list::push(icargs, mc.args[ica]); ica++ }
    mut icnames: []str = teko::list::empty()
    mut icn: u64 = 0
    loop { if icn >= icargs.len { break }; icnames = teko::list::push(icnames, ""); icn++ }
    let dargs = match resolve_defargs(f, icargs, icnames) { []parser::Expr as x => x; error as e => return e }
    if dargs.len != f.params.len { return error { message = "wrong number of arguments" } }
    mut iargs: []TExpr = teko::list::empty()
    mut ii: u64 = 0
    loop {
        if ii >= dargs.len { break }
        mut a = match type_expr(dargs[ii], env, table) { TExpr as te => te; error as e => return e }
        if type_is_void(a.type) { return error { message = "a `void` expression cannot be passed as an argument (M.1)" } }
        let pt = f.params[ii]
        if !assignable_to(a.type, pt, table) {
            if !literal_adopts(a, pt) { return teko::error::err_typed(error { message = "argument type mismatch" }, type_render(pt), type_render(a.type)) }
            a = TExpr { kind = a.kind; type = pt; line = a.line; col = a.col }
        } else {
            if !arg_keeps_narrow_type(pt, a.type, table) {
                a = TExpr { kind = a.kind; type = pt; line = a.line; col = a.col }
            }
        }
        iargs = teko::list::push(iargs, a)
        ii++
    }
    let seg_iface = parser::Segment { name = iface_canon }
    let seg_m = parser::Segment { name = mc.method }
    mut isegs: []parser::Segment = teko::list::push(teko::list::empty(), seg_iface)
    isegs = teko::list::push(isegs, seg_m)
    TExpr { kind = TCall { callee = parser::Path { segments = isegs }; args = iargs; call_ns = ""; is_closure_call = false; callee_type = ift; is_iface_dispatch = true; iface_slot = slot }; type = f.ret; line = 0; col = 0 }
}

/**
 * A single-segment path wrapping `name` (`Cell` → `Path{[Cell]}`) — the minimal path for resolving a
 * construction-site base type through `resolve_type` (#254 L5).
 *
 * @param name  the single segment name
 * @return      a one-segment path
 * @since onda-3 (#254 L5)
 */
fn single_seg_path(name: str) -> parser::Path {
    parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }
}

/**
 * A copy of `p` with the segment at position `idx` renamed to `name` (`Cell::make`, idx 0 → `X`,
 * yields `X::make`) — the positional twin of `rewrite_last_segment` (#254 L5). Used to rewrite a
 * generic static call's OWNER segment (the second-to-last) to the mangled instance name.
 *
 * @param p     the path to rewrite
 * @param idx   the segment position to rename
 * @param name  the new segment name
 * @return      `p` with segment `idx` renamed
 * @since onda-3 (#254 L5)
 */
fn rewrite_segment_at(p: parser::Path, idx: u64, name: str) -> parser::Path {
    mut segs: []parser::Segment = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= p.segments.len { break }
        if i == idx { segs = teko::list::push(segs, parser::Segment { name = name }) }
        else { segs = teko::list::push(segs, p.segments[i]) }
        i++
    }
    parser::Path { segments = segs }
}

/**
 * Retarget a static-call callee that carries construction-site type-args (`Cell<i64>::make(…)`) to the
 * mangled generic-instance owner (`Cell__g__i64::make`), so `lookup_call` resolves the stamped factory
 * `register_instance_methods` registered (#254 L5). Resolves the type-args to concrete types, mangles
 * the base (the callee's SECOND-TO-LAST segment) via `generic_inst_name`, and rewrites that segment.
 * A call with no type-args (or a single-segment callee) passes through unchanged → byte-identical for
 * every existing call.
 *
 * @param c      the parsed static call (carrying type_args)
 * @param table  the folded type table (arg resolution)
 * @param ref_ns the call's enclosing namespace
 * @return       the callee path with the owner segment mangled to the instance, or `c.callee` verbatim
 * @throws       when a type-arg fails to resolve
 * @since onda-3 (#254 L5)
 */
fn retarget_generic_static_callee(c: parser::Call, table: TypeTable, ref_ns: str) -> parser::Path | error {
    if c.type_args.len == 0 || c.callee.segments.len < 2 { return c.callee }
    let owner_idx = c.callee.segments.len - 2
    let base = c.callee.segments[owner_idx].name
    let nt = parser::NamedType { path = single_seg_path(base); args = c.type_args }
    let rt = match resolve_type(nt, table, ref_ns) { Type as t => t; error as e => return e }
    let inst = match rt { Named as n => n.name; _ => return c.callee }
    rewrite_segment_at(c.callee, owner_idx, inst)
}

fn type_call(c0: parser::Call, env: Env, table: TypeTable) -> TExpr | error {
    let c = if c0.type_args.len == 0 { c0 } else {
        let rc = match retarget_generic_static_callee(c0, table, env.cur_ns) { parser::Path as p => p; error as e => return e }
        parser::Call { callee = rc; args = c0.args; arg_names = c0.arg_names; type_args = c0.type_args }
    }
    match type_list_builtin(c, env, table) {   // teko::list::empty / push (generic)
        TExpr as te => return te
        error as e => return e
        NotListBuiltin => { }   // not a list builtin → fall through to the ordinary call
    }
    match type_mem_free(c, env, table) {   // teko::mem::free (manual dealloc — []T | class)
        TExpr as te => return te
        error as e => return e
        NotMemFree => { }
    }
    match type_region_new(c, env, table) {
        TExpr as te => return te
        error as e => return e
        NotRegionOp => { }
    }
    match type_region_alloc(c, env, table) {
        TExpr as te => return te
        error as e => return e
        NotRegionOp => { }
    }
    let name = c.callee.segments[c.callee.segments.len - 1].name
    // panic / exit — injected GLOBAL diverging builtins (legislator's ruling — NO `never` type).
    // panic(error | str) = the message; exit(<integer>) = the status code. Both terminate the
    // program; the call's STATIC type is void, but texpr_diverges accepts it in any value position.
    // Fire ONLY when the namespace-aware lookup finds nothing — so the runtime's own `fn panic`
    // resolves to ITSELF (below) while every other namespace gets the injected global (#41).
    let in_scope = match lookup_call(env, c.callee) { Type => true; error => false }
    let teko_rooted = c.callee.segments.len == 2 && c.callee.segments[0].name == "teko"   // reserved-root `teko::exit`/`teko::panic`
    if (c.callee.segments.len == 1 || teko_rooted) && !in_scope {
        if name == "panic" {
            if c.args.len != 1 { return error { message = "panic expects one argument (an `error` or a `str`)" } }
            let a = match type_expr(c.args[0], env, table) { TExpr as te => te; error as e => return e }
            let ok = match a.type { Str => true; Error => true; _ => false }
            if !ok { return error { message = "panic's argument must be an `error` or a `str`" } }
            mut pargs = teko::list::push(teko::list::empty(), a)
            return TExpr { kind = TCall { callee = c.callee; args = pargs; call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Void { }; line = 0; col = 0 }
        }
        if name == "exit" {
            if c.args.len != 1 { return error { message = "exit expects one argument (an integer status code)" } }
            let a = match type_expr(c.args[0], env, table) { TExpr as te => te; error as e => return e }
            let ok = match a.type { Prim as p => prim_is_int(p.kind); _ => false }
            if !ok { return error { message = "exit's argument must be an integer status code" } }
            mut eargs = teko::list::push(teko::list::empty(), a)
            return TExpr { kind = TCall { callee = c.callee; args = eargs; call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = Void { }; line = 0; col = 0 }
        }
    }
    // (#49) the resolved target's namespace drives the mangled C name. Only a USER function (found
    // in the env) carries one; a builtin (fallback below) leaves it empty → codegen's call-map path.
    let resolved_ns = match lookup_call(env, c.callee) { Type => call_ns(env, c.callee); error => "" }
    let ft = match lookup_call(env, c.callee) {   // (#41) namespace-aware: a local or
        Type as t => t   // a same-namespace fn (unqualified) / the qualified ns;
        error => match builtin_fn(name) { Type as t => t; error => return error { message = $"unknown function: {name}" } }   // …then the injected builtins; else name the symbol (M.3)
    }
    // (W10b.CLASS residual — intern visibility) a STATIC call (`ClassName::method(…)`) is
    // reachable under the SAME rule as an instance dot-call — check it here too, routed through
    // the resolved method namespace. `resolved_ns` names a real class only for a class(-static-
    // or -instance-called-as-static) method; any other qualified/unqualified call (an ordinary
    // namespaced function) leaves this a silent no-op (find_class_body errors → skipped).
    if resolved_ns != "" {
        match find_class_body(class_name_from_method_ns(resolved_ns), table) {
            parser::ClassBody => {
                let owner = match find_method_owner(class_name_from_method_ns(resolved_ns), table, name) { MemberOwner as mo => mo; error as e => return e }
                if !member_accessible(owner, env.owner_type, table) {
                    return error { message = $"method '{name}' is private to {owner.declaring_class}" }
                }
            }
            error => { }
        }
    }
    match ft {
        Func as f => {
            let dargs = if f.variadic { match pack_variadic_args(f, c.args, env, table) { []parser::Expr as x => x; error as e => return e } } else { match resolve_defargs(f, c.args, c.arg_names) { []parser::Expr as x => x; error as e => return e } }
            if dargs.len != f.params.len { return error { message = "wrong number of arguments" } }
            // Type every argument first (void rejected); strict-check / generic-infer below.
            mut targs: []TExpr = teko::list::empty()
            mut ti = 0
            loop {
                if ti >= dargs.len { break }
                // (W10) a closure-literal ARG whose parameter is a concrete function type infers its
                // un-annotated params from that target (ruling 3); other args type normally.
                let is_lam = match dargs[ti].kind { parser::Lambda => true; _ => false }
                let pt_is_func = match f.params[ti] { Func => true; _ => false }
                // (W10b.D3) an ARRAY-literal ARG under a `[]<interface>` param types against the
                // contract element too (heterogeneous `[]Shape` args), like the binding-annotation path.
                let is_arr = match dargs[ti].kind { parser::ArrayLit => true; _ => false }
                let iface_arr_target = is_arr && is_iface_slice(f.params[ti], table)
                let a = if (is_lam && pt_is_func) || iface_arr_target {
                    match type_value_expected(dargs[ti], f.params[ti], env, table) { TExpr as te => te; error as e => return e }
                } else {
                    match type_expr(dargs[ti], env, table) { TExpr as te => te; error as e => return e }
                }
                if type_is_void(a.type) { return error { message = "a `void` expression cannot be passed as an argument (M.1)" } }
                targs = teko::list::push(targs, a)
                ti++
            }
            // (S4) GENERIC callee — the sig carries type-param Named's: INFER the type-params from the
            // arg types and substitute into the return type for the call's result. The monomorph pass
            // (post-typer) stamps the concrete instance and rewrites the callee. Type-params that appear
            // only in the return type cannot be inferred from args (M.2 no-guessing) → honest error.
            let all_tps = collect_sig_type_params(ft, table, teko::list::empty())
            if all_tps.len > 0 {
                mut param_tps: []str = teko::list::empty()
                mut pp = 0
                loop { if pp >= f.params.len { break }; param_tps = collect_sig_type_params(f.params[pp], table, param_tps); pp++ }
                mut rk = 0
                loop {
                    if rk >= all_tps.len { break }
                    if !is_type_param(all_tps[rk], param_tps) { return error { message = $"cannot infer type parameter {all_tps[rk]} — it appears only in the return type; annotate the call" } }
                    rk++
                }
                mut s = Subst { params = param_tps; names = teko::list::empty(); types = teko::list::empty() }
                mut gi = 0
                loop {
                    if gi >= targs.len { break }   // targs.len == f.params.len (arity checked above); bound by the typed-arg list
                    s = match unify(f.params[gi], targs[gi].type, s, table) { Subst as x => x; error as e => return e }
                    gi++
                }
                return TExpr { kind = TCall { callee = c.callee; args = targs; call_ns = resolved_ns; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = subst_type(f.ret, s); line = 0; col = 0 }
            }
            // NON-generic: each argument must WIDEN into the parameter's type (B.14 case→variant, T→T?)
            // OR be a fitting literal that adopts it (C6) — same rule as binding/return/assign.
            mut args: []TExpr = teko::list::empty()
            mut i = 0
            loop {
                if i >= targs.len { break }
                mut a = targs[i]
                // (MEM-1b-ii) AUTO-REF: a `ref<T>` param accepts a `mut` lvalue of the pointed type T —
                // the compiler takes the reference (codegen emits `&`). Requires a `mut` variable (you
                // can't reference an immutable binding — there'd be nothing to mutate). A value ALREADY
                // of type `ref<T>` (e.g. forwarding a ref param) takes the normal assignable path below.
                mut auto_reffed = false
                match f.params[i] {
                    Reference as rf => {
                        if !assignable_to(a.type, f.params[i], table) && type_eq(a.type, rf.inner) {
                            match a.kind {
                                TVar as v => match lookup_binding(env, v.name) {
                                    ValBinding as vb => {
                                        if !vb.is_mut { return error { message = $"cannot take a reference to immutable `{v.name}` — declare it `mut` (a reference needs a mutable target)" } }
                                        auto_reffed = true   // keep a.type = T; emit_call emits `&` (param is ref<T>)
                                    }
                                    error => return error { message = "auto-ref requires a mutable variable (a `mut` binding)" }
                                }
                                _ => return error { message = "a `ref<T>` argument must be a mutable variable (a `mut` binding) — only an lvalue can be referenced" }
                            }
                        }
                    }
                    _ => { }
                }
                if !auto_reffed {
                    if !assignable_to(a.type, f.params[i], table) {
                        // (C1.8/E2) attach expected/actual — THE user's reported mismatch (mirrors expr.c).
                        if !literal_adopts(a, f.params[i]) { return teko::error::err_typed(error { message = "argument type mismatch" }, type_render(f.params[i]), type_render(a.type)) }
                        a = TExpr { kind = a.kind; type = f.params[i]; line = a.line; col = a.col }   // C6 literal adopts the param type
                    } else {
                        if !arg_keeps_narrow_type(f.params[i], a.type, table) {
                            a = TExpr { kind = a.kind; type = f.params[i]; line = a.line; col = a.col }
                        }
                    }
                }
                args = teko::list::push(args, a)
                i++
            }
            // (W10a) a CLOSURE call: the callee resolved IN-scope to a function type whose binding is a
            // LOCAL (resolved_ns == "" — only define_fn sets a namespace). It is a `tk_closure` VALUE,
            // so codegen calls through `((R(*)(A,B))f.fn)(args)` using the Func type for the cast.
            let is_closure = in_scope && resolved_ns.len == 0
            TExpr { kind = TCall { callee = c.callee; args = args; call_ns = resolved_ns; is_closure_call = is_closure; callee_type = ft; is_iface_dispatch = false; iface_slot = 0 }; type = f.ret; line = 0; col = 0 }
        }
        _ => error { message = $"not a function: {name}" }
    }
}

// ---- cast `to` (C2): a DEFINED conversion is allowed; loss is caught, never silent (M.1) ----
// Two-pronged — the ÷0/overflow/OOB lineage applied to conversions (homeostasis, Constitution §II):
//   • a CONSTANT operand the compiler can see out of range → COMPILE ERROR (fail early — M.1);
//   • a runtime value the compiler cannot see → the metal converts and the loss is caught at
//     runtime (debug-panic / release-defined, exactly like overflow) — that guard is CODEGEN's,
//     deferred (M.4). M.1 forbids only SILENT loss; a check/panic is not silent, so narrowing and
//     signed↔unsigned ARE allowed (the value might fit — M.0 keeps the metal conversion).
// Scoped to the seed's scalars: Bool casts and non-numeric casts are UNDEFINED (rejected). The
// native numeric set (B.38) — int↔int (incl 128), int↔float, float↔float — is ALL defined: the
// fit/loss is the runtime guard's (trunc toward zero, overflow/NaN/∞ → panic — §5). Decimal awaits
// its runtime; newtype↔base awaits `resolve_named` lowering a newtype to its base — both deferred
// (M.4). *(Redefines the early compile-forbid rule — see the Redefinitions Index; the prior rule
// over-applied M.1, forbidding what a guard makes non-silent.)*

// does a constant INTEGER value (i128 carrier) fit the target integer prim's range? (B.38 —
// extended to the full int set, incl 128-bit.) Floats are handled separately (float_fits);
// Bool is never a literal target. The carrier is signed i128, so an unsigned target gates on
// v >= 0 first; u128's upper bound is the carrier max, so non-negativity is its only gate.
fn value_fits(v: i128, k: PrimKind) -> bool {
    if prim_is_float(k) { return false }   // an int literal does not fit a float type (N1/N2)
    if k == PrimKind::U8 { return v >= 0 && v <= 255 }
    if k == PrimKind::U16 { return v >= 0 && v <= 65535 }
    if k == PrimKind::U32 { return v >= 0 && v <= 4294967295 }
    if k == PrimKind::U64 { return v >= 0 && v <= 18446744073709551615 }
    if k == PrimKind::U128 { return v >= 0 }   // i128 max < u128 max → any v>=0 fits
    if k == PrimKind::I8 { return v >= -128 && v <= 127 }
    if k == PrimKind::I16 { return v >= -32768 && v <= 32767 }
    if k == PrimKind::I32 { return v >= -2147483648 && v <= 2147483647 }
    if k == PrimKind::I64 { return v >= (-9223372036854775807 - 1) && v <= 9223372036854775807 }
    if k == PrimKind::I128 { return true }   // v is already an i128
    false   // Bool — not a numeric range (guarded by the caller)
}

// does a constant FLOAT literal fit the target float prim? Seed ruling (§5): a float constant
// is accepted into ANY float width — precision/range loss of float CONSTANTS is permissive for
// now (the runtime/codegen rounding-loss note in §5 still applies). Tightening f16/f32 over-range
// to a compile error is deferred (no fail-early for float consts yet).
fn float_fits(v: f64, k: PrimKind) -> bool { prim_is_float(k) }

// is `from -> to` a DEFINED conversion? Any integer↔integer is (the loss is runtime/codegen's,
// not a type error — B). Only genuinely-undefined conversions are rejected: Bool, and crossing
// to/from a non-numeric type. M.1 — no silent loss; M.3 — names the barrier. Reused by the
// counter-validation (E6-2) so the rule has ONE source of truth (M.5).
// byte casts AS u8 (B.36 "byte = u8 newtype"): byte's values ARE u8 values, so the effective
// PrimKind for range/cast rules is U8. Bool and non-numeric types have no cast kind (rejected).
// One source of truth (M.5) for cast_check + const_range_check.
fn cast_kind(t: Type) -> PrimKind | error {
    match t {
        Prim as p => {
            if p.kind == PrimKind::Bool { error { message = "bool casts are not defined in the seed" } }
            else { p.kind }
        }
        Byte => PrimKind::U8
        _ => error { message = "cast not defined for this type in the seed (Named/Str/Slice/… — pending)" }
    }
}

// is `from -> to` a DEFINED conversion? Any integer/byte ↔ integer/byte is (the loss is
// runtime/codegen's — B; byte casts AS u8 — B.36). Only Bool and non-numeric ends are rejected.
// Reused by the counter-validation (E6-2) — ONE source of truth (M.5).
fn cast_check(from: Type, to: Type) -> error? {
    if type_eq(from, to) { return null }   // same type — a no-op
    match cast_kind(from) { PrimKind => { }; error as e => return e }
    match cast_kind(to) { PrimKind => { }; error as e => return e }
    null   // any numeric/byte → any numeric/byte is defined (B; byte AS u8)
}

// a CONSTANT literal already out of the target's range is a compile error (M.1 — fail early);
// non-constant operands are guarded at runtime by codegen. Direct literals only (comptime folding deferred).
fn const_range_check(e: parser::Expr, target: Type) -> error? {
    match e.kind {
        parser::Number as n => match cast_kind(target) {   // byte target → U8 range (0..255)
            PrimKind as k => {
                // only the int-literal → int-target case is statically range-checkable (B.38, incl 128).
                // float→int / int→float / float→float constant conversions are runtime-guarded (trunc
                // toward zero, overflow/NaN/∞ → panic — §5); the checker permits them, the fit is codegen/VM.
                if n.is_float || !prim_is_int(k) { null }
                else if value_fits(n.value, k) { null }
                else { error { message = "constant out of range for the cast target (M.1 — fail early)" } }
            }
            error => null   // non-numeric target: cast_check already rejected it
        }
        _ => null   // not a constant literal → runtime-guarded (codegen)
    }
}

// C6 — an annotated binding `let x: T = <value>` whose value type ≠ T. A numeric LITERAL ADOPTS T
// if it fits: the leaf stays i64 (stored AS-IS — Side D) and T lives in the binding's `bound`.
// The fit is proven HERE at type time via `value_fits`. A NON-literal mismatch is a hard error —
// no implicit conversion (M.2; use `to`). An out-of-range literal fails EARLY (M.1).
// NOTE: the counter-validation does NOT yet re-prove the binding-level fit — a forged typed tree
// `bound=u8, value=300` would currently pass revalidate. That re-proof lands with `validate_statement`
// (deferred; named gap — §VI). The front-line type check above already rejects such source.
fn annotated_literal_ok(value: parser::Expr, ann: Type) -> error? {
    match value.kind {
        // an ARRAY LITERAL `[e0, e1, …]` annotated as `[]E` — adopts element-wise: every non-spread
        // element must itself be a fitting bare literal for E (recurses through nested arrays via
        // this same function). A spread element (`..xs`) is already a `[]T` value, not a literal —
        // skip it here (its own widen/adopt was checked at array-literal typing time). Mirrors
        // literal_adopts's TArrayLit case (the range-check side), which already recurses this way;
        // this is the RETYPING side's twin so `let a: []u8 = [1,2,3]` type-checks (#71).
        parser::ArrayLit as al => match ann {
            Slice as s => {
                mut i = 0
                mut result: error? = null
                loop {
                    if i >= al.elements.len { break }
                    if !al.elements[i].is_spread {
                        match annotated_literal_ok(al.elements[i].expr, s.element) {
                            null => { }
                            error as e => { result = e; break }
                        }
                    }
                    i++
                }
                result
            }
            _ => error { message = "value type does not match annotation" }
        }
        // a NEGATIVE numeric literal `-N` (unary minus over a NUMBER) — adopts a SIGNED int
        // annotation that N fits, or a float annotation for `-3.14` (parse_lit's `mut d: i128 = -1`).
        parser::Unary as u => {
            if u.op == lexer::TokenKind::Minus {
                match u.operand.kind {
                    parser::Number as n => match ann {
                        Prim as p => {
                            if n.is_float {
                                if !prim_is_float(p.kind) { error { message = "a float literal cannot be annotated as an integer type (B.38)" } }
                                else if float_fits(n.fval, p.kind) { null }
                                else { error { message = "float literal out of range for the annotated type (M.1 — fail early)" } }
                            } else {
                                if prim_is_float(p.kind) { error { message = "an integer literal cannot be annotated as a float type (write it with a `.` — B.38)" } }
                                else if !prim_is_signed(p.kind) { error { message = "a negative literal cannot be annotated as an unsigned type (M.1)" } }
                                else if value_fits(n.value, p.kind) { null }
                                else { error { message = "literal out of range for the annotated type (M.1 — fail early)" } }
                            }
                        }
                        _ => error { message = "value type does not match annotation" }
                    }
                    _ => error { message = "value type does not match annotation" }
                }
            } else {
                error { message = "value type does not match annotation" }
            }
        }
        parser::Number as n => match ann {
            Prim as p => {
                if n.is_float {
                    // a float literal (3.14, 1.5e3) adopts a float annotation only (N2).
                    if !prim_is_float(p.kind) { error { message = "a float literal cannot be annotated as an integer type (B.38)" } }
                    else if float_fits(n.fval, p.kind) { null }
                    else { error { message = "float literal out of range for the annotated type (M.1 — fail early)" } }
                } else {
                    // an integer literal adopts an integer annotation only; never a float type (N1).
                    if prim_is_float(p.kind) { error { message = "an integer literal cannot be annotated as a float type (write it with a `.` — B.38)" } }
                    else if value_fits(n.value, p.kind) { null }
                    else { error { message = "literal out of range for the annotated type (M.1 — fail early)" } }
                }
            }
            _ => error { message = "value type does not match annotation" }
        }
        _ => error { message = "value type does not match annotation" }
    }
}

// `x to T` — type the inner, resolve the target, demand the conversion is DEFINED, then reject a
// CONSTANT literal already out of range (fail early — M.1). The runtime fit-check for non-constant
// operands is codegen's (debug-panic / release-defined) — deferred (M.4).
// (E7) is `t` a NAMED type whose declaration is an `enum`? (C: is_enum_named.)
fn is_enum_named(t: Type, table: TypeTable) -> bool {
    match t {
        Named as n => match type_table_find(table, n.name, "") {   // (#109 W1) enum-kind probe on a resolved name — no referencing ns
            parser::TypeDecl as td => match td.body { parser::EnumBody => true; _ => false }
            error => false
        }
        _ => false
    }
}

// (E7) an INTEGER cast endpoint: an int prim, or `byte` (= u8). Floats/bool excluded. (C: is_int_cast_end.)
fn is_int_cast_end(t: Type) -> bool {
    match t {
        Byte => true
        Prim as p => prim_is_int(p.kind)
        _ => false
    }
}

// (UTF-8 increment 1) `char to <int>` — the EXPLICIT decode of a codepoint to its scalar value.
// Allowed for u32 (the natural codepoint width), and trivially for the wider unsigned/signed ints
// that hold any codepoint (u64/i64). The REVERSE (`<int> to char`, an encode) is a later increment.
fn is_char_decode_target(t: Type) -> bool {
    match t {
        Prim as p => p.kind == PrimKind::U32 || p.kind == PrimKind::U64 || p.kind == PrimKind::I64
        _ => false
    }
}

fn type_cast(c: parser::Cast, env: Env, table: TypeTable) -> TExpr | error {
    let inner = match type_expr(c.expr, env, table) { TExpr as te => te; error as e => return e }
    if type_is_void(inner.type) { return error { message = "a `void` expression cannot be cast (M.1)" } }
    let target = match resolve_type(c.target, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the cast's enclosing namespace
    // (UTF-8 increment 1) `char to u32`/u64/i64 — decode the codepoint to its scalar value. char is
    // NOT a numeric cast endpoint (cast_kind rejects it), so this pair is handled here; the result
    // type is the target. `<int> to char` (encode) is NOT allowed yet. (Mirrors expr.c type_cast.)
    match inner.type {
        Char => {
            if is_char_decode_target(target) {
                return TExpr { kind = TCast { expr = inner }; type = target; line = 0; col = 0 }
            }
            return error { message = "a `char` may only be cast to u32/u64/i64 (its codepoint value); other casts are not defined" }
        }
        _ => { }
    }
    // (E7) enum ↔ integer ORDINAL cast: an enum value → its ordinal integer, an integer → the enum
    // member (the `(byte)k` / `(TokenKind)b` the .tkb serializer relies on). cast_check is prim-only,
    // so handle this pair here (it has the type table to detect an enum); the result type is the
    // target. Any OTHER enum cast stays rejected by cast_check. (Mirrors expr.c type_cast's e7.)
    let e7 = (is_enum_named(inner.type, table) && is_int_cast_end(target)) ||
    (is_int_cast_end(inner.type) && is_enum_named(target, table))
    if !e7 {
        match cast_check(inner.type, target) { null => { }; error as e => return e }
    }
    match const_range_check(c.expr, target) { null => { }; error as e => return e }
    TExpr { kind = TCast { expr = inner }; type = target; line = 0; col = 0 }   // the cast's type IS the resolved target
}

// ---- field access `x.field` (C3): read a struct field; `.type` is the field's resolved type ----
// B.29: FIELD read only (method *checking* stays deferred). M.3: nominal — resolve the receiver's
// `Named` type to its `TypeDecl` body and read the field's declared type. Receiver must be a struct.

// find a field by name in a struct body and resolve its annotation (M.3 — exact).
fn field_type(fields: []parser::Field, field: str, table: TypeTable, ref_ns: str) -> Type | error {
    mut i = 0
    loop {
        if i >= fields.len { break }
        if fields[i].name == field { return resolve_type(fields[i].type_ann, table, ref_ns) }   // (#109 W2) field annotation resolves in the struct's OWN ns (its declaring namespace)
        i++
    }
    error { message = $"no such field: {field}" }
}

fn type_field_access(fa: parser::FieldAccess, env: Env, table: TypeTable) -> TExpr | error {
    let recv = match type_expr(fa.receiver, env, table) { TExpr as te => te; error as e => return e }
    // `.len` on a `str` or a slice (`[]T`) -> u64 (W5-idx). This precedes the struct-field
    // path: a str/slice has no struct body, so `len` is a built-in length, not a field.
    let is_str_or_slice = match recv.type { Str => true; Slice => true; _ => false }
    if is_str_or_slice && fa.field == "len" {
        return TExpr { kind = TFieldAccess { receiver = recv; field = fa.field }; type = Prim { kind = PrimKind::U64 }; line = 0; col = 0 }
    }
    // error diagnostic adornments (E2): the built-in `error` value exposes its carrier fields as
    // readable fields — message/file/expected/actual -> str, line/col -> u32. error has no struct
    // body, so (like str/slice `.len`) this precedes the struct-field path.
    let is_error = match recv.type { Error => true; _ => false }
    if is_error {
        if fa.field == "message" || fa.field == "file" || fa.field == "expected" || fa.field == "actual" {
            return TExpr { kind = TFieldAccess { receiver = recv; field = fa.field }; type = Str { }; line = 0; col = 0 }
        }
        if fa.field == "line" || fa.field == "col" {
            return TExpr { kind = TFieldAccess { receiver = recv; field = fa.field }; type = Prim { kind = PrimKind::U32 }; line = 0; col = 0 }
        }
        return error { message = "no such field on error (message/file/expected/actual: str; line/col: u32)" }
    }
    // (MEM-1b-ii) `Ref<T>.value` — the deref: reading `r.value` yields the referenced T. A Reference
    // has no struct body and exposes ONLY `.value` (the pointed-to value); any other field is an error.
    match recv.type {
        Reference as rf => {
            if fa.field == "value" {
                return TExpr { kind = TFieldAccess { receiver = recv; field = fa.field }; type = rf.inner; line = 0; col = 0 }
            }
            return error { message = "a reference (`Ref<T>`) exposes only `.value` (the referenced value)" }
        }
        _ => { }
    }
    // (NP-OOP, issue #116) a bare `.` on a nullable receiver stays a compile error — but say WHY
    // and point at the sanctioned readers (`?.`/`??`) instead of the generic struct message.
    match recv.type {
        Optional => return error { message = "cannot use `.` on a nullable value (`T?`) — read it with `?.` or `??` (REBOOT_PLAN §203)" }
        _ => { }
    }
    let name = match recv.type {
        Named as n => n.name
        _ => return error { message = "field access requires a struct receiver" }
    }
    let decl = match type_table_find(table, name, "") {   // (#109 W1) field-access receiver lookup on a resolved name — no referencing ns
        parser::TypeDecl as td => td
        error => return error { message = $"unknown type for field access: {name}" }
    }
    let ft = match decl.body {
        parser::StructBody as sb => match field_type(sb.fields, fa.field, table, type_ns_of(table, name)) { Type as t => t; error as e => return e }
        parser::ClassBody as cb => {
            let t = match effective_class_fields(cb, table) { []parser::Field as fs => match field_type(fs, fa.field, table, type_ns_of(table, name)) { Type as t => t; error as e => return e }; error as e => return e }   // (W10b.CLASS increment 2)
            // (W10b.CLASS residual — intern visibility) a private (default) field is reachable
            // only from its OWN declaring class's code, or — if `intern` — a subclass's too.
            let owner = match find_field_owner(name, table, fa.field) { MemberOwner as mo => mo; error as e => return e }
            if !member_accessible(owner, env.owner_type, table) {
                return error { message = $"field '{fa.field}' is private to {owner.declaring_class}" }
            }
            t
        }
        // (W10b.D3) an interface value is data + vtable — the contract exposes METHODS only.
        parser::InterfaceBody => return error { message = "an interface value exposes no fields — only its contract methods" }
        _ => return error { message = $"type {name} is not a struct (no fields)" }
    }
    TExpr { kind = TFieldAccess { receiver = recv; field = fa.field }; type = ft; line = 0; col = 0 }
}

// ---- `?.` safe navigation (NP-OOP, issue #116) — the shared checker DESUGAR ----
// `recv?.member…` on a CLASS/INTERFACE optional lowers IN THE CHECKER to the equivalent
// typed match (no new TAST node, so the VM and native codegen run it through their
// existing match/method/field machinery — twin-identical by construction):
//     match recv { null => null; <Inner> as __tkqL_C => __tkqL_C.<member…> }
// typed `R?` (an already-optional R stays R?; a void R makes the whole safe call void —
// statement position only, with an EMPTY null-arm body).

// the deterministic per-node binder name `__tkq<line>_<col>` (position-derived, no global
// counter — both twin checkers produce the same name for the same node).
fn safe_binder_name(line: u32, col: u32) -> str { $"__tkq{line}_{col}" }

// build the typed `match recv { null => <null:R?>; <Inner> as binder => <armv> }`.
// `armv` is the already-typed present-arm value (the member call/read on the binder).
fn safe_nav_match(recv: TExpr, inner_name: str, binder: str, armv: TExpr) -> TExpr {
    let is_void = match armv.type { Void => true; _ => false }
    let result = if is_void { armv.type } else {
        match armv.type { Optional => armv.type; _ => Optional { inner = armv.type } }
    }
    // null arm: `null => null` (typed to the result optional) — or an EMPTY body when void.
    mut null_body: []TStatement = teko::list::empty()
    if !is_void {
        null_body = teko::list::push(null_body, TExprStmt { expr = TExpr { kind = TNullLit { }; type = result; line = 0; col = 0 } })
    }
    mut arms: []TArm = teko::list::empty()
    let guard_ph = TExpr { kind = TNumber { is_float = false; value = 0; fval = 0.0 }; type = Void { }; line = 0; col = 0 }   // placeholder, gated by has_when (never read)
    arms = teko::list::push(arms, TArm { pattern = parser::NullPattern { }; has_when = false; guard = guard_ph; body = null_body })
    // present arm: `<Inner> as binder => <armv>` — the pattern re-resolves nominally in the
    // VM/codegen exactly like a user-written `match` over a `T?`.
    mut segs: []parser::Segment = teko::list::empty()
    segs = teko::list::push(segs, parser::Segment { name = inner_name })
    let bindp = parser::BindPattern { type_name = parser::Path { segments = segs }; has_binding = true; binding = binder; is_slice = false; slice_type = null; type_args = [] }
    mut pbody: []TStatement = teko::list::empty()
    pbody = teko::list::push(pbody, TExprStmt { expr = armv })
    arms = teko::list::push(arms, TArm { pattern = bindp; has_when = false; guard = guard_ph; body = pbody })
    TExpr { kind = TMatchExpr { subject = recv; arms = arms }; type = result; line = 0; col = 0 }
}

/**
 * is_foreach_elem_placeholder — is `p` the for-each loop-head desugar's element-bind placeholder
 * (§5.4)? `loop mut x in <it> { … }` desugars (`parser::loop_head.tks`) to `match _it() { null =>
 * break; <placeholder> => { … } }`, where `<placeholder>` is a `BindPattern` with an EMPTY
 * `type_name` — an internal marker reachable ONLY from the parser's own for-each desugar, never
 * from user source (a literal `_ as x` is now a parse-time error: `_` is a discard, `as x` a
 * capture — a semantic contradiction, owner ruling). `resolve_foreach_arm`, BEFORE any
 * pattern-matching/exhaustiveness/codegen ever sees a for-each match's arms, rewrites this
 * placeholder into a REAL `T as x` bind (T = the iterator's resolved element type) — the SAME
 * sound, pre-existing named-bind mechanism `Foo as v` already uses, so VM/native/LIR need NO
 * special case.
 *
 * @param p  the arm pattern to classify
 * @return   true iff `p` is the for-each placeholder
 */
fn is_foreach_elem_placeholder(p: parser::Pattern) -> bool {
    match p {
        parser::BindPattern as bp => bp.type_name.segments.len == 0 && !bp.is_slice && bp.has_binding
        _ => false
    }
}

/**
 * elem_type_name — the RUNTIME-facing BARE name of a for-each iterator's element type `t` — the
 * SAME bare, unqualified spelling VM's `bind_case_name`/`val_type_matches` and codegen's
 * `cg_path_last`/`cg_emit_case_key_str` already compare against for an ordinary `Foo as v` bind
 * (mirrors the "#109 W3 bare-vs-bare" convention throughout match.tks/vm.tks/codegen.tks — the
 * runtime never carries a namespace). Handles the realistic element-type shapes (prim, byte, char,
 * str, a named struct/class/enum); every other `Type` case is a clean, named internal error (not
 * yet supported by the for-each desugar).
 *
 * @param t  the iterator's resolved element type (`_it`'s `T?` with `null` stripped)
 * @return   the bare runtime name string, or an error for an unnameable element type
 */
fn elem_type_name(t: Type) -> str | error {
    match t {
        Prim as p => prim_name(p.kind)
        Byte => "byte"
        Char => "char"
        Str => "str"
        Named as n => name_last_segment(n.name)
        _ => error { message = "internal: a for-each iterator's element type must be a nameable type (prim/byte/char/str/named) — this shape is not yet supported" }
    }
}

/**
 * optional_inner_or_self — the Optional-stripped inner of `t` (or `t` itself when it is not an
 * Optional). A DEDICATED, single-purpose function (not inlined) so every caller shares ONE
 * extraction point.
 *
 * @param t  the type to strip
 * @return   `t`'s Optional inner, or `t` unchanged
 */
fn optional_inner_or_self(t: Type) -> Type {
    match t { Optional as o => o.inner; _ => t }
}

/**
 * resolve_foreach_arm — the SYNTACTIC completion one match arm needs for `exhaustive`'s coverage
 * check ONLY: when `a.pattern` is the for-each placeholder, rewrite it into a `BindPattern` carrying
 * a non-empty `type_name` (so `present_case_covered` recognizes it as covering the present case,
 * exactly like it already does for `Foo as v`); every other arm (the `null => break` arm, and any
 * ordinary user arm) passes through unchanged. This rewrite is NEVER re-resolved via `resolve_named`
 * (see `type_foreach_elem_arm` for the actual TYPED binding, which bypasses name-resolution — the
 * element type may live outside the match's own referencing namespace, exactly the reason the
 * existing `?.` desugar's `safe_nav_match` ALSO bypasses it).
 *
 * @param a        the syntactic match arm
 * @param subject  the match's subject type (an Optional when this is a for-each pull)
 * @return         the (possibly rewritten) arm, or an error when the element type is unnameable
 */
fn resolve_foreach_arm(a: parser::Arm, subject: Type) -> parser::Arm | error {
    if !is_foreach_elem_placeholder(a.pattern) { return a }
    let bp = match a.pattern { parser::BindPattern as b => b; _ => return a }
    let inner = optional_inner_or_self(subject)
    let tn = match elem_type_name(inner) { str as s => s; error as e => return e }
    let segs = teko::list::push(teko::list::empty(), parser::Segment { name = tn })
    let real = parser::BindPattern { type_name = parser::Path { segments = segs }; has_binding = bp.has_binding; binding = bp.binding; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    parser::Arm { pattern = real; has_when = a.has_when; guard = a.guard; body = a.body }
}

/**
 * resolve_foreach_placeholders — complete every arm of a match's arm list (`resolve_foreach_arm`,
 * applied in order) — used ONLY to build the arm list `exhaustive` checks coverage against. A no-op
 * (returns `arms` unchanged) for any match that carries no placeholder.
 *
 * @param arms     the syntactic match arm list
 * @param subject  the match's subject type
 * @return         the (possibly rewritten) arm list, or the first arm's completion error
 */
fn resolve_foreach_placeholders(arms: []parser::Arm, subject: Type) -> []parser::Arm | error {
    mut out: []parser::Arm = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= arms.len { break }
        let ra = match resolve_foreach_arm(arms[i], subject) { parser::Arm as a => a; error as e => return e }
        out = teko::list::push(out, ra)
        i++
    }
    out
}

/**
 * type_foreach_elem_arm — TYPE the for-each pull's element-bind placeholder arm DIRECTLY, bypassing
 * `check_pattern`'s name-based type-RESOLUTION (`bind_pattern_type`/`resolve_named`'s bare-path rule
 * requires the SAME referencing namespace as the type's own declaration — the element type may live
 * elsewhere; the SAME reason the existing `?.` desugar's `safe_nav_match` ALSO builds its `TArm`
 * directly instead of going through `check_pattern`). Extracts the placeholder's `BindPattern` and
 * the element type in ONE function (mirrors `resolve_foreach_arm`'s shape), binds the element name
 * directly to the ALREADY-KNOWN type (no re-derivation needed — it came straight from `_it`'s
 * resolved return type), types the body against that binding, and the emitted `TArm.pattern`
 * carries a REAL, bare-named `BindPattern` (`elem_type_name`) — so VM's `pat_match`/codegen's
 * `emit_pat_binds` see an ORDINARY named bind and need no special case (#517, §5.4.1).
 *
 * @param a        the syntactic placeholder arm
 * @param subject  the match's subject type (an Optional; its inner is the element type T)
 * @param env      the enclosing type environment
 * @param table    the type table
 * @return         the typed arm, or an error when the pattern is not the expected placeholder
 *                 shape, T is not a nameable element type, or the guard is non-bool
 */
fn type_foreach_elem_arm(a: parser::Arm, subject: Type, env: Env, table: TypeTable) -> TArm | error {
    let bp = match a.pattern { parser::BindPattern as b => b; _ => return error { message = "internal: for-each placeholder must be a BindPattern" } }
    let inner = optional_inner_or_self(subject)
    let tn = match elem_type_name(inner) { str as s => s; error as e => return e }
    let e2 = define(env, bp.binding, inner, false)
    let body = match type_block(a.body, e2, table) { TypedBlock as bk => bk; error as err => return err }
    mut guard = TExpr { kind = TNumber { is_float = false; value = 0; fval = 0.0 }; type = Void { }; line = 0; col = 0 }
    if a.has_when {
        let g = match type_expr(a.guard, e2, table) { TExpr as te => te; error as err => return err }
        if !is_bool(g.type) { return error { message = "a `when` guard must be a bool" } }
        guard = g
    }
    let segs = teko::list::push(teko::list::empty(), parser::Segment { name = tn })
    let real = parser::BindPattern { type_name = parser::Path { segments = segs }; has_binding = bp.has_binding; binding = bp.binding; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    TArm { pattern = real; has_when = a.has_when; guard = guard; body = body.stmts }
}

/**
 * type_match_arm — type ONE match arm, routing the for-each desugar's placeholder arm through the
 * bypass (`type_foreach_elem_arm`) and every other arm through the ordinary, unmodified `type_arm`.
 *
 * @param a        the syntactic match arm
 * @param subject  the match's subject type
 * @param env      the enclosing type environment
 * @param table    the type table
 * @return         the typed arm, or an error
 */
fn type_match_arm(a: parser::Arm, subject: Type, env: Env, table: TypeTable) -> TArm | error {
    if is_foreach_elem_placeholder(a.pattern) { return type_foreach_elem_arm(a, subject, env, table) }
    type_arm(a, subject, env, table)
}

// validate a `?.` receiver: must be a NON-sentinel optional; enrich the disjoint-domain
// case (an `X | error` union reads via `match`, never `?.` — the LAW's other half).
fn safe_nav_receiver(receiver: parser::Expr, env: Env, table: TypeTable) -> TExpr | error {
    let recv = match type_expr(receiver, env, table) { TExpr as te => te; error as e => return e }
    let inner = match recv.type {
        Optional as o => o.inner
        _ => {
            let is_error_like = match recv.type { Error => true; _ => match expand_variant(recv.type, table) { Variant => true; _ => false } }
            if is_error_like {
                return error { message = "`?.` reads absence (`T?`), never errors — inspect an `X | error` union with `match` (disjoint-domain law)" }
            }
            return error { message = "safe access `?.` needs an optional receiver (`T?`) — use `.` for a non-optional (REBOOT_PLAN §203)" }
        }
    }
    match inner {
        Void => error { message = "`?.` on a bare `null` has no member to reach (annotate the optional's type)" }
        _ => recv
    }
}

// `recv?.field` (REBOOT_PLAN §203): the receiver must be an OPTIONAL of a named struct or
// class; the result is the field's type made optional — null propagates. A STRUCT inner
// keeps the dedicated TSafeFieldAccess node; a CLASS inner desugars to the safe-nav match
// (NP-OOP), routing through type_field_access so visibility holds EXACTLY like a bare `.`.
fn type_safe_field_access(sfa: parser::SafeFieldAccess, line: u32, col: u32, env: Env, table: TypeTable) -> TExpr | error {
    let recv = match safe_nav_receiver(sfa.receiver, env, table) { TExpr as te => te; error as e => return e }
    let inner = match recv.type { Optional as o => o.inner; _ => return error { message = "internal: safe_nav_receiver guarantees an optional" } }
    let name = match inner {
        Named as n => n.name
        _ => return error { message = "safe field access on a non-struct optional is not yet supported (the struct-field layer is pending — M.3)" }
    }
    let decl = match type_table_find(table, name, "") {   // (#109 W1) safe-field-access receiver lookup on a resolved name — no referencing ns
        parser::TypeDecl as td => td
        error => return error { message = $"unknown type for safe field access: {name}" }
    }
    // (NP-OOP, issue #116) CLASS route — desugar to the safe-nav match; the arm's field read
    // is typed by type_field_access itself (same visibility, same `.len`/field rules).
    match decl.body {
        parser::ClassBody => {
            let binder = safe_binder_name(line, col)
            let env2 = define(env, binder, inner, false)
            let rvar = parser::Expr { kind = parser::Var { name = binder }; line = line; col = col }
            let fa2 = parser::FieldAccess { receiver = rvar; field = sfa.field }
            let tf = match type_field_access(fa2, env2, table) { TExpr as te => te; error as e => return e }
            return safe_nav_match(recv, name, binder, tf)
        }
        _ => { }
    }
    // STRUCT route — the original TSafeFieldAccess lowering (native emission is value-based).
    let ft = match decl.body {
        parser::StructBody as sb => match field_type(sb.fields, sfa.field, table, type_ns_of(table, name)) { Type as t => t; error as e => return e }
        _ => return error { message = $"type {name} is not a struct (no fields)" }
    }
    // the result is `(field)?` — an already-optional field stays as-is (no double-wrap).
    let rt = match ft { Optional => ft; _ => Optional { inner = ft } }
    TExpr { kind = TSafeFieldAccess { receiver = recv; field = sfa.field }; type = rt; line = 0; col = 0 }
}

// `recv?.method(args)` (NP-OOP, issue #116): a null-propagating METHOD call on a `T?` of a
// named struct/class/interface. Desugars to the safe-nav match; the arm's call is typed by
// type_method_call itself — visibility, arity, defaults and interface (vtable) dispatch all
// behave EXACTLY like a bare `.` call (no bypass through the null-propagating path).
fn type_safe_method_call(smc: parser::SafeMethodCall, line: u32, col: u32, env: Env, table: TypeTable) -> TExpr | error {
    let recv = match safe_nav_receiver(smc.receiver, env, table) { TExpr as te => te; error as e => return e }
    let inner = match recv.type { Optional as o => o.inner; _ => return error { message = "internal: safe_nav_receiver guarantees an optional" } }
    let name = match inner {
        Named as n => n.name
        _ => return error { message = "safe method call `?.` needs an optional of a named type (a struct, class or interface)" }
    }
    let decl = match type_table_find(table, name, "") {   // (#109 W1) safe-method-call receiver lookup on a resolved name — no referencing ns
        parser::TypeDecl as td => td
        error => return error { message = $"unknown type for safe method call: {name}" }
    }
    // an ENUM inner would desugar into a member pattern, not a type bind — honest stop.
    match decl.body {
        parser::EnumBody => return error { message = "safe method call on an optional enum is not yet supported — bind it with `match` first" }
        _ => { }
    }
    let binder = safe_binder_name(line, col)
    let env2 = define(env, binder, inner, false)
    let rvar = parser::Expr { kind = parser::Var { name = binder }; line = line; col = col }
    let call = parser::MethodCall { receiver = rvar; method = smc.method; args = smc.args }
    let tc = match type_method_call(call, env2, table) { TExpr as te => te; error as e => return e }
    safe_nav_match(recv, name, binder, tc)
}

// `a ?? b` (REBOOT_PLAN §203): the left must be Optional `T?`; the right is `T` (result `T`)
// or `T?` (result `T?`). A bare `null` on the right adopts the left's optional (the one site
// where `null` gets its context — REBOOT_PLAN §202).
fn type_coalesce(co: parser::Coalesce, env: Env, table: TypeTable) -> TExpr | error {
    let l = match type_expr(co.left, env, table) { TExpr as te => te; error as e => return e }
    let unwrapped = match l.type {
        Optional as o => o.inner
        _ => return error { message = "`??` needs an optional left operand (`T?`) — its right is the fallback (REBOOT_PLAN §203)" }
    }
    // (NP-OOP, issue #116) a SENTINEL optional left (`null ?? x`) has no inner `T` to unwrap —
    // honest error (M.1), mirroring the C twin's NULL-inner guard.
    match unwrapped {
        Void => return error { message = "`??` on a bare `null` has nothing to unwrap — the left must be a typed `T?` (REBOOT_PLAN §203)" }
        _ => { }
    }
    match co.right.kind {
        parser::NullLit => {   // `x ?? null` ⇒ T? — the right adopts the left's optional type
            let rnull = TExpr { kind = TNullLit { }; type = l.type; line = 0; col = 0 }
            return TExpr { kind = TCoalesce { left = l; right = rnull }; type = l.type; line = 0; col = 0 }
        }
        _ => { }
    }
    let r = match type_expr(co.right, env, table) { TExpr as te => te; error as e => return e }
    // A DIVERGING fallback (panic/exit) never produces a value — accept it for any left type; the
    // result is the unwrapped `T` (the present-case value). (No `never` type — legislator's ruling.)
    if texpr_diverges(r) { return TExpr { kind = TCoalesce { left = l; right = r }; type = unwrapped; line = 0; col = 0 } }
    // (issue #120) a `void` fallback never produces a value either — but unlike a diverging
    // call it does not GUARANTEE control never returns, so it cannot stand in for `T`. Honest
    // error (M.1), mirroring the C twin's `tk_type_is_void(&rt)` guard exactly (same message).
    if type_is_void(r.type) { return error { message = "a `void` expression cannot be the `??` fallback (M.1)" } }
    // `T? ?? T` ⇒ T (the unwrapping case). (NP-OOP, issue #116) the fallback may also WIDEN
    // into T — the same assignability a binding/param slot grants (widens_into), so a
    // conforming class instance backs an interface-typed optional: `shape_opt ?? circle`.
    if type_eq(r.type, unwrapped) || widens_into(r.type, unwrapped, table) {
        return TExpr { kind = TCoalesce { left = l; right = r }; type = unwrapped; line = 0; col = 0 }
    }
    if type_eq(r.type, l.type) {   // `T? ?? T?` ⇒ T?
        return TExpr { kind = TCoalesce { left = l; right = r }; type = l.type; line = 0; col = 0 }
    }
    error { message = "the `??` fallback must be `T` or `T?` for the left's optional `T?` (REBOOT_PLAN §203)" }
}

// ---- struct literal `Name { f = v, … }` (W4a) ----
// Resolve the named struct, require EXACTLY the declared fields (once each — M.1), check
// per-field value types, and emit the typed children in the struct's DECLARED order (so the
// VM and codegen lower identically). A numeric literal adopts a fitting field prim type
// (parity with annotated bindings).
// `expected` is the binding/return/param type the literal flows into (a `Void` sentinel = none). It
// retargets a GENERIC struct constructor `Box { … }` to the concrete instance named by the annotation
// (`Box__g__i64`), so the fields type against i64 — annotation-driven (S4 type-generics, legislated).
fn type_struct_lit(sl: parser::StructLit, expected: Type, env: Env, table: TypeTable) -> TExpr | error {
    let nt = match resolve_named(sl.type_path, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the literal's enclosing namespace
    // The builtin `error` is the one non-Named constructible type — `error { message = <str> }` (B.1).
    match nt {
        Error => {
            if sl.field_names.len != 1 || sl.field_names[0] != "message" {
                return error { message = "`error` is constructed as `error { message = <str> }` (one `message` field)" }
            }
            let v = match type_expr(sl.field_vals[0], env, table) { TExpr as te => te; error as e => return e }
            match v.type { Str => { }; _ => return error { message = "`error`'s `message` must be a `str`" } }
            mut enames = teko::list::push(teko::list::empty(), "message")
            mut evals = teko::list::push(teko::list::empty(), v)
            return TExpr { kind = TStructInit { field_names = enames; field_vals = evals }; type = Error { }; line = 0; col = 0 }
        }
        _ => { }
    }
    let canon_name = match nt {
        Named as n => n.name   // (#109 W3) CANONICAL result-type name (mirrors expr.c `name = nt.name`); type_eq compares canonical both sides
        _ => return error { message = "a struct literal requires a named struct type" }
    }
    let base_name = name_last_segment(canon_name)   // (#109 W3) BARE base — a generic instance name (Gen__g__i64) is bare, so name_has_generic_base matches the bare "Gen" prefix
    mut name = canon_name
    mut decl = match type_table_find(table, name, "") {   // (#109 W1) struct-literal decl lookup on a resolved name — no referencing ns
        parser::TypeDecl as td => td
        error => return error { message = $"unknown type in a struct literal: {name}" }
    }
    mut tgt = expected
    // (W9.4) explicit construction-site type-args `Foo<i64>{ … }` resolve to the concrete instance
    // `Foo__g__i64` directly — NO annotation required. This OVERRIDES `expected`: resolve the synthetic
    // generic type (the same path as an annotation), which validates arity and rejects non-generic-with-args.
    // The instance decl is stamped by instantiate_types (fed from the construction site). If the annotation
    // is ANOTHER instance of the SAME generic base, the two must name the same instance; if it is a wider
    // type (a variant the instance widens into), the binding-level widening check below handles it (so
    // `let w: Wrap = Gen<i64>{…}` is fine).
    if sl.type_args.len > 0 {
        let gte = parser::NamedType { path = sl.type_path; args = sl.type_args }
        let git = match resolve_type(gte, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the literal's enclosing namespace
        let ginst = match git { Named as gn => gn.name; _ => return error { message = "explicit type-arguments did not resolve to a struct instance" } }
        match tgt {
            Named as en => { if name_has_generic_base(en.name, base_name) && en.name != ginst { return error { message = "the explicit type-arguments at construction disagree with the annotated type" } } }
            _ => { }
        }
        tgt = git   // retarget below as if annotated
    }
    // (S4) constructing a GENERIC struct → retarget to the concrete instance named by `tgt` (the
    // annotation OR the W9.4 construction-site type-args), so `Box { … }` under `: Box<i64>`
    // (or `Box<i64> { … }`) builds `Box__g__i64` (its fields are T→i64).
    mut is_self_construct = false
    if decl.type_params.len > 0 {
        if is_self_generic_construct(base_name, env.owner_type, decl.type_params) {
            is_self_construct = true
            name = phantom_self_inst_name(base_name, decl.type_params)
        } else {
            let mname = match tgt {
                Named as en => en.name
                _ => return error { message = $"cannot infer the type arguments of `{base_name}` here — annotate it (e.g. `let x: {base_name}<…> = …`)" }
            }
            if !name_has_generic_base(mname, base_name) {
                return error { message = $"struct literal `{base_name}` does not match the annotated type" }
            }
            decl = match type_table_find(table, mname, "") {
                parser::TypeDecl as td => td
                error => return error { message = $"internal: generic instance `{mname}` was not stamped" }
            }
            name = mname
        }
    }
    // (W10b.CLASS) `Name { … }` also constructs a class instance — a class's fields are typed
    // identically to a struct's (increment 2: the EFFECTIVE, base-inherited fields too). An
    // `abstract` class cannot be instantiated directly (only a concrete subclass may be — it is
    // final, incomplete-by-design).
    let sb_fields = match decl.body {
        parser::StructBody as s => s.fields
        parser::ClassBody as c => {
            match c.kind { ClassKind::Abstract => return error { message = $"`{name}` is abstract and cannot be instantiated directly" }; _ => { } }
            // (W10b.D1) invariant-safe construction — a class's `{…}` literal is legal ONLY inside
            // the class's OWN methods (its static factories and instance methods), so the
            // arena-per-object and the class's invariants stay inviolable from outside code.
            // `env.owner_type` is the DECLARING class of the method body currently being typed
            // ("" outside any method) — a purely inherited method keeps its ORIGINAL declaring
            // class (type_struct_methods), so a base factory constructing the base stays legal when
            // re-typed under a derived class. Structs are pure value data: their literals stay free.
            if !is_self_construct && name_last_segment(env.owner_type) != name_last_segment(name) {
                return error { message = $"a class literal is only legal inside the class's own methods — construct it via a static factory: {name}" }
            }
            match effective_class_fields(c, table) { []parser::Field as fs => fs; error as e => return e }
        }
        // (TR0) a trait is NON-instantiable — it exists only to be derived. Point at the fix.
        parser::TraitBody => return error { message = $"'{name}' is a trait and cannot be instantiated — derive it from a struct or class instead (`type X = struct {name} …`)" }
        _ => return error { message = $"struct-literal target {name} is not a struct" }
    }
    if sl.field_names.len != sb_fields.len { return error { message = "a struct literal must set exactly the declared fields (count mismatch)" } }

    mut names: []str = teko::list::empty()
    mut vals: []TExpr = teko::list::empty()
    mut d = 0
    loop {
        if d >= sb_fields.len { break }
        let fname = sb_fields[d].name
        // locate the provided value for this declared field (count its hits for missing/dup checks).
        mut found = sl.field_names.len
        mut hits = 0
        mut i: u64 = 0   // u64 index (so `found = i` matches found's u64 type; mirrors the C twin's size_t)
        loop {
            if i >= sl.field_names.len { break }
            if sl.field_names[i] == fname { found = i; hits++ }
            i++
        }
        if hits == 0 { return error { message = "a struct literal is missing a declared field" } }
        if hits > 1 { return error { message = "a struct literal sets a field more than once" } }
        let ft = match resolve_type(sb_fields[d].type_ann, table, type_ns_of(table, name)) { Type as t => t; error as e => return e }   // (#109 W2) field annotation resolves in the struct's OWN ns
        // thread the field's type as EXPECTED so a nested generic constructor (`value = Box { … }`)
        // targets its concrete instance (S4). Non-struct-lit values type exactly as before.
        mut val = match type_value_expected(sl.field_vals[found], ft, env, table) { TExpr as te => te; error as e => return e }
        // literal adaptation: a fitting numeric literal adopts the field's prim type.
        match val.kind {
            TNumber as num => match ft {
                Prim as p => {
                    if !type_eq(val.type, ft) {
                        let fits = if num.is_float { prim_is_float(p.kind) }
                        else { prim_is_int(p.kind) && value_fits(num.value, p.kind) }
                        if fits { val = TExpr { kind = val.kind; type = ft; line = val.line; col = val.col } }
                    }
                }
                _ => { }
            }
            _ => { }
        }
        // (#4) a sentinel empty list ADOPTS the field's declared slice type (the field decl is the
        // known element source), so codegen emits the concrete element — no back-inference.
        let val_is_sentinel_slice = match val.type { Slice as vs => match vs.element { Void => true; _ => false }; _ => false }
        let ft_is_concrete_slice = match ft { Slice as fs => match fs.element { Void => false; _ => true }; _ => false }
        if val_is_sentinel_slice {
            if ft_is_concrete_slice {
                val = TExpr { kind = val.kind; type = ft; line = val.line; col = val.col }
            }
        }
        // The field value must WIDEN into the field's declared type (exact, a variant CASE into a
        // variant-typed field — keep the case type so codegen's emit_as wraps it — or `T` into a
        // `T?`); OR be a fitting numeric LITERAL that ADOPTS the field type (incl a `byte` field = u8,
        // `lo = 0x80`), in which case the leaf is retyped. Same rules as binding/arg adoption.
        if !widens_into(val.type, ft, table) {
            if literal_adopts(val, ft) {
                val = TExpr { kind = val.kind; type = ft; line = val.line; col = val.col }   // a fitting literal adopts the field's type
            } else {
                return error { message = "a struct-literal field value does not match the field's declared type" }
            }
        }
        names = teko::list::push(names, fname)
        vals = teko::list::push(vals, val)
        d++
    }
    TExpr { kind = TStructInit { field_names = names; field_vals = vals }; type = Named { name = name }; line = 0; col = 0 }
}

// is `mname` a generic INSTANCE of `base` (i.e. it begins with `base` + the `__g__` infix)? Used to
// confirm a generic struct literal matches its annotated instance type before retargeting (S4).
fn name_has_generic_base(mname: str, base: str) -> bool {
    let pfx = teko::str::concat(base, "__g__")
    if mname.len < pfx.len { return false }
    mut i = 0
    loop {
        if i >= pfx.len { break }
        if mname[i] != pfx[i] { return false }
        i++
    }
    true
}

// ---- subscript index `recv[index]` (W5-idx) ----
// The receiver is a `str` (-> byte) or a slice `[]T` (-> element type T); the index must be
// an integer prim. str indexing/.len is fully lowered in both backends; slice values can't
// be constructed yet, so a slice index type-checks here but is an honest stop in VM/codegen.
fn type_index(ix: parser::Index, env: Env, table: TypeTable) -> TExpr | error {
    let recv = match type_expr(ix.receiver, env, table) { TExpr as te => te; error as e => return e }
    let idx = match type_expr(ix.index, env, table) { TExpr as te => te; error as e => return e }
    if !is_integer(idx.type) { return error { message = "a subscript index must be an integer" } }
    match recv.type {
        Str => TExpr { kind = TIndex { receiver = recv; index = idx }; type = Byte { }; line = 0; col = 0 }
        Slice as s => TExpr { kind = TIndex { receiver = recv; index = idx }; type = s.element; line = 0; col = 0 }
        _ => error { message = "cannot index a value of this type" }
    }
}

// is_interp_formattable — ROUND 0 hole types: str, char, bool, byte, error, int, float prims.
fn is_interp_formattable(t: Type) -> bool {
    match t {
        Str => true
        Char => true
        Byte => true
        Error => true
        Prim => true   // all prim (int, float, bool)
        _ => false
    }
}
fn interp_is_numeric(t: Type) -> bool {
    match t { Prim as p => true; _ => false }
}

// ---- string interpolation `$"…{expr}…"` (self-host parity) ----
// ROUND 0 expansion: accepts str, char, bool, byte, error, int, float hole types.
// Format specs: static (`:literal`) → validate hole is numeric; dynamic (`:[arg1,…]`) → validate
// each arg is str. Named/variant types with specs → honest-stop. Result type is always `str`.
/**
 * The calendar `to_string` function name for a Date/Time-shaped hole type, or "" if the hole is
 * not a Date/Time value.
 *
 * A static format spec on a `Named` hole whose bare type name is `Date`, `Time`, or `DateTime`
 * is a CALENDAR PATTERN (`$"{d:yyyy-MM-dd}"`), not a numeric spec; it desugars to a call to the
 * type's own-namespace formatter (`date_to_string` for a Date/DateTime, `time_to_string` for a
 * Time). Recognizing by bare last segment lets a re-declared local `Date`/`Time` (a standalone
 * project cannot `use teko::time`) format identically to the canonical `teko::time` types.
 *
 * @param t  the hole's resolved type
 * @return   "date_to_string" / "time_to_string" for a Date/Time/DateTime hole, else ""
 */
fn datetime_formatter_of(t: Type) -> str {
    match t {
        Named as n => {
            let bare = name_last_segment(n.name)
            if bare == "Date" || bare == "DateTime" { return "date_to_string" }
            if bare == "Time" { return "time_to_string" }
            ""
        }
        _ => ""
    }
}

/**
 * Desugar a Date/Time interpolation hole with a calendar pattern into a `to_string` CALL.
 *
 * Rewrites `$"{d:yyyy-MM-dd}"` into `<ns>::date_to_string(d, "yyyy-MM-dd")` (or `time_to_string`),
 * typed here so codegen and the VM see an ordinary str-returning call — both engines then run the
 * SAME pure-Teko formatter, guaranteeing byte-identical output. The raw (un-typed) hole is reused
 * as the receiver so the call's own argument typing applies uniformly.
 *
 * @param raw_hole  the original (un-typed) hole expression
 * @param hole_ns   the namespace qualifier of the hole's Date/Time type ("" for a bare type)
 * @param fn_name   the formatter name from `datetime_formatter_of` (date_to_string/time_to_string)
 * @param pattern   the calendar pattern captured from the static spec
 * @param env       the current typing environment
 * @param table     the resolved type table
 * @return          the typed `to_string` call, or a checker error if it does not resolve
 */
fn desugar_datetime_hole(raw_hole: parser::Expr, hole_ns: str, fn_name: str, pattern: str, env: Env, table: TypeTable) -> TExpr | error {
    mut segs: []parser::Segment = teko::list::empty()
    if hole_ns != "" {
        mut qi: u64 = 0
        mut seg_start: u64 = 0
        loop {
            if qi + 1 >= hole_ns.len { break }
            if hole_ns[qi] == b':' && hole_ns[qi + 1] == b':' {
                segs = teko::list::push(segs, parser::Segment { name = teko::str::slice(hole_ns, seg_start, qi) })
                qi = qi + 2
                seg_start = qi
            } else { qi++ }
        }
        segs = teko::list::push(segs, parser::Segment { name = teko::str::slice_from(hole_ns, seg_start) })
    }
    segs = teko::list::push(segs, parser::Segment { name = fn_name })
    let pat_expr = parser::Expr { kind = parser::StrLit { text = pattern }; line = 0; col = 0 }
    mut args: []parser::Expr = teko::list::push(teko::list::empty(), raw_hole)
    args = teko::list::push(args, pat_expr)
    mut arg_names: []str = teko::list::push(teko::list::empty(), "")
    arg_names = teko::list::push(arg_names, "")
    let call = parser::Call { callee = parser::Path { segments = segs }; args = args; arg_names = arg_names; type_args = teko::list::empty() }
    type_call(call, env, table)
}

fn type_interp(in: parser::Interp, env: Env, table: TypeTable) -> TExpr | error {
    mut holes: []TExpr = teko::list::empty()
    mut specs: []TFSpec = teko::list::empty()
    mut i = 0
    loop {
        if i >= in.holes.len { break }
        let h = match type_expr(in.holes[i], env, table) { TExpr as te => te; error as e => return e }
        let dt_fmt = datetime_formatter_of(h.type)
        if dt_fmt != "" && i < in.specs.len {
            match in.specs[i].kind {
                parser::FSpecStatic as fs => {
                    let hole_ns = match h.type { Named as n => name_qualifier(n.name); _ => "" }
                    let dh = match desugar_datetime_hole(in.holes[i], hole_ns, dt_fmt, fs.s, env, table) { TExpr as te => te; error as e => return e }
                    holes = teko::list::push(holes, dh)
                    specs = teko::list::push(specs, TFSpec { kind = TFSpecNone { } })
                    i++
                    continue
                }
                _ => { }
            }
        }
        if !is_interp_formattable(h.type) {
            return error { message = "interpolation hole type not supported in ROUND 0 (must be str/char/bool/byte/error/int/float)" }
        }
        holes = teko::list::push(holes, h)
        // type-check format spec if present
        if i < in.specs.len {
            let raw_sp = in.specs[i]
            let typed_sp = match raw_sp.kind {
                parser::FSpecNone => TFSpec { kind = TFSpecNone { } }
                parser::FSpecStatic as fs => {
                    if !interp_is_numeric(h.type) {
                        return error { message = "format spec requires a numeric hole (int or float)" }
                    }
                    TFSpec { kind = TFSpecStatic { s = fs.s } }
                }
                parser::FSpecDynamic as fd => {
                    if !interp_is_numeric(h.type) {
                        return error { message = "format spec requires a numeric hole (int or float)" }
                    }
                    mut dyn_args: []TExpr = teko::list::empty()
                    mut k = 0
                    loop {
                        if k >= fd.args.len { break }
                        let da = match type_expr(fd.args[k], env, table) { TExpr as te => te; error as e => return e }
                        match da.type { Str => { }; _ => return error { message = "dynamic format spec argument must be str" } }
                        dyn_args = teko::list::push(dyn_args, da)
                        k++
                    }
                    TFSpec { kind = TFSpecDynamic { args = dyn_args } }
                }
            }
            specs = teko::list::push(specs, typed_sp)
        } else {
            specs = teko::list::push(specs, TFSpec { kind = TFSpecNone { } })
        }
        i++
    }
    TExpr { kind = TInterp { pieces = in.pieces; holes = holes; specs = specs }; type = Str { }; line = 0; col = 0 }
}

// <expr> in [ e0, e1, … ] (Phase 2) — membership test. Type the lhs ONCE; require each element
// be COMPARABLE to the lhs (the SAME is_comparable rule used by `==`/compare — B.22), since the
// runtime is `lhs == e0 || lhs == e1 || …`. The empty set `x in []` is allowed (result is still
// bool — always false). The node's `.type` is bool. C twin: type_in in expr.c.
fn type_in(n: parser::InExpr, env: Env, table: TypeTable) -> TExpr | error {
    let lhs = match type_expr(n.lhs, env, table) { TExpr as te => te; error as e => return e }
    if type_is_void(lhs.type) { return error { message = "a `void` expression cannot be an operand (M.1)" } }
    // (MEM Step 0, R4) ESCAPE GATE — `in` has its own element path (it does NOT build an ArrayLit),
    // so the literal-form gate doesn't reach it. A reference may not be an `in` operand (lhs or set
    // element): the [a, b] set is a value-position collection of refs. Mirror in expr.c::type_in.
    if type_contains_ref(lhs.type) { return error { message = "a reference cannot be stored in a struct/variant/collection" } }
    mut elems: []TExpr = teko::list::empty()
    mut i = 0
    loop {
        if i >= n.elems.len { break }
        let el = match type_expr(n.elems[i], env, table) { TExpr as te => te; error as e => return e }
        if type_is_void(el.type) { return error { message = "a `void` expression cannot be an operand (M.1)" } }
        if type_contains_ref(el.type) { return error { message = "a reference cannot be stored in a struct/variant/collection" } }
        if !is_comparable(lhs.type, el.type) { return error { message = "`in` element is not comparable to the left-hand operand" } }
        elems = teko::list::push(elems, el)
        i++
    }
    TExpr { kind = TInExpr { lhs = lhs; elems = elems }; type = Prim { kind = PrimKind::Bool }; line = 0; col = 0 }
}

// `[ e0, e1, … ]` (Increment B+): type every element, UNIFY to a common element type T (widening —
// a case joins into its variant; sibling cases → their union), result `[]T`. An empty `[]` yields
// the SENTINEL `[]Void` — exactly like `teko::list::empty()` — so a binding annotation (`: []T`)
// adopts it and a bare unannotated `[]` is rejected by type_binding (collections #4). Spread
// elements (`..xs`) must type as `[]T`; their element type T is widened into the unified element.
// C twin: type_array_lit in expr.c.
fn type_array_lit(a: parser::ArrayLit, env: Env, table: TypeTable) -> TExpr | error {
    mut elems: []TArrayElem = teko::list::empty()
    mut et: Type = Void { }   // sentinel for an empty `[]` (no inferable element)
    mut i = 0
    loop {
        if i >= a.elements.len { break }
        let ae = a.elements[i]
        let el = match type_expr(ae.expr, env, table) { TExpr as te => te; error as e => return e }
        if ae.is_spread {
            // spread element: expr must be a `[]T` slice; contribute T as the element type
            let spread_elem = match el.type {
                Slice as s => s.element
                _ => return error { message = "a spread element (`..xs`) must be a slice (`[]T`)" }
            }
            if type_is_void(spread_elem) { return error { message = "a spread element cannot be an untyped empty slice" } }
            if type_is_void(et) { et = spread_elem } else { et = type_join(et, spread_elem, table) }
        } else {
            // plain element: original logic
            if type_is_void(el.type) { return error { message = "a `void` expression cannot be an array element (M.1)" } }
            if type_is_void(et) { et = el.type } else { et = type_join(et, el.type, table) }
        }
        elems = teko::list::push(elems, TArrayElem { is_spread = ae.is_spread; expr = el })
        i++
    }
    // (MEM Step 0, R4) ESCAPE GATE — an INFERRED element type may not carry a reference. The
    // annotated form `let xs: []Ref<T> = …` is already rejected in resolve, but the inferred
    // element here (e.g. `[r, r]`) only surfaces now. This also rejects `a in [a, b]` (its `[a, b]`).
    if type_contains_ref(et) { return error { message = "a reference cannot be stored in a struct/variant/collection" } }
    // (#83) CONCRETIZE any sibling element still carrying a SENTINEL now that `et` (the join across
    // every element) is settled. `[[], [1]]`'s inner `[]` types as `[]Void` on its own (this fn's
    // own empty-array case, above); type_join now correctly folds `et` to the CONCRETE `[]i64`
    // (the #83 fix), but the individual element's own `TExpr.type` is untouched — it still says
    // `[]Void`, and codegen's array-literal case reads the element type OFF THE NODE ITSELF (not
    // the parent's contribution), so it would still honest-stop. Retype every element whose type
    // is a (possibly nested) sentinel form of the now-concrete `et` — same mechanism as the
    // `push(empty(), x)` base-concretization in type_list_builtin above. Only fires when the
    // element's type is type_eq to et (permissive-equal) AND actually carries a sentinel; a
    // genuinely-narrower case that WIDENS into a wider et (e.g. a case into a declared variant) is
    // left alone — codegen's emit_as wraps that at the use site instead.
    let final_elems = if a.elements.len != 0 && !type_has_sentinel(et) {
        mut out: []TArrayElem = teko::list::empty()
        mut j = 0
        loop {
            if j >= elems.len { break }
            let ael = elems[j]
            let retyped = !ael.is_spread && type_has_sentinel(ael.expr.type) && type_eq(ael.expr.type, et)
            out = teko::list::push(out, if retyped {
                    TArrayElem { is_spread = ael.is_spread; expr = TExpr { kind = ael.expr.kind; type = et; line = ael.expr.line; col = ael.expr.col } }
                } else {
                    ael
            })
            j++
        }
        out
    } else {
        elems
    }
    TExpr { kind = TArrayLit { elements = final_elems }; type = Slice { element = et }; line = 0; col = 0 }
}

// ---- the expression dispatch (the evolved check_expr) ----
// `Enum::Member` as a VALUE — the enum type (path minus the member) resolved to an `enum` decl,
// the member checked, the node typed NAMED(enum) carrying enum name + member ORDINAL (so both
// backends lower without re-lookup). C twin: type_path_expr in expr.c.
// (C8.3, ported 2026-07-01 alongside type_flags_method to unblock its self-host testing — see
// expr.c::type_path_expr) `Type::Member` as a VALUE: an ENUM member (ordinal = declaration
// index) OR a FLAGS member (ordinal = the BIT INDEX, i.e. the member's power-of-2 position, not
// its value). (#50) The node also carries the RESOLVED member `value` (enum: the ordinal;
// flags: `1 << ordinal`) so the VM reads it instead of recomputing (native codegen's pre-emitted
// constants already encode it). The .tks side previously supported ONLY enum; flags fell through
// to the enum-only error, a self-host divergence from expr.c.
// (#109 W1) `ref_ns` = the namespace the `Type::Member` expression is written in; unused until W2.
fn type_path_expr(pe: parser::PathExpr, table: TypeTable, ref_ns: str) -> TExpr | error {
    let p = pe.path
    if p.segments.len < 2 { return error { message = "a path expression must name an enum or flags member (`Type::Member`)" } }
    let member = p.segments[p.segments.len - 1].name
    mut segs: []parser::Segment = teko::list::empty()   // the type = the path minus its last segment
    mut i: u64 = 0
    loop {
        if i >= p.segments.len - 1 { break }
        segs = teko::list::push(segs, p.segments[i])
        i++
    }
    let et = match resolve_named(parser::Path { segments = segs }, table, ref_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the expression's enclosing namespace
    let tname = match et { Named as n => n.name; _ => return error { message = "`Type::Member` requires a named enum or flags type" } }
    let decl = match type_table_find(table, tname, "") { parser::TypeDecl as td => td; error => return error { message = $"unknown type in a `Type::Member` path: {tname}" } }   // (#109 W1) follow-up lookup of a resolved name — no referencing ns
    match decl.body {
        parser::EnumBody as eb => {
            mut j: u64 = 0
            loop {
                if j >= eb.members.len { break }
                if eb.members[j] == member { return TExpr { kind = TPathExpr { enum_name = tname; member = member; ordinal = j; value = j to u128 }; type = et; line = 0; col = 0 } }   // (#50) enum member VALUE = its ordinal
                j++
            }
            error { message = $"no member `{member}` in enum `{tname}`" }
        }
        parser::FlagsBody as fb => {
            if fb.members.len > 128 { return error { message = "flags type has more than 128 members (u128 overflow)" } }
            mut j: u64 = 0
            loop {
                if j >= fb.members.len { break }
                if fb.members[j] == member { return TExpr { kind = TPathExpr { enum_name = tname; member = member; ordinal = j; value = (1 to u128) << j }; type = et; line = 0; col = 0 } }   // (#50) flags member VALUE = 1 << ordinal (power-of-2)
                j++
            }
            error { message = $"no member `{member}` in the flags type `{tname}`" }
        }
        _ => error { message = "`Type::Member` requires an `enum` or `flags` type" }
    }
}

// (C1-POS) inner dispatch — the raw match over the untyped Expr's `kind`. The public type_expr
// (below) wraps this to copy each node's source position onto the typed node. The dispatch's
// TExpr constructions are built with line=0/col=0 (designated-init parity with the C twin); the
// wrapper overwrites them with the real e.line/e.col on success.
fn type_dispatch(e: parser::Expr, env: Env, table: TypeTable) -> TExpr | error {
    match e.kind {
        parser::Number as n => type_number(n)
        parser::StrLit as s => type_strlit(s)
        parser::ByteLit as b => type_bytelit(b)
        parser::CharLit as c => type_charlit(c)
        parser::BoolLit as bl => type_boollit(bl)
        parser::NullLit as nl => type_nulllit(nl)
        parser::Var as v => type_var(v, env)
        parser::Binary as b => type_binary(b, env, table)
        parser::Unary as u => type_unary(u, env, table)
        parser::Compare as c => type_compare(c, env, table)
        parser::Call as cl => type_call(cl, env, table)
        parser::IfExpr as f => type_if(f, env, table)
        parser::MatchExpr as m => type_match(m, env, table)
        parser::FieldAccess as fa => type_field_access(fa, env, table)
        parser::SafeFieldAccess as sfa => type_safe_field_access(sfa, e.line, e.col, env, table)
        parser::SafeMethodCall as smc => type_safe_method_call(smc, e.line, e.col, env, table)   // (NP-OOP, issue #116)
        parser::Coalesce as co => type_coalesce(co, env, table)
        parser::Cast as c => type_cast(c, env, table)
        parser::MethodCall as mc => {
            // (C8.3) flags helper methods are typed here; (OOP A1) struct instance methods
            // dispatch to type_method_call; anything else remains deferred. Mirror of expr.c's
            // TK_EXPR_METHOD_CALL case (the receiver is probed once for the flags check, then
            // re-typed inside whichever branch actually handles the call).
            match type_expr(mc.receiver, env, table) {
                TExpr as te => if is_flags_named(te.type, table) { type_flags_method(mc, env, table) } else { type_method_call(mc, env, table) }
                error => type_method_call(mc, env, table)   // let it re-type and surface the real error
            }
        }
        parser::PathExpr as pe => type_path_expr(pe, table, env.cur_ns)   // Enum::Member as a value   (#109 W1) ref_ns = the enclosing namespace
        parser::StructLit as sl => type_struct_lit(sl, Void { }, env, table)   // W4a (no expected type in expr position)
        parser::Index as ix => type_index(ix, env, table)   // W5-idx
        parser::Interp as in => type_interp(in, env, table)   // $"…{expr}…"
        parser::InExpr as n => type_in(n, env, table)   // <expr> in [ … ] (Phase 2)
        parser::ArrayLit as a => type_array_lit(a, env, table)   // [ e0, e1, … ] (Increment B+)
        parser::Lambda as lam => type_lambda(lam, Void { }, env, table)   // (W10) no target here → un-annotated params error (ruling 3); a binding/call-arg threads the target
    }
}

// (C1-POS/E1/E2) public entry — wrap the dispatch to thread the source position. On success, copy
// the untyped node's line/col onto the typed node so later passes (and the renderer) can point at
// it (mirrors the C twin's tk_typer_expr). On failure, stamp THIS expr's position onto the error
// UNLESS it already carries one — the innermost (most specific) expr that set it wins, so `f(g(x))`
// blames the inner `g(x)`/`x`. E2: the error value now carries the position adornments (err_loc +
// the line/col field reads, per the E2 contract), so this half is mirrored — no longer blocked.
fn type_expr(e: parser::Expr, env: Env, table: TypeTable) -> TExpr | error {
    match type_dispatch(e, env, table) {
        TExpr as te => TExpr { kind = te.kind; type = te.type; line = e.line; col = e.col }
        error as inner => {
            if inner.line == 0 { teko::error::err_loc(inner, e.line, e.col) } else { inner }
        }
    }
}

// ---- the value-type a TYPED block yields: the last stmt's, if an ExprStmt; else void ----
fn tblock_type(stmts: []TStatement) -> Type {
    if stmts.len == 0 { return Void { } }
    match stmts[stmts.len - 1] {
        TExprStmt as es => es.expr.type
        _ => Void { }
    }
}

// ---- does a TYPED block DIVERGE (exit via return/break/continue on every path)? ----
// True when its trailing statement is a return/break/continue, OR a trailing `if`-with-else
// / `match` whose every branch / arm diverges. Such a block yields NO trailing value, so
// match-as-value unification (type_match) skips it (B.20).
// A panic/exit call DIVERGES (terminates the program — legislator's ruling: no `never` type), so
// its result may stand in for ANY type at a value position. Recognized structurally (the injected
// global builtins panic/exit, unqualified).
fn texpr_diverges(e: TExpr) -> bool {
    match e.kind {
        TCall as c => c.callee.segments.len == 1 && (c.callee.segments[0].name == "panic" || c.callee.segments[0].name == "exit")
        // a `match` whose EVERY arm diverges, or an `if`/`else` where both branches diverge, yields
        // no value and never falls through — so a function ending in it satisfies any return type.
        TMatchExpr as m => {
            if m.arms.len == 0 { return false }
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                if !tblock_diverges(m.arms[i].body) { return false }
                i++
            }
            true
        }
        TIfExpr as f => f.has_else && tblock_diverges(f.then_blk) && tblock_diverges(f.else_blk)
        _ => false
    }
}

fn tblock_diverges(stmts: []TStatement) -> bool {
    if stmts.len == 0 { return false }
    match stmts[stmts.len - 1] {
        TReturn => true
        TBreakStmt => true
        TContinueStmt => true
        TExprStmt as es => {
            if texpr_diverges(es.expr) { return true }   // a trailing panic/exit call diverges
            match es.expr.kind {
                TIfExpr as f => f.has_else && tblock_diverges(f.then_blk) && tblock_diverges(f.else_blk)
                TMatchExpr as m => {
                    if m.arms.len == 0 { return false }
                    mut i = 0
                    loop {
                        if i >= m.arms.len { break }
                        if !tblock_diverges(m.arms[i].body) { return false }
                        i++
                    }
                    true
                }
                _ => false
            }
        }
        _ => false
    }
}

/**
 * (S2, the 0.1.0.0-beta memory+unsafe remodel #336) does every path through `stmts`, STARTING
 * AT INDEX `from`, either CONSUME the tracked `#must_free` binding `name` or DIVERGE, before
 * falling off the block's end? The DUAL of `tblock_diverges` (which asks "does every path exit
 * before falling off the end?"; this asks "does every path either consume `name` or exit
 * WITHOUT falling off the end unconsumed?"). Consumed = reaches `teko::mem::free(name)` (the
 * exact call `type_mem_free` recognizes, `call_ns == "teko::mem"`), is moved out via `return
 * name`, or is freed inside a `defer { … }` block (`stmt_consumes_must_free` — a `defer` runs
 * LIFO on every normal exit from its enclosing block, so freeing `name` inside one satisfies the
 * rest of the scope exactly as an inline free would; this is arguably THE canonical `#must_free`
 * idiom: `mut h = make(); defer { mem::free(h) }`). This is the first-cut consume set — a
 * follow-up may widen it to a general move-tracking pass, per the design's accepted
 * conservative-over-rejection tax (see the bounds below). A path that DIVERGES
 * (`break`/`continue`/a trailing `panic`/`exit` call) before reaching the block's end never
 * drops the value, so it needs no consume — but a bare `return <something-else>` is NOT treated
 * as divergence here (unlike `tblock_diverges`'s own primitive, which cares only about "does
 * this block yield a trailing value"): a return of anything OTHER than the tracked name abandons
 * the value just as surely as falling off the end does, so it is checked for CONSUMPTION first
 * (`stmt_consumes_must_free`), and only genuinely-diverging statements are exempted. `from` lets
 * a binding declared PARTWAY through a block be checked only over its OWN remaining scope (the
 * statements after its own `TBinding`), never over statements that precede its declaration.
 *
 * HONEST BOUNDS (`docs/design/memory-unsafe-backend-remodel.md` §5a — read it alongside the
 * `mem::free` aliased-UAF note at §5/`type_mem_free`): this is a LOCAL, PER-BINDING dataflow — it
 * has no points-to/uniqueness fact, so it catches only the SILENT-LEAK case (a `#must_free`
 * value dropped on some path). It is powerless against (1) the ALIASED-FREE use-after-free (`y =
 * x; free(x); use(y)`), (2) a `#must_free` binding declared INSIDE a `loop { }` body (never
 * walked — see `stmt_diverges_standalone`'s coverage note), (3) a PARAM consumed any way other
 * than `return name` (a param is immutable, B.21, so `mem::free` never applies to one; consuming
 * it by passing it to a callee needs move-tracking), and (4) reassigning a `mut` local before its
 * PRIOR value was freed (`mut h = make(); h = make()` leaks the first `h`) — all four need the
 * spine's general move/points-to tracking (`#331`), not this local check's.
 *
 * @param []TStatement stmts  the typed statement block to walk (a function body, or an if/match branch)
 * @param u64 from  the index to start walking from (0 for a param; a binding's own index + 1 for a local)
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff every path through `stmts[from..]` either consumes `name` or diverges
 */
fn must_free_consumed_on_all_paths(stmts: []TStatement, from: u64, name: str) -> bool {
    mut i = from
    loop {
        if i >= stmts.len { break }
        if stmt_consumes_must_free(stmts[i], name) { return true }
        if stmt_diverges_standalone(stmts[i]) { return true }
        if stmt_branches_all_consume_must_free(stmts[i], name) { return true }
        i++
    }
    false
}

/**
 * Does this ONE statement, by itself, unconditionally end the enclosing block's control flow
 * WITHOUT abandoning a `#must_free` value (a `break`/`continue`, or a trailing-expression-
 * statement `panic`/`exit` call)? Deliberately does NOT include `TReturn` — a `return` of
 * anything other than the tracked name is a DROP, not an exempting divergence (the caller
 * checks `stmt_consumes_must_free` first, which recognizes the ONE `return`-shape that IS a
 * legal consume: `return name` itself). A plain `if`/`match` embedded in a `TExprStmt` is
 * handled separately by `stmt_branches_all_consume_must_free` (it may consume on every branch
 * without ITSELF being a `tblock_diverges`-style divergence), so this predicate deliberately
 * does NOT recurse into one.
 *
 * COVERAGE NOTE: the `TBreakStmt`/`TContinueStmt` arms are genuinely unreachable from the
 * current call graph — `must_free_consumed_on_all_paths` never recurses into a `TLoopStmt`'s
 * body (a documented first-cut bound: a `#must_free` binding declared INSIDE a `loop { }` is not
 * checked at all today — see `docs/design/memory-unsafe-backend-remodel.md` §5a), so a
 * `break`/`continue` can never actually reach this function today. They are included for
 * FORWARD COMPATIBILITY (a future loop-body-aware widening would need them immediately) and
 * because they are the semantically-correct answer, not dead weight.
 *
 * @param TStatement s  the typed statement to test
 * @return bool  true iff this statement alone diverges (never falls through) without a `return`
 */
fn stmt_diverges_standalone(s: TStatement) -> bool {
    match s {
        TBreakStmt => true
        TContinueStmt => true
        TExprStmt as es => texpr_diverges(es.expr)
        _ => false
    }
}

/**
 * Does this ONE statement itself CONSUME the tracked `#must_free` binding `name` — a
 * `teko::mem::free(name)` call (a bare expression-statement), `return name` (a `TReturn` whose
 * value is exactly the tracked variable), or a `defer { … }` block whose body frees `name`
 * (`defer_frees`)? A `defer` runs LIFO on EVERY normal exit from its enclosing block (the
 * per-scope cleanup idiom — this is arguably THE canonical `#must_free` pattern: `mut h =
 * make(); defer { mem::free(h) }`), so once such a defer is seen, `name` is satisfied for the
 * rest of that scope exactly as if it had been freed on the spot — a later explicit
 * `mem::free(name)` would in fact double-free, but that is the EXISTING `mem::free` immutable-
 * binding-scrub story (out of this dataflow's scope), not a new gap this consume introduces.
 *
 * @param TStatement s  the typed statement to test
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff this statement consumes `name`
 */
fn stmt_consumes_must_free(s: TStatement, name: str) -> bool {
    match s {
        TReturn as r => r.has_value && texpr_is_must_free_var(r.value, name)
        TExprStmt as es => texpr_is_mem_free_call(es.expr, name)
        TDeferStmt as d => defer_frees(d.body, name)
        _ => false
    }
}

/**
 * Does a `defer { … }` block's body contain a `teko::mem::free(name)` call — anywhere among its
 * (flat, non-nested — nested `defer` is checker-rejected) statements? A defer body is typed in
 * void context as a plain statement list, so this is a direct scan (no branch/divergence
 * reasoning needed — the defer body always runs to completion once entered).
 *
 * @param []TStatement body  the defer block's typed statements
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff any statement in `body` is `teko::mem::free(name)`
 */
fn defer_frees(body: []TStatement, name: str) -> bool {
    mut i = 0
    loop {
        if i >= body.len { break }
        match body[i] { TExprStmt as es => { if texpr_is_mem_free_call(es.expr, name) { return true } }; _ => { } }
        i++
    }
    false
}

/**
 * Is `e` exactly a bare read of the tracked variable `name` (the first-cut MOVE consume, per the
 * design's "return x" consume set — also reused to match `mem::free`'s own single argument)?
 *
 * @param TExpr e  the typed expression to test
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff `e` is the bare variable `name`
 */
fn texpr_is_must_free_var(e: TExpr, name: str) -> bool {
    match e.kind { TVar as v => v.name == name; _ => false }
}

/**
 * Is `e` exactly the call `teko::mem::free(name)` — the one FREE consume this dataflow
 * recognizes, matching `type_mem_free`'s own dispatch (`call_ns == "teko::mem"`, one argument,
 * that argument a bare read of the tracked variable)?
 *
 * @param TExpr e  the typed expression to test
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff `e` is `teko::mem::free(name)`
 */
fn texpr_is_mem_free_call(e: TExpr, name: str) -> bool {
    match e.kind {
        TCall as c => {
            if c.call_ns != "teko::mem" { return false }
            if c.args.len != 1 { return false }
            texpr_is_must_free_var(c.args[0], name)
        }
        _ => false
    }
}

/**
 * Does this ONE statement embed a value-position `if`/`match` whose EVERY branch/arm either
 * diverges or consumes `name` (recursively, via `must_free_consumed_on_all_paths`) — the
 * split-control-flow case (acceptance criterion 3: "both arms of an `if` / all arms of a
 * `match`"). Only a trailing `TExprStmt` can carry a value-position `if`/`match` (B.20); any
 * other statement shape cannot branch, so it is not this case.
 *
 * @param TStatement s  the typed statement to test
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff `s` is an if/match whose every path consumes `name` (or diverges)
 */
fn stmt_branches_all_consume_must_free(s: TStatement, name: str) -> bool {
    match s {
        TExprStmt as es => match es.expr.kind {
            TIfExpr as f => f.has_else && must_free_consumed_on_all_paths(f.then_blk, 0, name) && must_free_consumed_on_all_paths(f.else_blk, 0, name)
            TMatchExpr as m => match_arms_all_consume_must_free(m, name)
            _ => false
        }
        _ => false
    }
}

/**
 * Does EVERY arm of `m` either diverge or consume `name`? An exhaustive `match` with zero arms
 * cannot occur (parser rejects an empty match), but the empty case is handled defensively as
 * "not consumed" (vacuously false) rather than assumed unreachable.
 *
 * @param TMatchExpr m  the typed match expression
 * @param str name  the tracked `#must_free` binding/param's name
 * @return bool  true iff every arm consumes `name` (or diverges)
 */
fn match_arms_all_consume_must_free(m: TMatchExpr, name: str) -> bool {
    if m.arms.len == 0 { return false }
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        if !must_free_consumed_on_all_paths(m.arms[i].body, 0, name) { return false }
        i++
    }
    true
}

/**
 * Check every `#must_free`-typed PARAMETER of `f` against the whole (typed) body — a param whose
 * resolved nominal type (`Named`) names a `TypeDecl` carrying `must_free = true`
 * (`is_must_free_name`). Params carry no source position of their own (`parser::Param` has
 * none), so a rejection blames the function's own `line`/`col` (the existing W-loc-2 fallback
 * `type_item` already applies to any error a checker pass leaves unpositioned). Returns the
 * FIRST dropped-path error found (fail-fast, mirrors every other checker pass).
 *
 * COVERAGE NOTE: `resolve_type`'s `error` arm here is genuinely unreachable in practice — by the
 * time `type_function` calls this (after `type_block`), it has ALREADY resolved every param's
 * type earlier in its own param-typing loop and returned on the first failure, so every param
 * type is already known-good; the re-resolution here can never itself fail.
 *
 * @param parser::Function f  the parsed function (its untyped params, walked in declaration order)
 * @param TypeTable tbl  the fn's type table (extended with its own generic type-params)
 * @param str ns  the fn's enclosing namespace (param types resolve against it, #109 W1)
 * @param []TStatement body  the fn's typed body
 * @return error?  an error naming the first dropped `#must_free` param, or nothing
 */
fn check_must_free_params(f: parser::Function, tbl: TypeTable, ns: str, body: []TStatement) -> error? {
    mut i = 0
    loop {
        if i >= f.params.len { break }
        if !f.params[i].has_type && f.params[i].name == "_" { i++; continue }
        let pt = match resolve_type(f.params[i].type_ann, tbl, ns) { Type as t => t; error as e => return e }
        match pt {
            Named as nm => {
                if is_must_free_name(nm.name, tbl) {
                    if !must_free_consumed_on_all_paths(body, 0, f.params[i].name) {
                        return teko::error::err_loc(error { message = must_free_dropped_message(f.params[i].name) }, f.line, f.col)
                    }
                }
            }
            _ => { }
        }
        i++
    }
    null
}

/**
 * The diagnostic for a dropped `#must_free` handle (S2 #336) — shared by the param check and the
 * local-binding check so both name the same contract in the same words.
 *
 * @param str name  the dropped handle's binding/param name
 * @return str  the rendered message
 */
fn must_free_dropped_message(name: str) -> str {
    $"`#must_free` value `{name}` is dropped without being freed on this path — call `teko::mem::free({name})` or move it out"
}

/**
 * Check every `#must_free`-typed LOCAL BINDING (`let`/`mut`/`const` simple-name target) declared
 * in `stmts` — a binding whose bound type (`TBinding.bound`) is a `Named` naming a `must_free`
 * `TypeDecl`. Each is checked over its OWN remaining scope: the statements strictly AFTER its own
 * declaration in the SAME block (`must_free_consumed_on_all_paths(stmts, i + 1, name)`), which is
 * exactly where a read of it can occur (the structural definite-assignment guarantee —
 * `initanalysis.tks` relies on the same fact for its unused-local check). Recurses into a value-
 * position `if`/`match`'s branch blocks (a binding declared inside one is scoped to that branch).
 * Returns the FIRST dropped-path error found (fail-fast, mirrors every other checker pass).
 *
 * @param []TStatement stmts  the typed statement block to walk
 * @param TypeTable table  the type table (kind probes for each binding's bound type)
 * @return error?  an error naming the first dropped `#must_free` local, or nothing
 */
fn check_must_free_locals(stmts: []TStatement, table: TypeTable) -> error? {
    mut i: u64 = 0
    loop {
        if i >= stmts.len { break }
        match check_must_free_locals_stmt(stmts[i], stmts, i, table) { null => { }; error as e => return e }
        i++
    }
    null
}

/**
 * The single-statement step of `check_must_free_locals`: if `stmts[i]` is a `#must_free`
 * binding, check its own remaining scope; if it carries nested branch blocks (`if`/`match`),
 * recurse into each. A `DestructurePattern` target is not tracked (mirrors
 * `initanalysis.tks`'s unused-local check — `type_binding` never defines destructure names,
 * so there is nothing to bind against here either).
 *
 * @param TStatement s  the statement at index `i`
 * @param []TStatement stmts  the enclosing block (so a binding's remaining scope can be re-walked)
 * @param u64 i  `s`'s own index in `stmts`
 * @param TypeTable table  the type table (kind probes for a binding's bound type)
 * @return error?  an error naming the first dropped `#must_free` local, or nothing
 */
fn check_must_free_locals_stmt(s: TStatement, stmts: []TStatement, i: u64, table: TypeTable) -> error? {
    match s {
        TBinding as b => match b.target {
            parser::SimpleName as sn => match b.bound {
                Named as nm => {
                    if is_must_free_name(nm.name, table) && !must_free_consumed_on_all_paths(stmts, i + 1, sn.name) {
                        return teko::error::err_loc(error { message = must_free_dropped_message(sn.name) }, b.value.line, b.value.col)
                    }
                    null
                }
                _ => null
            }
            parser::DestructurePattern => null
        }
        TExprStmt as es => check_must_free_locals_expr(es.expr, table)
        _ => null
    }
}

/**
 * Recurse `check_must_free_locals` into a value-position `if`/`match`'s branch blocks (a plain
 * non-branching expression carries none).
 *
 * @param TExpr e  the typed expression to inspect
 * @param TypeTable table  the type table (kind probes for each binding's bound type)
 * @return error?  an error naming the first dropped `#must_free` local inside `e`'s branches, or nothing
 */
fn check_must_free_locals_expr(e: TExpr, table: TypeTable) -> error? {
    match e.kind {
        TIfExpr as f => {
            match check_must_free_locals(f.then_blk, table) { null => { }; error as er => return er }
            if f.has_else { return check_must_free_locals(f.else_blk, table) }
            null
        }
        TMatchExpr as m => {
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                match check_must_free_locals(m.arms[i].body, table) { null => { }; error as er => return er }
                i++
            }
            null
        }
        _ => null
    }
}

/**
 * Run the consume-or-fail dataflow over every `#must_free`-tracked binding/param in a function
 * (S2, the 0.1.0.0-beta memory+unsafe remodel #336): each must be consumed
 * (`must_free_consumed_on_all_paths`) on every path reachable from its own declaration point —
 * params from the whole body, locals from their own declaring block onward. Returns the FIRST
 * dropped-path error found (fail-fast, mirrors every other checker pass).
 *
 * HONEST BOUNDS: see `must_free_consumed_on_all_paths`'s doc-comment and
 * `docs/design/memory-unsafe-backend-remodel.md` §5a — this pass does not walk loop bodies, does
 * not track a param consumed any way other than `return`, does not track a `mut` local
 * reassigned before its prior value was freed, and `#must_free` itself is not yet serialized in
 * the `.tkb` codec (module-local today).
 *
 * @param parser::Function f  the parsed function (for param collection + the position fallback)
 * @param TypeTable tbl  the fn's type table (extended with its own generic type-params)
 * @param str ns  the fn's enclosing namespace (param type resolution, #109 W1)
 * @param []TStatement body  the fn's typed body
 * @param TypeTable table  the outer type table (kind probes)
 * @return error?  an error naming the first dropped `#must_free` handle, or nothing
 */
fn check_must_free(f: parser::Function, tbl: TypeTable, ns: str, body: []TStatement, table: TypeTable) -> error? {
    match check_must_free_params(f, tbl, ns, body) { null => { }; error as e => return e }
    check_must_free_locals(body, table)
}

// ---- a typed block: thread the env, collect the typed statements ----
fn type_block(stmts: []parser::Statement, env: Env, table: TypeTable) -> TypedBlock | error {
    mut cur = env
    // (#148 R3 DECREE) `out` is a linear chain: born empty, self-append-only, read only after the
    // loop — so every copy-grow frees the superseded buffer (mem::push_fo; paranoid-gated).
    mut out: []TStatement = teko::list::empty()
    mut i = 0
    loop {
        if i >= stmts.len { break }
        // W5a — a block's TRAILING `if`-with-`else` / `match` is its VALUE (B.20): type it via
        // the VALUE form (type_expr → type_if/type_match) so the block yields the branch type.
        // A trailing `if` WITHOUT `else` can't be a value → stays a statement; `match` is
        // exhaustive so it always yields. Non-tail if/match → statement (value discarded).
        mut handled = false
        if i + 1 == stmts.len {
            match stmts[i] {
                ExprStmt as es => {
                    match es.expr.kind {
                        IfExpr as f => {
                            if f.has_else {
                                let te = match type_expr(es.expr, cur, table) { TExpr as x => x; error as e => return e }
                                out = teko::mem::push_fo(out, TExprStmt { expr = te })
                                handled = true
                            }
                        }
                        MatchExpr => {
                            let te = match type_expr(es.expr, cur, table) { TExpr as x => x; error as e => return e }
                            out = teko::mem::push_fo(out, TExprStmt { expr = te })
                            handled = true
                        }
                        _ => { }
                    }
                }
                _ => { }
            }
        }
        if !handled {
            let ts = match type_statement(stmts[i], cur, table) { TypedStmt as t => t; error as e => return e }
            out = teko::mem::push_fo(out, ts.node)
            cur = ts.env
        }
        i++
    }
    TypedBlock { stmts = out; env = cur }
}

// ---- if as a VALUE (B.20): cond bool; `else` required; both branches one type ----
fn type_if(f: parser::IfExpr, env: Env, table: TypeTable) -> TExpr | error {
    let c = match type_expr(f.cond, env, table) { TExpr as te => te; error as e => return e }
    if !is_bool(c.type) { return error { message = "an `if` condition must be a bool" } }
    if !f.has_else { return error { message = "an `if` used as a value needs an `else`" } }
    let tb = match type_block(f.then_blk, env, table) { TypedBlock as bk => bk; error as e => return e }
    let eb = match type_block(f.else_blk, env, table) { TypedBlock as bk => bk; error as e => return e }
    mut tt = tblock_type(tb.stmts)
    mut et = tblock_type(eb.stmts)
    // literal cross-adoption (mirrors expr.c type_if): a numeric-literal branch adopts the OTHER
    // branch's numeric type, so `if c { u32_expr } else { 64 }` is u32, not the union u32 | i64.
    let tl = trailing_number(tb.stmts)
    let el = trailing_number(eb.stmts)
    let then_adopts = match tl { TExpr as t => literal_adopts(t, et); null => false }
    if then_adopts { tt = et }
    else {
        let else_adopts = match el { TExpr as t => literal_adopts(t, tt); null => false }
        if else_adopts { et = tt }
    }
    let joined = type_join(tt, et, table)   // widen (a case joins into its variant; siblings → their union)
    TExpr { kind = TIfExpr { cond = c; then_blk = tb.stmts; has_else = true; else_blk = eb.stmts }; type = joined; line = 0; col = 0 }
}

// ---- if as a STATEMENT: cond bool; branches validated; no `else`; value discarded → void ----
fn type_if_stmt(f: parser::IfExpr, env: Env, table: TypeTable) -> TExpr | error {
    let c = match type_expr(f.cond, env, table) { TExpr as te => te; error as e => return e }
    if !is_bool(c.type) { return error { message = "an `if` condition must be a bool" } }
    let tb = match type_block(f.then_blk, env, table) { TypedBlock as bk => bk; error as e => return e }
    if f.has_else {
        let eb = match type_block(f.else_blk, env, table) { TypedBlock as bk => bk; error as e => return e }
        return TExpr { kind = TIfExpr { cond = c; then_blk = tb.stmts; has_else = true; else_blk = eb.stmts }; type = Void { }; line = 0; col = 0 }
    }
    TExpr { kind = TIfExpr { cond = c; then_blk = tb.stmts; has_else = false; else_blk = tb.stmts }; type = Void { }; line = 0; col = 0 }   // else_blk gated by has_else
}

// ---- one typed arm: pattern extends env; `when` guard bool; body BLOCK typed in that env ----
// The arm body is a STATEMENT BLOCK, typed exactly like an `if` then/else branch (B.20). Its
// value type is the block's trailing-value type (tblock_type), unless the block diverges.
fn type_arm(a: parser::Arm, subject: Type, env: Env, table: TypeTable) -> TArm | error {
    let e2 = match check_pattern(a.pattern, subject, env, table) { Env as e => e; error as err => return err }
    let body = match type_block(a.body, e2, table) { TypedBlock as bk => bk; error as err => return err }
    mut guard = TExpr { kind = TNumber { is_float = false; value = 0; fval = 0.0 }; type = Void { }; line = 0; col = 0 }   // placeholder, gated by has_when (never read when absent)
    if a.has_when {
        let g = match type_expr(a.guard, e2, table) { TExpr as te => te; error as err => return err }
        if !is_bool(g.type) { return error { message = "a `when` guard must be a bool" } }
        guard = g
    }
    TArm { pattern = a.pattern; has_when = a.has_when; guard = guard; body = body.stmts }
}

// ---- match as a VALUE: the common trailing-value type of the NON-diverging arms; EXHAUSTIVE (B.15) ----
// A diverging arm (`error as e => return e`) yields no value, so it is SKIPPED in unification
// (B.20). If ALL arms diverge the match type is void.
fn type_match(m: parser::MatchExpr, env: Env, table: TypeTable) -> TExpr | error {
    let s = match type_expr(m.subject, env, table) { TExpr as te => te; error as e => return e }
    if m.arms.len == 0 { return error { message = "a `match` needs at least one arm" } }
    mut arms: []TArm = teko::list::empty()
    mut have_type = false
    mut first: Type = Void { }   // Type-typed (so a case arm widens in); placeholder until first non-diverging arm
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        let ai = match type_match_arm(m.arms[i], s.type, env, table) { TArm as a => a; error as e => return e }
        arms = teko::list::push(arms, ai)
        if !tblock_diverges(ai.body) {
            let t = tblock_type(ai.body)
            if !have_type { first = t; have_type = true }
            else { first = type_join(first, t, table) }   // widen (a case joins into its variant; siblings → their union)
        }
        i++
    }
    let rarms = match resolve_foreach_placeholders(m.arms, s.type) { []parser::Arm as a => a; error as e => return e }
    if !exhaustive(rarms, s.type, table, env.cur_ns) { return error { message = "non-exhaustive `match` (cover all cases or add `_`)" } }
    let result = if have_type { first } else { Void { } }   // all arms diverge → void
    TExpr { kind = TMatchExpr { subject = s; arms = arms }; type = result; line = 0; col = 0 }
}

// ---- match as a STATEMENT: validate the arms; exhaustiveness forced; value discarded → void ----
fn type_match_stmt(m: parser::MatchExpr, env: Env, table: TypeTable) -> TExpr | error {
    let s = match type_expr(m.subject, env, table) { TExpr as te => te; error as e => return e }
    mut arms: []TArm = teko::list::empty()
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        let ai = match type_match_arm(m.arms[i], s.type, env, table) { TArm as a => a; error as e => return e }
        arms = teko::list::push(arms, ai)
        i++
    }
    let rarms = match resolve_foreach_placeholders(m.arms, s.type) { []parser::Arm as a => a; error as e => return e }
    if !exhaustive(rarms, s.type, table, env.cur_ns) { return error { message = "non-exhaustive `match` (cover all cases or add `_`)" } }
    TExpr { kind = TMatchExpr { subject = s; arms = arms }; type = Void { }; line = 0; col = 0 }
}

// ---- statements (the evolved check_* — produce the typed node + advance the env) ----

// Type an expression flowing into a known EXPECTED type: a struct-literal is given that type so a
// generic constructor `Box { … }` targets the concrete instance; anything else types normally. Used
// at the binding level AND for struct-literal field values, so NESTED `Box { value = Box { … } }`
// threads the expected type all the way down (S4 annotation-driven).
fn type_value_expected(e: parser::Expr, expected: Type, env: Env, table: TypeTable) -> TExpr | error {
    match e.kind {
        parser::StructLit as sl => type_struct_lit(sl, expected, env, table)
        parser::Lambda as lam => type_lambda(lam, expected, env, table)   // (W10) target type → un-annotated closure params infer (ruling 3)
        parser::ArrayLit as al => {
            if is_iface_slice(expected, table) { return type_array_lit_expected(al, expected, env, table) }   // (W10b.D3) []<interface> literal
            type_expr(e, env, table)
        }
        _ => type_expr(e, env, table)
    }
}

/**
 * (W10b.D3 / TR1) Is `t` a slice whose element is a NAMED contract — an interface OR a trait? The
 * gate for the heterogeneous-array expected path below (`[]Renderable = [label, button]`).
 *
 * @param t     the candidate slice type
 * @param table the folded type table
 * @return true iff `t` is `[]Contract` for an interface or trait element
 */
fn is_iface_slice(t: Type, table: TypeTable) -> bool {
    match t {
        Slice as s => match s.element {
            Named as n => is_interface_name(n.name, table) || is_trait_name(n.name, table)
            _ => false
        }
        _ => false
    }
}

// (W10b.D3) an ARRAY literal flowing into a `[]<interface>` slot: type each element AGAINST the
// contract element (so `[circle, square]` under `[]Shape` never joins to an inline class union
// the emitters cannot re-tag). Each element keeps its NARROW class type (emit_as builds the fat
// pointer per slot); the array's own type adopts the expected `[]<interface>`. A spread element
// contributes a whole `[]U` — U must widen into the contract element (its value covariant-
// rebuilds element-wise instead). Mirror of expr.c::type_array_lit_expected.
fn type_array_lit_expected(a: parser::ArrayLit, expected: Type, env: Env, table: TypeTable) -> TExpr | error {
    let elem = match expected { Slice as s => s.element; _ => return error { message = "internal: type_array_lit_expected needs a slice expected type" } }
    mut elems: []TArrayElem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= a.elements.len { break }
        let e = match type_expr(a.elements[i].expr, env, table) { TExpr as te => te; error as err2 => return err2 }
        if a.elements[i].is_spread {
            let selem = match e.type {
                Slice as fs => fs.element
                _ => return error { message = "a spread element (`..xs`) must be a slice (`[]T`)" }
            }
            let selem_is_void = match selem { Void => true; _ => false }
            if selem_is_void { return error { message = "a spread element (`..xs`) must be a slice (`[]T`)" } }
            if !assignable_to(selem, elem, table) {
                return teko::error::err_typed(error { message = "array element type mismatch" }, type_render(elem), type_render(selem))
            }
        } else {
            if type_is_void(e.type) { return error { message = "a `void` expression cannot be an array element (M.1)" } }
            if !assignable_to(e.type, elem, table) {
                return teko::error::err_typed(error { message = "array element type mismatch" }, type_render(elem), type_render(e.type))
            }
        }
        elems = teko::list::push(elems, TArrayElem { is_spread = a.elements[i].is_spread; expr = e })   // keep the NARROW type — the emit wraps per slot
        i++
    }
    TExpr { kind = TArrayLit { elements = elems }; type = expected; line = 0; col = 0 }
}

// Type a binding's value with the annotation as its expected type (so a generic constructor targets
// the concrete instance from `: Box<i64>`).
fn type_binding_value(b: parser::Binding, env: Env, table: TypeTable) -> TExpr | error {
    if b.has_type {
        let at = match resolve_type(b.type_ann, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the binding's enclosing namespace
        return type_value_expected(b.value, at, env, table)
    }
    type_expr(b.value, env, table)
}

/**
 * Type-checks a `let`/`mut`/`const` binding statement, producing its typed `TBinding` node and
 * the environment extended with the newly bound name (a `SimpleName` target; a
 * `DestructurePattern` target is left as a refinement — the environment is returned unchanged).
 *
 * @param parser::Binding b  the parsed binding (target, optional annotation, initializer)
 * @param Env env  the typing environment (read for `env.fn_unsafe`, U2's local-containment gate)
 * @param TypeTable table  the program's type table
 * @return TypedStmt | error  the typed statement plus the environment with the new binding defined
 *               collection, a reference is bound to a local (R5), or (U2, §2 line 84) a SAFE
 *               fn body binds a local of unsafe type (not as a param, return, field, OR local) —
 *               `env.fn_unsafe` was set once by `type_function`/`type_method` before this body's
 *               statements were typed
 */
fn type_binding(b: parser::Binding, env: Env, table: TypeTable) -> TypedStmt | error {
    mut v = match type_binding_value(b, env, table) { TExpr as te => te; error as e => return e }
    mut bound = v.type
    if type_is_void(bound) { return error { message = "cannot bind a `void` expression — it yields no value (M.1)" } }
    if b.has_type {
        let at = match resolve_type(b.type_ann, table, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the binding's enclosing namespace
        if !assignable_to(v.type, at, table) {   // B.14 widening (case → variant) OR C6: a fitting literal adopts T (leaf stays i64)
            // (C1.8/E2) wrap with expected=type_render(at), actual=type_render(v.type) — mirrors
            // typer.c type_binding's tk_error_types wrap of annotated_literal_reason's message.
            match annotated_literal_ok(b.value, at) {
                null => {
                    // a fitting bare-literal (plain-scalar) initializer ADOPTS the declared narrow
                    // type — retype the leaf itself (same mechanism as the arg/struct-field/negative-
                    // literal adoption sites), so codegen/VM see the narrow width (`mut y: u8 = 1`
                    // stores/shifts at width 8, not the literal's native i64). Mirrors typer.c.
                    // (#71) retype_literal RECURSES into an array literal's elements (`[]u8 = [1,2,3]`
                    // narrows each leaf, not just the array's own type) — a plain leaf still takes
                    // the annotation wholesale, unchanged from before.
                    v = retype_literal(v, at)
                }
                error as e => return teko::error::err_typed(e, type_render(at), type_render(v.type))
            }
        }
        bound = at
        // (#4) annotation-directed element type: a sentinel empty list/array (`teko::list::empty()`
        // / `[]`) ADOPTS the annotation's concrete slice type, so codegen sees the element WITHOUT
        // back-inference. Mirrors type_assign's target-adopt and emit_as's wrap.
        let v_is_sentinel_slice = match v.type { Slice as vs => match vs.element { Void => true; _ => false }; _ => false }
        let bound_is_concrete_slice = match bound { Slice as bs => match bs.element { Void => false; _ => true }; _ => false }
        if v_is_sentinel_slice {
            if bound_is_concrete_slice {
                v = TExpr { kind = v.kind; type = bound; line = v.line; col = v.col }
            }
        }
    }
    // (#4) REJECT an untyped empty collection. The element type MUST be fixed at the declaration —
    // by the binding annotation (`: []T`) or by typed initial elements (a non-empty literal / a
    // push that fixes the element). A bare `empty()`/`[]` whose element is still the sentinel is an
    // error: no silent element-less slice, no codegen back-inference (collections ruling #4).
    let bound_is_sentinel_slice = match bound { Slice as bs2 => match bs2.element { Void => true; _ => false }; _ => false }
    if bound_is_sentinel_slice {
        return error { message = "an empty list needs a known element type; annotate the binding (e.g. `mut xs: []i32 = teko::list::empty()`)" }
    }
    match bound {
        Reference => { }
        _ => if type_contains_ref(bound) { return error { message = "a reference cannot be bound to a local (parameter-only in this version)" } }
    }
    if !env.fn_unsafe && unsafe_carrying(bound, table) {
        return error { message = "safe fn binds a local of unsafe type — mark the enclosing fn `unsafe fn` or bind only safe types (§2: unsafe data cannot be held by a safe local)" }
    }
    let node = TBinding { kind = b.kind; target = b.target; bound = bound; value = v }
    match b.target {
        parser::SimpleName as sn => TypedStmt { node = node; env = define(env, sn.name, bound, bind_is_mut(b.kind)) }
        parser::DestructurePattern => TypedStmt { node = node; env = env }   // [destructuring binding: refinement]
    }
}

// (#88) the ROOT variable of a field-access lvalue chain (`a.b.c` → `a`). `reachable` is true when the
// whole chain roots at a plain variable (not an index / call / literal), so it has a binding to check
// for mutability. Mirrors typer.c::lvalue_root.
type LvalueRoot = struct { reachable: bool; name: str }
fn lvalue_root(e: parser::Expr) -> LvalueRoot {
    match e.kind {
        parser::Var as v => LvalueRoot { reachable = true; name = v.name }
        parser::FieldAccess as fa => lvalue_root(fa.receiver)
        _ => LvalueRoot { reachable = false; name = "" }
    }
}

// (#88) a FIELD-target assignment `recv.field op= value`. The parser routes EVERY `recv.field = …` here;
// this branch decides Ref-deref (`r.value` on a `Ref<T>` — the legacy MEM-1b-ii path, preserved) vs a
// struct/class field WRITE, enforcing write-visibility == read-visibility (the RULING). Mirrors
// typer.c::type_field_assign.
fn type_field_assign(a: parser::Assign, env: Env, table: TypeTable) -> TypedStmt | error {
    // Type the LHS field-access EXPR — this resolves the receiver + field type AND enforces read-side
    // visibility (a private class field written externally is rejected here with the SAME "field is
    // private to its declaring class" diagnostic a read raises — write-permission == read-permission).
    let lhs = match type_expr(a.target, env, table) { TExpr as te => te; error as e => return e }
    let lhs_fa = match a.target.kind { parser::FieldAccess as fa => fa; _ => return error { message = "assignment target is not a field access (internal: parser guarantees a field LHS)" } }
    let recv = match type_expr(lhs_fa.receiver, env, table) { TExpr as te => te; error as e => return e }
    let field_t = lhs.type

    // (MEM-1b-ii, preserved) `r.value op= x` on a `Ref<T>` — write THROUGH the reference. Detected from
    // the RECEIVER TYPE: a `Ref<T>` receiver + field `value`. Emit the SAME deref-shaped TAssign
    // (kind=RefDeref, name=the ref handle) the old parser produced, so downstream / the TKB layout stay
    // byte-identical for existing Ref writes.
    let ref_inner = match recv.type { Reference as rf => rf.inner; _ => Void { } }
    let is_ref_deref = match recv.type { Reference => (lhs_fa.field == "value"); _ => false }
    if is_ref_deref {
        let ref_name = match lhs_fa.receiver.kind { parser::Var as v => v.name; _ => return error { message = "`.value` deref-assignment requires a bare `Ref<T>` handle on the left" } }
        mut dv = match type_expr(a.value, env, table) { TExpr as te => te; error as e => return e }
        if !assignable_to(dv.type, ref_inner, table) {
            if !literal_adopts(dv, ref_inner) { return teko::error::err_typed(error { message = "assigned value does not match the referenced type" }, type_render(ref_inner), type_render(dv.type)) }
            dv = TExpr { kind = dv.kind; type = ref_inner; line = dv.line; col = dv.col }
        }
        return TypedStmt { node = TAssign { kind = parser::AssignKind::RefDeref; name = ref_name; op = a.op; bound = ref_inner; value = dv; deref = true; target = no_texpr() }; env = env }
    }

    // A struct/class FIELD write. Structs are VALUE types → the receiver must be a MUTABLE lvalue (its
    // root variable a `mut` binding — the RULING). Classes are REFERENCE types (the value is a pointer;
    // mutation flows through it — like a `Ref<T>`), so the handle need not be `mut`.
    let recv_is_class = match recv.type { Named as nm => match find_class_body(nm.name, table) { parser::ClassBody => true; error => false }; _ => false }
    if !recv_is_class {
        let root = lvalue_root(lhs_fa.receiver)
        if !root.reachable { return error { message = "cannot assign to a field of a temporary value — the receiver is not a mutable variable" } }
        let rb = match lookup_binding(env, root.name) { ValBinding as vb => vb; error as e => return e }
        if !rb.is_mut { return error { message = "cannot assign to a field of an immutable binding — declare it `mut` (B.21)" } }
    }

    // Type-check the RHS against the FIELD type (same widen/adopt rule as a simple assign / binding).
    mut v = match type_expr(a.value, env, table) { TExpr as te => te; error as e => return e }
    if type_contains_ref(field_t) || type_contains_ref(v.type) { return error { message = "a reference cannot be stored in a field (parameter-only in this version)" } }
    if !assignable_to(v.type, field_t, table) {
        if !literal_adopts(v, field_t) { return teko::error::err_typed(error { message = "assigned value does not match the field type" }, type_render(field_t), type_render(v.type)) }
        v = retype_literal(v, field_t)
    }
    let v_is_sentinel_slice = match v.type { Slice as vs => match vs.element { Void => true; _ => false }; _ => false }
    let field_is_concrete_slice = match field_t { Slice as bs => match bs.element { Void => false; _ => true }; _ => false }
    if v_is_sentinel_slice {
        if field_is_concrete_slice {
            v = TExpr { kind = v.kind; type = field_t; line = v.line; col = v.col }
        }
    }
    TypedStmt { node = TAssign { kind = parser::AssignKind::Field; name = ""; op = a.op; bound = field_t; value = v; deref = false; target = lhs }; env = env }
}

fn type_assign(a: parser::Assign, env: Env, table: TypeTable) -> TypedStmt | error {
    // (#88) a FIELD target (`recv.field = …`) — Ref-deref vs struct/class field write, decided by the
    // receiver TYPE (type_field_assign). The simple-name path below is unchanged.
    let is_field = match a.kind { parser::AssignKind::Field => true; _ => false }
    if is_field { return type_field_assign(a, env, table) }
    let tb = match lookup_binding(env, a.name) { ValBinding as vb => vb; error as e => return e }
    // (MEM-1b-ii) `r.value op= x` — write THROUGH a reference. The handle `r` need NOT be `mut`
    // (a `Ref<T>` is a const handle that grants WRITE to its mutable target — R2 mutable-target).
    // The assigned-to type is the ref's inner T; the value must widen/adopt into T.
    if a.deref {
        let inner = match tb.type {
            Reference as rf => rf.inner
            _ => return error { message = $"`{a.name}.value` requires a reference (`Ref<T>`) — `{a.name}` is not a reference" }
        }
        mut dv = match type_expr(a.value, env, table) { TExpr as te => te; error as e => return e }
        if !assignable_to(dv.type, inner, table) {
            if !literal_adopts(dv, inner) { return teko::error::err_typed(error { message = "assigned value does not match the referenced type" }, type_render(inner), type_render(dv.type)) }
            dv = TExpr { kind = dv.kind; type = inner; line = dv.line; col = dv.col }   // a fitting literal adopts T
        }
        return TypedStmt { node = TAssign { kind = parser::AssignKind::RefDeref; name = a.name; op = a.op; bound = inner; value = dv; deref = true; target = no_texpr() }; env = env }
    }
    if !tb.is_mut { return error { message = $"cannot assign to immutable `{a.name}` — declare it `mut` (B.21)" } }
    mut v = match type_expr(a.value, env, table) { TExpr as te => te; error as e => return e }
    let both_bare_ref = (match tb.type { Reference => true; _ => false }) && (match v.type { Reference => true; _ => false })
    if !both_bare_ref {
        if type_contains_ref(tb.type) || type_contains_ref(v.type) { return error { message = "a reference cannot be bound to a local (parameter-only in this version)" } }
    }
    // The value must WIDEN into the target's type (B.14 case→variant, T→T?) OR be a fitting literal
    // that adopts it (C6) — same rule as an annotated binding (the single source of truth).
    if !assignable_to(v.type, tb.type, table) {
        // (C1.8/E2) attach expected=type_render(tb.type), actual=type_render(v.type) — mirrors
        // typer.c type_assign's tk_error_types wrap.
        if !literal_adopts(v, tb.type) { return teko::error::err_typed(error { message = "assigned value does not match the target type" }, type_render(tb.type), type_render(v.type)) }
        // a fitting bare-literal (plain-scalar) RHS ADOPTS the target's narrow type — retype the leaf
        // itself (mirrors type_binding's identical adoption above), so a plain `y = 200` on a `u8`
        // slot stores/re-widths at 8 bits, not the literal's native i64.
        // (#71) retype_literal recurses into an array literal's elements — see type_binding.
        v = retype_literal(v, tb.type)
    }
    // (#4) a sentinel empty list/array ADOPTS the target's concrete slice type so codegen sees the
    // element. OTHERWISE keep the value's NATURAL (case / T) type and store the target as `bound` —
    // codegen's emit_as wraps the value into the target at the assign site (case→variant, T→T?, a
    // fitting literal). Mirrors type_binding (clobbering the case type made `node = OptionalType{…}`
    // emit the case's fields under the variant's C type → a field-designator error).
    let v_is_sentinel_slice = match v.type { Slice as vs => match vs.element { Void => true; _ => false }; _ => false }
    let bound_is_concrete_slice = match tb.type { Slice as bs => match bs.element { Void => false; _ => true }; _ => false }
    if v_is_sentinel_slice {
        if bound_is_concrete_slice {
            v = TExpr { kind = v.kind; type = tb.type; line = v.line; col = v.col }
        }
    }
    TypedStmt { node = TAssign { kind = parser::AssignKind::Simple; name = a.name; op = a.op; bound = tb.type; value = v; deref = false; target = no_texpr() }; env = env }   // mut rule enforced (B.21)
}

fn type_return(r: parser::Return, env: Env, table: TypeTable) -> TypedStmt | error {
    let v = match type_expr(r.value, env, table) { TExpr as te => te; error as e => return e }
    TypedStmt { node = TReturn { has_value = r.has_value; value = v }; env = env }   // value gated by has_value (B.20); the return-type match is enforced by type_function's check_returns (C5)
}

/**
 * type_loop — type a `[LABEL:] loop [head] { … }` (#517). The head is already desugared: `init`
 * is typed in a LOOP-PRIVATE child scope so its bindings (counter / bound / `_first` / `_it`) do
 * NOT leak past the loop, then `body` is typed in that same scope (so the body reads the preamble).
 * The env returned is the CALLER's env — every loop-local binding (init AND body) is dropped.
 *
 * @param l the surface loop node (label + init + body)
 * @param env the enclosing type environment
 * @param table the type table
 * @return the typed loop statement paired with the UNCHANGED outer env, or a type error
 */
fn type_loop(l: parser::LoopStmt, env: Env, table: TypeTable) -> TypedStmt | error {
    let ib = match type_block(l.init, env, table) { TypedBlock as bk => bk; error as e => return e }
    let bb = match type_block(l.body, ib.env, table) { TypedBlock as bk => bk; error as e => return e }
    TypedStmt { node = TLoopStmt { label = l.label; init = ib.stmts; body = bb.stmts }; env = env }
}

fn type_exprstmt(es: parser::ExprStmt, env: Env, table: TypeTable) -> TypedStmt | error {
    // a TOP-LEVEL if/match is a STATEMENT — its value is discarded, so no `else` is required.
    match es.expr.kind {
        parser::IfExpr as f => {
            let te = match type_if_stmt(f, env, table) { TExpr as x => x; error as e => return e }
            TypedStmt { node = TExprStmt { expr = te }; env = env }
        }
        parser::MatchExpr as m => {
            let te = match type_match_stmt(m, env, table) { TExpr as x => x; error as e => return e }
            TypedStmt { node = TExprStmt { expr = te }; env = env }
        }
        _ => {
            let te = match type_expr(es.expr, env, table) { TExpr as x => x; error as e => return e }
            TypedStmt { node = TExprStmt { expr = te }; env = env }
        }
    }
}

fn type_statement(s: parser::Statement, env: Env, table: TypeTable) -> TypedStmt | error {
    match s {
        parser::Binding as b => type_binding(b, env, table)
        parser::Assign as a => type_assign(a, env, table)
        parser::Return as r => type_return(r, env, table)
        parser::LoopStmt as l => type_loop(l, env, table)
        parser::BreakStmt as b => TypedStmt { node = TBreakStmt { label = b.label }; env = env }
        parser::ContinueStmt as c => TypedStmt { node = TContinueStmt { label = c.label }; env = env }
        parser::ExprStmt as es => type_exprstmt(es, env, table)
        parser::DeferStmt as d => {
            // Validate: defer block may not directly contain return, break, or nested defer.
            mut vi: u64 = 0
            loop {
                if vi >= d.body.len { break }
                match d.body[vi] {
                    parser::Return => return error { message = "defer block may not return" }
                    parser::BreakStmt => return error { message = "defer block may not break" }
                    parser::DeferStmt => return error { message = "nested defer is not allowed" }
                    _ => { }
                }
                vi++
            }
            // Type-check the body in void context; bindings are scoped inside (don't leak env).
            let tb = match type_block(d.body, env, table) { TypedBlock as x => x; error as e => return e }
            TypedStmt { node = TDeferStmt { body = tb.stmts }; env = env }
        }
        parser::AdoptStmt as a => type_adopt(a, env, table)
    }
}

/**
 * type_adopt — type-check an `adopt [name] { … }` block in void context. The body is an ordinary
 * control-flow block (return/break/continue and nested `adopt` are ALL allowed — no defer-style
 * rejection), typed via type_block so its bindings are scoped inside and don't leak `env`. The
 * bound name is a codegen/region label; it introduces no binding into `env` in this increment.
 *
 * @param parser::AdoptStmt a  the parsed AdoptStmt
 * @param Env env  the enclosing type environment (unchanged on return — the body is scoped)
 * @param TypeTable table  the program type table
 * @return TypedStmt | error  the typed statement, or a type error propagated from the body
 */
fn type_adopt(a: parser::AdoptStmt, env: Env, table: TypeTable) -> TypedStmt | error {
    let tb = match type_block(a.body, env, table) { TypedBlock as x => x; error as e => return e }
    TypedStmt { node = TAdoptStmt { name = a.name; body = tb.stmts }; env = env }
}

// ---- items + program (the evolved check_function/check_item/check_program — E5c) ----

// the resolved return type: the annotation if present, else void (no `-> ret` — M.3).
// (#109 W1) `ref_ns` = the function's declaring namespace; unused until W2's R0-R5 rules.
fn function_return(f: parser::Function, table: TypeTable, ref_ns: str) -> Type | error {
    if !f.has_return { return Void { } }
    resolve_type(f.return_type, table, ref_ns)
}

// ---- C5 (DEFER scope): `return`/final-expr vs the declared return type ----
// Every `return e` reachable as a statement must yield the declared return type, and — when the
// body's trailing statement is an expression — that value too. A `return <member>` into a variant
// return type is admissible (B.14 — a member is automatically the union, no cast). The FULL
// "every path yields a value" guarantee (divergence/definite-return analysis) is a SEPARATE later
// item (M.4): a body ending in a diverging `loop`/`if`/`match` makes NO trailing-value claim here,
// so the seed's value-fns that end in a breakless `loop` (exits are inner `return`s) are NOT
// false-rejected. (Lives in the typed pass — the producer; the superseded `check_*` layer is not
// dual-walked — see the check_*/type_* duplication note in "Próximas etapas".)

// is a value of type `from` admissible where `to` is expected? (B.14 — variant member inclusion.)
// The widening rule is now the single source of truth in resolve.tks (widens_into), shared with
// the match/`if` arm JOIN (type_join) so the binding/return/assign checks and arm unification can
// never drift apart. A case widens into a named variant (`let s: Shape = Circle { … }`), a nested
// case widens transitively, and `T` widens into `T?`.
fn assignable_to(from: Type, to: Type, table: TypeTable) -> bool { widens_into(from, to, table) }

/** arg_keeps_narrow_type — an argument that WIDENS into a parameter type `pt` normally ADOPTS `pt`
    (its TExpr.type is rewritten to `pt`); but where the EMIT wraps the value at the use site, the
    arg must KEEP its narrow `arg_type` so codegen/VM see the concrete value they must wrap. True for:
    a case→variant widen (emit_as tags the union), a bare `T`→`T?` widen (present-wrap), a class→
    interface/base upcast (fat-pointer build), and a `[]E_a`→`[]E_p` element widen where `E_a != E_p`
    (the slice is REBUILT element-wise — bare `[]i64`→`[]i64?` or covariant `[]Return`→`[]Statement`;
    #265: the native gate cc-compiles these for the first time, so a widened arg-type would hide the
    element mismatch and cc would reject the distinct `tk_slice_*` struct). */
fn arg_keeps_narrow_type(pt: Type, arg_type: Type, table: TypeTable) -> bool {
    let pt_is_variant = match expand_variant(pt, table) { Variant => true; _ => false }
    if pt_is_variant { return true }
    let pt_is_opt = match pt { Optional => true; _ => false }
    let arg_is_opt = match arg_type { Optional => true; _ => false }
    if pt_is_opt && !arg_is_opt { return true }
    if arg_class_upcast(pt, arg_type, table) { return true }
    slice_element_widens(pt, arg_type)
}

/** arg_class_upcast — the param is an interface, (TR1) a trait, or a polymorphic base and the arg is
    a DIFFERENT-named class conforming to it (a fat-pointer upcast the emit builds from the narrow
    class). (#265) */
fn arg_class_upcast(pt: Type, arg_type: Type, table: TypeTable) -> bool {
    match pt {
        Named as ptn => match arg_type {
            Named as atn => (is_interface_name(ptn.name, table) || is_trait_name(ptn.name, table) || is_polymorphic_base(ptn.name, table)) && is_class_name(atn.name, table) && ptn.name != atn.name
            _ => false
        }
        _ => false
    }
}

/** slice_element_widens — both types are slices whose ELEMENTS differ (`[]E_a` → `[]E_p`, `E_a != E_p`):
    a bare→optional element widen or a covariant case→variant element widen. The emit rebuilds the
    slice element-wise, so the arg must keep its narrow `[]E_a` type for codegen to see the mismatch.
    A SENTINEL empty slice (`teko::list::empty()`, element = `void`) is EXCLUDED — it carries no
    concrete element, so it ADOPTS the param's concrete slice type (collections #4) as before. */
fn slice_element_widens(pt: Type, arg_type: Type) -> bool {
    match pt {
        Slice as ps => match arg_type {
            Slice as as_ => !type_is_void(as_.element) && !type_eq(ps.element, as_.element)
            _ => false
        }
        _ => false
    }
}

// check every `return` reachable as a statement (descend into loop bodies and `if`-blocks;
// match-arm returns await the divergence item — arm bodies are expressions, not statements).
fn check_returns(stmts: []TStatement, ret: Type, table: TypeTable) -> error? {
    mut i = 0
    loop {
        if i >= stmts.len { break }
        match check_return_stmt(stmts[i], ret, table) { null => { }; error as e => return e }
        i++
    }
    null
}

// the trailing value-expr of a block (its last statement, when that is an expr-statement),
// or null. (C: tblock_trailing.)
fn tblock_trailing(stmts: []TStatement) -> TExpr? {
    if stmts.len == 0 { return null }
    match stmts[stmts.len - 1] {
        TExprStmt as es => es.expr
        _ => null
    }
}

// the block's trailing value-expr IF it is a numeric literal (else null) — for the if/match
// literal cross-adoption (a `64` branch adopts a sibling's numeric type). (C: tl/el + NUMBER tag.)
fn trailing_number(stmts: []TStatement) -> TExpr? {
    match tblock_trailing(stmts) {
        TExpr as t => match t.kind { TNumber => t; _ => null }
        null => null
    }
}

// C6 (extended) — a fitting numeric LITERAL adopts the destination type (return value / trailing
// expr): int-literal → an int prim it fits OR `byte` (=u8, B.36); float-literal → a fitting float
// prim. Reuses cast_kind (byte AS u8) + value_fits / float_fits — the same range rules as a binding.
// RECURSES through a `match`/`if` whose every contributing arm trails an adopting literal (so
// `match k { U8 => 8; … } : u32` adopts), mirroring tk_literal_adopts in expr.c.
fn literal_adopts(e: TExpr, to: Type) -> bool {
    match e.kind {
        TNumber as n => match cast_kind(to) {
            PrimKind as k => {
                if n.is_float { prim_is_float(k) && float_fits(n.fval, k) }
                else { prim_is_int(k) && value_fits(n.value, k) }
            }
            error => false
        }
        TMatchExpr as m => {
            mut any = false
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                if !tblock_diverges(m.arms[i].body) {   // a diverging arm yields no value (M.3)
                    match tblock_trailing(m.arms[i].body) {
                        TExpr as t => { if !literal_adopts(t, to) { return false }; any = true }
                        null => return false
                    }
                }
                i++
            }
            any   // ≥1 contributing arm, all adopt
        }
        TIfExpr as f => {
            if !f.has_else { return false }   // a one-armed `if` has no value
            mut any = false
            if !tblock_diverges(f.then_blk) {
                match tblock_trailing(f.then_blk) {
                    TExpr as t => { if !literal_adopts(t, to) { return false }; any = true }
                    null => return false
                }
            }
            if !tblock_diverges(f.else_blk) {
                match tblock_trailing(f.else_blk) {
                    TExpr as t => { if !literal_adopts(t, to) { return false }; any = true }
                    null => return false
                }
            }
            any
        }
        // an ARRAY LITERAL adopts a `[]E` slot when EVERY non-spread element adopts E (element-wise
        // literal adoption — e.g. `[0x68, 0x65]` adopts `[]byte`). Spread elements are already
        // `[]T` and were type-checked at construction time — skip adoption for them.
        // An empty `[]` adopts any slice.
        TArrayLit as a => match to {
            Slice as s => {
                mut i = 0
                loop {
                    if i >= a.elements.len { break }
                    if !a.elements[i].is_spread {
                        if !literal_adopts(a.elements[i].expr, s.element) { return false }
                    }
                    i++
                }
                true
            }
            _ => false
        }
        _ => false
    }
}

// (#71) RETYPE a value that `literal_adopts(e, to)` already accepted — the retyping twin of the
// range-check above. A plain leaf (number/match/if trailing) adopts by taking `to` wholesale (the
// existing single-site behavior at every adoption call site: binding/assign/arg/struct-field). An
// ARRAY LITERAL instead retypes ELEMENT-WISE: each non-spread element recurses into the slice's
// element type (so a nested array-of-arrays retypes at every depth), and the array's own `.type`
// becomes `to` — mirrors literal_adopts's recursion structure exactly, one level deeper (it
// REBUILDS the already-typed tree — TExpr/TArrayLit/TArrayElem are value types — rather than just
// reporting fit). A spread element is already a concrete `[]T` — left untouched (its own widen was
// checked at array-literal typing time, same as the read side above).
fn retype_literal(e: TExpr, to: Type) -> TExpr {
    match e.kind {
        TArrayLit as a => match to {
            Slice as s => {
                mut elems: []TArrayElem = teko::list::empty()
                mut i = 0
                loop {
                    if i >= a.elements.len { break }
                    let el = a.elements[i]
                    if el.is_spread {
                        elems = teko::list::push(elems, el)
                    } else {
                        elems = teko::list::push(elems, TArrayElem { is_spread = false; expr = retype_literal(el.expr, s.element) })
                    }
                    i++
                }
                TExpr { kind = TArrayLit { elements = elems }; type = to; line = e.line; col = e.col }
            }
            _ => TExpr { kind = e.kind; type = to; line = e.line; col = e.col }
        }
        _ => TExpr { kind = e.kind; type = to; line = e.line; col = e.col }
    }
}

fn check_return_stmt(s: TStatement, ret: Type, table: TypeTable) -> error? {
    match s {
        TReturn as r => {
            if r.has_value {
                if assignable_to(r.value.type, ret, table) || literal_adopts(r.value, ret) { null }   // a fitting int/float/byte literal adopts the return type (C6)
                // (C1.8/E2) attach expected=type_render(ret), actual=type_render(r.value.type) —
                // mirrors typer.c check_return_stmt's tk_error_types wrap.
                else { teko::error::err_typed(error { message = "return value does not match the function's declared return type" }, type_render(ret), type_render(r.value.type)) }
            } else {
                if type_is_void(ret) { null }   // a bare `return` is legal iff the function returns no value (M.3)
                else { error { message = "bare `return` in a function that declares a value-returning (non-void) return type" } }
            }
        }
        TLoopStmt as l => check_returns(l.body, ret, table)
        TExprStmt as es => check_returns_inexpr(es.expr, ret, table)
        TAdoptStmt as a => check_returns(a.body, ret, table)
        _ => null
    }
}

// returns can also live inside a top-level `if`'s blocks (`if c { return e }`) and inside a
// `match`'s arm blocks (arm bodies are blocks now — a `return` inside one is checked — B.20).
fn check_returns_inexpr(e: TExpr, ret: Type, table: TypeTable) -> error? {
    match e.kind {
        TIfExpr as f => {
            match check_returns(f.then_blk, ret, table) { null => { }; error as e => return e }
            check_returns(f.else_blk, ret, table)
        }
        TMatchExpr as m => {
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                match check_returns(m.arms[i].body, ret, table) { null => { }; error as e => return e }
                i++
            }
            null
        }
        _ => null
    }
}

// the trailing-value check — ONLY when the last statement is an expression (else: NO claim, the
// guard against false-rejecting a body that ends in a diverging loop/if/match — the every-path item).
fn check_trailing_value(stmts: []TStatement, ret: Type, table: TypeTable) -> error? {
    if stmts.len == 0 { return null }
    match stmts[stmts.len - 1] {
        TExprStmt as es => {
            if texpr_diverges(es.expr) { null }   // a trailing panic/exit yields no value (M.3)
            else { if assignable_to(es.expr.type, ret, table) || literal_adopts(es.expr, ret) { null }   // a fitting trailing literal adopts the return type (C6)
                // (C1.8/E2) attach expected=type_render(ret), actual=type_render(es.expr.type) — mirrors
                // typer.c check_trailing_value's tk_error_types wrap.
                else { teko::error::err_typed(error { message = "the function's final expression does not match its declared return type" }, type_render(ret), type_render(es.expr.type)) } }
        }
        _ => null
    }
}

// ---- W5-cf-2: loop-label validation (mirrors typer.c's check_labels; null = ok) ----
// A `break NAME`/`continue NAME` must name an ENCLOSING loop; a bare `break`/`continue` must
// be inside some loop; and all loop labels within one body must be DISTINCT, so codegen's C
// goto-labels (tk_lbl_<NAME>_break / _cont) cannot collide. `scope` is the list of enclosing
// loop labels (the C linked list, realized as a Teko list); `seen` accumulates every label in
// this body for the uniqueness check. Because Teko lists are by-value, `seen` is THREADED — it
// rides in/out of every recursive call via the LabelCheck carrier (the C threads a shared
// `seen`/`nseen` out-param; this is the same accumulation, expressed immutably). On failure the
// carrier holds the message; on success it returns the grown `seen`.
type LabelCheck = struct { failed: bool; message: str; seen: []str }

fn lbl_eq(a: str, b: str) -> bool { a == b }

fn lbl_enclosing(scope: []str, label: str) -> bool {
    mut i = 0
    loop {
        if i >= scope.len { break }
        if lbl_eq(scope[i], label) { return true }
        i++
    }
    false
}

// recurse into the IF then/else blocks and the MATCH arm bodies (the only expr forms that hold
// statements). Threads `seen` through; carries `scope`/`in_loop` unchanged into the branches.
fn check_labels_inexpr(e: TExpr, scope: []str, in_loop: bool, seen: []str) -> LabelCheck {
    match e.kind {
        TIfExpr as f => {
            let t = check_labels(f.then_blk, scope, in_loop, seen)
            if t.failed { return t }
            check_labels(f.else_blk, scope, in_loop, t.seen)
        }
        TMatchExpr as m => {   // arm bodies are blocks now — walk each arm block (B.20)
            mut acc = seen
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                let t = check_labels(m.arms[i].body, scope, in_loop, acc)
                if t.failed { return t }
                acc = t.seen
                i++
            }
            LabelCheck { failed = false; message = ""; seen = acc }
        }
        _ => LabelCheck { failed = false; message = ""; seen = seen }
    }
}

/**
 * check_labels — validate every `break`/`continue` in `stmts` against its enclosing loop
 * structure: a bare `break`/`continue` must be inside SOME loop (`in_loop`); a labeled one must
 * name a loop currently in `scope`; a `LABEL: loop { }` label must be UPPER_SNAKE (#517) and unique
 * among its enclosing siblings (`seen`, dedup-checked via `lbl_enclosing`). `adopt { }` is an
 * ORDINARY block, not a
 * loop — it introduces NO label frame and does not reset `in_loop`, so a bare `break`/`continue`
 * inside still targets the enclosing loop (or is rejected when there is none), and a labeled one
 * still resolves against the SAME enclosing `scope` (mirrors codegen's region-stack crossing
 * behavior, which drops an adopter region on the way out without treating it as a loop boundary).
 *
 * @param []TStatement stmts  the statement block to validate
 * @param []str scope  every loop label currently enclosing this block (innermost last)
 * @param bool in_loop  whether SOME enclosing loop exists (enables a bare break/continue)
 * @param []str seen  loop labels already declared among `stmts`' enclosing siblings (dup-check)
 * @return LabelCheck  a LabelCheck: failed=false with the accumulated `seen` on success, else the
 *                 first violation's message
 */
fn check_labels(stmts: []TStatement, scope: []str, in_loop: bool, seen: []str) -> LabelCheck {
    mut acc = seen
    mut i = 0
    loop {
        if i >= stmts.len { break }
        match stmts[i] {
            TLoopStmt as l => {
                if l.label.len > 0 {
                    if !lexer::is_upper_snake(l.label) { return LabelCheck { failed = true; message = "loop label must be UPPER_SNAKE"; seen = acc } }
                    if lbl_enclosing(acc, l.label) { return LabelCheck { failed = true; message = "duplicate loop label within the same body"; seen = acc } }
                    acc = teko::list::push(acc, l.label)
                }
                let frame = teko::list::push(scope, l.label)   // push this label as an enclosing frame
                let t = check_labels(l.body, frame, true, acc)
                if t.failed { return t }
                acc = t.seen
            }
            TBreakStmt as b => {
                if b.label.len == 0 {
                    if !in_loop { return LabelCheck { failed = true; message = "`break`/`continue` outside a loop"; seen = acc } }
                } else if !lbl_enclosing(scope, b.label) {
                    return LabelCheck { failed = true; message = "`break`/`continue` to an unknown loop label (no enclosing loop carries that label)"; seen = acc }
                }
            }
            TContinueStmt as c => {
                if c.label.len == 0 {
                    if !in_loop { return LabelCheck { failed = true; message = "`break`/`continue` outside a loop"; seen = acc } }
                } else if !lbl_enclosing(scope, c.label) {
                    return LabelCheck { failed = true; message = "`break`/`continue` to an unknown loop label (no enclosing loop carries that label)"; seen = acc }
                }
            }
            TExprStmt as es => {
                let t = check_labels_inexpr(es.expr, scope, in_loop, acc)
                if t.failed { return t }
                acc = t.seen
            }
            TAdoptStmt as a => {
                let t = check_labels(a.body, scope, in_loop, acc)
                if t.failed { return t }
                acc = t.seen
            }
            _ => { }
        }
        i++
    }
    LabelCheck { failed = false; message = ""; seen = acc }
}

// C7.1a: an `extern` param/return type must be primitive (int/float/bool) or `byte` — the
// only shapes that marshal 1:1 across the C ABI. `ptr`/`uptr` join next; `void` is allowed
// for the RETURN only (handled by the caller). Rejects str/slice/optional/variant/named.
// C7.1a: is `t` legal across the extern boundary? prims/byte/ptr/uptr, OR an `extern type`
// opaque handle (a Named whose decl is an ExternBody) — but NOT an ordinary Teko struct/enum/
// variant (those would be unsupported by-value aggregate FFI). `void` is handled by the caller.
fn extern_type_ok(t: Type, table: TypeTable) -> bool {
    match t {
        Prim => true
        Byte => true
        Ptr => true
        Uptr => true
        Named as nm => match type_table_find(table, nm.name, "") {   // (#109 W1) extern-kind probe on a resolved name — no referencing ns
            parser::TypeDecl as td => match td.body { parser::ExternBody => true; _ => false }
            error => false
        }
        _ => false
    }
}

// C7.2: teko_rt speaks Teko's own internal ABI (tk_str/tk_ffi_sres/tk_ffi_ures/etc.) and may
// legally declare str/[]str/str|error/error?/i32 — allow those for `from "teko_rt"` externs.
// `Named` is also allowed: user-defined structs declared in teko-native namespaces (e.g.
// teko::time's DateTime/Date/…) are passed by value across the teko_rt boundary using their
// generated C struct layout (the C side mirrors the Teko field layout exactly — SUPREME RULE).
fn teko_rt_type_ok(t: Type) -> bool {
    match t {
        Str => true
        Void => true
        Prim => true
        Byte => true
        Ptr => true
        Uptr => true
        Slice => true   // []str, []byte, etc.
        Variant => true   // str | error
        Optional => true   // error?
        Named => true   // user struct (e.g. DateTime, Date) — passed by value, layout-matched
        _ => false
    }
}

/**
 * params_have_discard — does any parameter in `ps` denote the write-only DISCARD `_` (owner
 * refinement 2026-07-15)? A discard parameter has no type and the reserved name "_" — a name the
 * lexer can never mint for a real identifier, so the test is unambiguous.
 *
 * @param ps  the parameter list
 * @return    true iff at least one parameter is a `_` discard
 */
fn params_have_discard(ps: []parser::Param) -> bool {
    mut i: u64 = 0
    loop {
        if i >= ps.len { break }
        if !ps[i].has_type && ps[i].name == "_" { return true }
        i++
    }
    false
}

/**
 * method_named — the first method in `ms` whose name equals `name`, or null when none matches. Used
 * to locate the base/interface method that GOVERNS a `_` discard parameter's type by position.
 *
 * @param ms    the method list to scan
 * @param name  the method name to find
 * @return      the matching method, or null
 */
fn method_named(ms: []parser::Function, name: str) -> parser::Function? {
    mut i: u64 = 0
    loop {
        if i >= ms.len { break }
        if ms[i].name == name { return ms[i] }
        i++
    }
    null
}

/**
 * type_implements_list — the interface `implements` list of the type named `name` (a class or a
 * struct), or an empty list when the type is neither, is unknown, or lists no interfaces.
 *
 * @param name    the enclosing type name
 * @param ref_ns  the referencing namespace for the type-table lookup
 * @param table   the folded type table
 * @return        the type's `implements` names, or an empty list
 */
fn type_implements_list(name: str, ref_ns: str, table: TypeTable) -> []str {
    match type_table_find(table, name, ref_ns) {
        parser::TypeDecl as td => match td.body {
            parser::ClassBody as cb => cb.implements
            parser::StructBody as sb => sb.implements
            _ => teko::list::empty()
        }
        error => teko::list::empty()
    }
}

/**
 * find_interface_method — the interface-required method named `name` provided by any interface in
 * `impls`, or null when none provides it. Mirrors check_one_interface's resolution (find_interface_decl
 * then effective_interface_methods), so the governing signature seen here is exactly the one the
 * conformance check validated.
 *
 * @param impls   the type's `implements` interface names
 * @param name    the method name to find
 * @param table   the folded type table
 * @param ref_ns  the conforming type's namespace (interface lookups resolve here)
 * @return        the matching interface method, or null
 */
fn find_interface_method(impls: []str, name: str, table: TypeTable, ref_ns: str) -> parser::Function? {
    mut i: u64 = 0
    loop {
        if i >= impls.len { break }
        match find_interface_decl(impls[i], table, ref_ns) {
            IfaceHit as h => match h.decl.body {
                parser::InterfaceBody as ib => match effective_interface_methods(ib, h.ns, table, teko::list::push(teko::list::empty(), qualify(h.ns, name_last_segment(h.decl.name)))) {
                    []parser::Function as ms => match method_named(ms, name) { parser::Function as m => return m; null => { } }
                    error => { }
                }
                _ => { }
            }
            error => { }
        }
        i++
    }
    null
}

/**
 * discard_governing_sig — the base/interface method whose signature dictates the TYPES of a `_`
 * discard parameter in method `f` of type `struct_name` (owner refinement 2026-07-15): the base
 * class's same-named method (when `f` overrides) or a same-named method of an interface the type
 * implements. Null when `f` neither overrides nor implements a same-named method — the caller then
 * rejects the discard parameter as illegal in a self-owned signature.
 *
 * @param f            the method being typed
 * @param struct_name  the enclosing type name (bare or canonical)
 * @param ref_ns       the enclosing type's namespace
 * @param table        the folded type table
 * @return             the governing base/interface method, or null when none matches
 */
fn discard_governing_sig(f: parser::Function, struct_name: str, ref_ns: str, table: TypeTable) -> parser::Function? {
    match type_table_find(table, struct_name, ref_ns) {
        parser::TypeDecl as td => match td.body {
            parser::ClassBody as cb => {
                if cb.has_base {
                    match find_class_body(cb.base_name, table) {
                        parser::ClassBody as bcb => match effective_class_methods(bcb, table) {
                            []parser::Function as ms => match method_named(ms, f.name) { parser::Function as m => return m; null => { } }
                            error => { }
                        }
                        error => { }
                    }
                }
            }
            _ => { }
        }
        error => { }
    }
    find_interface_method(type_implements_list(struct_name, ref_ns, table), f.name, table, ref_ns)
}

/**
 * discard_param_name — the synthesized C-visible name for the `_` discard parameter at position
 * `idx`: unique per position so multiple `_` params never collide in the emitted C signature, while
 * the body can never name it (a discard read is a compile error).
 *
 * @param idx  the parameter's positional index
 * @return     a per-position throwaway parameter name
 */
fn discard_param_name(idx: u64) -> str { $"_tk_discard_{idx}" }

/**
 * discard_param_type — the resolved type of the `_` discard parameter at position `idx`, taken BY
 * POSITION from the governing base/interface signature `gov`. A null `gov` is the GATE: a `_`
 * discard parameter is only legal in an implementing/overriding signature.
 *
 * @param gov     the governing base/interface method, or null
 * @param idx     the discard parameter's positional index
 * @param table   the folded type table
 * @param ref_ns  the conforming type's namespace (the governing param type resolves here, matching
 *                the conformance check's own resolution namespace)
 * @return        the resolved discard-parameter type
 * @throws        when `gov` is null (a discard param in a self-owned signature), when `idx` has no
 *                matching governing slot, or when the governing param type fails to resolve
 */
fn discard_param_type(gov: parser::Function?, idx: u64, table: TypeTable, ref_ns: str) -> Type | error {
    match gov {
        parser::Function as g => {
            if idx >= g.params.len { return error { message = "a `_` discard parameter has no matching slot in the implemented/overridden signature" } }
            resolve_type(g.params[idx].type_ann, table, ref_ns)
        }
        null => error { message = "a `_` discard parameter is only allowed when implementing an interface method or overriding a base method — a plain function must name its parameters" }
    }
}

/**
 * (OOP A1, 2026-07-01) Type-check a struct/class METHOD's BODY. Mirrors type_function, except the
 * RECEIVER param (`has_type=false`, only ever index 0) binds to `Named{struct_name}` instead of going
 * through resolve_type (its type is implicit, never written by the user). (#254) The method's
 * type-param table is PREPENDED with the enclosing type's own params, so a body referencing `T`
 * resolves against the owner's `T` — a NO-OP for a non-generic owner.
 *
 * @param f                  the method to type-check
 * @param struct_name        the enclosing type name (bare from the caller; canonicalized here)
 * @param env                the typing environment
 * @param table              the folded type table
 * @param has_base_binding   does the class expose a named base-object binding to this method?
 * @param base_binding_name  the base-binding local name (valid iff has_base_binding)
 * @param base_name          the (canonical) base class name (valid iff has_base_binding)
 * @param declaring_class    the class that ORIGINALLY declared this body (intern/private access ctx)
 * @return                   the typed method as a TFunction (namespace stamped by the caller)
 *                           or (U2, §2 line 72) a local/param/return of unsafe type when neither
 *                           the method's own `is_unsafe` nor its owning type's is set — a method
 *                           inherits its OWNER type's unsafe-ness (`method_is_effective_unsafe`)
 */
fn type_method(f: parser::Function, struct_name: str, env: Env, table: TypeTable, has_base_binding: bool, base_binding_name: str, base_name: str, declaring_class: str) -> TFunction | error {
    // (W10b.CLASS residual — intern visibility) this body's OWN field/method accesses are
    // checked against `declaring_class` (see type_struct_methods's own comment on why this can
    // differ from `struct_name`), NOT `struct_name` — set before typing the body below.
    mut local = with_fn_unsafe(with_owner(env, declaring_class), method_is_effective_unsafe(f, struct_name, env.cur_ns, table))
    let tbl = method_type_param_table(receiver_canonical_name(struct_name, env.cur_ns, table), f.type_params, f.type_constraints, "", table)
    let is_teko_rt = f.is_extern && f.from_lib == "teko_rt"
    // (W10b.CLASS) `class Base(parent) { … }` — the NAMED BINDING an instance method uses to
    // reach the base object. Only meaningful for an INSTANCE method (has a receiver); a class's
    // static methods never chain/inherit, so there is no base object to bind there. The binding
    // is a REINTERPRET of the SAME receiver pointer as the base type — sound because
    // effective_class_fields lays out the base's fields as a PREFIX of the derived struct
    // (field-flattening composition, increment 2), so a `tk_t_Derived *` and a `tk_t_Base *`
    // pointing at the SAME address read identical bytes for every base field.
    let is_instance_method = f.params.len > 0 && !f.params[0].has_type
    let inject_base_binding = has_base_binding && is_instance_method
    // codegen reads TFunction.params[i].type_ann DIRECTLY (the syntactic node, not the checked
    // Type) to emit a C signature — so the receiver's placeholder type_ann (no_type(), from
    // parsing) must be REWRITTEN to a real Named(struct_name) TypeExpr before it ever reaches
    // codegen, or emit_function_sig recurses on an empty path (M.1 crash). Every other param's
    // type_ann is already meaningful from parsing and passes through unchanged.
    let discard_gov: parser::Function? = if params_have_discard(f.params) { discard_governing_sig(f, struct_name, env.cur_ns, table) } else { null }
    mut fixed_params: []parser::Param = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= f.params.len { break }
        if !f.params[i].has_type && f.params[i].name == "_" {
            let dpt = match discard_param_type(discard_gov, i, tbl, env.cur_ns) { Type as t => t; error as e => return e }
            fixed_params = teko::list::push(fixed_params, parser::Param { name = discard_param_name(i); has_type = true; type_ann = type_to_texpr(dpt); is_params = false; has_default = false; default_expr = parser::no_expr() })
            i++
            continue
        }
        let pt = if !f.params[i].has_type {
            Named { name = qualify(env.cur_ns, struct_name) }   // (#109 W3) canonical: the method's own ns qualifies its receiver type
        } else {
            match resolve_type(f.params[i].type_ann, tbl, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the method's enclosing namespace
        }
        fixed_params = teko::list::push(fixed_params, if !f.params[i].has_type {
                parser::Param { name = f.params[i].name; has_type = true; type_ann = type_to_texpr(pt); is_params = false; has_default = false; default_expr = parser::no_expr() }
            } else {
                f.params[i]
        })
        if f.is_extern {
            if is_teko_rt {
                if !teko_rt_type_ok(pt) {
                    return error { message = "a `teko_rt` extern function parameter must be a primitive, `str`, slice, variant, or optional (C7.2)" }
                }
            } else {
                if !extern_type_ok(pt, table) {
                    return error { message = "an `extern` function parameter must be a primitive (int/float/bool), `byte`, `ptr`, `uptr`, or an `extern type` handle (C7.1a)" }
                }
            }
        }
        local = define(local, f.params[i].name, pt, false)
        i++
    }
    if inject_base_binding { local = define(local, base_binding_name, Named { name = if name_qualifier(base_name) != "" { base_name } else { qualify(env.cur_ns, base_name) } }, false) }   // (#109 W3 / #152) canonical: base_name arrives PRE-QUALIFIED from canon_class_bases (cross-ns exact); a bare (unresolvable/root) one qualifies by the class's own ns
    let ret = match function_return(f, tbl, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the fn's enclosing namespace
    match ret { Reference => return error { message = "a function cannot return a reference (pass-down only)" }; _ => { } }
    if f.is_extern {
        let ret_ok = if is_teko_rt {
            teko_rt_type_ok(ret)
        } else {
            match ret { Void => true; _ => extern_type_ok(ret, table) }
        }
        if !ret_ok {
            return error { message = "an `extern` function return must be a primitive (int/float/bool), `byte`, `ptr`, `uptr`, an `extern type` handle, or absent (C7.1a)" }
        }
        let no_body: []TStatement = teko::list::empty()
        return TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = fixed_params; return_type = ret; body = no_body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = ""; file = ""; line = 0; col = 0; is_test = f.is_test; is_extern = true; c_symbol = f.c_symbol; from_lib = f.from_lib }
    }
    let tb = match type_block(f.body, local, tbl) { TypedBlock as bk => bk; error as e => return e }
    match check_returns(tb.stmts, ret, table) { null => { }; error as e => return e }
    match check_trailing_value(tb.stmts, ret, table) { null => { }; error as e => return e }
    let lc = check_labels(tb.stmts, teko::list::empty(), false, teko::list::empty())
    if lc.failed { return error { message = lc.message } }
    // (W10b.CLASS / #98 Option A) PREPEND the base-binding as the method body's FIRST statement: a
    // synthetic `let <binding>: <Base> = <self>` — self UPCAST to the base, NOT a reinterpret-cast.
    // Binding self (the concrete subclass) with the base-typed `bound` lets emit_as build the D3 fat
    // pointer (data + tk_vt_<Sub>_<Base>), so dispatch through the base-binding works uniformly under
    // the one-representation model (widens_into now permits the Sub→Base widen). Checked ABOVE the
    // injection (check_returns/check_trailing_value/check_labels all read the ORIGINAL body) since it
    // changes nothing about return/trailing-value/label semantics.
    let body = if inject_base_binding {
        let receiver_name = f.params[0].name
        let cast_val = TExpr {
            kind = TVar { name = receiver_name; is_func = false; func_ns = "" }
            type = Named { name = qualify(env.cur_ns, struct_name) }   // (#109 W3) canonical: self's concrete subclass type qualified by the method's ns
            line = 0; col = 0
        }
        let bind_stmt = TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = base_binding_name }; bound = Named { name = if name_qualifier(base_name) != "" { base_name } else { qualify(env.cur_ns, base_name) } }; value = cast_val }   // (#109 W3 / #152) canonical: base_name arrives PRE-QUALIFIED from canon_class_bases; a bare one qualifies by the class's own ns
        mut prefixed: []TStatement = teko::list::push(teko::list::empty(), bind_stmt)
        mut si = 0
        loop { if si >= tb.stmts.len { break }; prefixed = teko::list::push(prefixed, tb.stmts[si]); si++ }
        prefixed
    } else {
        tb.stmts
    }
    let tf = TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = fixed_params; return_type = ret; body = body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = ""; file = ""; line = 0; col = 0; is_test = f.is_test; is_extern = false; c_symbol = ""; from_lib = "" }
    match check_ref_storability(tf) { null => { }; error as e => return e }
    tf
}

/**
 * (#331 L2a) POST-typing Ref-storability gate. `fn_spine` needs a fully-typed `TFunction`, so this
 * runs ONCE per function after the body is assembled (it cannot be threaded into `type_binding`,
 * which runs mid-typing before any `TFunction` exists). It ADMITS a ref bound / reassigned to a
 * local IFF the spine proves the borrow's referent outlives it; otherwise it re-raises the R5 reject
 * the inline gate deferred. The only ref value obtainable today is a `Ref<T>` parameter read, so an
 * admitted ref-to-local is `bf = BfParam` and its referent is caller-owned (strictly outlives the
 * local). An un-nameable RHS (`if`/`match`/call) yields `cell_of == -1` ⇒ conservative reject.
 *
 * @param TFunction tf  the fully-typed function
 * @return error?  null when every ref-to-local is spine-sound, else the R5 reject error
 */
fn check_ref_storability(tf: TFunction) -> error? {
    if !fn_has_ref_param(tf) {
        if !stmts_have_free(tf.body) { return null }
    }
    check_ref_storability_block(tf.body, fn_spine(tf))
}

/**
 * (#331 L2b) The freed target name of a `teko::mem::free(x)` call (a `teko::mem`-namespaced call
 * whose last segment is `free`, one bare-`TVar` argument), or `""` when `e` is not such a call.
 *
 * @param TExpr e  the typed expression
 * @return str  the freed variable name, or "" when not a `mem::free` call
 */
fn mem_free_target_name(e: TExpr) -> str {
    match e.kind {
        TCall as c => {
            if c.call_ns != "teko::mem" { return "" }
            if c.callee.segments.len == 0 { return "" }
            if c.callee.segments[c.callee.segments.len - 1].name != "free" { return "" }
            if c.args.len != 1 { return "" }
            match c.args[0].kind {
                TVar as v => v.name
                _ => ""
            }
        }
        _ => ""
    }
}

/**
 * (#331 L2b) The affine `mem::free` guard: the freed target must be the SOLE live handle
 * (`is_unique_at`). A shared / `⊤` target (`let y = x; mem::free(x)`) would leave `y` dangling — the
 * aliased-free UAF (remodel §5 / #336 HONEST-BOUNDS gap 1), invisible to static analysis AND ASan
 * (only `TEKO_MEM_PARANOID`). This closes it statically. A non-free expression is a no-op.
 *
 * @param TExpr e  the typed expression (a `mem::free` call site, or anything else)
 * @param Spine spine  the enclosing function's spine
 * @return error?  null when the free is sound (unique target) or `e` is not a free, else the reject
 */
fn check_free_site(e: TExpr, spine: Spine) -> error? {
    let target = mem_free_target_name(e)
    if target == "" { return null }
    let ci = cell_of(spine, target)
    if ci < 0 { return null }
    if is_unique_at(spine, ci to u32) { return null }
    error { message = $"cannot free `{target}` — it is aliased (another binding still holds it); `mem::free` requires the sole live handle" }
}

/**
 * (#331 L2b) Does a statement block (transitively, through loop/defer/adopt bodies + if/match arms)
 * contain a `mem::free` call? A cheap boolean scan (no spine) used by `check_ref_storability`'s
 * fast-path: build the per-function spine ONLY when a ref parameter OR a free call is present.
 *
 * @param []TStatement stmts  the typed statement block
 * @return bool  true iff a `mem::free` call is reachable in the block
 */
fn stmts_have_free(stmts: []TStatement) -> bool {
    mut i = 0
    loop {
        if i >= stmts.len { break }
        if stmt_has_free(stmts[i]) { return true }
        i++
    }
    false
}

/** (#331 L2b) Does one statement embed a `mem::free` call (recursing into nested blocks/arms)? */
fn stmt_has_free(s: TStatement) -> bool {
    match s {
        TExprStmt as es => expr_has_free(es.expr)
        TBinding as b => expr_has_free(b.value)
        TAssign as a => expr_has_free(a.value)
        TReturn as r => if r.has_value { expr_has_free(r.value) } else { false }
        TLoopStmt as l => stmts_have_free(l.init) || stmts_have_free(l.body)
        TDeferStmt as d => stmts_have_free(d.body)
        TAdoptStmt as a => stmts_have_free(a.body)
        TBreakStmt => false
        TContinueStmt => false
    }
}

/** (#331 L2b) Does an expression embed a `mem::free` call (itself, or in an if/match arm body)? */
fn expr_has_free(e: TExpr) -> bool {
    if mem_free_target_name(e) != "" { return true }
    match e.kind {
        TIfExpr as f => if stmts_have_free(f.then_blk) { true } else { if f.has_else { stmts_have_free(f.else_blk) } else { false } }
        TMatchExpr as m => match_arms_have_free(m)
        _ => false
    }
}

/** (#331 L2b) Does any match arm body embed a `mem::free` call? */
fn match_arms_have_free(m: TMatchExpr) -> bool {
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        if stmts_have_free(m.arms[i].body) { return true }
        i++
    }
    false
}

/**
 * True iff any of the function's parameters is a `Ref<T>`. The ONLY reference value obtainable today
 * is a `Ref<T>` parameter read, so a function with no ref parameter can hold no ref-to-local — the
 * gate skips it without building the spine (a per-function cost paid only where a ref can appear).
 *
 * @param TFunction tf  the typed function
 * @return bool  true iff at least one parameter is a reference
 */
fn fn_has_ref_param(tf: TFunction) -> bool {
    mut i = 0
    loop {
        if i >= tf.params.len { break }
        let p = tf.params[i]
        if p.has_type {
            if type_ann_is_ref(p.type_ann) { return true }
        }
        i++
    }
    false
}

/**
 * Walk a statement block, checking each ref-to-local bind/assign and recursing into nested blocks.
 *
 * @param []TStatement stmts  the typed statement block
 * @param Spine spine  the function's spine fact
 * @return error?  null when sound, else the first reject error
 */
fn check_ref_storability_block(stmts: []TStatement, spine: Spine) -> error? {
    mut i = 0
    loop {
        if i >= stmts.len { break }
        match check_ref_storability_stmt(stmts[i], spine) { error as e => return e; null => { } }
        i++
    }
    null
}

/**
 * Check one statement: a ref-to-local `TBinding` / simple `TAssign` is gated by the spine; loop /
 * defer / adopt bodies and value-position `if`/`match` arms recurse so a branch-nested ref-bind is
 * not missed (mirrors the cell-universe walk).
 *
 * @param TStatement s  the typed statement
 * @param Spine spine  the function's spine fact
 * @return error?  null when sound, else the reject error
 */
fn check_ref_storability_stmt(s: TStatement, spine: Spine) -> error? {
    match s {
        TBinding as b => match check_ref_bind_storable(b, spine) { error as e => return e; null => check_ref_storability_expr(b.value, spine) }
        TAssign as a => match check_ref_assign_storable(a, spine) { error as e => return e; null => check_ref_storability_expr(a.value, spine) }
        TLoopStmt as l => match check_ref_storability_block(l.init, spine) { error as e => return e; null => check_ref_storability_block(l.body, spine) }
        TDeferStmt as d => check_ref_storability_block(d.body, spine)
        TAdoptStmt as a => check_ref_storability_block(a.body, spine)
        TReturn as r => if r.has_value { check_ref_storability_expr(r.value, spine) } else { null }
        TExprStmt as es => check_ref_storability_expr(es.expr, spine)
        TBreakStmt => null
        TContinueStmt => null
    }
}

/**
 * Recurse the Ref-storability check into a value-position `if`/`match`'s arm bodies (each a statement
 * block); any other expression carries no block, so it is a no-op.
 *
 * @param TExpr e  the typed expression
 * @param Spine spine  the function's spine fact
 * @return error?  null when sound, else the reject error
 */
fn check_ref_storability_expr(e: TExpr, spine: Spine) -> error? {
    match e.kind {
        TIfExpr as f => match check_ref_storability_block(f.then_blk, spine) { error as er => return er; null => if f.has_else { check_ref_storability_block(f.else_blk, spine) } else { null } }
        TMatchExpr as m => check_ref_storability_match(m, spine)
        _ => check_free_site(e, spine)
    }
}

/**
 * Recurse the Ref-storability check into every match arm body.
 *
 * @param TMatchExpr m  the typed match expression
 * @param Spine spine  the function's spine fact
 * @return error?  null when sound, else the reject error
 */
fn check_ref_storability_match(m: TMatchExpr, spine: Spine) -> error? {
    mut i = 0
    loop {
        if i >= m.arms.len { break }
        match check_ref_storability_block(m.arms[i].body, spine) { error as e => return e; null => { } }
        i++
    }
    null
}

/**
 * Gate a `TBinding`: only a bare-`Reference`-bound `SimpleName` is a ref-to-local (nested-ref bounds
 * were rejected inline); check the spine. A destructure names no single ref cell.
 *
 * @param TBinding b  the typed binding
 * @param Spine spine  the function's spine fact
 * @return error?  null when sound, else the reject error
 */
fn check_ref_bind_storable(b: TBinding, spine: Spine) -> error? {
    match b.bound {
        Reference => match b.target {
            parser::SimpleName as sn => ref_borrow_or_error(spine, sn.name, b.value)
            parser::DestructurePattern => null
        }
        _ => null
    }
}

/**
 * Gate a `TAssign`: only a bare-`Reference` simple-name reassign is a ref-to-local; a field / deref
 * write names no single ref-to-local pair.
 *
 * @param TAssign a  the typed assignment
 * @param Spine spine  the function's spine fact
 * @return error?  null when sound, else the reject error
 */
fn check_ref_assign_storable(a: TAssign, spine: Spine) -> error? {
    match a.kind {
        parser::AssignKind::Simple => match a.bound { Reference => ref_borrow_or_error(spine, a.name, a.value); _ => null }
        _ => null
    }
}

/**
 * The core spine query for one ref-to-local site: ADMIT iff `ref_target_outlives(borrow = the storage
 * local's cell, referent = the RHS source cell)` holds. The bf-inherit writer set `bf[borrow] =
 * BfParam` so the tag is meaningful; an un-nameable RHS or an un-found cell (`cell_of == -1`) is a
 * conservative reject with the UNCHANGED R5 diagnostic (no fixture drift).
 *
 * @param Spine spine  the function's spine fact
 * @param str target  the ref-to-local binding/assign's storage local name
 * @param TExpr value  the RHS expression (its bare-`TVar` name is the referent)
 * @return error?  null when the borrow provably outlives, else the R5 reject error
 */
fn ref_borrow_or_error(spine: Spine, target: str, value: TExpr) -> error? {
    let borrow = cell_of(spine, target)
    let referent = cell_of(spine, alias_src_name(value))
    if borrow >= 0 {
        if referent >= 0 {
            if ref_target_outlives(spine, borrow to u32, referent to u32) { return null }
        }
    }
    error { message = "a reference cannot be bound to a local (parameter-only in this version)" }
}

/**
 * Type-checks a top-level namespace FUNCTION's body, producing the fully typed `TFunction` item
 * (an `extern` declaration is bodyless and returns early with an empty body — its return/param
 * marshalling is still validated).
 *
 * @param parser::Function f  the function to type-check
 * @param Env env  the typing environment
 * @param TypeTable table  the folded type table
 * @return TFunction | error  the typed function
 *               bad return/trailing value, a label failure, or (U2, §2) a param/return/local of
 *               unsafe type when `f` itself is not `unsafe` — a top-level fn has no owner to OR
 *               in (unlike a method, see `type_method`), so only `f.is_unsafe` itself governs
 */
fn type_function(f: parser::Function, env: Env, table: TypeTable) -> TFunction | error {
    mut local = with_fn_unsafe(env, f.is_unsafe)
    let tbl = type_param_table(f.type_params, f.type_constraints, "", table)   // (S4) the fn's generic type-params, opaque, in scope
    let is_teko_rt = f.is_extern && f.from_lib == "teko_rt"   // C7.2: bypass for Teko's own runtime
    mut i = 0
    loop {
        if i >= f.params.len { break }
        if !f.params[i].has_type && f.params[i].name == "_" {
            return error { message = "a `_` discard parameter is only allowed when implementing an interface method or overriding a base method — a plain function must name its parameters" }
        }
        let pt = match resolve_type(f.params[i].type_ann, tbl, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the fn's enclosing namespace
        if f.is_extern {
            if is_teko_rt {
                if !teko_rt_type_ok(pt) {
                    return error { message = "a `teko_rt` extern function parameter must be a primitive, `str`, slice, variant, or optional (C7.2)" }
                }
            } else {
                if !extern_type_ok(pt, table) {
                    return error { message = "an `extern` function parameter must be a primitive (int/float/bool), `byte`, `ptr`, `uptr`, or an `extern type` handle (C7.1a)" }
                }
            }
        }
        local = define(local, f.params[i].name, pt, false)   // params are immutable (B.21)
        i++
    }
    if f.has_inject {
        local = match seed_di_injects(f, local, tbl) { Env as e => e; error as e => return e }
    }
    let ret = match function_return(f, tbl, env.cur_ns) { Type as t => t; error as e => return e }   // (#109 W1) ref_ns = the fn's enclosing namespace
    // (MEM Step 0, R3) ESCAPE GATE — a function cannot RETURN a reference (pass-down only): a
    // returned ref would outlive its caller-stack target. References flow only DOWN as params.
    match ret { Reference => return error { message = "a function cannot return a reference (pass-down only)" }; _ => { } }
    if f.is_extern {
        // an extern is a bodyless foreign declaration (no body to check / return-analyze).
        // Validate the return marshals (void = no value is fine; else prim/byte only for now).
        let ret_ok = if is_teko_rt {
            teko_rt_type_ok(ret)
        } else {
            match ret { Void => true; _ => extern_type_ok(ret, table) }
        }
        if !ret_ok {
            return error { message = "an `extern` function return must be a primitive (int/float/bool), `byte`, `ptr`, `uptr`, an `extern type` handle, or absent (C7.1a)" }
        }
        let no_body: []TStatement = teko::list::empty()
        return TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = f.params; return_type = ret; body = no_body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = ""; file = ""; line = 0; col = 0; is_test = f.is_test; is_extern = true; c_symbol = f.c_symbol; from_lib = f.from_lib }
    }
    let tb = match type_block(f.body, local, tbl) { TypedBlock as bk => bk; error as e => return e }
    match check_returns(tb.stmts, ret, table) { null => { }; error as e => return e }   // C5: each `return e` matches `ret`
    match check_trailing_value(tb.stmts, ret, table) { null => { }; error as e => return e }   // C5: trailing value (when present) matches
    let lc = check_labels(tb.stmts, teko::list::empty(), false, teko::list::empty())   // W5-cf-2: loop labels resolve + are unique
    if lc.failed { return error { message = lc.message } }
    match check_must_free(f, tbl, env.cur_ns, tb.stmts, table) { null => { }; error as e => return e }
    let tf = TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = f.params; return_type = ret; body = tb.stmts; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = ""; file = ""; line = 0; col = 0; is_test = f.is_test; is_extern = false; c_symbol = ""; from_lib = "" }   // (#49/E3) namespace/file/line stamped by type_item from the parsed item
    match check_ref_storability(tf) { null => { }; error as e => return e }
    tf
}

// (OOP A1, 2026-07-01) type-check EVERY method body on a struct TypeDecl and stamp each into a
// full TFunction item (namespace = "<owning-ns>::<StructName>", mirroring collect_funcs'
// registration exactly, so codegen/VM mangle+resolve method calls to these SAME items). Called
// from both type_program and type_program_with_deps' main loops, alongside the ordinary
// TypeDecl pass-through — a struct with methods contributes MULTIPLE TItems, not one.
fn type_struct_methods(td: parser::TypeDecl, item_ns: str, file: str, env: Env, table: TypeTable) -> []TItem | error {
    // (W10b.CLASS) a class's methods are typed/stamped by this SAME pass — only the methods
    // list's source differs; a class method is otherwise identical to a struct method. Increment
    // 2: stamps the EFFECTIVE (base-inherited + overridden) methods against THIS class's own
    // name — an inherited-not-overridden method's body is re-typed/re-emitted per owning class
    // (no vtable/dispatch yet). An `abstract fn` signature (no body, never overridden by THIS
    // class) has nothing to emit — skipped.
    mut methods: []parser::Function = teko::list::empty()
    mut has_base_binding = false
    mut base_binding_name = ""
    mut base_name = ""
    mut is_class = false
    mut own_names: []str = teko::list::empty()   // (W10b.CLASS) methods declared DIRECTLY on td — the base-binding is only ever injected for these (see below)
    match td.body {
        parser::StructBody as sb => { methods = sb.methods }
        parser::ClassBody as cb => {
            methods = match effective_class_methods(cb, table) { []parser::Function as f => f; error as e => return e }
            has_base_binding = cb.has_base_binding
            base_binding_name = cb.base_binding_name
            base_name = cb.base_name
            is_class = true
            mut oi = 0
            loop { if oi >= cb.methods.len { break }; own_names = teko::list::push(own_names, cb.methods[oi].name); oi++ }
        }
        _ => { }
    }
    mut out: []TItem = teko::list::empty()
    let method_ns = if item_ns == "" { td.name } else { item_ns ~ "::" ~ td.name }
    mut mi = 0
    loop {
        if mi >= methods.len { break }
        if methods[mi].is_abstract { mi++; continue }
        // (W10b.CLASS) the base-binding is injected ONLY for a method DECLARED DIRECTLY on THIS
        // class (own or an override) — a PURELY inherited method (never touched by this class)
        // keeps its ORIGINAL declaring class's own context; re-typing it under a DIFFERENT
        // derived class must NOT inject a binding that method's body never asked for (it would
        // either be spuriously unused, or — worse — silently shadow an ancestor's OWN binding of
        // the same name in a 3+-level chain).
        let use_base_binding = has_base_binding && str_set_has(own_names, methods[mi].name)
        // (W10b.CLASS residual — intern visibility) the ACCESSOR context for THIS method body's
        // OWN field/method accesses: the class that ORIGINALLY DECLARED it (itself, if own/an
        // override; the ancestor that declared it, if purely inherited) — NEVER td.name when the
        // two differ, for the exact same reason as the base-binding fix above.
        let declaring_class = if is_class {
            match find_method_owner(td.name, table, methods[mi].name) { MemberOwner as mo => mo.declaring_class; error => td.name }
        } else {
            td.name
        }
        let mf = match type_method(methods[mi], td.name, env, table, use_base_binding, base_binding_name, base_name, declaring_class) {
            TFunction as x => x
            error as e => return surface_at(file, methods[mi].line, methods[mi].col, e)
        }
        let stamped = TFunction { name = mf.name; type_params = mf.type_params; type_constraints = mf.type_constraints; params = mf.params; return_type = mf.return_type; body = mf.body; vis = mf.vis; has_doc = mf.has_doc; doc = mf.doc; namespace = method_ns; file = file; line = methods[mi].line; col = methods[mi].col; is_test = mf.is_test; is_extern = mf.is_extern; c_symbol = mf.c_symbol; from_lib = mf.from_lib }
        out = teko::list::push(out, stamped)
        mi++
    }
    out
}

/**
 * type_const_decl — pass-2 typing for a module-level constant (#594 crumb 4): resolve the declared
 * type, type the initializer against it (adopting a fitting bare literal to the declared narrow
 * width exactly as `type_binding` does, so `const K: u8 = 300` reports an out-of-range error while
 * `const K: u8 = 1` narrows the leaf), then gate the checked initializer through `is_const_expr`
 * (the D1 grammar). The returned TConstDecl carries the checked initializer the inliner substitutes
 * at each use site; its `namespace` is seeded from `env.cur_ns` and re-stamped by `type_item` from
 * the item's provenance.
 *
 * @param cd     the parsed const declaration
 * @param env    the pass-2 environment (top-level names — including sibling consts — bound)
 * @param table  the program's type table
 * @return       the typed constant, or a located error on a type mismatch, an out-of-range literal,
 *               a `void`/element-less initializer, or a non-const initializer form
 * @throws       a type-mismatch error (expected the declared type, found the initializer's) when the
 *               initializer neither is assignable to nor adopts the declared type; the `is_const_expr`
 *               error naming the offending form when the initializer is not a legal const-expr
 * @since #594
 */
fn type_const_decl(cd: parser::ConstDecl, env: Env, table: TypeTable) -> TConstDecl | error {
    let at = match resolve_type(cd.ty, table, env.cur_ns) { Type as t => t; error as e => return e }
    mut v = match type_value_expected(cd.init, at, env, table) { TExpr as te => te; error as e => return e }
    if type_is_void(v.type) { return error { message = "a const initializer cannot be a `void` expression — it yields no value (M.1)" } }
    if !assignable_to(v.type, at, table) {
        match annotated_literal_ok(cd.init, at) {
            null => v = retype_literal(v, at)
            error as e => return teko::error::err_typed(e, type_render(at), type_render(v.type))
        }
    }
    let at_is_sentinel_slice = match at { Slice as bs => match bs.element { Void => true; _ => false }; _ => false }
    if at_is_sentinel_slice {
        return error { message = "a const of an element-less slice type needs a concrete element (e.g. `const XS: []u8 = …`)" }
    }
    let v_is_sentinel_slice = match v.type { Slice as vs => match vs.element { Void => true; _ => false }; _ => false }
    if v_is_sentinel_slice { v = TExpr { kind = v.kind; type = at; line = v.line; col = v.col } }
    match is_const_expr(v, table, env) { error as e => return e; null => { } }
    TConstDecl { name = cd.name; namespace = env.cur_ns; ty = at; init = v; vis = cd.vis; has_doc = cd.has_doc; doc = cd.doc; line = cd.line; col = cd.col }
}

fn type_item(item: parser::Item, env: Env, table: TypeTable) -> TItem | error {
    match item.content {
        parser::Function as f => {
            let tf = match type_function(f, env, table) { TFunction as x => x; error as e => return e }
            // (#49) stamp the declaring namespace from the parsed item so codegen mangles the C name.
            TFunction { name = tf.name; type_params = tf.type_params; type_constraints = tf.type_constraints; params = tf.params; return_type = tf.return_type; body = tf.body; vis = tf.vis; has_doc = tf.has_doc; doc = tf.doc; namespace = item.namespace; file = item.file; line = f.line; col = f.col; is_test = tf.is_test; is_extern = tf.is_extern; c_symbol = tf.c_symbol; from_lib = tf.from_lib }
        }
        parser::TypeDecl as td => {
            // (#109 W3) CANONICALIZE the decl name to "ns::Name" so codegen emits a namespace-distinct
            // typedef (matching the canonical Named.name at every USE). A generic `__g__` instance keeps
            // its already-unique bare name. Resolution stays bare-keyed (this is the TYPED program only).
            let cd = if name_is_g_instance(td.name) { td } else {
                parser::TypeDecl { name = qualify(item.namespace, td.name); type_params = td.type_params; type_constraints = td.type_constraints; body = td.body; vis = td.vis; has_doc = td.has_doc; doc = td.doc; line = td.line; col = td.col; di_kind = td.di_kind; has_di_key = td.has_di_key; di_key = td.di_key; is_unsafe = td.is_unsafe; must_free = td.must_free }
            }
            normalize_inst_decl(cd, table)   // (W9.4) rewrite `Gen<i64>` member refs to the bare stamped `Gen__g__i64` (no-op when none); else passes through (collect resolved its fields)
        }
        parser::UseDecl as ud => ud   // seed no-op (alias resolution is the checker's, later)
        parser::Statement as s => {
            let ts = match type_statement(s, env, table) { TypedStmt as x => x; error as e => return e }
            ts.node
        }
        parser::ConstDecl as cd => {
            let ti = match type_const_decl(cd, env, table) { TConstDecl as x => x; error as e => return e }
            TConstDecl { name = ti.name; namespace = item.namespace; ty = ti.ty; init = ti.init; vis = ti.vis; has_doc = ti.has_doc; doc = ti.doc; line = cd.line; col = cd.col }
        }
    }
}

// (C1.8/E2) surface an inner checker error at the program level — mirror of typer.c's surface_at.
// PREFER the inner error's own line/col over the item's (an inner-expr position wins — C1-POS),
// build the LOCATED message string (diag_at — file:line:col baked in, the fallback the driver
// prints when it can't read the file), then re-attach the STRUCTURED file/line/col (err_loc) and
// PRESERVE the inner error's expected/actual (err_typed) so a type mismatch still renders
// "expected X, found Y" after surfacing.
fn surface_at(file: str, item_line: u32, item_col: u32, inner: error) -> error {
    let el = if inner.line != 0 { inner.line } else { item_line }
    let ec = if inner.line != 0 { inner.col } else { item_col }
    let located = error { message = diag_at(file, el, ec, inner.message) }   // located string (fallback)
    let positioned = teko::error::err_loc(located, el, ec)   // structured position (renderer)
    teko::error::err_typed(positioned, inner.expected, inner.actual)   // preserve expected/actual (C1.8)
}

/**
 * A per-item progress hook, invoked `(done, total)` after each top-level item is
 * typed. Lets a caller (the `teko build` observability layer, `teko::build`) report
 * a live "N/M items" counter for the checker phase without the checker depending on
 * anything outside itself — the caller supplies the closure; the checker only ever
 * calls it.
 *
 * @param done   how many top-level items have been typed so far
 * @param total  the total top-level item count for this program
 */
pub type ProgressFn = (u64, u64) -> void

/**
 * `type_program_with_deps`'s result BEFORE monomorphization: the checked program
 * (still carrying its generic templates) plus the resolved `TypeTable`
 * `monomorphize` needs. Exposed so the build driver can time and report
 * monomorphization as its OWN phase, instead of it running silently inside
 * `type_program_with_deps`.
 */
pub type PreMono = struct {
    /** the checked program, before monomorphization */
    prog: TProgram
    /** the resolved type table, as `monomorphize` expects it */
    table: TypeTable
}

/**
 * The no-op `ProgressFn` `type_program_with_deps` passes to
 * `type_program_with_deps_pre_mono` when its caller wants no per-item progress
 * reporting (the original, pre-observability contract).
 *
 * @param done   how many top-level items have been typed so far (ignored)
 * @param total  the total top-level item count (ignored)
 */
fn no_item_progress(done: u64, total: u64) -> void { }

/**
 * The DEP-AWARE TYPED ENTRY POINT (C7.10). Same as `type_program` but pre-seeds the
 * collection environment from an already-typed dep `TProgram` before collecting and
 * typing the project, then MONOMORPHIZES the result (S4b) — a thin wrapper over
 * `type_program_with_deps_pre_mono` with no progress reporting, preserving this
 * function's original contract for its non-observability callers. The dep's items
 * are NOT re-typed; only their signatures enter scope so the project's code can
 * call dep functions and reference dep types. `dep_prog.items` is empty when there
 * are no deps -> degrades silently to `type_program`'s behavior.
 *
 * @param raw_program  the merged, un-typed program (project items only)
 * @param dep_prog     the already-typed dependency program (empty when depless)
 * @return             the fully checked and monomorphized program
 * @throws             the first collection/typing/monomorphization error
 */
pub fn type_program_with_deps(raw_program: parser::Program, dep_prog: TProgram) -> TProgram | error {
    let pre = match type_program_with_deps_pre_mono(raw_program, dep_prog, no_item_progress) { PreMono as p => p; error as e => return e }
    let mono = match monomorphize(pre.prog, pre.table) { TProgram as mp => mp; error as e => return e }
    inline_consts(mono)
}

/**
 * `type_program_with_deps`, split just BEFORE monomorphization (see `PreMono`) and
 * instrumented with a per-item progress hook (see `ProgressFn`) — the entry point
 * the build driver uses to report the `checker` phase's live "N/M items" counter
 * and time monomorphization as its own separate phase.
 *
 * @param raw_program  the merged, un-typed program (project items only)
 * @param dep_prog     the already-typed dependency program (empty when depless)
 * @param on_item      called `(done, total)` after each top-level item is typed
 * @return             the checked program (pre-monomorphization) and its type table
 * @throws             the first collection/typing error
 */
pub fn type_program_with_deps_pre_mono(raw_program: parser::Program, dep_prog: TProgram, on_item: ProgressFn) -> PreMono | error {
    // (TR0) FOLD trait derivations first — PROJECT-LOCAL only (a dep's traits don't fold here:
    // the .tkb codec does not carry trait bodies — the same method-serialization gap as
    // struct/class methods — so a dep trait name in an `&`-list surfaces as the conformance
    // check's honest "not an interface" error rather than a silent half-fold).
    let program0 = match fold_traits(raw_program) { parser::Program as p => p; error as e => return e }
    let program = canon_class_bases(program0)   // (#152) base_name -> qualified, order-independent base hops
    // Seed from dep first (build base table + env from dep's type decls + fn signatures).
    let seed_empty = Collected { types = teko::list::empty(); env = env_empty() }
    let seed = match seed_from_dep(dep_prog, seed_empty.types, seed_empty.env) {
        Collected as s => s
        error as e => return e
    }
    // Collect from the project on top of the seed.
    let c = match collect_with_seed(program, seed) { Collected as col => col; error as e => return e }
    // W-vis-enforce: enforce the module system over the project's own items.
    // We only check the project's items (not dep items — they were checked when the dep was built).
    match check_modules(program, c.types) { null => { }; error as e => return e }
    match check_di(program, c.types) { null => { }; error as e => return e }
    let di_reg = match build_di_registry(program, c.types) { DiRegistry as r => r; error as e => return e }
    // (S4 type-generics) stamp concrete decls for written generic uses before typing (no-op when none).
    let types = instantiate_types(program, c.types)
    let menv = match register_instance_methods(c.env, types) { Env as e => e; error as e => return e }
    let cenv = with_di(seal(menv), di_reg)
    mut items: []TItem = teko::list::empty()
    mut mainbody: []TStatement = teko::list::empty()
    mut cur = cenv
    mut i = 0
    loop {
        if i >= program.items.len { break }
        let it = program.items[i]
        // (#41) mirror typer.c (tk_type_program_with_deps line 689: `cur.cur_ns = it.namespace;`):
        // same fix as type_program — set cur_ns per item so a loose main.tks statement's unqualified
        // same-namespace call resolves. See type_program's comment for the full rationale.
        cur = with_ns(cur, it.namespace)
        let ienv = with_ns(cenv, it.namespace)
        mut line: u32 = 0
        mut col: u32 = 0
        match it.content {
            parser::Function as f => { line = f.line; col = f.col }
            parser::TypeDecl as td => { line = td.line; col = td.col }
            parser::ConstDecl as cd => { line = cd.line; col = cd.col }
            _ => { }
        }
        match it.content {
            parser::Statement as s => {
                let ts = match type_statement(s, cur, types) {
                    TypedStmt as x => x
                    error as e => return surface_at(it.file, line, col, e)
                }
                items = teko::list::push(items, ts.node)
                mainbody = teko::list::push(mainbody, ts.node)
                cur = ts.env
            }
            _ => {
                let ti = match type_item(it, ienv, types) {
                    TItem as x => x
                    error as e => return surface_at(it.file, line, col, e)
                }
                items = teko::list::push(items, ti)
                // (OOP A1) a struct TypeDecl also contributes its METHOD bodies as extra items.
                match it.content {
                    parser::TypeDecl as td => {
                        let mitems = match type_struct_methods(td, it.namespace, it.file, ienv, types) { []TItem as x => x; error as e => return e }
                        mut mi2 = 0
                        loop { if mi2 >= mitems.len { break }; items = teko::list::push(items, mitems[mi2]); mi2++ }
                    }
                    _ => { }
                }
            }
        }
        i++
        on_item(i to u64, program.items.len to u64)
    }
    let lc = check_labels(mainbody, teko::list::empty(), false, teko::list::empty())
    if lc.failed { return error { message = lc.message } }
    // For the result, prepend dep items so the TProgram contains the full program (dep + project).
    // This allows subsequent operations (codegen, VM, coverage) to see all items.
    mut all_items: []TItem = teko::list::empty()
    mut di: u64 = 0
    loop {
        if di >= dep_prog.items.len { break }
        all_items = teko::list::push(all_items, dep_prog.items[di])
        di++
    }
    mut pi: u64 = 0
    loop {
        if pi >= items.len { break }
        all_items = teko::list::push(all_items, items[pi])
        pi++
    }
    let tp = TProgram { items = all_items }
    PreMono { prog = tp; table = types }
}

// THE TYPED ENTRY POINT: pass 1 (collect top-level names) + pass 2 (type each item).
pub fn type_program(raw_program: parser::Program) -> TProgram | error {
    // (TR0) FOLD trait derivations FIRST — every later stage (collect, conformance, typing,
    // codegen layout, the VM) sees each deriver's already-folded body; a trait decl itself stays
    // registered (for honest value-position/instantiation errors) but is never emitted.
    let program0 = match fold_traits(raw_program) { parser::Program as p => p; error as e => return e }
    let program = canon_class_bases(program0)   // (#152) base_name -> qualified, order-independent base hops
    let c = match collect(program) { Collected as col => col; error as e => return e }
    // W-vis-enforce: enforce the module system (namespace qualification + pub/exp) over the
    // whole flattened program before typing — fail loud on any cross-namespace violation (M.1).
    match check_modules(program, c.types) { null => { }; error as e => return e }
    match check_di(program, c.types) { null => { }; error as e => return e }
    let di_reg = match build_di_registry(program, c.types) { DiRegistry as r => r; error as e => return e }
    // (S4 type-generics) STAMP concrete decls for written generic uses (`Box<i64>`) into the table
    // before typing, so field-access / struct-init see concrete fields. No-op when none are used.
    let types = instantiate_types(program, c.types)
    let menv = match register_instance_methods(c.env, types) { Env as e => e; error as e => return e }
    let cenv = with_di(seal(menv), di_reg)
    mut items: []TItem = teko::list::empty()
    mut mainbody: []TStatement = teko::list::empty()   // the loose top-level statements (the virtual-main), for label validation
    mut cur = cenv   // threaded virtual-main scope: each loose binding extends it for the next statement (mirrors typer.c's `cur`)
    mut i = 0
    loop {
        if i >= program.items.len { break }
        let it = program.items[i]
        // (#41) mirror typer.c (tk_type_program line 749: `cur.cur_ns = it.namespace;`): set the
        // namespace being type-checked on the THREADED virtual-main scope BEFORE typing a loose
        // top-level statement, so an UNQUALIFIED same-namespace call from main.tks (e.g.
        // `use_counter(21)` resolving to a fn defined in another file of the same project) matches
        // via lookup_call's `b.ns == env.cur_ns` clause. Without this, loose statements were typed
        // with cur_ns="" (from env_empty) → cross-file top-level fns reported "unknown function".
        // with_ns preserves cur's accumulated bindings (prior loose `let`s stay visible).
        cur = with_ns(cur, it.namespace)
        let ienv = with_ns(cenv, it.namespace)   // (#41) resolve this item's calls in its namespace
        // W-loc-2: the item's source file + the decl's line:col, so a type error in the
        // flattened program resolves to file:line:col (loose statements carry no loc → file only).
        mut line: u32 = 0
        mut col: u32 = 0
        match it.content {
            parser::Function as f => { line = f.line; col = f.col }
            parser::TypeDecl as td => { line = td.line; col = td.col }
            parser::ConstDecl as cd => { line = cd.line; col = cd.col }
            _ => { }
        }
        // a loose top-level Statement is typed directly so its node also feeds the virtual-main's
        // label validation below (mirrors typer.c's separate `mainbody` accumulator).
        // (C1-POS/C1.8/E2) surface_at prefers the ERROR's own line/col over the item's (inner-expr
        // position wins), bakes file:line:col into the message (diag_at fallback), sets the STRUCTURED
        // file/line/col (err_loc) AND preserves expected/actual (err_typed) — mirror of typer.c's
        // surface_at. The error value now carries those adornments per the E2 contract.
        match it.content {
            parser::Statement as s => {
                // type with the THREADED scope `cur` (not the base env) so a loose `let args = …`
                // is visible to the following statements; advance `cur` to the binding's env.
                let ts = match type_statement(s, cur, types) {
                    TypedStmt as x => x
                    error as e => return surface_at(it.file, line, col, e)
                }
                items = teko::list::push(items, ts.node)
                mainbody = teko::list::push(mainbody, ts.node)
                cur = ts.env
            }
            _ => {
                let ti = match type_item(it, ienv, types) {
                    TItem as x => x
                    error as e => return surface_at(it.file, line, col, e)
                }
                items = teko::list::push(items, ti)
                // (OOP A1) a struct TypeDecl also contributes its METHOD bodies as extra items.
                match it.content {
                    parser::TypeDecl as td => {
                        let mitems = match type_struct_methods(td, it.namespace, it.file, ienv, types) { []TItem as x => x; error as e => return e }
                        mut mi2 = 0
                        loop { if mi2 >= mitems.len { break }; items = teko::list::push(items, mitems[mi2]); mi2++ }
                    }
                    _ => { }
                }
            }
        }
        i++
    }
    let lc = check_labels(mainbody, teko::list::empty(), false, teko::list::empty())   // W5-cf-2: validate labels in the virtual-main
    if lc.failed { return error { message = lc.message } }
    let tp = TProgram { items = items }
    let mono = match monomorphize(tp, types) { TProgram as mp => mp; error as e => return e }
    inline_consts(mono)
}
