use teko::parser

/** e_path2 — a two-segment path expression `a::b` (a namespace-qualified value or `Type::Member`). */
fn e_path2(a: str, b: str) -> parser::Expr { ek(parser::PathExpr { path = parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = a }), parser::Segment { name = b }) } }) }

/**
 * fn_body_of — walk a typed program's items to the `TFunction` named `name` and return its typed
 * body. Asserts the fn exists: a `TProgram` without it fails the calling test.
 *
 * @param tp    the typed program to scan
 * @param name  the wanted fn's name
 * @return      the named fn's typed body
 */
fn fn_body_of(tp: TProgram, name: str) -> []TStatement {
    mut found = false
    mut body: []TStatement = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= tp.items.len { break }
        match tp.items[i] {
            TFunction as f => if f.name == name {
                found = true
                body = f.body
            }
            _ => { }
        }
        i++
    }
    teko::assert::is_true(found)
    body
}

/**
 * first_stmt_expr_of — the expression kind of the FIRST statement of the fn named `name` in a typed
 * program. Asserts the fn exists and its first statement is a `TExprStmt`; the const-inliner tests
 * pin the substituted initializer by matching the returned kind.
 *
 * @param tp    the typed program to scan
 * @param name  the wanted fn's name
 * @return      the kind of the fn's first statement-expression
 */
fn first_stmt_expr_of(tp: TProgram, name: str) -> TExprKind {
    let body = fn_body_of(tp, name)
    mut kind: TExprKind = TNullLit { }
    match body[0] {
        TExprStmt as es => kind = es.expr.kind
        _ => teko::assert::is_true(false)
    }
    kind
}

/**
 * assert_first_stmt_num — assert the fn named `name` in a typed program has, as its first statement,
 * a statement-expression whose kind is a `TNumber` carrying `expected` — the shape a scalar const
 * read collapses to after `inline_consts` substitutes the initializer.
 *
 * @param tp        the typed program to scan
 * @param name      the wanted fn's name
 * @param expected  the substituted integer value the first statement must carry
 */
fn assert_first_stmt_num(tp: TProgram, name: str, expected: i128) {
    match first_stmt_expr_of(tp, name) {
        TNumber as n => teko::assert::is_true(n.value == expected)
        _ => teko::assert::is_true(false)
    }
}

/** collects_const_forward_ref_resolves_in_pass1 — a fn body that reads a `const` declared LATER in
    the file type-checks: pass-1 collect resolves the const's declared type and binds its name, so
    the forward reference resolves before pass-2 (#594 crumb 2, collect_const_sig + define_const). */
#test
fn collects_const_forward_ref_resolves_in_pass1() {
    let uses_k = mk_fn("uses_k", named_t("i64"), one_stmt(e_var("K")))
    let k = parser::ConstDecl { name = "K"; ty = named_t("i64"); init = e_num(1); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 2; col = 1 }
    let fn_item = parser::Item { content = uses_k; namespace = ""; file = "" }
    let const_item = parser::Item { content = k; namespace = ""; file = "" }
    let items: []parser::Item = teko::list::push(teko::list::push(teko::list::empty(), fn_item), const_item)
    let table = collect_types(items)
    let env = match collect_funcs(items, table) { Env as e => e; error => { teko::assert::is_true(false); return } }
    let kb = match lookup_binding(env, "K") { ValBinding as b => b; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(kb.type, PrimKind::I64))
    teko::assert::is_true(kb.is_const)
    match type_function(uses_k, env, table) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

/**
 * type_program_with_deps_resolves_const_forward_ref — the REAL CLI build path
 * (`checked_program_of` → `type_program_with_deps` → `collect_with_seed`) binds EVERY module-level
 * const's name in pass-1 before any initializer is typed, so a const whose initializer FORWARD-
 * references a const declared LATER in the file resolves, and the dependency-ordered inliner
 * substitutes it. `const B: i64 = A + 1` sits ABOVE `const A: i64 = 1`; `uses_b` reads `B`. The
 * scalar inliner substitutes `A` into `B`'s initializer (`1 + 1`) and `B` into `uses_b`'s body, and
 * the comptime-fold pass (CF) then collapses the const-known op-tree `1 + 1` to the literal `2` — the
 * read becomes `TNumber{2}` (#594 crumb 2 + comptime-fold). The with-deps companion of
 * `collects_const_forward_ref_resolves_in_pass1` (which only exercised `type_program`/`collect_funcs`);
 * the dep program is EMPTY — the single-project path every `teko build` takes. A pass-1 that failed to
 * bind `A` before typing `B`'s initializer would surface "undefined name: A" here instead of a `TProgram`.
 */
#test
fn type_program_with_deps_resolves_const_forward_ref() {
    let b_init = ek(parser::Binary { op = lexer::TokenKind::Plus; left = e_var("A"); right = e_num(1) })
    let b = parser::ConstDecl { name = "B"; ty = named_t("i64"); init = b_init; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    let a = parser::ConstDecl { name = "A"; ty = named_t("i64"); init = e_num(1); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 2; col = 1 }
    let uses_b = mk_fn("uses_b", named_t("i64"), one_stmt(e_var("B")))
    mut items: []parser::Item = teko::list::empty()
    items = teko::list::push(items, parser::Item { content = b; namespace = ""; file = "app.tks" })
    items = teko::list::push(items, parser::Item { content = a; namespace = ""; file = "app.tks" })
    items = teko::list::push(items, parser::Item { content = uses_b; namespace = ""; file = "app.tks" })
    let empty_dep = TProgram { items = teko::list::empty() }
    match type_program_with_deps(parser::Program { items = items }, empty_dep) {
        TProgram as tp => match first_stmt_expr_of(tp, "uses_b") {
            TNumber as n => teko::assert::is_true(n.value == 2)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * ctt_struct_with_const — a minimal struct `TypeDecl` named `name` declaring exactly ONE static
 * member const (`const_name: i64 = value`), used to drive `Type::NAME` resolution through the REAL
 * build path without any unrelated field/method noise.
 *
 * @param name        the struct's bare name
 * @param const_name  the member const's name
 * @param value       the member const's `i64` initializer value
 * @return            a member-less-field struct `TypeDecl` carrying that one const
 */
fn ctt_struct_with_const(name: str, const_name: str, value: i128) -> parser::TypeDecl {
    let cd = parser::ConstDecl { name = const_name; ty = named_t("i64"); init = e_num(value); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1 }
    let consts: []parser::ConstDecl = teko::list::push(teko::list::empty(), cd)
    parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::empty(); methods = teko::list::empty(); implements = teko::list::empty(); consts = consts }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
}

/**
 * type_program_with_deps_inlines_member_const — the REAL build path (`type_program_with_deps`, which
 * runs `type_type_member_consts` (the hoist) then `inline_consts` (the substitution)) resolves
 * `Point::ORIGIN_X` and SUBSTITUTES its value, leaving no `TVar` naming the hoisted symbol — the
 * regression the CI positive-runner caught (#594): `find_member_const` stamped `func_ns = ""` while
 * the hoist stamps its `TConstDecl.namespace` to the type's OWN declaring namespace, so the c8b
 * `(name, namespace)`-keyed inliner's ref key never matched the hoisted const's key and the raw
 * `member_const_symbol`-shaped name (containing `::`) survived to codegen as an invalid C identifier.
 * `func_ns` must equal `owner_ns` — the SAME namespace `type_type_member_consts` hoists under.
 */
#test
fn type_program_with_deps_inlines_member_const() {
    let point = ctt_struct_with_const("Point", "ORIGIN_X", 7)
    let uses_origin = mk_fn("uses_origin", named_t("i64"), one_stmt(e_path2("Point", "ORIGIN_X")))
    mut items: []parser::Item = teko::list::empty()
    items = teko::list::push(items, parser::Item { content = point; namespace = "app"; file = "app.tks" })
    items = teko::list::push(items, parser::Item { content = uses_origin; namespace = "app"; file = "app.tks" })
    let empty_dep = TProgram { items = teko::list::empty() }
    match type_program_with_deps(parser::Program { items = items }, empty_dep) {
        TProgram as tp => assert_first_stmt_num(tp, "uses_origin", 7)
        error => teko::assert::is_true(false)
    }
}

/**
 * type_program_with_deps_inlines_inherited_member_const — the inheritance leg of the SAME regression:
 * `Sub` (a `class Base`, ABSTRACT base) declares NO member const of its own, so `Sub::K` resolves
 * through the base chain to `Base`'s `K`, and the hoist RE-MATERIALIZES it under `Sub`'s OWN name
 * (`type_type_member_consts` re-emits a class's EFFECTIVE — base-inherited — consts per owning class,
 * mirroring how an inherited method is re-emitted). `find_member_const`'s `owner` is `Sub` (the
 * resolved leading type), so `owner_ns` must be `Sub`'s OWN declaring namespace for the ref to key
 * onto `Sub`'s re-materialized hoist entry, not `Base`'s.
 */
#test
fn type_program_with_deps_inlines_inherited_member_const() {
    let base_k = parser::ConstDecl { name = "K"; ty = named_t("i64"); init = e_num(5); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1 }
    let base_consts: []parser::ConstDecl = teko::list::push(teko::list::empty(), base_k)
    let base = parser::TypeDecl { name = "Base"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Abstract; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = teko::list::empty(); methods = teko::list::empty(); consts = base_consts }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let sub = parser::TypeDecl { name = "Sub"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = true; base_name = "Base"; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = teko::list::empty(); methods = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let uses_sub_k = mk_fn("uses_sub_k", named_t("i64"), one_stmt(e_path2("Sub", "K")))
    mut items: []parser::Item = teko::list::empty()
    items = teko::list::push(items, parser::Item { content = base; namespace = "app"; file = "app.tks" })
    items = teko::list::push(items, parser::Item { content = sub; namespace = "app"; file = "app.tks" })
    items = teko::list::push(items, parser::Item { content = uses_sub_k; namespace = "app"; file = "app.tks" })
    let empty_dep = TProgram { items = teko::list::empty() }
    match type_program_with_deps(parser::Program { items = items }, empty_dep) {
        TProgram as tp => assert_first_stmt_num(tp, "uses_sub_k", 5)
        error => teko::assert::is_true(false)
    }
}

/** collects_const_unknown_type_is_located_error — a `const` whose declared type names no known type
    yields an error positioned at the const's own line/col, not a silent success (#594 crumb 2). */
#test
fn collects_const_unknown_type_is_located_error() {
    let bad = parser::ConstDecl { name = "B"; ty = named_t("Nonexistent"); init = e_num(1); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 7; col = 3 }
    match collect_const_sig(bad, empty_table(), "") {
        Type => teko::assert::is_true(false)
        error as e => {
            teko::assert::is_true(e.line == 7)
            teko::assert::is_true(e.col == 3)
        }
    }
}

/** type_const_u8_out_of_range_errors — `const A: u8 = 300` fails typing: the initializer does not
    fit the declared narrow width, so `type_const_decl` returns a range/type error (#594 crumb 4). */
#test
fn type_const_u8_out_of_range_errors() {
    let cd = parser::ConstDecl { name = "A"; ty = named_t("u8"); init = e_num(300); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    match type_const_decl(cd, empty_env(), empty_table()) {
        TConstDecl => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

/** type_const_i64_ok — `const A: i64 = 1` types successfully to a TConstDecl carrying the resolved
    i64 value type and a typed initializer usable as a value (#594 crumb 4). */
#test
fn type_const_i64_ok() {
    let cd = parser::ConstDecl { name = "A"; ty = named_t("i64"); init = e_num(1); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    match type_const_decl(cd, empty_env(), empty_table()) {
        TConstDecl as tc => {
            teko::assert::is_true(tc.name == "A")
            teko::assert::is_true(prim_is(tc.ty, PrimKind::I64))
            teko::assert::is_true(prim_is(tc.init.type, PrimKind::I64))
        }
        error => teko::assert::is_true(false)
    }
}

/** type_const_i128_cast_coerces — `const A: i128 = 0 to i128` coerces via the explicit cast: the
    initializer types as i128 and the const adopts that value type (#594 crumb 4). */
#test
fn type_const_i128_cast_coerces() {
    let init = ek(parser::Cast { expr = e_num(0); target = named_t("i128") })
    let cd = parser::ConstDecl { name = "A"; ty = named_t("i128"); init = init; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    match type_const_decl(cd, empty_env(), empty_table()) {
        TConstDecl as tc => {
            teko::assert::is_true(prim_is(tc.ty, PrimKind::I128))
            match tc.init.kind { TCast => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * A typed dep `TProgram` carrying a single module-level `const P: i64 = 120` (namespace "m1") at a
 * given visibility — the shape a built dependency serializes into its `.tkb` and `type_program_with_deps`
 * consumes through `seed_from_dep` (#594 crumb 8).
 *
 * @param name  the const's name
 * @param vis   the const's visibility (Pub/Exp are the exported surface; Private is module-local)
 * @return      a one-item typed dep program
 */
fn dep_prog_with_const(name: str, vis: parser::Visibility) -> TProgram {
    let init = TExpr { kind = TNumber { is_float = false; value = 120; fval = 0.0 }; type = Prim { kind = PrimKind::I64 }; line = 0; col = 0 }
    let cd = TConstDecl { name = name; namespace = "m1"; ty = Prim { kind = PrimKind::I64 }; init = init; vis = vis; has_doc = false; doc = ""; line = 1; col = 1 }
    TProgram { items = teko::list::push(teko::list::empty(), cd) }
}

/**
 * A typed dep `TProgram` (namespace "m1") carrying BOTH a `pub const P: i64 = 5` and a
 * `pub fn twice(x: i64) -> i64` — the surface a namespace-qualified reference `m1::P` (a value) or
 * `m1::twice` (a fn-value) resolves against after `seed_from_dep` (#594 crumb 8c, issue #613). The
 * fn body is empty: `seed_from_dep` registers only the SIGNATURE (params + return), never the body.
 *
 * @return a two-item typed dep program (a const + a fn)
 */
fn dep_prog_const_and_fn() -> TProgram {
    let init = TExpr { kind = TNumber { is_float = false; value = 5; fval = 0.0 }; type = Prim { kind = PrimKind::I64 }; line = 0; col = 0 }
    let cd = TConstDecl { name = "P"; namespace = "m1"; ty = Prim { kind = PrimKind::I64 }; init = init; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1 }
    let px = parser::Param { name = "x"; has_type = true; type_ann = named_t("i64"); is_params = false; has_default = false; default_expr = e_num(0) }
    let twice = TFunction { name = "twice"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::empty(), px); return_type = Prim { kind = PrimKind::I64 }; body = teko::list::empty(); vis = parser::Visibility::Pub; has_doc = false; doc = ""; namespace = "m1"; file = "m1.tks"; line = 1; col = 1; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
    mut items: []TItem = teko::list::push(teko::list::empty(), cd)
    items = teko::list::push(items, twice)
    TProgram { items = items }
}

/**
 * seed_from_dep_qualified_value_const_and_fn — the c8c namespace-qualified VALUE path (issue #613): a
 * consumer (namespace "app") references `m1::twice` (a fn-value bound to a local) and `m1::P` (a
 * value). Both resolve through the namespace-value fallback of `type_path_expr`; the fn-value `TVar`
 * carries `is_func = true` and `func_ns = "m1"` (its OWN declaring namespace), and the const `m1::P`
 * inlines to 5 because the emitted `func_ns` exactly matches the c8b `(name, namespace)`-keyed scalar
 * inliner. Proves both the fn-value stamp and the qualified-const substitution (#594 crumb 8c).
 */
#test
fn seed_from_dep_qualified_value_const_and_fn() {
    let bind_tw: parser::Statement = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "tw" }; has_type = false; type_ann = named_t("void"); value = e_path2("m1", "twice") }
    mut body: []parser::Statement = teko::list::push(teko::list::empty(), bind_tw)
    body = teko::list::push(body, st(e_path2("m1", "P")))
    let uses = mk_fn("uses_qualified", named_t("i64"), body)
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = uses; namespace = "app"; file = "app.tks" })
    match type_program_with_deps(parser::Program { items = items }, dep_prog_const_and_fn()) {
        TProgram as tp => {
            let fn_body = fn_body_of(tp, "uses_qualified")
            match fn_body[0] {
                TBinding as tb => match tb.value.kind { TVar as vv => teko::assert::is_true(vv.is_func && vv.func_ns == "m1"); _ => teko::assert::is_true(false) }
                _ => teko::assert::is_true(false)
            }
            match fn_body[1] {
                TExprStmt as es => match es.expr.kind { TNumber as n => teko::assert::is_true(n.value == 5); _ => teko::assert::is_true(false) }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/** seed_from_dep_surfaces_pub_module_const — a consuming module resolves a dep's `pub` module const
    by name AND inlines its serialized initializer: `type_program_with_deps` seeds the dep's exported
    const (`seed_from_dep`), types the consumer's reference, then `inline_consts` substitutes the
    value (120) — no cross-module data symbol (#594 crumb 8). */
#test
fn seed_from_dep_surfaces_pub_module_const() {
    let uses_p = mk_fn("uses_p", named_t("i64"), one_stmt(e_var("P")))
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = uses_p; namespace = "m2"; file = "m2.tks" })
    match type_program_with_deps(parser::Program { items = items }, dep_prog_with_const("P", parser::Visibility::Pub)) {
        TProgram as tp => assert_first_stmt_num(tp, "uses_p", 120)
        error => teko::assert::is_true(false)
    }
}

/** seed_from_dep_hides_private_module_const — a dep's `private` module const is NOT surfaced by
    `seed_from_dep`, so a consumer that names it fails to resolve: the cross-module visibility gate for
    a module-level const (#594 crumb 8). */
#test
fn seed_from_dep_hides_private_module_const() {
    let uses_p = mk_fn("uses_p", named_t("i64"), one_stmt(e_var("P")))
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = uses_p; namespace = "m2"; file = "m2.tks" })
    match type_program_with_deps(parser::Program { items = items }, dep_prog_with_const("P", parser::Visibility::Private)) {
        TProgram => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

/**
 * inline_uses_project_const_over_same_name_dep_const — the c8b dep↔project collision: a dep exports
 * `pub const P` (value 120, namespace "m1") AND the project declares its OWN `const P` (value 9,
 * namespace "app"). A bare `P` in the project resolves (tail-first) to the project const, so
 * `type_var` stamps `func_ns = "app"`; the `(name, namespace)`-keyed inliner must therefore
 * substitute 9 (the project value), NOT 120 (the dep value the OLD name-only inliner returned as the
 * first hit). Guards the silent cross-module miscompile (#594 crumb 8b).
 */
#test
fn inline_uses_project_const_over_same_name_dep_const() {
    let uses_p = mk_fn("uses_p", named_t("i64"), one_stmt(e_var("P")))
    let proj_p = parser::ConstDecl { name = "P"; ty = named_t("i64"); init = e_num(9); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 1; col = 1 }
    let const_item = parser::Item { content = proj_p; namespace = "app"; file = "app.tks" }
    let fn_item = parser::Item { content = uses_p; namespace = "app"; file = "app.tks" }
    let items = teko::list::push(teko::list::push(teko::list::empty(), const_item), fn_item)
    match type_program_with_deps(parser::Program { items = items }, dep_prog_with_const("P", parser::Visibility::Pub)) {
        TProgram as tp => assert_first_stmt_num(tp, "uses_p", 9)
        error => teko::assert::is_true(false)
    }
}

/**
 * inline_falls_back_to_dep_const_when_project_has_none — the symmetric c8b case: the project has NO
 * `P`, so a bare `P` in the project (namespace "app") resolves to the dep's exported `pub const P`
 * (value 120, namespace "m1") and `type_var` stamps `func_ns = "m1"`. The `(name, namespace)`-keyed
 * inliner still surfaces the dep value 120 — the keying only DISAMBIGUATES a real duplicate; a single
 * candidate is matched by its own namespace exactly as before (#594 crumb 8b).
 */
#test
fn inline_falls_back_to_dep_const_when_project_has_none() {
    let uses_p = mk_fn("uses_p", named_t("i64"), one_stmt(e_var("P")))
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = uses_p; namespace = "app"; file = "app.tks" })
    match type_program_with_deps(parser::Program { items = items }, dep_prog_with_const("P", parser::Visibility::Pub)) {
        TProgram as tp => assert_first_stmt_num(tp, "uses_p", 120)
        error => teko::assert::is_true(false)
    }
}

/**
 * perm_cast_to_u32 — build `Perm::<member> to u32` as a loose top-level
 * statement, exercising the E8 flags→integer wire cast (#594 crumb 11).
 *
 * @param member  the flags member name (`"Read"`/`"Write"`)
 * @return        the cast expression, wrapped as a statement
 */
fn perm_cast_to_u32(member: str) -> parser::Statement {
    st(ek(parser::Cast { expr = perm_member(member); target = named_t("u32") }))
}

/**
 * perm_cast_from_u32 — build `1 to Perm` as a loose top-level statement,
 * exercising the E8 integer→flags wire cast (#594 crumb 11).
 *
 * @return  the cast expression, wrapped as a statement
 */
fn perm_cast_from_u32() -> parser::Statement {
    st(ek(parser::Cast { expr = e_num(1); target = named_t("Perm") }))
}

/**
 * perm_cast_to_bool — build `Perm::Read to bool` as a loose top-level
 * statement: neither the E7 enum-ordinal nor the E8 flags-wire cast pair
 * covers a flags→bool target, so this must stay a compile error.
 *
 * @return  the cast expression, wrapped as a statement
 */
fn perm_cast_to_bool() -> parser::Statement {
    st(ek(parser::Cast { expr = perm_member("Read"); target = named_t("bool") }))
}

/**
 * flags_to_int_cast_type_checks — E8 (#594 crumb 11): a flags value casts to
 * its raw integer wire value.
 */
#test
fn flags_to_int_cast_type_checks() {
    let items = teko::list::push(teko::list::empty(), perm_item())
    let items2 = teko::list::push(items, parser::Item { content = perm_cast_to_u32("Read"); namespace = ""; file = "" })
    match type_program(parser::Program { items = items2 }) {
        TProgram => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
}

/**
 * int_to_flags_cast_type_checks — E8 (#594 crumb 11): an integer literal casts
 * to a flags-typed value.
 */
#test
fn int_to_flags_cast_type_checks() {
    let items = teko::list::push(teko::list::empty(), perm_item())
    let items2 = teko::list::push(items, parser::Item { content = perm_cast_from_u32(); namespace = ""; file = "" })
    match type_program(parser::Program { items = items2 }) {
        TProgram => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
}

/**
 * flags_to_bool_cast_is_error — a flags value cast to `bool` matches neither
 * E7 nor E8 and stays rejected by `cast_check`.
 */
#test
fn flags_to_bool_cast_is_error() {
    let items = teko::list::push(teko::list::empty(), perm_item())
    let items2 = teko::list::push(items, parser::Item { content = perm_cast_to_bool(); namespace = ""; file = "" })
    match type_program(parser::Program { items = items2 }) {
        TProgram => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}
