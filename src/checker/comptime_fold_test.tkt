use teko::parser
use teko::lexer

/**
 * u16t — the `u16` primitive type, for the comptime-fold value matrix.
 *
 * @return the `u16` primitive type
 */
fn u16t() -> Type { Prim { kind = PrimKind::U16 } }

/**
 * u64t — the `u64` primitive type, for the comptime-fold value matrix.
 *
 * @return the `u64` primitive type
 */
fn u64t() -> Type { Prim { kind = PrimKind::U64 } }

/**
 * u128t — the `u128` primitive type, for the comptime-fold unrepresentable-literal case.
 *
 * @return the `u128` primitive type
 */
fn u128t() -> Type { Prim { kind = PrimKind::U128 } }

/**
 * cf_num — an integer number-literal typed expression of type `t` carrying value `value`.
 *
 * @param value  the integer value (i128 carrier, like the parser's Number)
 * @param t      the literal's declared type
 * @return       the typed number literal
 */
fn cf_num(value: i128, t: Type) -> TExpr { te(TNumber { is_float = false; value = value; fval = 0.0 }, t) }

/**
 * cf_fnum — an `f64` number-literal typed expression carrying value `fval`.
 *
 * @param fval  the float value
 * @return      the typed f64 number literal
 */
fn cf_fnum(fval: f64) -> TExpr { te(TNumber { is_float = true; value = 0 to i128; fval = fval }, f64t()) }

/**
 * cf_bin — a binary-operator typed expression of result type `t` over two operands.
 *
 * @param op  the binary operator token kind
 * @param l   the left operand
 * @param r   the right operand
 * @param t   the result type
 * @return    the typed binary expression
 */
fn cf_bin(op: lexer::TokenKind, l: TExpr, r: TExpr, t: Type) -> TExpr { te(TBinary { op = op; left = l; right = r }, t) }

/**
 * cf_un — a unary-operator typed expression of result type `t` over one operand.
 *
 * @param op  the unary operator token kind
 * @param o   the operand
 * @param t   the result type
 * @return    the typed unary expression
 */
fn cf_un(op: lexer::TokenKind, o: TExpr, t: Type) -> TExpr { te(TUnary { op = op; operand = o }, t) }

/**
 * cf_cast — a `expr to t` cast typed expression (its `.type` is the cast target).
 *
 * @param e  the operand expression
 * @param t  the cast target type
 * @return   the typed cast expression
 */
fn cf_cast(e: TExpr, t: Type) -> TExpr { te(TCast { expr = e }, t) }

/**
 * cf_int_is — assert `eval_const` folds `e` to an integer value whose bits equal `want`.
 *
 * @param e     the const expression to fold
 * @param want  the expected two's-complement bits
 */
fn cf_int_is(e: TExpr, want: u128) {
    match eval_const(e, empty_table(), empty_env(), empty_agg()) {
        ConstValue as v => match v.kind {
            CVInt as ci => teko::assert::is_true(ci.bits == want)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * cf_bool_is — assert `eval_const` folds `e` to a boolean value equal to `want`.
 *
 * @param e     the const expression to fold
 * @param want  the expected boolean
 */
fn cf_bool_is(e: TExpr, want: bool) {
    match eval_const(e, empty_table(), empty_env(), empty_agg()) {
        ConstValue as v => match v.kind {
            CVBool as cb => teko::assert::is_true(cb.v == want)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * cf_float_is — assert `eval_const` folds `e` to an f64 value whose IEEE bits equal `want`.
 *
 * @param e     the const expression to fold
 * @param want  the expected raw IEEE bits
 */
fn cf_float_is(e: TExpr, want: u64) {
    match eval_const(e, empty_table(), empty_env(), empty_agg()) {
        ConstValue as v => match v.kind {
            CVFloat as cf => teko::assert::is_true(cf.bits == want && !cf.is_f32)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * cf_is_error — assert `eval_const` rejects `e` with a located error (overflow / ÷0 /
 * out-of-range / unsupported form).
 *
 * @param e  the const expression that must fail to fold
 */
fn cf_is_error(e: TExpr) {
    match eval_const(e, empty_table(), empty_env(), empty_agg()) {
        error => teko::assert::is_true(true)
        ConstValue => teko::assert::is_true(false)
    }
}

/**
 * fold_byte_and_bool_literals — a byte literal folds to its 8-bit value; a bool literal
 * folds to a CVBool.
 */
#test
fn fold_byte_and_bool_literals() {
    cf_int_is(te(TByteLit { value = 200 to byte }, bytet()), 200 to u128)
    cf_bool_is(te(TBoolLit { value = true }, boolt()), true)
    cf_bool_is(te(TBoolLit { value = false }, boolt()), false)
}

/**
 * fold_bitwise_ops — `& | ^` and `~` fold to their masked results at u8 width.
 */
#test
fn fold_bitwise_ops() {
    cf_int_is(cf_bin(lexer::TokenKind::Amp, cf_num(255 to i128, u8t()), cf_num(15 to i128, u8t()), u8t()), 15 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Pipe, cf_num(240 to i128, u8t()), cf_num(15 to i128, u8t()), u8t()), 255 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Caret, cf_num(255 to i128, u8t()), cf_num(15 to i128, u8t()), u8t()), 240 to u128)
    cf_int_is(cf_un(lexer::TokenKind::Tilde, cf_num(15 to i128, u8t()), u8t()), 240 to u128)
}

/**
 * fold_shift_ops — `<<`/`>>` fold with the runtime's width-masked count (an out-of-range
 * count wraps by `count & (width - 1)`, matching `teko_rt.h`), and a signed `>>` is
 * arithmetic (sign-preserving).
 */
#test
fn fold_shift_ops() {
    cf_int_is(cf_bin(lexer::TokenKind::Shl, cf_num(1 to i128, u32t()), cf_num(8 to i128, u32t()), u32t()), 256 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Shl, cf_num(1 to i128, u8t()), cf_num(10 to i128, u8t()), u8t()), 4 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Shr, cf_num(255 to i128, u8t()), cf_num(1 to i128, u8t()), u8t()), 127 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Shr, cf_num(-128 to i128, i8t()), cf_num(1 to i128, i8t()), i8t()), 192 to u128)
}

/**
 * fold_signed_divrem — signed `/` truncates toward zero and `%` takes the dividend's
 * sign, folding to the exact two's-complement bits (`-7 / 2 == -3`, `-7 % 2 == -1`).
 */
#test
fn fold_signed_divrem() {
    cf_int_is(cf_bin(lexer::TokenKind::Slash, cf_num(-7 to i128, i8t()), cf_num(2 to i128, i8t()), i8t()), 253 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Percent, cf_num(-7 to i128, i8t()), cf_num(2 to i128, i8t()), i8t()), 255 to u128)
    cf_int_is(cf_bin(lexer::TokenKind::Star, cf_num(-3 to i128, i8t()), cf_num(-4 to i128, i8t()), i8t()), 12 to u128)
}

/**
 * fold_overflow_const — the §8 fold-overflow-const case and its siblings: a provably-const
 * arithmetic result out of its type's range is a compile error, never a silent wrap
 * (`200 + 100` as u8, `127 + 1` as i8, `0 - 1` as u8, `128 * 2` as u8).
 */
#test
fn fold_overflow_const() {
    cf_is_error(cf_bin(lexer::TokenKind::Plus, cf_num(200 to i128, u8t()), cf_num(100 to i128, u8t()), u8t()))
    cf_is_error(cf_bin(lexer::TokenKind::Plus, cf_num(127 to i128, i8t()), cf_num(1 to i128, i8t()), i8t()))
    cf_is_error(cf_bin(lexer::TokenKind::Minus, cf_num(0 to i128, u8t()), cf_num(1 to i128, u8t()), u8t()))
    cf_is_error(cf_bin(lexer::TokenKind::Star, cf_num(128 to i128, u8t()), cf_num(2 to i128, u8t()), u8t()))
}

/**
 * fold_div0_const — the §8 fold-div0-const case: a constant divide/remainder by zero,
 * including the nested `1 / (1 - 1)` shape, is a compile error.
 */
#test
fn fold_div0_const() {
    cf_is_error(cf_bin(lexer::TokenKind::Slash, cf_num(5 to i128, u8t()), cf_num(0 to i128, u8t()), u8t()))
    cf_is_error(cf_bin(lexer::TokenKind::Percent, cf_num(5 to i128, u8t()), cf_num(0 to i128, u8t()), u8t()))
    let denom = cf_bin(lexer::TokenKind::Minus, cf_num(1 to i128, u64t()), cf_num(1 to i128, u64t()), u64t())
    cf_is_error(cf_bin(lexer::TokenKind::Slash, cf_num(1 to i128, u64t()), denom, u64t()))
}

/**
 * fold_signed_min_div_overflow — the signed `MIN / -1` overflow (its true quotient has no
 * representation) is a compile error.
 */
#test
fn fold_signed_min_div_overflow() {
    cf_is_error(cf_bin(lexer::TokenKind::Slash, cf_num(-128 to i128, i8t()), cf_num(-1 to i128, i8t()), i8t()))
}

/**
 * fold_cast_ok — an in-range cast folds: `255 to u8`, a `bool` to `u8` (the only
 * `bool -> numeric` cast), and a negative `i8` sign-extended to `i16`.
 */
#test
fn fold_cast_ok() {
    cf_int_is(cf_cast(cf_num(255 to i128, u16t()), u8t()), 255 to u128)
    cf_int_is(cf_cast(te(TBoolLit { value = true }, boolt()), u8t()), 1 to u128)
    cf_int_is(cf_cast(cf_num(-1 to i128, i8t()), i16t()), 65535 to u128)
}

/**
 * fold_float_ops — f64 literals and `+ - * /` fold through IEEE bits (byte-exact vs
 * `teko::f64_bits`), and a float divide by zero is a compile error.
 */
#test
fn fold_float_ops() {
    cf_float_is(cf_fnum(2.5), teko::f64_bits(2.5))
    cf_float_is(cf_bin(lexer::TokenKind::Plus, cf_fnum(1.5), cf_fnum(2.5), f64t()), teko::f64_bits(4.0))
    cf_float_is(cf_un(lexer::TokenKind::Minus, cf_fnum(2.5), f64t()), teko::f64_bits(-2.5))
    cf_is_error(cf_bin(lexer::TokenKind::Slash, cf_fnum(1.0), cf_fnum(0.0), f64t()))
}

/**
 * cf_folds_to_num — assert `fold_expr` folds `e` to a `TNumber` literal whose carrier equals `want`.
 *
 * @param e     the const op-tree the driver must fold
 * @param want  the expected reconstructed i128 carrier
 */
fn cf_folds_to_num(e: TExpr, want: i128) {
    match fold_expr(e, empty_table(), empty_env(), empty_agg()) {
        error => teko::assert::is_true(false)
        TExpr as f => match f.kind {
            TNumber as n => teko::assert::is_true(!n.is_float && n.value == want)
            _ => teko::assert::is_true(false)
        }
    }
}

/**
 * cf_fold_errors — assert `fold_expr` propagates a located error for the provably-const op-tree `e`
 * (an overflow / ÷0 / out-of-range surfaced by the M.1 fold).
 *
 * @param e  the const op-tree whose fold must fail
 */
fn cf_fold_errors(e: TExpr) {
    match fold_expr(e, empty_table(), empty_env(), empty_agg()) {
        error => teko::assert::is_true(true)
        TExpr => teko::assert::is_true(false)
    }
}

/**
 * cf_fold_kind_is — assert `fold_expr` succeeds and leaves `e`'s top-level kind a `TUnary` (proving
 * the driver did NOT splice a literal — the unrepresentable/non-integer path leaves the op-tree).
 *
 * @param e  the op-tree the driver must leave as a `TUnary`
 */
fn cf_fold_stays_unary(e: TExpr) {
    match fold_expr(e, empty_table(), empty_env(), empty_agg()) {
        error => teko::assert::is_true(false)
        TExpr as f => match f.kind { TUnary => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    }
}

/**
 * fold_expr_folds_scalar_families — the driver folds an unsigned mask, a bitwise-and, a shift and a
 * signed negation to their exact literal carriers (unsigned as the magnitude, signed as the signed
 * integer).
 */
#test
fn fold_expr_folds_scalar_families() {
    cf_folds_to_num(cf_un(lexer::TokenKind::Tilde, cf_cast(cf_num(0 to i128, i64t()), u8t()), u8t()), 255 to i128)
    cf_folds_to_num(cf_bin(lexer::TokenKind::Amp, cf_num(255 to i128, u8t()), cf_num(15 to i128, u8t()), u8t()), 15 to i128)
    cf_folds_to_num(cf_bin(lexer::TokenKind::Shl, cf_num(1 to i128, u32t()), cf_num(8 to i128, u32t()), u32t()), 256 to i128)
    cf_folds_to_num(cf_un(lexer::TokenKind::Minus, cf_cast(cf_num(1 to i128, i64t()), i8t()), i8t()), -1 to i128)
}

/**
 * fold_expr_propagates_overflow — a provably-const overflow (`200 + 100` as u8) and a ÷0 (`5 / 0` as
 * u8) surface through the driver as located compile errors, never a folded wrap.
 */
#test
fn fold_expr_propagates_overflow() {
    cf_fold_errors(cf_bin(lexer::TokenKind::Plus, cf_num(200 to i128, u8t()), cf_num(100 to i128, u8t()), u8t()))
    cf_fold_errors(cf_bin(lexer::TokenKind::Slash, cf_num(5 to i128, u8t()), cf_num(0 to i128, u8t()), u8t()))
}

/**
 * cf_let — a `let NAME = value` typed local binding (its `bound` is the value's type), the shape CF3
 * (Layer 1b) propagates when the value is a provably-const integer op-tree.
 *
 * @param name   the bound local's name
 * @param value  the binding's typed initializer
 * @return       the typed `let` binding statement
 */
fn cf_let(name: str, value: TExpr) -> TStatement { TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; bound = value.type; value = value } }

/**
 * cf_const_bind — a `const NAME = value` typed LOCAL binding (a `BindKind::Const` statement, distinct
 * from a module const), the second immutable shape CF3 propagates.
 *
 * @param name   the bound local's name
 * @param value  the binding's typed initializer
 * @return       the typed local `const` binding statement
 */
fn cf_const_bind(name: str, value: TExpr) -> TStatement { TBinding { kind = parser::BindKind::Const; target = parser::SimpleName { name = name }; bound = value.type; value = value } }

/**
 * cf_mut — a `mut NAME = value` typed local binding, the boundary CF3 must never propagate (a later
 * reassignment would make a folded use dishonest).
 *
 * @param name   the bound local's name
 * @param value  the binding's typed initializer
 * @return       the typed `mut` binding statement
 */
fn cf_mut(name: str, value: TExpr) -> TStatement { TBinding { kind = parser::BindKind::Mut; target = parser::SimpleName { name = name }; bound = value.type; value = value } }

/**
 * cf_destructure — a `let { a; b } = value` typed destructure binding, whose names CF3 never records
 * (they hold projected runtime values) and removes from the fold map (shadow kill).
 *
 * @param names  the destructured names
 * @param value  the aggregate initializer
 * @return       the typed destructure binding statement
 */
fn cf_destructure(names: []str, value: TExpr) -> TStatement { TBinding { kind = parser::BindKind::Let; target = parser::DestructurePattern { names = names }; bound = value.type; value = value } }

/**
 * cf_var — a typed local reference `TVar` of type `t` (a use site CF3 may substitute with the
 * recorded const's initializer).
 *
 * @param name  the referenced local's name
 * @param t     the reference's resolved type
 * @return      the typed reference expression
 */
fn cf_var(name: str, t: Type) -> TExpr { te(TVar { name = name; is_func = false; func_ns = "teko::checker" }, t) }

/**
 * cf_return_of — the value of the `return` statement in the function named `name` of `prog`, wherever
 * it sits in the body (unlike `first_fn_return`, which inspects only the first statement), or null.
 *
 * @param prog  the folded program
 * @param name  the function's name
 * @return      the returned typed expression, or null
 */
fn cf_return_of(prog: TProgram, name: str) -> TExpr? {
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            TFunction as f => if f.name == name { return cf_block_return(f.body) }
            _ => { }
        }
        i++
    }
    null
}

/**
 * cf_block_return — the value of the first value-returning `return` statement in `body`, or null.
 *
 * @param body  the typed statement block
 * @return      the returned typed expression, or null
 */
fn cf_block_return(body: []TStatement) -> TExpr? {
    mut i: u64 = 0
    loop {
        if i >= body.len { break }
        match body[i] {
            TReturn as r => if r.has_value { return r.value }
            _ => { }
        }
        i++
    }
    null
}

/**
 * cf_return_is_num — assert the folded `prog`'s function `name` returns the integer literal `want`
 * (proving a propagated local-const use collapsed to a single literal — CF3 + the composed fold).
 *
 * @param prog  the folded program
 * @param name  the function's name
 * @param want  the expected reconstructed i128 carrier
 */
fn cf_return_is_num(prog: TProgram, name: str, want: i128) {
    match cf_return_of(prog, name) {
        TExpr as rv => match rv.kind {
            TNumber as n => teko::assert::is_true(!n.is_float && n.value == want)
            _ => teko::assert::is_true(false)
        }
        null => teko::assert::is_true(false)
    }
}

/**
 * cf_return_is_var — assert the folded `prog`'s function `name` returns a bare `TVar` (proving a
 * runtime-valued binding was left UNTOUCHED — the CF3 strict guard, DECISION_LOG:391).
 *
 * @param prog  the folded program
 * @param name  the function's name
 */
fn cf_return_is_var(prog: TProgram, name: str) {
    match cf_return_of(prog, name) {
        TExpr as rv => match rv.kind {
            TVar => teko::assert::is_true(true)
            _ => teko::assert::is_true(false)
        }
        null => teko::assert::is_true(false)
    }
}

/**
 * cf_fn_of — a private nullary function named `name` with body `body`, then `inline_consts` run over a
 * one-function program, returning the folded program (or failing the test on an unexpected fold error).
 *
 * @param name  the function's name
 * @param body  its typed statement block
 * @return      the folded program
 */
fn cf_fn_of(name: str, body: []TStatement) -> TProgram {
    let items = teko::list::push(teko::list::empty(), c_fn(name, body))
    match inline_consts(TProgram { items = items }) {
        TProgram as out => return out
        error => {
            teko::assert::is_true(false)
            return TProgram { items = teko::list::empty() }
        }
    }
}

/**
 * cf3_local_const_binding_folds — a LOCAL `const` binding (`BindKind::Const`, not a module const) of a
 * provably-const integer folds identically to a `let`: `const k: u8 = 240 | 15; return k` → `255`.
 */
#test
fn cf3_local_const_binding_folds() {
    let init = cf_bin(lexer::TokenKind::Pipe, cf_num(240 to i128, u8t()), cf_num(15 to i128, u8t()), u8t())
    let let_k = cf_const_bind("k", init)
    mut body: []TStatement = teko::list::push(teko::list::empty(), let_k)
    body = teko::list::push(body, c_ret(cf_var("k", u8t())))
    cf_return_is_num(cf_fn_of("f", body), "f", 255 to i128)
}

/**
 * cf3_destructure_shadow_kills_const — a destructure binding re-binding the name of an outer const
 * removes it from the fold map, so a later use of that name is NOT folded: `let a = 5; let { a } = pt;
 * return a` leaves `a` a bare `TVar`.
 */
#test
fn cf3_destructure_shadow_kills_const() {
    let outer_a = cf_let("a", cf_num(5 to i128, u64t()))
    let names = teko::list::push(teko::list::empty(), "a")
    let de = cf_destructure(names, cf_var("pt", Named { name = "Pt" }))
    mut body: []TStatement = teko::list::push(teko::list::empty(), outer_a)
    body = teko::list::push(body, de)
    body = teko::list::push(body, c_ret(cf_var("a", u64t())))
    cf_return_is_var(cf_fn_of("f", body), "f")
}

/**
 * cf3_walk_covers_expr_and_stmt_arms — a coverage walk: a const local `a` is used inside every common
 * expression form (call, cast, unary, compare, index, struct-init, coalesce, `in`, interp with a
 * none-spec AND a dynamic spec, array) and every statement form (mut, simple + field assign, loop with
 * an init-recorded const + break/continue, defer, adopt, expr-stmt, return). The walk must complete
 * without a fold error, exercising the total `lp_expr`/`lp_stmt` rewrite.
 */
#test
fn cf3_walk_covers_expr_and_stmt_arms() {
    let av = cf_var("a", u64t())
    let call_use = tcall1("g", cf_var("a", u64t()), u64t())
    let cast_use = cf_cast(cf_var("a", u64t()), u8t())
    let unary_use = cf_un(lexer::TokenKind::Tilde, cf_var("a", u64t()), u64t())
    let cmp_use = te(TCompare { first = cf_var("a", u64t()); rest = teko::list::push(teko::list::empty(), TCmpTerm { op = lexer::TokenKind::Lt; operand = cf_num(1000 to i128, u64t()) }) }, boolt())
    let index_use = te(TIndex { receiver = cf_var("arr", Slice { element = u64t() }); index = cf_var("a", u64t()) }, u64t())
    let struct_use = te(TStructInit { field_names = teko::list::push(teko::list::empty(), "v"); field_vals = teko::list::push(teko::list::empty(), cf_var("a", u64t())) }, Named { name = "N" })
    let coalesce_use = te(TCoalesce { left = cf_var("o", Optional { inner = u64t() }); right = cf_var("a", u64t()) }, u64t())
    let in_use = te(TInExpr { lhs = cf_var("a", u64t()); elems = teko::list::push(teko::list::empty(), cf_num(1 to i128, u64t())) }, boolt())
    let none_spec = TFSpec { kind = TFSpecNone { } }
    let interp_use = te(TInterp { pieces = teko::list::push(teko::list::push(teko::list::empty(), "x"), ""); holes = teko::list::push(teko::list::empty(), cf_var("a", u64t())); specs = teko::list::push(teko::list::empty(), none_spec) }, strt())
    let dyn_spec = TFSpec { kind = TFSpecDynamic { args = teko::list::push(teko::list::empty(), cf_var("a", u64t())) } }
    let interp_dyn = te(TInterp { pieces = teko::list::push(teko::list::push(teko::list::empty(), "y"), ""); holes = teko::list::push(teko::list::empty(), cf_var("a", u64t())); specs = teko::list::push(teko::list::empty(), dyn_spec) }, strt())
    let array_use = te(TArrayLit { elements = teko::list::push(teko::list::empty(), TArrayElem { is_spread = false; expr = cf_var("a", u64t()) }) }, Slice { element = u64t() })
    let field_use = te(TFieldAccess { receiver = cf_var("s", Named { name = "N" }); field = "v" }, u64t())
    let safe_use = te(TSafeFieldAccess { receiver = cf_var("o", Optional { inner = Named { name = "N" } }); field = "v" }, Optional { inner = u64t() })

    mut body: []TStatement = teko::list::push(teko::list::empty(), cf_let("a", cf_num(255 to i128, u64t())))
    body = teko::list::push(body, cf_mut("m", cf_num(0 to i128, u64t())))
    body = teko::list::push(body, TAssign { kind = parser::AssignKind::Simple; name = "m"; op = lexer::TokenKind::Assign; bound = u64t(); value = cf_var("a", u64t()); deref = false; target = no_texpr() })
    body = teko::list::push(body, TAssign { kind = parser::AssignKind::Field; name = ""; op = lexer::TokenKind::Assign; bound = u64t(); value = cf_var("a", u64t()); deref = false; target = field_use })
    body = teko::list::push(body, texpr_stmt(call_use))
    body = teko::list::push(body, texpr_stmt(cast_use))
    body = teko::list::push(body, texpr_stmt(unary_use))
    body = teko::list::push(body, texpr_stmt(cmp_use))
    body = teko::list::push(body, texpr_stmt(index_use))
    body = teko::list::push(body, texpr_stmt(struct_use))
    body = teko::list::push(body, texpr_stmt(coalesce_use))
    body = teko::list::push(body, texpr_stmt(in_use))
    body = teko::list::push(body, texpr_stmt(interp_use))
    body = teko::list::push(body, texpr_stmt(interp_dyn))
    body = teko::list::push(body, texpr_stmt(array_use))
    body = teko::list::push(body, texpr_stmt(safe_use))
    body = teko::list::push(body, texpr_stmt(te(TBorrow { operand = cf_var("m", u64t()) }, Reference { inner = u64t() })))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), texpr_stmt(cf_bin(lexer::TokenKind::Plus, cf_var("li", u64t()), cf_num(0 to i128, u64t()), u64t())))
    loopbody = teko::list::push(loopbody, TBreakStmt { label = "" })
    loopbody = teko::list::push(loopbody, TContinueStmt { label = "" })
    let loop_init = teko::list::push(teko::list::empty(), cf_let("li", cf_bin(lexer::TokenKind::Shl, cf_var("a", u64t()), cf_num(1 to i128, u64t()), u64t())))
    body = teko::list::push(body, TLoopStmt { label = ""; init = loop_init; body = loopbody })
    body = teko::list::push(body, TDeferStmt { body = teko::list::push(teko::list::empty(), texpr_stmt(cf_var("a", u64t()))) })
    body = teko::list::push(body, TAdoptStmt { name = "reg"; body = teko::list::push(teko::list::empty(), texpr_stmt(cf_var("a", u64t()))) })
    body = teko::list::push(body, c_ret(av))

    let out = cf_fn_of("walk", body)
    cf_return_is_num(out, "walk", 255 to i128)
}

/**
 * cf3_match_arm_pattern_shadow — the match path: an arm whose pattern BINDS the name of the outer const
 * shadows it (its body's use of that name is not folded), while a wildcard arm inherits the const and
 * folds it. Exercises `lp_match`/`lp_arm`/`pattern_binds` over bind-, field-, alt- and wildcard patterns.
 */
#test
fn cf3_match_arm_pattern_shadow() {
    let bind_pat: parser::Pattern = parser::BindPattern { type_name = cf3_path("Some"); has_binding = true; binding = "a"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    let field_pat: parser::Pattern = parser::FieldPattern { type_name = cf3_path("Pt"); fields = teko::list::push(teko::list::empty(), "a") }
    let alt_inner: parser::Pattern = parser::BindPattern { type_name = cf3_path("Other"); has_binding = true; binding = "w"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    let alt_wild: parser::Pattern = parser::WildcardPattern { }
    mut alt_opts: []parser::Pattern = teko::list::push(teko::list::empty(), alt_wild)
    alt_opts = teko::list::push(alt_opts, alt_inner)
    let alt_pat: parser::Pattern = parser::AltPattern { options = alt_opts }
    let arm_bind = TArm { pattern = bind_pat; has_when = false; guard = no_texpr(); body = teko::list::push(teko::list::empty(), texpr_stmt(cf_bin(lexer::TokenKind::Amp, cf_var("a", u64t()), cf_num(1 to i128, u64t()), u64t()))) }
    let arm_field = TArm { pattern = field_pat; has_when = true; guard = cf_bin(lexer::TokenKind::Amp, cf_var("a", u64t()), cf_num(1 to i128, u64t()), u64t()); body = teko::list::push(teko::list::empty(), texpr_stmt(cf_num(0 to i128, u64t()))) }
    let arm_alt = TArm { pattern = alt_pat; has_when = false; guard = no_texpr(); body = teko::list::push(teko::list::empty(), texpr_stmt(cf_var("a", u64t()))) }
    mut arms: []TArm = teko::list::push(teko::list::empty(), arm_bind)
    arms = teko::list::push(arms, arm_field)
    arms = teko::list::push(arms, arm_alt)
    let me = te(TMatchExpr { subject = cf_var("a", u64t()); arms = arms }, Void { })
    mut body: []TStatement = teko::list::push(teko::list::empty(), cf_let("a", cf_num(255 to i128, u64t())))
    body = teko::list::push(body, texpr_stmt(me))
    body = teko::list::push(body, c_ret(cf_var("a", u64t())))
    cf_return_is_num(cf_fn_of("m", body), "m", 255 to i128)
}

/**
 * cf3_path — a one-segment `parser::Path` naming `name`, for a match pattern's `type_name`.
 *
 * @param name  the path's single segment name
 * @return      the parser path
 */
fn cf3_path(name: str) -> parser::Path { parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) } }

/**
 * cf3_lambda_body_not_propagated — a const local used inside a CLOSURE body is left UNTOUCHED (the
 * capture set was fixed by the typer), so the lambda's body keeps the bare `TVar` — proving CF3 does
 * not fold locals across a closure boundary.
 */
#test
fn cf3_lambda_body_not_propagated() {
    let lam_body = teko::list::push(teko::list::empty(), texpr_stmt(cf_var("a", u64t())))
    let lam_ty = Func { params = teko::list::empty(); ret = u64t(); variadic = false; param_names = teko::list::empty(); n_required = 0; defaults = teko::list::empty() }
    let lam = te(TLambda { params = teko::list::empty(); body = lam_body; captures = teko::list::empty(); ret = u64t(); lift_id = 0 }, lam_ty)
    mut body: []TStatement = teko::list::push(teko::list::empty(), cf_let("a", cf_num(255 to i128, u64t())))
    body = teko::list::push(body, cf_let("f", lam))
    body = teko::list::push(body, c_ret(cf_var("a", u64t())))
    let out = cf_fn_of("lz", body)
    cf3_assert_lambda_body_var(out, "lz")
}

/**
 * cf3_assert_lambda_body_var — assert the `let f = || a` binding in function `name` kept its lambda
 * body's `a` a bare `TVar` (unpropagated across the closure boundary).
 *
 * @param prog  the folded program
 * @param name  the enclosing function's name
 */
fn cf3_assert_lambda_body_var(prog: TProgram, name: str) {
    match cf_second_binding_value(prog, name) {
        TExpr as v => match v.kind {
            TLambda as lam => cf3_assert_first_stmt_var(lam.body)
            _ => teko::assert::is_true(false)
        }
        null => teko::assert::is_true(false)
    }
}

/**
 * cf_second_binding_value — the value expression of the second statement (a binding) of function
 * `name`'s body, or null.
 *
 * @param prog  the program
 * @param name  the function's name
 * @return      the second binding's value, or null
 */
fn cf_second_binding_value(prog: TProgram, name: str) -> TExpr? {
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] {
            TFunction as f => if f.name == name && f.body.len > 1 {
                match f.body[1] { TBinding as b => return b.value; _ => return null }
            }
            _ => { }
        }
        i++
    }
    null
}

/**
 * cf3_assert_first_stmt_var — assert the first statement of `body` is an expression statement carrying a
 * bare `TVar`.
 *
 * @param body  the statement block
 */
fn cf3_assert_first_stmt_var(body: []TStatement) {
    teko::assert::is_true(body.len > 0)
    match body[0] {
        TExprStmt as es => match es.expr.kind {
            TVar => teko::assert::is_true(true)
            _ => teko::assert::is_true(false)
        }
        _ => teko::assert::is_true(false)
    }
}

/**
 * fold_expr_leaves_unrepresentable_u128 — `~(0 to u128)` evaluates to an all-ones u128 that has no
 * literal carrier (its magnitude exceeds i128-max), so the driver leaves the op-tree unfolded rather
 * than emit a dishonest literal — behavior preserved.
 */
#test
fn fold_expr_leaves_unrepresentable_u128() {
    let e = cf_un(lexer::TokenKind::Tilde, cf_cast(cf_num(0 to i128, i64t()), u128t()), u128t())
    cf_fold_stays_unary(e)
}

/**
 * cf_cvint — a `CVInt` comptime value carrying the two's-complement bits `bits` of type `ty`, for the
 * CF5 `comptime_format` matrix.
 *
 * @param bits  the value's two's-complement bits
 * @param ty    the value's declared integer type
 * @return      the integer comptime value
 */
fn cf_cvint(bits: u128, ty: Type) -> ConstValue { ConstValue { kind = CVInt { bits = bits; ty = ty } } }

/**
 * cf_spec_static — a static (`:literal`) format spec carrying spec string `s`.
 *
 * @param s  the static spec string (e.g. `"X"`, `"d5"`)
 * @return   the static format spec
 */
fn cf_spec_static(s: str) -> TFSpec { TFSpec { kind = TFSpecStatic { s = s } } }

/**
 * cf_spec_none — a no-format (`TFSpecNone`) spec, the natural-form render.
 *
 * @return  the none format spec
 */
fn cf_spec_none() -> TFSpec { TFSpec { kind = TFSpecNone { } } }

/**
 * cf_fmt_is — assert `comptime_format(v, sp, ty)` renders byte-for-byte to `want`.
 *
 * @param v     the const hole value
 * @param sp    the format spec
 * @param ty    the hole's resolved type
 * @param want  the expected rendered string
 */
fn cf_fmt_is(v: ConstValue, sp: TFSpec, ty: Type, want: str) {
    match comptime_format(v, sp, ty) {
        error => teko::assert::is_true(false)
        []byte as b => teko::assert::is_true(str_of_bytes(b) == want)
    }
}

/**
 * cf_fmt_declined — assert `comptime_format(v, sp, ty)` declines to fold (returns an error), so the
 * caller leaves the hole runtime (a float / dynamic / unrecognized spec).
 *
 * @param v   the const hole value
 * @param sp  the format spec
 * @param ty  the hole's resolved type
 */
fn cf_fmt_declined(v: ConstValue, sp: TFSpec, ty: Type) {
    match comptime_format(v, sp, ty) {
        error => teko::assert::is_true(true)
        []byte => teko::assert::is_true(false)
    }
}

/**
 * fmt_hex_family — the `:x`/`:X` hex render mirrors `tk_fmt_x_lower`/`tk_fmt_x_upper`: no leading zeros,
 * `"0"` for zero, and a negative signed value sign-extended to 64 bits (`-1 to i8 : X` → all-ones), the
 * exact `(uint64_t)` cast the C backend emits.
 */
#test
fn fmt_hex_family() {
    cf_fmt_is(cf_cvint(255 to u128, u64t()), cf_spec_static("X"), u64t(), "FF")
    cf_fmt_is(cf_cvint(255 to u128, u64t()), cf_spec_static("x"), u64t(), "ff")
    cf_fmt_is(cf_cvint(0 to u128, u64t()), cf_spec_static("X"), u64t(), "0")
    cf_fmt_is(cf_cvint(3735928559 to u128, u64t()), cf_spec_static("X"), u64t(), "DEADBEEF")
    cf_fmt_is(cf_cvint(3735928559 to u128, u64t()), cf_spec_static("x"), u64t(), "deadbeef")
    cf_fmt_is(cf_cvint((~(0 to u64)) to u128, u64t()), cf_spec_static("X"), u64t(), "FFFFFFFFFFFFFFFF")
    cf_fmt_is(cf_cvint(255 to u128, i8t()), cf_spec_static("X"), i8t(), "FFFFFFFFFFFFFFFF")
    cf_fmt_is(cf_cvint(4294967291 to u128, i32t()), cf_spec_static("X"), i32t(), "FFFFFFFFFFFFFFFB")
}

/**
 * fmt_binary_family — the `:b` render mirrors `tk_fmt_b`: no leading zeros, `"0"` for zero.
 */
#test
fn fmt_binary_family() {
    cf_fmt_is(cf_cvint(255 to u128, u64t()), cf_spec_static("b"), u64t(), "11111111")
    cf_fmt_is(cf_cvint(0 to u128, u64t()), cf_spec_static("b"), u64t(), "0")
    cf_fmt_is(cf_cvint(5 to u128, u8t()), cf_spec_static("b"), u8t(), "101")
}

/**
 * fmt_none_decimal — the natural (`TFSpecNone`) render mirrors `tk_u64_to_str` (unsigned) and
 * `tk_i64_to_str` (signed, `'-'`-prefixed), including the u64/i64 edges.
 */
#test
fn fmt_none_decimal() {
    cf_fmt_is(cf_cvint(255 to u128, u64t()), cf_spec_none(), u64t(), "255")
    cf_fmt_is(cf_cvint(0 to u128, u64t()), cf_spec_none(), u64t(), "0")
    cf_fmt_is(cf_cvint((~(0 to u64)) to u128, u64t()), cf_spec_none(), u64t(), "18446744073709551615")
    cf_fmt_is(cf_cvint((~(0 to u64)) to u128, i64t()), cf_spec_none(), i64t(), "-1")
    cf_fmt_is(cf_cvint(255 to u128, i8t()), cf_spec_none(), i8t(), "-1")
    cf_fmt_is(cf_cvint((1 to u128) << 63, i64t()), cf_spec_none(), i64t(), "-9223372036854775808")
}

/**
 * fmt_d_width — the `:d` render mirrors `tk_fmt_d` (`%0*PRId64`): a default width of 1 (no padding), a
 * wider field zero-padded AFTER the sign.
 */
#test
fn fmt_d_width() {
    cf_fmt_is(cf_cvint(42 to u128, i64t()), cf_spec_static("d"), i64t(), "42")
    cf_fmt_is(cf_cvint(42 to u128, i64t()), cf_spec_static("d5"), i64t(), "00042")
    cf_fmt_is(cf_cvint((~(0 to u64)) to u128, i64t()), cf_spec_static("d5"), i64t(), "-0001")
    cf_fmt_is(cf_cvint((~(0 to u64)) to u128, i64t()), cf_spec_static("d"), i64t(), "-1")
}

/**
 * fmt_n_thousands — the `:n` render mirrors `tk_fmt_n_i`: a `','` every three digits from the right, sign
 * preserved.
 */
#test
fn fmt_n_thousands() {
    cf_fmt_is(cf_cvint(1000000 to u128, u64t()), cf_spec_static("n"), u64t(), "1,000,000")
    cf_fmt_is(cf_cvint(255 to u128, u64t()), cf_spec_static("n"), u64t(), "255")
    cf_fmt_is(cf_cvint(1234 to u128, i64t()), cf_spec_static("n"), i64t(), "1,234")
    cf_fmt_is(cf_cvint((~(0 to u64)) to u128, i64t()), cf_spec_static("n"), i64t(), "-1")
}

/**
 * fmt_none_bool_byte_bytes — the natural render of a bool (`"true"`/`"false"`), a byte (unsigned
 * decimal) and a str/char value (its raw bytes passed through).
 */
#test
fn fmt_none_bool_byte_bytes() {
    cf_fmt_is(ConstValue { kind = CVBool { v = true } }, cf_spec_none(), boolt(), "true")
    cf_fmt_is(ConstValue { kind = CVBool { v = false } }, cf_spec_none(), boolt(), "false")
    cf_fmt_is(cf_cvint(200 to u128, bytet()), cf_spec_none(), bytet(), "200")
    cf_fmt_is(ConstValue { kind = CVBytes { data = bytes_of_str("hi!") } }, cf_spec_none(), strt(), "hi!")
    cf_fmt_is(ConstValue { kind = CVBytes { data = bytes_of_str("A") } }, cf_spec_none(), Char { }, "A")
}

/**
 * fmt_declines_float_and_dynamic — the fold NEVER touches a float family (`:f`/`:e`/`:g`/`:p`, and a
 * float hole with no spec) nor a dynamic spec — `comptime_format` returns an error so the caller leaves
 * the hole runtime (M.3 honesty: no byte-divergent fold).
 */
#test
fn fmt_declines_float_and_dynamic() {
    cf_fmt_declined(cf_cvint(42 to u128, u64t()), cf_spec_static("f2"), u64t())
    cf_fmt_declined(cf_cvint(42 to u128, u64t()), cf_spec_static("e"), u64t())
    cf_fmt_declined(cf_cvint(42 to u128, u64t()), cf_spec_static("g"), u64t())
    cf_fmt_declined(cf_cvint(42 to u128, u64t()), cf_spec_static("p"), u64t())
    cf_fmt_declined(cf_cvint(42 to u128, u64t()), TFSpec { kind = TFSpecDynamic { args = teko::list::empty() } }, u64t())
    cf_fmt_declined(ConstValue { kind = CVFloat { bits = teko::f64_bits(1.5); is_f32 = false } }, cf_spec_none(), f64t())
}

/**
 * empty_agg — an empty `AggConstMap` (no module aggregate consts recorded), the CF4a companion to
 * `empty_env()`/`empty_table()` for a fold-test call site that resolves no `TVar` receiver.
 *
 * @return  an `AggConstMap` with empty parallel lists
 */
fn empty_agg() -> AggConstMap { ScalarConstMap { names = teko::list::empty(); nss = teko::list::empty(); inits = teko::list::empty() } }

/**
 * cf_index_is — assert `eval_const` over the map `agg` folds the index expression `ix` to an integer
 * whose bits equal `want`.
 *
 * @param ix    the index expression to fold
 * @param agg   the module-aggregate resolution table
 * @param want  the expected element's two's-complement bits
 */
fn cf_index_is(ix: TExpr, agg: AggConstMap, want: u128) {
    match eval_const(ix, empty_table(), empty_env(), agg) {
        ConstValue as v => match v.kind {
            CVInt as ci => teko::assert::is_true(ci.bits == want)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * cf_str — an in-tree `str`-literal typed expression carrying text `text`, the CF4d/CF4c const-string
 * receiver (its `.type` is `str`, the shape the typer gives a string literal).
 *
 * @param text  the literal's text
 * @return      the typed string-literal expression
 */
fn cf_str(text: str) -> TExpr { te(TStrLit { text = text }, strt()) }

/**
 * cf_field — a `recv.field` field-access typed expression of result type `t`, the CF4c/CF4d fold
 * receiver shape (`.len` of a const string/aggregate, or a field of a const struct).
 *
 * @param recv   the receiver expression
 * @param field  the accessed field's name
 * @param t      the field access's resolved type
 * @return       the typed field-access expression
 */
fn cf_field(recv: TExpr, field: str, t: Type) -> TExpr { te(TFieldAccess { receiver = recv; field = field }, t) }

/**
 * cf_slice_lit — an in-tree slice array-literal typed expression over `elems` with element type
 * `elemty`, the CF4d `.len` receiver (its `.type` is `Slice`, so `is_len_field` admits the length fold).
 *
 * @param elems   the array's element expressions, in index order
 * @param elemty  the slice's element type
 * @return        the typed slice array-literal expression
 */
fn cf_slice_lit(elems: []TExpr, elemty: Type) -> TExpr {
    mut es: []TArrayElem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= elems.len { break }
        es = teko::list::push(es, TArrayElem { is_spread = false; expr = elems[i] })
        i++
    }
    te(TArrayLit { elements = es }, Slice { element = elemty })
}

/**
 * cf_point_init — an in-tree `Point { x = 30, y = 12 }` struct-init typed expression, the CF4c
 * const-struct-field receiver (fields in declared order, `.type` the named struct type).
 *
 * @return  the typed struct-init expression
 */
fn cf_point_init() -> TExpr {
    let names = teko::list::push(teko::list::push(teko::list::empty(), "x"), "y")
    let vals = teko::list::push(teko::list::push(teko::list::empty(), cf_num(30 to i128, i64t())), cf_num(12 to i128, i64t()))
    te(TStructInit { field_names = names; field_vals = vals }, Named { name = "Point" })
}

/**
 * cf_agg_str — a hand-built `AggConstMap` recording `const GREETING: str = "hello"` in namespace
 * `teko::checker`, the CF4d module-const-string receiver `GREETING.len` resolves against.
 *
 * @return  the module-aggregate resolution table holding `GREETING`
 */
fn cf_agg_str() -> AggConstMap {
    ScalarConstMap { names = teko::list::push(teko::list::empty(), "GREETING"); nss = teko::list::push(teko::list::empty(), "teko::checker"); inits = teko::list::push(teko::list::empty(), cf_str("hello")) }
}

/**
 * cf_agg_first_is — assert `eval_const` over `agg` folds `e` to a `CVAgg` of exactly `want_len`
 * elements whose first element is a `CVInt` with bits `first` (the CF4c `str -> []byte` const value).
 *
 * @param e         the const expression to fold
 * @param agg       the module-aggregate resolution table
 * @param want_len  the expected element count
 * @param first     the expected first element's two's-complement bits
 */
fn cf_agg_first_is(e: TExpr, agg: AggConstMap, want_len: u64, first: u128) {
    match eval_const(e, empty_table(), empty_env(), agg) {
        error => teko::assert::is_true(false)
        ConstValue as v => match v.kind {
            CVAgg as ag => {
                teko::assert::is_true(ag.elems.len == want_len)
                match ag.elems[0].kind {
                    CVInt as ci => teko::assert::is_true(ci.bits == first)
                    _ => teko::assert::is_true(false)
                }
            }
            _ => teko::assert::is_true(false)
        }
    }
}

/**
 * eval_const_folds_inline_agg_len — the CF4d mandate case: `.len` of an in-tree `[]i64` array literal
 * `[10, 20, 30]` folds to the element count `3` (with an EMPTY map — the receiver is in-tree).
 */
#test
fn eval_const_folds_inline_agg_len() {
    let elems = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), cf_num(10 to i128, i64t())), cf_num(20 to i128, i64t())), cf_num(30 to i128, i64t()))
    cf_int_is(cf_field(cf_slice_lit(elems, i64t()), "len", u64t()), 3 to u128)
}

/**
 * eval_const_folds_module_string_len — the CF4d module-string case: `GREETING.len` over the hand-built
 * map for `const GREETING: str = "hello"` folds to the byte count `5`.
 */
#test
fn eval_const_folds_module_string_len() {
    cf_index_is(cf_field(cf_var("GREETING", strt()), "len", u64t()), cf_agg_str(), 5 to u128)
}

/**
 * eval_const_folds_inline_struct_field — the CF4c mandate case: `p.x`/`p.y` of an in-tree
 * `Point { x = 30, y = 12 }` struct literal fold to the field values `30`/`12` (with an EMPTY map).
 */
#test
fn eval_const_folds_inline_struct_field() {
    cf_int_is(cf_field(cf_point_init(), "x", i64t()), 30 to u128)
    cf_int_is(cf_field(cf_point_init(), "y", i64t()), 12 to u128)
}

/**
 * eval_const_folds_str_to_bytes — the CF4c coercion case: `"hi" to []byte` folds to the byte-array
 * const value — a `CVAgg` of two `byte` elements whose first is `0x68` (`'h'`).
 */
#test
fn eval_const_folds_str_to_bytes() {
    cf_agg_first_is(cf_cast(cf_str("hi"), Slice { element = bytet() }), empty_agg(), 2 to u64, 0x68 to u128)
}
