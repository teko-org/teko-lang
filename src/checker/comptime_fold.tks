use teko::lexer
use teko::parser

/**
 * ConstValue — the comptime value domain: the result of evaluating a provably-const
 * expression subtree. An integer is stored as its raw two's-complement bit pattern in
 * a `u128` PLUS its declared type, so every integer family (i8..i128 / u8..u128 /
 * byte / char) re-emits and re-wraps exactly as the metal would; a float keeps its raw
 * bits so formatting is byte-exact; a string/bytes keeps its bytes; an aggregate holds
 * child ConstValues in order. This domain exists ONLY inside the fold — it never
 * escapes to lowering (the fold reconstructs a literal TExpr from it via `literal_of`).
 *
 * @field kind  the value's case (int / float / bool / bytes / aggregate)
 * @since #comptime-fold
 */
pub type ConstValue = struct { kind: ConstValueKind }

/**
 * ConstValueKind — the case of a ConstValue.
 *
 * @since #comptime-fold
 */
pub type ConstValueKind = variant CVInt | CVFloat | CVBool | CVBytes | CVAgg

/**
 * CVInt — an integer comptime value: the two's-complement bit pattern (`bits`) as it
 * would sit in a register of `ty`, plus the declared integer type (so a fold knows the
 * width for wrapping/overflow checks and re-emission).
 *
 * @field bits  the value's raw two's-complement bits, zero-extended into u128
 * @field ty    the declared integer type (drives width, signedness, wrap/overflow)
 * @since #comptime-fold
 */
pub type CVInt = struct { bits: u128; ty: Type }

/**
 * CVFloat — a float comptime value: the raw IEEE-754 bits (so re-emission and
 * formatting are byte-exact and never route through the host locale — M.1) plus
 * whether it is an f32 (32 significant bits in `bits`) or f64.
 *
 * @field bits   the raw IEEE-754 bits (f32 in the low 32)
 * @field is_f32 true iff the value is an f32, false for f64
 * @since #comptime-fold
 */
pub type CVFloat = struct { bits: u64; is_f32: bool }

/**
 * CVBool — a boolean comptime value.
 *
 * @field v  the boolean
 * @since #comptime-fold
 */
pub type CVBool = struct { v: bool }

/**
 * CVBytes — a string / char / []byte comptime value: the raw UTF-8 (str/char) or raw
 * (byte-slice) bytes, exactly as they would live in rodata.
 *
 * @field data  the raw bytes
 * @since #comptime-fold
 */
pub type CVBytes = struct { data: []byte }

/**
 * CVAgg — an aggregate (array / struct / variant) comptime value: the child values in
 * declaration order. Indexing (`TIndex`, Layer 1c) reads `elems[i]`; struct/array
 * re-emission rebuilds the aggregate literal from the children.
 *
 * @field elems  the child comptime values, in order
 * @since #comptime-fold
 */
pub type CVAgg = struct { elems: []ConstValue }

/**
 * IntInfo — the width/signedness a comptime integer op runs at: the number of value
 * bits and whether the top bit is a sign bit. Derived from a `CVInt.ty` (a `Prim`
 * integer or `byte`) by `int_info`; every wrap/overflow/re-emission decision reads it.
 *
 * @field width   the integer's bit width (8 / 16 / 32 / 64 / 128)
 * @field is_signed  true iff the type is a signed integer (i8..i128), false for unsigned/byte
 * @since #comptime-fold
 */
type IntInfo = struct { width: u32; is_signed: bool }

/**
 * cv_int — wrap a two's-complement bit pattern and its declared type into a ConstValue.
 *
 * @param bits  the value's raw two's-complement bits, zero-extended into u128
 * @param ty    the declared integer type
 * @return      the integer ConstValue
 * @since #comptime-fold
 */
fn cv_int(bits: u128, ty: Type) -> ConstValue { ConstValue { kind = CVInt { bits = bits; ty = ty } } }

/**
 * cv_float — wrap raw IEEE-754 bits into a float ConstValue.
 *
 * @param bits    the raw IEEE-754 bits (f32 in the low 32)
 * @param is_f32  true iff the value is an f32
 * @return        the float ConstValue
 * @since #comptime-fold
 */
fn cv_float(bits: u64, is_f32: bool) -> ConstValue { ConstValue { kind = CVFloat { bits = bits; is_f32 = is_f32 } } }

/**
 * cv_bool — wrap a boolean into a ConstValue.
 *
 * @param v  the boolean
 * @return   the boolean ConstValue
 * @since #comptime-fold
 */
fn cv_bool(v: bool) -> ConstValue { ConstValue { kind = CVBool { v = v } } }

/**
 * cv_bytes — wrap a raw byte sequence (a folded str/char) into a ConstValue.
 *
 * @param data  the raw bytes
 * @return      the bytes ConstValue
 * @since #comptime-fold
 */
fn cv_bytes(data: []byte) -> ConstValue { ConstValue { kind = CVBytes { data = data } } }

/**
 * AggConstMap — the module-level AGGREGATE-const resolution table the Layer-1c (CF4) index fold
 * reads: three PARALLEL lists (names / namespaces / collapsed initializers) over every module
 * aggregate const, in dependency order, exactly as `build_aggregate_map` (`consteval.tks`) already
 * produces. A `TVar` receiver of a const `TIndex` is resolved by a `(name, namespace)` lookup keyed
 * on the reference's `func_ns` — the SAME key `inline_rw_var` uses — so the index fold and the
 * type-checker never diverge. This table resolves ONLY module aggregate consts; a fn-value, a local
 * binding, and a scalar const are never in it, so the CF3 fn-value/scalar invariants are untouched.
 *
 * @since #comptime-fold
 */
pub type AggConstMap = ScalarConstMap

/**
 * cv_agg — wrap an ordered list of child comptime values into an aggregate ConstValue (the
 * constructor for `CVAgg`). The children are in declaration/index order, so `eval_index_expr` reads
 * `elems[i]` directly.
 *
 * @param elems  the child comptime values, in order
 * @return       the aggregate ConstValue
 * @since #comptime-fold
 */
fn cv_agg(elems: []ConstValue) -> ConstValue { ConstValue { kind = CVAgg { elems = elems } } }

/**
 * width_mask — the low-`w`-bits mask (2^w - 1) as a u128, the ceiling of an unsigned
 * value of width `w` and the modulus a width-`w` operation reduces modulo. Width 128 is
 * the all-ones u128 (its `1 << 128` cannot be spelled), every other width builds the
 * mask from a single in-range shift.
 *
 * @param w  the bit width (8 / 16 / 32 / 64 / 128)
 * @return   the mask 2^w - 1 as a u128
 * @since #comptime-fold
 */
fn width_mask(w: u32) -> u128 {
    if w >= 128 { return ~(0 to u128) }
    (1 to u128 << w) - 1
}

/**
 * mask_to_width — reduce a u128 bit pattern to its low `w` bits, the two's-complement
 * normalization every width-`w` result passes through before it becomes a `CVInt.bits`.
 *
 * @param bits  the unreduced bit pattern
 * @param w     the target bit width
 * @return      `bits` with every bit at or above position `w` cleared
 * @since #comptime-fold
 */
fn mask_to_width(bits: u128, w: u32) -> u128 { bits & width_mask(w) }

/**
 * bit_set — is the bit at position `pos` set in `bits`? Used to read a value's sign bit
 * (position width-1) during signed overflow and shift decisions.
 *
 * @param bits  the bit pattern to inspect
 * @param pos   the bit position (0-based)
 * @return      true iff bit `pos` is 1
 * @since #comptime-fold
 */
fn bit_set(bits: u128, pos: u32) -> bool { ((bits >> pos) & (1 to u128)) == (1 to u128) }

/**
 * msb_value — 2^(w-1), the magnitude of the most-negative signed value of width `w` and
 * the exclusive ceiling of a signed magnitude at that width.
 *
 * @param w  the bit width
 * @return   2^(w-1) as a u128
 * @since #comptime-fold
 */
fn msb_value(w: u32) -> u128 { 1 to u128 << (w - 1) }

/**
 * is_negative — does `bits` denote a negative value under `info`? False for every
 * unsigned type; for a signed type it is the state of the sign bit (position width-1).
 *
 * @param bits  the value's bit pattern
 * @param info  the value's width/signedness
 * @return      true iff the value is a negative signed value
 * @since #comptime-fold
 */
fn is_negative(bits: u128, info: IntInfo) -> bool { info.is_signed && bit_set(mask_to_width(bits, info.width), info.width - 1) }

/**
 * twos_neg — the width-`w` two's-complement negation of `x` (2^w - x mod 2^w), computed
 * with in-range subtraction only (never an underflowing `0 - x`), so it is safe on every
 * engine and for every width including 128.
 *
 * @param x  the value to negate (its low `w` bits are used)
 * @param w  the bit width
 * @return   the two's-complement negation, reduced to width `w`
 * @since #comptime-fold
 */
fn twos_neg(x: u128, w: u32) -> u128 { mask_to_width((width_mask(w) - mask_to_width(x, w)) + (1 to u128), w) }

/**
 * magnitude — the unsigned magnitude of the value `bits` denotes under `info`: the value
 * itself when non-negative, its two's-complement negation when negative. The signed
 * multiply/divide paths run on magnitudes and re-apply the sign at the end.
 *
 * @param bits  the value's bit pattern
 * @param info  the value's width/signedness
 * @return      the absolute value as a u128
 * @since #comptime-fold
 */
fn magnitude(bits: u128, info: IntInfo) -> u128 {
    if is_negative(bits, info) { return twos_neg(bits, info.width) }
    mask_to_width(bits, info.width)
}

/**
 * is_min_bits — does `bits` denote the most-negative value of a signed type under
 * `info` (bit pattern 2^(w-1))? The `MIN / -1` overflow and `-MIN` overflow guards test
 * this; always false for an unsigned type.
 *
 * @param bits  the value's bit pattern
 * @param info  the value's width/signedness
 * @return      true iff the value is the signed minimum
 * @since #comptime-fold
 */
fn is_min_bits(bits: u128, info: IntInfo) -> bool { info.is_signed && mask_to_width(bits, info.width) == msb_value(info.width) }

/**
 * is_all_ones — is every low bit of `bits` set at width `w` (the bit pattern of a signed
 * `-1`)? The signed `MIN / -1` overflow guard tests the divisor with this.
 *
 * @param bits  the value's bit pattern
 * @param w     the bit width
 * @return      true iff the low `w` bits are all 1
 * @since #comptime-fold
 */
fn is_all_ones(bits: u128, w: u32) -> bool { mask_to_width(bits, w) == width_mask(w) }

/**
 * int_info — classify a type as an integer width/signedness, or error when it is not an
 * integer (a `Prim` integer drives its width/signedness; `byte` is 8-bit unsigned).
 *
 * @param t  the type to classify
 * @return   the width/signedness, or an error when `t` is not an integer type
 * @since #comptime-fold
 */
fn int_info(t: Type) -> IntInfo | error {
    match t {
        Prim as p => {
            if !prim_is_int(p.kind) { return error { message = "comptime fold: type is not an integer" } }
            IntInfo { width = prim_width(p.kind); is_signed = prim_is_signed(p.kind) }
        }
        Byte => IntInfo { width = 8; is_signed = false }
        _ => error { message = "comptime fold: type is not an integer" }
    }
}

/**
 * signed_min_i128 — the minimum value of a signed type of width `w` as an i128 carrier
 * (-2^(w-1)), the lower bound the literal range check compares against.
 *
 * @param w  the bit width
 * @return   -2^(w-1) as an i128
 * @since #comptime-fold
 */
fn signed_min_i128(w: u32) -> i128 {
    let mx = (msb_value(w) - (1 to u128)) to i128
    -(mx) - (1 to i128)
}

/**
 * neg_literal_bits — the width-`w` two's-complement bit pattern of a NEGATIVE i128
 * literal value, computed without ever negating i128-MIN directly (which would overflow):
 * it forms the magnitude from `-(value + 1)` (always in range) and subtracts.
 *
 * @param value  the negative literal value (< 0, already range-checked)
 * @param w      the target bit width
 * @return       the value's two's-complement bits at width `w`
 * @since #comptime-fold
 */
fn neg_literal_bits(value: i128, w: u32) -> u128 {
    let k = (-(value + (1 to i128))) to u128
    width_mask(w) - k
}

/**
 * eval_const — evaluate a PROVABLY-const expression subtree (one already accepted by
 * `is_const_expr`) to its ConstValue, matching the backend's arithmetic semantics
 * EXACTLY (Layer 1a). Recurses over the Tier-0..5 grammar plus `TIndex` of a const
 * aggregate at a const index (Layer 1c). An overflow, a ÷0, or an out-of-range cast on
 * a constant is a LOCATED COMPILE ERROR, never a silent wrap (M.1; LEGISLATION:148) —
 * a value the compiler can already see is out of range fails loudly at compile time.
 * The caller MUST have proven `is_const_expr(e) == null` first; a non-const form here
 * is an internal-error located at `e`.
 *
 * @param e      the typed, provably-const expression to evaluate
 * @param table  the type table (to classify a callee / resolve a referenced type)
 * @param env    the environment resolving a name to a const/binding + its value
 * @param agg    the module-aggregate resolution table (resolves a `TVar` index receiver, Layer 1c)
 * @return       the computed comptime value, or a located error (overflow / ÷0 /
 *               out-of-range / a non-const form reaching this evaluator)
 * @since #comptime-fold
 */
pub fn eval_const(e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    match e.kind {
        TNumber as n => eval_number(n, e)
        TBoolLit as b => cv_bool(b.value)
        TByteLit as by => cv_int(by.value to u128, Byte { })
        TCharLit as ch => cv_bytes(bytes_of_str(ch.bytes))
        TStrLit as s => cv_bytes(bytes_of_str(s.text))
        TCast as c => eval_cast_expr(c, e, table, env, agg)
        TUnary as u => eval_unary_expr(u, e, table, env, agg)
        TBinary as bi => eval_binary_expr(bi, e, table, env, agg)
        TVar as v => eval_agg_ref(v, e, table, env, agg)
        TArrayLit as a => eval_array_agg(a, table, env, agg)
        TIndex as ix => eval_index_expr(ix, e, table, env, agg)
        _ => const_form_error("this expression is not a Tier-0..2 scalar constant the comptime fold evaluates yet (#comptime-fold)", e)
    }
}

/**
 * eval_number — evaluate a numeric literal (Tier 0): a float routes to the float-literal
 * encoder, an integer to the range-checked integer-literal encoder.
 *
 * @param n  the typed number literal
 * @param e  the enclosing expression (its type is the literal's declared type; its
 *           line/col position any error)
 * @return   the literal's comptime value, or a located error
 * @since #comptime-fold
 */
fn eval_number(n: TNumber, e: TExpr) -> ConstValue | error {
    if n.is_float { return eval_float_literal(n.fval, e.type, e) }
    eval_int_literal(n.value, e.type, e)
}

/**
 * eval_int_literal — encode an integer literal `value` as its declared type `t`,
 * erroring when `t` is not an integer or the value is out of range for it.
 *
 * @param value  the literal's integer value (i128 carrier)
 * @param t      the literal's declared type
 * @param e      the enclosing expression (positions any error)
 * @return       the integer comptime value, or a located error
 * @since #comptime-fold
 */
fn eval_int_literal(value: i128, t: Type, e: TExpr) -> ConstValue | error {
    match int_info(t) {
        error => return const_form_error("comptime fold: a non-integer type on an integer literal (#comptime-fold)", e)
        IntInfo as info => encode_int_literal(value, info, t, e)
    }
}

/**
 * encode_int_literal — range-check `value` against the type `t` of width/signedness
 * `info` and produce its two's-complement bits, erroring (M.1; LEGISLATION:148) when the
 * literal is out of range for its type.
 *
 * @param value  the literal's integer value (i128 carrier)
 * @param info   the type's width/signedness
 * @param t      the literal's declared type
 * @param e      the enclosing expression (positions any error)
 * @return       the integer comptime value, or a located out-of-range error
 * @since #comptime-fold
 */
fn encode_int_literal(value: i128, info: IntInfo, t: Type, e: TExpr) -> ConstValue | error {
    if value < (0 to i128) {
        if !info.is_signed { return const_form_error("negative literal is out of range for an unsigned type (#comptime-fold)", e) }
        if value < signed_min_i128(info.width) { return const_form_error("integer literal is out of range for its type (#comptime-fold)", e) }
        return cv_int(neg_literal_bits(value, info.width), t)
    }
    let uv = value to u128
    let max = if info.is_signed { msb_value(info.width) - (1 to u128) } else { width_mask(info.width) }
    if uv > max { return const_form_error("integer literal is out of range for its type (#comptime-fold)", e) }
    cv_int(mask_to_width(uv, info.width), t)
}

/**
 * eval_float_literal — encode a float literal from its f64 value into raw IEEE bits.
 * Only f64 is folded today; an f32 (which needs the not-yet-exposed `f32_bits`
 * primitive) and any non-float type are a located error.
 *
 * @param fval  the literal's f64 value
 * @param t     the literal's declared type
 * @param e     the enclosing expression (positions any error)
 * @return      the float comptime value, or a located error
 * @since #comptime-fold
 */
fn eval_float_literal(fval: f64, t: Type, e: TExpr) -> ConstValue | error {
    match t {
        Prim as p => {
            if p.kind == PrimKind::F64 { return cv_float(teko::f64_bits(fval), false) }
            const_form_error("comptime folding of this float width is not yet supported (only f64) (#comptime-fold)", e)
        }
        _ => const_form_error("comptime fold: a non-float type on a float literal (#comptime-fold)", e)
    }
}

/**
 * eval_cast_expr — evaluate a `to T` cast (Tier 1): fold the operand, then convert it to
 * the cast's target type `e.type`, erroring on an out-of-range value (M.1).
 *
 * @param c      the typed cast node
 * @param e      the enclosing expression (its type is the cast target; positions errors)
 * @param table  the type table (forwarded to the operand fold)
 * @param env    the environment (forwarded to the operand fold)
 * @param agg    the module-aggregate resolution table (forwarded to the operand fold)
 * @return       the converted comptime value, or a located error
 * @since #comptime-fold
 */
fn eval_cast_expr(c: TCast, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    match eval_const(c.expr, table, env, agg) {
        error as x => return x
        ConstValue as v => apply_cast(v, e.type, e)
    }
}

/**
 * apply_cast — convert a folded value `v` to the target type `target`. The comptime fold
 * supports integer and `byte` targets (int-to-int with an M.1 range check, and the sole
 * `bool -> numeric` cast); a float target is a located error until the float-cast crumb.
 *
 * @param v       the folded operand value
 * @param target  the cast's target type
 * @param e       the enclosing expression (positions any error)
 * @return        the converted comptime value, or a located error
 * @since #comptime-fold
 */
fn apply_cast(v: ConstValue, target: Type, e: TExpr) -> ConstValue | error {
    match int_info(target) {
        IntInfo as dst => cast_to_int(v, target, dst, e)
        error => const_form_error("comptime fold: this cast target is not yet supported (#comptime-fold)", e)
    }
}

/**
 * cast_to_int — convert a folded value to an integer target of width/signedness `dst`.
 * A CVInt re-ranges (int-to-int); a CVBool folds to 1/0 (the only `bool -> numeric`
 * cast Teko allows); every other kind is a located error.
 *
 * @param v       the folded operand value
 * @param target  the integer target type
 * @param dst     the target's width/signedness
 * @param e       the enclosing expression (positions any error)
 * @return        the integer comptime value, or a located error
 * @since #comptime-fold
 */
fn cast_to_int(v: ConstValue, target: Type, dst: IntInfo, e: TExpr) -> ConstValue | error {
    match v.kind {
        CVInt as ci => cast_int_to_int(ci, target, dst, e)
        CVBool as cb => cv_int(if cb.v { 1 to u128 } else { 0 to u128 }, target)
        _ => const_form_error("comptime fold: cannot cast this constant kind to an integer (#comptime-fold)", e)
    }
}

/**
 * cast_int_to_int — re-range an integer value `ci` into the integer target `target` of
 * width/signedness `dst`, erroring when the source is not an integer.
 *
 * @param ci      the source integer value
 * @param target  the integer target type
 * @param dst     the target's width/signedness
 * @param e       the enclosing expression (positions any error)
 * @return        the re-ranged integer value, or a located error
 * @since #comptime-fold
 */
fn cast_int_to_int(ci: CVInt, target: Type, dst: IntInfo, e: TExpr) -> ConstValue | error {
    match int_info(ci.ty) {
        error as x => return x
        IntInfo as src => cast_int_widths(ci.bits, src, target, dst, e)
    }
}

/**
 * cast_int_widths — the integer-to-integer range check + re-encode: a negative source
 * fits only a signed target whose magnitude admits it; a non-negative source fits any
 * target whose ceiling admits it. An out-of-range value is a located compile error,
 * mirroring the runtime's trapping narrowing cast (M.1) rather than truncating.
 *
 * @param bits    the source value's bit pattern
 * @param src     the source's width/signedness
 * @param target  the integer target type
 * @param dst     the target's width/signedness
 * @param e       the enclosing expression (positions any error)
 * @return        the re-encoded integer value, or a located out-of-range error
 * @since #comptime-fold
 */
fn cast_int_widths(bits: u128, src: IntInfo, target: Type, dst: IntInfo, e: TExpr) -> ConstValue | error {
    if is_negative(bits, src) {
        if !dst.is_signed { return const_form_error("constant is out of range for the cast target (a negative value to an unsigned type) (#comptime-fold)", e) }
        let m = twos_neg(bits, src.width)
        if m > msb_value(dst.width) { return const_form_error("constant is out of range for the cast target (#comptime-fold)", e) }
        return cv_int(twos_neg(m, dst.width), target)
    }
    let v = mask_to_width(bits, src.width)
    if v > cast_max(dst) { return const_form_error("constant is out of range for the cast target (#comptime-fold)", e) }
    cv_int(mask_to_width(v, dst.width), target)
}

/**
 * cast_max — the largest non-negative value an integer target of width/signedness `dst`
 * admits: its signed maximum 2^(w-1)-1, or its unsigned ceiling 2^w-1.
 *
 * @param dst  the target's width/signedness
 * @return     the inclusive maximum as a u128
 * @since #comptime-fold
 */
fn cast_max(dst: IntInfo) -> u128 {
    if dst.is_signed { return msb_value(dst.width) - (1 to u128) }
    width_mask(dst.width)
}

/**
 * eval_unary_expr — evaluate a unary comptime expression. A leading `-` on an integer literal is a
 * NEGATIVE LITERAL, not a negation OPERATION applied to a positive one: `-9223372036854775808` IS
 * i64::MIN, whose positive magnitude `2^63` has no i64 form, so evaluating the operand in isolation
 * would overflow even though the literal is in range. That form is encoded directly — the negated
 * value `-N` range-checked against the whole expression's type via `encode_int_literal`'s negative
 * path (the type checker's own negative-literal rule, `typer.tks`). Every other unary (`-2.5` over a
 * float, `~x`, `-x` over a non-literal) takes the general evaluate-then-`apply_unary` path.
 *
 * @param u      the unary expression
 * @param e      the enclosing expression (its type; positions any error)
 * @param table  the type table (forwarded to the operand evaluator)
 * @param env    the environment (module consts + provably-const locals)
 * @param agg    the module-aggregate resolution table (forwarded to the operand evaluator)
 * @return       the evaluated comptime value, or a located error
 * @since #comptime-fold
 */
fn eval_unary_expr(u: TUnary, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    if u.op == lexer::TokenKind::Minus {
        match u.operand.kind {
            TNumber as n => if !n.is_float { return eval_int_literal((0 to i128) - n.value, e.type, e) }
            _ => { }
        }
    }
    match eval_const(u.operand, table, env, agg) {
        error as x => return x
        ConstValue as v => apply_unary(u.op, v, e)
    }
}

/**
 * apply_unary — apply a unary operator to a folded value: integer `~`/`-` on a CVInt,
 * `-` on a CVFloat; any other pairing is a located error.
 *
 * @param op  the unary operator token
 * @param v   the folded operand value
 * @param e   the enclosing expression (positions any error)
 * @return    the folded value, or a located error
 * @since #comptime-fold
 */
fn apply_unary(op: lexer::TokenKind, v: ConstValue, e: TExpr) -> ConstValue | error {
    match v.kind {
        CVInt as ci => int_unary(op, ci, e)
        CVFloat as cf => apply_float_unary(op, cf, e)
        _ => const_form_error("comptime fold: unsupported unary operator on this constant (#comptime-fold)", e)
    }
}

/**
 * int_unary — apply `~` (bitwise complement, masked to width) or unary `-` (negation) to
 * an integer value.
 *
 * @param op  the unary operator token
 * @param ci  the integer operand
 * @param e   the enclosing expression (positions any error)
 * @return    the folded integer value, or a located error
 * @since #comptime-fold
 */
fn int_unary(op: lexer::TokenKind, ci: CVInt, e: TExpr) -> ConstValue | error {
    match int_info(ci.ty) {
        error as x => return x
        IntInfo as info => int_unary_at(op, ci, info, e)
    }
}

/**
 * int_unary_at — apply an integer unary operator once the operand's width/signedness is
 * known: `~` masks the complement to width, `-` negates with an M.1 overflow guard.
 *
 * @param op    the unary operator token
 * @param ci    the integer operand (carries its type)
 * @param info  the operand's width/signedness
 * @param e     the enclosing expression (positions any error)
 * @return      the folded integer value, or a located error
 * @since #comptime-fold
 */
fn int_unary_at(op: lexer::TokenKind, ci: CVInt, info: IntInfo, e: TExpr) -> ConstValue | error {
    let a = mask_to_width(ci.bits, info.width)
    match op {
        lexer::TokenKind::Tilde => cv_int(width_mask(info.width) ^ a, ci.ty)
        lexer::TokenKind::Minus => int_negate(a, info, ci.ty, e)
        _ => const_form_error("comptime fold: unsupported unary operator on an integer constant (#comptime-fold)", e)
    }
}

/**
 * int_negate — negate an integer value. Negating a signed MIN, or any non-zero unsigned
 * value, is out of range and a located compile error (M.1); every other case is the
 * exact two's-complement negation.
 *
 * @param a     the operand's bit pattern (masked to width)
 * @param info  the operand's width/signedness
 * @param ty    the operand's declared type (the result's type)
 * @param e     the enclosing expression (positions any error)
 * @return      the negated integer value, or a located out-of-range error
 * @since #comptime-fold
 */
fn int_negate(a: u128, info: IntInfo, ty: Type, e: TExpr) -> ConstValue | error {
    if !info.is_signed {
        if mask_to_width(a, info.width) == (0 to u128) { return cv_int(0 to u128, ty) }
        return const_form_error("negation of a non-zero unsigned constant is out of range (#comptime-fold)", e)
    }
    if is_min_bits(a, info) { return const_form_error("integer overflow negating a constant (a signed MIN has no positive) (#comptime-fold)", e) }
    cv_int(twos_neg(a, info.width), ty)
}

/**
 * apply_float_unary — apply a unary operator to a float value: only `-` (sign flip) is
 * defined on a float; any other is a located error.
 *
 * @param op  the unary operator token
 * @param cf  the float operand
 * @param e   the enclosing expression (positions any error)
 * @return    the folded float value, or a located error
 * @since #comptime-fold
 */
fn apply_float_unary(op: lexer::TokenKind, cf: CVFloat, e: TExpr) -> ConstValue | error {
    match op {
        lexer::TokenKind::Minus => float_negate(cf, e)
        _ => const_form_error("comptime fold: unsupported unary operator on a float constant (#comptime-fold)", e)
    }
}

/**
 * float_negate — negate an f64 value through its IEEE bits; an f32 is not yet folded.
 *
 * @param cf  the float operand
 * @param e   the enclosing expression (positions any error)
 * @return    the negated float value, or a located error
 * @since #comptime-fold
 */
fn float_negate(cf: CVFloat, e: TExpr) -> ConstValue | error {
    if cf.is_f32 { return const_form_error("comptime folding of f32 is not yet supported (#comptime-fold)", e) }
    cv_float(teko::f64_bits(-(teko::f64_from_bits(cf.bits))), false)
}

/**
 * eval_binary_expr — evaluate a binary `+ - * / % & | ^ << >>` expression (Tier 2): fold
 * both operands, then apply the operator.
 *
 * @param bi     the typed binary node
 * @param e      the enclosing expression (positions any error)
 * @param table  the type table (forwarded to the operand folds)
 * @param env    the environment (forwarded to the operand folds)
 * @param agg    the module-aggregate resolution table (forwarded to the operand folds)
 * @return       the folded value, or a located error
 * @since #comptime-fold
 */
fn eval_binary_expr(bi: TBinary, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    match eval_const(bi.left, table, env, agg) {
        error as x => return x
        ConstValue as lv => eval_binary_right(bi, lv, e, table, env, agg)
    }
}

/**
 * eval_binary_right — the left operand of a binary op is folded; fold the right operand
 * and apply the operator.
 *
 * @param bi     the typed binary node
 * @param lv     the folded left value
 * @param e      the enclosing expression (positions any error)
 * @param table  the type table (forwarded to the right-operand fold)
 * @param env    the environment (forwarded to the right-operand fold)
 * @param agg    the module-aggregate resolution table (forwarded to the right-operand fold)
 * @return       the folded value, or a located error
 * @since #comptime-fold
 */
fn eval_binary_right(bi: TBinary, lv: ConstValue, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    match eval_const(bi.right, table, env, agg) {
        error as y => return y
        ConstValue as rv => apply_binary(bi.op, lv, rv, e)
    }
}

/**
 * agg_const_init — resolve the collapsed initializer of the module aggregate const named
 * `(name, ns)` in `agg`, or null when no such const is recorded (a fn-value, a local, a scalar
 * const, or a different-module name never resolves — the fold then leaves the index runtime). A thin
 * `(name, ns)`-keyed lookup over the parallel lists, mirroring `scalar_const_init` (`consteval.tks`).
 *
 * @param agg   the module-aggregate resolution table
 * @param name  the reference's name
 * @param ns    the reference's resolved namespace (`func_ns`)
 * @return      the const's collapsed initializer, or null
 * @since #comptime-fold
 */
fn agg_const_init(agg: AggConstMap, name: str, ns: str) -> TExpr? {
    mut i: u64 = 0
    loop {
        if i >= agg.names.len { break }
        if agg.names[i] == name && agg.nss[i] == ns { return agg.inits[i] }
        i++
    }
    null
}

/**
 * eval_agg_ref — evaluate a `TVar` reference that names a module-level aggregate const: resolve its
 * collapsed initializer through `agg` and evaluate that (Layer 1c). A function-value reference
 * (`is_func`) is never a const aggregate; a name absent from `agg` (a local, a scalar, a
 * different-module name) is a soft `const_form_error` located at `e` — the `cf_agg_value`/
 * `cf_can_index` gate proves the shape before the fold calls `eval_const`, so this arm never spuriously
 * rejects a program: a non-foldable receiver simply stays runtime.
 *
 * @param v      the reference node
 * @param e      the enclosing expression (positions any error)
 * @param table  the type table (forwarded to the initializer eval)
 * @param env    the environment (forwarded to the initializer eval)
 * @param agg    the module-aggregate resolution table
 * @return       the aggregate comptime value, or a located error
 * @since #comptime-fold
 */
fn eval_agg_ref(v: TVar, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    if v.is_func { return const_form_error("comptime fold: a function value is not a const aggregate (#comptime-fold)", e) }
    match agg_const_init(agg, v.name, v.func_ns) {
        null => const_form_error("comptime fold: this reference is not a module aggregate const (#comptime-fold)", e)
        TExpr as init => eval_const(init, table, env, agg)
    }
}

/**
 * eval_array_agg — evaluate an array/slice literal's elements to a `CVAgg`, recursing `eval_const`
 * into each element expression (Layer 1c). A spread element is not const-foldable in CF4 and makes
 * the aggregate non-const; its presence — rejected by `cf_agg_value` before the fold reaches here —
 * is a located error on the direct-eval path. Element order is index order.
 *
 * @param a      the typed array literal
 * @param table  the type table (forwarded to each element eval)
 * @param env    the environment (forwarded to each element eval)
 * @param agg    the module-aggregate resolution table (forwarded)
 * @return       the aggregate comptime value, or the first located element error
 * @since #comptime-fold
 */
fn eval_array_agg(a: TArrayLit, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    mut elems: []ConstValue = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= a.elements.len { break }
        if a.elements[i].is_spread { return error { message = "comptime fold: a spread element is not a const aggregate (#comptime-fold)" } }
        let v = match eval_const(a.elements[i].expr, table, env, agg) { error as x => return x; ConstValue as cv => cv }
        elems = teko::list::push(elems, v)
        i++
    }
    cv_agg(elems)
}

/**
 * eval_index_expr — evaluate a `TIndex` of a const aggregate at a const index (Layer 1c): evaluate
 * the receiver (which must yield a `CVAgg`) and the index (which must yield a `CVInt`), then read the
 * element. A negative index or an index `>= elems.len` is a LOCATED COMPILE ERROR (M.1;
 * LEGISLATION:148) — a hazard the compiler can already see. A non-aggregate receiver or non-integer
 * index reaching here is a located error (the `cf_can_index` gate proves the shape before the fold
 * calls `eval_const`).
 *
 * @param ix     the typed index expression
 * @param e      the enclosing expression (positions any error)
 * @param table  the type table (forwarded to the child evals)
 * @param env    the environment (forwarded to the child evals)
 * @param agg    the module-aggregate resolution table (forwarded)
 * @return       the element comptime value, or a located error (out-of-range / shape)
 * @since #comptime-fold
 */
fn eval_index_expr(ix: TIndex, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> ConstValue | error {
    let recv = match eval_const(ix.receiver, table, env, agg) { error as x => return x; ConstValue as cv => cv }
    let idx = match eval_const(ix.index, table, env, agg) { error as x => return x; ConstValue as cv => cv }
    match recv.kind {
        CVAgg as ag => eval_index_at(ag, idx, e)
        _ => const_form_error("comptime fold: index receiver is not a const aggregate (#comptime-fold)", e)
    }
}

/**
 * eval_index_at — read element `idx` of the folded aggregate `ag`: the index must be a `CVInt` with a
 * representable non-negative value strictly below `ag.elems.len`; a negative or out-of-range index is
 * a located compile error (M.1). The bounds hazard the compiler can already see fails loudly at
 * comptime, never as a silent wrap or a deferred runtime trap.
 *
 * @param ag   the folded aggregate value
 * @param idx  the folded index value (must be a `CVInt`)
 * @param e    the enclosing expression (positions any error)
 * @return     the element comptime value, or a located out-of-range error
 * @since #comptime-fold
 */
fn eval_index_at(ag: CVAgg, idx: ConstValue, e: TExpr) -> ConstValue | error {
    match idx.kind {
        CVInt as ci => eval_index_pick(ag, ci, e)
        _ => const_form_error("comptime fold: index is not a const integer (#comptime-fold)", e)
    }
}

/**
 * eval_index_pick — the bounds-checked element read: recover the index's signed carrier, reject a
 * negative or unrepresentable value, reject an index at or beyond the aggregate length, then return
 * the element. Every rejection is a located M.1 compile error.
 *
 * @param ag  the folded aggregate value
 * @param ci  the folded index integer
 * @param e   the enclosing expression (positions any error)
 * @return    the element comptime value, or a located out-of-range error
 * @since #comptime-fold
 */
fn eval_index_pick(ag: CVAgg, ci: CVInt, e: TExpr) -> ConstValue | error {
    let iv = match index_carrier(ci) { null => return const_form_error("comptime fold: index is out of range (#comptime-fold)", e); i128 as v => v }
    if iv < (0 to i128) { return const_form_error("comptime fold: a negative index is out of range (#comptime-fold)", e) }
    if (iv to u128) >= (ag.elems.len to u128) { return const_form_error("comptime fold: index is out of range for the aggregate length (#comptime-fold)", e) }
    ag.elems[iv to u64]
}

/**
 * index_carrier — the signed i128 value a const index `CVInt` denotes, or null when the value has no
 * i128 form (a u128 whose magnitude exceeds i128-max — necessarily an out-of-range index). Reuses
 * `int_info`/`cv_int_to_i128`, the same reconstruction `literal_of` uses.
 *
 * @param ci  the folded index integer
 * @return    the index's i128 value, or null when unrepresentable
 * @since #comptime-fold
 */
fn index_carrier(ci: CVInt) -> i128? {
    match int_info(ci.ty) {
        error => null
        IntInfo as info => cv_int_to_i128(ci.bits, info)
    }
}

/**
 * apply_binary — apply a binary operator to two folded operands, dispatching on their
 * kinds: two integers to the integer op family, two f64 floats to the float op family.
 * A mismatched or unsupported pairing is a located error.
 *
 * @param op  the binary operator token
 * @param lv  the folded left value
 * @param rv  the folded right value
 * @param e   the enclosing expression (positions any error)
 * @return    the folded value, or a located error
 * @since #comptime-fold
 */
fn apply_binary(op: lexer::TokenKind, lv: ConstValue, rv: ConstValue, e: TExpr) -> ConstValue | error {
    match lv.kind {
        CVInt as li => apply_binary_int(op, li, rv, e)
        CVFloat as lf => apply_binary_float(op, lf, rv, e)
        _ => const_form_error("comptime fold: unsupported operand kind in a binary op (#comptime-fold)", e)
    }
}

/**
 * apply_binary_int — the left operand is an integer: require an integer right operand and
 * dispatch to the integer op family.
 *
 * @param op  the binary operator token
 * @param li  the folded left integer value
 * @param rv  the folded right value
 * @param e   the enclosing expression (positions any error)
 * @return    the folded value, or a located error
 * @since #comptime-fold
 */
fn apply_binary_int(op: lexer::TokenKind, li: CVInt, rv: ConstValue, e: TExpr) -> ConstValue | error {
    match rv.kind {
        CVInt as ri => int_binop(op, li, ri, e)
        _ => const_form_error("comptime fold: mismatched operand kinds in a binary op (#comptime-fold)", e)
    }
}

/**
 * apply_binary_float — the left operand is a float: require a float right operand and
 * dispatch to the float op family.
 *
 * @param op  the binary operator token
 * @param lf  the folded left float value
 * @param rv  the folded right value
 * @param e   the enclosing expression (positions any error)
 * @return    the folded value, or a located error
 * @since #comptime-fold
 */
fn apply_binary_float(op: lexer::TokenKind, lf: CVFloat, rv: ConstValue, e: TExpr) -> ConstValue | error {
    match rv.kind {
        CVFloat as rf => float_binop(op, lf, rf, e)
        _ => const_form_error("comptime fold: mismatched operand kinds in a binary op (#comptime-fold)", e)
    }
}

/**
 * int_binop — apply an integer binary operator, running at the LEFT operand's width and
 * signedness (Teko requires both operands share that integer type; a shift reads its
 * count from the right operand's value).
 *
 * @param op  the binary operator token
 * @param la  the folded left integer value (carries the operation's type)
 * @param ra  the folded right integer value
 * @param e   the enclosing expression (positions any error)
 * @return    the folded integer value, or a located error
 * @since #comptime-fold
 */
fn int_binop(op: lexer::TokenKind, la: CVInt, ra: CVInt, e: TExpr) -> ConstValue | error {
    match int_info(la.ty) {
        error as x => return x
        IntInfo as info => int_binop_dispatch(op, la, ra, info, e)
    }
}

/**
 * int_binop_dispatch — dispatch an integer binary operator to its arithmetic, bitwise, or
 * shift handler once the operation's width/signedness `info` is known.
 *
 * @param op    the binary operator token
 * @param la    the folded left integer value (carries the operation's type)
 * @param ra    the folded right integer value
 * @param info  the operation's width/signedness
 * @param e     the enclosing expression (positions any error)
 * @return      the folded integer value, or a located error
 * @since #comptime-fold
 */
fn int_binop_dispatch(op: lexer::TokenKind, la: CVInt, ra: CVInt, info: IntInfo, e: TExpr) -> ConstValue | error {
    let a = mask_to_width(la.bits, info.width)
    let b = mask_to_width(ra.bits, info.width)
    match op {
        lexer::TokenKind::Plus => int_add(a, b, info, la.ty, e)
        lexer::TokenKind::Minus => int_sub(a, b, info, la.ty, e)
        lexer::TokenKind::Star => int_mul(a, b, info, la.ty, e)
        lexer::TokenKind::Slash => int_divrem(true, a, b, info, la.ty, e)
        lexer::TokenKind::Percent => int_divrem(false, a, b, info, la.ty, e)
        lexer::TokenKind::Amp => cv_int(mask_to_width(a & b, info.width), la.ty)
        lexer::TokenKind::Pipe => cv_int(mask_to_width(a | b, info.width), la.ty)
        lexer::TokenKind::Caret => cv_int(mask_to_width(a ^ b, info.width), la.ty)
        lexer::TokenKind::Shl => int_shift(true, la, ra, info, e)
        lexer::TokenKind::Shr => int_shift(false, la, ra, info, e)
        _ => const_form_error("comptime fold: unsupported binary operator on an integer constant (#comptime-fold)", e)
    }
}

/**
 * int_add — integer addition. The two's-complement sum is exact for the in-range case;
 * an addition whose true result leaves the type's range is a located overflow error
 * (M.1), never a silent wrap.
 *
 * @param a     the left operand's bit pattern (masked to width)
 * @param b     the right operand's bit pattern (masked to width)
 * @param info  the operation's width/signedness
 * @param ty    the result's declared type
 * @param e     the enclosing expression (positions any error)
 * @return      the folded sum, or a located overflow error
 * @since #comptime-fold
 */
fn int_add(a: u128, b: u128, info: IntInfo, ty: Type, e: TExpr) -> ConstValue | error {
    let raw = a + b
    let res = mask_to_width(raw, info.width)
    if int_add_overflows(a, b, res, raw, info) { return const_form_error("integer overflow in a constant `+` (out of range for its type) (#comptime-fold)", e) }
    cv_int(res, ty)
}

/**
 * int_add_overflows — does the addition leave the type's range? Signed: both operands
 * share a sign the result does not. Unsigned: a carry beyond the width (at width 128 a
 * u128 carry-out, else a sum exceeding the width mask).
 *
 * @param a     the left operand's bit pattern
 * @param b     the right operand's bit pattern
 * @param res   the width-reduced sum
 * @param raw   the un-reduced u128 sum
 * @param info  the operation's width/signedness
 * @return      true iff the addition overflows
 * @since #comptime-fold
 */
fn int_add_overflows(a: u128, b: u128, res: u128, raw: u128, info: IntInfo) -> bool {
    if info.is_signed {
        let sa = bit_set(a, info.width - 1)
        let sb = bit_set(b, info.width - 1)
        let sr = bit_set(res, info.width - 1)
        return (sa == sb) && (sr != sa)
    }
    if info.width >= 128 { return raw < a }
    raw > width_mask(info.width)
}

/**
 * int_sub — integer subtraction, computed as an addition of the two's-complement of the
 * right operand (never an underflowing `a - b`), erroring on an out-of-range true result.
 *
 * @param a     the left operand's bit pattern (masked to width)
 * @param b     the right operand's bit pattern (masked to width)
 * @param info  the operation's width/signedness
 * @param ty    the result's declared type
 * @param e     the enclosing expression (positions any error)
 * @return      the folded difference, or a located overflow error
 * @since #comptime-fold
 */
fn int_sub(a: u128, b: u128, info: IntInfo, ty: Type, e: TExpr) -> ConstValue | error {
    let res = mask_to_width(a + twos_neg(b, info.width), info.width)
    if int_sub_overflows(a, b, res, info) { return const_form_error("integer overflow in a constant `-` (out of range for its type) (#comptime-fold)", e) }
    cv_int(res, ty)
}

/**
 * int_sub_overflows — does the subtraction leave the type's range? Signed: the operands'
 * signs differ and the result's sign is not the minuend's. Unsigned: a borrow (`a < b`).
 *
 * @param a     the left operand's bit pattern
 * @param b     the right operand's bit pattern
 * @param res   the width-reduced difference
 * @param info  the operation's width/signedness
 * @return      true iff the subtraction overflows
 * @since #comptime-fold
 */
fn int_sub_overflows(a: u128, b: u128, res: u128, info: IntInfo) -> bool {
    if info.is_signed {
        let sa = bit_set(a, info.width - 1)
        let sb = bit_set(b, info.width - 1)
        let sr = bit_set(res, info.width - 1)
        return (sa != sb) && (sr != sa)
    }
    a < b
}

/**
 * int_mul — integer multiplication. The two's-complement product's low bits are the exact
 * in-range result; a product whose true value leaves the type's range is a located
 * overflow error (M.1).
 *
 * @param a     the left operand's bit pattern (masked to width)
 * @param b     the right operand's bit pattern (masked to width)
 * @param info  the operation's width/signedness
 * @param ty    the result's declared type
 * @param e     the enclosing expression (positions any error)
 * @return      the folded product, or a located overflow error
 * @since #comptime-fold
 */
fn int_mul(a: u128, b: u128, info: IntInfo, ty: Type, e: TExpr) -> ConstValue | error {
    let res = mask_to_width(a * b, info.width)
    if int_mul_overflows(a, b, info) { return const_form_error("integer overflow in a constant `*` (out of range for its type) (#comptime-fold)", e) }
    cv_int(res, ty)
}

/**
 * int_mul_overflows — does the multiplication leave the type's range? It compares
 * magnitudes: the product of the unsigned magnitudes must not carry out of u128 and must
 * fit the type's magnitude ceiling (a signed result may reach 2^(w-1) only when the signs
 * differ, i.e. the minimum).
 *
 * @param a     the left operand's bit pattern
 * @param b     the right operand's bit pattern
 * @param info  the operation's width/signedness
 * @return      true iff the multiplication overflows
 * @since #comptime-fold
 */
fn int_mul_overflows(a: u128, b: u128, info: IntInfo) -> bool {
    if !info.is_signed { return unsigned_mul_overflows(a, b, info) }
    signed_mul_overflows(a, b, info)
}

/**
 * unsigned_mul_overflows — does an unsigned product leave the width? A u128 carry-out, or
 * (below width 128) a product exceeding the width mask.
 *
 * @param a     the left operand's bit pattern
 * @param b     the right operand's bit pattern
 * @param info  the operation's width/signedness
 * @return      true iff the unsigned product overflows
 * @since #comptime-fold
 */
fn unsigned_mul_overflows(a: u128, b: u128, info: IntInfo) -> bool {
    if mul_mag_overflows(a, b) { return true }
    if info.width >= 128 { return false }
    (a * b) > width_mask(info.width)
}

/**
 * signed_mul_overflows — does a signed product leave the width? The magnitude product must
 * not carry out of u128 nor exceed 2^(w-1); a magnitude of exactly 2^(w-1) is in range
 * only when the signs differ (the type minimum).
 *
 * @param a     the left operand's bit pattern
 * @param b     the right operand's bit pattern
 * @param info  the operation's width/signedness
 * @return      true iff the signed product overflows
 * @since #comptime-fold
 */
fn signed_mul_overflows(a: u128, b: u128, info: IntInfo) -> bool {
    let ua = magnitude(a, info)
    let ub = magnitude(b, info)
    if mul_mag_overflows(ua, ub) { return true }
    let cap = msb_value(info.width)
    let prod = ua * ub
    if prod > cap { return true }
    if prod == cap { return bit_set(a, info.width - 1) == bit_set(b, info.width - 1) }
    false
}

/**
 * mul_mag_overflows — does the unsigned product `x * y` carry out of the u128 carrier?
 * Detected without a wider type: a non-zero `x` whose product divided back does not
 * recover `y` overflowed.
 *
 * @param x  the first magnitude
 * @param y  the second magnitude
 * @return   true iff `x * y` exceeds u128
 * @since #comptime-fold
 */
fn mul_mag_overflows(x: u128, y: u128) -> bool { x != (0 to u128) && ((x * y) / x != y) }

/**
 * int_divrem — integer division (`is_div`) or remainder. A zero divisor and the signed
 * `MIN / -1` overflow are located compile errors (M.1, mirroring the runtime's trapping
 * divide); otherwise the result is the trunc-toward-zero quotient or its remainder.
 *
 * @param is_div  true for `/`, false for `%`
 * @param a       the dividend's bit pattern (masked to width)
 * @param b       the divisor's bit pattern (masked to width)
 * @param info    the operation's width/signedness
 * @param ty      the result's declared type
 * @param e       the enclosing expression (positions any error)
 * @return        the folded quotient/remainder, or a located error
 * @throws        a located error when the divisor is zero or a signed `MIN / -1` overflows
 * @since #comptime-fold
 */
fn int_divrem(is_div: bool, a: u128, b: u128, info: IntInfo, ty: Type, e: TExpr) -> ConstValue | error {
    if mask_to_width(b, info.width) == (0 to u128) { return divrem_zero_error(is_div, e) }
    if info.is_signed && is_min_bits(a, info) && is_all_ones(b, info.width) { return const_form_error("integer overflow in a constant signed division (MIN / -1) (#comptime-fold)", e) }
    if !info.is_signed { return cv_int(mask_to_width(if is_div { a / b } else { a % b }, info.width), ty) }
    let ua = magnitude(a, info)
    let ub = magnitude(b, info)
    if is_div { return int_div_signed(ua, ub, a, b, info, ty) }
    int_rem_signed(ua, ub, a, info, ty)
}

/**
 * divrem_zero_error — the located compile error for a constant divide/remainder by zero.
 *
 * @param is_div  true for `/`, false for `%`
 * @param e       the enclosing expression (positions the error)
 * @return        the located error
 * @since #comptime-fold
 */
fn divrem_zero_error(is_div: bool, e: TExpr) -> error {
    if is_div { return const_form_error("division by zero in a constant (#comptime-fold)", e) }
    const_form_error("remainder by zero in a constant (#comptime-fold)", e)
}

/**
 * int_div_signed — the signed quotient from magnitudes: its magnitude is `ua / ub`, and
 * it is negative when the operand signs differ (truncation toward zero).
 *
 * @param ua    the dividend's magnitude
 * @param ub    the divisor's magnitude
 * @param a     the dividend's bit pattern (for its sign)
 * @param b     the divisor's bit pattern (for its sign)
 * @param info  the operation's width/signedness
 * @param ty    the result's declared type
 * @return      the folded signed quotient
 * @since #comptime-fold
 */
fn int_div_signed(ua: u128, ub: u128, a: u128, b: u128, info: IntInfo, ty: Type) -> ConstValue | error {
    let uq = ua / ub
    let neg = bit_set(a, info.width - 1) != bit_set(b, info.width - 1)
    let res = if neg { twos_neg(uq, info.width) } else { uq }
    cv_int(mask_to_width(res, info.width), ty)
}

/**
 * int_rem_signed — the signed remainder from magnitudes: its magnitude is `ua % ub`, and
 * it takes the dividend's sign (C truncation semantics).
 *
 * @param ua    the dividend's magnitude
 * @param ub    the divisor's magnitude
 * @param a     the dividend's bit pattern (for its sign)
 * @param info  the operation's width/signedness
 * @param ty    the result's declared type
 * @return      the folded signed remainder
 * @since #comptime-fold
 */
fn int_rem_signed(ua: u128, ub: u128, a: u128, info: IntInfo, ty: Type) -> ConstValue | error {
    let ur = ua % ub
    let neg = bit_set(a, info.width - 1)
    let res = if neg { twos_neg(ur, info.width) } else { ur }
    cv_int(mask_to_width(res, info.width), ty)
}

/**
 * int_shift — a `<<` or `>>` at the LEFT operand's width, with the shift count taken from
 * the right operand's value and masked by (width - 1) — the SAME defined-wrap the runtime
 * shift helpers apply (the `teko_rt.h` tk_shl and tk_shr families), so an out-of-range
 * count never traps and the comptime result matches the metal bit-for-bit. A signed
 * right shift is arithmetic (sign-preserving).
 *
 * @param is_left  true for `<<`, false for `>>`
 * @param la       the folded left value (carries width/type)
 * @param ra       the folded right value (carries the count)
 * @param info     the left operand's width/signedness
 * @param e        the enclosing expression (positions any error)
 * @return         the folded shifted value, or a located error
 * @since #comptime-fold
 */
fn int_shift(is_left: bool, la: CVInt, ra: CVInt, info: IntInfo, e: TExpr) -> ConstValue | error {
    let cnt = shift_count(ra.bits, info.width)
    let a = mask_to_width(la.bits, info.width)
    if is_left { return cv_int(mask_to_width(a << cnt, info.width), la.ty) }
    if is_arith_shift(a, cnt, info) { return cv_int(arith_shr(a, cnt, info), la.ty) }
    cv_int(mask_to_width(a >> cnt, info.width), la.ty)
}

/**
 * shift_count — the effective shift amount: the count value's low log2(width) bits (the
 * runtime's `count & (width - 1)` mask), always in `[0, width - 1]`.
 *
 * @param bits  the count operand's bit pattern
 * @param w     the shifted value's bit width
 * @return      the masked shift amount as a u32
 * @since #comptime-fold
 */
fn shift_count(bits: u128, w: u32) -> u32 { (bits & ((w - 1) to u128)) to u32 }

/**
 * is_arith_shift — is this right-shift an arithmetic (sign-filling) one? Only when the
 * type is signed, the value is negative, and the count is non-zero.
 *
 * @param a     the shifted value's bit pattern
 * @param cnt   the shift amount
 * @param info  the shifted value's width/signedness
 * @return      true iff the shift must fill the vacated high bits with ones
 * @since #comptime-fold
 */
fn is_arith_shift(a: u128, cnt: u32, info: IntInfo) -> bool { info.is_signed && cnt > 0 && bit_set(a, info.width - 1) }

/**
 * arith_shr — the arithmetic right-shift of a negative signed value: the logical shift
 * with the `cnt` vacated high bits (within the width) filled with ones.
 *
 * @param a     the shifted value's bit pattern
 * @param cnt   the shift amount (non-zero)
 * @param info  the shifted value's width/signedness
 * @return      the sign-preserving shifted bits, reduced to width
 * @since #comptime-fold
 */
fn arith_shr(a: u128, cnt: u32, info: IntInfo) -> u128 {
    let logical = a >> cnt
    let fill = mask_to_width(width_mask(info.width) << (info.width - cnt), info.width)
    mask_to_width(logical | fill, info.width)
}

/**
 * float_binop — an f64 binary `+ - * /` through IEEE bits (mirroring the target's f64
 * arithmetic). A `/` by zero is a located compile error (M.1, mirroring the runtime's
 * trapping float divide); an f32 operand is not yet folded.
 *
 * @param op  the binary operator token
 * @param lf  the folded left float value
 * @param rf  the folded right float value
 * @param e   the enclosing expression (positions any error)
 * @return    the folded float value, or a located error
 * @throws    a located error on a division by zero
 * @since #comptime-fold
 */
fn float_binop(op: lexer::TokenKind, lf: CVFloat, rf: CVFloat, e: TExpr) -> ConstValue | error {
    if lf.is_f32 || rf.is_f32 { return const_form_error("comptime folding of f32 is not yet supported (#comptime-fold)", e) }
    let x = teko::f64_from_bits(lf.bits)
    let y = teko::f64_from_bits(rf.bits)
    match op {
        lexer::TokenKind::Plus => cv_float(teko::f64_bits(x + y), false)
        lexer::TokenKind::Minus => cv_float(teko::f64_bits(x - y), false)
        lexer::TokenKind::Star => cv_float(teko::f64_bits(x * y), false)
        lexer::TokenKind::Slash => float_div(x, y, e)
        _ => const_form_error("comptime fold: unsupported binary operator on a float constant (#comptime-fold)", e)
    }
}

/**
 * float_div — an f64 division with a zero-divisor guard (mirroring the runtime's trapping
 * float divide — M.1).
 *
 * @param x  the dividend
 * @param y  the divisor
 * @param e  the enclosing expression (positions any error)
 * @return   the folded quotient, or a located divide-by-zero error
 * @throws   a located error when the divisor is zero
 * @since #comptime-fold
 */
fn float_div(x: f64, y: f64, e: TExpr) -> ConstValue | error {
    if y == 0.0 { return const_form_error("float division by zero in a constant (#comptime-fold)", e) }
    cv_float(teko::f64_bits(x / y), false)
}

/**
 * cf_is_int_type — true iff `t` is an integer type the fold re-emits as a `TNumber` literal (a
 * `Prim` integer i8..i128 / u8..u128, or `byte`). The evaluability predicate and `literal_of` both
 * gate on this so the CF2 fold stays within the integer scalar subset (floats, chars, strings and
 * aggregates are left unfolded for a later crumb).
 *
 * @param t  the type to classify
 * @return   whether `t` is an integer/byte type
 * @since #comptime-fold
 */
fn cf_is_int_type(t: Type) -> bool {
    match int_info(t) {
        IntInfo => true
        error => false
    }
}

/**
 * cf_int_value — true iff `e` is a name-free, provably-const INTEGER op-tree the CF2 fold evaluates:
 * an integer literal, a byte literal, a cast to an integer type, or `~`/`-`/`+ - * / % & | ^ << >>`
 * over such operands. It is DELIBERATELY narrower than `is_const_expr` (the grammar oracle): it
 * excludes enum-member paths (`TPathExpr`), aggregate literals, allowlisted calls and float forms —
 * every shape `eval_const` does not yet reduce to a scalar integer — so a `true` guarantees
 * `eval_const` either produces a `CVInt` or raises a genuine M.1 value error (overflow / ÷0 /
 * out-of-range), never an unsupported-form error that would spuriously fail a valid program. Because
 * no admitted shape resolves a name, `eval_const` never touches the environment (an empty `Env`
 * suffices at the CF2 wiring site).
 *
 * @param e  the typed expression to classify
 * @return   whether `e` is an integer op-tree the fold may evaluate
 * @since #comptime-fold
 */
fn cf_int_value(e: TExpr) -> bool {
    match e.kind {
        TNumber as n => !n.is_float && cf_is_int_type(e.type)
        TByteLit => true
        TCast as c => cf_is_int_type(e.type) && cf_cast_operand_ok(c.expr)
        TUnary as u => is_const_unary_op(u.op) && cf_int_value(u.operand)
        TBinary as b => is_const_binary_op(b.op) && cf_int_value(b.left) && cf_int_value(b.right)
        _ => false
    }
}

/**
 * cf_cast_operand_ok — true iff `e` is a legal operand of an integer-target cast the fold evaluates:
 * an integer op-tree (`cf_int_value`) or a bare boolean literal (the sole `bool -> numeric` cast Teko
 * admits, folded by `cast_to_int` to 1/0). A boolean is admitted ONLY here, never as a bare fold root
 * or an arithmetic operand, so a fold never reaches `eval_const`'s unsupported `CVBool` arithmetic.
 *
 * @param e  the cast operand to classify
 * @return   whether the operand is a foldable integer op-tree or a bare boolean literal
 * @since #comptime-fold
 */
fn cf_cast_operand_ok(e: TExpr) -> bool {
    match e.kind {
        TBoolLit => true
        _ => cf_int_value(e)
    }
}

/**
 * cf_agg_value — true iff `e` is a const AGGREGATE the index fold may evaluate: an in-tree
 * `TArrayLit` whose every element is a foldable const (`cf_int_value`, or a nested `cf_agg_value`), or
 * a `TVar` (non-`is_func`) naming a module aggregate const in `agg`. A fn-value reference, a local
 * binding, a spread element, or any runtime leaf returns false, so the index stays runtime. The gate
 * that keeps `eval_const` from being called on a non-const receiver (the aggregate mirror of
 * `cf_int_value`).
 *
 * @param e    the receiver expression to classify
 * @param agg  the module-aggregate resolution table
 * @return     whether `e` is a foldable const aggregate
 * @since #comptime-fold
 */
fn cf_agg_value(e: TExpr, agg: AggConstMap) -> bool {
    match e.kind {
        TArrayLit as a => cf_array_elems_const(a, agg)
        TVar as v => cf_var_is_agg_const(v, agg)
        _ => false
    }
}

/**
 * cf_var_is_agg_const — true iff `v` is a non-function reference naming a module aggregate const
 * recorded in `agg`. A fn-value (`is_func`) is never a const aggregate; a name absent from `agg` (a
 * local, a scalar const, a different-module name) is not foldable.
 *
 * @param v    the reference node
 * @param agg  the module-aggregate resolution table
 * @return     whether `v` resolves to a module aggregate const
 * @since #comptime-fold
 */
fn cf_var_is_agg_const(v: TVar, agg: AggConstMap) -> bool {
    if v.is_func { return false }
    match agg_const_init(agg, v.name, v.func_ns) {
        null => false
        TExpr => true
    }
}

/**
 * cf_array_elems_const — true iff every element of the array literal `a` is a foldable const (a
 * `cf_int_value` scalar or a nested `cf_agg_value`) and none is a spread. Any runtime or spread
 * element makes the whole aggregate non-const, so the index stays runtime.
 *
 * @param a    the typed array literal
 * @param agg  the module-aggregate resolution table (for a nested aggregate element)
 * @return     whether every element is a foldable const
 * @since #comptime-fold
 */
fn cf_array_elems_const(a: TArrayLit, agg: AggConstMap) -> bool {
    mut i: u64 = 0
    loop {
        if i >= a.elements.len { break }
        if a.elements[i].is_spread { return false }
        if !cf_element_const(a.elements[i].expr, agg) { return false }
        i++
    }
    true
}

/**
 * cf_element_const — true iff the array element `e` is a foldable const: a scalar integer op-tree
 * (`cf_int_value`) or a nested const aggregate (`cf_agg_value`).
 *
 * @param e    the element expression
 * @param agg  the module-aggregate resolution table (for a nested aggregate element)
 * @return     whether `e` is a foldable const element
 * @since #comptime-fold
 */
fn cf_element_const(e: TExpr, agg: AggConstMap) -> bool {
    if cf_int_value(e) { return true }
    cf_agg_value(e, agg)
}

/**
 * cf_can_index — true iff the whole `TIndex` folds: a foldable const-aggregate receiver
 * (`cf_agg_value`) AND a foldable const-integer index (`cf_int_value`). When false the index is
 * rebuilt around its folded children (stays runtime), preserving today's behavior for a runtime index
 * or receiver.
 *
 * @param ix   the typed index expression
 * @param agg  the module-aggregate resolution table
 * @return     whether the index expression is fully const-foldable
 * @since #comptime-fold
 */
fn cf_can_index(ix: TIndex, agg: AggConstMap) -> bool {
    cf_agg_value(ix.receiver, agg) && cf_int_value(ix.index)
}

/**
 * cf_fold_int — the fold's integer-evaluability gate: `cf_int_value` EXTENDED with a
 * `TIndex`-of-const-aggregate arm (agg-aware), so an enclosing cast or op-tree over a const index
 * collapses to a single literal (`(G[0] to u64) to i32` -> `31`, not `((31 to byte) to u64) to i32`).
 * Kept SEPARATE from `cf_int_value` so the CF3 local-binding recording gate (`lp_record_simple`) — the
 * `seed_from_dep_qualified_value_const_and_fn` guard — keeps the name-free `cf_int_value` untouched.
 *
 * @param e    the typed expression to classify
 * @param agg  the module-aggregate resolution table
 * @return     whether `e` is an integer op-tree (possibly over a const index) the fold may evaluate
 * @since #comptime-fold
 */
fn cf_fold_int(e: TExpr, agg: AggConstMap) -> bool {
    match e.kind {
        TNumber as n => !n.is_float && cf_is_int_type(e.type)
        TByteLit => true
        TCast as c => cf_is_int_type(e.type) && cf_fold_cast_operand(c.expr, agg)
        TUnary as u => is_const_unary_op(u.op) && cf_fold_int(u.operand, agg)
        TBinary as b => is_const_binary_op(b.op) && cf_fold_int(b.left, agg) && cf_fold_int(b.right, agg)
        TIndex as ix => cf_can_index(ix, agg)
        _ => false
    }
}

/**
 * cf_fold_cast_operand — the fold's cast-operand gate: a bare boolean literal (the sole
 * `bool -> numeric` cast) or an integer op-tree the fold evaluates (`cf_fold_int`, so a const index
 * under a cast collapses). The agg-aware mirror of `cf_cast_operand_ok`.
 *
 * @param e    the cast operand to classify
 * @param agg  the module-aggregate resolution table
 * @return     whether the operand is a foldable integer op-tree or a bare boolean literal
 * @since #comptime-fold
 */
fn cf_fold_cast_operand(e: TExpr, agg: AggConstMap) -> bool {
    match e.kind {
        TBoolLit => true
        _ => cf_fold_int(e, agg)
    }
}

/**
 * i128_max_as_u128 — the largest signed-i128 value (2^127 - 1) as a u128, the ceiling above which an
 * unsigned comptime integer has NO `TNumber` literal form (the parser's `Number.value` carrier is an
 * i128, and `value_fits` admits an unsigned literal only when it is non-negative — a u128 whose top
 * bit is set cannot be spelled and is left unfolded).
 *
 * @return  2^127 - 1 as a u128
 * @since #comptime-fold
 */
fn i128_max_as_u128() -> u128 { msb_value(128) - (1 to u128) }

/**
 * cv_int_to_i128 — reconstruct the i128 literal carrier a `CVInt` of width/signedness `info` re-emits
 * as, in the SAME representation the parser/typer use (an unsigned value as its non-negative
 * magnitude, a signed value as its signed integer), or null when the value has no literal form (a
 * u128 whose magnitude exceeds i128-max — e.g. `~(0 to u128)`; such a value is left as its op-tree so
 * behavior is preserved). Every returned carrier round-trips: fed back to the pipeline as a `TNumber`
 * of the same type, it lowers to exactly the folded bits on both engines, because it is
 * indistinguishable from a hand-written literal the existing lowering already emits correctly.
 *
 * @param bits  the value's two's-complement bits
 * @param info  the value's width/signedness
 * @return      the i128 literal carrier, or null when the value is unrepresentable as a literal
 * @since #comptime-fold
 */
fn cv_int_to_i128(bits: u128, info: IntInfo) -> i128? {
    let v = mask_to_width(bits, info.width)
    if !info.is_signed {
        if v > i128_max_as_u128() { return null }
        return v to i128
    }
    if !bit_set(v, info.width - 1) { return v to i128 }
    if is_min_bits(v, info) { return signed_min_i128(info.width) }
    -(twos_neg(v, info.width) to i128)
}

/**
 * literal_of — reconstruct a literal `TExpr` from a computed `ConstValue`, typed as `ty` and
 * positioned at (`line`, `col`) — the inverse of `eval_const` used by the fold to splice a folded
 * literal back into the typed AST. CF2 reconstructs the INTEGER case (a `CVInt` becomes a `TNumber`
 * whose carrier is re-derived from the bits under `ty`); a value with no literal form (the u128
 * top-bit case, `cv_int_to_i128 == null`) and every non-integer kind (folded only from a later crumb)
 * return null, signalling the caller to leave the original op-tree unfolded (behavior preserved). The
 * produced node is indistinguishable to lowering from a hand-written literal — zero runtime.
 *
 * @param v     the computed comptime value
 * @param ty    the type the fold site resolved (the reconstructed literal's `.type`)
 * @param line  the original expression's source line (diagnostics/position)
 * @param col   the original expression's source column
 * @return      a literal `TExpr` carrying `v` typed `ty`, or null when `v` has no literal form
 * @since #comptime-fold
 */
fn literal_of(v: ConstValue, ty: Type, line: u32, col: u32) -> TExpr? {
    match v.kind {
        CVInt as ci => int_literal_of(ci, ty, line, col)
        _ => null
    }
}

/**
 * int_literal_of — reconstruct a `TNumber` literal from an integer comptime value `ci`, typed `ty`
 * and positioned at (`line`, `col`), or null when `ty` is not an integer or the value has no literal
 * carrier (`cv_int_to_i128 == null`).
 *
 * @param ci    the integer comptime value
 * @param ty    the reconstructed literal's type
 * @param line  the original expression's source line
 * @param col   the original expression's source column
 * @return      the `TNumber` literal, or null when unrepresentable
 * @since #comptime-fold
 */
fn int_literal_of(ci: CVInt, ty: Type, line: u32, col: u32) -> TExpr? {
    match int_info(ty) {
        error => null
        IntInfo as info => match cv_int_to_i128(ci.bits, info) {
            null => null
            i128 as val => TExpr { kind = TNumber { is_float = false; value = val; fval = 0.0 }; type = ty; line = line; col = col }
        }
    }
}

/**
 * fold_expr — the Layer-1a fold driver (CF2): rewrite `e` so every name-free, provably-const INTEGER
 * op-tree becomes the literal it evaluates to (`literal_of(eval_const(e))`), and every other node is
 * rebuilt around its folded children (a partially-const tree folds its const sub-trees). Composed
 * AFTER `inline_rw_expr`'s reference substitution, so a module const's op-tree (e.g. `~(0 to u64)`,
 * substituted at each use) collapses to its literal on BOTH engines — the VM loads an immediate
 * instead of re-executing the op-tree. TOTAL over `TExprKind`. A provably-const overflow / ÷0 /
 * out-of-range surfaces as a located compile error (M.1), propagated from `eval_const`.
 *
 * @param e      the typed expression to fold (post reference-substitution)
 * @param table  the type table (forwarded to the evaluator; unused for the integer subset)
 * @param env    the environment (unused for the name-free integer subset the fold admits)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the folded expression (a literal where provably const), or a located error
 * @throws       a located error when a folded constant overflows / divides by zero / is out of range
 * @since #comptime-fold
 */
pub fn fold_expr(e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    match e.kind {
        TUnary => fold_op_node(e, table, env, agg)
        TBinary => fold_op_node(e, table, env, agg)
        TCast => fold_op_node(e, table, env, agg)
        _ => fold_children(e, table, env, agg)
    }
}

/**
 * fold_op_node — fold a `~`/`-`/binary/cast node: when the whole subtree is a foldable integer
 * op-tree (`cf_fold_int`, which admits a const index under the op-tree so an enclosing cast over
 * `G[0]` collapses), evaluate it and splice the resulting literal; otherwise (or when the value has
 * no literal form) rebuild the node around its folded children.
 *
 * @param e      the operator/cast expression to fold
 * @param table  the type table (forwarded to the evaluator)
 * @param env    the environment (forwarded to the evaluator)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the folded literal, or the node rebuilt around folded children, or a located error
 * @since #comptime-fold
 */
fn fold_op_node(e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    if !cf_fold_int(e, agg) { return fold_children(e, table, env, agg) }
    match eval_const(e, table, env, agg) {
        error as x => return x
        ConstValue as v => fold_splice(v, e, table, env, agg)
    }
}

/**
 * fold_splice — splice a folded value `v` into the AST as a literal at `e`'s type/position, or (when
 * `v` has no literal form) rebuild `e` around its folded children so foldable sub-trees still fold.
 *
 * @param v      the folded comptime value
 * @param e      the original expression (its type/position for the reconstructed literal)
 * @param table  the type table (forwarded to the child rebuild)
 * @param env    the environment (forwarded to the child rebuild)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the reconstructed literal, or `e` rebuilt around folded children, or a located error
 * @since #comptime-fold
 */
fn fold_splice(v: ConstValue, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    match literal_of(v, e.type, e.line, e.col) {
        TExpr as lit => lit
        null => fold_children(e, table, env, agg)
    }
}

/**
 * fold_children — rebuild `e` around its folded children, recursing `fold_expr` into every
 * sub-expression, block and format spec (the structural mirror of `inline_rw_expr`, but
 * error-propagating so a folded overflow/÷0 surfaces). TOTAL over `TExprKind`; a leaf carries no
 * foldable child and is returned unchanged.
 *
 * @param e      the typed expression to rebuild
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       `e` rebuilt with folded children, or a located error from a child fold
 * @since #comptime-fold
 */
fn fold_children(e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    match e.kind {
        TNumber => e
        TStrLit => e
        TByteLit => e
        TCharLit => e
        TBoolLit => e
        TNullLit => e
        TPathExpr => e
        TVar => e
        TBinary as b => fold_binary(b, e, table, env, agg)
        TUnary as u => fold_unary(u, e, table, env, agg)
        TCompare as c => fold_compare(c, e, table, env, agg)
        TCall as cl => fold_call(cl, e, table, env, agg)
        TIfExpr as f => fold_if(f, e, table, env, agg)
        TMatchExpr as m => fold_match(m, e, table, env, agg)
        TCast as c => fold_cast(c, e, table, env, agg)
        TFieldAccess as fa => fold_field(fa, e, table, env, agg)
        TSafeFieldAccess as sfa => fold_safe_field(sfa, e, table, env, agg)
        TCoalesce as co => fold_coalesce(co, e, table, env, agg)
        TStructInit as si => fold_struct(si, e, table, env, agg)
        TIndex as ix => fold_index(ix, e, table, env, agg)
        TInterp as in => fold_rw_interp(in, e, table, env, agg)
        TInExpr as n => fold_in(n, e, table, env, agg)
        TArrayLit as a => fold_array(a, e, table, env, agg)
        TLambda as lam => fold_lambda(lam, e, table, env, agg)
        TBorrow as b => fold_borrow(b, e, table, env, agg)
    }
}

/**
 * fold_exprs — fold every expression in `xs` in order, propagating the first located error.
 *
 * @param xs     the typed expressions to fold
 * @param table  the type table (forwarded to each fold)
 * @param env    the environment (forwarded to each fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the folded expressions in order, or the first located error
 * @since #comptime-fold
 */
fn fold_exprs(xs: []TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> []TExpr | error {
    mut out: []TExpr = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= xs.len { break }
        let v = match fold_expr(xs[i], table, env, agg) { error as x => return x; TExpr as f => f }
        out = teko::list::push(out, v)
        i++
    }
    out
}

/**
 * fold_binary — rebuild a binary node around its folded operands (the non-evaluable path: at least
 * one operand carries a runtime leaf, so the operator itself stays runtime).
 *
 * @param b      the typed binary expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each operand fold)
 * @param env    the environment (forwarded to each operand fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the binary rebuilt with folded operands, or a located error
 * @since #comptime-fold
 */
fn fold_binary(b: TBinary, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let l = match fold_expr(b.left, table, env, agg) { error as x => return x; TExpr as v => v }
    let r = match fold_expr(b.right, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TBinary { op = b.op; left = l; right = r }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_unary — rebuild a unary node around its folded operand (the non-evaluable path: the operand
 * carries a runtime leaf).
 *
 * @param u      the typed unary expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to the operand fold)
 * @param env    the environment (forwarded to the operand fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the unary rebuilt with a folded operand, or a located error
 * @since #comptime-fold
 */
fn fold_unary(u: TUnary, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let o = match fold_expr(u.operand, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TUnary { op = u.op; operand = o }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_cast — rebuild a cast node around its folded operand (the non-evaluable / non-integer path).
 *
 * @param c      the typed cast expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to the operand fold)
 * @param env    the environment (forwarded to the operand fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the cast rebuilt with a folded operand, or a located error
 * @since #comptime-fold
 */
fn fold_cast(c: TCast, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let o = match fold_expr(c.expr, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TCast { expr = o }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_field — rebuild a field-access node around its folded receiver.
 *
 * @param fa     the typed field-access expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to the receiver fold)
 * @param env    the environment (forwarded to the receiver fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the field access rebuilt with a folded receiver, or a located error
 * @since #comptime-fold
 */
fn fold_field(fa: TFieldAccess, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let r = match fold_expr(fa.receiver, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TFieldAccess { receiver = r; field = fa.field }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_safe_field — rebuild an optional field-access node around its folded receiver.
 *
 * @param sfa    the typed optional field-access expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to the receiver fold)
 * @param env    the environment (forwarded to the receiver fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the optional field access rebuilt with a folded receiver, or a located error
 * @since #comptime-fold
 */
fn fold_safe_field(sfa: TSafeFieldAccess, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let r = match fold_expr(sfa.receiver, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TSafeFieldAccess { receiver = r; field = sfa.field }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_coalesce — rebuild a `??` coalesce node around its folded operands.
 *
 * @param co     the typed coalesce expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each operand fold)
 * @param env    the environment (forwarded to each operand fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the coalesce rebuilt with folded operands, or a located error
 * @since #comptime-fold
 */
fn fold_coalesce(co: TCoalesce, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let l = match fold_expr(co.left, table, env, agg) { error as x => return x; TExpr as v => v }
    let r = match fold_expr(co.right, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TCoalesce { left = l; right = r }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_index — fold an index of a const aggregate at a const index (Layer 1c): when the whole index
 * is const-foldable (`cf_can_index` — a const-aggregate receiver at a const integer index), evaluate
 * it and splice the element literal (mirroring `fold_op_node`); otherwise rebuild the index around its
 * folded receiver and index, so a runtime index or receiver stays a runtime `TIndex` (behavior
 * identical to today). An out-of-range or negative const index surfaces as a located compile error
 * (M.1), propagated from `eval_const`.
 *
 * @param ix     the typed index expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the folded element literal, or the index rebuilt with folded children, or a located error
 * @since #comptime-fold
 */
fn fold_index(ix: TIndex, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    if cf_can_index(ix, agg) {
        match eval_const(e, table, env, agg) {
            error as x => return x
            ConstValue as v => return fold_splice(v, e, table, env, agg)
        }
    }
    let r = match fold_expr(ix.receiver, table, env, agg) { error as x => return x; TExpr as v => v }
    let n = match fold_expr(ix.index, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TIndex { receiver = r; index = n }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_borrow — rebuild a `&x` borrow node around its folded operand.
 *
 * @param b      the typed borrow expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to the operand fold)
 * @param env    the environment (forwarded to the operand fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the borrow rebuilt with a folded operand, or a located error
 * @since #comptime-fold
 */
fn fold_borrow(b: TBorrow, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let o = match fold_expr(b.operand, table, env, agg) { error as x => return x; TExpr as v => v }
    TExpr { kind = TBorrow { operand = o }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_call — rebuild a call node around its folded argument expressions (the callee path carries no
 * foldable expression).
 *
 * @param cl     the typed call expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each argument fold)
 * @param env    the environment (forwarded to each argument fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the call rebuilt with folded arguments, or a located error
 * @since #comptime-fold
 */
fn fold_call(cl: TCall, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let args = match fold_exprs(cl.args, table, env, agg) { error as x => return x; []TExpr as a => a }
    TExpr { kind = TCall { callee = cl.callee; args = args; call_ns = cl.call_ns; is_closure_call = cl.is_closure_call; callee_type = cl.callee_type; is_iface_dispatch = cl.is_iface_dispatch; iface_slot = cl.iface_slot }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_struct — rebuild a struct-init node around its folded field values.
 *
 * @param si     the typed struct-init expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each field fold)
 * @param env    the environment (forwarded to each field fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the struct-init rebuilt with folded field values, or a located error
 * @since #comptime-fold
 */
fn fold_struct(si: TStructInit, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let vals = match fold_exprs(si.field_vals, table, env, agg) { error as x => return x; []TExpr as v => v }
    TExpr { kind = TStructInit { field_names = si.field_names; field_vals = vals }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_in — rebuild an `in` membership node around its folded left-hand side and element list.
 *
 * @param n      the typed `in` expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the `in` expression rebuilt with folded children, or a located error
 * @since #comptime-fold
 */
fn fold_in(n: TInExpr, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let lhs = match fold_expr(n.lhs, table, env, agg) { error as x => return x; TExpr as v => v }
    let elems = match fold_exprs(n.elems, table, env, agg) { error as x => return x; []TExpr as v => v }
    TExpr { kind = TInExpr { lhs = lhs; elems = elems }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_if — rebuild an `if` expression around its folded condition and folded branch blocks.
 *
 * @param f      the typed `if` expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the `if` expression rebuilt with folded children, or a located error
 * @since #comptime-fold
 */
fn fold_if(f: TIfExpr, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let cond = match fold_expr(f.cond, table, env, agg) { error as x => return x; TExpr as v => v }
    let then_blk = match fold_block(f.then_blk, table, env, agg) { error as x => return x; []TStatement as v => v }
    let else_blk = match fold_block(f.else_blk, table, env, agg) { error as x => return x; []TStatement as v => v }
    TExpr { kind = TIfExpr { cond = cond; then_blk = then_blk; has_else = f.has_else; else_blk = else_blk }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_compare — rebuild a comparison chain around its folded first operand and every folded
 * subsequent term.
 *
 * @param c      the typed comparison expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each operand fold)
 * @param env    the environment (forwarded to each operand fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the comparison rebuilt with folded operands, or a located error
 * @since #comptime-fold
 */
fn fold_compare(c: TCompare, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let first = match fold_expr(c.first, table, env, agg) { error as x => return x; TExpr as v => v }
    mut terms: []TCmpTerm = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= c.rest.len { break }
        let operand = match fold_expr(c.rest[i].operand, table, env, agg) { error as x => return x; TExpr as v => v }
        terms = teko::list::push(terms, TCmpTerm { op = c.rest[i].op; operand = operand })
        i++
    }
    TExpr { kind = TCompare { first = first; rest = terms }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_match — rebuild a match expression around its folded subject and every folded arm.
 *
 * @param m      the typed match expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the match rebuilt with folded children, or a located error
 * @since #comptime-fold
 */
fn fold_match(m: TMatchExpr, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let subject = match fold_expr(m.subject, table, env, agg) { error as x => return x; TExpr as v => v }
    mut arms: []TArm = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= m.arms.len { break }
        let arm = match fold_arm(m.arms[i], table, env, agg) { error as x => return x; TArm as a => a }
        arms = teko::list::push(arms, arm)
        i++
    }
    TExpr { kind = TMatchExpr { subject = subject; arms = arms }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_arm — fold one match arm: its guard (when present) and its body block.
 *
 * @param arm    the typed match arm
 * @param table  the type table (forwarded to the guard/body folds)
 * @param env    the environment (forwarded to the guard/body folds)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the arm with a folded guard and body, or a located error
 * @since #comptime-fold
 */
fn fold_arm(arm: TArm, table: TypeTable, env: Env, agg: AggConstMap) -> TArm | error {
    let guard = if arm.has_when {
        match fold_expr(arm.guard, table, env, agg) { error as x => return x; TExpr as v => v }
    } else { arm.guard }
    let body = match fold_block(arm.body, table, env, agg) { error as x => return x; []TStatement as v => v }
    TArm { pattern = arm.pattern; has_when = arm.has_when; guard = guard; body = body }
}

/**
 * fold_lambda — rebuild a closure literal around its folded body block (signature and captures carry
 * no foldable expression).
 *
 * @param lam    the typed closure literal
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to the body fold)
 * @param env    the environment (forwarded to the body fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the closure rebuilt with a folded body, or a located error
 * @since #comptime-fold
 */
fn fold_lambda(lam: TLambda, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    let body = match fold_block(lam.body, table, env, agg) { error as x => return x; []TStatement as v => v }
    TExpr { kind = TLambda { params = lam.params; body = body; captures = lam.captures; ret = lam.ret; lift_id = lam.lift_id }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_rw_interp — fold an interpolation: first fold each hole's op-tree (Layer 1a) so a
 * provably-const hole becomes its literal, then delegate the FINAL step to `fold_interp` (Layer 2),
 * which collapses the whole interpolation to a single `TStrLit` when every hole is a const literal and
 * every spec is `TFSpecNone`/`TFSpecStatic` of a foldable family — otherwise the interpolation is
 * returned as its runtime concat shape (behavior preserved for any runtime hole or dynamic spec).
 *
 * @param in     the typed interpolation expression
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each hole/spec fold and to `fold_interp`)
 * @param env    the environment (forwarded to each hole/spec fold and to `fold_interp`)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       a folded `TStrLit` when fully const, else the interpolation rebuilt with folded holes
 *               and specs, or a located error
 * @since #comptime-fold
 */
fn fold_rw_interp(in: TInterp, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    mut holes: []TExpr = teko::list::empty()
    mut specs: []TFSpec = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= in.holes.len { break }
        let hole = match fold_expr(in.holes[i], table, env, agg) { error as x => return x; TExpr as v => v }
        holes = teko::list::push(holes, hole)
        if i < in.specs.len {
            let sp = match fold_fspec(in.specs[i], table, env, agg) { error as x => return x; TFSpec as s => s }
            specs = teko::list::push(specs, sp)
        }
        i++
    }
    fold_interp(TInterp { pieces = in.pieces; holes = holes; specs = specs }, e, table, env, agg)
}

/**
 * fold_fspec — fold a format spec: a dynamic (`:[…]`) spec's argument expressions are folded; a
 * none/static spec carries no expression and is returned unchanged.
 *
 * @param sp     the format spec to fold
 * @param table  the type table (forwarded to each argument fold)
 * @param env    the environment (forwarded to each argument fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the spec with folded dynamic arguments, or a located error
 * @since #comptime-fold
 */
fn fold_fspec(sp: TFSpec, table: TypeTable, env: Env, agg: AggConstMap) -> TFSpec | error {
    match sp.kind {
        TFSpecDynamic as fd => {
            let args = match fold_exprs(fd.args, table, env, agg) { error as x => return x; []TExpr as a => a }
            TFSpec { kind = TFSpecDynamic { args = args } }
        }
        _ => sp
    }
}

/**
 * fold_array — rebuild an array/slice literal around its folded elements (a spread element's
 * sub-slice expression included).
 *
 * @param a      the typed array literal
 * @param e      the enclosing expression (its type/position)
 * @param table  the type table (forwarded to each element fold)
 * @param env    the environment (forwarded to each element fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the array literal rebuilt with folded elements, or a located error
 * @since #comptime-fold
 */
fn fold_array(a: TArrayLit, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    mut elems: []TArrayElem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= a.elements.len { break }
        let ex = match fold_expr(a.elements[i].expr, table, env, agg) { error as x => return x; TExpr as v => v }
        elems = teko::list::push(elems, TArrayElem { is_spread = a.elements[i].is_spread; expr = ex })
        i++
    }
    TExpr { kind = TArrayLit { elements = elems }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_block — fold every statement in `stmts` in order, propagating the first located error.
 *
 * @param stmts  the typed statement block
 * @param table  the type table (forwarded to each statement fold)
 * @param env    the environment (forwarded to each statement fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the block with each statement folded, or the first located error
 * @since #comptime-fold
 */
fn fold_block(stmts: []TStatement, table: TypeTable, env: Env, agg: AggConstMap) -> []TStatement | error {
    mut out: []TStatement = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= stmts.len { break }
        let s = match fold_stmt(stmts[i], table, env, agg) { error as x => return x; TStatement as v => v }
        out = teko::list::push(out, s)
        i++
    }
    out
}

/**
 * fold_stmt — fold one typed statement, folding every expression and nested block it carries. TOTAL
 * over `TStatement`; a value-less `break`/`continue` carries no foldable expression and is returned
 * unchanged.
 *
 * @param st     the typed statement to fold
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the statement with folded children, or a located error
 * @since #comptime-fold
 */
fn fold_stmt(st: TStatement, table: TypeTable, env: Env, agg: AggConstMap) -> TStatement | error {
    match st {
        TBinding as b => {
            let v = match fold_expr(b.value, table, env, agg) { error as x => return x; TExpr as f => f }
            TBinding { kind = b.kind; target = b.target; bound = b.bound; value = v }
        }
        TAssign as a => fold_assign(a, table, env, agg)
        TReturn as r => fold_return(r, st, table, env, agg)
        TLoopStmt as l => {
            let init = match fold_block(l.init, table, env, agg) { error as x => return x; []TStatement as v => v }
            let body = match fold_block(l.body, table, env, agg) { error as x => return x; []TStatement as v => v }
            TLoopStmt { label = l.label; init = init; body = body }
        }
        TBreakStmt => st
        TContinueStmt => st
        TExprStmt as es => {
            let v = match fold_expr(es.expr, table, env, agg) { error as x => return x; TExpr as f => f }
            TExprStmt { expr = v }
        }
        TDeferStmt as d => {
            let body = match fold_block(d.body, table, env, agg) { error as x => return x; []TStatement as v => v }
            TDeferStmt { body = body }
        }
        TAdoptStmt as a => {
            let body = match fold_block(a.body, table, env, agg) { error as x => return x; []TStatement as v => v }
            TAdoptStmt { name = a.name; body = body }
        }
    }
}

/**
 * fold_return — fold a `return` statement's value (a value-less `return` is returned unchanged).
 *
 * @param r      the typed return statement
 * @param st     the original statement (returned unchanged when value-less)
 * @param table  the type table (forwarded to the value fold)
 * @param env    the environment (forwarded to the value fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the return with a folded value, or a located error
 * @since #comptime-fold
 */
fn fold_return(r: TReturn, st: TStatement, table: TypeTable, env: Env, agg: AggConstMap) -> TStatement | error {
    if !r.has_value { return st }
    let v = match fold_expr(r.value, table, env, agg) { error as x => return x; TExpr as f => f }
    TReturn { has_value = true; value = v }
}

/**
 * fold_assign — fold an assignment's value and, for a field target, its typed LHS field-access
 * expression (a simple/ref-deref target carries no foldable expression).
 *
 * @param a      the typed assignment
 * @param table  the type table (forwarded to each child fold)
 * @param env    the environment (forwarded to each child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the assignment with folded children, or a located error
 * @since #comptime-fold
 */
fn fold_assign(a: TAssign, table: TypeTable, env: Env, agg: AggConstMap) -> TStatement | error {
    let value = match fold_expr(a.value, table, env, agg) { error as x => return x; TExpr as f => f }
    match a.kind {
        parser::AssignKind::Field => {
            let target = match fold_expr(a.target, table, env, agg) { error as x => return x; TExpr as f => f }
            TAssign { kind = a.kind; name = a.name; op = a.op; bound = a.bound; value = value; deref = a.deref; target = target }
        }
        _ => TAssign { kind = a.kind; name = a.name; op = a.op; bound = a.bound; value = value; deref = a.deref; target = a.target }
    }
}

/**
 * fold_empty_table — an empty type table for the CF2 fold: the name-free integer subset the fold
 * admits never resolves a type through the table, so an empty one suffices at the wiring site.
 *
 * @return  an empty type table
 * @since #comptime-fold
 */
fn fold_empty_table() -> TypeTable { teko::list::empty() }

/**
 * fold_program — fold every item of the substituted program: a function's body, a const declaration's
 * initializer and a loose statement each have their op-trees folded; every other item passes through
 * unchanged. Composed after `inline_consts`'s reference substitution as the second Layer-1a pass. The
 * `agg` map (built once by the caller from the substituted program) resolves a module-aggregate-const
 * `TVar` receiver of a const `TIndex` so `G[0]` folds to its element on BOTH engines (Layer 1c).
 *
 * @param prog  the reference-substituted typed program
 * @param agg   the module-aggregate resolution table (module aggregate consts, dependency-ordered)
 * @return      the program with provably-const integer op-trees folded to literals, or a located
 *              error (a folded constant overflow / ÷0 / out-of-range)
 * @since #comptime-fold
 */
pub fn fold_program(prog: TProgram, agg: AggConstMap) -> TProgram | error {
    let table = fold_empty_table()
    let env = env_empty()
    mut out: []TItem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        let it = match fold_item(prog.items[i], table, env, agg) { error as x => return x; TItem as v => v }
        out = teko::list::push(out, it)
        i++
    }
    TProgram { items = out }
}

/**
 * fold_item — fold one program item: a function's body, a const declaration's initializer or a loose
 * statement; every other item (a type/use declaration) passes through unchanged.
 *
 * @param it     the program item to fold
 * @param table  the type table (forwarded to the child fold)
 * @param env    the environment (forwarded to the child fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the item with its op-trees folded, or a located error
 * @since #comptime-fold
 */
fn fold_item(it: TItem, table: TypeTable, env: Env, agg: AggConstMap) -> TItem | error {
    match it {
        TFunction as f => fold_function(f, table, env, agg)
        TConstDecl as cd => fold_const_decl(cd, table, env, agg)
        TStatement as s => match fold_stmt(s, table, env, agg) { error as x => return x; TStatement as v => v }
        _ => it
    }
}

/**
 * fold_function — fold a top-level function's body; its signature, visibility and metadata are
 * preserved.
 *
 * @param f      the typed function
 * @param table  the type table (forwarded to the body fold)
 * @param env    the environment (forwarded to the body fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the function with a folded body, or a located error
 * @since #comptime-fold
 */
fn fold_function(f: TFunction, table: TypeTable, env: Env, agg: AggConstMap) -> TItem | error {
    let body = match fold_block(f.body, table, env, agg) { error as x => return x; []TStatement as v => v }
    TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = f.params; return_type = f.return_type; body = body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = f.namespace; file = f.file; line = f.line; col = f.col; is_test = f.is_test; is_extern = f.is_extern; c_symbol = f.c_symbol; from_lib = f.from_lib }
}

/**
 * fold_const_decl — fold a const declaration's initializer (the surviving exported scalar consts and
 * every aggregate const collapse their op-trees to literals); the declaration's metadata is preserved.
 *
 * @param cd     the typed const declaration
 * @param table  the type table (forwarded to the initializer fold)
 * @param env    the environment (forwarded to the initializer fold)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the const declaration with a folded initializer, or a located error
 * @since #comptime-fold
 */
fn fold_const_decl(cd: TConstDecl, table: TypeTable, env: Env, agg: AggConstMap) -> TItem | error {
    let init = match fold_expr(cd.init, table, env, agg) { error as x => return x; TExpr as v => v }
    TConstDecl { name = cd.name; namespace = cd.namespace; ty = cd.ty; init = init; vis = cd.vis; has_doc = cd.has_doc; doc = cd.doc; line = cd.line; col = cd.col }
}

/**
 * LocalConstMap — the CF3 (Layer 1b) local-binding substitution table: two PARALLEL lists over the
 * provably-const LOCAL `let`/`const` bindings currently in scope. A binding is recorded by NAME
 * (locals resolve lexically inside a function, so a bare name is the key — unlike the module map's
 * `(name, namespace)`), mapping to its already-substituted, provably-const integer initializer op-tree.
 * A use of the name splices a clone of that op-tree, which the composed `fold_program` pass then
 * collapses to a literal on BOTH engines. The map is threaded block-scoped: a nested block inherits the
 * outer entries but its own additions do NOT leak past the block, and a shadowing binding overrides (a
 * runtime-valued or `mut` shadow REMOVES the name, so a use of the shadow is never folded).
 *
 * @field names  the recorded const locals' names, in record order (a shadow is removed-then-appended)
 * @field inits  PARALLEL to `names` — each local's already-substituted provably-const initializer
 * @since #comptime-fold
 */
type LocalConstMap = struct { names: []str; inits: []TExpr }

/**
 * LpBlock — the result of local-propagating a statement block: the rewritten statements plus the map
 * the block LEAVES (its bindings extend it). A loop's `init` preamble hands its leaving map to the loop
 * `body` through this carrier; a plain scope discards the leaving map (block-local bindings do not leak).
 *
 * @field stmts  the block's statements with local-const references substituted
 * @field map    the local-const map the block leaves (its own bindings recorded)
 * @since #comptime-fold
 */
type LpBlock = struct { stmts: []TStatement; map: LocalConstMap }

/**
 * LpStmt — the result of local-propagating one statement: the rewritten statement plus the map it
 * leaves (a `let`/`const` binding of a provably-const integer extends the map; every other statement
 * leaves it unchanged).
 *
 * @field stmt  the statement with local-const references substituted
 * @field map   the local-const map the statement leaves
 * @since #comptime-fold
 */
type LpStmt = struct { stmt: TStatement; map: LocalConstMap }

/**
 * LpItem — the result of local-propagating one top-level item: the rewritten item plus the map it
 * leaves (a loose top-level `let`/`const` statement — the implicit `main`'s body — threads its recorded
 * const into the following loose statements; a function or declaration leaves the top-level map as it
 * was, its own body propagated in a fresh scope).
 *
 * @field item  the item with local-const references substituted
 * @field map   the top-level local-const map the item leaves
 * @since #comptime-fold
 */
type LpItem = struct { item: TItem; map: LocalConstMap }

/**
 * lp_empty — an empty local-const map, the fresh scope a function body (and the loose top-level
 * statement stream) starts from.
 *
 * @return  a local-const map with no entries
 * @since #comptime-fold
 */
fn lp_empty() -> LocalConstMap { LocalConstMap { names = teko::list::empty(); inits = teko::list::empty() } }

/**
 * lp_lookup — the recorded provably-const initializer of the local named `name`, or null when no
 * in-scope const local matches. Scans from the most recent entry so a same-name shadow recorded later
 * wins.
 *
 * @param m     the local-const map
 * @param name  the referenced local's name
 * @return      the recorded initializer op-tree, or null
 * @since #comptime-fold
 */
fn lp_lookup(m: LocalConstMap, name: str) -> TExpr? {
    mut i: u64 = m.names.len
    loop {
        if i == 0 { break }
        i--
        if m.names[i] == name { return m.inits[i] }
    }
    null
}

/**
 * lp_remove — the local-const map with every entry named `name` dropped, the operation a `mut`,
 * runtime-valued, or destructured binding performs to KILL any prior const of that name for the rest of
 * the scope (so a use of the shadow is never folded — DECISION_LOG:391 preserved).
 *
 * @param m     the local-const map
 * @param name  the name to drop
 * @return      `m` with `name` removed
 * @since #comptime-fold
 */
fn lp_remove(m: LocalConstMap, name: str) -> LocalConstMap {
    mut names: []str = teko::list::empty()
    mut inits: []TExpr = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= m.names.len { break }
        if m.names[i] != name {
            names = teko::list::push(names, m.names[i])
            inits = teko::list::push(inits, m.inits[i])
        }
        i++
    }
    LocalConstMap { names = names; inits = inits }
}

/**
 * lp_set — the local-const map with `name` bound to the provably-const initializer `init`, replacing
 * any prior binding of that name (remove-then-append, so a shadow overrides cleanly).
 *
 * @param m     the local-const map
 * @param name  the binding's name
 * @param init  its already-substituted provably-const initializer op-tree
 * @return      `m` with `name` bound to `init`
 * @since #comptime-fold
 */
fn lp_set(m: LocalConstMap, name: str, init: TExpr) -> LocalConstMap {
    let r = lp_remove(m, name)
    LocalConstMap { names = teko::list::push(r.names, name); inits = teko::list::push(r.inits, init) }
}

/**
 * lp_remove_names — the local-const map with every name in `names` dropped, used to kill the outer
 * const of a name a destructure or a match pattern re-binds inside a nested scope.
 *
 * @param m      the local-const map
 * @param names  the names to drop
 * @return       `m` with every listed name removed
 * @since #comptime-fold
 */
fn lp_remove_names(m: LocalConstMap, names: []str) -> LocalConstMap {
    mut cur = m
    mut i: u64 = 0
    loop {
        if i >= names.len { break }
        cur = lp_remove(cur, names[i])
        i++
    }
    cur
}

/**
 * lp_is_const_binding — true iff a binding of kind `k` is IMMUTABLE (`let`/`const`), the only family
 * CF3 propagates. A `mut` binding is never recorded even when its initializer is provably const,
 * because a later reassignment (`mut a = 0xFF; a = read()`) would make a folded use dishonest.
 *
 * @param k  the binding kind
 * @return   whether the binding is a `let` or `const` (immutable)
 * @since #comptime-fold
 */
fn lp_is_const_binding(k: parser::BindKind) -> bool { k == parser::BindKind::Let || k == parser::BindKind::Const }

/**
 * pattern_binds — the names a match pattern binds into its arm scope: the optional binding of a
 * `Foo as x` bind-pattern, the destructured field names of a `Type { f; g }` field-pattern, or the
 * union over an alternation's options. These names shadow any outer const of the same name inside the
 * arm, so CF3 removes them from the arm's map before propagating.
 *
 * @param pat  the arm's pattern
 * @return     the names the pattern binds
 * @since #comptime-fold
 */
fn pattern_binds(pat: parser::Pattern) -> []str {
    match pat {
        parser::BindPattern as bp => if bp.has_binding { teko::list::push(teko::list::empty(), bp.binding) } else { teko::list::empty() }
        parser::FieldPattern as fp => fp.fields
        parser::AltPattern as ap => pattern_binds_alts(ap.options)
        _ => teko::list::empty()
    }
}

/**
 * pattern_binds_alts — the union of the names bound by every option of an alternation pattern.
 *
 * @param options  the alternation's sub-patterns
 * @return         the concatenated bound names of every option
 * @since #comptime-fold
 */
fn pattern_binds_alts(options: []parser::Pattern) -> []str {
    mut out: []str = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= options.len { break }
        let names = pattern_binds(options[i])
        mut j: u64 = 0
        loop {
            if j >= names.len { break }
            out = teko::list::push(out, names[j])
            j++
        }
        i++
    }
    out
}

/**
 * lp_record_binding — extend the map with a binding's contribution: a `let`/`const` SimpleName target
 * whose (already-substituted) initializer is a provably-const integer op-tree (`cf_int_value`) is
 * recorded; every other binding (a `mut`, a runtime-valued initializer, a destructure) REMOVES its
 * name(s) from the map so a use of the shadow is never folded.
 *
 * @param m       the local-const map
 * @param kind    the binding kind
 * @param target  the binding target (a simple name or a destructure pattern)
 * @param value   the binding's already-substituted initializer
 * @return        `m` extended (const binding) or with the bound name(s) removed
 * @since #comptime-fold
 */
fn lp_record_binding(m: LocalConstMap, kind: parser::BindKind, target: parser::BindTarget, value: TExpr) -> LocalConstMap {
    match target {
        parser::SimpleName as sn => lp_record_simple(m, kind, sn.name, value)
        parser::DestructurePattern as dp => lp_remove_names(m, dp.names)
    }
}

/**
 * lp_record_simple — record a simple-name binding: an immutable binding of a provably-const integer
 * op-tree is bound in the map; anything else removes the name (killing an outer const it shadows).
 *
 * @param m      the local-const map
 * @param kind   the binding kind
 * @param name   the bound name
 * @param value  the binding's already-substituted initializer
 * @return       `m` with `name` bound (const) or removed
 * @since #comptime-fold
 */
fn lp_record_simple(m: LocalConstMap, kind: parser::BindKind, name: str, value: TExpr) -> LocalConstMap {
    if lp_is_const_binding(kind) && cf_int_value(value) { return lp_set(m, name, value) }
    lp_remove(m, name)
}

/**
 * lp_var — substitute a reference to a recorded const local with a clone of its provably-const
 * initializer (widened to the reference's resolved type when they differ, reusing the module-const
 * path's `widen_inlined_const`). A function-value reference (`is_func`) is never a const local, and a
 * name not in the map (a param, a runtime binding, an outer name) passes through unchanged.
 *
 * @param v  the reference node
 * @param e  the original expression (returned when `v` is not a recorded const local)
 * @param m  the local-const map
 * @return   the substituted initializer, or `e` unchanged
 * @since #comptime-fold
 */
fn lp_var(v: TVar, e: TExpr, m: LocalConstMap) -> TExpr {
    if v.is_func { return e }
    match lp_lookup(m, v.name) {
        TExpr as sub => widen_inlined_const(e, sub)
        null => e
    }
}

/**
 * lp_exprs — local-propagate every expression in `xs`, in order.
 *
 * @param xs  the expressions to rewrite
 * @param m   the local-const map
 * @return    the rewritten expressions, in order
 * @since #comptime-fold
 */
fn lp_exprs(xs: []TExpr, m: LocalConstMap) -> []TExpr {
    mut out: []TExpr = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= xs.len { break }
        out = teko::list::push(out, lp_expr(xs[i], m))
        i++
    }
    out
}

/**
 * lp_expr — local-propagate one typed expression: replace every reference to a recorded const local
 * with a clone of its provably-const initializer, recursing TOTALLY into every child. A nested
 * statement block (`if`/`match` branch) is propagated as a fresh child scope that inherits the current
 * map but does not leak its own bindings (`lp_scope_block`). A closure literal (`TLambda`) is left
 * UNCHANGED: its capture set was fixed by the typer, so substituting a captured local inside its body
 * would leave a stale capture — CF3 conservatively does not fold locals across a closure boundary.
 * TOTAL over every `TExprKind`.
 *
 * @param e  the typed expression to rewrite
 * @param m  the local-const map
 * @return   the expression with local-const references substituted
 * @since #comptime-fold
 */
fn lp_expr(e: TExpr, m: LocalConstMap) -> TExpr {
    match e.kind {
        TNumber => e
        TStrLit => e
        TByteLit => e
        TCharLit => e
        TBoolLit => e
        TNullLit => e
        TPathExpr => e
        TVar as v => lp_var(v, e, m)
        TBinary as b => TExpr { kind = TBinary { op = b.op; left = lp_expr(b.left, m); right = lp_expr(b.right, m) }; type = e.type; line = e.line; col = e.col }
        TUnary as u => TExpr { kind = TUnary { op = u.op; operand = lp_expr(u.operand, m) }; type = e.type; line = e.line; col = e.col }
        TCompare as c => lp_compare(c, e, m)
        TCall as cl => TExpr { kind = TCall { callee = cl.callee; args = lp_exprs(cl.args, m); call_ns = cl.call_ns; is_closure_call = cl.is_closure_call; callee_type = cl.callee_type; is_iface_dispatch = cl.is_iface_dispatch; iface_slot = cl.iface_slot }; type = e.type; line = e.line; col = e.col }
        TIfExpr as f => lp_if(f, e, m)
        TMatchExpr as mm => lp_match(mm, e, m)
        TCast as c => TExpr { kind = TCast { expr = lp_expr(c.expr, m) }; type = e.type; line = e.line; col = e.col }
        TFieldAccess as fa => TExpr { kind = TFieldAccess { receiver = lp_expr(fa.receiver, m); field = fa.field }; type = e.type; line = e.line; col = e.col }
        TSafeFieldAccess as sfa => TExpr { kind = TSafeFieldAccess { receiver = lp_expr(sfa.receiver, m); field = sfa.field }; type = e.type; line = e.line; col = e.col }
        TCoalesce as co => TExpr { kind = TCoalesce { left = lp_expr(co.left, m); right = lp_expr(co.right, m) }; type = e.type; line = e.line; col = e.col }
        TStructInit as si => TExpr { kind = TStructInit { field_names = si.field_names; field_vals = lp_exprs(si.field_vals, m) }; type = e.type; line = e.line; col = e.col }
        TIndex as ix => TExpr { kind = TIndex { receiver = lp_expr(ix.receiver, m); index = lp_expr(ix.index, m) }; type = e.type; line = e.line; col = e.col }
        TInterp as in => lp_interp(in, e, m)
        TInExpr as n => TExpr { kind = TInExpr { lhs = lp_expr(n.lhs, m); elems = lp_exprs(n.elems, m) }; type = e.type; line = e.line; col = e.col }
        TArrayLit as a => lp_array(a, e, m)
        TLambda => e
        TBorrow as b => TExpr { kind = TBorrow { operand = lp_expr(b.operand, m) }; type = e.type; line = e.line; col = e.col }
    }
}

/**
 * lp_compare — local-propagate a comparison chain's first operand and every subsequent term.
 *
 * @param c  the typed comparison expression
 * @param e  the enclosing expression (its type/position)
 * @param m  the local-const map
 * @return   the comparison with local-const references substituted
 * @since #comptime-fold
 */
fn lp_compare(c: TCompare, e: TExpr, m: LocalConstMap) -> TExpr {
    mut terms: []TCmpTerm = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= c.rest.len { break }
        terms = teko::list::push(terms, TCmpTerm { op = c.rest[i].op; operand = lp_expr(c.rest[i].operand, m) })
        i++
    }
    TExpr { kind = TCompare { first = lp_expr(c.first, m); rest = terms }; type = e.type; line = e.line; col = e.col }
}

/**
 * lp_if — local-propagate an `if` expression: its condition in the current scope, each branch block as
 * a fresh child scope (a branch-local binding does not leak past the branch).
 *
 * @param f  the typed `if` expression
 * @param e  the enclosing expression (its type/position)
 * @param m  the local-const map
 * @return   the `if` with local-const references substituted
 * @since #comptime-fold
 */
fn lp_if(f: TIfExpr, e: TExpr, m: LocalConstMap) -> TExpr {
    let cond = lp_expr(f.cond, m)
    let then_blk = lp_scope_block(f.then_blk, m)
    let else_blk = lp_scope_block(f.else_blk, m)
    TExpr { kind = TIfExpr { cond = cond; then_blk = then_blk; has_else = f.has_else; else_blk = else_blk }; type = e.type; line = e.line; col = e.col }
}

/**
 * lp_match — local-propagate a match expression: its subject in the current scope, then every arm.
 *
 * @param mm  the typed match expression
 * @param e   the enclosing expression (its type/position)
 * @param m   the local-const map
 * @return    the match with local-const references substituted
 * @since #comptime-fold
 */
fn lp_match(mm: TMatchExpr, e: TExpr, m: LocalConstMap) -> TExpr {
    let subject = lp_expr(mm.subject, m)
    mut arms: []TArm = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= mm.arms.len { break }
        arms = teko::list::push(arms, lp_arm(mm.arms[i], m))
        i++
    }
    TExpr { kind = TMatchExpr { subject = subject; arms = arms }; type = e.type; line = e.line; col = e.col }
}

/**
 * lp_arm — local-propagate one match arm as a fresh child scope: the names the pattern binds shadow any
 * outer const of the same name, so they are removed from the arm's map before its guard and body are
 * propagated.
 *
 * @param arm  the typed match arm
 * @param m    the local-const map
 * @return     the arm with local-const references substituted
 * @since #comptime-fold
 */
fn lp_arm(arm: TArm, m: LocalConstMap) -> TArm {
    let scoped = lp_remove_names(m, pattern_binds(arm.pattern))
    let guard = if arm.has_when { lp_expr(arm.guard, scoped) } else { arm.guard }
    let body = lp_scope_block(arm.body, scoped)
    TArm { pattern = arm.pattern; has_when = arm.has_when; guard = guard; body = body }
}

/**
 * lp_interp — local-propagate a string interpolation's hole expressions and dynamic format specs.
 *
 * @param in  the typed interpolation expression
 * @param e   the enclosing expression (its type/position)
 * @param m   the local-const map
 * @return    the interpolation with local-const references substituted
 * @since #comptime-fold
 */
fn lp_interp(in: TInterp, e: TExpr, m: LocalConstMap) -> TExpr {
    mut holes: []TExpr = teko::list::empty()
    mut specs: []TFSpec = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= in.holes.len { break }
        holes = teko::list::push(holes, lp_expr(in.holes[i], m))
        if i < in.specs.len { specs = teko::list::push(specs, lp_fspec(in.specs[i], m)) }
        i++
    }
    TExpr { kind = TInterp { pieces = in.pieces; holes = holes; specs = specs }; type = e.type; line = e.line; col = e.col }
}

/**
 * lp_fspec — local-propagate a format spec: a dynamic (`:[…]`) spec's argument expressions; a
 * none/static spec carries no expression and is returned unchanged.
 *
 * @param sp  the format spec
 * @param m   the local-const map
 * @return    the spec with local-const references substituted in its dynamic args
 * @since #comptime-fold
 */
fn lp_fspec(sp: TFSpec, m: LocalConstMap) -> TFSpec {
    match sp.kind {
        TFSpecDynamic as fd => TFSpec { kind = TFSpecDynamic { args = lp_exprs(fd.args, m) } }
        _ => sp
    }
}

/**
 * lp_array — local-propagate an array/slice literal's elements (a spread element's sub-slice included).
 *
 * @param a  the typed array literal
 * @param e  the enclosing expression (its type/position)
 * @param m  the local-const map
 * @return   the array literal with local-const references substituted
 * @since #comptime-fold
 */
fn lp_array(a: TArrayLit, e: TExpr, m: LocalConstMap) -> TExpr {
    mut elems: []TArrayElem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= a.elements.len { break }
        elems = teko::list::push(elems, TArrayElem { is_spread = a.elements[i].is_spread; expr = lp_expr(a.elements[i].expr, m) })
        i++
    }
    TExpr { kind = TArrayLit { elements = elems }; type = e.type; line = e.line; col = e.col }
}

/**
 * lp_scope_block — local-propagate a nested block as a fresh child scope: it inherits the outer map but
 * the map it leaves is discarded (a block-local binding does not leak past the block).
 *
 * @param stmts  the nested block's statements
 * @param m      the inherited local-const map
 * @return       the block with local-const references substituted
 * @since #comptime-fold
 */
fn lp_scope_block(stmts: []TStatement, m: LocalConstMap) -> []TStatement { lp_block(stmts, m).stmts }

/**
 * lp_block — local-propagate a straight-line block, THREADING the map through its statements in order
 * so a `let a = 0xFF` recorded by one statement is visible to the next (`let hi = a >> 4`). Returns both
 * the rewritten statements and the map the block leaves (a loop's `init` hands its leaving map to the
 * loop body).
 *
 * @param stmts  the block's statements
 * @param m      the inherited local-const map
 * @return       the rewritten statements plus the map the block leaves
 * @since #comptime-fold
 */
fn lp_block(stmts: []TStatement, m: LocalConstMap) -> LpBlock {
    mut cur = m
    mut out: []TStatement = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= stmts.len { break }
        let r = lp_stmt(stmts[i], cur)
        out = teko::list::push(out, r.stmt)
        cur = r.map
        i++
    }
    LpBlock { stmts = out; map = cur }
}

/**
 * lp_stmt — local-propagate one typed statement, returning it plus the map it leaves. A `let`/`const`
 * binding of a provably-const integer extends the map (`lp_binding`); every other statement propagates
 * its expressions/nested blocks and leaves the map unchanged. TOTAL over every `TStatement` case.
 *
 * @param st  the typed statement
 * @param m   the local-const map
 * @return    the statement with local-const references substituted, plus the map it leaves
 * @since #comptime-fold
 */
fn lp_stmt(st: TStatement, m: LocalConstMap) -> LpStmt {
    match st {
        TBinding as b => lp_binding(b, m)
        TAssign as a => LpStmt { stmt = lp_assign(a, m); map = m }
        TReturn as r => LpStmt { stmt = lp_return(r, st, m); map = m }
        TLoopStmt as l => LpStmt { stmt = lp_loop(l, m); map = m }
        TBreakStmt => LpStmt { stmt = st; map = m }
        TContinueStmt => LpStmt { stmt = st; map = m }
        TExprStmt as es => LpStmt { stmt = TExprStmt { expr = lp_expr(es.expr, m) }; map = m }
        TDeferStmt as d => LpStmt { stmt = TDeferStmt { body = lp_scope_block(d.body, m) }; map = m }
        TAdoptStmt as a => LpStmt { stmt = lp_adopt(a, m); map = m }
    }
}

/**
 * lp_binding — local-propagate a binding: substitute local-const references in its initializer, then
 * extend the map with the binding's contribution (recorded when it is an immutable, provably-const
 * integer; otherwise its name is removed so a shadow is never folded).
 *
 * @param b  the typed binding
 * @param m  the local-const map
 * @return   the binding with its initializer substituted, plus the map it leaves
 * @since #comptime-fold
 */
fn lp_binding(b: TBinding, m: LocalConstMap) -> LpStmt {
    let value = lp_expr(b.value, m)
    let m2 = lp_record_binding(m, b.kind, b.target, value)
    LpStmt { stmt = TBinding { kind = b.kind; target = b.target; bound = b.bound; value = value }; map = m2 }
}

/**
 * lp_loop — local-propagate a loop: its run-once `init` preamble threads its recorded consts into the
 * loop `body`, but neither the init nor the body leak past the loop (the loop is a scope) — the caller
 * leaves the outer map unchanged.
 *
 * @param l  the typed loop statement
 * @param m  the local-const map
 * @return   the loop with local-const references substituted
 * @since #comptime-fold
 */
fn lp_loop(l: TLoopStmt, m: LocalConstMap) -> TStatement {
    let ib = lp_block(l.init, m)
    let body = lp_scope_block(l.body, ib.map)
    TLoopStmt { label = l.label; init = ib.stmts; body = body }
}

/**
 * lp_adopt — local-propagate an `adopt` region block as a fresh child scope; its optional bound region
 * name shadows any outer const of the same name inside the body.
 *
 * @param a  the typed adopt statement
 * @param m  the local-const map
 * @return   the adopt with local-const references substituted
 * @since #comptime-fold
 */
fn lp_adopt(a: TAdoptStmt, m: LocalConstMap) -> TStatement {
    let scoped = lp_remove(m, a.name)
    TAdoptStmt { name = a.name; body = lp_scope_block(a.body, scoped) }
}

/**
 * lp_return — local-propagate a `return` statement's value (a value-less `return` is unchanged).
 *
 * @param r   the typed return statement
 * @param st  the original statement (returned unchanged when value-less)
 * @param m   the local-const map
 * @return    the return with its value substituted
 * @since #comptime-fold
 */
fn lp_return(r: TReturn, st: TStatement, m: LocalConstMap) -> TStatement {
    if !r.has_value { return st }
    TReturn { has_value = true; value = lp_expr(r.value, m) }
}

/**
 * lp_assign — local-propagate an assignment's value and, for a field target, its typed LHS field-access
 * expression. An assignment never targets a recorded const (the checker forbids assigning a `let`/
 * `const`), so it leaves the map unchanged.
 *
 * @param a  the typed assignment
 * @param m  the local-const map
 * @return   the assignment with local-const references substituted
 * @since #comptime-fold
 */
fn lp_assign(a: TAssign, m: LocalConstMap) -> TStatement {
    let value = lp_expr(a.value, m)
    match a.kind {
        parser::AssignKind::Field => TAssign { kind = a.kind; name = a.name; op = a.op; bound = a.bound; value = value; deref = a.deref; target = lp_expr(a.target, m) }
        _ => TAssign { kind = a.kind; name = a.name; op = a.op; bound = a.bound; value = value; deref = a.deref; target = a.target }
    }
}

/**
 * lp_function — local-propagate a top-level function's body in a FRESH scope (its parameters are
 * runtime values, never recorded); signature and metadata are preserved.
 *
 * @param f  the typed function
 * @return   the function with local-const references substituted in its body
 * @since #comptime-fold
 */
fn lp_function(f: TFunction) -> TItem {
    let body = lp_block(f.body, lp_empty()).stmts
    TFunction { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = f.params; return_type = f.return_type; body = body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; namespace = f.namespace; file = f.file; line = f.line; col = f.col; is_test = f.is_test; is_extern = f.is_extern; c_symbol = f.c_symbol; from_lib = f.from_lib }
}

/**
 * lp_top_item — local-propagate one top-level item: a function body in a fresh scope; a loose top-level
 * statement (the implicit `main`'s body) threaded through the top-level map so a top-level `let a = 0xFF`
 * folds a following `exit(a >> 4)`; every declaration passes through unchanged.
 *
 * @param it   the program item
 * @param top  the top-level local-const map (threaded across loose statements)
 * @return     the item with local-const references substituted, plus the top-level map it leaves
 * @since #comptime-fold
 */
fn lp_top_item(it: TItem, top: LocalConstMap) -> LpItem {
    match it {
        TFunction as f => LpItem { item = lp_function(f); map = top }
        TStatement as s => {
            let r = lp_stmt(s, top)
            LpItem { item = r.stmt; map = r.map }
        }
        _ => LpItem { item = it; map = top }
    }
}

/**
 * propagate_locals — the CF3 (Layer 1b) per-function local-binding const-propagation pass: seed each
 * function's fold scope (and the loose top-level statement stream) with its provably-const LOCAL
 * `let`/`const` bindings, and substitute every use of such a binding with a clone of its initializer, so
 * the composed `fold_program` pass collapses it to a literal on BOTH engines (the canonical
 * `let a: u64 = 0xFF; let hi = a >> 4` folds `hi` to `0x0F`). STRICTLY GUARDED: a binding whose
 * initializer carries ANY runtime leaf — a `mut`, a call, an IO result, a param — is left UNTOUCHED, so
 * a use of a runtime-valued binding is never folded (DECISION_LOG:391 preserved). Composed BETWEEN the
 * module-const substitution and `fold_program` in `inline_consts`; a pure structural rewrite (no
 * evaluation, no error) — the fold and its M.1 value errors are `fold_program`'s job.
 *
 * @param prog  the module-const-substituted typed program
 * @return      the program with provably-const local-binding references substituted by their initializers
 * @since #comptime-fold
 */
pub fn propagate_locals(prog: TProgram) -> TProgram {
    mut top = lp_empty()
    mut out: []TItem = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= prog.items.len { break }
        let r = lp_top_item(prog.items[i], top)
        out = teko::list::push(out, r.item)
        top = r.map
        i++
    }
    TProgram { items = out }
}

/**
 * cf_single_byte — a one-element `[]byte` holding `b`, the base case the digit/character builders start
 * from (the `"0"` of a zero-valued decimal/hex/binary render).
 *
 * @param b  the single byte
 * @return   a `[]byte` of length one holding `b`
 * @since #comptime-fold
 */
fn cf_single_byte(b: byte) -> []byte { teko::list::push(teko::list::empty(), b) }

/**
 * cf_append_bytes — the concatenation `a ++ b`, appending every byte of `b` onto `a` in order (the
 * comptime formatter's piece/hole joiner and sign/pad prefixer).
 *
 * @param a  the prefix bytes
 * @param b  the suffix bytes
 * @return   the bytes of `a` followed by the bytes of `b`
 * @since #comptime-fold
 */
fn cf_append_bytes(a: []byte, b: []byte) -> []byte {
    mut out = a
    mut i: u64 = 0
    loop {
        if i >= b.len { break }
        out = teko::list::push(out, b[i])
        i++
    }
    out
}

/**
 * cf_reverse_bytes — the reverse of `a`, the last step of every digit builder (digits are produced
 * least-significant first and emitted most-significant first).
 *
 * @param a  the bytes to reverse
 * @return   the bytes of `a` in reverse order
 * @since #comptime-fold
 */
fn cf_reverse_bytes(a: []byte) -> []byte {
    mut out: []byte = teko::list::empty()
    mut i: u64 = a.len
    loop {
        if i == (0 to u64) { break }
        i--
        out = teko::list::push(out, a[i])
    }
    out
}

/**
 * cf_project_u64 — the low 64 bits of `bits` after the width/signedness `info` projection the C backend
 * performs when it casts an interpolation hole to `uint64_t` (the argument every `tk_fmt_x_*`/`tk_fmt_b`
 * / `tk_u64_to_str` receives). A signed value narrower than 64 bits is SIGN-EXTENDED to 64 (so `-1 to
 * i8` renders as `FFFFFFFFFFFFFFFF` under `:X`, exactly as `(uint64_t)((int8_t)-1)` does); every other
 * value is its low 64 bits (an unsigned value zero-extends, a 64-bit-or-wider value truncates — the
 * SAME truncation `(uint64_t)` applies to an i128/u128 hole).
 *
 * @param bits  the value's two's-complement bits
 * @param info  the value's width/signedness
 * @return      the 64-bit pattern the runtime formatter receives, as a u128 in `[0, 2^64)`
 * @since #comptime-fold
 */
fn cf_project_u64(bits: u128, info: IntInfo) -> u128 {
    let masked = mask_to_width(bits, info.width)
    if info.width >= 64 { return mask_to_width(masked, 64) }
    if info.is_signed && bit_set(masked, info.width - 1) { return masked | (width_mask(64) ^ width_mask(info.width)) }
    masked
}

/**
 * cf_as_u64 — the 64-bit pattern a `CVInt` presents to the runtime formatters (the `(uint64_t)`/
 * `(int64_t)` cast argument): its width/signedness drives `cf_project_u64`. A non-integer type never
 * reaches here (the fold gates every static/numeric spec on an integer hole), so the error arm returns
 * zero defensively and is unreachable.
 *
 * @param ci  the integer comptime value
 * @return    the 64-bit pattern as a u128 in `[0, 2^64)`
 * @since #comptime-fold
 */
fn cf_as_u64(ci: CVInt) -> u128 {
    match int_info(ci.ty) {
        error => 0 to u128
        IntInfo as info => cf_project_u64(ci.bits, info)
    }
}

/**
 * cf_u64_decimal — the unsigned decimal render of `v` (a value in `[0, 2^64)`): the digits with no
 * leading zeros, `"0"` for zero — byte-identical to `tk_u64_to_str`.
 *
 * @param v  the value to render (must be `< 2^64`)
 * @return   the decimal digit bytes
 * @since #comptime-fold
 */
fn cf_u64_decimal(v: u128) -> []byte {
    if v == (0 to u128) { return cf_single_byte(48 to byte) }
    mut rev: []byte = teko::list::empty()
    mut x = v
    loop {
        if x == (0 to u128) { break }
        let d = (x % (10 to u128)) to u64
        rev = teko::list::push(rev, (48 + d) to byte)
        x = x / (10 to u128)
    }
    cf_reverse_bytes(rev)
}

/**
 * cf_i64_decimal — the signed decimal render of the 64-bit pattern `u` (interpreted as int64): a `'-'`
 * prefix then the magnitude digits for a negative value, the plain digits otherwise — byte-identical to
 * `tk_i64_to_str` (which forms the magnitude as `-(v + 1) + 1`, matched here by the two's-complement
 * negation at width 64).
 *
 * @param u  the 64-bit pattern (a u128 in `[0, 2^64)`) interpreted as a signed int64
 * @return   the signed decimal bytes
 * @since #comptime-fold
 */
fn cf_i64_decimal(u: u128) -> []byte {
    if bit_set(u, 63) { return cf_append_bytes(cf_single_byte(45 to byte), cf_u64_decimal(twos_neg(u, 64))) }
    cf_u64_decimal(u)
}

/**
 * cf_hex_digit — the ASCII byte of hex nibble `d` (`0`..`15`): a decimal digit for `0`..`9`, else an
 * upper- or lower-case letter per `upper`.
 *
 * @param d      the nibble value (`0`..`15`)
 * @param upper  true for `A`..`F`, false for `a`..`f`
 * @return       the hex digit's ASCII byte
 * @since #comptime-fold
 */
fn cf_hex_digit(d: u64, upper: bool) -> byte {
    if d < (10 to u64) { return (48 + d) to byte }
    if upper { return (65 + (d - (10 to u64))) to byte }
    (97 + (d - (10 to u64))) to byte
}

/**
 * cf_hex — the hex render of `v`: no leading zeros, `"0"` for zero, letters cased by `upper` —
 * byte-identical to `tk_fmt_x_upper` (`%PRIX64`) / `tk_fmt_x_lower` (`%PRIx64`).
 *
 * @param v      the value to render (the projected 64-bit pattern)
 * @param upper  true for upper-case hex (`:X`), false for lower-case (`:x`)
 * @return       the hex digit bytes
 * @since #comptime-fold
 */
fn cf_hex(v: u128, upper: bool) -> []byte {
    if v == (0 to u128) { return cf_single_byte(48 to byte) }
    mut rev: []byte = teko::list::empty()
    mut x = v
    loop {
        if x == (0 to u128) { break }
        let nib = (x & (15 to u128)) to u64
        rev = teko::list::push(rev, cf_hex_digit(nib, upper))
        x = x >> (4 to u32)
    }
    cf_reverse_bytes(rev)
}

/**
 * cf_binary — the binary render of `v`: no leading zeros, `"0"` for zero — byte-identical to `tk_fmt_b`
 * (which emits from the highest set bit down).
 *
 * @param v  the value to render (the projected 64-bit pattern)
 * @return   the binary digit bytes
 * @since #comptime-fold
 */
fn cf_binary(v: u128) -> []byte {
    if v == (0 to u128) { return cf_single_byte(48 to byte) }
    mut rev: []byte = teko::list::empty()
    mut x = v
    loop {
        if x == (0 to u128) { break }
        rev = teko::list::push(rev, (48 + ((x & (1 to u128)) to u64)) to byte)
        x = x >> (1 to u32)
    }
    cf_reverse_bytes(rev)
}

/**
 * cf_fmt_d — the `:d` render of the 64-bit pattern `u` (interpreted as int64) zero-padded to `width` —
 * byte-identical to `tk_fmt_d` (`%0*PRId64`): a leading `'-'` for a negative value, then enough `'0'`
 * fill to reach `width` (the field width COUNTS the sign), then the magnitude digits. A width no larger
 * than the rendered body adds no padding.
 *
 * @param u      the 64-bit pattern (a u128 in `[0, 2^64)`) interpreted as a signed int64
 * @param width  the minimum field width (the parsed spec digits, default 1)
 * @return       the zero-padded signed decimal bytes
 * @since #comptime-fold
 */
fn cf_fmt_d(u: u128, width: u64) -> []byte {
    let neg = bit_set(u, 63)
    let mag = if neg { twos_neg(u, 64) } else { u }
    let digits = cf_u64_decimal(mag)
    let sign_len = if neg { 1 to u64 } else { 0 to u64 }
    let body = sign_len + digits.len
    let pad = if width > body { width - body } else { 0 to u64 }
    mut out: []byte = teko::list::empty()
    if neg { out = teko::list::push(out, 45 to byte) }
    mut i: u64 = 0
    loop {
        if i >= pad { break }
        out = teko::list::push(out, 48 to byte)
        i++
    }
    cf_append_bytes(out, digits)
}

/**
 * cf_fmt_n — the `:n` render of the 64-bit pattern `u` (interpreted as int64): the signed decimal digits
 * with a `','` thousands separator inserted every three digits from the right of the integer part —
 * byte-identical to `tk_fmt_n_i`.
 *
 * @param u  the 64-bit pattern (a u128 in `[0, 2^64)`) interpreted as a signed int64
 * @return   the comma-grouped signed decimal bytes
 * @since #comptime-fold
 */
fn cf_fmt_n(u: u128) -> []byte {
    let neg = bit_set(u, 63)
    let mag = if neg { twos_neg(u, 64) } else { u }
    let digits = cf_u64_decimal(mag)
    let ndigits = digits.len
    mut out: []byte = teko::list::empty()
    if neg { out = teko::list::push(out, 45 to byte) }
    mut k: u64 = 0
    loop {
        if k >= ndigits { break }
        out = teko::list::push(out, digits[k])
        let pos = ndigits - k - (1 to u64)
        if pos > (0 to u64) && (pos % (3 to u64)) == (0 to u64) { out = teko::list::push(out, 44 to byte) }
        k++
    }
    out
}

/**
 * cf_spec_lead_low — the spec's leading format character, lowercased (an upper-case leading letter is
 * folded to lower-case exactly as `emit_interp` does). An empty spec yields `'f'` (`102`), the same
 * default `emit_interp` uses so an empty static spec routes to the float family (which the fold then
 * declines).
 *
 * @param spec  the static format spec string
 * @return      the normalized leading format character
 * @since #comptime-fold
 */
fn cf_spec_lead_low(spec: str) -> byte {
    let fc0 = if spec.len > (0 to u64) { spec[0] } else { 102 to byte }
    if fc0 >= (65 to byte) && fc0 <= (90 to byte) { return (fc0 to u64 + 32) to byte }
    fc0
}

/**
 * cf_spec_width — the `:d` field width parsed from `spec`: the accumulated decimal digits anywhere after
 * the leading character, or `1` when the spec carries no digits — mirroring `emit_interp`'s `prec`
 * accumulation and its `'d'` default of `1`.
 *
 * @param spec  the static format spec string
 * @return      the field width for `tk_fmt_d`
 * @since #comptime-fold
 */
fn cf_spec_width(spec: str) -> u64 {
    mut prec: u64 = 0
    mut has: bool = false
    mut si: u64 = 1
    loop {
        if si >= spec.len { break }
        let ch = spec[si]
        if ch >= (48 to byte) && ch <= (57 to byte) {
            prec = prec * (10 to u64) + ((ch to u64) - (48 to u64))
            has = true
        }
        si++
    }
    if !has { return 1 to u64 }
    prec
}

/**
 * cf_format_static_int — render integer value `ci` under the static spec `spec`, dispatching on its
 * normalized leading character to the culture-invariant integer families the fold reproduces
 * byte-for-byte: `x`/`X` hex, `b` binary, `d` zero-padded decimal, `n` comma-grouped decimal. Every
 * other family (the float `f`/`e`/`g`/`p` and any unrecognized character) is an error the caller treats
 * as "leave runtime" — the fold never emits bytes it cannot prove match `teko_rt.c`.
 *
 * @param ci    the integer comptime value
 * @param spec  the static format spec string
 * @return      the rendered bytes, or an error for a non-folded spec family
 * @throws      an error when the spec's family is float or unrecognized (leave the hole runtime)
 * @since #comptime-fold
 */
fn cf_format_static_int(ci: CVInt, spec: str) -> []byte | error {
    let fc_low = cf_spec_lead_low(spec)
    let u = cf_as_u64(ci)
    if fc_low == (120 to byte) { return cf_hex(u, spec.len > (0 to u64) && spec[0] == (88 to byte)) }
    if fc_low == (98 to byte) { return cf_binary(u) }
    if fc_low == (100 to byte) { return cf_fmt_d(u, cf_spec_width(spec)) }
    if fc_low == (110 to byte) { return cf_fmt_n(u) }
    error { message = "comptime fold: this static format spec is not folded (#comptime-fold)" }
}

/**
 * cf_format_static — render `v` under a static spec: only an integer value has a folded static family
 * (hex/binary/decimal/thousands); a non-integer static hole (which cannot arise from a type-checked
 * program) is an error the caller treats as "leave runtime".
 *
 * @param v     the hole's comptime value
 * @param spec  the static format spec string
 * @return      the rendered bytes, or an error to leave the hole runtime
 * @since #comptime-fold
 */
fn cf_format_static(v: ConstValue, spec: str) -> []byte | error {
    match v.kind {
        CVInt as ci => cf_format_static_int(ci, spec)
        _ => error { message = "comptime fold: a static format spec on a non-integer constant is not folded (#comptime-fold)" }
    }
}

/**
 * cf_bytes_value — the raw bytes of a folded string/char value, the natural (`TFSpecNone`) render of a
 * `str`/`char` hole — the same bytes the runtime emits by passing the value straight through.
 *
 * @param v  the hole's comptime value
 * @return   the raw bytes, or an error when the value is not a bytes value
 * @since #comptime-fold
 */
fn cf_bytes_value(v: ConstValue) -> []byte | error {
    match v.kind {
        CVBytes as cb => cb.data
        _ => error { message = "comptime fold: expected a string/char constant here (#comptime-fold)" }
    }
}

/**
 * cf_bool_value — the natural render of a folded boolean: `"true"` or `"false"`, byte-identical to the
 * ternary `emit_interp` emits for a bool hole.
 *
 * @param v  the hole's comptime value
 * @return   the boolean's text bytes, or an error when the value is not a boolean
 * @since #comptime-fold
 */
fn cf_bool_value(v: ConstValue) -> []byte | error {
    match v.kind {
        CVBool as cb => if cb.v { bytes_of_str("true") } else { bytes_of_str("false") }
        _ => error { message = "comptime fold: expected a boolean constant here (#comptime-fold)" }
    }
}

/**
 * cf_int_none_value — the natural (`TFSpecNone`) decimal render of an integer hole of prim kind `pk`: the
 * signed decimal (`tk_i64_to_str`) for a signed integer, the unsigned decimal (`tk_u64_to_str`)
 * otherwise.
 *
 * @param ci  the integer comptime value
 * @param pk  the hole's prim kind (drives signed vs unsigned)
 * @return    the decimal bytes
 * @since #comptime-fold
 */
fn cf_int_none_value(ci: CVInt, pk: PrimKind) -> []byte {
    if prim_is_signed(pk) { return cf_i64_decimal(cf_as_u64(ci)) }
    cf_u64_decimal(cf_as_u64(ci))
}

/**
 * cf_format_none_prim — the natural render of a `Prim` hole: `"true"`/`"false"` for a bool, the signed or
 * unsigned decimal for an integer; a float (or any other prim) is an error the caller treats as "leave
 * runtime" (the fold never touches float formatting).
 *
 * @param v  the hole's comptime value
 * @param p  the hole's `Prim` type
 * @return   the rendered bytes, or an error to leave the hole runtime
 * @since #comptime-fold
 */
fn cf_format_none_prim(v: ConstValue, p: Prim) -> []byte | error {
    if p.kind == PrimKind::Bool { return cf_bool_value(v) }
    if prim_is_int(p.kind) {
        match v.kind {
            CVInt as ci => cf_int_none_value(ci, p.kind)
            _ => error { message = "comptime fold: expected an integer constant here (#comptime-fold)" }
        }
    } else {
        error { message = "comptime fold: this prim hole type is not folded (#comptime-fold)" }
    }
}

/**
 * cf_format_none — the natural render of a hole with no format spec, dispatching on its resolved type:
 * `str`/`char` pass their bytes through, `byte` renders as unsigned decimal, a `Prim` routes to
 * `cf_format_none_prim`; every other type (error message, aggregate, float) is an error the caller
 * treats as "leave runtime".
 *
 * @param v        the hole's comptime value
 * @param hole_ty  the hole's resolved type
 * @return         the rendered bytes, or an error to leave the hole runtime
 * @since #comptime-fold
 */
fn cf_format_none(v: ConstValue, hole_ty: Type) -> []byte | error {
    match hole_ty {
        Str => cf_bytes_value(v)
        Char => cf_bytes_value(v)
        Byte => match v.kind { CVInt as ci => cf_u64_decimal(cf_as_u64(ci)); _ => error { message = "comptime fold: expected a byte constant here (#comptime-fold)" } }
        Prim as p => cf_format_none_prim(v, p)
        _ => error { message = "comptime fold: this interpolation hole type is not folded (#comptime-fold)" }
    }
}

/**
 * comptime_format — the Layer-2 comptime formatter: render `v` under `sp` exactly as the runtime
 * formatter in `teko_rt.c` would, producing the SAME bytes. Mirrors the spec-family dispatch of
 * `codegen.tks:emit_interp` and `fmt_family_takes_prec`, but DELIBERATELY only for the culture-invariant
 * integer/bool families the fold can prove byte-exact: `x`/`X` hex (`tk_fmt_x_lower/_upper`), `b` binary
 * (`tk_fmt_b`), `d` zero-padded decimal (`tk_fmt_d`), `n` comma-grouped decimal (`tk_fmt_n_i`), and the
 * `TFSpecNone` natural forms of int/uint (`tk_i64_to_str`/`tk_u64_to_str`), byte, bool and str/char. A
 * FLOAT family (`f`/`e`/`g`/`p`, and `n` on a float), a `TFSpecDynamic` spec, and any unrecognized spec
 * are NOT folded — an error is returned and the caller leaves the hole runtime, because a byte-divergent
 * fold is worse than no fold (M.3 honesty). This function is the DUPLICATION risk (§10): its output MUST
 * be byte-identical to `teko_rt.c` for every (value, spec) pair it folds, PINNED by the format-oracle
 * differential fixture.
 *
 * @param v        the const hole value (from `eval_const`)
 * @param sp       the hole's format spec (`TFSpecNone` or `TFSpecStatic`)
 * @param hole_ty  the hole's resolved type (selects signed/unsigned/bool/str family)
 * @return         the formatted bytes (byte-identical to the runtime), or an error for a spec the fold
 *                 declines (the caller then leaves the hole runtime)
 * @throws         an error for a float / dynamic / unrecognized spec, or a value/type kind mismatch
 * @since #comptime-fold
 */
pub fn comptime_format(v: ConstValue, sp: TFSpec, hole_ty: Type) -> []byte | error {
    match sp.kind {
        TFSpecStatic as fs => cf_format_static(v, fs.s)
        TFSpecDynamic => error { message = "comptime fold: a dynamic format spec is not folded (#comptime-fold)" }
        _ => cf_format_none(v, hole_ty)
    }
}

/**
 * cf_is_const_literal — true iff `e` is a bare const literal a folded interpolation hole may render: an
 * INTEGER number (a float literal is excluded — the fold never formats floats), a bool, a str, a char or
 * a byte literal. After Layer-1, a provably-const hole IS such a literal; a runtime hole (a param, a
 * call, an IO result) is not, so the interpolation stays runtime.
 *
 * @param e  the (already Layer-1 folded) hole expression
 * @return   whether the hole is a bare const literal the fold can render
 * @since #comptime-fold
 */
fn cf_is_const_literal(e: TExpr) -> bool {
    match e.kind {
        TNumber as n => !n.is_float
        TBoolLit => true
        TStrLit => true
        TCharLit => true
        TByteLit => true
        _ => false
    }
}

/**
 * cf_none_spec_ok — true iff a hole of type `t` with NO format spec has a folded natural form:
 * `str`/`char`/`byte`, a bool, or an integer prim. A float (or any other type) is left runtime.
 *
 * @param t  the hole's resolved type
 * @return   whether the natural-form fold applies
 * @since #comptime-fold
 */
fn cf_none_spec_ok(t: Type) -> bool {
    match t {
        Str => true
        Char => true
        Byte => true
        Prim as p => p.kind == PrimKind::Bool || prim_is_int(p.kind)
        _ => false
    }
}

/**
 * cf_static_spec_ok — true iff a hole of type `t` with static spec `spec` has a folded render: `t` must
 * be an integer/byte type and the spec's leading family one of the culture-invariant integer families
 * the fold reproduces (`x`/`X` hex, `b` binary, `d` decimal, `n` thousands). A float family and any
 * unrecognized character are declined (left runtime).
 *
 * @param spec  the static format spec string
 * @param t     the hole's resolved type
 * @return      whether the static-spec fold applies
 * @since #comptime-fold
 */
fn cf_static_spec_ok(spec: str, t: Type) -> bool {
    if !cf_is_int_type(t) { return false }
    if spec.len == (0 to u64) { return false }
    let fc_low = cf_spec_lead_low(spec)
    fc_low == (120 to byte) || fc_low == (98 to byte) || fc_low == (100 to byte) || fc_low == (110 to byte)
}

/**
 * cf_hole_foldable — true iff hole `hole` under spec `sp` can be folded byte-exactly: the hole is a bare
 * const literal AND the (spec, hole-type) pair names a folded family. A `TFSpecDynamic` spec is never
 * folded (its arg selects the family at runtime).
 *
 * @param hole  the (already Layer-1 folded) hole expression
 * @param sp    the hole's format spec
 * @return      whether the hole is foldable to bytes
 * @since #comptime-fold
 */
fn cf_hole_foldable(hole: TExpr, sp: TFSpec) -> bool {
    if !cf_is_const_literal(hole) { return false }
    match sp.kind {
        TFSpecDynamic => false
        TFSpecStatic as fs => cf_static_spec_ok(fs.s, hole.type)
        _ => cf_none_spec_ok(hole.type)
    }
}

/**
 * cf_spec_at — the format spec for hole index `i`: `in.specs[i]` when present, else a `TFSpecNone` (an
 * interpolation may carry fewer specs than holes for the trailing no-spec holes).
 *
 * @param in  the interpolation
 * @param i   the hole index
 * @return    the hole's format spec, or `TFSpecNone`
 * @since #comptime-fold
 */
fn cf_spec_at(in: TInterp, i: u64) -> TFSpec {
    if i < in.specs.len { return in.specs[i] }
    TFSpec { kind = TFSpecNone { } }
}

/**
 * cf_interp_foldable — true iff EVERY hole of `in` is foldable under its spec (`cf_hole_foldable`), the
 * precondition for collapsing the whole interpolation to a single `TStrLit`. A single runtime hole or
 * dynamic/float spec makes the whole interpolation stay its runtime concat shape.
 *
 * @param in  the interpolation (holes already Layer-1 folded)
 * @return    whether the entire interpolation folds to a literal
 * @since #comptime-fold
 */
fn cf_interp_foldable(in: TInterp) -> bool {
    mut i: u64 = 0
    loop {
        if i >= in.holes.len { break }
        if !cf_hole_foldable(in.holes[i], cf_spec_at(in, i)) { return false }
        i++
    }
    true
}

/**
 * cf_hole_bytes — evaluate hole `hole` to its comptime value and render it under `sp` via
 * `comptime_format`. The caller has proven `cf_hole_foldable`, so both steps succeed for a well-typed
 * program; an unexpected error propagates and makes the caller leave the interpolation runtime.
 *
 * @param hole   the (already Layer-1 folded) hole expression
 * @param sp     the hole's format spec
 * @param table  the type table (forwarded to `eval_const`)
 * @param env    the environment (forwarded to `eval_const`)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the rendered bytes, or an error to leave the interpolation runtime
 * @since #comptime-fold
 */
fn cf_hole_bytes(hole: TExpr, sp: TFSpec, table: TypeTable, env: Env, agg: AggConstMap) -> []byte | error {
    match eval_const(hole, table, env, agg) {
        error as x => return x
        ConstValue as v => comptime_format(v, sp, hole.type)
    }
}

/**
 * cf_interp_bytes — the byte-exact render of a fully-const interpolation: the literal pieces interleaved
 * with each hole's `cf_hole_bytes` render (`pieces[0] ++ hole0 ++ pieces[1] ++ … ++ pieces[last]`,
 * `pieces.len == holes.len + 1`). Any per-hole error propagates so the caller leaves the interpolation
 * runtime.
 *
 * @param in     the fully-const interpolation
 * @param table  the type table (forwarded to each hole render)
 * @param env    the environment (forwarded to each hole render)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       the concatenated bytes, or an error to leave the interpolation runtime
 * @since #comptime-fold
 */
fn cf_interp_bytes(in: TInterp, table: TypeTable, env: Env, agg: AggConstMap) -> []byte | error {
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= in.pieces.len { break }
        out = cf_append_bytes(out, bytes_of_str(in.pieces[i]))
        if i < in.holes.len {
            let hb = match cf_hole_bytes(in.holes[i], cf_spec_at(in, i), table, env, agg) { error as x => return x; []byte as b => b }
            out = cf_append_bytes(out, hb)
        }
        i++
    }
    out
}

/**
 * cf_interp_expr — rewrap an interpolation as its runtime `TExpr` (the non-folded outcome), preserving
 * the enclosing expression's type/position.
 *
 * @param in  the interpolation (holes already Layer-1 folded)
 * @param e   the enclosing expression (its type/position)
 * @return    the interpolation `TExpr` unchanged in shape
 * @since #comptime-fold
 */
fn cf_interp_expr(in: TInterp, e: TExpr) -> TExpr {
    TExpr { kind = TInterp { pieces = in.pieces; holes = in.holes; specs = in.specs }; type = e.type; line = e.line; col = e.col }
}

/**
 * fold_interp — the Layer-2 interpolation fold: when EVERY hole of `in` is a const literal (post
 * Layer-1) and EVERY spec is a folded `TFSpecNone`/`TFSpecStatic` family, format each hole via
 * `comptime_format`, concatenate with the piece literals, and return a single `TStrLit` (interned to
 * rodata by lowering, like any string literal) — zero runtime concat/format. If ANY hole is runtime, ANY
 * spec is `TFSpecDynamic`, or any hole/spec is a family the fold declines (float in particular), `in` is
 * returned UNCHANGED (still a runtime `tk_str_concat` shape), preserving today's behavior. A rendering
 * that unexpectedly errors also leaves the interpolation runtime — the fold never emits bytes it cannot
 * prove match `teko_rt.c`.
 *
 * @param in     the typed interpolation (holes already Layer-1 folded)
 * @param e      the enclosing expression (its type/position for the produced `TStrLit`)
 * @param table  the type table (forwarded to the per-hole evaluator)
 * @param env    the environment (module consts + provably-const locals)
 * @param agg    the module-aggregate resolution table (forwarded through the fold spine to the index fold)
 * @return       a single folded `TStrLit` when fully const, else `in` unchanged
 * @since #comptime-fold
 */
pub fn fold_interp(in: TInterp, e: TExpr, table: TypeTable, env: Env, agg: AggConstMap) -> TExpr | error {
    if !cf_interp_foldable(in) { return cf_interp_expr(in, e) }
    match cf_interp_bytes(in, table, env, agg) {
        error => cf_interp_expr(in, e)
        []byte as bs => TExpr { kind = TStrLit { text = str_of_bytes(bs) }; type = e.type; line = e.line; col = e.col }
    }
}
