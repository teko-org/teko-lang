// src/checker/resolve.tks  (namespace 'teko::checker')

use teko::parser

// a registered user type: name + the NAMESPACE it was declared in (A3 provenance) + its
// VISIBILITY (private/pub/exp) + its parsed declaration. namespace/vis drive W-vis-enforce.
type TypeReg = struct { name: str; namespace: str; vis: parser::Visibility; decl: parser::TypeDecl }
pub type TypeTable = []TypeReg

// (#109 W3) the CANONICAL name of a type: "ns::Name" (bare "Name" at the root ns). The semantic
// `Named.name` carries THIS — so two same-bare-name public types in different namespaces (teko::io::
// Reader vs teko::emit::Reader) are DISTINCT identities (type_eq) and DISTINCT C mangles. Builtins,
// type-params, and generic `__g__` instances stay bare (ns == "" → returns the name unchanged).
pub fn qualify(ns: str, name: str) -> str {
    if ns == "" { name } else { ns ~ "::" ~ name }
}
// (#148) qualify_eq — does `name` equal qualify(ns, bare) WITHOUT building the string? The hot
// table scans compared a freshly-CONCATENATED "ns::Name" per candidate per lookup (measured 63M
// concats / ~1 GB+overhead on a self-build); this byte-wise test allocates nothing.
pub fn qualify_eq(ns: str, bare: str, name: str) -> bool {
    if ns.len == 0 { return bare == name }
    if name.len != ns.len + 2 + bare.len { return false }
    mut i: u64 = 0
    loop { if i >= ns.len { break }; if name[i] != ns[i] { return false }; i++ }
    if name[ns.len] != b':' { return false }
    if name[ns.len + 1] != b':' { return false }
    mut j: u64 = 0
    loop { if j >= bare.len { break }; if name[ns.len + 2 + j] != bare[j] { return false }; j++ }
    true
}
// (#109 W3) the bare last "::"-segment of a (possibly canonical) name: "teko::emit::Reader" → "Reader",
// "Reader" → "Reader". Manual byte-loop (mirrors class_name_from_method_ns), since last_index_of is a
// host-only FFI edge unavailable to the VM-interpreted checker.
pub fn name_last_segment(name: str) -> str {
    mut last_sep: i64 = -1
    mut i: u64 = 0
    loop {
        if i + 1 >= name.len { break }
        if name[i] == b':' && name[i + 1] == b':' { last_sep = i to i64 }
        i++
    }
    if last_sep < 0 { return name }
    // (#148) the BUILTIN slice (→ tk_str_slice_from, one memcpy) — the materialized
    // teko::runtime::str_slice_from builds byte-by-byte (a push loop + a final copy), and this
    // helper runs per type-name comparison (measured ~144M tiny allocs on a self-build).
    teko::str::slice_from(name, (last_sep to u64) + 2)
}
// (#109 W3) the namespace qualifier of a canonical name (everything before the final "::"):
// "teko::emit::Reader" → "teko::emit"; "Reader" → "".
pub fn name_qualifier(name: str) -> str {
    mut last_sep: i64 = -1
    mut i: u64 = 0
    loop {
        if i + 1 >= name.len { break }
        if name[i] == b':' && name[i + 1] == b':' { last_sep = i to i64 }
        i++
    }
    if last_sep < 0 { return "" }
    teko::str::slice_to(name, last_sep to u64)   // (#148) builtin slice — see name_last_segment
}

// find a user type by name; error if not registered.
// (#109 W3) `name` may be a CANONICAL "ns::Name" (a resolved Named.name) OR a bare source name. The
// table entry may carry (bare name + real ns) [the typing collect table] OR (canonical name + "")
// [the codegen/vm type_table_of re-collection]. Match when the entry's name equals `name` directly
// OR when its qualified form qualify(ns, name) equals `name` — covering every combination. ref_ns is
// unused (a resolved-name probe is namespace-blind; the SOURCE-reference sites use resolve_type_ref).
fn type_table_find(table: TypeTable, name: str, ref_ns: str) -> parser::TypeDecl | error {
    // (#152) TWO PASSES: pass 1 = exact name OR the entry's qualified form (both UNIQUE post-W0's
    // per-namespace dup ban) — so a canonical query can never be stolen by a same-bare cousin that
    // merely appears earlier in the table (discovery order differs per platform). Pass 2 = the
    // legacy bare last-segment fallback (bare probes of a CANONICAL-keyed type_table_of table).
    mut i = 0
    loop {
        if i >= table.len { break }
        if table[i].name == name || qualify_eq(table[i].namespace, table[i].name, name) { return table[i].decl }   // (#148) allocation-free qualified compare
        i++
    }
    mut j = 0
    loop {
        if j >= table.len { break }
        if name_last_segment(table[j].name) == name { return table[j].decl }
        j++
    }
    error { message = "not a user type" }
}

// (#109 W2) does the qualifier `qual` (a path's segments BEFORE the last, joined with "::") select
// namespace `ns`? A qualifier matches when `ns` equals it OR ends with `"::" ~ qual` — so the single
// segment `emit` matches the canonical `teko::emit`, and the absolute `teko::emit` matches exactly
// (R0, a special case of R4). An empty qualifier (a bare 1-segment path) never reaches here.
fn qualifier_selects_ns(ns: str, qual: str) -> bool {
    if ns == qual { return true }
    teko::runtime::str_ends_with(ns, "::" ~ qual)
}

// (#109 W2) join a path's FIRST `count` segments with "::" — the qualifier of a qualified reference
// (`teko::emit::Reader` with count=2 → "teko::emit"; `lexer::Token` with count=1 → "lexer").
fn path_qualifier(path: parser::Path, count: u64) -> str {
    mut out = ""
    mut i: u64 = 0
    loop {
        if i >= count { break }
        if i == 0 { out = path.segments[i].name } else { out = out ~ "::" ~ path.segments[i].name }
        i++
    }
    out
}

// (#109 W2) list the namespaces a bare name IS declared in (for the R3 fail-loud diagnostic), joined
// with ", "; "" is rendered "<top-level>". O(n) scan — used only when a bare reference misses.
fn namespaces_declaring(table: TypeTable, name: str) -> str {
    mut out = ""
    mut i: u64 = 0
    loop {
        if i >= table.len { break }
        if table[i].name == name {
            let label = if table[i].namespace == "" { "<top-level>" } else { table[i].namespace }
            if out == "" { out = label } else { out = out ~ ", " ~ label }
        }
        i++
    }
    out
}

// (#109 W2) the DECLARING namespace of a type by its (resolved) name — first match, "" if unknown.
// A struct/class field's, or a method signature's, source type annotation is written in the type's
// OWN namespace, so resolving those annotations must reference that namespace, not the code site's.
// Shared across the checker (collect conformance, typer field/struct-init resolution). Under W0 no
// two types share a bare name, so the first match is unambiguous (W3 canonical names make it exact).
fn type_ns_of(table: TypeTable, name: str) -> str {
    mut i: u64 = 0
    loop {
        if i >= table.len { break }
        // (#109 W3) `name` may be a CANONICAL "ns::Name" (a resolved Named.name) or a bare stamped
        // `__g__` instance — match exact OR by the entry's qualified form (like type_table_find).
        if table[i].name == name || qualify_eq(table[i].namespace, table[i].name, name) { return table[i].namespace }   // (#148) allocation-free qualified compare
        i++
    }
    ""
}

// (#109 W2) the namespace-aware SOURCE-reference resolver — R0-R5. `path` is the WRITTEN reference,
// `ref_ns` the namespace of the code that wrote it. Resolves to the ONE declaration the reference
// names, or a fail-loud error. R1 (type-params) and R2 (builtins) are handled by the callers BEFORE
// this point (type_param_table registers params in ref_ns; builtin_type runs first). Here:
//   R3 — BARE (a 1-segment path): resolve STRICTLY within ref_ns. A same-ns entry wins; a name that
//        exists ONLY in other namespace(s) is REJECTED (the cross-namespace collision fix) with a
//        diagnostic naming those namespaces. An unknown name → "not a user type" (the caller renders
//        the final "unknown type" message, unchanged).
//   R4/R0 — QUALIFIED (a >1-segment path): match the LAST segment AND the qualifier (segments minus
//        the last). An entry matches when name == last AND its namespace is SELECTED by the qualifier
//        (equals, or ends-with `::qualifier`) — so `emit::Reader` binds ns `teko::emit`, and a fully
//        canonical `teko::emit::Reader` binds it exactly (R0). Exactly one match wins; zero → unknown;
//        two or more → an ambiguity error listing the namespaces.
//   Privates: found-then-rejected is left to the module-visibility pass (check_modules) — a private
//        type in another namespace is MENTIONABLE here (so error wording is precise), the existing
//        visibility check keeps rejecting it.
/**
 * Resolve a BARE stamped generic-instance name (`Box__g__i64`) to its TypeDecl from ANY namespace, or
 * null when `last` is not a stamped instance name (#254 L4/L5). A stamped instance name is
 * collision-proof — no user symbol may carry the `__g__` infix — so it is bare-visible everywhere,
 * exactly like a root-level or type-param name. A stamped instance's own methods carry the instance
 * name in their (normalized) signatures, and `register_instance_methods` resolves those signatures with
 * no referencing namespace, so a bare `Box__g__i64` in a `-> Box<T>` return / `Box<T>` param must
 * resolve regardless of the instance's declaring namespace. Consulted BEFORE the cross-namespace
 * collision error, which would otherwise reject the bare stamped name from "".
 *
 * @param last  the path's last segment (the referenced type name)
 * @param table the folded type table
 * @return      the stamped instance's decl, or null when `last` is not a stamped instance name
 * @since onda-3 (#254 L4/L5)
 */
fn resolve_bare_g_instance(last: str, table: TypeTable) -> parser::TypeDecl? {
    if !name_is_g_instance(last) { return null }
    mut g: u64 = 0
    loop {
        if g >= table.len { break }
        if table[g].name == last { return table[g].decl }
        g++
    }
    null
}

fn resolve_type_ref(path: parser::Path, table: TypeTable, ref_ns: str) -> parser::TypeDecl | error {
    if path.segments.len == 0 { return error { message = "not a user type" } }
    let last = path.segments[path.segments.len - 1].name
    if path.segments.len == 1 {
        // R3 — BARE: strict own-namespace resolution.
        mut i: u64 = 0
        loop {
            if i >= table.len { break }
            if table[i].name == last && table[i].namespace == ref_ns { return table[i].decl }
            i++
        }
        // (R1/root) a generic type-PARAM (type_param_table registers it at "") and a root-level ("")
        // type are bare-visible from ANY namespace — "" is the global root scope. Resolve it before
        // the cross-namespace collision error, so a bare `T` inside a namespaced fn still resolves.
        if ref_ns != "" {
            mut k: u64 = 0
            loop {
                if k >= table.len { break }
                if table[k].name == last && table[k].namespace == "" { return table[k].decl }
                k++
            }
        }
        match resolve_bare_g_instance(last, table) { parser::TypeDecl as td => return td; null => { } }
        // No same-ns entry. If the name lives elsewhere, that is the cross-namespace collision — the
        // reference is not visible bare and MUST be qualified (fail-loud). Otherwise it is simply
        // unknown (the caller's "unknown type" message stands).
        mut j: u64 = 0
        loop {
            if j >= table.len { break }
            if table[j].name == last {
                let nss = namespaces_declaring(table, last)
                let here = if ref_ns == "" { "<top-level>" } else { ref_ns }
                return error { message = $"type '{last}' is not visible bare from namespace '{here}' — it is declared in: {nss}. Qualify it (`ns::{last}`) or reference it from its own namespace." }
            }
            j++
        }
        return error { message = "not a user type" }
    }
    // R4 / R0 — QUALIFIED: match last segment + qualifier; unique winner, else ambiguity/unknown.
    let qual = path_qualifier(path, path.segments.len - 1)
    mut winner_idx: i64 = -1
    mut matched_ns = ""
    mut ambiguous = false
    mut i2: u64 = 0
    loop {
        if i2 >= table.len { break }
        if table[i2].name == last && qualifier_selects_ns(table[i2].namespace, qual) {
            if winner_idx >= 0 && table[i2].namespace != matched_ns {
                ambiguous = true
            } else {
                winner_idx = i2 to i64
                matched_ns = table[i2].namespace
            }
        }
        i2++
    }
    if ambiguous {
        let nss = namespaces_declaring(table, last)
        return error { message = $"ambiguous type reference '{qual}::{last}' — the qualifier matches more than one namespace ({nss}). Use the absolute path (`teko::…::{last}`)." }
    }
    if winner_idx >= 0 { return table[winner_idx to u64].decl }
    error { message = "not a user type" }
}

// (#109 order fix) split a SOURCE-WRITTEN type name string on "::" into a Path — so an
// `implements`/`extends` entry or a trait-derive probe (bare "Reader" or qualified "io::Reader")
// can ride the R0-R5 resolver like any other source reference. (Mirror resolve.c::name_to_path.)
fn name_to_path(name: str) -> parser::Path {
    mut segs: []parser::Segment = teko::list::empty()
    mut rest = name
    loop {
        mut sep: i64 = -1
        mut i: u64 = 0
        loop {
            if i + 1 >= rest.len { break }
            if rest[i] == b':' && rest[i + 1] == b':' { sep = i to i64; break }
            i++
        }
        if sep < 0 { break }
        segs = teko::list::push(segs, parser::Segment { name = teko::str::slice_to(rest, sep to u64) })
        rest = teko::str::slice_from(rest, (sep to u64) + 2)
    }
    segs = teko::list::push(segs, parser::Segment { name = rest })
    parser::Path { segments = segs }
}

// (#109 order fix) resolve a SOURCE-WRITTEN type name string by the R0-R5 rules from `ref_ns` —
// the string-shaped twin of resolve_type_ref. `resolved_name_ns` mirrors the WINNING namespace
// (companion, like type_ref_ns). Used by collect's `implements`/`extends`/trait-derive walks, so
// a bare name never resolves by table-scan order. (Mirrors resolve.c.)
pub fn resolve_name_ref(name: str, table: TypeTable, ref_ns: str) -> parser::TypeDecl | error {
    resolve_type_ref(name_to_path(name), table, ref_ns)
}
pub fn resolved_name_ns(name: str, table: TypeTable, ref_ns: str) -> str {
    type_ref_ns(name_to_path(name), table, ref_ns)
}

// (#109 W2) the DECLARING namespace of the type `path` resolves to (mirrors resolve_type_ref's winning
// match) — the namespace a TRANSPARENT alias's body must resolve in. `TypeTable = []TypeReg` in
// teko::checker, referenced qualified from teko::emit, expands `[]TypeReg` in teko::checker (its own
// ns), NOT the referencing emit ns. Returns "" for a root/builtin/unknown path (its body, if any,
// resolves at root). Companion to resolve_type_ref; W4 folds the two into one ns-carrying resolver.
fn type_ref_ns(path: parser::Path, table: TypeTable, ref_ns: str) -> str {
    if path.segments.len == 0 { return "" }
    let last = path.segments[path.segments.len - 1].name
    if path.segments.len == 1 {
        mut i: u64 = 0
        loop {
            if i >= table.len { break }
            if table[i].name == last && table[i].namespace == ref_ns { return ref_ns }   // R3 own-ns match → its own ns
            i++
        }
        return ""   // R1/root ("") match, or unknown → root scope
    }
    let qual = path_qualifier(path, path.segments.len - 1)
    mut j: u64 = 0
    loop {
        if j >= table.len { break }
        if table[j].name == last && qualifier_selects_ns(table[j].namespace, qual) { return table[j].namespace }
        j++
    }
    ""
}

/**
 * (S6, issue #162 / TR1 #176) A contract-atom's own EFFECTIVE methods — the leaf case of a
 * constraint's method surface. An INTERFACE contributes its extends-transitive methods; a TRAIT
 * contributes its own method list (no `extends` to walk). Every other KNOWN atom kind
 * (struct/enum/flags/variant/alias/extern/class — no shared nominal method contract to expose)
 * contributes an EMPTY surface: it may still satisfy the constraint nominally, but authorizes no
 * operation on T through it. (TR3) A compiler-known STRUCTURAL trait atom is likewise opaque on T —
 * its methods are synthesized per concrete deriver, not dispatched through T in v1. An atom naming
 * NO TypeDecl at all is a named error (M.1 fail-loud — never silently opaque).
 *
 * @param name  the constraint atom's name
 * @param table the folded type table
 * @return the atom's authorized method surface (possibly empty)
 * @throws when `name` names no declared type
 */
fn atom_surface(name: str, table: TypeTable) -> []parser::Function | error {
    if is_trait_name(name, table) { return trait_methods_by_name(name, table) }
    if is_interface_name(name, table) { return iface_methods_by_name(name, table) }
    if is_structural_trait(name) { let empty_surface: []parser::Function = teko::list::empty(); return empty_surface }
    match type_table_find(table, name, "") {
        parser::TypeDecl => { let empty_surface: []parser::Function = teko::list::empty(); empty_surface }
        error => error { message = $"unknown constraint atom '{name}' — names no declared type" }
    }
}

/** (S6) does `m` already appear (by name) in `methods`? */
fn surface_has(methods: []parser::Function, m: parser::Function) -> bool {
    mut i = 0
    loop { if i >= methods.len { return false }; if methods[i].name == m.name { return true }; i++ }
    false
}

/** (S6) the UNION of two method surfaces (an `A & B` constraint — T satisfies BOTH contracts, so
    every method of both is authorized). A name shared by both sides is kept once. */
fn surface_union(a: []parser::Function, b: []parser::Function) -> []parser::Function {
    mut out = a
    mut i = 0
    loop {
        if i >= b.len { break }
        if !surface_has(out, b[i]) { out = teko::list::push(out, b[i]) }
        i++
    }
    out
}

/** (S6) the signature-matched INTERSECTION of two method surfaces (an `A | B` constraint — T is
    one OR the other at runtime, so only what BOTH universally guarantee — same name, same
    non-receiver param types, same return type, via method_sig_matches — is safe to authorize). */
fn surface_intersect(a: []parser::Function, b: []parser::Function, table: TypeTable) -> []parser::Function {
    mut out: []parser::Function = teko::list::empty()
    mut i = 0
    loop {
        if i >= a.len { break }
        mut j = 0
        loop {
            if j >= b.len { break }
            if a[i].name == b[j].name && method_sig_matches(a[i], b[j], table, "") { out = teko::list::push(out, a[i]) }
            j++
        }
        i++
    }
    out
}

/** The effective method surface a ConstraintExpr authorizes on a type-param T: an interface atom
    contributes its own effective methods; `And` UNIONS the two sides' surfaces (both contracts
    hold, so both surfaces' methods are safe); `Or` signature-matches INTERSECTS them (only what
    every reachable branch guarantees is universally safe); a struct/variant atom or NoConstraint
    contributes an empty (opaque-only) surface; a trait atom is atom_surface's named TR1 stop.
    Recursive over the ConstraintExpr tree, mirroring constraint_satisfied's shape. */
pub fn constraint_surface(c: parser::ConstraintExpr, table: TypeTable) -> []parser::Function | error {
    match c {
        parser::ConstraintAnd as a => {
            let l = match constraint_surface(a.left, table) { []parser::Function as f => f; error as e => return e }
            let r = match constraint_surface(a.right, table) { []parser::Function as f => f; error as e => return e }
            surface_union(l, r)
        }
        parser::ConstraintOr as o => {
            let l = match constraint_surface(o.left, table) { []parser::Function as f => f; error as e => return e }
            let r = match constraint_surface(o.right, table) { []parser::Function as f => f; error as e => return e }
            surface_intersect(l, r, table)
        }
        parser::ConstraintAtom as a => atom_surface(a.name, table)
        parser::NoConstraint => { let empty_surface: []parser::Function = teko::list::empty(); empty_surface }
    }
}

/** (S6, Risco 3) does `iface` already have a method (by NAME) present among `names`'s OWN methods
    with a DIFFERENT signature — an ambiguous `A & B` where both declare e.g. `area` incompatibly?
    Same name + SAME signature is fine (equivalent, kept once); same name + different signature is
    rejected at the DEFINITION with a named error (never a silent pick). */
fn interface_conflicts_with(iface: str, names: []str, table: TypeTable) -> str | error {
    let ims = match iface_methods_by_name(iface, table) { []parser::Function as f => f; error as e => return e }
    mut i = 0
    loop {
        if i >= names.len { break }
        let others = match iface_methods_by_name(names[i], table) { []parser::Function as f => f; error as e => return e }
        mut mi = 0
        loop {
            if mi >= ims.len { break }
            mut oi = 0
            loop {
                if oi >= others.len { break }
                if ims[mi].name == others[oi].name && !method_sig_matches(ims[mi], others[oi], table, "") {
                    return $"method '{ims[mi].name}' is ambiguous — declared by both '{names[i]}' and '{iface}' with different signatures"
                }
                oi++
            }
            mi++
        }
        i++
    }
    ""
}

/** (S6) append `iface` to `names`, rejecting an ambiguous same-name-different-signature clash
    against any interface already in the list (Risco 3) — the AND-union of a constraint's
    interfaces. Duplicates (the exact same interface reachable via two branches) are kept once. */
fn interfaces_and_union(names: []str, iface: str, table: TypeTable) -> []str | error {
    mut i = 0
    loop { if i >= names.len { break }; if names[i] == iface { return names }; i++ }
    let conflict = match interface_conflicts_with(iface, names, table) { str as s => s; error as e => return e }
    if conflict != "" { return error { message = conflict } }
    teko::list::push(names, iface)
}

/** (S6) the interface names an `And` constraint contributes, merged with Risco-3 ambiguity
    checking — every interface of `l` folded into `r`'s list (or vice versa; either order is
    equivalent since the check is symmetric). */
fn merge_interfaces_and(l: []str, r: []str, table: TypeTable) -> []str | error {
    mut out = r
    mut i = 0
    loop {
        if i >= l.len { break }
        out = match interfaces_and_union(out, l[i], table) { []str as s => s; error as e => return e }
        i++
    }
    out
}

/** (S6) keep only the interfaces of `names` that still own at least one method in `surface` (an
    `Or`'s intersected surface) — an interface contributing nothing to the surviving surface would
    add an unreachable `extends` to the synthetic InterfaceBody. */
fn interfaces_surviving(names: []str, surface: []parser::Function, table: TypeTable) -> []str | error {
    mut out: []str = teko::list::empty()
    mut i = 0
    loop {
        if i >= names.len { break }
        let ms = match iface_methods_by_name(names[i], table) { []parser::Function as f => f; error as e => return e }
        mut keep = false
        mut mi = 0
        loop { if mi >= ms.len { break }; if surface_has(surface, ms[mi]) { keep = true; break }; mi++ }
        if keep { out = teko::list::push(out, names[i]) }
        i++
    }
    out
}

/** The contract names a ConstraintExpr contributes to a type-param's synthetic InterfaceBody
    `extends` list — the And-UNION of contract atoms (Risco-3 ambiguity-checked); an `Or`
    contributes only the contracts whose methods SURVIVE the intersected surface. Empty for a
    struct/variant atom or NoConstraint. (TR1) A trait atom contributes its OWN name exactly like an
    interface — the synthetic type-param's `extends` names it, and `method_owner_interface` keys the
    vtable slot off it via the now-trait-aware `iface_methods_by_name`. Recursive, mirroring
    constraint_surface's shape — the two stay in lockstep by construction. */
fn constraint_interfaces(c: parser::ConstraintExpr, table: TypeTable) -> []str | error {
    match c {
        parser::ConstraintAnd as a => {
            let l = match constraint_interfaces(a.left, table) { []str as s => s; error as e => return e }
            let r = match constraint_interfaces(a.right, table) { []str as s => s; error as e => return e }
            merge_interfaces_and(l, r, table)
        }
        parser::ConstraintOr as o => {
            let surface = match constraint_surface(c, table) { []parser::Function as f => f; error as e => return e }
            let l = match constraint_interfaces(o.left, table) { []str as s => s; error as e => return e }
            let r = match constraint_interfaces(o.right, table) { []str as s => s; error as e => return e }
            interfaces_surviving(surface_union_names(l, r), surface, table)
        }
        parser::ConstraintAtom as a => {
            if is_trait_name(a.name, table) { return teko::list::push(teko::list::empty(), a.name) }
            if is_interface_name(a.name, table) { return teko::list::push(teko::list::empty(), a.name) }
            let no_interfaces: []str = teko::list::empty()
            no_interfaces
        }
        parser::NoConstraint => { let no_interfaces: []str = teko::list::empty(); no_interfaces }
    }
}

/** (S6) the union of two interface-name lists with no ambiguity check (an Or's two branches are
    ALREADY narrowed by their own constraint_interfaces call; interfaces_surviving does the actual
    gating against the intersected surface right after) — no duplicates. */
fn surface_union_names(a: []str, b: []str) -> []str {
    mut out = a
    mut i = 0
    loop {
        if i >= b.len { break }
        mut already = false
        mut j = 0
        loop { if j >= out.len { break }; if out[j] == b[i] { already = true; break }; j++ }
        if !already { out = teko::list::push(out, b[i]) }
        i++
    }
    out
}

/** (S6) which interface in `ifaces` (a type-param's synthetic InterfaceBody `extends` list) OWNS
    `method` — the first (in `extends` order) whose OWN effective methods declare it — or null. This
    keys the D3 vtable slot: an N-extends surface's method dispatches through whichever interface
    actually declares it, exactly generalizing the single-interface `<T: I>` redirect. */
pub fn method_owner_interface(ifaces: []str, method: str, table: TypeTable) -> str? {
    mut i = 0
    loop {
        if i >= ifaces.len { break }
        let no_methods: []parser::Function = teko::list::empty()
        let ms = match iface_methods_by_name(ifaces[i], table) { []parser::Function as f => f; error => no_methods }
        mut j = 0
        loop { if j >= ms.len { break }; if ms[j].name == method { return ifaces[i] }; j++ }
        i++
    }
    null
}

/** (S6) the type-param's synthetic InterfaceBody `extends` list for constraint `c` — the empty list
    (opaque ExternBody, honest stop) for NoConstraint/a struct-or-variant atom, the constraint's
    interfaces (constraint_interfaces) otherwise. A TR1/ambiguity error here is swallowed to the
    opaque fallback: type_param_table has no error channel (mirrors S4's total-function shape), so
    the SAME error re-surfaces, named, the moment the body actually operates on T (crumb 4/6) or a
    concrete instantiation is checked (check_constraints) — never silently ignored (M.1). */
fn type_param_extends(c: parser::ConstraintExpr, table: TypeTable) -> []str {
    let no_interfaces: []str = teko::list::empty()
    match constraint_interfaces(c, table) {
        []str as ifaces => ifaces
        error => no_interfaces
    }
}

/** (S6) the constraint at index `i`, or NoConstraint when the caller supplied fewer constraints
    than type-params (the parser's own invariant keeps them same-length, but callers that build
    `type_constraints` by hand — tests, synthetic tables — may not). */
fn constraint_at(type_constraints: []parser::ConstraintExpr, i: u64) -> parser::ConstraintExpr {
    if i < type_constraints.len { return type_constraints[i] }
    parser::NoConstraint { }
}

/** (S6) a type-param's synthetic TypeReg for `type_param_table`: namespace = the USING namespace
    (so the W-vis-enforce cross-namespace/visibility check treats the type-param as LOCAL, never a
    cross-namespace reference), and `body` mirrors the constraint's own contract surface (empty
    `extends` → opaque ExternBody, an honest stop; a non-empty `extends` → InterfaceBody, unlocking
    D3 dispatch — see type_param_extends). The synthetic TypeDecl carries the OWN constraint on its
    own `type_constraints` (a single-element list — `type_params` stays empty, so this can never
    collide with a genuine multi-param user decl's parallel arrays) so a later honest-stop site
    (type_method_call) can recompute the REAL reason a swallowed error occurred (a trait atom / an
    unknown atom / a Risco-3 ambiguity) instead of a generic "deferred" message (M.1 fail-loud even
    when type_param_extends itself has to swallow the error, S4's total-function shape). The two
    `body` arms are DIFFERENT members of the wider `TypeBody` variant; the arm-join infers the
    narrow `InterfaceBody | ExternBody` union while the binding is the wider `TypeBody` — native
    codegen widens each arm into `TypeBody` (fix/selfhost-arm-join-widen), so this natural form (was
    a per-arm whole-TypeReg workaround under #99) compiles on the self-host BUILD too. */
fn type_param_reg(name: str, own_constraint: parser::ConstraintExpr, ns: str, table: TypeTable) -> TypeReg {
    let ifaces: []str = type_param_extends(own_constraint, table)
    let body: parser::TypeBody = if ifaces.len > 0 { parser::InterfaceBody { extends = ifaces; methods = teko::list::empty() } } else { parser::ExternBody { } }
    let carried_constraints = teko::list::push(teko::list::empty(), own_constraint)
    let d = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = carried_constraints; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    TypeReg { name = name; namespace = ns; vis = parser::Visibility::Private; decl = d }
}

/** (S4) Extend the type table with generic type-params as OPAQUE nominal types, so a generic
    signature/body resolves with `T` abstract. An unconstrained `T` has no members/operators, so
    OPERATING on it (`x.foo`, `a > b`) fails at the definition (M.1 fail-loud, no reflection) — only
    opaque usage (store/pass/return/hold/match-bind) is allowed (constraints unlock ops at S6). The
    monomorph pass substitutes each `Named{T}` with the concrete arg before codegen. PREPENDED so a
    type-param SHADOWS a same-named user type within the generic. Empty type_params → table unchanged.
    Used by collect (func sigs), check_modules (vis check), and typer (bodies). (C: tk_type_param_table.)
    (W10b.D2, issue #99; generalized S6/issue #162) `type_constraints` runs PARALLEL to
    `type_params` (same length; NoConstraint where the caller has none) — see type_param_reg for how
    index i's constraint becomes its synthetic TypeReg (a single-interface atom `<T: I>` is the N=1
    degenerate case, unchanged since #99). */
pub fn type_param_table(type_params: []str, type_constraints: []parser::ConstraintExpr, ns: str, table: TypeTable) -> TypeTable {
    if type_params.len == 0 { return table }
    mut tbl: TypeTable = teko::list::empty()
    mut i = 0
    loop {
        if i >= type_params.len { break }
        let own_constraint = constraint_at(type_constraints, i to u64)
        tbl = teko::list::push(tbl, type_param_reg(type_params[i], own_constraint, ns, table))
        i++
    }
    mut j = 0
    loop {
        if j >= table.len { break }
        tbl = teko::list::push(tbl, table[j])
        j++
    }
    tbl
}

/**
 * Append two type-param name lists (`a ++ b`) — the enclosing type's params ahead of a method's own.
 * A trivial two-list concat, factored so the method-table builder reads declaratively.
 *
 * @param a  the leading names (the enclosing type's type-params)
 * @param b  the trailing names (the method's own type-params)
 * @return   a new list holding every name of `a` followed by every name of `b`
 * @since onda-3 (#254)
 */
fn concat_tps(a: []str, b: []str) -> []str {
    mut out: []str = teko::list::empty()
    mut i = 0
    loop { if i >= a.len { break }; out = teko::list::push(out, a[i]); i++ }
    mut j = 0
    loop { if j >= b.len { break }; out = teko::list::push(out, b[j]); j++ }
    out
}

/**
 * Append two constraint lists (`a ++ b`), parallel to concat_tps so the enclosing type's constraints
 * stay index-aligned with its params when both lists are prepended to a method's own.
 *
 * @param a  the leading constraints (the enclosing type's type-constraints)
 * @param b  the trailing constraints (the method's own type-constraints)
 * @return   a new list holding every constraint of `a` followed by every constraint of `b`
 * @since onda-3 (#254)
 */
fn concat_tcs(a: []parser::ConstraintExpr, b: []parser::ConstraintExpr) -> []parser::ConstraintExpr {
    mut out: []parser::ConstraintExpr = teko::list::empty()
    mut i = 0
    loop { if i >= a.len { break }; out = teko::list::push(out, a[i]); i++ }
    mut j = 0
    loop { if j >= b.len { break }; out = teko::list::push(out, b[j]); j++ }
    out
}

/**
 * Build a method's type-param table PREPENDED with the enclosing type's own type-params/constraints,
 * so a method of `Box<T>` that references `T` resolves against the OWNER's `T` instead of failing
 * with "unknown type: T" (#254 layer 1). `owner_name` is looked up by its CANONICAL name via the
 * two-pass exact/qualified match (never an order-dependent bare probe — #290/#109 family): a bare
 * name absent from the table (a plain non-generic owner, a free fn, or a receiver type-param)
 * contributes an empty prefix, keeping the result byte-identical to `type_param_table(mtps, …)` for
 * the existing corpus (which carries ZERO generic methods).
 *
 * @param owner_name  the enclosing type's canonical name (`ns::…::Type`, or bare at the root ns)
 * @param mtps        the method's own type-params
 * @param mtcs        the method's own type-constraints
 * @param ns          the using namespace for the synthesized type-param TypeRegs (per type_param_table)
 * @param table       the folded type table (source of the owner's params + the canonical lookup)
 * @return            a type-param table over `owner_tps ++ mtps` / `owner_tcs ++ mtcs`
 * @since onda-3 (#254)
 */
pub fn method_type_param_table(owner_name: str, mtps: []str, mtcs: []parser::ConstraintExpr, ns: str, table: TypeTable) -> TypeTable {
    match type_table_find(table, owner_name, "") {
        parser::TypeDecl as td => type_param_table(concat_tps(td.type_params, mtps), concat_tcs(td.type_constraints, mtcs), ns, table)
        error => type_param_table(mtps, mtcs, ns, table)
    }
}

// resolve a NAMED type (a path) to a semantic Type: built-in or user type.
// (#109 W2) `ref_ns` = the referencing namespace; drives the R0-R5 resolution rules (via
// resolve_type_ref). R2 builtins are matched FIRST (bare only — a builtin is never namespaced); the
// user-type lookup then applies R3 (bare = strict own-ns) / R4/R0 (qualified = last+qualifier).
fn resolve_named(path: parser::Path, table: TypeTable, ref_ns: str) -> Type | error {
    // M.1: an empty path is an internal invariant break — an honest error, never an out-of-bounds.
    if path.segments.len == 0 { return error { message = "internal: empty type path (a void/missing type used where a value type is required)" } }
    let name = path.segments[path.segments.len - 1].name   // seed: last segment
    // R2 — a BUILTIN resolves only for a BARE reference (`u8`…`u64`, `byte`, `str`, `error`, …). A
    // qualified path can never name a builtin, so a `ns::str` falls through to the user-type rules.
    if path.segments.len == 1 {
        match builtin_type(name) {
            Type as t => return t
            error => { }
        }
    }
    match resolve_type_ref(path, table, ref_ns) {   // R0/R3/R4 — a user struct/enum/variant/alias
        // A TRANSPARENT alias `type Name = <type-expr>` resolves THROUGH to the aliased type
        // (self-host parity): `TypeTable = []TypeReg` → a Slice, `Foo = Circle` → its Named
        // struct, etc. struct/enum/variant decls stay NOMINAL (a bare Named of `name`).
        parser::TypeDecl as td => {
            match td.body {
                parser::AliasBody as ab => return resolve_type(ab.alias, table, type_ref_ns(path, table, ref_ns))   // (#109 W2) alias body resolves in the alias's OWN ns, not the referencing ns
                _ => return if name_is_g_instance(name) { Named { name = name } } else { Named { name = qualify(type_ref_ns(path, table, ref_ns), name) } }
            }
        }
        // R3/R4 fail-loud diagnostics (cross-namespace collision, ambiguity) propagate verbatim;
        // the plain "not a user type" sentinel becomes the caller-facing "unknown type" message.
        error as e => { if e.message == "not a user type" { return error { message = $"unknown type: {name}" } }; return e }
    }
    error { message = $"unknown type: {name}" }
}

// A NAMED type referring to a `variant` decl → its expanded Variant. A variant decl's body IS
// a union type-expr (A | B | …), so resolve_type on it yields the Variant with its members; the
// members resolve to Named (resolve_named keeps user types nominal), so this terminates and does
// NOT recurse into nested named variants. Anything else returns unchanged.
fn expand_variant(t: Type, table: TypeTable) -> Type {
    let name = match t {
        Named as n => n.name
        _ => return t   // not a named type → unchanged
    }
    let decl = match type_table_find(table, name, "") {   // (#109 W1) resolved-name probe, no referencing ns
        parser::TypeDecl as td => td
        error => return t   // not a user type → unchanged
    }
    match decl.body {
        parser::VariantBody as vb => {
            match resolve_type(vb.type_expr, table, type_ns_of(table, name)) {   // (#109 W2) variant body resolves in the variant's OWN ns (its members are written there)
                Type as ex => ex   // the variant body's union → its Variant
                error => t   // unresolvable → unchanged (honest fallback, like the C `ex.ok ? … : t`)
            }
        }
        _ => t   // a struct/enum decl, not a variant → unchanged
    }
}

/**
 * ptr_widens_to_opaque — C7.19 OPAQUE-PTR DEGRADE: a typed `ptr<T>` (`from`) widens into the
 * untyped opaque `ptr` (`to = Ptr{inner = null}`) — the reverse of `type_eq`'s `ptr_inner_eq`,
 * which requires matching inners because it also backs strict overload/return checks. Transport-
 * only builtins (`bytes_from_ptr`, `str_from_cstr`) take the opaque `ptr` so ANY typed pointer
 * (e.g. `teko::mem::buf_ptr`'s `ptr<byte>`) may flow in without a cast; a typed pointer never
 * widens into a DIFFERENTLY typed one (no `ptr<byte>` -> `ptr<i32>`).
 */
fn ptr_widens_to_opaque(from: Type, to: Type) -> bool {
    match from {
        Ptr => match to {
            Ptr as tp => match tp.inner { null => true; Type => false }
            _ => false
        }
        _ => false
    }
}

// (#41-followon) Does a value of `from` WIDEN into `to`? The single source of truth for value-
// position widening, shared by the return/trailing-value/assign/binding check (assignable_to
// delegates here) and the match/`if` arm JOIN (type_join). Rules (B.14 + present-wrap §202):
//   • type equality,
//   • a VARIANT `from` iff EVERY member widens in (sub-variant → wider variant) — TRANSITIVE,
//   • `T` into `T?` (and `U?`/sentinel into `T?`),
//   • a variant MEMBER into the (named-expanded) variant — also transitive (a nested case).
// Depth-bounded so a pathological self-referential variant cannot loop. (Mirror of resolve.c.)
fn widens_into_at(from: Type, to: Type, table: TypeTable, depth: i64) -> bool {
    if type_eq(from, to) { return true }
    if depth <= 0 { return false }
    if from_is_bare_null(from) && null_widens_into(to, table) { return true }
    // PRESENT-WRAP first (before variant decomposition): a whole `T` (even a named variant like
    // `TypeExpr`) wraps into `T?`. Checking this before the variant-from split keeps `TypeExpr →
    // TypeExpr?` a single present-wrap, not a member-by-member (which would wrongly fail).
    match to {
        Optional as opt => {
            if widens_into_at(from, opt.inner, table, depth - 1) { return true }   // T (or a case of T) → T?
            match from { Optional => return true; _ => { } }   // U? / sentinel → T?
        }
        _ => { }
    }
    match expand_variant(from, table) {   // a VARIANT source decomposes into its members
        Variant as fv => {
            mut i = 0
            loop {
                if i >= fv.members.len { break }
                if !widens_into_at(fv.members[i], to, table, depth - 1) { return false }
                i++
            }
            return true
        }
        _ => { }
    }
    // COVARIANT value slices: `[]A` widens into `[]B` iff A widens into B (value/copy semantics —
    // sound; a sentinel `Void` element is already accepted by type_eq above). `[]Str` fits `[]Type`.
    match from {
        Slice as fs => match to {
            Slice as ts => return widens_into_at(fs.element, ts.element, table, depth - 1)
            _ => { }
        }
        _ => { }
    }
    if ptr_widens_to_opaque(from, to) { return true }
    // (W10b.D3) UPCAST — a CLASS instance widens into a contract (interface) it NOMINALLY
    // conforms to: `let s: Shape = circle`. Classes only (reference semantics ride the object
    // pointer into the fat-pointer `data` field); a STRUCT is pure value data — no stable
    // address to dispatch on — so it does NOT widen (its conformance still serves `<T: I>`).
    // (#98) A CLASS instance ALSO widens into an ANCESTOR class (`let a: Animal = dog`) — the
    // Sub→Base upcast, reusing the SAME fat pointer (data + the base's virtual vtable). Nominal:
    // `from` must be a (transitive) subclass of `to`, and `to` must be a polymorphic base
    // (`abstract`/`virtual`) — a `sealed` class can never be a base, so it never widens into.
    match from {
        Named as fname => match to {
            Named as tname => {
                if is_class_name(fname.name, table) && (is_interface_name(tname.name, table) || is_trait_name(tname.name, table)) && type_conforms_to(fname.name, tname.name, table) { return true }
                if fname.name != tname.name && is_class_name(fname.name, table) && is_polymorphic_base(tname.name, table) && subclass_reaches(fname.name, tname.name, table, 64) { return true }
            }
            _ => { }
        }
        _ => { }
    }
    match expand_variant(to, table) {   // a NAMED variant → its Variant (so cases widen in)
        Variant as tv => {
            mut j = 0
            loop {
                if j >= tv.members.len { break }
                if widens_into_at(from, tv.members[j], table, depth - 1) { return true }
                j++
            }
            false
        }
        _ => false
    }
}
fn widens_into(from: Type, to: Type, table: TypeTable) -> bool { widens_into_at(from, to, table, 16) }

/**
 * Is `from` a bare `null` value — either the concrete `Null` type (null-as-union), or the legacy
 * `Optional{Void}` bare-null sentinel that a `null` literal still carries in an optional context?
 * Both denote the value `null`, so both widen into a union listing `null`.
 *
 * @param from  the source value type
 * @return      true iff `from` is a bare `null` in either representation
 */
fn from_is_bare_null(from: Type) -> bool {
    match from {
        Null => true
        Optional as o => match o.inner { Void => true; _ => false }
        _ => false
    }
}

/**
 * null_widens_into — a bare `null` (type `Null`) is assignable into a target that is `Null` itself
 * or a union (inline or named) listing `null` among its members (set membership, order-independent).
 *
 * @param target  the resolved destination type
 * @param table   the type table (to expand a named-variant target)
 * @return        true iff a `Null` value is assignable into `target`
 */
fn null_widens_into(target: Type, table: TypeTable) -> bool {
    match target { Null => return true; _ => { } }
    match expand_variant(target, table) {
        Variant as v => {
            mut i = 0
            loop {
                if i >= v.members.len { break }
                match v.members[i] { Null => return true; _ => { } }
                i++
            }
            false
        }
        _ => false
    }
}

// ── (W10b.D3) nominal contract conformance — the interface-value upcast / constraint gates ──────
// These live HERE (not collect.tks) because widens_into needs them and resolve sits below collect
// in the module DAG. "Contract" wording: the mechanism is per-(type, contract) and agnostic to
// which decl kind the contract came from (today `interface`; traits reuse it later).

// is `name` declared as an interface? Mirror of resolve.c::tk_is_interface_name.
pub fn is_interface_name(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {   // (#109 W1) kind probe on a resolved name — no referencing ns
        parser::TypeDecl as td => match td.body { parser::InterfaceBody => true; _ => false }
        error => false
    }
}

// is `name` declared as a class? Mirror of resolve.c::tk_is_class_name.
pub fn is_class_name(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {   // (#109 W1) kind probe on a resolved name — no referencing ns
        parser::TypeDecl as td => match td.body { parser::ClassBody => true; _ => false }
        error => false
    }
}

/**
 * Is `name` a `#must_free` RELEVANT type (S2, the 0.1.0.0-beta memory+unsafe remodel #336) — a
 * type whose value must be consumed (freed or moved) on every non-diverging control-flow path?
 * Any TypeDecl kind may carry the flag (struct/class are the intended shape; the flag is purely
 * a `TypeDecl` field, not gated by body kind here — a non-heap `#must_free` type still requires
 * consumption, it just cannot reach `teko::mem::free`'s heap-shape check, so a stray one only
 * ever fails the dataflow check, never silently passes).
 *
 * @param str name  a resolved (canonical or bare) type name
 * @param TypeTable table  the program's type table
 * @return bool  true iff `name`'s TypeDecl carries `must_free = true`
 */
pub fn is_must_free_name(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {
        parser::TypeDecl as td => td.must_free
        error => false
    }
}

/**
 * Is `name` a MANUAL REGION-HANDLE type (S3, issue #358 — the `unsafe #must_free type Arena`
 * shape) — a `#must_free` struct declaring exactly one `uptr` field, which holds the raw
 * `tk_region *` this handle bulk-frees? This is the STRUCTURAL signal that routes
 * `teko::mem::free(handle)` to `tk_region_drop_subtree` (bulk-drop the whole child region),
 * rather than the slice free-list or the class arena-per-object drop. Keyed off shape + the
 * `#must_free` flag, never a hard-coded `Arena` name, so any project's region-handle type (the
 * stdlib `teko::mem::unsafe::Arena` OR a fixture's local copy) is recognized identically.
 *
 * A non-`#must_free` struct, or one whose single field is not `uptr`, or any multi-field /
 * non-struct type, is NOT a region handle — those keep their existing `teko::mem::free` routing
 * (or are rejected as non-heap). Fails CLOSED: an unresolvable field type is treated as non-`uptr`.
 *
 * @param str name  a resolved (canonical or bare) type name
 * @param TypeTable table  the program's type table
 * @return bool  true iff `name` is a `#must_free` struct with a single `uptr` field
 */
pub fn is_region_handle_name(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {
        parser::TypeDecl as td => is_region_handle_decl(td, table)
        error => false
    }
}

/**
 * The structural test behind `is_region_handle_name`: `td` is a `#must_free` struct whose sole
 * field resolves to the opaque word-size `uptr` (the raw `tk_region *` carrier). Split out so the
 * region-field NAME can be recovered separately (`region_handle_field_name`) without re-deciding.
 *
 * @param parser::TypeDecl td  a resolved type declaration
 * @param TypeTable table  the program's type table
 * @return bool  true iff `td` is a `#must_free` single-`uptr`-field struct
 */
fn is_region_handle_decl(td: parser::TypeDecl, table: TypeTable) -> bool {
    if !td.must_free { return false }
    match td.body {
        parser::StructBody as sb => {
            if sb.fields.len != 1 { return false }
            match resolve_type(sb.fields[0].type_ann, table, "") {
                Type as t => match t { Uptr => true; _ => false }
                error => false
            }
        }
        _ => false
    }
}

/**
 * The NAME of a region-handle type's single `uptr` field — the field `teko::mem::free` codegen
 * reads to reach the raw `tk_region *`. Only meaningful when `is_region_handle_name(name, …)` is
 * true; returns the empty string otherwise (the caller has already gated on the predicate).
 *
 * @param str name  a resolved region-handle type name
 * @param TypeTable table  the program's type table
 * @return str  the single `uptr` field's name, or "" if `name` is not a region handle
 */
pub fn region_handle_field_name(name: str, table: TypeTable) -> str {
    match type_table_find(table, name, "") {
        parser::TypeDecl as td => match td.body {
            parser::StructBody as sb => if sb.fields.len == 1 { sb.fields[0].name } else { "" }
            _ => ""
        }
        error => ""
    }
}

/**
 * Is `name` declared `unsafe` (U1/U2, the 0.1.0.0-beta memory+unsafe remodel #333) — a
 * `unsafe type M = struct|class { … }` whose values may only be named by another `unsafe`
 * type or an `unsafe fn` (contagion-by-composition, never a spine/flow analysis — a pure
 * nominal probe, mirroring `is_must_free_name`/`is_interface_name`). A bare builtin
 * (`str`, `u64`, `byte`, `error`, …) or a type-param (`T`) misses the table entirely (or
 * resolves to a synthetic opaque registration whose `is_unsafe` is false), so this
 * predicate returns false for them by construction — never a false positive on safe
 * scalars/generics.
 *
 * @param str name  a resolved (canonical or bare) type name
 * @param TypeTable table  the program's type table
 * @return bool  true iff `name`'s TypeDecl carries `is_unsafe = true`
 */
pub fn is_unsafe_type(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {
        parser::TypeDecl as td => td.is_unsafe
        error => false
    }
}

/**
 * Does the resolved `t` CARRY an unsafe-typed component — either `t` itself names an
 * `unsafe type` (the leaf case) or `t` is a compositional carrier (`[]M`, `M?`, `Ref<M>`,
 * `ptr<M>`, a variant with an unsafe member, or a `fn(…)->…` signature naming an unsafe
 * param/return) wrapping one? Mirrors the recursion shape of `widens_into_at`/
 * `carries_sentinel`: depth-bounded so a self-referential variant cannot loop. Fails
 * CLOSED at the depth bound (a containment gate exhausting its budget must REJECT, never
 * silently pass unsafe data through as "not carrying"). A `Func` is recursed into because
 * this walk is about DATA the value's TYPE names, not call sites — calls stay uncolored,
 * but a safe field/param typed `fn(Raw)->Raw` still stores/exposes `Raw` in its shape. This
 * is the sole engine behind the U2 containment gates (field composition, fn signatures,
 * locals, and generic-instance stamping) — every carrier the checker lets a value travel
 * through must be walked here, or unsafe data could leak through it unchecked.
 *
 * @param Type t  a resolved semantic Type (a field/param/return/local's annotation)
 * @param TypeTable table  the program's type table (for the leaf `is_unsafe_type` probe)
 * @param i64 depth  remaining recursion budget (seed 32 — deeper than `widens_into`'s 16, since
 *               generic composition (`Box<Box<Box<…>>>`) is a nesting source this walk
 *               traverses that `widens_into_at` never does)
 * @return bool  true iff `t` names, or transitively wraps, an unsafe type
 */
fn unsafe_carrying_at(t: Type, table: TypeTable, depth: i64) -> bool {
    if depth <= 0 { return true }
    match t {
        Named as n => is_unsafe_type(n.name, table)
        Slice as s => unsafe_carrying_at(s.element, table, depth - 1)
        Optional as o => unsafe_carrying_at(o.inner, table, depth - 1)
        Reference as r => unsafe_carrying_at(r.inner, table, depth - 1)
        Ptr as p => match p.inner { Type as inner => unsafe_carrying_at(inner, table, depth - 1); null => false }
        Func as f => func_type_unsafe_carrying(f, table, depth - 1)
        Variant as v => {
            mut i = 0
            loop {
                if i >= v.members.len { break }
                if unsafe_carrying_at(v.members[i], table, depth - 1) { return true }
                i++
            }
            false
        }
        _ => false
    }
}

/**
 * Does a `Func` type's signature — every param and the return — name or carry an unsafe
 * type? Split out of `unsafe_carrying_at`'s `Func` arm to keep that match flat (single
 * early-return loop over params, then the return type).
 *
 * @param Func f  the resolved function-type signature
 * @param TypeTable table  the program's type table
 * @param i64 depth  remaining recursion budget, already decremented by the caller
 * @return bool  true iff any param or the return type is unsafe-carrying
 */
fn func_type_unsafe_carrying(f: Func, table: TypeTable, depth: i64) -> bool {
    mut i = 0
    loop {
        if i >= f.params.len { break }
        if unsafe_carrying_at(f.params[i], table, depth) { return true }
        i++
    }
    unsafe_carrying_at(f.ret, table, depth)
}

/**
 * Does the resolved `t` carry an unsafe-typed component (§2 contagion-by-composition)?
 * The public, depth-seeded entry point over `unsafe_carrying_at` — seeded at 32 (deeper than
 * `widens_into`'s 16 seed; see `unsafe_carrying_at`'s doc for why).
 *
 * @param Type t  a resolved semantic Type (a field/param/return/local's annotation)
 * @param TypeTable table  the program's type table
 * @return bool { unsafe_carrying_at(t, table, 32) }  true iff `t` names, or transitively wraps, an unsafe type
 */
pub fn unsafe_carrying(t: Type, table: TypeTable) -> bool { unsafe_carrying_at(t, table, 32) }

/**
 * Does ANY of a generic instantiation's resolved type-ARGUMENTS carry an unsafe type
 * (`Box<Raw>`, `List<Raw>`, `Map<str, Raw>`, …)? Used at STAMP time (`instantiate_types`)
 * so a generic instance whose substituted body embeds unsafe data becomes `is_unsafe = true`
 * itself — otherwise a safe fn/field/local naming `Box<Raw>` would resolve to a stamped
 * `Named{"Box__g__Raw"}` decl whose OWN `is_unsafe` is false (inherited only from the
 * generic base template, which never mentions `Raw`), silently defeating every downstream
 * containment gate (field/signature/local) that trusts a `Named`'s resolved decl. Marking
 * the STAMP itself unsafe means the existing gates fire automatically, uniformly, with no
 * separate `__g__`-name special-casing at each call site.
 *
 * @param []Type argtypes  the instantiation's resolved type-arguments, in declaration order
 * @param TypeTable table  the program's type table
 * @return bool  true iff any argument names, or transitively wraps, an unsafe type
 */
fn generic_args_unsafe_carrying(argtypes: []Type, table: TypeTable) -> bool {
    mut i = 0
    loop {
        if i >= argtypes.len { break }
        if unsafe_carrying(argtypes[i], table) { return true }
        i++
    }
    false
}

// (#98) is `name` a POLYMORPHIC BASE — a class that MAY be inherited (`abstract`/`virtual`, never
// `sealed`)? A Sub→Base upcast (and the base-typed dispatch/fat-pointer it enables) is only sound
// against such a class: a `sealed` class can never be anyone's base, so a base-typed value of it
// can only ever BE it — no polymorphism to model. Mirror of resolve.c::tk_is_polymorphic_base.
pub fn is_polymorphic_base(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {   // (#109 W1) kind probe on a resolved name — no referencing ns
        parser::TypeDecl as td => match td.body {
            parser::ClassBody as cb => match cb.kind { parser::ClassKind::Sealed => false; _ => true }
            _ => false
        }
        error => false
    }
}

// (#98) does class `sub` reach ANCESTOR class `want` through the `base_name` chain, transitively?
// Hop-bounded (cyclic inheritance is decl-rejected; the bound keeps this total regardless). Used
// by the Sub→Base widen. Mirror of resolve.c::tk_subclass_reaches.
pub fn subclass_reaches(sub: str, want: str, table: TypeTable, depth: i64) -> bool {
    if depth <= 0 { return false }
    let cb = match type_table_find(table, sub, "") {   // (#109 W1) ancestor walk on resolved names — no referencing ns
        parser::TypeDecl as td => match td.body { parser::ClassBody as b => b; _ => return false }
        error => return false
    }
    if !cb.has_base { return false }
    if name_last_segment(cb.base_name) == name_last_segment(want) { return true }   // (#109 W3) base_name is a bare source name; `want` may be canonical — compare bare
    subclass_reaches(cb.base_name, want, table, depth - 1)
}

// (TR0) is `name` declared as a trait? Mirror of resolve.c::tk_is_trait_name. Used by the
// honest stops (a trait as a constraint atom / instantiation target) — the FOLD itself splits
// the `&`-list with its own table-scan (collect.tks::split_trait_derives).
pub fn is_trait_name(name: str, table: TypeTable) -> bool {
    match type_table_find(table, name, "") {   // (#109 W1) kind probe on a resolved name — no referencing ns
        parser::TypeDecl as td => match td.body { parser::TraitBody => true; _ => false }
        error => false
    }
}

/**
 * (TR3) The closed set of compiler-known STRUCTURAL trait names — `Eq`, `Ord`, `Hash`, `Clone`,
 * `Default` — whose provided method bodies the compiler SYNTHESIZES from the deriver's field view
 * (TR2), with no surface declaration and no runtime metadata (Law M.0). Matched on the bare last
 * segment: these are reserved trait names, unqualified. A user type of the same name is not
 * intended (the set is closed per the trait design §5 open 4). `Hashable` is accepted as a SYNONYM
 * of `Hash` and `Comparable` of `Ord` (the collections Map-key capability names, R1) — the
 * structural trait IS the capability, so no parallel interface is introduced.
 *
 * @param name a name from a deriver's `&`-list or a constraint atom (a source or resolved name)
 * @return true iff `name`'s last segment is one of the structural trait names (or a synonym)
 */
pub fn is_structural_trait(name: str) -> bool {
    let last = name_last_segment(name)
    last == "Eq" || last == "Ord" || last == "Hash" || last == "Clone" || last == "Default" || last == "Hashable" || last == "Comparable"
}

/**
 * (TR3) The canonical structural-trait name of `name` — collapsing the R1 synonyms so a deriver
 * lists ONE name per capability: `Hashable` → `Hash`, `Comparable` → `Ord`; every other structural
 * name maps to itself. Callers pass a name already known to `is_structural_trait`; a non-structural
 * name is returned unchanged (the caller never reaches this with one).
 *
 * @param name a structural-trait name (possibly a synonym), bare or qualified
 * @return the canonical bare structural-trait name
 */
pub fn structural_trait_canonical(name: str) -> str {
    let last = name_last_segment(name)
    if last == "Hashable" { return "Hash" }
    if last == "Comparable" { return "Ord" }
    last
}

// does contract `sub` reach contract `want` through `extends`, transitively? Depth-bounded so a
// (decl-rejected) cyclic `extends` can never loop here. Mirror of resolve.c::iface_extends_reaches.
fn iface_extends_reaches(sub: str, want: str, table: TypeTable, depth: i64) -> bool {
    if depth <= 0 { return false }
    let ib = match type_table_find(table, sub, "") {   // (#109 W1) extends walk on resolved names — no referencing ns
        parser::TypeDecl as td => match td.body { parser::InterfaceBody as b => b; _ => return false }
        error => return false
    }
    mut i: u64 = 0
    loop {
        if i >= ib.extends.len { break }
        // (#152) EXACT compare when BOTH sides are qualified (post canon_class_bases the entries
        // are canonical whenever they resolve — a cross-ns same-bare cousin no longer conforms);
        // a bare side (root canonical, or a synthetic type-param extends) keeps the bare compare.
        if name_qualifier(ib.extends[i]) != "" && name_qualifier(want) != "" {
            if ib.extends[i] == want { return true }
        } else {
            if name_last_segment(ib.extends[i]) == name_last_segment(want) { return true }
        }
        if iface_extends_reaches(ib.extends[i], want, table, depth - 1) { return true }
        i++
    }
    false
}

// NOMINAL conformance: does class/struct `name` implement contract `iface` — via its OWN
// `implements` list, an ANCESTOR class's (the class-inheritance chain), or a listed contract
// that `extends` `iface` transitively? DECLARED conformance only (nominal, closed-world) — a
// type that merely HAPPENS to have the methods does not conform. Hop-bounded like the extends
// walk (cyclic inheritance is decl-rejected; the bound keeps this total regardless). Mirror of
// resolve.c::tk_type_conforms_to.
pub fn type_conforms_to(name: str, iface: str, table: TypeTable) -> bool {
    mut cur = name
    mut hops = 0
    loop {
        if hops >= 64 { break }
        let td = match type_table_find(table, cur, "") { parser::TypeDecl as d => d; error => return false }   // (#109 W1) conformance walk on resolved names — no referencing ns
        mut impls: []str = teko::list::empty()
        mut has_base = false
        mut base = ""
        match td.body {
            parser::ClassBody as cb => {
                impls = cb.implements
                has_base = cb.has_base
                base = cb.base_name
            }
            parser::StructBody as sb => { impls = sb.implements }
            _ => return false
        }
        mut i: u64 = 0
        loop {
            if i >= impls.len { break }
            // (#152) EXACT when BOTH qualified (see iface_extends_reaches); bare-compat otherwise.
            if name_qualifier(impls[i]) != "" && name_qualifier(iface) != "" {
                if impls[i] == iface { return true }
            } else {
                if name_last_segment(impls[i]) == name_last_segment(iface) { return true }
            }
            if iface_extends_reaches(impls[i], iface, table, 64) { return true }
            i++
        }
        if !has_base { return false }
        cur = base
        hops++
    }
    false
}

// (#83) Does `t` carry a SENTINEL anywhere (a Slice whose element is `Void`, or an Optional whose
// inner is `Void`)? `type_eq` treats a sentinel as equal to ANY concrete peer (see type.tks), which
// is right for ASSIGNABILITY but wrong for JOIN's "equal → return `a`" shortcut: if `a` is the
// (less informative) sentinel side and `b` is concrete, blindly returning `a` silently discards
// the concrete element type a sibling array-literal entry established (`[[], [1]]`'s inner `[]`
// joined against `[1]`'s `[]i64` — see type_join). Recurses through Slice/Optional so a nested
// sentinel (`[][]Void`) is still detected. Mirror: resolve.c::tk_type_has_sentinel.
fn type_has_sentinel(t: Type) -> bool {
    match t {
        Slice as s => match s.element { Void => true; _ => type_has_sentinel(s.element) }
        Optional as o => match o.inner { Void => true; _ => type_has_sentinel(o.inner) }
        _ => false
    }
}

// (#41-followon) Collect `t`'s members into `acc` for a union JOIN: an INLINE variant contributes
// its members (flattened); anything else contributes itself. Deduped by type_eq. Named variants
// stay NOMINAL (consistent with how `Type | error` keeps `Type` named). (Mirror of resolve.c.)
fn union_collect(acc: []Type, t: Type, table: TypeTable) -> []Type {
    match t {
        Variant as v => {
            mut out = acc
            mut i = 0
            loop {
                if i >= v.members.len { break }
                out = union_collect(out, v.members[i], table)
                i++
            }
            out
        }
        _ => {
            mut i = 0
            loop {
                if i >= acc.len { break }
                if type_eq(acc[i], t) { return acc }   // dedup
                i++
            }
            teko::list::push(acc, t)
        }
    }
}

// (#41-followon) The JOIN (least-upper-bound) of two arm/branch types for match/`if` value
// unification (B.20). If either widens into the other, the WIDER one; otherwise the UNION variant
// `a | b` (members flattened + deduped) — the branch values are bare cases that each widen into
// this union, which in turn widens into any wider declared return variant. (Mirror of resolve.c.)
//
// (#83) "Equal" per type_eq ALSO holds sentinel-vs-concrete (`[]Void == []i64`, permissive by
// design — see type_eq's Slice/Optional cases). Blindly returning `a` in that branch discards a
// concrete element type when the SENTINEL happens to be the first operand: an array literal like
// `[[], [1]]` unifies its element type by folding type_join left-to-right over `[]`'s `[]Void`
// then `[1]`'s `[]i64`, and `a` (the accumulator) was the sentinel — the join silently kept
// `[]Void`, so codegen later saw an untyped empty slice with no contextual element (issue #83;
// the VM, which ignores element types, ran fine). Prefer the CONCRETE side when the two are
// sentinel-equal but not type_has_sentinel-equal.
fn type_join(a: Type, b: Type, table: TypeTable) -> Type {
    if type_eq(a, b) {
        let a_sentinel = type_has_sentinel(a)
        let b_sentinel = type_has_sentinel(b)
        return if a_sentinel && !b_sentinel { b } else { a }   // prefer the concrete side
    }
    if widens_into(a, b, table) { return b }
    if widens_into(b, a, table) { return a }
    let m1 = union_collect(teko::list::empty(), a, table)
    let m2 = union_collect(m1, b, table)
    Variant { members = m2 }
}

// ── (S4) generics inference: subst + unify ───────────────────────────────────────────────────
// A type-param → concrete-type binding (parallel arrays). `params` is the generic's type-param
// universe; `names`/`types` are the bindings discovered by unify. Used by type_call (call result
// type) and the monomorph pass (stamping). (C: tk_subst.)
pub type Subst = struct { params: []str; names: []str; types: []Type }

fn is_type_param(name: str, params: []str) -> bool {
    mut i = 0
    loop { if i >= params.len { break }; if params[i] == name { return true }; i++ }
    false
}

fn subst_find(s: Subst, name: str) -> Type? {
    mut i = 0
    loop { if i >= s.names.len { break }; if s.names[i] == name { return s.types[i] }; i++ }
    null
}

// substitute each BOUND type-param Named{Tp} by its concrete type. TOTAL over Type cases; structural
// recursion. A Named that is not a bound param passes through unchanged. (C: tk_subst_type.)
pub fn subst_type(t: Type, s: Subst) -> Type {
    match t {
        Named as n => match subst_find(s, n.name) { Type as ct => ct; null => t }
        Slice as sl => Slice { element = subst_type(sl.element, s) }
        Optional as o => Optional { inner = subst_type(o.inner, s) }
        Reference as r => Reference { inner = subst_type(r.inner, s) }   // (MEM-1b) Ref<T> substitutes its referenced type
        Variant as v => {
            mut ms: []Type = teko::list::empty()
            mut i = 0
            loop { if i >= v.members.len { break }; ms = teko::list::push(ms, subst_type(v.members[i], s)); i++ }
            Variant { members = ms }
        }
        Func as f => {
            mut ps: []Type = teko::list::empty()
            mut i = 0
            loop { if i >= f.params.len { break }; ps = teko::list::push(ps, subst_type(f.params[i], s)); i++ }
            Func { params = ps; ret = subst_type(f.ret, s); variadic = false; param_names = []; n_required = (ps).len; defaults = [] }
        }
        _ => t   // Prim, Byte, Char, Str, Error, Void, Ptr, Uptr — leaves
    }
}

// a non-concrete Void SENTINEL (`empty()` → []Void, bare `null` → Void?)? Such a type cannot pin a
// type-param (it concretizes only in a typed slot — M.2 no-guessing). (C: tk_type_has_void_sentinel.)
fn type_has_void_sentinel(t: Type) -> bool {
    match t {
        Void => true
        Slice as sl => match sl.element { Void => true; _ => false }
        Optional as o => match o.inner { Void => true; _ => false }
        _ => false
    }
}

// unify a param PATTERN (may contain type-param Named's) against a concrete ARG type, extending the
// Subst. Binds each type-param; a re-occurrence must AGREE (S4: exact; LUB is a future refinement).
// `[]T`/`T?` unify their element/inner by structure. REJECT a Void-sentinel arg (cannot pin T —
// M.2). A non-type-param (concrete) pattern binds nothing (strict arg-check happens elsewhere).
// (C: tk_unify.)
pub fn unify(pattern: Type, arg: Type, s: Subst, table: TypeTable) -> Subst | error {
    match pattern {
        Named as n => {
            if !is_type_param(n.name, s.params) { return s }
            if type_has_void_sentinel(arg) {
                return error { message = $"cannot infer type parameter {n.name} from an untyped empty slice / null — annotate the argument" }
            }
            // (MEM Step 0, B) ESCAPE GATE — a reference can NEVER be the INFERRED binding for a type
            // parameter: `id(r)` where r: Ref<i64> would stamp `int64_t * id__g__ref_i64(int64_t *)`,
            // returning a raw reference that outlives its target. Mirror of the written-arg gate in
            // resolve_generic_inst (A); same message.
            match arg { Reference => return error { message = "a reference cannot be a generic type argument (it would be stored/escape)" }; _ => { } }
            match subst_find(s, n.name) {
                Type as existing => {
                    if type_eq(existing, arg) { s }
                    else { error { message = $"type parameter {n.name} inferred as conflicting types" } }
                }
                null => Subst { params = s.params; names = teko::list::push(s.names, n.name); types = teko::list::push(s.types, arg) }
            }
        }
        Slice as sl => match arg { Slice as asl => unify(sl.element, asl.element, s, table); _ => s }
        Optional as o => match arg { Optional as ao => unify(o.inner, ao.inner, s, table); _ => s }
        Reference as r => match arg { Reference as ar => unify(r.inner, ar.inner, s, table); _ => s }   // (MEM-1b)
        _ => s
    }
}

// the type-param names that appear in a function signature: a Named whose name is NOT a registered
// user type (type-params live only in the per-fn scope, never the global table). In order, deduped.
// (C: tk_collect_sig_type_params.)
pub fn collect_sig_type_params(t: Type, table: TypeTable, acc: []str) -> []str {
    match t {
        Named as n => match type_table_find(table, n.name, "") {   // (#109 W1) type-param scan on resolved names — no referencing ns
            parser::TypeDecl => acc
            error => if is_type_param(n.name, acc) { acc } else { teko::list::push(acc, n.name) }
        }
        Slice as sl => collect_sig_type_params(sl.element, table, acc)
        Optional as o => collect_sig_type_params(o.inner, table, acc)
        Reference as r => collect_sig_type_params(r.inner, table, acc)   // (MEM-1b) Ref<T> may carry a type-param
        Variant as v => { mut a = acc; mut i = 0; loop { if i >= v.members.len { break }; a = collect_sig_type_params(v.members[i], table, a); i++ }; a }
        Func as f => { mut a = acc; mut i = 0; loop { if i >= f.params.len { break }; a = collect_sig_type_params(f.params[i], table, a); i++ }; collect_sig_type_params(f.ret, table, a) }
        _ => acc
    }
}

/**
 * Is this named type-expr the `null` type-atom (null-as-union)? The parser carries a `null`
 * in a type position as a single-segment, argument-free `NamedType` named "null" (`null` is a
 * reserved keyword, so no user type ever bears that name).
 *
 * @param nt  the resolved-against named type-expr
 * @return    true iff `nt` is exactly the `null` type-atom
 */
fn named_type_is_null(nt: parser::NamedType) -> bool {
    if nt.args.len != 0 { return false }
    if nt.path.segments.len != 1 { return false }
    nt.path.segments[0].name == "null"
}

/**
 * Canonicalize a union's member order so `null`, if present, is FIRST — leaving every other
 * member in source order and collapsing any repeated `null` to a single leading one. Guarantees
 * `null | error` and `error | null` share one resolved type (and one mangled typedef). A null-free
 * member list is returned unchanged (behavior-preserving for the existing corpus).
 *
 * @param members  the resolved union members (source order)
 * @return         the members with any `Null` moved to (a single) index 0
 */
fn union_normalize_null(members: []Type) -> []Type {
    mut has_null = false
    mut i = 0
    loop {
        if i >= members.len { break }
        match members[i] { Null => has_null = true; _ => { } }
        i++
    }
    if !has_null { return members }
    mut out: []Type = teko::list::push(teko::list::empty(), Null { })
    mut j = 0
    loop {
        if j >= members.len { break }
        match members[j] { Null => { }; _ => out = teko::list::push(out, members[j]) }
        j++
    }
    out
}

// resolve a syntactic TypeExpr to a pure semantic Type (recursive — B.8).
// (#109 W1) `ref_ns` = the REFERENCING namespace (the namespace of the code that wrote `te`).
// Threaded down every recursion (slice element / union members / fn-type params+ret / optional
// inner) and into resolve_named/resolve_generic_inst unchanged. Reserved for W2's R0-R5 rules;
// the W1 body IGNORES it (behavior byte-identical).
pub fn resolve_type(te: parser::TypeExpr, table: TypeTable, ref_ns: str) -> Type | error {
    // (#109 W1) reserved for the R0-R5 rules (W2)
    match te {
        // A plain name resolves as before; generic type-ARGUMENTS `Box<i64>` (S4 type-generics)
        // resolve to the nominal instance `Named{Box__g__i64}` — the concrete decl is stamped by the
        // instantiation pass / mono (blocker #1: reuse the Named case, no new Type variant).
        parser::NamedType as nt => {
            if named_type_is_null(nt) { Null { } }
            else if nt.args.len == 0 { resolve_named(nt.path, table, ref_ns) }
            else { resolve_generic_inst(nt, table, ref_ns) }
        }
        parser::SliceType as st => {
            let el = match resolve_type(st.element, table, ref_ns) {
                Type as t => t
                error as e => return e
            }
            // (MEM Step 0, R4) ESCAPE GATE — a reference cannot be a collection element.
            match el { Reference => return error { message = "a reference cannot be stored in a struct/variant/collection" }; _ => { } }
            Slice { element = el }
        }
        parser::UnionType as ut => {
            mut members: []Type = teko::list::empty()
            mut i = 0
            loop {
                if i >= ut.members.len { break }
                let m = match resolve_type(ut.members[i], table, ref_ns) {
                    Type as t => t
                    error as e => return e
                }
                // M.1/rules 2 & 3: a variant member must be a COMPLETE type — never
                // `void` (not a value) and never nullable (`T?` — disjoint domain).
                match m {
                    Void => return error { message = "a variant member may not be `void`" }
                    Optional => return error { message = "a variant member may not be nullable (`T?`) — use `T | …` and mark the whole type `?`" }
                    Reference => return error { message = "a reference cannot be stored in a struct/variant/collection" }   // (MEM Step 0, R4)
                    // (W10b.D3) an interface (contract) variant member is an honest stop: the VM's
                    // untagged values discriminate a match arm by the CONCRETE class name, so a
                    // `Shape | error` subject would silently diverge between the engines (native
                    // has a tag, the VM does not). Plain interface-typed values work — bind first.
                    Named as nm => {
                        if is_interface_name(nm.name, table) {
                            return error { message = "an interface cannot be a variant member yet — bind the interface value on its own (no `I | error` unions)" }
                        }
                    }
                    _ => { }
                }
                members = teko::list::push(members, m)
                i++
            }
            Variant { members = union_normalize_null(members) }
        }
        // (W10a) FunctionType `(A, B) -> R` → Func { params; ret ; variadic = false }. The return MAY be `void`
        // (a function value can return nothing); params must be COMPLETE value types (void/ref
        // rejected — a ref cannot be stored, R4; void is not a value, M.3).
        parser::FunctionType as fnt => {
            mut ps: []Type = teko::list::empty()
            mut i = 0
            loop {
                if i >= fnt.params.len { break }
                let pt = match resolve_type(fnt.params[i], table, ref_ns) { Type as t => t; error as e => return e }
                match pt {
                    Void => return error { message = "a function type parameter may not be `void` (M.3)" }
                    Reference => return error { message = "a reference cannot be a function-type parameter (a ref cannot escape, R4)" }
                    _ => { }
                }
                ps = teko::list::push(ps, pt)
                i++
            }
            let rt = match resolve_type(fnt.ret, table, ref_ns) { Type as t => t; error as e => return e }
            return Func { params = ps; ret = rt; variadic = false; param_names = []; n_required = (ps).len; defaults = [] }
        }
        parser::OptionalType as ot => {
            // OptionalType `T?` → Optional { inner } (REBOOT_PLAN §202). The variant case
            // above already rejects an optional as a variant member; here we just build it.
            let in = match resolve_type(ot.inner, table, ref_ns) {
                Type as t => t
                error as e => return e
            }
            // `void?` is illegal (void is not a value — M.3); `T??` collapses to `T?`.
            // (MEM Step 0, R2) ESCAPE GATE — a reference is NEVER null, so `Ref<T>?` is rejected.
            match in {
                Void => return error { message = "`void` cannot be made optional (`void?`) — void is not a value (M.3)" }
                Reference => return error { message = "a reference cannot be nullable (a ref is never null, R2)" }
                Optional => return in   // `T??` collapses to `T?`
                _ => Optional { inner = in }
            }
        }
    }
}

// (C1.8) the surface spelling of a prim kind — the same names builtin_type accepts (scope.tks),
// so a rendered mismatch reads in the user's own vocabulary. Mirror of resolve.c::prim_name.
fn prim_name(k: PrimKind) -> str {
    match k {
        U8 => "u8"; U16 => "u16"; U32 => "u32"; U64 => "u64"; U128 => "u128"
        I8 => "i8"; I16 => "i16"; I32 => "i32"; I64 => "i64"; I128 => "i128"
        F16 => "f16"; F32 => "f32"; F64 => "f64"
        Bool => "bool"
    }
}

// (S4) a concrete type → its symbol fragment for a mangled generic-instance name. Prim → its
// surface spelling (i64/…), Str/Byte/Error/Void/Ptr/Uptr → fixed words, Named → the name, Slice →
// "slice_"+elem, Optional → "opt_"+inner. Total — always yields a symbol-safe fragment. Shared by
// resolve (type instantiation) and the mono pass so a use and its stamped decl agree byte-for-byte.
// (#109 W3) a symbol-safe fragment of a canonical name: each "::" → "__". Keeps a generic-instance
// name (Gen__g__teko__emit__Reader) a valid C identifier AND distinct from Gen<teko::io::Reader> —
// name_last_segment would collide the two. Slice-based (no byte-append-to-str primitive exists).
pub fn mangle_ns_frag(name: str) -> str {
    mut out = ""
    mut start: u64 = 0
    mut i: u64 = 0
    loop {
        if i + 1 >= name.len { break }
        if name[i] == b':' && name[i + 1] == b':' {
            out = out ~ teko::str::slice(name, start, i) ~ "__"   // (#148) builtin slice — see name_last_segment
            i = i + 2
            start = i
        } else {
            i++
        }
    }
    out ~ teko::str::slice_from(name, start)   // (#148) builtin slice
}

// (C: tk_type_mangle.)
pub fn type_mangle(t: Type) -> str {
    match t {
        Prim as p => prim_name(p.kind)
        Str => "str"
        Byte => "byte"
        Char => "char"
        Named as n => name_last_segment(n.name)   // (#109 W3) BARE last-segment — slice/opt/generic-inst suffixes stay bare (matching the syntactic cg_opt_mangle_texpr/cg_texpr_inst_name); only DIRECT tk_t_ typedefs (mangle_type_name) carry the canonical ns where the io/emit Reader collision needs distinguishing.
        Slice as sl => teko::str::concat("slice_", type_mangle(sl.element))
        Optional as o => teko::str::concat("opt_", type_mangle(o.inner))
        Error => "error"
        Void => "void"
        Ptr as p => match p.inner { null => "ptr"; Type as t => teko::str::concat("ptr_", type_mangle(t)) }
        Uptr => "uptr"
        Reference as r => teko::str::concat("ref_", type_mangle(r.inner))   // (MEM-1b)
        Variant => "variant"
        Func => "func"
        Null => "null"
    }
}

// (S4) the mangled name of a generic INSTANCE: `<base>__g__<arg0>[__<arg1>…]` over the args IN
// ORDER. The `__g__` infix marks a stamped symbol (no user name may contain it). (C: tk_generic_inst_name.)
pub fn generic_inst_name(base: str, args: []Type) -> str {
    mut out = teko::str::concat(base, "__g__")
    mut i = 0
    loop {
        if i >= args.len { break }
        if i > 0 { out = teko::str::concat(out, "__") }
        out = teko::str::concat(out, type_mangle(args[i]))
        i++
    }
    out
}

/**
 * Is this struct/class literal a SELF-CONSTRUCT inside its own generic template — i.e. the base
 * being constructed equals the enclosing method's owner type, AND that owner is generic (so no
 * concrete instance is stamped while typing the abstract template)? Only then do we type against the
 * abstract template body and tag the node with the phantom `Base__g__<param>` instance name that the
 * mono pass will later remap to the concrete stamp (#254 L4/L5). A non-generic owner, or a
 * construction of a DIFFERENT generic type, is NOT a self-construct → the ordinary
 * expected-instance path (unchanged) applies.
 *
 * @param base_name    the bare base of the constructed type (`Box`)
 * @param owner_type   the enclosing method's owner (`env.owner_type`, canonical or "")
 * @param decl_tparams the constructed base's type-params (generic iff non-empty)
 * @return             true iff this is a self-construct of the enclosing generic template
 * @since onda-3 (#254 L4/L5)
 */
pub fn is_self_generic_construct(base_name: str, owner_type: str, decl_tparams: []str) -> bool {
    if decl_tparams.len == 0 { return false }
    if owner_type == "" { return false }
    name_last_segment(owner_type) == base_name
}

/**
 * The PHANTOM generic-instance name for a self-construct inside a generic template: the enclosing
 * type's OWN type-params, in order, mangled exactly as `resolve_generic_inst` mangles `-> Box<T>`
 * (`Box__g__T`). The template body's self-init, its `-> Box<T>` return, and any `Box<T>` local all
 * carry this SAME spelling, so the mono pass's single `phantom → concrete` remap retargets them
 * together (#254 L4/L5). Reuses `generic_inst_name` over the owner's params-as-Named so the spelling
 * cannot drift from the resolver's.
 *
 * @param base_name     the bare base (`Box`)
 * @param owner_tparams the enclosing type's type-param names (`["T"]`)
 * @return              the phantom instance name (`Box__g__T`)
 * @since onda-3 (#254 L4/L5)
 */
pub fn phantom_self_inst_name(base_name: str, owner_tparams: []str) -> str {
    mut args: []Type = teko::list::empty()
    mut i = 0
    loop {
        if i >= owner_tparams.len { break }
        args = teko::list::push(args, Named { name = owner_tparams[i] })
        i++
    }
    generic_inst_name(base_name, args)
}

// (S4) `Box<i64>` → the nominal instance `Named{Box__g__i64}`. Resolves every type-argument, then
// validates against the generic decl's arity (the decl must exist, be generic, same count). The
// concrete decl (fields with T→arg substituted) is stamped by the instantiation pass / mono.
fn resolve_generic_inst(nt: parser::NamedType, table: TypeTable, ref_ns: str) -> Type | error {
    // (#109 W1) reserved for the R0-R5 rules (W2); threaded to every resolve_type arg + the table lookup.
    let name = nt.path.segments[nt.path.segments.len - 1].name
    // (S-mem) the builtin generic `ptr<T>` → a typed pointer `Ptr{inner}`. `ptr<void>` ≡ the opaque
    // `ptr` (void isn't a value type) → null inner. Not a user decl, handled before the table lookup.
    if name == "ptr" {
        if nt.args.len != 1 { return error { message = "`ptr<T>` takes exactly one type argument" } }
        let argt = match resolve_type(nt.args[0], table, ref_ns) { Type as t => t; error as e => return e }
        match argt { Void => return Ptr { inner = null }; _ => return Ptr { inner = argt } }
    }
    // (MEM-1b) the compiler-known generic struct `Ref<T>` → the SAFE reference `Ref{inner}` (the safe
    // surface OVER the raw `ptr<T>`). Capitalized (a struct-like named type, reusing generics — no
    // keyword). Unlike `ptr`, a ref is never null and never opaque, so `Ref<void>` is rejected (void
    // is not a value) and `Ref` requires a type argument. Not a user decl — reserved, handled before
    // the table lookup.
    if name == "Ref" {
        if nt.args.len != 1 { return error { message = "`Ref<T>` takes exactly one type argument" } }
        let argt = match resolve_type(nt.args[0], table, ref_ns) { Type as t => t; error as e => return e }
        match argt { Void => return error { message = "`Ref<void>` is invalid — void is not a value (M.3)" }; _ => { } }
        // (W9a) ESCAPE GATE — the inner must be a VALUE TYPE. Teko has NO field/index assignment
        // (value-functional), so a non-scalar ref is ONLY ever mutated by WHOLE-`.value` REPLACEMENT
        // (`r.value = newWhole` — native `*r = newWhole` struct/slice copy; VM cell_set), and read
        // by `r.value` (native `(*r)`; VM cell_get). Under the cell-IDENTITY model both are
        // observationally identical in VM and native, exactly like scalars. So Prim, Byte, Str,
        // Named (struct/enum/variant), Slice, Optional and Variant are all allowed. REJECT only the
        // NON-values / aliasing hazards: Void (already above — not a value), Reference (no ref-to-ref),
        // Ptr/Uptr (raw FFI addresses), Func (a function value carries no replaceable storage).
        match argt {
            Reference => return error { message = "a reference cannot target another reference (`Ref<Ref<T>>` is invalid)" }
            Ptr => return error { message = "a reference cannot target a raw pointer (`Ref<ptr<T>>` is invalid — raw FFI addresses are not safe ref targets)" }
            Uptr => return error { message = "a reference cannot target a raw pointer (`Ref<uptr>` is invalid — raw FFI addresses are not safe ref targets)" }
            Func => return error { message = "a reference cannot target a function (`Ref<(…)->…>` is invalid)" }
            _ => return Reference { inner = argt }
        }
    }
    mut argtypes: []Type = teko::list::empty()
    mut i = 0
    loop {
        if i >= nt.args.len { break }
        let a = match resolve_type(nt.args[i], table, ref_ns) { Type as t => t; error as e => return e }
        // (MEM Step 0, A) ESCAPE GATE — a reference can NEVER be a generic type ARGUMENT: carrying a
        // `Ref<T>` into a user generic would stamp it into a struct field / return position (e.g.
        // `Box<Ref<i64>>` → `struct { value: int64_t * }` returned by value) and escape. The template
        // itself is validated pre-instantiation (R1–R5); the only way a Reference enters a stamped
        // decl/fn is via a type-arg — blocked here (written) and in unify (inferred).
        match a { Reference => return error { message = "a reference cannot be a generic type argument (it would be stored/escape)" }; _ => { } }
        argtypes = teko::list::push(argtypes, a)
        i++
    }
    match resolve_type_ref(nt.path, table, ref_ns) {   // (#109 W2) R0/R3/R4 over the WRITTEN path
        parser::TypeDecl as td => {
            if td.type_params.len == 0 {
                return error { message = $"type `{name}` is not generic but was given type arguments" }
            }
            if td.type_params.len != nt.args.len {
                return error { message = $"generic type `{name}` expects a different number of type arguments" }
            }
            Named { name = generic_inst_name(name, argtypes) }
        }
        // R3/R4 fail-loud diagnostics propagate verbatim; the plain "not a user type" sentinel
        // becomes the generic-specific "unknown generic type" message.
        error as e => { if e.message == "not a user type" { return error { message = $"unknown generic type: {name}" } }; return e }
    }
}

// (C1.8) render a semantic Type to a human string for diagnostics ("expected X, found Y"):
//   prims → "i32"/… , "byte", "str", "error", "void", slice → "[]<elem>", optional → "<inner>?",
//   variant → "A | B | …", named → "<name>". Recursion builds slice/optional/variant bottom-up.
// Mirror of resolve.c::tk_type_render. This depends ONLY on the Type model (E2-independent — it
// never touches the surface `error` value), so it is materialized now, not deferred to E2.
// (A SENTINEL slice/optional — a `Void`-marker element/inner, the untyped `empty()` / bare `null`
//  — renders its hole as "_", matching the C twin's NULL-pointer case.)
pub fn type_render(t: Type) -> str {
    match t {
        Prim as p => prim_name(p.kind)
        Byte => "byte"
        Char => "char"
        Str => "str"
        Error => "error"
        Void => "void"
        Named as n => name_last_segment(n.name)   // (#109 W3) canonical "ns::Name" → bare "Name" for readable diagnostics
        Slice as s => match s.element { Void => "[]_"; _ => $"[]{type_render(s.element)}" }
        Optional as o => match o.inner { Void => "_?"; _ => $"{type_render(o.inner)}?" }
        Variant as v => render_members(v.members)
        Func as f => render_func(f)   // (C1.8) "(p0, …) -> ret" — full mirror of resolve.c (M.3, show what we know)
        Ptr as p => match p.inner { null => "ptr"; Type as t => $"ptr<{type_render(t)}>" }   // ptr<T> human render
        Uptr => "uptr"   // (C7.1a) opaque word-size unsigned
        Reference as r => $"Ref<{type_render(r.inner)}>"   // (MEM-1b) Ref<T> human render
        Null => "null"
    }
}

// (C1.8) render a function type "(p0, p1, …) -> ret" — mirror of the FUNC branch of
// resolve.c::tk_type_render (M.3, show what we know). `ret` may be void.
fn render_func(f: Func) -> str {
    mut params = ""
    mut i = 0
    loop {
        if i >= f.params.len { break }
        if i > 0 { params = $"{params}, " }
        params = $"{params}{type_render(f.params[i])}"
        i++
    }
    $"({params}) -> {type_render(f.ret)}"
}

// (C1.8) join variant members with " | " (e.g. "Circle | Square | Triangle"). Mirror of the
// variant branch of resolve.c::tk_type_render.
fn render_members(members: []Type) -> str {
    if members.len == 0 { return "<empty variant>" }
    mut out = type_render(members[0])
    mut i = 1
    loop {
        if i >= members.len { break }
        out = $"{out} | {type_render(members[i])}"
        i++
    }
    out
}

// ── (S4) type-generic INSTANTIATION pass ────────────────────────────────────────────────────────
// Discover every WRITTEN generic-type use `Box<i64>` across the program and STAMP a concrete decl
// `Box__g__i64 = struct { value: i64 }` into the TypeTable BEFORE typing, so field-access and
// struct-init see concrete fields. No generic type used → the table is returned UNCHANGED (the
// non-generic corpus is unperturbed). The stamped name reuses generic_inst_name, so a USE
// (resolve_generic_inst) and its stamped decl agree byte-for-byte. (C: tk_instantiate_types.)
//
// SCOPE (this crumb): instantiation sites are fn params/returns, type-decl bodies (struct/variant/
// alias), and binding ANNOTATIONS (recursing loop/defer blocks). Casts and if/match-nested bindings
// are not yet walked (a later crumb) — those surface as an "unknown type" at typing, not silently.

// substitute type-parameter NAMES with their argument type-exprs throughout a (syntactic) type-expr.
fn subst_texpr_names(te: parser::TypeExpr, params: []str, args: []parser::TypeExpr) -> parser::TypeExpr {
    match te {
        parser::NamedType as nt => {
            if nt.path.segments.len == 1 && nt.args.len == 0 {
                let nm = nt.path.segments[0].name
                mut k = 0
                loop {
                    if k >= params.len { break }
                    if params[k] == nm { return args[k] }
                    k++
                }
            }
            mut nargs: []parser::TypeExpr = teko::list::empty()
            mut j = 0
            loop { if j >= nt.args.len { break }; nargs = teko::list::push(nargs, subst_texpr_names(nt.args[j], params, args)); j++ }
            parser::NamedType { path = nt.path; args = nargs }
        }
        parser::SliceType as st => parser::SliceType { element = subst_texpr_names(st.element, params, args) }
        parser::OptionalType as ot => parser::OptionalType { inner = subst_texpr_names(ot.inner, params, args) }
        parser::UnionType as ut => {
            mut ms: []parser::TypeExpr = teko::list::empty()
            mut i = 0
            loop { if i >= ut.members.len { break }; ms = teko::list::push(ms, subst_texpr_names(ut.members[i], params, args)); i++ }
            parser::UnionType { members = ms }
        }
        parser::FunctionType as fnt => {   // (W10a) recurse into params + return
            mut nps: []parser::TypeExpr = teko::list::empty()
            mut i = 0
            loop { if i >= fnt.params.len { break }; nps = teko::list::push(nps, subst_texpr_names(fnt.params[i], params, args)); i++ }
            parser::FunctionType { params = nps; ret = subst_texpr_names(fnt.ret, params, args) }
        }
    }
}

/**
 * Substitute the enclosing type's parameters through a method's SIGNATURE (its param type
 * annotations and return type) so a stamped instance carries a concrete method signature (#254
 * layer 2). Only the signature is rewritten — the body statements are left untouched, because a
 * stamped-instance method is never re-typed nor re-emitted from this syntactic body; its concrete
 * body is stamped from the ALREADY-TYPED template method by the mono pass (layer 3). The receiver
 * param (index 0, `has_type=false`) is preserved verbatim: the checker re-injects the enclosing
 * (now concrete) type as its type when the instance's method is typed/registered.
 *
 * @param f       the method (a struct/class body Function)
 * @param params  the enclosing type's parameter names
 * @param args    the concrete type-args at this instantiation
 * @return        the method with its param annotations + return type substituted to concrete types
 * @since onda-3 (#254)
 */
fn subst_method_sig_names(f: parser::Function, params: []str, args: []parser::TypeExpr) -> parser::Function {
    mut nps: []parser::Param = teko::list::empty()
    mut i = 0
    loop {
        if i >= f.params.len { break }
        let np = if f.params[i].has_type {
            parser::Param { name = f.params[i].name; has_type = true; type_ann = subst_texpr_names(f.params[i].type_ann, params, args); is_params = f.params[i].is_params; has_default = f.params[i].has_default; default_expr = f.params[i].default_expr }
        } else {
            f.params[i]
        }
        nps = teko::list::push(nps, np)
        i++
    }
    let nret = if f.has_return { subst_texpr_names(f.return_type, params, args) } else { f.return_type }
    parser::Function { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = nps; has_return = f.has_return; return_type = nret; body = f.body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; line = f.line; col = f.col; is_test = f.is_test; is_extern = f.is_extern; c_symbol = f.c_symbol; from_lib = f.from_lib; os_guard = f.os_guard; is_intern = f.is_intern; is_abstract = f.is_abstract; is_virtual = f.is_virtual; is_override = f.is_override; has_inject = f.has_inject; injects = f.injects; is_unsafe = f.is_unsafe }
}

/**
 * Substitute the enclosing type's parameters through a method LIST — every method's signature is
 * rewritten to concrete types (#254 layer 2). A NO-OP on an empty list (the existing corpus's
 * generic types carry no methods) → byte-identical.
 *
 * @param methods the enclosing type's methods
 * @param params  the enclosing type's parameter names
 * @param args    the concrete type-args at this instantiation
 * @return        the methods with their signatures substituted
 * @since onda-3 (#254)
 */
fn subst_methods_names(methods: []parser::Function, params: []str, args: []parser::TypeExpr) -> []parser::Function {
    mut out: []parser::Function = teko::list::empty()
    mut i = 0
    loop { if i >= methods.len { break }; out = teko::list::push(out, subst_method_sig_names(methods[i], params, args)); i++ }
    out
}

/**
 * Substitute the enclosing type's parameters throughout a type-decl BODY (struct fields + methods /
 * class fields + methods / variant / alias). (#254 layer 2) methods are now KEPT and their signatures
 * substituted — previously dropped for a struct (`methods = []`), previously passed through
 * un-substituted for a class via the `_` arm. A body kind that carries no type-exprs (enum/flags/
 * extern) passes through unchanged.
 *
 * @param body    the generic type's body
 * @param params  the enclosing type's parameter names
 * @param args    the concrete type-args at this instantiation
 * @return        the body with fields AND method signatures substituted to concrete types
 * @since onda-3 (#254)
 */
fn subst_body_names(body: parser::TypeBody, params: []str, args: []parser::TypeExpr) -> parser::TypeBody {
    match body {
        parser::StructBody as sb => {
            mut nf: []parser::Field = teko::list::empty()
            mut i = 0
            loop { if i >= sb.fields.len { break }; nf = teko::list::push(nf, parser::Field { name = sb.fields[i].name; type_ann = subst_texpr_names(sb.fields[i].type_ann, params, args); vis = parser::Visibility::Pub; is_intern = false; has_doc = sb.fields[i].has_doc; doc = sb.fields[i].doc }); i++ }
            parser::StructBody { fields = nf; methods = subst_methods_names(sb.methods, params, args); implements = sb.implements; consts = sb.consts }
        }
        parser::ClassBody as cb => {
            mut nf: []parser::Field = teko::list::empty()
            mut i = 0
            loop { if i >= cb.fields.len { break }; nf = teko::list::push(nf, parser::Field { name = cb.fields[i].name; type_ann = subst_texpr_names(cb.fields[i].type_ann, params, args); vis = cb.fields[i].vis; is_intern = cb.fields[i].is_intern; has_doc = cb.fields[i].has_doc; doc = cb.fields[i].doc }); i++ }
            parser::ClassBody { kind = cb.kind; has_base = cb.has_base; base_name = cb.base_name; has_base_binding = cb.has_base_binding; base_binding_name = cb.base_binding_name; implements = cb.implements; fields = nf; methods = subst_methods_names(cb.methods, params, args); consts = cb.consts }
        }
        parser::VariantBody as vb => parser::VariantBody { type_expr = subst_texpr_names(vb.type_expr, params, args) }
        parser::AliasBody as ab => parser::AliasBody { alias = subst_texpr_names(ab.alias, params, args) }
        _ => body   // enum / flags / extern carry no type-exprs
    }
}

// collect every generic-type USE (a NamedType carrying args) reachable in a type-expr — innermost
// first, so a nested `Box<i64>` inside `[]Box<i64>` is stamped before the enclosing use.
fn collect_texpr_insts(te: parser::TypeExpr, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    match te {
        parser::NamedType as nt => {
            mut i = 0
            loop { if i >= nt.args.len { break }; out = collect_texpr_insts(nt.args[i], out); i++ }
            if nt.args.len > 0 { out = teko::list::push(out, te) }
        }
        parser::SliceType as st => out = collect_texpr_insts(st.element, out)
        parser::OptionalType as ot => out = collect_texpr_insts(ot.inner, out)
        parser::UnionType as ut => { mut i = 0; loop { if i >= ut.members.len { break }; out = collect_texpr_insts(ut.members[i], out); i++ } }
        parser::FunctionType as fnt => { mut i = 0; loop { if i >= fnt.params.len { break }; out = collect_texpr_insts(fnt.params[i], out); i++ }; out = collect_texpr_insts(fnt.ret, out) }   // (W10a)
    }
    out
}

/**
 * Collect every generic-type USE reachable through a method — its signature (param annotations +
 * return type) AND its body statements (#254 layer 2). This is what makes a transitive instance
 * that appears ONLY inside a method body (`list.push(Box<i64>{…})`) get stamped: without it, such an
 * instance is never discovered. A NO-OP when the method references no generic type.
 *
 * @param f    the method (a struct/class body Function)
 * @param acc  the accumulated generic-use list
 * @return     `acc` extended with every generic use found in the method's signature and body
 * @since onda-3 (#254)
 */
fn collect_method_insts(f: parser::Function, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    mut i = 0
    loop { if i >= f.params.len { break }; if f.params[i].has_type { out = collect_texpr_insts(f.params[i].type_ann, out) }; i++ }
    if f.has_return { out = collect_texpr_insts(f.return_type, out) }
    collect_stmts_insts(f.body, out)
}

/**
 * Collect every generic-type USE reachable through a method LIST (#254 layer 2). NO-OP on empty.
 *
 * @param methods the type's methods
 * @param acc     the accumulated generic-use list
 * @return        `acc` extended with every generic use found in the methods
 * @since onda-3 (#254)
 */
fn collect_methods_insts(methods: []parser::Function, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    mut i = 0
    loop { if i >= methods.len { break }; out = collect_method_insts(methods[i], out); i++ }
    out
}

fn collect_body_insts(body: parser::TypeBody, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    match body {
        parser::StructBody as sb => {
            mut i = 0
            loop { if i >= sb.fields.len { break }; out = collect_texpr_insts(sb.fields[i].type_ann, out); i++ }
            out = collect_methods_insts(sb.methods, out)
        }
        parser::ClassBody as cb => {
            mut i = 0
            loop { if i >= cb.fields.len { break }; out = collect_texpr_insts(cb.fields[i].type_ann, out); i++ }
            out = collect_methods_insts(cb.methods, out)
        }
        parser::VariantBody as vb => out = collect_texpr_insts(vb.type_expr, out)
        parser::AliasBody as ab => out = collect_texpr_insts(ab.alias, out)
        _ => { }
    }
    out
}

fn collect_stmts_insts(stmts: []parser::Statement, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    mut i = 0
    loop { if i >= stmts.len { break }; out = collect_stmt_insts(stmts[i], out); i++ }
    out
}

// (W9.4) collect the generic instance a construction-site / bind-pattern type-arg list names: synthesize
// the NamedType `<path><args>` and run it through collect_texpr_insts (which pushes it AND recurses into
// the args), so `Foo<i64>{…}` / `Foo<i64> as x` get `Foo__g__i64` stamped exactly like an annotation.
fn collect_site_args(path: parser::Path, args: []parser::TypeExpr, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    if args.len == 0 { return acc }
    collect_texpr_insts(parser::NamedType { path = path; args = args }, acc)
}

/**
 * Collect the generic-instance a static-factory call names via construction-site type-args
 * (`Cell<i64>::make(…)` → stamp `Cell__g__i64`) (#254 L5). The instance's OWNER base is the callee's
 * SECOND-TO-LAST segment (`Cell` of `Cell::make`); synthesizing `Cell<i64>` and running it through
 * `collect_site_args` stamps it exactly like a `Cell<i64>{…}` construction. A call with no type-args
 * (or a single-segment callee) contributes nothing — every existing call is unchanged.
 *
 * @param call the parsed call (possibly carrying construction-site type-args)
 * @param acc  the instance worklist so far
 * @return     `acc` plus the factory instance's synthetic NamedType (or `acc` unchanged)
 * @since onda-3 (#254 L5)
 */
fn collect_call_site_args(call: parser::Call, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    if call.type_args.len == 0 { return acc }
    if call.callee.segments.len < 2 { return acc }
    let base = call.callee.segments[call.callee.segments.len - 2].name
    collect_site_args(parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = base }) }, call.type_args, acc)
}

// (W9.4) walk an expression for construction-site type-args (`Foo<i64>{…}`) and nested patterns.
fn collect_expr_insts(e: parser::Expr, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    match e.kind {
        parser::StructLit as sl => {
            out = collect_site_args(sl.type_path, sl.type_args, out)
            mut i = 0
            loop { if i >= sl.field_vals.len { break }; out = collect_expr_insts(sl.field_vals[i], out); i++ }
        }
        parser::Binary as b => { out = collect_expr_insts(b.left, out); out = collect_expr_insts(b.right, out) }
        parser::Unary as u => out = collect_expr_insts(u.operand, out)
        parser::Compare as c => {
            out = collect_expr_insts(c.first, out)
            mut i = 0
            loop { if i >= c.rest.len { break }; out = collect_expr_insts(c.rest[i].operand, out); i++ }
        }
        parser::Call as call => {
            out = collect_call_site_args(call, out)
            mut i = 0
            loop { if i >= call.args.len { break }; out = collect_expr_insts(call.args[i], out); i++ }
        }
        parser::IfExpr as f => {
            out = collect_expr_insts(f.cond, out)
            out = collect_stmts_insts(f.then_blk, out)
            if f.has_else { out = collect_stmts_insts(f.else_blk, out) }
        }
        parser::MatchExpr as m => {
            out = collect_expr_insts(m.subject, out)
            mut i = 0
            loop {
                if i >= m.arms.len { break }
                out = collect_pattern_insts(m.arms[i].pattern, out)
                if m.arms[i].has_when { out = collect_expr_insts(m.arms[i].guard, out) }
                out = collect_stmts_insts(m.arms[i].body, out)
                i++
            }
        }
        parser::FieldAccess as fa => out = collect_expr_insts(fa.receiver, out)
        parser::SafeFieldAccess as sfa => out = collect_expr_insts(sfa.receiver, out)
        parser::Coalesce as co => { out = collect_expr_insts(co.left, out); out = collect_expr_insts(co.right, out) }
        parser::MethodCall as mc => {
            out = collect_expr_insts(mc.receiver, out)
            mut i = 0
            loop { if i >= mc.args.len { break }; out = collect_expr_insts(mc.args[i], out); i++ }
        }
        parser::SafeMethodCall as smc => {   // (NP-OOP, issue #116) recv?.method(args)
            out = collect_expr_insts(smc.receiver, out)
            mut i = 0
            loop { if i >= smc.args.len { break }; out = collect_expr_insts(smc.args[i], out); i++ }
        }
        parser::Cast as ct => out = collect_expr_insts(ct.expr, out)
        parser::Index as ix => { out = collect_expr_insts(ix.receiver, out); out = collect_expr_insts(ix.index, out) }
        parser::Interp as ip => { mut i = 0; loop { if i >= ip.holes.len { break }; out = collect_expr_insts(ip.holes[i], out); i++ } }
        parser::InExpr as ie => {
            out = collect_expr_insts(ie.lhs, out)
            mut i = 0
            loop { if i >= ie.elems.len { break }; out = collect_expr_insts(ie.elems[i], out); i++ }
        }
        parser::ArrayLit as al => { mut i = 0; loop { if i >= al.elements.len { break }; out = collect_expr_insts(al.elements[i].expr, out); i++ } }
        _ => { }   // leaves (Number/Var/StrLit/ByteLit/BoolLit/NullLit/PathExpr) carry no type-args
    }
    out
}

// (W9.4) walk a pattern for bind-pattern type-args (`Foo<i64> as x`, incl alt options).
fn collect_pattern_insts(p: parser::Pattern, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    match p {
        parser::BindPattern as bp => { if !bp.is_slice { out = collect_site_args(bp.type_name, bp.type_args, out) } }
        parser::AltPattern as ap => { mut i = 0; loop { if i >= ap.options.len { break }; out = collect_pattern_insts(ap.options[i], out); i++ } }
        _ => { }
    }
    out
}

fn collect_stmt_insts(s: parser::Statement, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    match s {
        parser::Binding as b => { if b.has_type { out = collect_texpr_insts(b.type_ann, out) }; out = collect_expr_insts(b.value, out) }
        parser::Assign as a => { out = collect_expr_insts(a.value, out); match a.kind { parser::AssignKind::Field => out = collect_expr_insts(a.target, out); _ => { } } }   // (#88) the FIELD LHS receiver may name generic instances
        parser::Return as r => { if r.has_value { out = collect_expr_insts(r.value, out) } }
        parser::ExprStmt as es => out = collect_expr_insts(es.expr, out)
        parser::LoopStmt as l => out = collect_stmts_insts(l.body, out)
        parser::DeferStmt as d => out = collect_stmts_insts(d.body, out)
        parser::AdoptStmt as a => out = collect_stmts_insts(a.body, out)
        _ => { }
    }
    out
}

fn collect_item_insts(it: parser::Item, acc: []parser::TypeExpr) -> []parser::TypeExpr {
    mut out = acc
    match it.content {
        parser::Function as f => {
            mut i = 0
            loop { if i >= f.params.len { break }; out = collect_texpr_insts(f.params[i].type_ann, out); i++ }
            if f.has_return { out = collect_texpr_insts(f.return_type, out) }
            out = collect_stmts_insts(f.body, out)
        }
        parser::TypeDecl as td => out = collect_body_insts(td.body, out)
        parser::Statement as s => out = collect_stmt_insts(s, out)
        _ => { }
    }
    out
}

// THE PASS: collect instantiation sites, then stamp each concrete decl into the table (dedup by
// mangled name), scanning each stamped body for transitive instantiations until the worklist drains.
pub fn instantiate_types(program: parser::Program, table: TypeTable) -> TypeTable {
    mut work: []parser::TypeExpr = teko::list::empty()
    mut i = 0
    loop { if i >= program.items.len { break }; work = collect_item_insts(program.items[i], work); i++ }
    if work.len == 0 { return table }   // no generic type used → unchanged (corpus-safe)
    mut tbl = table
    mut wi = 0
    loop {
        if wi >= work.len { break }
        let te = work[wi]
        wi++
        match te {
            parser::NamedType as nt => {
                if nt.args.len == 0 { continue }
                let name = nt.path.segments[nt.path.segments.len - 1].name
                // resolve args → concrete types for the mangled name; an unresolved arg (e.g. a
                // type-param inside a generic body) means this site concretizes only when the OUTER
                // generic is instantiated — skip it here.
                mut argtypes: []Type = teko::list::empty()
                mut ok = true
                mut a = 0
                loop {
                    if a >= nt.args.len { break }
                    match resolve_type(nt.args[a], tbl, type_ns_of(tbl, name)) { Type as t => argtypes = teko::list::push(argtypes, t); error => { ok = false; break } }   // (#109 W2) resolve args in the generic base's OWN ns (its args are written alongside it)
                    a++
                }
                if !ok { continue }
                let mangled = generic_inst_name(name, argtypes)
                match type_table_find(tbl, mangled, "") { parser::TypeDecl => continue; error => { } }   // (#109 W1) already-stamped probe — no referencing ns
                match type_table_find(tbl, name, "") {   // (#109 W1) generic-base lookup in the program-wide pass — no referencing ns
                    parser::TypeDecl as gen => {
                        if gen.type_params.len != nt.args.len { continue }   // arity error surfaces at resolve
                        let nbody = subst_body_names(gen.body, gen.type_params, nt.args)
                        let inst_unsafe = gen.is_unsafe || generic_args_unsafe_carrying(argtypes, tbl)
                        let stamped = parser::TypeDecl { name = mangled; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = nbody; vis = gen.vis; has_doc = false; doc = ""; line = gen.line; col = gen.col; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = inst_unsafe; must_free = gen.must_free }
                        tbl = teko::list::push(tbl, TypeReg { name = mangled; namespace = type_ns_of(tbl, name); vis = gen.vis; decl = stamped })   // (#109 W2) stamp in the generic base's ns so the substituted body's bare field types resolve there
                        work = collect_body_insts(nbody, work)   // transitive instantiations in the stamped body
                    }
                    error => continue   // unknown base type → reported at typing
                }
            }
            _ => continue
        }
    }
    // (W9.4) normalize generic-INSTANCE references in the stamped bodies to bare stamped names, so
    // codegen / VM / TKB (reading the syntactic body) agree with the resolved value types.
    normalize_table_instances(tbl)
}

// does `name` carry the `__g__` generic-instance infix? (the collision-proof marker a stamped
// instance name uses; no user symbol may contain it.) (C: tk_name_is_g_instance.)
pub fn name_is_g_instance(name: str) -> bool {
    if name.len < 5 { return false }
    mut i = 0
    loop {
        if i + 5 > name.len { break }
        if name[i] == b'_' && name[i + 1] == b'_' && name[i + 2] == b'g' && name[i + 3] == b'_' && name[i + 4] == b'_' { return true }
        i++
    }
    false
}

/** A generic TEMPLATE decl paired with its declaring namespace — the mono pass needs both to stamp
    an instance's methods (the template carries the abstract method bodies; the ns canonicalizes the
    receiver remap). TypeReg is file-private, so this pub struct exposes just the two fields (#254). */
pub type TemplateReg = struct { decl: parser::TypeDecl; namespace: str }

/**
 * The GENERIC TEMPLATE decl (`type Box<T>`) named `base`, paired with its declaring namespace — the
 * source of a stamped instance's abstract method bodies + the receiver-remap canonical name (#254
 * layer 3). Matches the template by its base name being `base` (name OR last segment) AND carrying
 * type-params. Returns null when no generic template named `base` is registered.
 *
 * @param table the folded type table
 * @param base  the generic base name (`Box`, from `g_instance_base` of the instance)
 * @return      the template decl + its namespace, or null when no generic `base` exists
 * @since onda-3 (#254)
 */
pub fn find_generic_template(table: TypeTable, base: str) -> TemplateReg? {
    mut i = 0
    loop {
        if i >= table.len { break }
        let reg = table[i]
        if reg.decl.type_params.len > 0 {
            if teko::runtime::str_eq(reg.name, base) || teko::runtime::str_eq(name_last_segment(reg.name), base) {
                return TemplateReg { decl = reg.decl; namespace = reg.namespace }
            }
        }
        i++
    }
    null
}

// (S4) the concrete generic-type INSTANCE decls stamped into the table (the `__g__`-marked entries),
// for the mono pass to emit as program items so codegen sees the concrete struct/variant. TypeReg is
// file-private, so this accessor exposes just the decls. (C: tk_table_generic_instances.)
pub fn table_generic_instances(table: TypeTable) -> []parser::TypeDecl {
    mut out: []parser::TypeDecl = teko::list::empty()
    mut i = 0
    loop {
        if i >= table.len { break }
        if name_is_g_instance(table[i].name) {
            if table[i].decl.type_params.len == 0 { out = teko::list::push(out, table[i].decl) }
        }
        i++
    }
    out
}

// (W9.4) NORMALIZE generic-INSTANCE references in a (syntactic) type-expr to the BARE stamped name.
// A `Base<args>` reference where `Base` is a user-defined generic (so it resolves to a stamped
// `Base__g__<mangle>` instance) is rewritten to a bare `NamedType{[Base__g__mangle]}` with NO args,
// so codegen / VM / TKB (which read the SYNTACTIC declaration body) carry the SAME stamped name the
// RESOLVED value type carries. A type-PARAMETER name (`T`, args_len == 0) is NOT rewritten; builtin
// `ptr<T>`/`Ref<T>` (which resolve to Ptr/Ref, not a Named instance) keep their structural shape and
// their args are normalized recursively. NO-OP when the expr carries no generic-instance reference.
// (C: tk_normalize_inst_texpr.)
fn normalize_inst_texpr(te: parser::TypeExpr, table: TypeTable) -> parser::TypeExpr {
    match te {
        parser::NamedType as nt => {
            if nt.args.len > 0 {
                // does this `Base<args>` resolve to a stamped user generic instance? (resolve_type
                // → resolve_generic_inst yields Named{Base__g__mangle}; ptr/Ref yield Ptr/Ref.)
                match resolve_type(te, table, type_ns_of(table, nt.path.segments[nt.path.segments.len - 1].name)) {   // (#109 W2) normalization probe resolves in the generic base's OWN ns
                    Type as rt => {
                        match rt {
                            Named as rn => {
                                if name_is_g_instance(rn.name) {
                                    let seg = parser::Segment { name = rn.name }
                                    return parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), seg) }; args = teko::list::empty() }
                                }
                            }
                            _ => { }
                        }
                    }
                    error => { }
                }
            }
            // not a stamped instance (plain name, type-param, or builtin) → recurse into the args.
            mut nargs: []parser::TypeExpr = teko::list::empty()
            mut j = 0
            loop { if j >= nt.args.len { break }; nargs = teko::list::push(nargs, normalize_inst_texpr(nt.args[j], table)); j++ }
            parser::NamedType { path = nt.path; args = nargs }
        }
        parser::SliceType as st => parser::SliceType { element = normalize_inst_texpr(st.element, table) }
        parser::OptionalType as ot => parser::OptionalType { inner = normalize_inst_texpr(ot.inner, table) }
        parser::UnionType as ut => {
            mut ms: []parser::TypeExpr = teko::list::empty()
            mut i = 0
            loop { if i >= ut.members.len { break }; ms = teko::list::push(ms, normalize_inst_texpr(ut.members[i], table)); i++ }
            parser::UnionType { members = ms }
        }
        parser::FunctionType as fnt => {   // (W10a) normalize params + return
            mut nps: []parser::TypeExpr = teko::list::empty()
            mut i = 0
            loop { if i >= fnt.params.len { break }; nps = teko::list::push(nps, normalize_inst_texpr(fnt.params[i], table)); i++ }
            parser::FunctionType { params = nps; ret = normalize_inst_texpr(fnt.ret, table) }
        }
    }
}

/**
 * Normalize the generic-instance references in a method's SIGNATURE (param annotations + return type)
 * to bare stamped names, mirroring normalize_inst_body's field walk (#254 layer 2). The receiver
 * (index 0, `has_type=false`) and the body are preserved verbatim (the concrete body is stamped from
 * the typed template by the mono pass). A NO-OP when the signature carries no generic-instance ref.
 *
 * @param f      the method (a struct/class body Function)
 * @param table  the folded type table (drives the generic-instance name resolution)
 * @return       the method with its signature's generic-instance refs normalized to bare stamped names
 * @since onda-3 (#254)
 */
fn normalize_inst_method(f: parser::Function, table: TypeTable) -> parser::Function {
    mut nps: []parser::Param = teko::list::empty()
    mut i = 0
    loop {
        if i >= f.params.len { break }
        let np = if f.params[i].has_type {
            parser::Param { name = f.params[i].name; has_type = true; type_ann = normalize_inst_texpr(f.params[i].type_ann, table); is_params = f.params[i].is_params; has_default = f.params[i].has_default; default_expr = f.params[i].default_expr }
        } else {
            f.params[i]
        }
        nps = teko::list::push(nps, np)
        i++
    }
    let nret = if f.has_return { normalize_inst_texpr(f.return_type, table) } else { f.return_type }
    parser::Function { name = f.name; type_params = f.type_params; type_constraints = f.type_constraints; params = nps; has_return = f.has_return; return_type = nret; body = f.body; vis = f.vis; has_doc = f.has_doc; doc = f.doc; line = f.line; col = f.col; is_test = f.is_test; is_extern = f.is_extern; c_symbol = f.c_symbol; from_lib = f.from_lib; os_guard = f.os_guard; is_intern = f.is_intern; is_abstract = f.is_abstract; is_virtual = f.is_virtual; is_override = f.is_override; has_inject = f.has_inject; injects = f.injects; is_unsafe = f.is_unsafe }
}

/**
 * Normalize the generic-instance references in a method LIST (#254 layer 2). NO-OP on an empty list.
 *
 * @param methods the type's methods
 * @param table   the folded type table
 * @return        the methods with their signatures' generic-instance refs normalized
 * @since onda-3 (#254)
 */
fn normalize_inst_methods(methods: []parser::Function, table: TypeTable) -> []parser::Function {
    mut out: []parser::Function = teko::list::empty()
    mut i = 0
    loop { if i >= methods.len { break }; out = teko::list::push(out, normalize_inst_method(methods[i], table)); i++ }
    out
}

/**
 * (W9.4) Normalize generic-instance references to bare stamped names throughout a type-decl BODY.
 * (#254 layer 2) methods are now KEPT and their signatures normalized — previously dropped for a
 * struct, previously un-normalized for a class (the `_` passthrough). A body kind with no type-exprs
 * passes through unchanged.
 *
 * @param body   the type-decl's body
 * @param table  the folded type table (drives the generic-instance name resolution)
 * @return       the body with fields AND method signatures' generic-instance refs normalized
 * @since onda-3 (#254)
 */
fn normalize_inst_body(body: parser::TypeBody, table: TypeTable) -> parser::TypeBody {
    match body {
        parser::StructBody as sb => {
            mut nf: []parser::Field = teko::list::empty()
            mut i = 0
            loop { if i >= sb.fields.len { break }; nf = teko::list::push(nf, parser::Field { name = sb.fields[i].name; type_ann = normalize_inst_texpr(sb.fields[i].type_ann, table); vis = parser::Visibility::Pub; is_intern = false; has_doc = sb.fields[i].has_doc; doc = sb.fields[i].doc }); i++ }
            parser::StructBody { fields = nf; methods = normalize_inst_methods(sb.methods, table); implements = sb.implements; consts = sb.consts }
        }
        parser::ClassBody as cb => {
            mut nf: []parser::Field = teko::list::empty()
            mut i = 0
            loop { if i >= cb.fields.len { break }; nf = teko::list::push(nf, parser::Field { name = cb.fields[i].name; type_ann = normalize_inst_texpr(cb.fields[i].type_ann, table); vis = cb.fields[i].vis; is_intern = cb.fields[i].is_intern; has_doc = cb.fields[i].has_doc; doc = cb.fields[i].doc }); i++ }
            parser::ClassBody { kind = cb.kind; has_base = cb.has_base; base_name = cb.base_name; has_base_binding = cb.has_base_binding; base_binding_name = cb.base_binding_name; implements = cb.implements; fields = nf; methods = normalize_inst_methods(cb.methods, table); consts = cb.consts }
        }
        parser::VariantBody as vb => parser::VariantBody { type_expr = normalize_inst_texpr(vb.type_expr, table) }
        parser::AliasBody as ab => parser::AliasBody { alias = normalize_inst_texpr(ab.alias, table) }
        _ => body
    }
}

// (W9.4) normalize generic-instance references throughout a type-decl. Used by the typer to rewrite
// BOTH the stamped instances (in the table) AND every non-generic decl item (e.g. `Wrap` whose
// variant member is `Gen<i64>`), so the syntactic body codegen/VM read agrees with the resolved
// type. A NO-OP when the body has no generic-instance reference. (C: tk_normalize_inst_decl.)
pub fn normalize_inst_decl(d: parser::TypeDecl, table: TypeTable) -> parser::TypeDecl {
    parser::TypeDecl { name = d.name; type_params = d.type_params; type_constraints = d.type_constraints; body = normalize_inst_body(d.body, table); vis = d.vis; has_doc = d.has_doc; doc = d.doc; line = d.line; col = d.col; di_kind = d.di_kind; has_di_key = d.has_di_key; di_key = d.di_key; is_unsafe = d.is_unsafe; must_free = d.must_free }
}

// (W9.4) normalize EVERY stamped generic-instance decl's body in the table, so table_generic_instances
// (which the mono pass emits as program items) carries bare stamped names. Non-`__g__` entries (the
// templates + ordinary decls) pass through unchanged here; ordinary decls are normalized as program
// ITEMS by the typer (their bodies do not live in the emitted table). (C: tk_normalize_table_instances.)
pub fn normalize_table_instances(table: TypeTable) -> TypeTable {
    mut out: TypeTable = teko::list::empty()
    mut i = 0
    loop {
        if i >= table.len { break }
        if name_is_g_instance(table[i].name) {
            let nd = normalize_inst_decl(table[i].decl, table)
            out = teko::list::push(out, TypeReg { name = table[i].name; namespace = table[i].namespace; vis = table[i].vis; decl = nd })
        } else {
            out = teko::list::push(out, table[i])
        }
        i++
    }
    out
}
