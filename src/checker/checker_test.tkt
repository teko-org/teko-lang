#test
fn iface_static_method_does_not_satisfy_instance_method() {
    // the interface wants an INSTANCE `describe(self)`; the struct provides a STATIC `describe()`.
    // A static method must NOT satisfy an instance interface method -> "missing method" error.
    let ifc = iface_item("Greetable", list1(iface_method("greet")), teko::list::empty())
    let imp = impl_struct_item("Hi", list1(impl_static_method("greet", parser::Visibility::Pub)), slist1("Greetable"))
