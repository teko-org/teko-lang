    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // static != instance -> must fail
        error => teko::assert::is_true(true)
    }
}

#test
fn iface_cyclic_extends_is_error() {
    // Acyc extends Bcyc, Bcyc extends Acyc -> a cycle. Conformance must fail GRACEFULLY (an honest
    // error), NOT recurse forever / crash the test run.
    let a = iface_item("Acyc", list1(iface_method("a")), slist1("Bcyc"))
    let b = iface_item("Bcyc", list1(iface_method("b")), slist1("Acyc"))
    let both = teko::list::push(list1(impl_method("a", parser::Visibility::Pub)), impl_method("b", parser::Visibility::Pub))
    let imp = impl_struct_item("Tcyc", both, slist1("Acyc"))
    mut items: []parser::Item = teko::list::empty()
    items = teko::list::push(items, a)
    items = teko::list::push(items, b)
    items = teko::list::push(items, imp)
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // cyclic extends -> must fail (not hang/crash)
        error => teko::assert::is_true(true)
    }
}

#test
fn iface_diamond_extends_ok() {
    // Dtop extends Bmid & Cmid; Bmid extends Abase; Cmid extends Abase. Abase is reached via TWO
    // branches — that is a DIAMOND, NOT a cycle — so a struct providing a/b/c/d must conform.
    let a = iface_item("Abase", list1(iface_method("a")), teko::list::empty())
    let b = iface_item("Bmid", list1(iface_method("b")), slist1("Abase"))
    let c = iface_item("Cmid", list1(iface_method("c")), slist1("Abase"))
    let d = iface_item("Dtop", list1(iface_method("d")), teko::list::push(slist1("Bmid"), "Cmid"))
    mut methods = list1(impl_method("a", parser::Visibility::Pub))
    methods = teko::list::push(methods, impl_method("b", parser::Visibility::Pub))
    methods = teko::list::push(methods, impl_method("c", parser::Visibility::Pub))
    methods = teko::list::push(methods, impl_method("d", parser::Visibility::Pub))
    let imp = impl_struct_item("Tdia", methods, slist1("Dtop"))
    mut items: []parser::Item = teko::list::empty()
    items = teko::list::push(items, a)
    items = teko::list::push(items, b)
    items = teko::list::push(items, c)
    items = teko::list::push(items, d)
    items = teko::list::push(items, imp)
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)   // diamond is legal -> must NOT fail
        error => teko::assert::is_true(false)
    }
}

#test
fn cls_cyclic_inheritance_is_error() {
