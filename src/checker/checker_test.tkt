// src/checker/checker_test.tkt — tests for the typer (C1). #test functions the runner collects.
// The typer is unit-tested on HAND-BUILT AST: each type_* must produce a fully typed node (happy)
// or refuse an ill-typed one (barrier). Rewritten to current Teko (the `Expr` node-wrapper C1-POS,
// all-fields struct literals, `Function`/`Arm`/`TypeDecl`/`Item` shapes) and module-qualified.

use teko::parser

// --- AST constructors (every expression is wrapped in a positioned `parser::Expr`) ---
fn ek(k: parser::ExprKind) -> parser::Expr { parser::Expr { kind = k; line = 0; col = 0 } }
fn e_num(v: i128) -> parser::Expr { ek(parser::Number { is_float = false; value = v; fval = 0.0 }) }
fn e_var(name: str) -> parser::Expr { ek(parser::Var { name = name }) }
fn e_str(t: str)    -> parser::Expr { ek(parser::StrLit { text = t }) }
fn st(e: parser::Expr) -> parser::Statement { parser::ExprStmt { expr = e } }   // an expr-statement
fn one_stmt(e: parser::Expr) -> []parser::Statement { teko::list::push(teko::list::empty(), st(e)) }
fn path1(name: str) -> parser::Path { parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) } }
fn named_t(name: str) -> parser::TypeExpr { parser::NamedType { path = path1(name); args = teko::list::empty() } }

// --- Type/env constructors ---
fn u32t()  -> Type { Prim { kind = PrimKind::U32 } }
fn u8t()   -> Type { Prim { kind = PrimKind::U8 } }
fn i64t()  -> Type { Prim { kind = PrimKind::I64 } }
fn boolt() -> Type { Prim { kind = PrimKind::Bool } }
fn empty_env()   -> Env       { Env { bindings = teko::list::empty(); cur_ns = "" } }
fn empty_table() -> TypeTable { teko::list::empty() }
fn prim_is(t: Type, k: PrimKind) -> bool { match t { Prim as p => p.kind == k; _ => false } }

#test
fn types_leaves() {
    let n = type_number(parser::Number { is_float = false; value = 5; fval = 0.0 })
    teko::assert::is_true(prim_is(n.type, PrimKind::I64))
    match n.kind { TNumber as tn => teko::assert::is_true(tn.value == 5); _ => teko::assert::is_true(false) }
    let s = type_strlit(parser::StrLit { text = "hi" })
    match s.type { Str => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    let b = type_bytelit(parser::ByteLit { value = b'A' })
    match b.type { Byte => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

#test
fn types_var_and_binary() {
    let env = define(empty_env(), "x", u32t(), false)
    let vx = match type_var(parser::Var { name = "x" }, env) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(vx.type, PrimKind::U32))
    let bin = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("x"); right = e_var("x") }
    let tb = match type_binary(bin, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tb.type, PrimKind::U32))
    match tb.kind {
        TBinary as bb => {
            teko::assert::is_true(prim_is(bb.left.type, PrimKind::U32))
            teko::assert::is_true(prim_is(bb.right.type, PrimKind::U32))
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn types_compare_and_unary() {
    let env = define(empty_env(), "x", u32t(), false)
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cmp = parser::Compare { first = e_var("x"); rest = crest }
    let tc = match type_compare(cmp, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tc.type, PrimKind::Bool))
    let un = parser::Unary { op = lexer::TokenKind::Bang; operand = ek(cmp) }   // !(x < x) — operand is bool
    let tu = match type_unary(un, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tu.type, PrimKind::Bool))
}

#test
fn types_call() {
    let env0 = define(empty_env(), "x", u32t(), false)
    let params: []Type = teko::list::push(teko::list::empty(), u32t())
    let env = define(env0, "f", Func { params = params; ret = boolt() }, false)
    let args: []parser::Expr = teko::list::push(teko::list::empty(), e_var("x"))
    let tcall = match type_call(parser::Call { callee = path1("f"); args = args }, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tcall.type, PrimKind::Bool))
    match tcall.kind { TCall as cc => teko::assert::is_true(cc.args.len == 1); _ => teko::assert::is_true(false) }
}

#test
fn types_if_value() {
    let env = define(empty_env(), "x", u32t(), false)
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cond = ek(parser::Compare { first = e_var("x"); rest = crest })
    let iff = parser::IfExpr { cond = cond; then_blk = one_stmt(e_num(1)); has_else = true; else_blk = one_stmt(e_num(2)) }
    let ti = match type_if(iff, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(ti.type, PrimKind::I64))
    match ti.kind { TIfExpr as tif => teko::assert::is_true(tif.has_else); _ => teko::assert::is_true(false) }
}

// a bare (non-binding) literal arm / wildcard arm with the given body value.
fn lit_arm(v: i128, body: i128) -> parser::Arm {
    parser::Arm { pattern = parser::LiteralPattern { value = e_num(v) }; has_when = false; guard = e_num(0); body = one_stmt(e_num(body)) }
}
fn wild_arm(body: i128) -> parser::Arm {
    parser::Arm { pattern = parser::WildcardPattern { }; has_when = false; guard = e_num(0); body = one_stmt(e_num(body)) }
}

#test
fn types_match() {
    let env = define(empty_env(), "n", i64t(), false)
    let arms: []parser::Arm = teko::list::push(teko::list::push(teko::list::empty(), lit_arm(0, 10)), wild_arm(20))
    let m = parser::MatchExpr { subject = e_var("n"); arms = arms }
    let tm = match type_match(m, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tm.type, PrimKind::I64))
    match tm.kind { TMatchExpr as tmm => teko::assert::is_true(tmm.arms.len == 2); _ => teko::assert::is_true(false) }
}

// build a `fn NAME(x: u32) -> <ret> { body }` for the function/return tests.
fn mk_fn(name: str, ret: parser::TypeExpr, body: []parser::Statement) -> parser::Function {
    let p = parser::Param { name = "x"; type_ann = named_t("u32") }
    let params = teko::list::push(teko::list::empty(), p)
    parser::Function { name = name; type_params = teko::list::empty(); params = params; has_return = true; return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = "" }
}

#test
fn types_function_and_program() {
    let f = mk_fn("id", named_t("u32"), one_stmt(e_var("x")))
    let tf = match type_function(f, empty_env(), empty_table()) { TFunction as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tf.return_type, PrimKind::U32))
    teko::assert::is_true(tf.body.len == 1)
    match tf.body[0] { TExprStmt as es => teko::assert::is_true(prim_is(es.expr.type, PrimKind::U32)); _ => teko::assert::is_true(false) }

    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = f; namespace = ""; file = "" })
    let tp = match type_program(parser::Program { items = items }) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(tp.items.len == 1)
    match tp.items[0] { TFunction as ff => teko::assert::is_true(prim_is(ff.return_type, PrimKind::U32)); _ => teko::assert::is_true(false) }
}

#test
fn rejects_ill_typed() {
    let env2 = define(define(empty_env(), "x", u32t(), false), "y", u8t(), false)
    // mixed-width arithmetic — no promotion (B.22).
    let mix = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("x"); right = e_var("y") }
    match type_binary(mix, env2, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // an undefined name has no type.
    match type_var(parser::Var { name = "z" }, empty_env()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // an `if` used as a VALUE needs an `else` (B.20).
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cond  = ek(parser::Compare { first = e_var("x"); rest = crest })
    let noelse = parser::IfExpr { cond = cond; then_blk = one_stmt(e_num(1)); has_else = false; else_blk = one_stmt(e_num(1)) }
    match type_if(noelse, env2, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // a non-exhaustive `match` (integer subject, only a literal arm, no `_`).
    let envi = define(empty_env(), "n", i64t(), false)
    let arms: []parser::Arm = teko::list::push(teko::list::empty(), lit_arm(0, 1))
    match type_match(parser::MatchExpr { subject = e_var("n"); arms = arms }, envi, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- C2 cast helpers ---
fn i8t()  -> Type { Prim { kind = PrimKind::I8 } }
fn i16t() -> Type { Prim { kind = PrimKind::I16 } }
fn i32t() -> Type { Prim { kind = PrimKind::I32 } }
fn strt() -> Type { Str { } }
fn cast_of(varname: str, target_name: str) -> parser::Cast {
    parser::Cast { expr = e_var(varname); target = named_t(target_name) }
}
fn cast_types_to(varname: str, src: Type, target_name: str, want: PrimKind) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, target_name), env, empty_table()) { TExpr as te => prim_is(te.type, want); error => false }
}
fn cast_errors(varname: str, src: Type, target_name: str) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, target_name), env, empty_table()) { TExpr => false; error => true }
}
fn cast_const_types_to(v: i64, target_name: str, want: PrimKind) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t(target_name) }
    match type_cast(c, empty_env(), empty_table()) { TExpr as te => prim_is(te.type, want); error => false }
}
fn cast_const_errors(v: i64, target_name: str) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t(target_name) }
    match type_cast(c, empty_env(), empty_table()) { TExpr => false; error => true }
}

#test
fn casts_allowed() {
    teko::assert::is_true(cast_types_to("a", i8t(),  "i32", PrimKind::I32))
    teko::assert::is_true(cast_types_to("c", i32t(), "i8",  PrimKind::I8))
    teko::assert::is_true(cast_types_to("d", i32t(), "u32", PrimKind::U32))
    teko::assert::is_true(cast_types_to("e", u32t(), "i8",  PrimKind::I8))
    teko::assert::is_true(cast_types_to("f", i32t(), "i32", PrimKind::I32))
    teko::assert::is_true(cast_const_types_to(200, "u8",  PrimKind::U8))
    teko::assert::is_true(cast_const_types_to(5,   "i8",  PrimKind::I8))
}

#test
fn casts_forbidden() {
    teko::assert::is_true(cast_errors("a", boolt(), "i32"))
    teko::assert::is_true(cast_errors("b", i32t(),  "bool"))
    teko::assert::is_true(cast_errors("c", strt(),  "i32"))
    teko::assert::is_true(cast_const_errors(300, "i8"))
    teko::assert::is_true(cast_const_errors(-1,  "u8"))
    teko::assert::is_true(cast_const_errors(5000000000, "i32"))
}

#test
fn revalidate_rederives_casts() {
    let goodinner = TExpr { kind = TVar { name = "y" }; type = i32t(); line = 0; col = 0 }
    let good = TExpr { kind = TCast { expr = goodinner }; type = i8t(); line = 0; col = 0 }
    match validate_texpr(good) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let badinner = TExpr { kind = TVar { name = "s" }; type = strt(); line = 0; col = 0 }
    let bad = TExpr { kind = TCast { expr = badinner }; type = i32t(); line = 0; col = 0 }
    match validate_texpr(bad) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- byte↔int cast helpers (byte casts AS u8 — B.36) ---
fn bytet() -> Type { Byte { } }
fn cast_types_to_byte(varname: str, src: Type) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, "byte"), env, empty_table()) { TExpr as te => type_eq(te.type, Byte { }); error => false }
}
fn cast_const_types_to_byte(v: i64) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t("byte") }
    match type_cast(c, empty_env(), empty_table()) { TExpr as te => type_eq(te.type, Byte { }); error => false }
}

#test
fn byte_int_casts_allowed() {
    teko::assert::is_true(cast_types_to("a", bytet(), "u32", PrimKind::U32))
    teko::assert::is_true(cast_types_to("b", bytet(), "u8",  PrimKind::U8))
    teko::assert::is_true(cast_types_to("c", bytet(), "i64", PrimKind::I64))
    teko::assert::is_true(cast_types_to_byte("d", u8t()))
    teko::assert::is_true(cast_types_to_byte("e", u32t()))
    teko::assert::is_true(cast_const_types_to_byte(200))
}

#test
fn byte_int_casts_forbidden() {
    teko::assert::is_true(cast_const_errors(300, "byte"))
    teko::assert::is_true(cast_const_errors(-1,  "byte"))
    teko::assert::is_true(cast_errors("a", boolt(), "byte"))
    teko::assert::is_true(cast_errors("b", bytet(), "bool"))
    teko::assert::is_true(cast_errors("c", bytet(), "str"))
}

#test
fn revalidate_rederives_byte_casts() {
    let gi  = TExpr { kind = TVar { name = "b" }; type = bytet(); line = 0; col = 0 }
    let g   = TExpr { kind = TCast { expr = gi }; type = u32t(); line = 0; col = 0 }
    match validate_texpr(g) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let gi2 = TExpr { kind = TVar { name = "x" }; type = u8t(); line = 0; col = 0 }
    let g2  = TExpr { kind = TCast { expr = gi2 }; type = bytet(); line = 0; col = 0 }
    match validate_texpr(g2) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let bi  = TExpr { kind = TVar { name = "b" }; type = bytet(); line = 0; col = 0 }
    let bad = TExpr { kind = TCast { expr = bi }; type = boolt(); line = 0; col = 0 }
    match validate_texpr(bad) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- C3 field-access: a TypeTable with one struct `Foo { token: u8 }` ---
fn foo_decl() -> parser::TypeDecl {
    let fld = parser::Field { name = "token"; type_ann = named_t("u8") }
    let fields = teko::list::push(teko::list::empty(), fld)
    parser::TypeDecl { name = "Foo"; type_params = teko::list::empty(); body = parser::StructBody { fields = fields }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
}
fn foo_table() -> TypeTable {
    teko::list::push(teko::list::empty(), TypeReg { name = "Foo"; namespace = ""; vis = parser::Visibility::Private; decl = foo_decl() })
}
fn foo_env() -> Env { define(empty_env(), "s", Named { name = "Foo" }, false) }

#test
fn field_read_types_to_field_type() {
    let fa = parser::FieldAccess { receiver = e_var("s"); field = "token" }
    match type_field_access(fa, foo_env(), foo_table()) { TExpr as te => teko::assert::is_true(prim_is(te.type, PrimKind::U8)); error => teko::assert::is_true(false) }
}

#test
fn field_not_found_errors() {
    let fa = parser::FieldAccess { receiver = e_var("s"); field = "nope" }
    match type_field_access(fa, foo_env(), foo_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn field_on_non_struct_errors() {
    let env = define(empty_env(), "n", Prim { kind = PrimKind::I32 }, false)
    let fa = parser::FieldAccess { receiver = e_var("n"); field = "token" }
    match type_field_access(fa, env, foo_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn revalidate_rederives_field_access() {
    let recv = TExpr { kind = TVar { name = "s" }; type = Named { name = "Foo" }; line = 0; col = 0 }
    let good = TExpr { kind = TFieldAccess { receiver = recv; field = "token" }; type = Prim { kind = PrimKind::U8 }; line = 0; col = 0 }
    match validate_texpr(good) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let badrecv = TExpr { kind = TVar { name = "n" }; type = Prim { kind = PrimKind::I32 }; line = 0; col = 0 }
    let bad = TExpr { kind = TFieldAccess { receiver = badrecv; field = "token" }; type = Prim { kind = PrimKind::U8 }; line = 0; col = 0 }
    match validate_texpr(bad) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn mut_rule_assign() {
    let menv = define(empty_env(), "m", u32t(), true)
    let ok = parser::Assign { name = "m"; op = lexer::TokenKind::Assign; value = e_var("m") }
    match type_assign(ok, menv, empty_table()) { TypedStmt => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let lenv = define(empty_env(), "l", u32t(), false)
    let bad = parser::Assign { name = "l"; op = lexer::TokenKind::Assign; value = e_var("l") }
    match type_assign(bad, lenv, empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

fn binding_of(name: str, ann: str, value: parser::Expr) -> parser::Binding {
    parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; has_type = true; type_ann = named_t(ann); value = value }
}

#test
fn annotated_literal() {
    let b = binding_of("x", "u8", e_num(1))
    match type_binding(b, empty_env(), empty_table()) {
        TypedStmt as ts => match ts.node {
            TBinding as tb => {
                teko::assert::is_true(prim_is(tb.bound, PrimKind::U8))
                teko::assert::is_true(prim_is(tb.value.type, PrimKind::I64))
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
    let b2 = binding_of("y", "u8", e_num(999))
    match type_binding(b2, empty_env(), empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let env = define(empty_env(), "w", i32t(), false)
    let b3 = binding_of("z", "u8", e_var("w"))
    match type_binding(b3, env, empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn return_type_checks() {
    let body1 = one_stmt(e_var("x"))
    match type_function(mk_fn("f", named_t("u32"), body1), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let body2: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_var("x") })
    match type_function(mk_fn("f", named_t("u32"), body2), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let loopbody: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_var("x") })
    let body3: []parser::Statement = teko::list::push(teko::list::empty(), parser::LoopStmt { label = ""; body = loopbody })
    match type_function(mk_fn("f", named_t("u32"), body3), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let umembers: []parser::TypeExpr = teko::list::push(teko::list::push(teko::list::empty(), named_t("u32")), named_t("error"))
    let body4: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_var("x") })
    match type_function(mk_fn("f", parser::UnionType { members = umembers }, body4), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

#test
fn return_type_mismatch_errors() {
    let body1 = one_stmt(e_var("x"))
    match type_function(mk_fn("f", named_t("u8"), body1), empty_env(), empty_table()) { TFunction => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let body2: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_var("x") })
    match type_function(mk_fn("f", named_t("u8"), body2), empty_env(), empty_table()) { TFunction => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- C7: pattern checking + exhaustiveness over a variant Color = RED | GREEN | BLUE ---
fn color_subject() -> Type {
    mut members: []Type = teko::list::empty()
    members = teko::list::push(members, Named { name = "RED" })
    members = teko::list::push(members, Named { name = "GREEN" })
    members = teko::list::push(members, Named { name = "BLUE" })
    Variant { members = members }
}
fn color_table() -> TypeTable {
    mut t: TypeTable = teko::list::empty()
    mut i = 0
    let names = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RED"), "GREEN"), "BLUE")
    loop {
        if i >= names.len { break }
        let td = parser::TypeDecl { name = names[i]; type_params = teko::list::empty(); body = parser::StructBody { fields = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
        t = teko::list::push(t, TypeReg { name = names[i]; namespace = ""; vis = parser::Visibility::Private; decl = td })
        i++
    }
    t
}
fn case_pat(name: str) -> parser::Pattern { parser::BindPattern { type_name = path1(name); has_binding = false; binding = ""; is_slice = false; slice_type = null } }
fn arm_of(p: parser::Pattern) -> parser::Arm { parser::Arm { pattern = p; has_when = false; guard = e_num(0); body = one_stmt(e_num(0)) } }
fn guarded_arm_of(p: parser::Pattern) -> parser::Arm { parser::Arm { pattern = p; has_when = true; guard = ek(parser::BoolLit { value = true }); body = one_stmt(e_num(0)) } }

#test
fn field_pattern_binds_fields() {
    let fp = parser::FieldPattern { type_name = path1("Foo"); fields = teko::list::push(teko::list::empty(), "token") }
    let e2 = match check_pattern(fp, Named { name = "Foo" }, foo_env(), foo_table()) { Env as e => e; error => { teko::assert::is_true(false); return } }
    match lookup(e2, "token") { Type as t => teko::assert::is_true(prim_is(t, PrimKind::U8)); error => teko::assert::is_true(false) }
}

#test
fn field_pattern_barriers() {
    let badfield = parser::FieldPattern { type_name = path1("Foo"); fields = teko::list::push(teko::list::empty(), "nope") }
    match check_pattern(badfield, Named { name = "Foo" }, foo_env(), foo_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let prim = parser::FieldPattern { type_name = path1("u8"); fields = teko::list::empty() }
    match check_pattern(prim, Named { name = "Foo" }, foo_env(), foo_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn range_pattern_check() {
    let env = define(empty_env(), "n", i64t(), false)
    let rp = parser::RangePattern { lo = e_num(0); hi = e_num(9) }
    match check_pattern(rp, i64t(), env, empty_table()) { Env => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let rpb = parser::RangePattern { lo = e_num(0); hi = e_num(1) }
    match check_pattern(rpb, boolt(), env, empty_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let rps = parser::RangePattern { lo = e_str("a"); hi = e_num(9) }
    match check_pattern(rps, i64t(), env, empty_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn alt_pattern_check() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    let alt = parser::AltPattern { options = opts }
    match check_pattern(alt, color_subject(), empty_env(), color_table()) { Env => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    mut bopts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    bopts = teko::list::push(bopts, parser::BindPattern { type_name = path1("GREEN"); has_binding = true; binding = "g"; is_slice = false; slice_type = null })
    let balt = parser::AltPattern { options = bopts }
    match check_pattern(balt, color_subject(), empty_env(), color_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn exhaustive_with_alt() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    mut arms: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(parser::AltPattern { options = opts }))
    arms = teko::list::push(arms, arm_of(case_pat("BLUE")))
    teko::assert::is_true(exhaustive(arms, color_subject(), color_table()))
}

#test
fn exhaustive_barriers() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    let arms1: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(parser::AltPattern { options = opts }))
    teko::assert::is_false(exhaustive(arms1, color_subject(), color_table()))
    mut arms2: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(case_pat("RED")))
    arms2 = teko::list::push(arms2, arm_of(case_pat("GREEN")))
    arms2 = teko::list::push(arms2, guarded_arm_of(case_pat("BLUE")))
    teko::assert::is_false(exhaustive(arms2, color_subject(), color_table()))
    let arms3: []parser::Arm = teko::list::push(teko::list::empty(), guarded_arm_of(parser::WildcardPattern { }))
    teko::assert::is_false(exhaustive(arms3, color_subject(), color_table()))
}

// ---------------------------------------------------------------------------
// Helpers for extended coverage tests
// ---------------------------------------------------------------------------
fn color_enum_decl() -> parser::TypeDecl {
    let members = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RED"), "GREEN"), "BLUE")
    parser::TypeDecl { name = "Color"; type_params = teko::list::empty(); body = parser::EnumBody { members = members }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
}
fn color_enum_table() -> TypeTable {
    teko::list::push(teko::list::empty(), TypeReg { name = "Color"; namespace = ""; vis = parser::Visibility::Private; decl = color_enum_decl() })
}

// ---------------------------------------------------------------------------
// Group A: numeric predicates + type utilities
// ---------------------------------------------------------------------------
#test
fn checker_basic_predicates() {
    let _ = i16t()   // cover the unused i16t() helper
    // is_float
    teko::assert::is_true(is_float(Prim { kind = PrimKind::F64 }))
    teko::assert::is_true(is_float(Prim { kind = PrimKind::F32 }))
    teko::assert::is_false(is_float(Prim { kind = PrimKind::I64 }))
    // op_is_arith_bitwise  (%, &, |, ^)
    teko::assert::is_true(op_is_arith_bitwise(lexer::TokenKind::Percent))
    teko::assert::is_true(op_is_arith_bitwise(lexer::TokenKind::Amp))
    teko::assert::is_false(op_is_arith_bitwise(lexer::TokenKind::Plus))
    // prim_width
    teko::assert::is_true(prim_width(PrimKind::I32) == 32)
    teko::assert::is_true(prim_width(PrimKind::U64) == 64)
    teko::assert::is_true(prim_width(PrimKind::I8) == 8)
    // types_eq
    let ts1: []Type = teko::list::push(teko::list::empty(), i64t())
    let ts2: []Type = teko::list::push(teko::list::empty(), i64t())
    let ts3: []Type = teko::list::push(teko::list::empty(), u32t())
    teko::assert::is_true(types_eq(teko::list::empty(), teko::list::empty()))
    teko::assert::is_true(types_eq(ts1, ts2))
    teko::assert::is_false(types_eq(ts1, ts3))
    // float_fits
    teko::assert::is_true(float_fits(3.14, PrimKind::F64))
    teko::assert::is_true(float_fits(1.0, PrimKind::F32))
    teko::assert::is_false(float_fits(1.0, PrimKind::I64))
}

// ---------------------------------------------------------------------------
// Group B: type_boollit / type_nulllit
// ---------------------------------------------------------------------------
#test
fn checker_boollit_nulllit() {
    let bt = type_boollit(parser::BoolLit { value = true })
    match bt.type { Prim as p => teko::assert::is_true(p.kind == PrimKind::Bool); _ => teko::assert::is_true(false) }
    match bt.kind { TBoolLit as b => teko::assert::is_true(b.value); _ => teko::assert::is_true(false) }
    let bf = type_boollit(parser::BoolLit { value = false })
    match bf.kind { TBoolLit as b => teko::assert::is_false(b.value); _ => teko::assert::is_true(false) }
    let nl = match type_nulllit(parser::NullLit { }) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match nl.type { Optional as o => match o.inner { Void => teko::assert::is_true(true); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group C: enum_has_member, check_enum_pattern, enum_covered, some_arm_is_null,
//          some_arm_covers_type (via exhaustive on a non-Named variant), present_case_covered
// ---------------------------------------------------------------------------
#test
fn checker_enum_and_optional_patterns() {
    let eb = parser::EnumBody { members = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RED"), "GREEN"), "BLUE") }
    // enum_has_member
    teko::assert::is_true(enum_has_member(eb, "RED"))
    teko::assert::is_false(enum_has_member(eb, "YELLOW"))
    // some_arm_is_null
    let null_arm = parser::Arm { pattern = parser::NullPattern { }; has_when = false; guard = e_num(0); body = one_stmt(e_num(0)) }
    let with_null: []parser::Arm = teko::list::push(teko::list::empty(), null_arm)
    teko::assert::is_true(some_arm_is_null(with_null))
    let no_null: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(parser::WildcardPattern { }))
    teko::assert::is_false(some_arm_is_null(no_null))
    // check_enum_pattern — wildcard matches any enum member
    match check_enum_pattern(parser::WildcardPattern { }, Named { name = "Color" }, eb, empty_env(), empty_table()) {
        Env => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
    // enum_covered — all three covered vs partial
    let ra = arm_of(case_pat("RED"))
    let ga = arm_of(case_pat("GREEN"))
    let ba = arm_of(case_pat("BLUE"))
    mut all3: []parser::Arm = teko::list::push(teko::list::empty(), ra)
    all3 = teko::list::push(all3, ga)
    all3 = teko::list::push(all3, ba)
    teko::assert::is_true(enum_covered(all3, eb))
    teko::assert::is_false(enum_covered(teko::list::push(teko::list::empty(), ra), eb))
    // some_arm_covers_type (called by variant_covered for non-Named members)
    // build a Variant with prim members: i64 | error
    let m1: []Type = teko::list::push(teko::list::empty(), i64t())
    let m2: []Type = teko::list::push(m1, Error { })
    let ie_var = Variant { members = m2 }
    let i64_pat = parser::BindPattern { type_name = path1("i64"); has_binding = true; binding = "n"; is_slice = false; slice_type = null }
    let err_pat = parser::BindPattern { type_name = path1("error"); has_binding = true; binding = "e"; is_slice = false; slice_type = null }
    mut ie_arms: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(i64_pat))
    ie_arms = teko::list::push(ie_arms, arm_of(err_pat))
    teko::assert::is_true(exhaustive(ie_arms, ie_var, empty_table()))
    // present_case_covered (called by exhaustive for Optional subject)
    let opt_i64 = Optional { inner = i64t() }
    let bind_arm = arm_of(parser::BindPattern { type_name = path1("i64"); has_binding = true; binding = "v"; is_slice = false; slice_type = null })
    mut opt_arms: []parser::Arm = teko::list::push(teko::list::empty(), null_arm)
    opt_arms = teko::list::push(opt_arms, bind_arm)
    teko::assert::is_true(exhaustive(opt_arms, opt_i64, empty_table()))
}

// ---------------------------------------------------------------------------
// Group D: type_array_lit, type_index, type_interp, type_in
// ---------------------------------------------------------------------------
#test
fn checker_array_index_interp_in() {
    // type_array_lit [1, 2] → []i64
    let ae1 = parser::ArrayElem { is_spread = false; expr = e_num(1) }
    let ae2 = parser::ArrayElem { is_spread = false; expr = e_num(2) }
    let arr = parser::ArrayLit { elements = teko::list::push(teko::list::push(teko::list::empty(), ae1), ae2) }
    let ae = match type_array_lit(arr, empty_env(), empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match ae.type { Slice as s => match s.element { Prim as p => teko::assert::is_true(p.kind == PrimKind::I64); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    // empty [] → []Void sentinel
    let arr0 = parser::ArrayLit { elements = teko::list::empty() }
    let ae0 = match type_array_lit(arr0, empty_env(), empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match ae0.type { Slice as s => match s.element { Void => teko::assert::is_true(true); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    // type_index — str[0] → byte
    let str_env = define(empty_env(), "s", Str { }, false)
    let ix = parser::Index { receiver = e_var("s"); index = e_num(0) }
    let ie2 = match type_index(ix, str_env, empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match ie2.type { Byte => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    // type_interp — $"val {n}" with n: i64 → str
    let int_env = define(empty_env(), "n", i64t(), false)
    let pieces: []str = teko::list::push(teko::list::push(teko::list::empty(), "val "), "")
    let holes: []parser::Expr = teko::list::push(teko::list::empty(), e_var("n"))
    let interp = parser::Interp { pieces = pieces; holes = holes }
    let interpe = match type_interp(interp, int_env, empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match interpe.type { Str => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    // type_in — n in [1, 2] → bool
    let elems: []parser::Expr = teko::list::push(teko::list::push(teko::list::empty(), e_num(1)), e_num(2))
    let in_expr = parser::InExpr { lhs = e_var("n"); elems = elems }
    let ine = match type_in(in_expr, int_env, empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match ine.type { Prim as p => teko::assert::is_true(p.kind == PrimKind::Bool); _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group E: type_struct_lit (error literal — simplest case)
// ---------------------------------------------------------------------------
#test
fn checker_struct_lit_error_builtin() {
    let fn_names: []str = teko::list::push(teko::list::empty(), "message")
    let fn_vals: []parser::Expr = teko::list::push(teko::list::empty(), e_str("oops"))
    let sl = parser::StructLit { type_path = path1("error"); field_names = fn_names; field_vals = fn_vals }
    let sr = match type_struct_lit(sl, empty_env(), empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match sr.type { Error => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group F: type_if_stmt, type_match_stmt
// ---------------------------------------------------------------------------
#test
fn checker_if_match_stmt_forms() {
    // type_if_stmt — if b { 1 } (no else) → void
    let benv = define(empty_env(), "b", boolt(), false)
    let if_ast = parser::IfExpr { cond = e_var("b"); then_blk = one_stmt(e_num(1)); has_else = false; else_blk = teko::list::empty() }
    let ife = match type_if_stmt(if_ast, benv, empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match ife.type { Void => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    // type_match_stmt — exhaustive match over color variant → void
    let c_env = define(empty_env(), "c", color_subject(), false)
    let ra = arm_of(case_pat("RED"))
    let ga = arm_of(case_pat("GREEN"))
    let ba = arm_of(case_pat("BLUE"))
    mut match_arms: []parser::Arm = teko::list::push(teko::list::empty(), ra)
    match_arms = teko::list::push(match_arms, ga)
    match_arms = teko::list::push(match_arms, ba)
    let me = parser::MatchExpr { subject = e_var("c"); arms = match_arms }
    let mer = match type_match_stmt(me, c_env, color_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match mer.type { Void => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group G: type_path_expr (enum PathExpr)
// ---------------------------------------------------------------------------
#test
fn checker_type_path_expr() {
    let ct = color_enum_table()
    let segs: []parser::Segment = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "Color" }), parser::Segment { name = "RED" })
    let pe = parser::PathExpr { path = parser::Path { segments = segs } }
    let per = match type_path_expr(pe, ct) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match per.type { Named as n => teko::assert::is_true(n.name == "Color"); _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group H: type_safe_field_access, type_coalesce
// ---------------------------------------------------------------------------
#test
fn checker_safe_field_and_coalesce() {
    // type_safe_field_access — ms?.token where ms: Foo? → u8?
    let opt_foo_env = define(empty_env(), "ms", Optional { inner = Named { name = "Foo" } }, false)
    let sfa = parser::SafeFieldAccess { receiver = e_var("ms"); field = "token" }
    let sfar = match type_safe_field_access(sfa, opt_foo_env, foo_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match sfar.type { Optional as o => match o.inner { Prim as p => teko::assert::is_true(p.kind == PrimKind::U8); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    // type_coalesce — os ?? "default" where os: str? → str
    let opt_str_env = define(empty_env(), "os", Optional { inner = Str { } }, false)
    let co = parser::Coalesce { left = e_var("os"); right = e_str("default") }
    let cor = match type_coalesce(co, opt_str_env, empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match cor.type { Str => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group I: render_func, render_members, union_collect
// ---------------------------------------------------------------------------
#test
fn checker_render_and_join() {
    // render_members directly — two-member variant renders with " | "
    let m1: []Type = teko::list::push(teko::list::empty(), i64t())
    let m2: []Type = teko::list::push(m1, Str { })
    let rms = render_members(m2)
    teko::assert::is_true(teko::str::contains(rms, "|"))
    // render_func directly — "(i64) -> str"
    let fparams: []Type = teko::list::push(teko::list::empty(), i64t())
    let rf = render_func(Func { params = fparams; ret = Str { } })
    teko::assert::is_true(teko::str::contains(rf, "->"))
    // union_collect directly — accumulate two types
    let acc1 = union_collect(teko::list::empty(), i64t(), empty_table())
    teko::assert::is_true(acc1.len == 1)
    let acc2 = union_collect(acc1, Str { }, empty_table())
    teko::assert::is_true(acc2.len == 2)
    // dedup: same type twice → still length 1
    let acc3 = union_collect(teko::list::empty(), i64t(), empty_table())
    let acc4 = union_collect(acc3, i64t(), empty_table())
    teko::assert::is_true(acc4.len == 1)
}

// ---------------------------------------------------------------------------
// Group J: lbl_eq, lbl_enclosing, surface_at
// ---------------------------------------------------------------------------
#test
fn checker_label_surface() {
    // lbl_eq
    teko::assert::is_true(lbl_eq("outer", "outer"))
    teko::assert::is_false(lbl_eq("outer", "inner"))
    // lbl_enclosing
    let scope: []str = teko::list::push(teko::list::push(teko::list::empty(), "outer"), "inner")
    teko::assert::is_true(lbl_enclosing(scope, "outer"))
    teko::assert::is_true(lbl_enclosing(scope, "inner"))
    teko::assert::is_false(lbl_enclosing(scope, "missing"))
    // surface_at
    let e = error { message = "test error" }
    let surfaced = surface_at("test.tks", 3, 7, e)
    teko::assert::is_true(teko::str::contains(surfaced.message, "test.tks"))
}

// ---------------------------------------------------------------------------
// Group K: check_node_type, rederive_binary, validate_each (revalidate helpers)
// ---------------------------------------------------------------------------
#test
fn checker_revalidate_helpers() {
    // check_node_type — match/mismatch
    match check_node_type(i64t(), i64t()) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match check_node_type(i64t(), u32t()) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // rederive_binary
    match rederive_binary(i64t(), i64t(), lexer::TokenKind::Plus) { Type as t => teko::assert::is_true(type_eq(t, i64t())); error => teko::assert::is_true(false) }
    match rederive_binary(i64t(), i64t(), lexer::TokenKind::Percent) { Type as t => teko::assert::is_true(type_eq(t, i64t())); error => teko::assert::is_true(false) }
    match rederive_binary(boolt(), boolt(), lexer::TokenKind::Plus) { Type => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // validate_each — list of valid TNumber nodes
    let e1 = TExpr { kind = TNumber { is_float = false; value = 1; fval = 0.0 }; type = i64t(); line = 0; col = 0 }
    let e2 = TExpr { kind = TNumber { is_float = false; value = 2; fval = 0.0 }; type = i64t(); line = 0; col = 0 }
    let xs: []TExpr = teko::list::push(teko::list::push(teko::list::empty(), e1), e2)
    match validate_each(xs) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group L: ns_last_seg, builtin_fn, find_in_ns, name_exists_anywhere,
//          alias_target, diag_at, join_n
// ---------------------------------------------------------------------------
#test
fn checker_scope_module_helpers() {
    // ns_last_seg
    teko::assert::is_true(ns_last_seg("teko::checker") == "checker")
    teko::assert::is_true(ns_last_seg("foo") == "foo")
    teko::assert::is_true(ns_last_seg("a::b::c") == "c")
    // builtin_fn — "slice" → a Func type (str::slice seed retained); unknown → error
    match builtin_fn("slice") { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("__nonexistent__") { Type => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // find_in_ns
    let t = foo_table()
    match find_in_ns(t, "Foo", "") { TypeReg as tr => teko::assert::is_true(tr.name == "Foo"); null => teko::assert::is_true(false) }
    match find_in_ns(t, "Bar", "") { TypeReg => teko::assert::is_true(false); null => teko::assert::is_true(true) }
    // name_exists_anywhere
    teko::assert::is_true(name_exists_anywhere(t, "Foo"))
    teko::assert::is_false(name_exists_anywhere(t, "Baz"))
    // alias_target
    let al: []AliasBind = teko::list::push(teko::list::empty(), AliasBind { ns = "teko::checker"; alias = "prs"; target = "teko::parser" })
    teko::assert::is_true(alias_target(al, "teko::checker", "prs") == "teko::parser")
    teko::assert::is_true(alias_target(al, "teko::checker", "nope") == "")
    // diag_at
    let m1 = diag_at("foo.tks", 3, 5, "err here")
    teko::assert::is_true(teko::str::contains(m1, "foo.tks"))
    teko::assert::is_true(teko::str::contains(m1, "err here"))
    teko::assert::is_true(diag_at("", 0, 0, "bare") == "bare")
    // join_n
    let segs: []parser::Segment = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "teko" }), parser::Segment { name = "checker" })
    let p = parser::Path { segments = segs }
    teko::assert::is_true(join_n(p, 0) == "")
    teko::assert::is_true(join_n(p, 1) == "teko")
    teko::assert::is_true(join_n(p, 2) == "teko::checker")
}

// (S4) generics inference primitives — subst_type / unify / collect_sig_type_params.
#test
fn subst_unify_inference() {
    let tbl: TypeTable = teko::list::empty()
    let params: []str = teko::list::push(teko::list::empty(), "T")
    let s0 = Subst { params = params; names = teko::list::empty(); types = teko::list::empty() }
    let patT: Type = Named { name = "T" }

    // unify Named{T} ~ i64 binds T=i64; subst_type then yields i64.
    let s1 = match unify(patT, i64t(), s0, tbl) { Subst as x => x; error => s0 }
    teko::assert::is_true(prim_is(subst_type(patT, s1), PrimKind::I64))
    // a non-type-param Named passes through subst unchanged.
    teko::assert::is_true(match subst_type(Named { name = "Other" }, s1) { Named as n => n.name == "Other"; _ => false })

    // unify []T ~ []str binds T=str; subst []T → []str (structural recursion).
    let patSlice: Type = Slice { element = Named { name = "T" } }
    let s2 = match unify(patSlice, Slice { element = Str { } }, s0, tbl) { Subst as x => x; error => s0 }
    teko::assert::is_true(match subst_type(patSlice, s2) { Slice as sl => match sl.element { Str => true; _ => false }; _ => false })

    // a Void-sentinel arg (empty()/null) cannot pin a type-param → unify errors.
    teko::assert::is_true(match unify(patSlice, Slice { element = Void { } }, s0, tbl) { Subst => false; error => true })

    // collect_sig_type_params over Func{(T) -> T} → ["T"] (deduped).
    let sig: Type = Func { params = teko::list::push(teko::list::empty(), Named { name = "T" }); ret = Named { name = "T" } }
    let tps = collect_sig_type_params(sig, tbl, teko::list::empty())
    teko::assert::is_true(tps.len == 1)
    teko::assert::is_true(tps[0] == "T")
}

// (S4 type-generics) a single-segment NamedType type-expr with no args.
fn ttype_named(name: str) -> parser::TypeExpr {
    parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }; args = teko::list::empty() }
}
// a table with one GENERIC struct decl: `type Box<T> = struct { value: T }`.
fn box_generic_table() -> TypeTable {
    let fld = parser::Field { name = "value"; type_ann = ttype_named("T") }
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld) }
    let decl = parser::TypeDecl { name = "Box"; type_params = teko::list::push(teko::list::empty(), "T"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    teko::list::push(teko::list::empty(), TypeReg { name = "Box"; namespace = ""; vis = parser::Visibility::Private; decl = decl })
}

// (S4 type-generics) resolve_type on `Box<i64>` → Named{Box__g__i64}; arity is validated; the
// mangle helpers produce the shared instance name.
#test
fn resolves_generic_type_instantiation() {
    let tbl = box_generic_table()
    // Box<i64> → Named{"Box__g__i64"}
    let one = teko::list::push(teko::list::empty(), ttype_named("i64"))
    let inst = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = one }
    teko::assert::is_true(match resolve_type(inst, tbl) { Named as n => n.name == "Box__g__i64"; error => false; _ => false })

    // wrong arity Box<i64, str> → error
    mut two: []parser::TypeExpr = teko::list::push(teko::list::empty(), ttype_named("i64"))
    two = teko::list::push(two, ttype_named("str"))
    let inst2 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = two }
    teko::assert::is_true(match resolve_type(inst2, tbl) { error => true; _ => false })

    // a plain `Box` (no args) still resolves nominally — no regression.
    teko::assert::is_true(match resolve_type(ttype_named("Box"), tbl) { Named as n => n.name == "Box"; error => false; _ => false })

    // generic_inst_name / type_mangle directly: Box + [i64, str] → "Box__g__i64__str".
    mut at: []Type = teko::list::push(teko::list::empty(), i64t())
    at = teko::list::push(at, Str { })
    teko::assert::is_true(generic_inst_name("Box", at) == "Box__g__i64__str")
}

// ---------------------------------------------------------------------------
// Group K: monomorphize (S4b crumb 2c) — direct VM coverage of the mono walk.
// Build typed programs by hand (a generic TFunction template + non-generic callers /
// virtual-main statements), call monomorphize, and assert the generic is DROPPED and a
// stamped concrete copy (idg__g__<arg>) appears with the right return type. The generic
// bodies + caller bodies span varied TExprKind / TStatement cases so the total walk and
// both driver phases (seed collection + fixpoint stamping) execute on the VM.
// ---------------------------------------------------------------------------

// a typed VAR expr of a given type.
fn tvar(name: str, t: Type) -> TExpr { TExpr { kind = TVar { name = name }; type = t; line = 0; col = 0 } }
// a typed integer literal (i64).
fn tnum(v: i128) -> TExpr { TExpr { kind = TNumber { is_float = false; value = v; fval = 0.0 }; type = i64t(); line = 0; col = 0 } }
// a generic TFunction `fn NAME<T>(x: PARAMSPELL) -> RET { body }`.
fn gfn(name: str, param_ann: parser::TypeExpr, ret: Type, body: []TStatement) -> TFunction {
    let tps: []str = teko::list::push(teko::list::empty(), "T")
    let p = parser::Param { name = "x"; type_ann = param_ann }
    let params = teko::list::push(teko::list::empty(), p)
    TFunction { name = name; type_params = tps; params = params; return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}
// a non-generic TFunction with a hand-built body.
fn plainfn(name: str, ret: Type, body: []TStatement) -> TFunction {
    TFunction { name = name; type_params = teko::list::empty(); params = teko::list::empty(); return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}
// a typed call `NAME(arg)` with result type `rt`.
fn tcall1(name: str, arg: TExpr, rt: Type) -> TExpr {
    let callee = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }
    let args = teko::list::push(teko::list::empty(), arg)
    TExpr { kind = TCall { callee = callee; args = args; call_ns = "" }; type = rt; line = 0; col = 0 }
}
fn texpr_stmt(e: TExpr) -> TStatement { TExprStmt { expr = e } }
fn treturn(e: TExpr) -> TStatement { TReturn { has_value = true; value = e } }
// find a stamped fn (mangled name) in a typed program's items.
fn find_titem_fn(prog: TProgram, name: str) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if teko::runtime::str_eq(f.name, name) { return true } }; _ => {} }
        i++
    }
    false
}
// is there a stamped instance of `bare` (a fn whose name contains "<bare>__g__")? VM-robust:
// it checks the synthetic `__g__` infix, not the full type-arg spelling.
fn has_stamped_instance(prog: TProgram, bare: str) -> bool {
    let needle = teko::str::concat(bare, "__g__")
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if teko::str::contains(f.name, needle) { return true } }; _ => {} }
        i++
    }
    false
}
fn count_generic_fns(prog: TProgram) -> u64 {
    mut n: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if f.type_params.len > 0 { n++ } }; _ => {} }
        i++
    }
    n
}

#test
fn mono_noop_when_no_generics() {
    // a program with NO generic fn passes through unchanged (the no-op guard).
    let body = teko::list::push(teko::list::empty(), treturn(tnum(1)))
    let f = plainfn("plain", i64t(), body)
    let items: []TItem = teko::list::push(teko::list::empty(), f)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(mp.items.len == 1)
    teko::assert::is_true(count_generic_fns(mp) == 0)
}

#test
fn mono_stamps_two_instances() {
    // fn idg<T>(x: T) -> T { return x } + two callers (i64 + str). After mono: the generic is
    // DROPPED and idg__g__i64 / idg__g__str are stamped; the callers' callees are rewritten.
    let gbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, gbody)
    // a non-generic caller calling idg(7) [i64] and idg("hi") [str] as virtual-main statements.
    let call_i = texpr_stmt(tcall1("idg", tnum(7), i64t()))
    let call_s = texpr_stmt(tcall1("idg", TExpr { kind = TStrLit { text = "hi" }; type = strt(); line = 0; col = 0 }, strt()))
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, call_i)
    items = teko::list::push(items, call_s)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    // generic dropped; both instances stamped.
    teko::assert::is_true(count_generic_fns(mp) == 0)
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "idg__g__str"))
    // a stamped fn's return type is concrete.
    mut found_i64_ret = false
    mut i = 0
    loop {
        if i >= mp.items.len { break }
        match mp.items[i] { TFunction as f => { if teko::runtime::str_eq(f.name, "idg__g__i64") { found_i64_ret = prim_is(f.return_type, PrimKind::I64) } }; _ => {} }
        i++
    }
    teko::assert::is_true(found_i64_ret)
}

#test
fn mono_transitive_fixpoint() {
    // fn idg<T>(x: T) -> T { return x } ; fn wrapg<T>(x: T) -> T { return idg(x) } ; caller wrapg(9)
    // → stamping wrapg__g__i64 discovers idg__g__i64 (the Phase-2 fixpoint), which is then stamped.
    let idgbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, idgbody)
    // wrapg body: return idg(x)  — the inner call's arg is `x: T` (opaque), result T.
    let inner_call = tcall1("idg", tvar("x", Named { name = "T" }), Named { name = "T" })
    let wrapbody = teko::list::push(teko::list::empty(), treturn(inner_call))
    let wrapg = gfn("wrapg", named_t("T"), Named { name = "T" }, wrapbody)
    let caller = texpr_stmt(tcall1("wrapg", tnum(9), i64t()))
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, wrapg)
    items = teko::list::push(items, caller)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(count_generic_fns(mp) == 0)
    teko::assert::is_true(find_titem_fn(mp, "wrapg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))   // discovered transitively
}

#test
fn mono_slice_and_optional_mangle() {
    // fn firstg<T>(xs: []T) -> T { return xs[0] } called with []i64 → firstg__g__i64 (slice unify
    // in the PARAM pattern: unify([]T, []i64) binds T=i64). The instance name has a plain i64 arg.
    let idx = TExpr { kind = TIndex { receiver = tvar("xs", Slice { element = Named { name = "T" } }); index = tnum(0) }; type = Named { name = "T" }; line = 0; col = 0 }
    let fbody = teko::list::push(teko::list::empty(), treturn(idx))
    let firstg = gfn("firstg", parser::SliceType { element = named_t("T") }, Named { name = "T" }, fbody)
    let arg = tvar("v", Slice { element = i64t() })
    let caller = texpr_stmt(tcall1("firstg", arg, i64t()))
    mut items: []TItem = teko::list::push(teko::list::empty(), firstg)
    items = teko::list::push(items, caller)
    let mp = match monomorphize(TProgram { items = items }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(find_titem_fn(mp, "firstg__g__i64"))

    // a Slice TYPE-ARG (T bound to []i64) drives the slice_<elem> mangle branch in mono_type_mangle:
    // fn idh<T>(x: T) -> T called with arg of type []i64 → T = []i64 → instance idh__g__slice_i64.
    // (The exact slice_ spelling depends on a recursive-match string compose; assert the stamped
    // instance EXISTS via the synthetic `__g__` infix — VM-robust, and still exercises the branch.)
    let hbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idh = gfn("idh", named_t("T"), Named { name = "T" }, hbody)
    let slice_arg = tvar("s", Slice { element = i64t() })
    let hcaller = texpr_stmt(tcall1("idh", slice_arg, Slice { element = i64t() }))
    mut items2: []TItem = teko::list::push(teko::list::empty(), idh)
    items2 = teko::list::push(items2, hcaller)
    let mp2 = match monomorphize(TProgram { items = items2 }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(count_generic_fns(mp2) == 0)
    teko::assert::is_true(has_stamped_instance(mp2, "idh"))
    // directly exercise EVERY mono_type_mangle arm (branch coverage of the mangle + type_to_texpr).
    teko::assert::is_true(teko::str::len(mono_type_mangle(Slice { element = i64t() })) > 0)
    teko::assert::is_true(teko::str::len(mono_type_mangle(Optional { inner = Str { } })) > 0)
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Str { }), "str"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Byte { }), "byte"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Error { }), "error"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Void { }), "void"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Ptr { }), "ptr"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Uptr { }), "uptr"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Named { name = "Foo" }), "Foo"))
}

#test
fn mono_walk_covers_node_kinds() {
    // a generic fn whose body + a non-generic caller body together exercise many TExprKind /
    // TStatement walk cases (binary, compare, if, cast, field-access, struct-init, interp, in,
    // array, coalesce, safe-field, unary, loop, assign, defer, break/continue), all under the
    // total rewrite walk. The generic call inside drives stamping.
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" }))))

    // non-generic caller body with a grab-bag of typed nodes (well-typedness is not re-checked
    // by mono — it only rewrites types + callees, so hand-built shapes are fine for the walk).
    let n = tvar("n", i64t())
    let bin = TExpr { kind = TBinary { op = lexer::TokenKind::Plus; left = n; right = tnum(1) }; type = i64t(); line = 0; col = 0 }
    let cmpterm = TCmpTerm { op = lexer::TokenKind::Lt; operand = tnum(10) }
    let cmp = TExpr { kind = TCompare { first = n; rest = teko::list::push(teko::list::empty(), cmpterm) }; type = boolt(); line = 0; col = 0 }
    let un = TExpr { kind = TUnary { op = lexer::TokenKind::Minus; operand = n }; type = i64t(); line = 0; col = 0 }
    let cast = TExpr { kind = TCast { expr = n }; type = u8t(); line = 0; col = 0 }
    let cor = TExpr { kind = TCoalesce { left = tvar("o", Optional { inner = i64t() }); right = tnum(0) }; type = i64t(); line = 0; col = 0 }
    let arr = TExpr { kind = TArrayLit { elements = teko::list::push(teko::list::empty(), TArrayElem { is_spread = false; expr = tnum(1) }) }; type = Slice { element = i64t() }; line = 0; col = 0 }
    let interp = TExpr { kind = TInterp { pieces = teko::list::push(teko::list::push(teko::list::empty(), "v"), ""); holes = teko::list::push(teko::list::empty(), n) }; type = strt(); line = 0; col = 0 }
    let inx = TExpr { kind = TInExpr { lhs = n; elems = teko::list::push(teko::list::empty(), tnum(2)) }; type = boolt(); line = 0; col = 0 }
    // an if-expr value with both branches; a match with one wildcard-bodied arm.
    let ife = TExpr { kind = TIfExpr { cond = cmp; then_blk = teko::list::push(teko::list::empty(), texpr_stmt(tnum(1))); has_else = true; else_blk = teko::list::push(teko::list::empty(), texpr_stmt(tnum(2))) }; type = i64t(); line = 0; col = 0 }
    let genstamp = tcall1("idg", tnum(5), i64t())   // drives stamping from within the walk

    // statements: binding, assign, expr, loop (with break/continue), defer, return.
    mut body: []TStatement = teko::list::push(teko::list::empty(), TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "a" }; bound = i64t(); value = bin })
    body = teko::list::push(body, TAssign { name = "a"; op = lexer::TokenKind::Assign; bound = i64t(); value = un })
    body = teko::list::push(body, texpr_stmt(cast))
    body = teko::list::push(body, texpr_stmt(cor))
    body = teko::list::push(body, texpr_stmt(arr))
    body = teko::list::push(body, texpr_stmt(interp))
    body = teko::list::push(body, texpr_stmt(inx))
    body = teko::list::push(body, texpr_stmt(ife))
    body = teko::list::push(body, texpr_stmt(genstamp))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), TBreakStmt { label = "" })
    loopbody = teko::list::push(loopbody, TContinueStmt { label = "" })
    body = teko::list::push(body, TLoopStmt { label = ""; body = loopbody })
    body = teko::list::push(body, TDeferStmt { body = teko::list::push(teko::list::empty(), texpr_stmt(tnum(0))) })
    body = teko::list::push(body, treturn(tnum(0)))

    let caller = plainfn("caller", i64t(), body)
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, caller)
    let mp = match monomorphize(TProgram { items = items }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "caller"))
}
