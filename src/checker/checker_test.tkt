// ---------------------------------------------------------------------------
// Group P: (W10b.D1) invariant-safe construction — a class's `{…}` literal is
// legal ONLY inside the class's OWN methods (static factories / instance
// methods); everywhere else it must be a compile error. Struct literals are
// pure value data and stay free.
// ---------------------------------------------------------------------------
// a `Cls { v = 0 }` literal expression for the given class name.
fn d1_lit(cls: str) -> parser::Expr {
    let names: []str = teko::list::push(teko::list::empty(), "v")
    let vals: []parser::Expr = teko::list::push(teko::list::empty(), e_num(0))
    ek(parser::StructLit { type_path = path1(cls); type_args = teko::list::empty(); field_names = names; field_vals = vals })
}
// `[pub] fn name(params…) -> ret { body }` — the D1 tests' method/function builder.
fn d1_fn(name: str, params: []parser::Param, ret: str, body: []parser::Statement) -> parser::Function {
    parser::Function { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = named_t(ret); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
}
// a sealed `type name = class { v: i64  <methods> }` item.
fn d1_class_item(name: str, methods: []parser::Function) -> parser::Item {
    let field_v = parser::Field { name = "v"; type_ann = named_t("i64"); vis = parser::Visibility::Pub; is_intern = false }
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = teko::list::push(teko::list::empty(), field_v); methods = methods }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn d1_item(f: parser::Function) -> parser::Item { parser::Item { content = f; namespace = ""; file = "" } }

#test
fn d1_static_factory_constructs_own_class_ok() {
    // `Cls::make()` — the canonical factory: a static method of Cls building `Cls { … }`.
    let make = d1_fn("make", teko::list::empty(), "Cls", one_stmt(d1_lit("Cls")))
    let items = teko::list::push(teko::list::empty(), d1_class_item("Cls", list1(make)))
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)
        error => teko::assert::is_true(false)   // its OWN factory must stay legal
    }
}

#test
fn d1_instance_method_constructs_own_class_ok() {
    // an INSTANCE method of Cls building a fresh `Cls { … }` — same encapsulation boundary.
    let dup_params = teko::list::push(teko::list::empty(), recv_param("self"))
    let dup = d1_fn("dup", dup_params, "Cls", one_stmt(d1_lit("Cls")))
    let items = teko::list::push(teko::list::empty(), d1_class_item("Cls", list1(dup)))
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)
        error => teko::assert::is_true(false)   // its OWN instance method must stay legal
    }
}

#test
fn d1_free_function_constructing_class_is_error() {
    // a FREE function building `Cls { … }` — outside the class's surface, must fail.
    let make = d1_fn("make", teko::list::empty(), "Cls", one_stmt(d1_lit("Cls")))
    let sneaky = d1_fn("sneaky", teko::list::empty(), "Cls", one_stmt(d1_lit("Cls")))
    let items = teko::list::push(teko::list::push(teko::list::empty(), d1_class_item("Cls", list1(make))), d1_item(sneaky))
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // external construction -> must fail
        error => teko::assert::is_true(true)
    }
}

#test
fn d1_top_level_statement_constructing_class_is_error() {
    // a top-level `Cls { … }` statement (script main) — outside any method, must fail.
    let make = d1_fn("make", teko::list::empty(), "Cls", one_stmt(d1_lit("Cls")))
    let items = teko::list::push(teko::list::push(teko::list::empty(), d1_class_item("Cls", list1(make))), parser::Item { content = st(d1_lit("Cls")); namespace = ""; file = "" })
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // external construction -> must fail
        error => teko::assert::is_true(true)
    }
}

#test
fn d1_other_class_method_constructing_is_error() {
    // ANOTHER class's method building `Cls { … }` — a method, but not Cls's own, must fail.
    let make = d1_fn("make", teko::list::empty(), "Cls", one_stmt(d1_lit("Cls")))
    let forge = d1_fn("forge", teko::list::empty(), "Cls", one_stmt(d1_lit("Cls")))
    let items = teko::list::push(teko::list::push(teko::list::empty(), d1_class_item("Cls", list1(make))), d1_class_item("Other", list1(forge)))
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // another type's method -> must fail
        error => teko::assert::is_true(true)
    }
}

#test
fn d1_struct_literal_stays_free() {
    // a STRUCT literal from a free function — structs are pure value data, always legal.
    let names: []str = teko::list::push(teko::list::empty(), "x")
    let vals: []parser::Expr = teko::list::push(teko::list::empty(), e_num(0))
    let pt_lit = ek(parser::StructLit { type_path = path1("Pt"); type_args = teko::list::empty(); field_names = names; field_vals = vals })
    let free_build = d1_fn("free_build", teko::list::empty(), "Pt", one_stmt(pt_lit))
    let items = teko::list::push(teko::list::push(teko::list::empty(), pt_item()), d1_item(free_build))
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)
        error => teko::assert::is_true(false)   // struct init is FREE — must NOT fail
    }
}

// --- (#110) skip-level variant matching: a match arm naming an INNER variant's case (`Foo`)
// directly against an OUTER `FooBar | error` subject must be REJECTED — native codegen only
// synthesizes tags for the subject's own direct union members, never a nested member's cases.
// The safe idiom (`FooBar as v => match v { Foo as f => … }`) must stay accepted.
fn empty_struct_decl(name: str) -> parser::TypeDecl {
    parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::empty(); methods = teko::list::empty(); implements = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
}
fn foobar_variant_decl() -> parser::TypeDecl {
    let union = parser::UnionType { members = teko::list::push(teko::list::push(teko::list::empty(), named_t("Foo")), named_t("Bar")) }
    parser::TypeDecl { name = "FooBar"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::VariantBody { type_expr = union }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
}
// FooBar = variant Foo | Bar; the type table also registers Foo/Bar themselves.
fn foobar_table() -> TypeTable {
    mut t: TypeTable = teko::list::empty()
    t = teko::list::push(t, TypeReg { name = "Foo"; namespace = ""; vis = parser::Visibility::Private; decl = empty_struct_decl("Foo") })
    t = teko::list::push(t, TypeReg { name = "Bar"; namespace = ""; vis = parser::Visibility::Private; decl = empty_struct_decl("Bar") })
    t = teko::list::push(t, TypeReg { name = "FooBar"; namespace = ""; vis = parser::Visibility::Private; decl = foobar_variant_decl() })
    t
}
// the `FooBar | error` subject (mirrors `fn make(..) -> FooBar | error` from issue #110's repro).
fn foobar_or_error_subject() -> Type {
    mut members: []Type = teko::list::empty()
    members = teko::list::push(members, Named { name = "FooBar" })
    members = teko::list::push(members, Error { })
    Variant { members = members }
}

#test
fn skip_level_match_is_rejected() {
    // `Foo as f` matched directly against `FooBar | error` — Foo is a case of the INNER FooBar
    // variant, not a direct case of the outer subject. Must be rejected with the double-match hint.
    let bad = parser::BindPattern { type_name = path1("Foo"); has_binding = true; binding = "f"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    match check_pattern(bad, foobar_or_error_subject(), empty_env(), foobar_table()) {
        Env => teko::assert::is_true(false)   // must be REJECTED (#110)
        error as e => {
            teko::assert::is_true(true)
            teko::assert::is_true(teko::runtime::str_contains(e.message, "not a direct case of"))
            teko::assert::is_true(teko::runtime::str_contains(e.message, "FooBar as v"))   // the double-match hint
        }
    }
}

#test
fn skip_level_field_pattern_is_rejected() {
    // the FIELD-pattern axis (`Foo { }` style) must be guarded the same way as BIND.
    let bad = parser::FieldPattern { type_name = path1("Foo"); fields = teko::list::empty() }
    match check_pattern(bad, foobar_or_error_subject(), empty_env(), foobar_table()) {
        Env => teko::assert::is_true(false)   // must be REJECTED (#110)
        error => teko::assert::is_true(true)
    }
}

#test
fn direct_case_match_on_the_outer_subject_is_accepted() {
    // CONTROL: matching `FooBar` (a DIRECT case of `FooBar | error`) is legal — same subject, only
    // the arm's named type changes from the inner `Foo` to the outer `FooBar`.
    let ok = parser::BindPattern { type_name = path1("FooBar"); has_binding = true; binding = "v"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    match check_pattern(ok, foobar_or_error_subject(), empty_env(), foobar_table()) {
        Env => teko::assert::is_true(true)
        error => teko::assert::is_true(false)   // FooBar IS a direct case — must NOT fail
    }
}

#test
fn direct_case_match_on_error_is_accepted() {
    // CONTROL: `error as e` against `FooBar | error` — error IS a direct (non-nominal) case.
    let ok = parser::BindPattern { type_name = path1("error"); has_binding = true; binding = "e"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    match check_pattern(ok, foobar_or_error_subject(), empty_env(), foobar_table()) {
        Env => teko::assert::is_true(true)
        error => teko::assert::is_true(false)   // error IS a direct case — must NOT fail
    }
}

#test
fn skip_level_match_still_rejected_inside_alt() {
    // the guard must also fire when the skip-level case appears as an Alt option (`Foo | Bar` where
    // Foo/Bar are cases of the INNER variant, matched directly against the outer subject).
    let opts: []parser::Pattern = teko::list::push(teko::list::empty(), parser::BindPattern { type_name = path1("Foo"); has_binding = false; binding = ""; is_slice = false; slice_type = null; type_args = teko::list::empty() })
    let alt = parser::AltPattern { options = opts }
    match check_pattern(alt, foobar_or_error_subject(), empty_env(), foobar_table()) {
        Env => teko::assert::is_true(false)   // must be REJECTED (#110)
        error => teko::assert::is_true(true)
    }
}

// --- (W10b.D2, 2026-07-02) interface atoms in `<T: I>` constraints — NOMINAL conformance -----
// A generic fn `fn hold<T: <iface>>(x: T) -> T { return x }` (the opaque hold).
fn generic_hold_fn(iface: str) -> parser::Item {
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = iface })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_var("x") })
    let f = parser::Function { name = "holdc"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("T"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    parser::Item { content = f; namespace = ""; file = "" }
}
// `let p = <StructName> { }` then `holdc(p)` as a loose statement pair.
fn hold_call_items(struct_name: str) -> []parser::Item {
    let lit = ek(parser::StructLit { type_path = path1(struct_name); type_args = teko::list::empty(); field_names = teko::list::empty(); field_vals = teko::list::empty() })
    let bind = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "p" }; has_type = false; type_ann = named_t("i64"); value = lit }
    let callargs = teko::list::push(teko::list::empty(), e_var("p"))
    let call = st(ek(parser::Call { callee = path1("holdc"); args = callargs; arg_names = pos_names(callargs.len) }))
    let items = teko::list::push(teko::list::empty(), parser::Item { content = bind; namespace = ""; file = "" })
    teko::list::push(items, parser::Item { content = call; namespace = ""; file = "" })
}

// a CONFORMING struct (declared `implements`) satisfies the interface atom at monomorphization.
#test
fn iface_constraint_conforming_struct_ok() {
    let ifc = iface_item("Greetable", list1(iface_method("greet")), teko::list::empty())
    let imp = impl_struct_item("Hi", list1(impl_method("greet", parser::Visibility::Private)), slist1("Greetable"))
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc), imp)
    items = teko::list::push(items, generic_hold_fn("Greetable"))
    let tail = hold_call_items("Hi")
    items = teko::list::push(teko::list::push(items, tail[0]), tail[1])
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
}

// a NON-conforming struct (has the method but NEVER declares `implements`) is REJECTED —
// conformance is nominal/declared, never structural.
#test
fn iface_constraint_nonconforming_struct_is_error() {
    let ifc = iface_item("Greetable", list1(iface_method("greet")), teko::list::empty())
    let imp = impl_struct_item("Loner", list1(impl_method("greet", parser::Visibility::Private)), teko::list::empty())   // NO implements
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc), imp)
    items = teko::list::push(items, generic_hold_fn("Greetable"))
    let tail = hold_call_items("Loner")
    items = teko::list::push(teko::list::push(items, tail[0]), tail[1])
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // must fail the constraint at instantiation
        error => teko::assert::is_true(true)
    }
}

// (W10b.D3) an interface may NOT be a variant member yet (the VM's untagged class values
// cannot discriminate `I | error` — an honest checker stop, never an engine divergence).
#test
fn iface_variant_member_is_error() {
    let ifc = iface_item("Greetable", list1(iface_method("greet")), teko::list::empty())
    let uni = parser::UnionType { members = teko::list::push(teko::list::push(teko::list::empty(), named_t("Greetable")), named_t("error")) }
    // an INLINE union in a fn's return annotation — resolved at collect time, so the ban fires.
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::StructLit { type_path = path1("error"); type_args = teko::list::empty(); field_names = teko::list::push(teko::list::empty(), "message"); field_vals = teko::list::push(teko::list::empty(), e_str("x")) }) })
    let f = parser::Function { name = "gf"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); has_return = true; return_type = uni; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    let items = teko::list::push(teko::list::push(teko::list::empty(), ifc), parser::Item { content = f; namespace = ""; file = "" })
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(false)   // must fail
        error => teko::assert::is_true(true)
    }
}

// (#109 W0) an empty-struct-body TypeDecl named `name`, wrapped as an Item under `namespace`.
fn w0_empty_struct_item(name: str, namespace: str) -> parser::Item {
    let td = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::empty(); methods = teko::list::empty(); implements = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
    parser::Item { content = td; namespace = namespace; file = "" }
}

// (#109 W0) registering the SAME (namespace, name) twice — e.g. two files both declaring
// `namespace aa { type Reader = struct {} }` — is a real duplicate declaration, now a compile
// error (today it silently shadowed: first-match-wins in the flat table).
#test
fn w0_duplicate_same_namespace_and_name_is_error() {
    let items = teko::list::push(teko::list::push(teko::list::empty(), w0_empty_struct_item("Reader", "aa")), w0_empty_struct_item("Reader", "aa"))
    match collect(parser::Program { items = items }) {
        Collected => teko::assert::is_true(false)   // must fail
        error as e => {
            teko::assert::is_true(true)
            teko::assert::is_true(teko::str::contains(e.message, "duplicate type"))
            teko::assert::is_true(teko::str::contains(e.message, "Reader"))
        }
    }
}

// (#109 W3 ACCEPTANCE) the ratified design's P1 probe: `aa::Reader` and `bb::Reader` — same bare
// name, DIFFERENT namespaces. W0 fail-loud-rejected this as "not yet supported"; W3's canonical-name
// (`Named.name` = "ns::Name") resolution now makes the two DISTINCT identities that COEXIST — the
// exact incident that motivated #109 (teko::io::Reader colliding with emit's codec Reader).
#test
fn w0_cross_namespace_bare_name_now_coexists() {
    let items = teko::list::push(teko::list::push(teko::list::empty(), w0_empty_struct_item("Reader", "aa")), w0_empty_struct_item("Reader", "bb"))
    match collect(parser::Program { items = items }) {
        Collected => teko::assert::is_true(true)   // (#109 W3) now legal — distinct canonical names aa::Reader / bb::Reader
        error => teko::assert::is_true(false)
    }
}

// (#109 order fix) a BARE `implements` name must resolve from the IMPLEMENTING type's namespace —
// never by table-scan order. Reproduces the CI-only failure deterministically: a same-named
// NON-interface type in another namespace registered FIRST (readdir order put teko::emit::Reader,
// a struct, ahead of teko::io::Reader on linux-arm64) made conformance find the struct and fail
// with "Reader is not an interface".
#test
fn iface_bare_implements_resolves_in_own_namespace_not_scan_order() {
    let decoy = w0_empty_struct_item("Reader", "aa")   // NON-interface named Reader, FIRST in table order
    let ifc0 = iface_item("Reader", teko::list::empty(), teko::list::empty())
    let ifc = parser::Item { content = ifc0.content; namespace = "bb"; file = "" }
    let imp0 = impl_struct_item("File", teko::list::empty(), slist1("Reader"))
    let imp = parser::Item { content = imp0.content; namespace = "bb"; file = "" }
    let items = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), decoy), ifc), imp)
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)   // bb::File implements bb::Reader — the aa decoy must not interfere
        error => teko::assert::is_true(false)
    }
}

// (#152) a CLASS base-chain hop must be namespace-precise: a NON-class decoy named `Base` in
// another namespace registered FIRST must not shadow the extending class's own bb::Base
// (readdir-order twin of the interface Reader regression — canon_class_bases + two-pass
// type_table_find keep the hop exact).
#test
fn class_bare_base_resolves_in_own_namespace_not_scan_order() {
    let decoy = w0_empty_struct_item("Base", "aa")   // NON-class named Base, FIRST in table order
    let base_td = parser::TypeDecl { name = "Base"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Virtual; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = teko::list::empty(); methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
    let base = parser::Item { content = base_td; namespace = "bb"; file = "" }
    let sub0 = cyclic_class_item("Sub", "Base")   // a virtual-class helper: `class Sub Base {}`
    let sub = parser::Item { content = sub0.content; namespace = "bb"; file = "" }
    let items = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), decoy), base), sub)
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)   // bb::Sub extends bb::Base — the aa decoy must not interfere
        error => teko::assert::is_true(false)
    }
}

// (#152) nominal conformance must be namespace-exact for qualified identities: aa::S implementing
// aa::X does NOT conform to bb::X (the old bare last-segment compare said it did). The probe runs
// against the COLLECT table (the real callers' table) after canon_class_bases qualified the
// implements entries.
#test
fn conformance_is_namespace_exact_for_qualified_names() {
    let x0 = iface_item("X", teko::list::empty(), teko::list::empty())
    let xa = parser::Item { content = x0.content; namespace = "aa"; file = "" }
    let x1 = iface_item("X", teko::list::empty(), teko::list::empty())
    let xb = parser::Item { content = x1.content; namespace = "bb"; file = "" }
    let s0 = impl_struct_item("S", teko::list::empty(), slist1("X"))
    let sa = parser::Item { content = s0.content; namespace = "aa"; file = "" }
    let items = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), xa), xb), sa)
    let canon = canon_class_bases(parser::Program { items = items })
    match collect(canon) {
        Collected as c => {
            teko::assert::is_true(type_conforms_to("S", "aa::X", c.types))
            teko::assert::is_false(type_conforms_to("S", "bb::X", c.types))
        }
        error => teko::assert::is_true(false)
    }
}

// (#109 W0) top-level (namespace "") duplicate reads as "<top-level>" in the diagnostic, not an
// empty/blank namespace label.
#test
fn w0_duplicate_top_level_names_top_level_in_message() {
    let items = teko::list::push(teko::list::push(teko::list::empty(), w0_empty_struct_item("Widget", "")), w0_empty_struct_item("Widget", ""))
    match collect(parser::Program { items = items }) {
        Collected => teko::assert::is_true(false)   // must fail
        error as e => teko::assert::is_true(teko::str::contains(e.message, "<top-level>"))
    }
}

// (#109 W0) the ban must NOT false-positive on distinct types in distinct namespaces (the
// ordinary, legitimate case), nor on same-name-same-namespace when there is only ONE decl.
#test
fn w0_distinct_namespaces_distinct_names_still_collect_ok() {
    mut items = teko::list::push(teko::list::empty(), w0_empty_struct_item("Reader", "aa"))
    items = teko::list::push(items, w0_empty_struct_item("Writer", "aa"))
    items = teko::list::push(items, w0_empty_struct_item("Reader2", "bb"))
    match collect(parser::Program { items = items }) {
        Collected => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
}

// (#109 W0 tightened exemption — soundness) a genuine USER type whose name carries the `__g__`
// infix (the lexer accepts it in ordinary identifiers) must NOT slip through the ban via the
// naive substring exemption: the strict predicate requires empty ns AND a generic base behind
// the prefix. The verifier's exact bypass scenario: `Foo__g__Bar` in aa AND bb → the W0
// cross-namespace error, exactly like any other bare-name duplicate.
#test
fn w0_user_type_with_g_infix_cross_ns_coexists_same_ns_dup_errors() {
    // (#109 W3) `Foo__g__Bar` in aa AND bb is just another cross-namespace bare-name pair — now COEXISTS.
    let items = teko::list::push(teko::list::push(teko::list::empty(), w0_empty_struct_item("Foo__g__Bar", "aa")), w0_empty_struct_item("Foo__g__Bar", "bb"))
    match collect(parser::Program { items = items }) {
        Collected => teko::assert::is_true(true)
        error => teko::assert::is_true(false)
    }
    // and at the TOP LEVEL (ns "", so condition (b) alone can't reject): with NO generic `Foo`
    // base declared, condition (c) fails → still banned as an ordinary duplicate.
    let top = teko::list::push(teko::list::push(teko::list::empty(), w0_empty_struct_item("Foo__g__Bar", "")), w0_empty_struct_item("Foo__g__Bar", ""))
    match collect(parser::Program { items = top }) {
        Collected => teko::assert::is_true(false)   // must fail
        error as e2 => teko::assert::is_true(teko::str::contains(e2.message, "duplicate type"))
    }
}

// (#109 W0 tightened exemption — positive control) REAL stamped generic instances stay exempt.
// A dep-seeded table shaped like post-stamping state: the generic base `Box<T>` plus TWO stamped
// `Box__g__i64` entries (both ns "" — e.g. two dep namespaces each instantiated Box<i64>, merged
// into one seed). collect_with_seed's validate_type_decls sees the merged table and must NOT
// report them as duplicates — all three strict-exemption conditions hold.
#test
fn w0_stamped_generic_instances_remain_exempt() {
    mut seedtbl = box_generic_table()   // `type Box<T> = struct { value: T }` (the generic base)
    let inst_fld = parser::Field { name = "value"; type_ann = ttype_named("i64"); vis = parser::Visibility::Pub; is_intern = false }
    let inst_decl = parser::TypeDecl { name = "Box__g__i64"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), inst_fld); methods = teko::list::empty(); implements = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
    seedtbl = teko::list::push(seedtbl, TypeReg { name = "Box__g__i64"; namespace = ""; vis = parser::Visibility::Private; decl = inst_decl })
    seedtbl = teko::list::push(seedtbl, TypeReg { name = "Box__g__i64"; namespace = ""; vis = parser::Visibility::Private; decl = inst_decl })
    let seed = Collected { types = seedtbl; env = empty_env() }
    match collect_with_seed(parser::Program { items = teko::list::empty() }, seed) {
        Collected => teko::assert::is_true(true)
        error => teko::assert::is_true(false)   // the strict exemption must still cover real stamps
    }
}

// ---------------------------------------------------------------------------
// Group NP-OOP (ROUND 3.5 Stage A, issue #116): null propagation × classes/interfaces.
// `?.method(args)` + class-`?.field` DESUGAR in the checker to a typed match (safe_nav_match);
// these tests lock the typing surface: result optionality, the disjoint-domain rejections,
// visibility parity with bare `.`, and the `??` conforming-fallback widening.
// ---------------------------------------------------------------------------
// `type Gadget = class { pub v: i64  w: i64  pub fn ping(self)->i64  fn covert(self)->i64  pub fn silent(self) }`
fn np_gadget_decl() -> parser::TypeDecl {
    let fv = parser::Field { name = "v"; type_ann = named_t("i64"); vis = parser::Visibility::Pub; is_intern = false }
    let fw = parser::Field { name = "w"; type_ann = named_t("i64"); vis = parser::Visibility::Private; is_intern = false }
    let fields = teko::list::push(teko::list::push(teko::list::empty(), fv), fw)
    let silent = parser::Function { name = "silent"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::empty(), recv_param("self")); has_return = false; return_type = named_t("i64"); body = teko::list::empty(); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    let methods = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), impl_method("ping", parser::Visibility::Pub)), impl_method("covert", parser::Visibility::Private)), silent)
    parser::TypeDecl { name = "Gadget"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = fields; methods = methods }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
}
fn np_program() -> parser::Program {
    let item = parser::Item { content = np_gadget_decl(); namespace = ""; file = "" }
    parser::Program { items = teko::list::push(teko::list::empty(), item) }
}
// collect() the one-class program so the class's methods are REGISTERED as callable fns
// (the desugared arm call resolves `Gadget::ping` through the collected env, like real code).
fn np_table() -> TypeTable {
    match collect(np_program()) { Collected as c => c.types; error => panic("np_table: collect failed") }
}
fn np_env() -> Env {
    let base = match collect(np_program()) { Collected as c => c.env; error => panic("np_env: collect failed") }
    define(base, "g", Optional { inner = Named { name = "Gadget" } }, false)
}
fn np_smc(method: str) -> parser::SafeMethodCall { parser::SafeMethodCall { receiver = e_var("g"); method = method; args = teko::list::empty() } }

#test
fn np_safe_method_call_types_to_optional_match() {
    // g?.ping() where g: Gadget? → i64? — and the node IS the desugared match (TMatchExpr).
    let r = match type_safe_method_call(np_smc("ping"), 3, 7, np_env(), np_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match r.type { Optional as o => match o.inner { Prim as p => teko::assert::is_true(p.kind == PrimKind::I64); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    match r.kind { TMatchExpr as m => teko::assert::is_true(m.arms.len == 2); _ => teko::assert::is_true(false) }
}

#test
fn np_safe_method_call_void_types_to_void() {
    // g?.silent() — a void method makes the whole safe call void (statement position only).
    let r = match type_safe_method_call(np_smc("silent"), 3, 7, np_env(), np_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match r.type { Void => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

#test
fn np_safe_method_call_private_rejected() {
    // g?.covert() from OUTSIDE the class — `?.` must respect visibility exactly like `.`.
    match type_safe_method_call(np_smc("covert"), 3, 7, np_env(), np_table()) {
        TExpr => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn np_safe_field_on_class_desugars_and_respects_visibility() {
    // g?.v → i64? through the desugared match; g?.w (private) is rejected — no visibility
    // bypass through the null-propagating path.
    let pub_read = parser::SafeFieldAccess { receiver = e_var("g"); field = "v" }
    let r = match type_safe_field_access(pub_read, 3, 7, np_env(), np_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match r.type { Optional as o => match o.inner { Prim as p => teko::assert::is_true(p.kind == PrimKind::I64); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    match r.kind { TMatchExpr => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    let priv_read = parser::SafeFieldAccess { receiver = e_var("g"); field = "w" }
    match type_safe_field_access(priv_read, 3, 7, np_env(), np_table()) {
        TExpr => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

#test
fn np_safe_nav_on_error_union_rejected_disjoint_domain() {
    // a `Gadget | error` receiver: `?.` reads absence, never errors (the disjoint-domain law).
    mut members: []Type = teko::list::empty()
    members = teko::list::push(members, Named { name = "Gadget" })
    members = teko::list::push(members, Error { })
    let env = define(empty_env(), "g", Variant { members = members }, false)
    match type_safe_method_call(np_smc("ping"), 3, 7, env, np_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "`?.` reads absence (`T?`), never errors — inspect an `X | error` union with `match` (disjoint-domain law)")
    }
    let sfa = parser::SafeFieldAccess { receiver = e_var("g"); field = "v" }
    match type_safe_field_access(sfa, 3, 7, env, np_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "`?.` reads absence (`T?`), never errors — inspect an `X | error` union with `match` (disjoint-domain law)")
    }
}

#test
fn np_bare_dot_on_nullable_rejected_with_pointer_message() {
    // bare `.` on a `Gadget?` stays a compile error — field AND method forms.
    let fa = parser::FieldAccess { receiver = e_var("g"); field = "v" }
    match type_field_access(fa, np_env(), np_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "cannot use `.` on a nullable value (`T?`) — read it with `?.` or `??` (REBOOT_PLAN §203)")
    }
    let mc = parser::MethodCall { receiver = e_var("g"); method = "ping"; args = teko::list::empty() }
    match type_method_call(mc, np_env(), np_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "cannot call a method with `.` on a nullable value (`T?`) — use `?.` (REBOOT_PLAN §203)")
    }
}

#test
fn np_coalesce_conforming_class_fallback_widens_to_interface() {
    // shape_opt ?? circle — the fallback WIDENS into the left's interface inner (Shape? ?? Circle → Shape).
    let shape = iface_item("Shape", list1(impl_method("area", parser::Visibility::Pub)), teko::list::empty())
    let circle = impl_class_item("Circle", list1(impl_method("area", parser::Visibility::Pub)), slist1("Shape"))
    mut tbl: TypeTable = teko::list::empty()
    match shape.content { parser::TypeDecl as td => tbl = teko::list::push(tbl, TypeReg { name = "Shape"; namespace = ""; vis = parser::Visibility::Private; decl = td }); _ => { } }
    match circle.content { parser::TypeDecl as td => tbl = teko::list::push(tbl, TypeReg { name = "Circle"; namespace = ""; vis = parser::Visibility::Private; decl = td }); _ => { } }
    let env = define(define(empty_env(), "s", Optional { inner = Named { name = "Shape" } }, false), "c", Named { name = "Circle" }, false)
    let co = parser::Coalesce { left = e_var("s"); right = e_var("c") }
    let r = match type_coalesce(co, env, tbl) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match r.type { Named as n => teko::assert::is_true(n.name == "Shape"); _ => teko::assert::is_true(false) }
    // and a NON-conforming fallback still fails.
    let loner = impl_class_item("Loner", list1(impl_method("area", parser::Visibility::Pub)), teko::list::empty())
    match loner.content { parser::TypeDecl as td => tbl = teko::list::push(tbl, TypeReg { name = "Loner"; namespace = ""; vis = parser::Visibility::Private; decl = td }); _ => { } }
    let env2 = define(env, "l", Named { name = "Loner" }, false)
    let co2 = parser::Coalesce { left = e_var("s"); right = e_var("l") }
    match type_coalesce(co2, env2, tbl) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn np_coalesce_sentinel_left_rejected() {
    // `null ?? x` — a sentinel optional left has no inner T to unwrap (honest error, M.1).
    let co = parser::Coalesce { left = ek(parser::NullLit { }); right = e_num(1) }
    match type_coalesce(co, empty_env(), empty_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "`??` on a bare `null` has nothing to unwrap — the left must be a typed `T?` (REBOOT_PLAN §203)")
    }
}

#test
fn np_coalesce_void_fallback_rejected() {
    // (issue #120) `x ?? y` where y types to `void` — a void expression cannot stand as the
    // fallback value (M.1). Mirrors the C twin's `tk_type_is_void(&rt)` guard exactly, same
    // message, so both checker engines reject a void `??` fallback identically.
    let env = define(define(empty_env(), "os", Optional { inner = Str { } }, false), "v", Void { }, false)
    let co = parser::Coalesce { left = e_var("os"); right = e_var("v") }
    match type_coalesce(co, env, empty_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "a `void` expression cannot be the `??` fallback (M.1)")
    }
}

#test
fn np_safe_nav_on_bare_null_rejected() {
    // `null?.ping()` — a sentinel optional receiver has no member to reach.
    let smc = parser::SafeMethodCall { receiver = ek(parser::NullLit { }); method = "ping"; args = teko::list::empty() }
    match type_safe_method_call(smc, 3, 7, empty_env(), np_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::is_true(e.message == "`?.` on a bare `null` has no member to reach (annotate the optional's type)")
    }
}

// --- (TR0, 2026-07-02) trait derivation — the FOLD + requirement/conflict rules + honest stops ---
// A trait is declared like a struct (fields + methods, bodies optional), derived via the same
// `&`-list as interfaces; fold_traits rewrites derivers BEFORE typing (fields flatten in, bodied
// methods fold in, bodyless methods become requirements). See TEKO_ROADMAP_TRAITS.md TR0.
fn tr_field(name: str) -> parser::Field { parser::Field { name = name; type_ann = named_t("i64"); vis = parser::Visibility::Pub; is_intern = false } }
fn tr_fields1(name: str) -> []parser::Field { teko::list::push(teko::list::empty(), tr_field(name)) }
fn trait_item(name: str, fields: []parser::Field, methods: []parser::Function) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::TraitBody { fields = fields; methods = methods }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn deriver_struct_item(name: str, fields: []parser::Field, methods: []parser::Function, derives: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = methods; implements = derives }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn deriver_class_item(name: str, fields: []parser::Field, methods: []parser::Function, derives: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = derives; fields = fields; methods = methods }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn items2(a: parser::Item, b: parser::Item) -> []parser::Item { teko::list::push(teko::list::push(teko::list::empty(), a), b) }
fn items3(a: parser::Item, b: parser::Item, c: parser::Item) -> []parser::Item { teko::list::push(items2(a, b), c) }
fn tr_program_ok(items: []parser::Item) -> bool {
    match type_program(parser::Program { items = items }) { TProgram => true; error => false }
}

#test
fn trait_fold_struct_gains_field_and_method() {
    // trait Stamp { at: i64; fn stamp(self) -> i64 { 0 } } + struct P derives it; a loose
    // statement constructs P with BOTH its own and the folded field, then calls the folded method.
    let tr = trait_item("Stamp", tr_fields1("at"), list1(impl_method("stamp", parser::Visibility::Private)))
    let dv = deriver_struct_item("P", tr_fields1("own"), teko::list::empty(), slist1("Stamp"))
    let lit = ek(parser::StructLit { type_path = path1("P"); type_args = teko::list::empty(); field_names = teko::list::push(teko::list::push(teko::list::empty(), "own"), "at"); field_vals = teko::list::push(teko::list::push(teko::list::empty(), e_num(1)), e_num(2)) })
    let bind_p = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "p" }; has_type = false; type_ann = named_t("i64"); value = lit }
    let call = st(ek(parser::MethodCall { receiver = e_var("p"); method = "stamp"; args = teko::list::empty() }))
    let items = teko::list::push(items3(tr, dv, parser::Item { content = bind_p; namespace = ""; file = "" }), parser::Item { content = call; namespace = ""; file = "" })
    teko::assert::is_true(tr_program_ok(items))
}

#test
fn trait_fold_class_gains_members() {
    // a CLASS deriving a trait: folded field participates in a factory's class literal, the
    // folded method satisfies nothing but must type-check under the deriver.
    let tr = trait_item("Stamp", tr_fields1("at"), list1(impl_method("stamp", parser::Visibility::Private)))
    let dv = deriver_class_item("C", teko::list::empty(), teko::list::empty(), slist1("Stamp"))
    teko::assert::is_true(tr_program_ok(items2(tr, dv)))
}

#test
fn trait_missing_requirement_is_error() {
    // trait Need { fn need(self) -> i64 } (bodyless = requirement); the deriver defines nothing.
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let dv = deriver_struct_item("P", tr_fields1("own"), teko::list::empty(), slist1("Need"))
    teko::assert::is_true(!tr_program_ok(items2(tr, dv)))
}

#test
fn trait_requirement_satisfied_by_deriver_method() {
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let dv = deriver_struct_item("P", tr_fields1("own"), list1(impl_method("need", parser::Visibility::Private)), slist1("Need"))
    teko::assert::is_true(tr_program_ok(items2(tr, dv)))
}

#test
fn trait_requirement_sig_mismatch_is_error() {
    // the deriver provides `need(self, x)` where the trait requires `need(self)`.
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let dv = deriver_struct_item("P", tr_fields1("own"), list1(impl_method_arg("need", parser::Visibility::Private)), slist1("Need"))
    teko::assert::is_true(!tr_program_ok(items2(tr, dv)))
}

#test
fn trait_two_bodied_conflict_needs_deriver_override() {
    // two traits both PROVIDE `m` — without a deriver-defined `m` it is a compile error; the
    // deriver defining its own `m` IS the override (no implicit resolution order).
    let t1 = trait_item("T1", teko::list::empty(), list1(impl_method("m", parser::Visibility::Private)))
    let t2 = trait_item("T2", teko::list::empty(), list1(impl_method("m", parser::Visibility::Private)))
    let bad = deriver_struct_item("P", tr_fields1("own"), teko::list::empty(), teko::list::push(slist1("T1"), "T2"))
    teko::assert::is_true(!tr_program_ok(items3(t1, t2, bad)))
    let good = deriver_struct_item("Q", tr_fields1("own"), list1(impl_method("m", parser::Visibility::Private)), teko::list::push(slist1("T1"), "T2"))
    teko::assert::is_true(tr_program_ok(items3(t1, t2, good)))
}

#test
fn trait_shared_bodyless_requirement_satisfied_once() {
    // two traits REQUIRE the same `need(self) -> i64`; one deriver method satisfies both.
    let t1 = trait_item("T1", teko::list::empty(), list1(iface_method("need")))
    let t2 = trait_item("T2", teko::list::empty(), list1(iface_method("need")))
    let dv = deriver_struct_item("P", tr_fields1("own"), list1(impl_method("need", parser::Visibility::Private)), teko::list::push(slist1("T1"), "T2"))
    teko::assert::is_true(tr_program_ok(items3(t1, t2, dv)))
}

#test
fn trait_field_collision_is_error() {
    // a trait field colliding with the deriver's own field — fields cannot be overridden.
    let tr = trait_item("Stamp", tr_fields1("x"), teko::list::empty())
    let dv = deriver_struct_item("P", tr_fields1("x"), teko::list::empty(), slist1("Stamp"))
    teko::assert::is_true(!tr_program_ok(items2(tr, dv)))
    // ... and across two derived traits.
    let t2 = trait_item("Stamp2", tr_fields1("y"), teko::list::empty())
    let t3 = trait_item("Stamp3", tr_fields1("y"), teko::list::empty())
    let dv2 = deriver_struct_item("Q", tr_fields1("own"), teko::list::empty(), teko::list::push(slist1("Stamp2"), "Stamp3"))
    teko::assert::is_true(!tr_program_ok(items3(t2, t3, dv2)))
}

#test
fn trait_is_not_instantiable() {
    // `Stamp { at = 1 }` — a trait literal is rejected (derive it instead).
    let tr = trait_item("Stamp", tr_fields1("at"), teko::list::empty())
    let lit = ek(parser::StructLit { type_path = path1("Stamp"); type_args = teko::list::empty(); field_names = teko::list::push(teko::list::empty(), "at"); field_vals = teko::list::push(teko::list::empty(), e_num(1)) })
    let bind_v = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "v" }; has_type = false; type_ann = named_t("i64"); value = lit }
    teko::assert::is_true(!tr_program_ok(items2(tr, parser::Item { content = bind_v; namespace = ""; file = "" })))
}

#test
fn trait_as_value_type_is_error() {
    // a trait as a PARAM type is TR1 territory — rejected honestly at resolution.
    let tr = trait_item("Stamp", tr_fields1("at"), teko::list::empty())
    let p = parser::Param { name = "s"; has_type = true; type_ann = named_t("Stamp"); is_params = false; has_default = false; default_expr = e_num(0) }
    let f = parser::Function { name = "use_stamp"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::empty(), p); has_return = true; return_type = named_t("i64"); body = one_stmt(e_num(0)); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    teko::assert::is_true(!tr_program_ok(items2(tr, parser::Item { content = f; namespace = ""; file = "" })))
}

#test
fn trait_method_with_dispatch_markers_is_error() {
    // `virtual fn` inside a trait body — the class dispatch markers are meaningless in a trait.
    mut m = impl_method("m", parser::Visibility::Private)
    let vm = parser::Function { name = m.name; type_params = m.type_params; type_constraints = m.type_constraints; params = m.params; has_return = m.has_return; return_type = m.return_type; body = m.body; vis = m.vis; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = true; is_override = false; has_inject = false; injects = teko::list::empty() }
    let tr = trait_item("Stamp", teko::list::empty(), list1(vm))
    teko::assert::is_true(!tr_program_ok(teko::list::push(teko::list::empty(), tr)))
}

#test
fn trait_duplicate_derive_is_error() {
    let tr = trait_item("Stamp", tr_fields1("at"), teko::list::empty())
    let dv = deriver_struct_item("P", tr_fields1("own"), teko::list::empty(), teko::list::push(slist1("Stamp"), "Stamp"))
    teko::assert::is_true(!tr_program_ok(items2(tr, dv)))
}

#test
fn trait_class_requirement_satisfied_by_pub_method() {
    // a CLASS deriving a trait with a requirement — a `pub` class method satisfies it; a class
    // with NO such method does not.
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let ok = deriver_class_item("C", teko::list::empty(), list1(impl_method("need", parser::Visibility::Pub)), slist1("Need"))
    teko::assert::is_true(tr_program_ok(items2(tr, ok)))
    let bad = deriver_class_item("D", teko::list::empty(), teko::list::empty(), slist1("Need"))
    teko::assert::is_true(!tr_program_ok(items2(tr, bad)))
}

#test
fn generic_trait_is_rejected() {
    // `type T<X> = trait { }` — outside TR0's unit; honest error.
    let td = parser::TypeDecl { name = "GT"; type_params = teko::list::push(teko::list::empty(), "X"); type_constraints = teko::list::push(teko::list::empty(), parser::NoConstraint { }); body = parser::TraitBody { fields = teko::list::empty(); methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
    teko::assert::is_true(!tr_program_ok(teko::list::push(teko::list::empty(), parser::Item { content = td; namespace = ""; file = "" })))
}

/** (S6, issue #162) constraint-surface FIXTURES (crumb 7): a synthetic 2-interface TypeTable
    (`Geo.area` / `Named2.label`) for constraint_interfaces unit checks below, independent of a
    full program (crumb-1/2's own isolation).
    These fixtures are AST-BUILT (via type_program), not real `A & B` SYNTAX in a `.tks` fixture:
    the CI/release gate's front-end is the PREVIOUSLY RELEASED `teko` seed (governance #235,
    mirroring retired), whose checker predates this PR's fix — a real `<T: A & B>` fixture
    parsed+typed by THAT seed would fail with the OLD "method typing is deferred" message and turn
    the gate red, even though gen-1 (built FROM this fix) type-checks and RUNS the identical program
    correctly (verified manually: seed compiles this source into gen-1, gen-1 in turn compiles+runs
    a `both<T: Geo & Named2>` program end to end, exit 0). These AST-level tests exercise the SAME
    checker functions the real syntax would reach (constraint_interfaces/type_method_call), so they
    are equivalent coverage today; the real-syntax end-to-end `generics_test.tkt` fixture can be
    added once a release carries this fix. */
fn s6_iface_decl(name: str, methods: []parser::Function) -> parser::TypeDecl {
    parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::InterfaceBody { extends = teko::list::empty(); methods = methods }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
}
fn s6_geo_named2_table() -> TypeTable {
    let d_geo = s6_iface_decl("Geo", list1(iface_method("area")))
    let d_named2 = s6_iface_decl("Named2", list1(iface_method("label")))
    teko::list::push(teko::list::push(empty_table(), TypeReg { name = "Geo"; namespace = ""; vis = parser::Visibility::Private; decl = d_geo }), TypeReg { name = "Named2"; namespace = ""; vis = parser::Visibility::Private; decl = d_named2 })
}

#test
/** `Geo & Named2`'s constraint_interfaces is the AND-union of both atoms — both interfaces,
    unambiguous (disjoint method names). */
fn s6_and_constraint_interfaces_is_the_union() {
    let c: parser::ConstraintExpr = parser::ConstraintAnd { left = parser::ConstraintAtom { name = "Geo" }; right = parser::ConstraintAtom { name = "Named2" } }
    match constraint_interfaces(c, s6_geo_named2_table()) {
        []str as ifaces => teko::assert::is_true(ifaces.len == 2)
        error as e => { teko::io::println(e.message); teko::assert::is_true(false) }
    }
}

/** A full program `fn both<T: Geo & Named2>(x: T) -> i64 { return x.area() }` type-checks: the
    UNION surface authorizes `area` (owned by Geo), and `Sq2` conforms to both interfaces. */
fn s6_and_program(body_method: str) -> parser::Program {
    let ifc_geo = iface_item("Geo", list1(iface_method("area")), teko::list::empty())
    let ifc_named2 = iface_item("Named2", list1(iface_method("label")), teko::list::empty())
    let sq2 = impl_class_item("Sq2", teko::list::push(list1(impl_method("area", parser::Visibility::Pub)), impl_method("label", parser::Visibility::Pub)), teko::list::push(teko::list::push(teko::list::empty(), "Geo"), "Named2"))
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAnd { left = parser::ConstraintAtom { name = "Geo" }; right = parser::ConstraintAtom { name = "Named2" } })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::MethodCall { receiver = e_var("x"); method = body_method; args = teko::list::empty() }) })
    let f = parser::Function { name = "both"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    let fitem = parser::Item { content = f; namespace = ""; file = "" }
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc_geo), ifc_named2)
    items = teko::list::push(items, sq2)
    items = teko::list::push(items, fitem)
    parser::Program { items = items }
}

#test
/** crumb-7 fixture 1: `A&B`, a method of EACH side (`x.area()`) — accepted. */
fn s6_and_constraint_authorizes_either_sides_method() {
    teko::assert::is_true(tr_program_ok(s6_and_program("area").items))
}

#test
/** crumb-7 fixture 3: a member outside a SINGLE-interface constraint's surface (`label` is not on
    `Geo`) is rejected AT THE DEFINITION, independent of any instantiation. */
fn s6_single_constraint_rejects_member_outside_surface() {
    let ifc_geo = iface_item("Geo", list1(iface_method("area")), teko::list::empty())
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = "Geo" })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::MethodCall { receiver = e_var("x"); method = "label"; args = teko::list::empty() }) })
    let f = parser::Function { name = "bad"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    let items = teko::list::push(teko::list::push(teko::list::empty(), ifc_geo), parser::Item { content = f; namespace = ""; file = "" })
    teko::assert::is_true(!tr_program_ok(items))
}

#test
/** crumb-7 fixture 4: nominal mono-rejection is UNTOUCHED — a concrete arg conforming to only ONE
    side of `Geo & Named2` (missing `label`/`Named2`) still fails at `check_constraints`, the
    existing per-instance safety net (S6 adds no new instance-time check). */
fn s6_and_constraint_mono_rejects_non_conforming_concrete() {
    let ifc_geo = iface_item("Geo", list1(iface_method("area")), teko::list::empty())
    let ifc_named2 = iface_item("Named2", list1(iface_method("label")), teko::list::empty())
    let sq_geo_only = impl_class_item("SqGeoOnly", list1(impl_method("area", parser::Visibility::Pub)), slist1("Geo"))
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAnd { left = parser::ConstraintAtom { name = "Geo" }; right = parser::ConstraintAtom { name = "Named2" } })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::MethodCall { receiver = e_var("x"); method = "area"; args = teko::list::empty() }) })
    let f = parser::Function { name = "both2"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    let make_lit = ek(parser::StructLit { type_path = path1("SqGeoOnly"); type_args = teko::list::empty(); field_names = teko::list::empty(); field_vals = teko::list::empty() })
    let call = st(ek(parser::Call { callee = path1("both2"); args = teko::list::push(teko::list::empty(), make_lit); arg_names = pos_names(1) }))
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc_geo), ifc_named2)
    items = teko::list::push(items, sq_geo_only)
    items = teko::list::push(items, parser::Item { content = f; namespace = ""; file = "" })
    items = teko::list::push(items, parser::Item { content = call; namespace = ""; file = "" })
    teko::assert::is_true(!tr_program_ok(items))
}

/** crumb-7 fixture 2: `A|B` INTERSECTS by signature — `Geo | Named2Alt` (a 2nd interface ALSO
    declaring `area(self)->i64`, matching Geo's signature exactly) authorizes `area` (common to
    both branches) but NOT `label` (only on one branch). */
fn s6_or_program(body_method: str) -> parser::Program {
    let ifc_geo = iface_item("Geo", list1(iface_method("area")), teko::list::empty())
    let ifc_alt = iface_item("GeoAlt", list1(iface_method("area")), teko::list::empty())
    let sq2 = impl_class_item("SqAlt", list1(impl_method("area", parser::Visibility::Pub)), slist1("Geo"))
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintOr { left = parser::ConstraintAtom { name = "Geo" }; right = parser::ConstraintAtom { name = "GeoAlt" } })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::MethodCall { receiver = e_var("x"); method = body_method; args = teko::list::empty() }) })
    let f = parser::Function { name = "only_common"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
    let fitem = parser::Item { content = f; namespace = ""; file = "" }
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc_geo), ifc_alt)
    items = teko::list::push(items, sq2)
    items = teko::list::push(items, fitem)
    parser::Program { items = items }
}

#test
fn s6_or_constraint_authorizes_the_common_method() {
    teko::assert::is_true(tr_program_ok(s6_or_program("area").items))
}

#test
fn s6_or_constraint_rejects_a_method_outside_the_intersection() {
    teko::assert::is_true(!tr_program_ok(s6_or_program("label").items))
}

/**
 * (TR2, 2026-07-04) the compile-time FIELD VIEW — `deriver_field_view`. The compiler-internal,
 * deriver-agnostic enumeration of a struct/class's fields with each annotation resolved to a real
 * `Type` (name + type, no runtime value). See TEKO_ROADMAP_TRAITS.md TR2. TR3 (a later unit)
 * synthesizes structural-trait bodies (Eq/Ord/Hash/Clone/Default) from it.
 */
fn fv_field(name: str, type_ann: parser::TypeExpr) -> parser::Field { parser::Field { name = name; type_ann = type_ann; vis = parser::Visibility::Pub; is_intern = false } }
fn fv_struct_item(name: str, fields: []parser::Field) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn fv_struct_item_derives(name: str, fields: []parser::Field, derives: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = derives }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn fv_class_item(name: str, kind: parser::ClassKind, has_base: bool, base_name: str, fields: []parser::Field) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = kind; has_base = has_base; base_name = base_name; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = fields; methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}
fn fv_table(items: []parser::Item) -> TypeTable {
    match collect(parser::Program { items = items }) { Collected as c => c.types; error => panic("fv_table: collect failed") }
}

#test
/**
 * A plain struct's field view: names + RESOLVED types, in declaration order.
 */
fn field_view_struct_own_fields_with_types() {
    let fields = teko::list::push(teko::list::push(teko::list::empty(), fv_field("x", named_t("i64"))), fv_field("active", named_t("bool")))
    let table = fv_table(teko::list::push(teko::list::empty(), fv_struct_item("Point", fields)))
    let view = match deriver_field_view("Point", table) { []FieldView as v => v; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(view.len == 2)
    teko::assert::is_true(view[0].name == "x")
    teko::assert::is_true(type_eq(view[0].type, i64t()))
    teko::assert::is_true(view[1].name == "active")
    teko::assert::is_true(type_eq(view[1].type, boolt()))
}

#test
/**
 * `fold_traits` runs before the field view is ever consulted — a struct deriving a trait already
 * carries the trait's field in its OWN `fields` by the time `collect()` sees it.
 */
fn field_view_struct_includes_trait_folded_fields() {
    let tr = trait_item("Stamp", tr_fields1("at"), teko::list::empty())
    let dv = fv_struct_item_derives("Post", teko::list::push(teko::list::empty(), fv_field("title", named_t("str"))), slist1("Stamp"))
    let folded = match fold_traits(parser::Program { items = items2(tr, dv) }) { parser::Program as p => p; error => { teko::assert::is_true(false); return } }
    let table = fv_table(folded.items)
    let view = match deriver_field_view("Post", table) { []FieldView as v => v; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(view.len == 2)
    teko::assert::is_true(view[0].name == "title")
    teko::assert::is_true(view[1].name == "at")
    teko::assert::is_true(type_eq(view[1].type, i64t()))
}

#test
/**
 * A class's view walks the FULL base chain (`effective_class_fields`) — base fields first, then
 * the derived class's own, exactly like construction/field-access already sees it.
 */
fn field_view_class_includes_base_chain_fields() {
    let base = fv_class_item("Animal", parser::ClassKind::Virtual, false, "", teko::list::push(teko::list::empty(), fv_field("name", named_t("str"))))
    let derived = fv_class_item("Dog", parser::ClassKind::Sealed, true, "Animal", teko::list::push(teko::list::empty(), fv_field("breed", named_t("str"))))
    let table = fv_table(items2(base, derived))
    let view = match deriver_field_view("Dog", table) { []FieldView as v => v; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(view.len == 2)
    teko::assert::is_true(view[0].name == "name")
    teko::assert::is_true(view[1].name == "breed")
}

#test
/**
 * A field typed as another user struct resolves to `Named{that struct}`, not left as a bare
 * source `TypeExpr` — this is exactly what a synthesized Eq/Hash needs to recurse per field.
 */
fn field_view_nested_named_field_resolves() {
    let inner = fv_struct_item("Address", teko::list::push(teko::list::empty(), fv_field("city", named_t("str"))))
    let outer = fv_struct_item("Person", teko::list::push(teko::list::empty(), fv_field("home", named_t("Address"))))
    let table = fv_table(items2(inner, outer))
    let view = match deriver_field_view("Person", table) { []FieldView as v => v; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(view.len == 1)
    teko::assert::is_true(view[0].name == "home")
    match view[0].type { Named as n => teko::assert::is_true(n.name == "Address"); _ => teko::assert::is_true(false) }
}

#test
fn field_view_unknown_deriver_is_error() {
    let table = fv_table(teko::list::push(teko::list::empty(), fv_struct_item("Solo", teko::list::empty())))
    match deriver_field_view("Ghost", table) { []FieldView => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
/**
 * An enum has no field shape — the view must refuse it (TR3 can only synthesize field-wise
 * bodies for a struct/class deriver).
 */
fn field_view_non_struct_or_class_is_error() {
    let table = color_enum_table()
    match deriver_field_view("Color", table) { []FieldView => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

/** An empty TypeTable — the DI pass keys its registry by source interface names, never touching
 *  the table, so DI unit tests need no `collect` (which would reject the deliberately dangling
 *  interface names these fixtures use). */
fn di_empty_table() -> TypeTable { teko::list::empty() }

/** A `#lifetime` DI class item: a class with a no-arg static factory `make` and an implements list. */
fn di_class_item(name: str, kind: parser::DiKind, implements: []str) -> parser::Item {
    let methods = teko::list::push(teko::list::empty(), impl_static_method("make", parser::Visibility::Pub))
    let body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = implements; fields = teko::list::empty(); methods = methods }
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = kind; has_di_key = false; di_key = "" }; namespace = ""; file = "" }
}

/** A function item carrying a single `#inject(name: Type)` binding. */
fn di_inject_fn_item(fn_name: str, bind_name: str, bind_type: str) -> parser::Item {
    let binding = parser::InjectBinding { name = bind_name; type_ann = named_t(bind_type); has_key = false; key = ""; line = 7; col = 3 }
    let injects = teko::list::push(teko::list::empty(), binding)
    let f = parser::Function { name = fn_name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); has_return = false; return_type = named_t("i64"); body = teko::list::empty(); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = true; injects = injects }
    parser::Item { content = f; namespace = ""; file = "" }
}

#test
fn di_single_provider_registers_and_resolves() {
    let items = teko::list::push(teko::list::empty(), di_class_item("Logger", parser::DiKind::Singleton, teko::list::push(teko::list::empty(), "Log")))
    match build_di_registry(parser::Program { items = items }, di_empty_table()) {
        DiRegistry as reg => {
            teko::assert::is_true(reg.providers.len == 1)
            teko::assert::is_true(reg.providers[0].iface == "Log")
            teko::assert::is_true(reg.providers[0].impl_name == "Logger")
            teko::assert::is_true(reg.providers[0].factory == "make")
            match resolve_provider(reg, "Log") { DiProvider as p => teko::assert::is_true(p.kind == parser::DiKind::Singleton); error => teko::assert::is_true(false) }
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn di_duplicate_registration_is_error() {
    let a = di_class_item("LoggerA", parser::DiKind::Singleton, teko::list::push(teko::list::empty(), "Log"))
    let b = di_class_item("LoggerB", parser::DiKind::Scoped, teko::list::push(teko::list::empty(), "Log"))
    let items = teko::list::push(teko::list::push(teko::list::empty(), a), b)
    match build_di_registry(parser::Program { items = items }, di_empty_table()) { DiRegistry => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn di_missing_provider_is_error() {
    let fn_item = di_inject_fn_item("handle", "log", "Log")
    let items = teko::list::push(teko::list::empty(), fn_item)
    match check_di(parser::Program { items = items }, di_empty_table()) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn di_inject_with_registered_provider_is_accepted() {
    let cls = di_class_item("Logger", parser::DiKind::Singleton, teko::list::push(teko::list::empty(), "Log"))
    let fn_item = di_inject_fn_item("handle", "log", "Log")
    let items = teko::list::push(teko::list::push(teko::list::empty(), cls), fn_item)
    match check_di(parser::Program { items = items }, di_empty_table()) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

#test
fn di_lifetime_on_non_class_is_error() {
    let te = teko::list::push(teko::list::empty(), fv_field("x", named_t("i64")))
    let bad = fv_struct_item("Thing", te)
    let items = teko::list::push(teko::list::empty(), with_struct_di_singleton(bad))
    match build_di_registry(parser::Program { items = items }, di_empty_table()) { DiRegistry => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

/** Attach `#singleton` to a struct item (an illegal placement the DI pass must reject). */
fn with_struct_di_singleton(item: parser::Item) -> parser::Item {
    match item.content {
        parser::TypeDecl as td => parser::Item { content = parser::TypeDecl { name = td.name; type_params = td.type_params; type_constraints = td.type_constraints; body = td.body; vis = td.vis; has_doc = td.has_doc; doc = td.doc; line = td.line; col = td.col; di_kind = parser::DiKind::Singleton; has_di_key = false; di_key = "" }; namespace = item.namespace; file = item.file }
        _ => item
    }
}

#test
fn di_use_lowers_to_materializer_call() {
    let ib = DiInjectBind { name = "log"; iface = "Log"; impl_name = "Logger"; kind = parser::DiKind::Singleton }
    let te = di_lower_use(ib, Named { name = "Log" })
    match te.kind {
        TCall as c => {
            teko::assert::is_true(c.callee.segments.len == 1)
            teko::assert::is_true(c.callee.segments[0].name == "__di_materialize_Logger")
            teko::assert::is_true(c.args.len == 0)
            teko::assert::is_false(c.is_iface_dispatch)
        }
        _ => teko::assert::is_true(false)
    }
    teko::assert::is_true(is_di_materializer_call("__di_materialize_Logger"))
    teko::assert::is_false(is_di_materializer_call("make"))
}

#test
fn di_materializer_name_is_impl_prefixed() {
    teko::assert::is_true(di_materializer_name("Logger") == "__di_materialize_Logger")
}
