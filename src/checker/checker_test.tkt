}

// ---------------------------------------------------------------------------
// Group H: type_safe_field_access, type_coalesce
// ---------------------------------------------------------------------------
#test
fn checker_safe_field_and_coalesce() {
    // type_safe_field_access — ms?.token where ms: Foo? → u8?
    let opt_foo_env = define(empty_env(), "ms", Optional { inner = Named { name = "Foo" } }, false)
    let sfa = parser::SafeFieldAccess { receiver = e_var("ms"); field = "token" }
    let sfar = match type_safe_field_access(sfa, opt_foo_env, foo_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match sfar.type { Optional as o => match o.inner { Prim as p => teko::assert::is_true(p.kind == PrimKind::U8); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    // type_coalesce — os ?? "default" where os: str? → str
    let opt_str_env = define(empty_env(), "os", Optional { inner = Str { } }, false)
    let co = parser::Coalesce { left = e_var("os"); right = e_str("default") }
    let cor = match type_coalesce(co, opt_str_env, empty_table()) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    match cor.type { Str => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group I: render_func, render_members, union_collect
// ---------------------------------------------------------------------------
#test
fn checker_render_and_join() {
    // render_members directly — two-member variant renders with " | "
    let m1: []Type = teko::list::push(teko::list::empty(), i64t())
    let m2: []Type = teko::list::push(m1, Str { })
    let rms = render_members(m2)
    teko::assert::is_true(teko::str::contains(rms, "|"))
    // render_func directly — "(i64) -> str"
    let fparams: []Type = teko::list::push(teko::list::empty(), i64t())
    let rf = render_func(Func { params = fparams; ret = Str { } ; variadic = false ; param_names = []; n_required = (fparams).len; defaults = [] })
    teko::assert::is_true(teko::str::contains(rf, "->"))
    // union_collect directly — accumulate two types
    let acc1 = union_collect(teko::list::empty(), i64t(), empty_table())
    teko::assert::is_true(acc1.len == 1)
    let acc2 = union_collect(acc1, Str { }, empty_table())
    teko::assert::is_true(acc2.len == 2)
    // dedup: same type twice → still length 1
    let acc3 = union_collect(teko::list::empty(), i64t(), empty_table())
    let acc4 = union_collect(acc3, i64t(), empty_table())
    teko::assert::is_true(acc4.len == 1)
}

// ---------------------------------------------------------------------------
// Group J: lbl_eq, lbl_enclosing, surface_at
// ---------------------------------------------------------------------------
#test
fn checker_label_surface() {
    // lbl_eq
    teko::assert::is_true(lbl_eq("outer", "outer"))
    teko::assert::is_false(lbl_eq("outer", "inner"))
    // lbl_enclosing
    let scope: []str = teko::list::push(teko::list::push(teko::list::empty(), "outer"), "inner")
    teko::assert::is_true(lbl_enclosing(scope, "outer"))
    teko::assert::is_true(lbl_enclosing(scope, "inner"))
    teko::assert::is_false(lbl_enclosing(scope, "missing"))
    // surface_at
    let e = error { message = "test error" }
    let surfaced = surface_at("test.tks", 3, 7, e)
    teko::assert::is_true(teko::str::contains(surfaced.message, "test.tks"))
}

// ---------------------------------------------------------------------------
// Group K: check_node_type, rederive_binary, validate_each (revalidate helpers)
// ---------------------------------------------------------------------------
#test
fn checker_revalidate_helpers() {
    // check_node_type — match/mismatch
    match check_node_type(i64t(), i64t()) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match check_node_type(i64t(), u32t()) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // rederive_binary
    match rederive_binary(i64t(), i64t(), lexer::TokenKind::Plus) { Type as t => teko::assert::is_true(type_eq(t, i64t())); error => teko::assert::is_true(false) }
    match rederive_binary(i64t(), i64t(), lexer::TokenKind::Percent) { Type as t => teko::assert::is_true(type_eq(t, i64t())); error => teko::assert::is_true(false) }
    match rederive_binary(boolt(), boolt(), lexer::TokenKind::Plus) { Type => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // validate_each — list of valid TNumber nodes
    let e1 = TExpr { kind = TNumber { is_float = false; value = 1; fval = 0.0 }; type = i64t(); line = 0; col = 0 }
    let e2 = TExpr { kind = TNumber { is_float = false; value = 2; fval = 0.0 }; type = i64t(); line = 0; col = 0 }
    let xs: []TExpr = teko::list::push(teko::list::push(teko::list::empty(), e1), e2)
    match validate_each(xs) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

// ---------------------------------------------------------------------------
// Group L: ns_last_seg, builtin_fn, find_in_ns, name_exists_anywhere,
//          alias_target, diag_at, join_n
// ---------------------------------------------------------------------------
#test
fn checker_scope_module_helpers() {
    // ns_last_seg
    teko::assert::is_true(ns_last_seg("teko::checker") == "checker")
    teko::assert::is_true(ns_last_seg("foo") == "foo")
    teko::assert::is_true(ns_last_seg("a::b::c") == "c")
    // builtin_fn — "slice" → a Func type (str::slice seed retained); unknown → error
    match builtin_fn("slice") { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("__nonexistent__") { Type => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // find_in_ns
    let t = foo_table()
    match find_in_ns(t, "Foo", "") { TypeReg as tr => teko::assert::is_true(tr.name == "Foo"); null => teko::assert::is_true(false) }
    match find_in_ns(t, "Bar", "") { TypeReg => teko::assert::is_true(false); null => teko::assert::is_true(true) }
    // name_exists_anywhere
    teko::assert::is_true(name_exists_anywhere(t, "Foo"))
    teko::assert::is_false(name_exists_anywhere(t, "Baz"))
    // alias_target
    let al: []AliasBind = teko::list::push(teko::list::empty(), AliasBind { ns = "teko::checker"; alias = "prs"; target = "teko::parser" })
    teko::assert::is_true(alias_target(al, "teko::checker", "prs") == "teko::parser")
    teko::assert::is_true(alias_target(al, "teko::checker", "nope") == "")
    // diag_at
    let m1 = diag_at("foo.tks", 3, 5, "err here")
    teko::assert::is_true(teko::str::contains(m1, "foo.tks"))
    teko::assert::is_true(teko::str::contains(m1, "err here"))
    teko::assert::is_true(diag_at("", 0, 0, "bare") == "bare")
    // join_n
    let segs: []parser::Segment = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "teko" }), parser::Segment { name = "checker" })
    let p = parser::Path { segments = segs }
    teko::assert::is_true(join_n(p, 0) == "")
    teko::assert::is_true(join_n(p, 1) == "teko")
    teko::assert::is_true(join_n(p, 2) == "teko::checker")
}

// --- ROUND 0: chars / len_chars builtin type checks ---
// Verify that the scope.c (and scope.tks) registrations produce the correct Func types and
// that type_call resolves them end-to-end to the right return types.
#test
fn types_chars_and_len_chars_builtins() {
    // builtin_fn("chars")     → Func type; builtin_fn("len_chars") → Func type.
    match builtin_fn("chars")     { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("len_chars") { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    // type_call: chars("abc") must type as []char (Slice { element = Char {} }).
    let str_args: []parser::Expr = teko::list::push(teko::list::empty(), e_str("abc"))
    let tc = match type_call(parser::Call { callee = path1("chars"); args = str_args; arg_names = pos_names(str_args.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    match tc.type { Slice as sl => match sl.element { Char => teko::assert::is_true(true); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    // type_call: len_chars("abc") must type as i64.
    let str_args2: []parser::Expr = teko::list::push(teko::list::empty(), e_str("abc"))
    let tlc = match type_call(parser::Call { callee = path1("len_chars"); args = str_args2; arg_names = pos_names(str_args2.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    teko::assert::is_true(prim_is(tlc.type, PrimKind::I64))
}

// --- ROUND 0: char_at / str_slice_chars / is_alpha / is_digit / is_space / to_lower / to_upper ---
// Verify scope registrations + type_call return types for the new UTF-8 codepoint builtins.
#test
fn types_round0_char_ops_builtins() {
    // builtin_fn registrations exist for all 7 new names.
    match builtin_fn("char_at")         { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("str_slice_chars") { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("is_alpha")        { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("is_digit")        { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("is_space")        { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("to_lower")        { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    match builtin_fn("to_upper")        { Type => teko::assert::is_true(true); error => teko::assert::is_true(false) }

    // type_call: char_at("hello", 1i64) must type as char.
    let str_i64_args: []parser::Expr = teko::list::push(teko::list::push(teko::list::empty(), e_str("hello")), e_num(1))
    let tca = match type_call(parser::Call { callee = path1("char_at"); args = str_i64_args; arg_names = pos_names(str_i64_args.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    match tca.type { Char => teko::assert::is_true(true); _ => teko::assert::is_true(false) }

    // type_call: str_slice_chars("hello", 1i64, 3i64) must type as str.
    let ssc_args: []parser::Expr = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), e_str("hello")), e_num(1)), e_num(3))
    let tssc = match type_call(parser::Call { callee = path1("str_slice_chars"); args = ssc_args; arg_names = pos_names(ssc_args.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    match tssc.type { Str => teko::assert::is_true(true); _ => teko::assert::is_true(false) }

    // type_call: is_alpha(char_literal) must type as bool.
    let char_args: []parser::Expr = teko::list::push(teko::list::empty(), ek(parser::CharLit { bytes = "a" }))
    let tia = match type_call(parser::Call { callee = path1("is_alpha"); args = char_args; arg_names = pos_names(char_args.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    teko::assert::is_true(prim_is(tia.type, PrimKind::Bool))

    // type_call: to_lower(char_literal) must type as char.
    let char_args2: []parser::Expr = teko::list::push(teko::list::empty(), ek(parser::CharLit { bytes = "A" }))
    let ttl = match type_call(parser::Call { callee = path1("to_lower"); args = char_args2; arg_names = pos_names(char_args2.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    match ttl.type { Char => teko::assert::is_true(true); _ => teko::assert::is_true(false) }

    // type_call: to_upper(char_literal) must type as char.
    let char_args3: []parser::Expr = teko::list::push(teko::list::empty(), ek(parser::CharLit { bytes = "a" }))
    let ttu = match type_call(parser::Call { callee = path1("to_upper"); args = char_args3; arg_names = pos_names(char_args3.len) }, empty_env(), empty_table()) {
        TExpr as e => e
        error => { teko::assert::is_true(false); return }
    }
    match ttu.type { Char => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
}

// (S4) generics inference primitives — subst_type / unify / collect_sig_type_params.
#test
fn subst_unify_inference() {
    let tbl: TypeTable = teko::list::empty()
    let params: []str = teko::list::push(teko::list::empty(), "T")
    let s0 = Subst { params = params; names = teko::list::empty(); types = teko::list::empty() }
    let patT: Type = Named { name = "T" }

    // unify Named{T} ~ i64 binds T=i64; subst_type then yields i64.
    let s1 = match unify(patT, i64t(), s0, tbl) { Subst as x => x; error => s0 }
    teko::assert::is_true(prim_is(subst_type(patT, s1), PrimKind::I64))
    // a non-type-param Named passes through subst unchanged.
    teko::assert::is_true(match subst_type(Named { name = "Other" }, s1) { Named as n => n.name == "Other"; _ => false })

    // unify []T ~ []str binds T=str; subst []T → []str (structural recursion).
    let patSlice: Type = Slice { element = Named { name = "T" } }
    let s2 = match unify(patSlice, Slice { element = Str { } }, s0, tbl) { Subst as x => x; error => s0 }
    teko::assert::is_true(match subst_type(patSlice, s2) { Slice as sl => match sl.element { Str => true; _ => false }; _ => false })

    // a Void-sentinel arg (empty()/null) cannot pin a type-param → unify errors.
    teko::assert::is_true(match unify(patSlice, Slice { element = Void { } }, s0, tbl) { Subst => false; error => true })

    // collect_sig_type_params over Func{(T) -> T} → ["T"] (deduped).
    let sig: Type = Func { params = teko::list::push(teko::list::empty(), Named { name = "T" }); ret = Named { name = "T" } ; variadic = false ; param_names = []; n_required = (teko::list::push(teko::list::empty(), Named { name = "T" })).len; defaults = [] }
    let tps = collect_sig_type_params(sig, tbl, teko::list::empty())
    teko::assert::is_true(tps.len == 1)
    teko::assert::is_true(tps[0] == "T")
}

// (S4 type-generics) a single-segment NamedType type-expr with no args.
fn ttype_named(name: str) -> parser::TypeExpr {
    parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }; args = teko::list::empty() }
}
// a table with one GENERIC struct decl: `type Box<T> = struct { value: T }`.
fn box_generic_table() -> TypeTable {
    let fld = parser::Field { name = "value"; type_ann = ttype_named("T") ; vis = parser::Visibility::Pub; is_intern = false }
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld) ; methods = teko::list::empty() }
    let decl = parser::TypeDecl { name = "Box"; type_params = teko::list::push(teko::list::empty(), "T"); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    teko::list::push(teko::list::empty(), TypeReg { name = "Box"; namespace = ""; vis = parser::Visibility::Private; decl = decl })
}

// (S4 type-generics) resolve_type on `Box<i64>` → Named{Box__g__i64}; arity is validated; the
// mangle helpers produce the shared instance name.
#test
fn resolves_generic_type_instantiation() {
    let tbl = box_generic_table()
    // Box<i64> → Named{"Box__g__i64"}
    let one = teko::list::push(teko::list::empty(), ttype_named("i64"))
    let inst = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = one }
    teko::assert::is_true(match resolve_type(inst, tbl) { Named as n => n.name == "Box__g__i64"; error => false; _ => false })

    // wrong arity Box<i64, str> → error
    mut two: []parser::TypeExpr = teko::list::push(teko::list::empty(), ttype_named("i64"))
    two = teko::list::push(two, ttype_named("str"))
    let inst2 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = two }
    teko::assert::is_true(match resolve_type(inst2, tbl) { error => true; _ => false })

    // a plain `Box` (no args) still resolves nominally — no regression.
    teko::assert::is_true(match resolve_type(ttype_named("Box"), tbl) { Named as n => n.name == "Box"; error => false; _ => false })

    // generic_inst_name / type_mangle directly: Box + [i64, str] → "Box__g__i64__str".
    mut at: []Type = teko::list::push(teko::list::empty(), i64t())
    at = teko::list::push(at, Str { })
    teko::assert::is_true(generic_inst_name("Box", at) == "Box__g__i64__str")
}

// (S-mem) `ptr<T>` — typed pointer: resolves to Ptr{inner}, opaque ptr = Ptr{null}, equal-by-inner.
#test
fn resolves_ptr_generic() {
    let ptr_i64 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "ptr" }) }; args = teko::list::push(teko::list::empty(), ttype_named("i64")) }
    let pi = match resolve_type(ptr_i64, empty_table()) { Type as t => t; error => { teko::assert::is_true(false); return } }
    // STRUCTURE (VM-safe): ptr<i64> → Ptr{inner present = i64}; opaque ptr = Ptr{inner null}; distinct.
    // (exact `ptr_i64`/`ptr<i64>` mangle/render is verified via real codegen, not here — the VM drops
    // a self-recursive match arm's string prefix; see selfhost-vm-perf.)
    teko::assert::is_true(match pi { Ptr as p => match p.inner { null => false; Type as t => match t { Prim => true; _ => false } }; _ => false })
    teko::assert::is_true(type_eq(pi, pi))
    let bare = match resolve_type(ttype_named("ptr"), empty_table()) { Type as t => t; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(match bare { Ptr as p => match p.inner { null => true; Type => false }; _ => false })   // opaque ptr = null inner
    teko::assert::is_true(!type_eq(bare, pi))   // opaque ptr ≠ ptr<i64>
}

// (MEM-1b) the builtin generic `ref<T>` resolves to the safe reference `Ref{inner}` — never null,
// no opaque/bare form, `ref<void>` rejected. Structure-only assertions (VM-safe; exact mangle/render
// is verified via real codegen — the VM drops a self-recursive match arm's string prefix).
#test
fn resolves_ref_generic() {
    let ref_i64 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Ref" }) }; args = teko::list::push(teko::list::empty(), ttype_named("i64")) }
    let ri = match resolve_type(ref_i64, empty_table()) { Type as t => t; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(match ri { Reference as r => match r.inner { Prim => true; _ => false }; _ => false })   // Ref<i64> = Reference{inner = i64}
    teko::assert::is_true(type_eq(ri, ri))
    // NOTE: `ref<i64> ≠ ptr<i64>` (and `ref<i64> ≠ i64`) holds NATIVELY (tag discrimination) but is
    // NOT asserted here — the VM's transparent-field-descent matches a single-field wrapper by its
    // INNER type against an earlier same-inner arm (Ref/Ptr/Optional/Slice all collapse to `inner`),
    // so VM `type_eq(ref<i64>, ptr<i64>)` is unreliable. The native engine verifies distinctness.
    // `Ref<void>` is invalid — void is not a value.
    let ref_void = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Ref" }) }; args = teko::list::push(teko::list::empty(), ttype_named("void")) }
    teko::assert::is_true(match resolve_type(ref_void, empty_table()) { error => true; _ => false })
    // bare `Ref` (no type argument) is invalid.
    teko::assert::is_true(match resolve_type(ttype_named("Ref"), empty_table()) { error => true; _ => false })
}

// ---------------------------------------------------------------------------
// MEM Step 0 — the checker ESCAPE GATE. A `Ref<T>` is memory-safe BY CONSTRUCTION: the ONLY
// permitted flow is PARAMETER PASS-DOWN. These tests drive the checker functions DIRECTLY,
// asserting each forbidden position yields `error` and the allowed forms still succeed.
// Structure/error-only assertions (VM-safe; no message-string match — the VM drops a
// self-recursive match arm's string prefix; mirrors resolves_ref_generic's discipline).
// ---------------------------------------------------------------------------

// a `Ref<INNER>` type-expr where INNER is itself a (hand-built) type-expr.
fn ref_te_of(inner: parser::TypeExpr) -> parser::TypeExpr {
    parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Ref" }) }; args = teko::list::push(teko::list::empty(), inner) }
}
// a `Ref<NAME>` type-expr over a plain named type.
fn ref_te(name: str) -> parser::TypeExpr { ref_te_of(ttype_named(name)) }

// (W9a) NON-SCALAR inner — a `Ref<T>` may target any VALUE TYPE (Prim, Byte, Str, struct/Named,
// slice, optional, variant), NOT just a scalar prim. Teko has NO field/index assignment, so a
// non-scalar ref is only ever WHOLE-`.value`-replaced + read — observationally identical to a scalar
// ref under the cell-identity model (VM == native). REJECT only the non-values / aliasing hazards:
// `Ref<void>` (not a value), `Ref<Ref<i64>>` (ref-to-ref), `Ref<ptr<i64>>` (raw FFI).
#test
fn mem_ref_nonscalar_inner_allowed() {
    // Ref<i64> (a scalar prim) → Reference. (allowed) — descend like resolves_ref_generic (VM-safe).
    teko::assert::is_true(match resolve_type(ref_te("i64"), empty_table()) { Reference as r => match r.inner { Prim => true; _ => false }; _ => false })
    // Ref<Foo> (a struct/Named inner) → Reference. (ALLOWED under W9a) — inner is a Named (VM-reliable).
    teko::assert::is_true(match resolve_type(ref_te("Foo"), foo_table()) { Reference as r => match r.inner { Named => true; _ => false }; _ => false })
    // Ref<[]i64> (a slice inner) → Reference. (ALLOWED under W9a) — assert the OUTER tag only; the inner
    // is a Slice (a single-field wrapper), so `match r.inner { Slice => }` is unreliable in the VM
    // (transparent-field-descent); the native engine verifies the inner Slice.
    teko::assert::is_true(match resolve_type(ref_te_of(parser::SliceType { element = ttype_named("i64") }), empty_table()) { Reference => true; _ => false })
    // Ref<void> → error (void is not a value).
    teko::assert::is_true(match resolve_type(ref_te("void"), empty_table()) { error => true; _ => false })
    // Ref<Ref<i64>> → error (no ref-to-ref). The inner resolves to a Reference, which R1 rejects —
    // VM-reliable: the inner type-expr `Ref<i64>` is itself resolved, hits the Reference reject arm.
    teko::assert::is_true(match resolve_type(ref_te_of(ref_te("i64")), empty_table()) { error => true; _ => false })
    // NOTE: Ref<i64?> (optional inner) is ALSO allowed under W9a but NOT asserted in the VM — a
    // CONSTRUCTED Reference{inner=Optional} cannot be discriminated by the inner in the VM (the
    // transparent-field-descent caveat); the native engine (`teko build`) verifies it. Ref<ptr<i64>>
    // is rejected NATIVELY (inner tag == TK_TYPE_PTR); the VM cannot construct a ptr<i64> inner here.
}

// (MEM Step 0, R2) NOT NULLABLE — `Ref<…>?` is an error.
// VM NOTE: a CONSTRUCTED `Ref<value>` cannot be discriminated in the VM (the VM's transparent-
// field-descent collapses a single-field wrapper to its inner — and a constructed Reference VALUE
// matched in a multi-arm match is unreliable), so an isolated `Ref<i64>?` rejection (driven by the
// OptionalType arm's `Reference => error`) is observable only NATIVELY (the C twin's
// `in.tag == TK_TYPE_REF` check + the native self-host enforce it). To assert the OPTIONAL position
// is gated in the VM too, we use a CONSTRUCTION-REJECTED inner (`Ref<Ref<i64>>`): the inner
// `Ref<i64>` resolves, then R1 rejects `Ref<Ref<…>>` at CONSTRUCTION (VM-reliable — matching a
// resolved Reference type-VALUE in resolve_generic_inst), so the error propagates out of the
// OptionalType arm before it ever needs to match a constructed Reference.
#test
fn mem_ref_not_nullable() {
    let ref_opt = parser::OptionalType { inner = ref_te_of(ref_te("i64")) }   // Ref<Ref<i64>>?
    teko::assert::is_true(match resolve_type(ref_opt, empty_table()) { error => true; _ => false })
}

// (MEM Step 0, R3) NOT a RETURN type — a function returning a reference is an error; the same fn
// returning i64 type-checks. VM NOTE (see R2): the value-inner `-> Ref<i64>` rejection (driven by
// typer's `match ret { Reference => error }`) is checked NATIVELY by the C twin (`ret.tag ==
// TK_TYPE_REF`) + native self-host; here a CONSTRUCTION-REJECTED inner (`-> Ref<Ref<i64>>`) makes
// R1 reject the return type VM-reliably (at resolve_generic_inst), proving the return position is gated.
#test
fn mem_ref_not_return_type() {
    let body = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_num(0) })
    match type_function(mk_fn("f", ref_te_of(ref_te("i64")), body), empty_env(), empty_table()) { TFunction => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let body2 = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_num(0) })
    match type_function(mk_fn("f", named_t("i64"), body2), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

// (MEM Step 0, R4) NOT a STRUCT FIELD — a `struct { r: Ref<…> }` is rejected at collect
// (validate_type_decls); a struct with a scalar field collects fine. VM NOTE (see R2): the field
// uses a CONSTRUCTION-REJECTED inner (`Ref<Ref<i64>>`) so R1's VM-reliable rejection drives the
// collect error; the value-inner field (`Ref<i64>`) is rejected NATIVELY by the C twin's
// `tag == TK_TYPE_REF` check in the bare-position field validation.
#test
fn mem_ref_not_struct_field() {
    let fld = parser::Field { name = "r"; type_ann = ref_te_of(ref_te("i64")) ; vis = parser::Visibility::Pub; is_intern = false }   // Ref<Ref<i64>>
    let decl = parser::TypeDecl { name = "Holder"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld) ; methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = decl; namespace = ""; file = "" })
    teko::assert::is_true(match collect(parser::Program { items = items }) { error => true; _ => false })
    // a plain scalar field collects without error.
    let okfld = parser::Field { name = "n"; type_ann = named_t("i64") ; vis = parser::Visibility::Pub; is_intern = false }
    let okdecl = parser::TypeDecl { name = "Holder2"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), okfld) ; methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let okitems: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = okdecl; namespace = ""; file = "" })
    teko::assert::is_true(match collect(parser::Program { items = okitems }) { Collected => true; _ => false })
}

// (MEM Step 0, R4) NOT a SLICE ELEMENT / VARIANT MEMBER — `[]Ref<…>` and `Ref<…> | T` reject.
// VM NOTE (see R2): a CONSTRUCTION-REJECTED inner (`Ref<Ref<i64>>`) so R1's VM-reliable rejection
// drives the error out of the SliceType / UnionType arm; the value-inner element/member
// (`[]Ref<i64>` / `Ref<i64> | T`) is rejected NATIVELY by the C twin's `el.tag == TK_TYPE_REF` /
// `m.tag == TK_TYPE_REF` checks.
#test
fn mem_ref_not_collection_or_variant() {
    // []Ref<Ref<i64>> → error.
    teko::assert::is_true(match resolve_type(parser::SliceType { element = ref_te_of(ref_te("i64")) }, empty_table()) { error => true; _ => false })
    // Ref<Ref<i64>> | i64 → error (a reference may not be a variant member).
    let members: []parser::TypeExpr = teko::list::push(teko::list::push(teko::list::empty(), ref_te_of(ref_te("i64"))), ttype_named("i64"))
    teko::assert::is_true(match resolve_type(parser::UnionType { members = members }, empty_table()) { error => true; _ => false })
}

// (MEM Step 0, R5) NOT a let/mut/const BINDING type — `let r: Ref<…> = …` is an error; a scalar
// binding still succeeds. VM NOTE (see R2): a CONSTRUCTION-REJECTED inner (`Ref<Ref<i64>>`) so R1's
// VM-reliable rejection drives the binding-annotation error; the value-inner local
// (`let r: Ref<i64>`) is rejected NATIVELY by the C twin's `bound.tag == TK_TYPE_REF` check in
// type_binding (type_contains_ref / R5).
#test
fn mem_ref_not_binding_type() {
    let env = define(empty_env(), "src", i64t(), true)
    let bad = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "r" }; has_type = true; type_ann = ref_te_of(ref_te("i64")); value = e_var("src") }
    match type_binding(bad, env, empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // a plain scalar binding still type-checks.
    let okb = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "n" }; has_type = true; type_ann = named_t("i64"); value = e_num(0) }
    match type_binding(okb, empty_env(), empty_table()) { TypedStmt => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

// (MEM Step 0, ALLOWED) a `Ref<i64>` function PARAMETER type-checks — the one permitted ref
// position (parameter pass-down). Build `fn f(r: Ref<i64>) -> i64 { 0 }` directly.
#test
fn mem_ref_param_allowed() {
    let p = parser::Param { name = "r"; has_type = true; type_ann = ref_te("i64"); is_params = false ; has_default = false; default_expr = e_num(0) }
    let params = teko::list::push(teko::list::empty(), p)
    let body = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_num(0) })
    let f = parser::Function { name = "f"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false }
    match type_function(f, empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

// (MEM Step 0, R4 — INFERRED) the HOLE: an unannotated array LITERAL whose elements are references
// (e.g. `let xs = [r, r]`) must be rejected even with NO `: []Ref<…>` annotation. We drive
// type_array_lit DIRECTLY with `[r, r]` over an env where `r : Reference{inner}` — the joined
// element type is a bare `Reference`, so type_contains_ref(et) fires and the literal is `error`.
// VM-safe: `et` is a BARE Reference (type_join of two equal Refs returns the Ref), so the match
// hits the `Reference => true` arm directly (no cross-wrapper descent ambiguity). A normal scalar
// array `[1, 2, 3]` still type-checks to `[]i64`. This is the adversarial-probe regression test.
#test
fn mem_ref_not_inferred_array_element() {
    // an env where `r` is a reference (the kind a `Ref<i64>` parameter binds in a real body).
    let env = define(empty_env(), "r", Reference { inner = i64t() }, false)
    let two = teko::list::push(teko::list::push(teko::list::empty(), parser::ArrayElem { is_spread = false; expr = e_var("r") }), parser::ArrayElem { is_spread = false; expr = e_var("r") })
    // `[r, r]` — an INFERRED ref collection → error (no annotation needed).
    match type_array_lit(parser::ArrayLit { elements = two }, env, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // positive control: a plain scalar array `[1, 2, 3]` still type-checks to a slice.
    mut nums: []parser::ArrayElem = teko::list::empty()
    nums = teko::list::push(nums, parser::ArrayElem { is_spread = false; expr = e_num(1) })
    nums = teko::list::push(nums, parser::ArrayElem { is_spread = false; expr = e_num(2) })
    nums = teko::list::push(nums, parser::ArrayElem { is_spread = false; expr = e_num(3) })
    match type_array_lit(parser::ArrayLit { elements = nums }, empty_env(), empty_table()) {
        TExpr as te => teko::assert::is_true(match te.type { Slice => true; _ => false })
        error => teko::assert::is_true(false)
    }
}

// (MEM Step 0, R4 — `in`) the `in` operator has its OWN element path (it does NOT build an
// ArrayLit), so `a in [a, b]` over reference operands must be rejected by type_in's own gate.
// Driven directly: `r in [r]` over an env where `r : Reference` → error. A scalar `n in [n]`
// still type-checks to bool.
#test
fn mem_ref_not_in_operand() {
    let env = define(empty_env(), "r", Reference { inner = i64t() }, false)
    let set = teko::list::push(teko::list::empty(), e_var("r"))
    match type_in(parser::InExpr { lhs = e_var("r"); elems = set }, env, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // positive control: a scalar `in` still type-checks to bool.
    let nenv = define(empty_env(), "n", i64t(), false)
    let nset = teko::list::push(teko::list::empty(), e_var("n"))
    match type_in(parser::InExpr { lhs = e_var("n"); elems = nset }, nenv, empty_table()) {
        TExpr as te => teko::assert::is_true(match te.type { Prim as p => p.kind == PrimKind::Bool; _ => false })
        error => teko::assert::is_true(false)
    }
}

// (MEM Step 0, R5 — INFERRED) a binding whose value INFERS to a ref collection is rejected even
// without an annotation: `let xs = [r, r]` flows through type_array_lit (rejected) within
// type_binding. The bound-type contains-ref gate also guards a hand-built ref-collection value.
// A plain scalar binding `let n = 0` still type-checks.
#test
fn mem_ref_not_inferred_binding() {
    let env = define(empty_env(), "r", Reference { inner = i64t() }, false)
    let two = teko::list::push(teko::list::push(teko::list::empty(), parser::ArrayElem { is_spread = false; expr = e_var("r") }), parser::ArrayElem { is_spread = false; expr = e_var("r") })
    let arr = ek(parser::ArrayLit { elements = two })
    let bad = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "xs" }; has_type = false; type_ann = named_t("i64"); value = arr }
    match type_binding(bad, env, empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // positive control: a plain scalar binding still type-checks.
    let okb = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "n" }; has_type = false; type_ann = named_t("i64"); value = e_num(0) }
    match type_binding(okb, empty_env(), empty_table()) { TypedStmt => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

// (S4 type-generics) the instantiation pass stamps a concrete decl for a written `Box<i64>` use.
#test
fn instantiate_types_stamps_concrete_decl() {
    let tbl = box_generic_table()   // generic `Box<T> = struct { value: T }`
    // a program with `type Node = struct { b: Box<i64> }` — a written Box<i64> use site.
    let boxi64 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = teko::list::push(teko::list::empty(), ttype_named("i64")) }
    let fld = parser::Field { name = "b"; type_ann = boxi64 ; vis = parser::Visibility::Pub; is_intern = false }
    let node = parser::TypeDecl { name = "Node"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld) ; methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = node; namespace = ""; file = "" })
    let ext = instantiate_types(parser::Program { items = items }, tbl)
    // Box__g__i64 = struct { value: i64 } is now in the table (T substituted to i64).
    match type_table_find(ext, "Box__g__i64") {
        parser::TypeDecl as d => match d.body {
            parser::StructBody as sb => {
                teko::assert::is_true(sb.fields.len == 1)
                teko::assert::is_true(sb.fields[0].name == "value")
                teko::assert::is_true(match sb.fields[0].type_ann { parser::NamedType as n => n.path.segments.len == 1 && n.path.segments[0].name == "i64"; _ => false })
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

// (S4 type-generics) a generic struct constructor `Box { value = 42 }` under expected `Box<i64>`
// types as the concrete instance Box__g__i64, with the field value adopting i64 (annotation-driven).
#test
fn types_generic_struct_lit() {
    // stamp Box__g__i64 into the table via the instantiation pass (as a `Box<i64>` annotation would).
    let boxi64 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = teko::list::push(teko::list::empty(), ttype_named("i64")) }
    let node = parser::TypeDecl { name = "Node"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), parser::Field { name = "b"; type_ann = boxi64 ; vis = parser::Visibility::Pub; is_intern = false }) ; methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = node; namespace = ""; file = "" })
    let tbl = instantiate_types(parser::Program { items = items }, box_generic_table())
    let sl = parser::StructLit { type_path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; type_args = teko::list::empty(); field_names = teko::list::push(teko::list::empty(), "value"); field_vals = teko::list::push(teko::list::empty(), e_num(42)) }
    let r = match type_struct_lit(sl, Named { name = "Box__g__i64" }, empty_env(), tbl) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(match r.type { Named as n => n.name == "Box__g__i64"; _ => false })
    match r.kind { TStructInit as si => teko::assert::is_true(prim_is(si.field_vals[0].type, PrimKind::I64)); _ => teko::assert::is_true(false) }
}

// (W9.4) explicit construction-site type-args `Box<i64>{ value = 42 }` — NO annotation (expected=Void)
// — resolve to the concrete instance Box__g__i64 by themselves.
#test
fn types_struct_lit_explicit_type_args() {
    // stamp Box__g__i64 into the table (the instantiation pass walks the construction site's type-args,
    // but type_struct_lit is called directly here, so pre-stamp via a `Box<i64>`-bearing decl).
    let boxi64 = parser::NamedType { path = path1("Box"); args = teko::list::push(teko::list::empty(), ttype_named("i64")) }
    let node = parser::TypeDecl { name = "Node2"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), parser::Field { name = "b"; type_ann = boxi64 ; vis = parser::Visibility::Pub; is_intern = false }) ; methods = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = node; namespace = ""; file = "" })
    let tbl = instantiate_types(parser::Program { items = items }, box_generic_table())
    // construct with type_args = [i64], expected = Void (no annotation).
    let args = teko::list::push(teko::list::empty(), ttype_named("i64"))
    let sl = parser::StructLit { type_path = path1("Box"); type_args = args; field_names = teko::list::push(teko::list::empty(), "value"); field_vals = teko::list::push(teko::list::empty(), e_num(42)) }
    let r = match type_struct_lit(sl, Void { }, empty_env(), tbl) { TExpr as te => te; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(match r.type { Named as n => n.name == "Box__g__i64"; _ => false })
    match r.kind { TStructInit as si => teko::assert::is_true(prim_is(si.field_vals[0].type, PrimKind::I64)); _ => teko::assert::is_true(false) }
    // arity mismatch: Box<i64, str>{ … } → error (the `error` arm asserts pass; the TExpr arm asserts fail).
    mut two: []parser::TypeExpr = teko::list::push(teko::list::empty(), ttype_named("i64"))
    two = teko::list::push(two, ttype_named("str"))
    let bad = parser::StructLit { type_path = path1("Box"); type_args = two; field_names = teko::list::push(teko::list::empty(), "value"); field_vals = teko::list::push(teko::list::empty(), e_num(42)) }
    match type_struct_lit(bad, Void { }, empty_env(), tbl) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// (W9.4) a bind pattern carrying explicit type-args `Box<i64> as x` resolves to the stamped instance
// Box__g__i64 (so exhaustiveness / binding use the concrete case type).
#test
fn bind_pattern_explicit_type_args_resolves_instance() {
    let tbl = box_generic_table()
    let args = teko::list::push(teko::list::empty(), ttype_named("i64"))
    let bp = parser::BindPattern { type_name = path1("Box"); has_binding = true; binding = "x"; is_slice = false; slice_type = null; type_args = args }
    teko::assert::is_true(match bind_pattern_type(bp, tbl) { Named as n => n.name == "Box__g__i64"; _ => false })
    // a bare bind (no type-args) keeps the base name (no regression).
    let plain = parser::BindPattern { type_name = path1("Box"); has_binding = true; binding = "x"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    teko::assert::is_true(match bind_pattern_type(plain, tbl) { Named as n => n.name == "Box"; _ => false })
}

// ---------------------------------------------------------------------------
// Group K: monomorphize (S4b crumb 2c) — direct VM coverage of the mono walk.
// Build typed programs by hand (a generic TFunction template + non-generic callers /
// virtual-main statements), call monomorphize, and assert the generic is DROPPED and a
// stamped concrete copy (idg__g__<arg>) appears with the right return type. The generic
// bodies + caller bodies span varied TExprKind / TStatement cases so the total walk and
// both driver phases (seed collection + fixpoint stamping) execute on the VM.
// ---------------------------------------------------------------------------

// a typed VAR expr of a given type.
fn tvar(name: str, t: Type) -> TExpr { TExpr { kind = TVar { name = name; is_func = false; func_ns = "" }; type = t; line = 0; col = 0 } }
// a typed integer literal (i64).
fn tnum(v: i128) -> TExpr { TExpr { kind = TNumber { is_float = false; value = v; fval = 0.0 }; type = i64t(); line = 0; col = 0 } }
// a generic TFunction `fn NAME<T>(x: PARAMSPELL) -> RET { body }`.
fn gfn(name: str, param_ann: parser::TypeExpr, ret: Type, body: []TStatement) -> TFunction {
    let tps: []str = teko::list::push(teko::list::empty(), "T")
    let tcs: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::NoConstraint { })
    let p = parser::Param { name = "x"; has_type = true; type_ann = param_ann; is_params = false ; has_default = false; default_expr = e_num(0) }
    let params = teko::list::push(teko::list::empty(), p)
    TFunction { name = name; type_params = tps; type_constraints = tcs; params = params; return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}
// a non-generic TFunction with a hand-built body.
fn plainfn(name: str, ret: Type, body: []TStatement) -> TFunction {
    TFunction { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}
// a typed call `NAME(arg)` with result type `rt`.
fn tcall1(name: str, arg: TExpr, rt: Type) -> TExpr {
    let callee = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }
    let args = teko::list::push(teko::list::empty(), arg)
    TExpr { kind = TCall { callee = callee; args = args; call_ns = ""; is_closure_call = false; callee_type = Void { } }; type = rt; line = 0; col = 0 }
}
fn texpr_stmt(e: TExpr) -> TStatement { TExprStmt { expr = e } }
fn treturn(e: TExpr) -> TStatement { TReturn { has_value = true; value = e } }
// find a stamped fn (mangled name) in a typed program's items.
fn find_titem_fn(prog: TProgram, name: str) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if teko::runtime::str_eq(f.name, name) { return true } }; _ => {} }
        i++
    }
    false
}
// is there a stamped instance of `bare` (a fn whose name contains "<bare>__g__")? VM-robust:
// it checks the synthetic `__g__` infix, not the full type-arg spelling.
fn has_stamped_instance(prog: TProgram, bare: str) -> bool {
    let needle = teko::str::concat(bare, "__g__")
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if teko::str::contains(f.name, needle) { return true } }; _ => {} }
        i++
    }
    false
}
fn count_generic_fns(prog: TProgram) -> u64 {
    mut n: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if f.type_params.len > 0 { n++ } }; _ => {} }
        i++
    }
    n
}

#test
fn mono_noop_when_no_generics() {
    // a program with NO generic fn passes through unchanged (the no-op guard).
    let body = teko::list::push(teko::list::empty(), treturn(tnum(1)))
    let f = plainfn("plain", i64t(), body)
    let items: []TItem = teko::list::push(teko::list::empty(), f)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(mp.items.len == 1)
    teko::assert::is_true(count_generic_fns(mp) == 0)
}

#test
fn mono_stamps_two_instances() {
    // fn idg<T>(x: T) -> T { return x } + two callers (i64 + str). After mono: the generic is
    // DROPPED and idg__g__i64 / idg__g__str are stamped; the callers' callees are rewritten.
    let gbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, gbody)
    // a non-generic caller calling idg(7) [i64] and idg("hi") [str] as virtual-main statements.
    let call_i = texpr_stmt(tcall1("idg", tnum(7), i64t()))
    let call_s = texpr_stmt(tcall1("idg", TExpr { kind = TStrLit { text = "hi" }; type = strt(); line = 0; col = 0 }, strt()))
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, call_i)
    items = teko::list::push(items, call_s)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    // generic dropped; both instances stamped.
    teko::assert::is_true(count_generic_fns(mp) == 0)
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "idg__g__str"))
    // a stamped fn's return type is concrete.
    mut found_i64_ret = false
    mut i = 0
    loop {
        if i >= mp.items.len { break }
        match mp.items[i] { TFunction as f => { if teko::runtime::str_eq(f.name, "idg__g__i64") { found_i64_ret = prim_is(f.return_type, PrimKind::I64) } }; _ => {} }
        i++
    }
    teko::assert::is_true(found_i64_ret)
}

#test
fn mono_transitive_fixpoint() {
    // fn idg<T>(x: T) -> T { return x } ; fn wrapg<T>(x: T) -> T { return idg(x) } ; caller wrapg(9)
    // → stamping wrapg__g__i64 discovers idg__g__i64 (the Phase-2 fixpoint), which is then stamped.
    let idgbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, idgbody)
    // wrapg body: return idg(x)  — the inner call's arg is `x: T` (opaque), result T.
    let inner_call = tcall1("idg", tvar("x", Named { name = "T" }), Named { name = "T" })
    let wrapbody = teko::list::push(teko::list::empty(), treturn(inner_call))
    let wrapg = gfn("wrapg", named_t("T"), Named { name = "T" }, wrapbody)
    let caller = texpr_stmt(tcall1("wrapg", tnum(9), i64t()))
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, wrapg)
    items = teko::list::push(items, caller)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(count_generic_fns(mp) == 0)
    teko::assert::is_true(find_titem_fn(mp, "wrapg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))   // discovered transitively
}

#test
fn mono_slice_and_optional_mangle() {
    // fn firstg<T>(xs: []T) -> T { return xs[0] } called with []i64 → firstg__g__i64 (slice unify
    // in the PARAM pattern: unify([]T, []i64) binds T=i64). The instance name has a plain i64 arg.
    let idx = TExpr { kind = TIndex { receiver = tvar("xs", Slice { element = Named { name = "T" } }); index = tnum(0) }; type = Named { name = "T" }; line = 0; col = 0 }
    let fbody = teko::list::push(teko::list::empty(), treturn(idx))
    let firstg = gfn("firstg", parser::SliceType { element = named_t("T") }, Named { name = "T" }, fbody)
    let arg = tvar("v", Slice { element = i64t() })
    let caller = texpr_stmt(tcall1("firstg", arg, i64t()))
    mut items: []TItem = teko::list::push(teko::list::empty(), firstg)
    items = teko::list::push(items, caller)
    let mp = match monomorphize(TProgram { items = items }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(find_titem_fn(mp, "firstg__g__i64"))

    // a Slice TYPE-ARG (T bound to []i64) drives the slice_<elem> mangle branch in mono_type_mangle:
    // fn idh<T>(x: T) -> T called with arg of type []i64 → T = []i64 → instance idh__g__slice_i64.
    // (The exact slice_ spelling depends on a recursive-match string compose; assert the stamped
    // instance EXISTS via the synthetic `__g__` infix — VM-robust, and still exercises the branch.)
    let hbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idh = gfn("idh", named_t("T"), Named { name = "T" }, hbody)
    let slice_arg = tvar("s", Slice { element = i64t() })
    let hcaller = texpr_stmt(tcall1("idh", slice_arg, Slice { element = i64t() }))
    mut items2: []TItem = teko::list::push(teko::list::empty(), idh)
    items2 = teko::list::push(items2, hcaller)
    let mp2 = match monomorphize(TProgram { items = items2 }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(count_generic_fns(mp2) == 0)
    teko::assert::is_true(has_stamped_instance(mp2, "idh"))
    // directly exercise EVERY mono_type_mangle arm (branch coverage of the mangle + type_to_texpr).
    teko::assert::is_true(teko::str::len(mono_type_mangle(Slice { element = i64t() })) > 0)
    teko::assert::is_true(teko::str::len(mono_type_mangle(Optional { inner = Str { } })) > 0)
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Str { }), "str"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Byte { }), "byte"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Error { }), "error"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Void { }), "void"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Ptr { inner = null }), "ptr"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Uptr { }), "uptr"))
    teko::assert::is_true(teko::str::len(mono_type_mangle(Reference { inner = i64t() })) > 0)   // (MEM-1b) recursive mangle — len-only (VM prefix-drop)
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Named { name = "Foo" }), "Foo"))
}

#test
fn mono_walk_covers_node_kinds() {
    // a generic fn whose body + a non-generic caller body together exercise many TExprKind /
    // TStatement walk cases (binary, compare, if, cast, field-access, struct-init, interp, in,
    // array, coalesce, safe-field, unary, loop, assign, defer, break/continue), all under the
    // total rewrite walk. The generic call inside drives stamping.
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" }))))

    // non-generic caller body with a grab-bag of typed nodes (well-typedness is not re-checked
    // by mono — it only rewrites types + callees, so hand-built shapes are fine for the walk).
    let n = tvar("n", i64t())
    let bin = TExpr { kind = TBinary { op = lexer::TokenKind::Plus; left = n; right = tnum(1) }; type = i64t(); line = 0; col = 0 }
    let cmpterm = TCmpTerm { op = lexer::TokenKind::Lt; operand = tnum(10) }
    let cmp = TExpr { kind = TCompare { first = n; rest = teko::list::push(teko::list::empty(), cmpterm) }; type = boolt(); line = 0; col = 0 }
    let un = TExpr { kind = TUnary { op = lexer::TokenKind::Minus; operand = n }; type = i64t(); line = 0; col = 0 }
    let cast = TExpr { kind = TCast { expr = n }; type = u8t(); line = 0; col = 0 }
    let cor = TExpr { kind = TCoalesce { left = tvar("o", Optional { inner = i64t() }); right = tnum(0) }; type = i64t(); line = 0; col = 0 }
    let arr = TExpr { kind = TArrayLit { elements = teko::list::push(teko::list::empty(), TArrayElem { is_spread = false; expr = tnum(1) }) }; type = Slice { element = i64t() }; line = 0; col = 0 }
    let interp = TExpr { kind = TInterp { pieces = teko::list::push(teko::list::push(teko::list::empty(), "v"), ""); holes = teko::list::push(teko::list::empty(), n); specs = teko::list::push(teko::list::empty(), TFSpec { kind = TFSpecNone { } }) }; type = strt(); line = 0; col = 0 }
    let inx = TExpr { kind = TInExpr { lhs = n; elems = teko::list::push(teko::list::empty(), tnum(2)) }; type = boolt(); line = 0; col = 0 }
    // an if-expr value with both branches; a match with one wildcard-bodied arm.
    let ife = TExpr { kind = TIfExpr { cond = cmp; then_blk = teko::list::push(teko::list::empty(), texpr_stmt(tnum(1))); has_else = true; else_blk = teko::list::push(teko::list::empty(), texpr_stmt(tnum(2))) }; type = i64t(); line = 0; col = 0 }
    let genstamp = tcall1("idg", tnum(5), i64t())   // drives stamping from within the walk

    // statements: binding, assign, expr, loop (with break/continue), defer, return.
    mut body: []TStatement = teko::list::push(teko::list::empty(), TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "a" }; bound = i64t(); value = bin })
    body = teko::list::push(body, TAssign { name = "a"; op = lexer::TokenKind::Assign; bound = i64t(); value = un; deref = false })
    body = teko::list::push(body, texpr_stmt(cast))
    body = teko::list::push(body, texpr_stmt(cor))
    body = teko::list::push(body, texpr_stmt(arr))
    body = teko::list::push(body, texpr_stmt(interp))
    body = teko::list::push(body, texpr_stmt(inx))
    body = teko::list::push(body, texpr_stmt(ife))
    body = teko::list::push(body, texpr_stmt(genstamp))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), TBreakStmt { label = "" })
    loopbody = teko::list::push(loopbody, TContinueStmt { label = "" })
    body = teko::list::push(body, TLoopStmt { label = ""; body = loopbody })
    body = teko::list::push(body, TDeferStmt { body = teko::list::push(teko::list::empty(), texpr_stmt(tnum(0))) })
    body = teko::list::push(body, treturn(tnum(0)))

    let caller = plainfn("caller", i64t(), body)
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, caller)
    let mp = match monomorphize(TProgram { items = items }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "caller"))
}

// =========================================================================
// MEM Step 1 — THE ESCAPE CHECK (escape.tks). The classifier must (1) call a returned
// allocation ESCAPING (never frame-local — a leak is safe, a UAF is a vulnerability) and
// (2) call a purely-local allocation FRAME-LOCAL (read only through a scalar field copy).
// =========================================================================

// a typed `Node { val = <i64>; }` struct-init value (Node is the recursive value type).
fn t_node_init(val: TExpr) -> TExpr {
    let fnames = teko::list::push(teko::list::empty(), "val")
    let fvals  = teko::list::push(teko::list::empty(), val)
    TExpr { kind = TStructInit { field_names = fnames; field_vals = fvals }; type = Named { name = "Node" }; line = 0; col = 0 }
}
// a `let n = <value>` binding (not const, not discard) to a SimpleName — returned as the raw
// TBinding (the codegen's emit_binding receives this same destructured node).
fn t_let(name: str, value: TExpr) -> TBinding {
    TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; bound = value.type; value = value }
}
// `n.val` typed as i64 (a SCALAR field read — a pure copy, so the receiver does not escape).
fn t_field_i64(recv_name: str, field: str) -> TExpr {
    let recv = tvar(recv_name, Named { name = "Node" })
    TExpr { kind = TFieldAccess { receiver = recv; field = field }; type = i64t(); line = 0; col = 0 }
}

#test
fn escape_returned_allocation_is_escaping() {
    // fn f() -> Node { let n = Node { val = 5 }; return n }   — `n` is RETURNED ⇒ ESCAPING.
    let binding = t_let("n", t_node_init(tnum(5)))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, treturn(tvar("n", Named { name = "Node" })))
    let f = plainfn("f", Named { name = "Node" }, body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))                 // proven to escape
    teko::assert::is_true(!binding_is_frame_local(esc, binding)) // ⇒ NOT frame-local (stays in root)
}

#test
fn escape_local_scalar_read_is_frame_local() {
    // fn f() -> i64 { let n = Node { val = 5 }; return n.val }   — `n` is read ONLY as a SCALAR
    // field copy ⇒ it does NOT escape ⇒ the allocation is FRAME-LOCAL (region-freed at exit).
    let binding = t_let("n", t_node_init(tnum(5)))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, treturn(t_field_i64("n", "val")))
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(!str_set_has(esc, "n"))               // proven NOT to escape
    teko::assert::is_true(binding_is_frame_local(esc, binding)) // ⇒ frame-local (provable subset)
}

#test
fn escape_call_argument_is_escaping() {
    // fn f() { let n = Node { val = 5 }; use(n) }   — `n` is passed to a call ⇒ may be retained
    // ⇒ conservatively ESCAPING (one-depth: a callee could store the argument).
    let binding = t_let("n", t_node_init(tnum(5)))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tcall1("use", tvar("n", Named { name = "Node" }), i64t())))
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))
    teko::assert::is_true(!binding_is_frame_local(esc, binding))
}

#test
fn escape_const_binding_is_never_frame_local() {
    // a `const` binding never goes in the frame region (it may be folded / outlive the frame).
    let cbind = TBinding { kind = parser::BindKind::Const; target = parser::SimpleName { name = "k" }; bound = Named { name = "Node" }; value = t_node_init(tnum(1)) }
    let body: []TStatement = teko::list::push(teko::list::empty(), cbind)
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(!binding_is_frame_local(esc, cbind))   // const ⇒ never frame-local
}

// --- MEM Step 1 UAF FIX regression: a TAIL expr-statement is an IMPLICIT RETURN (escaping) ---
// Codegen (emit_block_tail/emit_exprstmt_tail) drops the frame region BEFORE the implicit
// trailing-value return, so a frame-local recursive-struct read in that tail value would be a
// use-after-free. The escape check must AGREE with codegen and mark such a binding ESCAPING.

// `Node { val = <i64>; next = <Node-typed> }` — the recursive back-edge carrying field.
fn t_node_init2(val: TExpr, next: TExpr) -> TExpr {
    mut fnames = teko::list::push(teko::list::empty(), "val")
    fnames = teko::list::push(fnames, "next")
    mut fvals = teko::list::push(teko::list::empty(), val)
    fvals = teko::list::push(fvals, next)
    TExpr { kind = TStructInit { field_names = fnames; field_vals = fvals }; type = Named { name = "Node" }; line = 0; col = 0 }
}
// `n.next` typed as Node (a NON-scalar field read — surfaces an interior pointer).
fn t_field_node(recv_name: str, field: str) -> TExpr {
    let recv = tvar(recv_name, Named { name = "Node" })
    TExpr { kind = TFieldAccess { receiver = recv; field = field }; type = Named { name = "Node" }; line = 0; col = 0 }
}

#test
fn escape_tail_implicit_return_rebox_is_escaping() {
    // fn f() -> Node { let n = Node { val = 5; next = n }; Node { val = n.val; next = n.next } }
    // The trailing struct-init is an IMPLICIT RETURN (no `return` keyword). It re-boxes `n.next`
    // (a NON-scalar interior pointer) into the returned value — so `n` ESCAPES. Before the fix the
    // tail expr-statement was DISCARDED (non-escaping) ⇒ `n` was wrongly frame-local ⇒ the frame
    // region was dropped on the return edge, then the tail dereferenced the freed cell = UAF.
    // The binding does NOT read `n` (no self-reference) — only the TAIL re-box does, so this test
    // genuinely isolates the tail-position escape (not the binding RHS).
    let binding = t_let("n", t_node_init(tnum(5)))
    let tail = t_node_init2(t_field_i64("n", "val"), t_field_node("n", "next"))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tail))           // implicit-return tail (no `return`)
    let f = plainfn("f", Named { name = "Node" }, body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))               // tail value escapes ⇒ `n` escapes
    teko::assert::is_true(!binding_is_frame_local(esc, binding)) // ⇒ NOT frame-local (routes to root)
}

#test
fn escape_tail_safe_field_coalesce_is_escaping() {
    // fn f() -> Node { let n = Node{…}; (n.next?.next) ?? other }
    // The implicit-return tail reads `n.next` (a NON-scalar interior pointer) via a safe-field
    // access whose receiver is a non-scalar field read, then COALESCES the (non-scalar) result —
    // so `n` ESCAPES. (Reproducer A: `?.` + `??` in the implicit tail.) The safe-field RESULT type
    // is kept NOMINAL (Node, not Optional) to dodge the VM single-field-wrapper-descent landmine
    // [memory: VM conflates Ref/Ptr/Optional/Slice in `match`]; the native engine handles either,
    // and what the escape check needs is only that the result is NON-scalar.
    let binding = t_let("n", t_node_init(tnum(5)))           // binding does NOT read `n` — only the tail does
    let nnext = t_field_node("n", "next")                    // n.next : Node (non-scalar interior pointer)
    let sfa = TExpr { kind = TSafeFieldAccess { receiver = nnext; field = "next" }; type = Named { name = "Node" }; line = 0; col = 0 }
    let tail = TExpr { kind = TCoalesce { left = sfa; right = tvar("other", Named { name = "Node" }) }; type = Named { name = "Node" }; line = 0; col = 0 }
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tail))           // implicit-return tail (no `return`)
    let f = plainfn("f", Named { name = "Node" }, body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))               // tail value escapes ⇒ `n` escapes
    teko::assert::is_true(!binding_is_frame_local(esc, binding))
}

// =========================================================================
// S2 — THE PER-BLOCK ESCAPE CHECK (escape.tks::binding_is_block_local). A binding declared in a
// scope-introducing BLOCK may be freed at the block's exit edges ONLY when every read of it in the
// whole function is a SAFE non-tail/non-assign read strictly inside that block. SECURITY-FIRST:
// any read outside B, in B's tail value, or as an assignment RHS ⇒ NOT block-local (route to the
// enclosing region — a leak is safe, a use-after-free is NEVER).
// =========================================================================

#test
fn block_local_read_only_inside_block_is_block_local() {
    // fn f() -> i64 { mut t=0; loop { let n = Node{val=5}; let g = n.val; t = t+g; break }; t }
    // `n` is declared in the LOOP body and read ONLY via a scalar field copy inside it (non-tail,
    // non-assign) ⇒ block-local ⇒ the loop body region may free it per-iteration.
    let binding = t_let("n", t_node_init(tnum(5)))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), binding)
    loopbody = teko::list::push(loopbody, t_let("g", t_field_i64("n", "val")))   // let g = n.val (scalar copy)
    loopbody = teko::list::push(loopbody, TBreakStmt { label = "" })
    let loopstmt = TLoopStmt { label = ""; body = loopbody }
    mut body: []TStatement = teko::list::push(teko::list::empty(), t_let("t", t_node_init(tnum(0))))
    body = teko::list::push(body, loopstmt)
    body = teko::list::push(body, treturn(t_field_i64("t", "val")))
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    // n is NOT function-escaping (only a scalar copy is read) AND only read inside the loop body.
    teko::assert::is_true(binding_is_block_local(esc, f.body, loopbody, false, binding))
}

#test
fn block_local_read_outside_block_is_not_block_local() {
    // The SAME `n` binding, but read AGAIN OUTSIDE the loop body (a scalar copy in the fn tail).
    // A read outside B ⇒ NOT block-local (must outlive the block) ⇒ route to the enclosing region.
    let binding = t_let("n", t_node_init(tnum(5)))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), binding)
    loopbody = teko::list::push(loopbody, t_let("g", t_field_i64("n", "val")))
    loopbody = teko::list::push(loopbody, TBreakStmt { label = "" })
    let loopstmt = TLoopStmt { label = ""; body = loopbody }
    mut body: []TStatement = teko::list::push(teko::list::empty(), loopstmt)
    body = teko::list::push(body, treturn(t_field_i64("n", "val")))   // reads `n` OUTSIDE the loop
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(!binding_is_block_local(esc, f.body, loopbody, false, binding))
}

#test
fn block_local_assigned_to_outer_var_is_not_block_local() {
    // fn f() { mut acc=Node{…}; loop { let cur = Node{…}; acc = cur; break }; acc.val }
    // `cur` is assigned to an OUTER-declared mut (`acc`) ⇒ it may outlive the loop body ⇒ NOT
    // block-local (the assignment RHS is excluded from the safe-inside reads — UAF trap rule 4).
    let cur = t_let("cur", t_node_init(tnum(1)))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), cur)
    loopbody = teko::list::push(loopbody, TAssign { name = "acc"; op = lexer::TokenKind::Assign; bound = Named { name = "Node" }; value = tvar("cur", Named { name = "Node" }); deref = false })
    loopbody = teko::list::push(loopbody, TBreakStmt { label = "" })
    let loopstmt = TLoopStmt { label = ""; body = loopbody }
    mut body: []TStatement = teko::list::push(teko::list::empty(), t_let("acc", t_node_init(tnum(0))))
    body = teko::list::push(body, loopstmt)
    body = teko::list::push(body, treturn(t_field_i64("acc", "val")))
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(!binding_is_block_local(esc, f.body, loopbody, false, cur))
}

#test
fn block_local_arm_tail_value_is_not_block_local() {
    // A value-yielding block (is_value=true) whose TAIL value is the bare binding `p` — the value
    // is used OUTSIDE the block (an if/match value) ⇒ NOT block-local (the UAF trap rule 3). Here
    // the block IS the function body, so `p` is also function-escaping; either gate (frame-local or
    // the tail-read exclusion) yields the correct, security-first answer: NOT block-local.
    let binding = t_let("p", t_node_init(tnum(5)))
    mut blk: []TStatement = teko::list::push(teko::list::empty(), binding)
    blk = teko::list::push(blk, texpr_stmt(tvar("p", Named { name = "Node" })))   // tail value = p
    let f = plainfn("f", i64t(), blk)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(!binding_is_block_local(esc, f.body, blk, true, binding))
}

#test
fn escape_tail_scalar_implicit_return_stays_frame_local() {
    // fn f() -> i64 { let n = Node { val = 5; next = n }; n.val }
    // The implicit-return tail reads ONLY a SCALAR field (a pure copy carrying no interior
    // pointer), so `n` does NOT escape and the allocation stays FRAME-LOCAL — the legitimate free
    // the fix must PRESERVE (do not over-conservatively kill the provable frame-local subset).
    let binding = t_let("n", t_node_init(tnum(5)))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(t_field_i64("n", "val")))   // implicit-return scalar tail
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(!str_set_has(esc, "n"))             // scalar tail copy ⇒ does NOT escape
    teko::assert::is_true(binding_is_frame_local(esc, binding)) // ⇒ STILL frame-local (free preserved)
}

// --- MEM Step 1 UAF FIX #2 regression: a SCALAR read through a BOXED HOP (`a.b.y`) escapes ---
// The scalar non-escaping refinement is SOUND ONLY for a scalar field of a BARE local (a stack
// member). `a.b.y` reads a scalar `.y` but THROUGH `a.b` — a boxed (recursive) field that is a
// heap pointer into the frame region. The whole tail value is evaluated AFTER the region drop, so
// dereferencing the freed `a.b` is a use-after-free. The refinement must route `a` to ESCAPING
// because the field-access receiver (`a.b`) is NOT a bare TVar.

#test
fn escape_tail_scalar_through_boxed_hop_is_escaping() {
    // fn f() -> i64 { let n = Node { val = 5 }; n.next.val }
    // `.val` is scalar (i64) but its receiver `n.next` is a NON-scalar (boxed) interior pointer —
    // a frame-region heap hop. The bare-TVar refinement must NOT fire (receiver is a field access,
    // not a TVar) ⇒ `n` ESCAPES ⇒ NOT frame-local (the only sound choice — avoids the UAF).
    let binding = t_let("n", t_node_init(tnum(5)))
    let nnext = t_field_node("n", "next")                    // n.next : Node (boxed heap hop)
    let deep  = TExpr { kind = TFieldAccess { receiver = nnext; field = "val" }; type = i64t(); line = 0; col = 0 }  // (n.next).val : i64 (scalar through a boxed hop)
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(deep))          // implicit-return tail (no `return`)
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))             // scalar-through-boxed-hop ⇒ `n` escapes
    teko::assert::is_true(!binding_is_frame_local(esc, binding)) // ⇒ NOT frame-local (UAF avoided)
}

#test
fn escape_tail_index_receiver_is_escaping() {
    // fn f() -> i64 { let n = Node { val = 5 }; arr[n.val] }
    // An index read derefs a heap-backed slice. The index sub-expression `n.val` is evaluated
    // post-drop too; `n.val` is a bare-TVar scalar (frame-local), but the receiver `arr` (a TVar)
    // is read in an escaping context. This pins down that the index path propagates escaping to its
    // receiver while still allowing a bare-TVar scalar index (`n.val`) to stay frame-local.
    let binding = t_let("n", t_node_init(tnum(5)))
    let arr = tvar("arr", Slice { element = i64t() })
    let idx = t_field_i64("n", "val")                        // n.val : i64 (bare-TVar scalar)
    let tail = TExpr { kind = TIndex { receiver = arr; index = idx }; type = i64t(); line = 0; col = 0 }
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tail))          // implicit-return tail (no `return`)
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "arr"))          // index receiver (heap slice) escapes
    teko::assert::is_true(!str_set_has(esc, "n"))           // bare-TVar scalar index stays frame-local
    teko::assert::is_true(binding_is_frame_local(esc, binding))
}

// --- teko::time ROUND 0: extern fn with Named return type (C7.2 teko_rt bypass) ---
// Verifies that `from "teko_rt"` extern fns may return a user-defined struct (Named type).
// Before this fix, teko_rt_type_ok() rejected Named; now it accepts it so DateTime/Date/…
// can be returned by value across the teko_rt ABI boundary (SUPREME RULE: layout-matched).
#test
fn ffi_teko_rt_named_struct_return() {
    // Build:  `extern fn date_from_days(d: i32) -> Date = "tk_rt_date_from_days" from "teko_rt"`
    // This requires a TypeTable entry for `Date` (a struct with one `days: i32` field).
    let days_field = parser::Field { name = "days"; type_ann = named_t("i32") ; vis = parser::Visibility::Pub; is_intern = false }
    mut date_fields: []parser::Field = teko::list::empty()
    date_fields = teko::list::push(date_fields, days_field)
    let date_struct = parser::TypeDecl { name = "Date"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = date_fields ; methods = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0 }
    let tbl: TypeTable = teko::list::push(empty_table(), TypeReg { name = "Date"; namespace = ""; vis = parser::Visibility::Pub; decl = date_struct })
    // extern fn: one param d: i32, returns Date (a Named struct), from "teko_rt"
    let param_d = parser::Param { name = "d"; has_type = true; type_ann = named_t("i32"); is_params = false ; has_default = false; default_expr = e_num(0) }
    mut params: []parser::Param = teko::list::empty()
    params = teko::list::push(params, param_d)
    mut no_body: []parser::Statement = teko::list::empty()
    let f = parser::Function { name = "date_from_days"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = named_t("Date"); body = no_body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = true; c_symbol = "tk_rt_date_from_days"; from_lib = "teko_rt"; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false }
    // Must succeed: Named return is allowed for `from "teko_rt"` externs (C7.2 + teko_rt_type_ok fix)
    match type_function(f, empty_env(), tbl) {
        TFunction => teko::assert::is_true(true)
        error     => teko::assert::is_true(false)   // must NOT fail
    }
}

// --- teko::time ROUND 0: arithmetic extern fn — TWO Named params + Named return ---
// Verifies `from "teko_rt"` extern fns may take multiple Named struct PARAMS (not just a
// Named return), the shape used by datetime_add/timespan_add/date_add_days etc:
//   extern fn timespan_add(a: TimeSpan, b: TimeSpan) -> TimeSpan = "tk_rt_timespan_add" from "teko_rt"
#test
fn ffi_teko_rt_named_struct_two_params() {
    let ticks_field = parser::Field { name = "ticks"; type_ann = named_t("i128") ; vis = parser::Visibility::Pub; is_intern = false }
    mut span_fields: []parser::Field = teko::list::empty()
    span_fields = teko::list::push(span_fields, ticks_field)
    let span_struct = parser::TypeDecl { name = "TimeSpan"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = span_fields ; methods = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0 }
    let tbl: TypeTable = teko::list::push(empty_table(), TypeReg { name = "TimeSpan"; namespace = ""; vis = parser::Visibility::Pub; decl = span_struct })
    let param_a = parser::Param { name = "a"; has_type = true; type_ann = named_t("TimeSpan"); is_params = false ; has_default = false; default_expr = e_num(0) }
    let param_b = parser::Param { name = "b"; has_type = true; type_ann = named_t("TimeSpan"); is_params = false ; has_default = false; default_expr = e_num(0) }
    mut params: []parser::Param = teko::list::empty()
    params = teko::list::push(params, param_a)
    params = teko::list::push(params, param_b)
    mut no_body: []parser::Statement = teko::list::empty()
    let f = parser::Function { name = "timespan_add"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = named_t("TimeSpan"); body = no_body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = true; c_symbol = "tk_rt_timespan_add"; from_lib = "teko_rt"; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false }
    // Must succeed: TWO Named params + a Named return, all `from "teko_rt"` (C7.2)
    match type_function(f, empty_env(), tbl) {
        TFunction => teko::assert::is_true(true)
        error     => teko::assert::is_true(false)   // must NOT fail
    }
}

// --- DEFARGS (2026-07-01): call-site named-arg resolution + default-value fill ------------
// `fn add(a: i64, b: i64 = 10) -> i64` — a: required (index 0), b: defaulted (n_required = 1,
// defaults = [10]). Mirrors the .tkt Func literal env0/env pattern from types_call above.
fn defargs_env() -> Env {
    let params: []Type = teko::list::push(teko::list::push(teko::list::empty(), i64t()), i64t())
    let names: []str = teko::list::push(teko::list::push(teko::list::empty(), "a"), "b")
    let defaults: []parser::Expr = teko::list::push(teko::list::empty(), e_num(10))
    define(empty_env(), "add", Func { params = params; ret = i64t(); variadic = false; param_names = names; n_required = 1; defaults = defaults }, false)
}
fn names1(a: str) -> []str { teko::list::push(teko::list::empty(), a) }
fn names2(a: str, b: str) -> []str { teko::list::push(teko::list::push(teko::list::empty(), a), b) }

#test
fn defargs_positional_fill() {
    // add(1) -- omitted `b` fills from the default (10).
    let args: []parser::Expr = teko::list::push(teko::list::empty(), e_num(1))
    let tcall = match type_call(parser::Call { callee = path1("add"); args = args; arg_names = names1("") }, defargs_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match tcall.kind { TCall as cc => teko::assert::is_true(cc.args.len == 2); _ => teko::assert::is_true(false) }
}

#test
fn defargs_named_call_all() {
    // add(a = 1, b = 2) -- fully named, both provided.
    let args: []parser::Expr = teko::list::push(teko::list::push(teko::list::empty(), e_num(1)), e_num(2))
    let tcall = match type_call(parser::Call { callee = path1("add"); args = args; arg_names = names2("a", "b") }, defargs_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match tcall.kind { TCall as cc => teko::assert::is_true(cc.args.len == 2); _ => teko::assert::is_true(false) }
}

#test
fn defargs_named_out_of_order() {
    // add(b = 2, a = 1) -- named-call may reorder freely.
    let args: []parser::Expr = teko::list::push(teko::list::push(teko::list::empty(), e_num(2)), e_num(1))
    let tcall = match type_call(parser::Call { callee = path1("add"); args = args; arg_names = names2("b", "a") }, defargs_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match tcall.kind { TCall as cc => teko::assert::is_true(cc.args.len == 2); _ => teko::assert::is_true(false) }
}

#test
fn defargs_mixed_positional_then_named() {
    // add(1, b = 2) -- positional `a`, named `b` (named-last, rule D).
    let args: []parser::Expr = teko::list::push(teko::list::push(teko::list::empty(), e_num(1)), e_num(2))
    let tcall = match type_call(parser::Call { callee = path1("add"); args = args; arg_names = names2("", "b") }, defargs_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match tcall.kind { TCall as cc => teko::assert::is_true(cc.args.len == 2); _ => teko::assert::is_true(false) }
}

#test
fn defargs_missing_required_is_error() {
    // add() -- `a` has no default -- must fail.
    mut no_args: []parser::Expr = teko::list::empty()
    match type_call(parser::Call { callee = path1("add"); args = no_args; arg_names = pos_names(0) }, defargs_env(), empty_table()) {
        TExpr => teko::assert::is_true(false)   // must fail
        error => teko::assert::is_true(true)
    }
}

#test
fn defargs_unknown_named_is_error() {
    // add(a = 1, c = 2) -- `c` is not a param of add -- must fail.
    let args: []parser::Expr = teko::list::push(teko::list::push(teko::list::empty(), e_num(1)), e_num(2))
    match type_call(parser::Call { callee = path1("add"); args = args; arg_names = names2("a", "c") }, defargs_env(), empty_table()) {
        TExpr => teko::assert::is_true(false)   // must fail
        error => teko::assert::is_true(true)
    }
}

// --- W11/S6 (2026-07-01): generic type-parameter CONSTRAINTS -- checked at monomorphization ---
// `type Numeric = i64 | f64` is the constraint TARGET (a variant); T:Numeric is satisfied by a
// concrete i64/f64 binding (nominal membership vs the variant's declared members), violated by
// anything else (e.g. str). Mirrors the pattern established for DEFARGS: exercise the checker
// function directly (check_constraints/monomorph.tks) rather than only end-to-end.
fn numeric_table() -> TypeTable {
    let union = parser::UnionType { members = teko::list::push(teko::list::push(teko::list::empty(), named_t("i64")), named_t("f64")) }
    let decl = parser::TypeDecl { name = "Numeric"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::VariantBody { type_expr = union }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
    teko::list::push(empty_table(), TypeReg { name = "Numeric"; namespace = ""; vis = parser::Visibility::Private; decl = decl })
}
fn tps1(name: str) -> []str { teko::list::push(teko::list::empty(), name) }
fn atom_constraint(name: str) -> []parser::ConstraintExpr { teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = name }) }
fn subst_of(param: str, bound: Type) -> Subst {
    Subst { params = tps1(param); names = tps1(param); types = teko::list::push(teko::list::empty(), bound) }
}

#test
fn constraint_atom_satisfied_by_variant_member() {
    match check_constraints(tps1("T"), atom_constraint("Numeric"), subst_of("T", i64t()), numeric_table()) {
        null      => teko::assert::is_true(true)
        error     => teko::assert::is_true(false)   // i64 IS a Numeric member -- must NOT fail
    }
}

#test
fn constraint_atom_violated_by_non_member() {
    let str_t: Type = Str { }
    match check_constraints(tps1("T"), atom_constraint("Numeric"), subst_of("T", str_t), numeric_table()) {
        null      => teko::assert::is_true(false)   // str is NOT a Numeric member -- must fail
        error     => teko::assert::is_true(true)
    }
}

#test
fn constraint_unknown_atom_is_unsatisfiable() {
    // "DoesNotExist" names no TypeDecl at all -- unsatisfiable (M.1 fail-loud, never silently ignored).
    match check_constraints(tps1("T"), atom_constraint("DoesNotExist"), subst_of("T", i64t()), numeric_table()) {
        null      => teko::assert::is_true(false)
        error     => teko::assert::is_true(true)
    }
}

#test
fn constraint_and_requires_both() {
    let l: parser::ConstraintExpr = parser::ConstraintAtom { name = "Numeric" }
    let r: parser::ConstraintExpr = parser::ConstraintAtom { name = "DoesNotExist" }
    let both: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAnd { left = l; right = r })
    match check_constraints(tps1("T"), both, subst_of("T", i64t()), numeric_table()) {
        null      => teko::assert::is_true(false)   // second conjunct is unsatisfiable -- must fail
        error     => teko::assert::is_true(true)
    }
}

#test
fn constraint_or_requires_either() {
    let l: parser::ConstraintExpr = parser::ConstraintAtom { name = "DoesNotExist" }
    let r: parser::ConstraintExpr = parser::ConstraintAtom { name = "Numeric" }
    let either: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintOr { left = l; right = r })
    match check_constraints(tps1("T"), either, subst_of("T", i64t()), numeric_table()) {
        null      => teko::assert::is_true(true)    // second disjunct (Numeric) is satisfied -- must NOT fail
        error     => teko::assert::is_true(false)
    }
}

#test
fn constraint_no_constraint_always_satisfied() {
    let str_t: Type = Str { }
    match check_constraints(tps1("T"), teko::list::push(teko::list::empty(), parser::NoConstraint { }), subst_of("T", str_t), numeric_table()) {
        null      => teko::assert::is_true(true)
        error     => teko::assert::is_true(false)
    }
}

// --- OOP A1 (2026-07-01): unified method model -- struct instance + static methods ---------
// `type Pt = struct { x: i64; fn sum(self) -> i64 { self.x }; fn origin() -> i64 { 0 } }` --
// sum(self)=instance (1st param untyped, the receiver), origin()=static (no untyped 1st param).
fn recv_param(name: str) -> parser::Param { parser::Param { name = name; has_type = false; type_ann = named_t("i64"); is_params = false; has_default = false; default_expr = e_num(0) } }
fn mk_pt_struct() -> parser::TypeDecl {
    let field_x = parser::Field { name = "x"; type_ann = named_t("i64") ; vis = parser::Visibility::Pub; is_intern = false }
    let sum_params = teko::list::push(teko::list::empty(), recv_param("self"))
    let sum_body = one_stmt(ek(parser::FieldAccess { receiver = e_var("self"); field = "x" }))
    let sum_fn = parser::Function { name = "sum"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = sum_params; has_return = true; return_type = named_t("i64"); body = sum_body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false }
    let origin_fn = parser::Function { name = "origin"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); has_return = true; return_type = named_t("i64"); body = one_stmt(e_num(0)); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false }
    let methods = teko::list::push(teko::list::push(teko::list::empty(), sum_fn), origin_fn)
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), field_x); methods = methods }
    parser::TypeDecl { name = "Pt"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0 }
}
fn pt_item() -> parser::Item { parser::Item { content = mk_pt_struct(); namespace = ""; file = "" } }
fn pt_struct_lit(x: i128) -> parser::Expr {
    ek(parser::StructLit { type_path = path1("Pt"); type_args = teko::list::empty(); field_names = teko::list::push(teko::list::empty(), "x"); field_vals = teko::list::push(teko::list::empty(), e_num(x)) })
}

#test
fn oop_instance_method_call_type_checks() {
    // `let p = Pt { x = 7 }; p.sum()` — the struct + a loose statement dot-calling its instance method.
    let bind_p = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "p" }; has_type = false; type_ann = named_t("i64"); value = pt_struct_lit(7) }
    let call_sum = st(ek(parser::MethodCall { receiver = e_var("p"); method = "sum"; args = teko::list::empty() }))
    let items = teko::list::push(teko::list::push(teko::list::empty(), pt_item()), parser::Item { content = bind_p; namespace = ""; file = "" })
    let items2 = teko::list::push(items, parser::Item { content = call_sum; namespace = ""; file = "" })
    match type_program(parser::Program { items = items2 }) {
        TProgram as tp => teko::assert::is_true(tp.items.len >= 3)   // the struct decl + the 2 methods (stamped as extra TFunction items) + the 2 statements
        error          => teko::assert::is_true(false)
    }
}

#test
fn oop_static_method_call_type_checks() {
    // `Pt::origin()` -- resolves through the SAME namespace-qualified-call machinery as any other qualified call.
    let call_origin = st(ek(parser::Call { callee = parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "Pt" }), parser::Segment { name = "origin" }) }; args = teko::list::empty(); arg_names = teko::list::empty() }))
    let items = teko::list::push(teko::list::push(teko::list::empty(), pt_item()), parser::Item { content = call_origin; namespace = ""; file = "" })
    match type_program(parser::Program { items = items }) {
        TProgram => teko::assert::is_true(true)
        error    => teko::assert::is_true(false)
    }
}

#test
fn oop_dot_call_on_static_method_is_error() {
    // `p.origin()` -- origin is STATIC (no untyped receiver) -- dot-call must be rejected.
    let bind_p = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "p" }; has_type = false; type_ann = named_t("i64"); value = pt_struct_lit(7) }
    let call_bad = st(ek(parser::MethodCall { receiver = e_var("p"); method = "origin"; args = teko::list::empty() }))
    let items = teko::list::push(teko::list::push(teko::list::empty(), pt_item()), parser::Item { content = bind_p; namespace = ""; file = "" })
    let items2 = teko::list::push(items, parser::Item { content = call_bad; namespace = ""; file = "" })
    match type_program(parser::Program { items = items2 }) {
        TProgram => teko::assert::is_true(false)   // must fail
        error    => teko::assert::is_true(true)
    }
}

#test
fn oop_unknown_method_is_error() {
    let bind_p = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "p" }; has_type = false; type_ann = named_t("i64"); value = pt_struct_lit(7) }
    let call_bad = st(ek(parser::MethodCall { receiver = e_var("p"); method = "nope"; args = teko::list::empty() }))
