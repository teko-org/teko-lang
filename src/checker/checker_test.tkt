// src/checker/checker_test.tkt — tests for the typer (C1). #test functions the runner collects.
// The typer is unit-tested on HAND-BUILT AST: each type_* must produce a fully typed node (happy)
// or refuse an ill-typed one (barrier). Rewritten to current Teko (the `Expr` node-wrapper C1-POS,
// all-fields struct literals, `Function`/`Arm`/`TypeDecl`/`Item` shapes) and module-qualified.

use teko::parser

// --- AST constructors (every expression is wrapped in a positioned `parser::Expr`) ---
fn ek(k: parser::ExprKind) -> parser::Expr { parser::Expr { kind = k; line = 0; col = 0 } }
fn e_num(v: i128) -> parser::Expr { ek(parser::Number { is_float = false; value = v; fval = 0.0 }) }
fn e_var(name: str) -> parser::Expr { ek(parser::Var { name = name }) }
fn e_str(t: str) -> parser::Expr { ek(parser::StrLit { text = t }) }
// DEFARGS (2026-07-01) — an all-positional arg_names array of length n, for tests unrelated to named-call.
fn pos_names(n: u64) -> []str {
    mut out: []str = teko::list::empty()
    mut i: u64 = 0
    loop { if i >= n { break }; out = teko::list::push(out, ""); i++ }
    out
}
/** st — an expr-statement wrapping `e`, widened to the `Statement` variant. */
fn st(e: parser::Expr) -> parser::Statement { parser::ExprStmt { expr = e } }
fn one_stmt(e: parser::Expr) -> []parser::Statement { teko::list::push(teko::list::empty(), st(e)) }
/** ret_stmt — a `return e` statement widened to the `Statement` variant, so a `[]Statement` built
    from it carries the correct element type (native codegen keys a slice's element type on the
    pushed value's type; #265's native gate cc-compiles these test bodies for the first time). */
fn ret_stmt(e: parser::Expr) -> parser::Statement { parser::Return { has_value = true; value = e } }
/** loop_stmt — a `loop { body }` statement widened to the `Statement` variant (see ret_stmt). */
fn loop_stmt(body: []parser::Statement) -> parser::Statement { parser::LoopStmt { label = ""; body = body } }
fn path1(name: str) -> parser::Path { parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) } }
fn named_t(name: str) -> parser::TypeExpr { parser::NamedType { path = path1(name); args = teko::list::empty() } }

// --- Type/env constructors ---
fn u32t() -> Type { Prim { kind = PrimKind::U32 } }
fn u8t() -> Type { Prim { kind = PrimKind::U8 } }
fn i64t() -> Type { Prim { kind = PrimKind::I64 } }
fn boolt() -> Type { Prim { kind = PrimKind::Bool } }
fn empty_env() -> Env { Env { base = teko::list::empty(); bindings = teko::list::empty(); cur_ns = ""; owner_type = ""; di = DiRegistry { providers = teko::list::empty() }; injects = teko::list::empty() } }
fn empty_table() -> TypeTable { teko::list::empty() }
fn prim_is(t: Type, k: PrimKind) -> bool { match t { Prim as p => p.kind == k; _ => false } }

#test
fn types_leaves() {
    let n = type_number(parser::Number { is_float = false; value = 5; fval = 0.0 })
    teko::assert::is_true(prim_is(n.type, PrimKind::I64))
    match n.kind { TNumber as tn => teko::assert::is_true(tn.value == 5); _ => teko::assert::is_true(false) }
    let s = type_strlit(parser::StrLit { text = "hi" })
    match s.type { Str => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    let b = type_bytelit(parser::ByteLit { value = b'A' })
    match b.type { Byte => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    // a char literal `c'A'` types as `char` (its own tag, distinct from byte / str).
    let c = type_charlit(parser::CharLit { bytes = "A" })
    match c.type { Char => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
    match c.kind { TCharLit as tc => teko::assert::is_true(tc.bytes == "A"); _ => teko::assert::is_true(false) }
}

#test
fn types_char_cast_to_u32() {
    // `c'A' to u32` — the explicit codepoint decode types as u32 (the cast's target).
    let cast = parser::Cast { expr = ek(parser::CharLit { bytes = "A" }); target = named_t("u32") }
    let tc = match type_cast(cast, empty_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tc.type, PrimKind::U32))
    // the cast's inner node is the char literal.
    match tc.kind { TCast as cc => match cc.expr.type { Char => teko::assert::is_true(true); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
    // `c'A' to str` is NOT a defined char cast → error.
    let bad = parser::Cast { expr = ek(parser::CharLit { bytes = "A" }); target = named_t("str") }
    match type_cast(bad, empty_env(), empty_table()) { error => teko::assert::is_true(true); TExpr => teko::assert::is_true(false) }
}

#test
fn types_var_and_binary() {
    let env = define(empty_env(), "x", u32t(), false)
    let vx = match type_var(parser::Var { name = "x" }, env) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(vx.type, PrimKind::U32))
    let bin = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("x"); right = e_var("x") }
    let tb = match type_binary(bin, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tb.type, PrimKind::U32))
    match tb.kind {
        TBinary as bb => {
            teko::assert::is_true(prim_is(bb.left.type, PrimKind::U32))
            teko::assert::is_true(prim_is(bb.right.type, PrimKind::U32))
        }
        _ => teko::assert::is_true(false)
    }
}

// (2026-07-01) `~` — chain flattening + adjacent-literal constant folding.
#test
fn types_tilde_all_literal_folds_to_one_literal() {
    // "a" ~ "b" ~ "c" — every piece is a literal, so the whole chain collapses to ONE TStrLit
    // ("abc"), NOT a TCall to concat — zero runtime concat calls.
    let ab = parser::Binary { op = lexer::TokenKind::Tilde; left = e_str("a"); right = e_str("b") }
    let abc = parser::Binary { op = lexer::TokenKind::Tilde; left = ek(ab); right = e_str("c") }
    let t = match type_binary(abc, empty_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match t.kind {
        TStrLit as s => teko::assert::is_true(s.text == "abc")
        _ => teko::assert::is_true(false)
    }
}

#test
fn types_tilde_mixed_chain_desugars_to_one_concat_call() {
    // x ~ "a" ~ "b" ~ y — the middle literal run folds to "ab" FIRST, then the whole 3-piece
    // chain (x, "ab", y) desugars to ONE concat call, not two nested 2-arg calls.
    let env = define(empty_env(), "x", Str { }, false)
    let env2 = define(env, "y", Str { }, false)
    let xab = parser::Binary { op = lexer::TokenKind::Tilde; left = e_var("x"); right = e_str("a") }
    let xabb = parser::Binary { op = lexer::TokenKind::Tilde; left = ek(xab); right = e_str("b") }
    let full = parser::Binary { op = lexer::TokenKind::Tilde; left = ek(xabb); right = e_var("y") }
    // `concat` (params-variadic) desugars ITS OWN call site too: 3 raw pieces pack into ONE
    // []str argument (TCall.args.len == 1), whose ArrayLit holds all 3 folded pieces — so the
    // WHOLE `~` chain still ends up as exactly one runtime concat call either way.
    let t = match type_binary(full, env2, empty_table()) { TExpr as e => e; error as e => { teko::io::eprintln(e.message); teko::assert::is_true(false); return } }
    match t.kind {
        TCall as c => {
            teko::assert::is_true(c.args.len == 1)
            match c.args[0].kind {
                TArrayLit as al => teko::assert::is_true(al.elements.len == 3)   // [x, "ab", y]
                _ => teko::assert::is_true(false)
            }
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn types_tilde_rejects_non_str_operand() {
    let env = define(empty_env(), "n", u32t(), false)
    let bad = parser::Binary { op = lexer::TokenKind::Tilde; left = e_str("x"); right = e_var("n") }
    match type_binary(bad, env, empty_table()) {
        TExpr => teko::assert::is_true(false)
        error => teko::assert::is_true(true)
    }
}

// (2026-07-01) `~` and the FULL string-literal-kind matrix — plain/verbatim/multi-line all
// decode to a plain StrLit by parse time (no flag leaks), so they fold identically; an
// interpolated string with a REAL hole cannot fold (runtime-dependent); an interpolated string
// with ZERO holes ($"…" / $@"…" with nothing to interpolate) is a rare but foldable edge case.

#test
fn types_tilde_interp_with_a_hole_does_not_fold() {
    // $"hi {n}" ~ "!" — the interp piece has a REAL hole, so it can't fold into a literal; the
    // chain still desugars to exactly one concat call (this interp piece + the literal "!").
    let env = define(empty_env(), "n", Str { }, false)
    let pieces: []str = teko::list::push(teko::list::push(teko::list::empty(), "hi "), "")
    let holes: []parser::Expr = teko::list::push(teko::list::empty(), e_var("n"))
    let interp = ek(parser::Interp { pieces = pieces; holes = holes; specs = teko::list::empty() })
    let chain = parser::Binary { op = lexer::TokenKind::Tilde; left = interp; right = e_str("!") }
    let t = match type_binary(chain, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match t.kind {
        TCall as c => {
            teko::assert::is_true(c.args.len == 1)   // concat's own packing: one []str arg
            match c.args[0].kind {
                TArrayLit as al => teko::assert::is_true(al.elements.len == 2)   // [interp-piece, "!"] — NOT folded together
                _ => teko::assert::is_true(false)
            }
        }
        _ => teko::assert::is_true(false)
    }
}

#test
fn types_tilde_interp_with_zero_holes_folds() {
    // $"no holes" ~ "-tail" — an interp with NO holes is foldable just like a plain literal:
    // the whole chain collapses to ONE literal, "no holes-tail".
    let pieces: []str = teko::list::push(teko::list::empty(), "no holes")
    let holes: []parser::Expr = teko::list::empty()
    let interp = ek(parser::Interp { pieces = pieces; holes = holes; specs = teko::list::empty() })
    let chain = parser::Binary { op = lexer::TokenKind::Tilde; left = interp; right = e_str("-tail") }
    let t = match type_binary(chain, empty_env(), empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    match t.kind {
        TStrLit as s => teko::assert::is_true(s.text == "no holes-tail")
        _ => teko::assert::is_true(false)
    }
}

#test
fn types_compare_and_unary() {
    let env = define(empty_env(), "x", u32t(), false)
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cmp = parser::Compare { first = e_var("x"); rest = crest }
    let tc = match type_compare(cmp, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tc.type, PrimKind::Bool))
    let un = parser::Unary { op = lexer::TokenKind::Bang; operand = ek(cmp) }   // !(x < x) — operand is bool
    let tu = match type_unary(un, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tu.type, PrimKind::Bool))
}

#test
fn types_call() {
    let env0 = define(empty_env(), "x", u32t(), false)
    let params: []Type = teko::list::push(teko::list::empty(), u32t())
    let env = define(env0, "f", Func { params = params; ret = boolt(); variadic = false; param_names = []; n_required = (params).len; defaults = [] }, false)
    let args: []parser::Expr = teko::list::push(teko::list::empty(), e_var("x"))
    let tcall = match type_call(parser::Call { callee = path1("f"); args = args; arg_names = pos_names(args.len) }, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tcall.type, PrimKind::Bool))
    match tcall.kind { TCall as cc => teko::assert::is_true(cc.args.len == 1); _ => teko::assert::is_true(false) }
}

#test
fn types_if_value() {
    let env = define(empty_env(), "x", u32t(), false)
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cond = ek(parser::Compare { first = e_var("x"); rest = crest })
    let iff = parser::IfExpr { cond = cond; then_blk = one_stmt(e_num(1)); has_else = true; else_blk = one_stmt(e_num(2)) }
    let ti = match type_if(iff, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(ti.type, PrimKind::I64))
    match ti.kind { TIfExpr as tif => teko::assert::is_true(tif.has_else); _ => teko::assert::is_true(false) }
}

// a bare (non-binding) literal arm / wildcard arm with the given body value.
fn lit_arm(v: i128, body: i128) -> parser::Arm {
    parser::Arm { pattern = parser::LiteralPattern { value = e_num(v) }; has_when = false; guard = e_num(0); body = one_stmt(e_num(body)) }
}
fn wild_arm(body: i128) -> parser::Arm {
    parser::Arm { pattern = parser::WildcardPattern { }; has_when = false; guard = e_num(0); body = one_stmt(e_num(body)) }
}

#test
fn types_match() {
    let env = define(empty_env(), "n", i64t(), false)
    let arms: []parser::Arm = teko::list::push(teko::list::push(teko::list::empty(), lit_arm(0, 10)), wild_arm(20))
    let m = parser::MatchExpr { subject = e_var("n"); arms = arms }
    let tm = match type_match(m, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tm.type, PrimKind::I64))
    match tm.kind { TMatchExpr as tmm => teko::assert::is_true(tmm.arms.len == 2); _ => teko::assert::is_true(false) }
}

// build a `fn NAME(x: u32) -> <ret> { body }` for the function/return tests.
fn mk_fn(name: str, ret: parser::TypeExpr, body: []parser::Statement) -> parser::Function {
    let p = parser::Param { name = "x"; has_type = true; type_ann = named_t("u32"); is_params = false; has_default = false; default_expr = e_num(0) }
    let params = teko::list::push(teko::list::empty(), p)
    parser::Function { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty() }
}

#test
fn types_function_and_program() {
    let f = mk_fn("id", named_t("u32"), one_stmt(e_var("x")))
    let tf = match type_function(f, empty_env(), empty_table()) { TFunction as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tf.return_type, PrimKind::U32))
    teko::assert::is_true(tf.body.len == 1)
    match tf.body[0] { TExprStmt as es => teko::assert::is_true(prim_is(es.expr.type, PrimKind::U32)); _ => teko::assert::is_true(false) }

    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = f; namespace = ""; file = "" })
    let tp = match type_program(parser::Program { items = items }) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(tp.items.len == 1)
    match tp.items[0] { TFunction as ff => teko::assert::is_true(prim_is(ff.return_type, PrimKind::U32)); _ => teko::assert::is_true(false) }
}

// REGRESSION (self-hosted cross-file top-level fn call): a top-level function declared in a
// namespace (a non-main source file) called UNQUALIFIED from a LOOSE top-level statement (the
// virtual-main / main.tks) in the SAME namespace. type_program must set the threaded scope's
// cur_ns to each item's namespace BEFORE typing a loose statement, so lookup_call's `b.ns ==
// env.cur_ns` clause matches the fn (registered with ns="order_test"). Before the fix, the loose
// statement was typed with cur_ns="" → "unknown function". The .c twin already set cur.cur_ns per
// item; this guards the .tks parity so `./bin/teko <project>` matches `./build/teko <project>`.
#test
fn resolves_unqualified_cross_file_call_from_main() {
    // fn use_counter(x: u32) -> u32 { x }  in namespace "order_test" (as if from counter.tks)
    let f = mk_fn("use_counter", named_t("u32"), one_stmt(e_var("x")))
    let fitem = parser::Item { content = f; namespace = "order_test"; file = "counter.tks" }
    // a LOOSE top-level statement `let _ = use_counter(21)` in the SAME namespace (as if from
    // main.tks): an UNQUALIFIED call to the cross-file fn. `_` is the discard binding (exempt from
    // the unused-local check); the call resolving is the point under test.
    let callargs = teko::list::push(teko::list::empty(), e_num(21))
    let callexpr = ek(parser::Call { callee = path1("use_counter"); args = callargs; arg_names = pos_names(callargs.len) })
    let discard = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "_" }; has_type = false; type_ann = named_t("u32"); value = callexpr }
    let sitem = parser::Item { content = discard; namespace = "order_test"; file = "main.tks" }
    let items2 = teko::list::push(teko::list::push(teko::list::empty(), fitem), sitem)
    // Before the fix this returns error "unknown function: use_counter"; after, it type-checks OK.
    match type_program(parser::Program { items = items2 }) {
        TProgram as tp2 => teko::assert::is_true(tp2.items.len == 2)
        error => teko::assert::is_true(false)
    }
}

#test
fn rejects_ill_typed() {
    let env2 = define(define(empty_env(), "x", u32t(), false), "y", u8t(), false)
    // mixed-width arithmetic — no promotion (B.22).
    let mix = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("x"); right = e_var("y") }
    match type_binary(mix, env2, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // an undefined name has no type.
    match type_var(parser::Var { name = "z" }, empty_env()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // an `if` used as a VALUE needs an `else` (B.20).
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cond = ek(parser::Compare { first = e_var("x"); rest = crest })
    let noelse = parser::IfExpr { cond = cond; then_blk = one_stmt(e_num(1)); has_else = false; else_blk = one_stmt(e_num(1)) }
    match type_if(noelse, env2, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // a non-exhaustive `match` (integer subject, only a literal arm, no `_`).
    let envi = define(empty_env(), "n", i64t(), false)
    let arms: []parser::Arm = teko::list::push(teko::list::empty(), lit_arm(0, 1))
    match type_match(parser::MatchExpr { subject = e_var("n"); arms = arms }, envi, empty_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- C2 cast helpers ---
fn i8t() -> Type { Prim { kind = PrimKind::I8 } }
fn i16t() -> Type { Prim { kind = PrimKind::I16 } }
fn i32t() -> Type { Prim { kind = PrimKind::I32 } }
fn strt() -> Type { Str { } }
fn cast_of(varname: str, target_name: str) -> parser::Cast {
    parser::Cast { expr = e_var(varname); target = named_t(target_name) }
}
fn cast_types_to(varname: str, src: Type, target_name: str, want: PrimKind) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, target_name), env, empty_table()) { TExpr as te => prim_is(te.type, want); error => false }
}
fn cast_errors(varname: str, src: Type, target_name: str) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, target_name), env, empty_table()) { TExpr => false; error => true }
}
fn cast_const_types_to(v: i64, target_name: str, want: PrimKind) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t(target_name) }
    match type_cast(c, empty_env(), empty_table()) { TExpr as te => prim_is(te.type, want); error => false }
}
fn cast_const_errors(v: i64, target_name: str) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t(target_name) }
    match type_cast(c, empty_env(), empty_table()) { TExpr => false; error => true }
}

#test
fn casts_allowed() {
    teko::assert::is_true(cast_types_to("a", i8t(), "i32", PrimKind::I32))
    teko::assert::is_true(cast_types_to("c", i32t(), "i8", PrimKind::I8))
    teko::assert::is_true(cast_types_to("d", i32t(), "u32", PrimKind::U32))
    teko::assert::is_true(cast_types_to("e", u32t(), "i8", PrimKind::I8))
    teko::assert::is_true(cast_types_to("f", i32t(), "i32", PrimKind::I32))
    teko::assert::is_true(cast_const_types_to(200, "u8", PrimKind::U8))
    teko::assert::is_true(cast_const_types_to(5, "i8", PrimKind::I8))
}

#test
fn casts_forbidden() {
    teko::assert::is_true(cast_errors("a", boolt(), "i32"))
    teko::assert::is_true(cast_errors("b", i32t(), "bool"))
    teko::assert::is_true(cast_errors("c", strt(), "i32"))
    teko::assert::is_true(cast_const_errors(300, "i8"))
    teko::assert::is_true(cast_const_errors(-1, "u8"))
    teko::assert::is_true(cast_const_errors(5000000000, "i32"))
}

#test
fn revalidate_rederives_casts() {
    let goodinner = TExpr { kind = TVar { name = "y"; is_func = false; func_ns = "" }; type = i32t(); line = 0; col = 0 }
    let good = TExpr { kind = TCast { expr = goodinner }; type = i8t(); line = 0; col = 0 }
    match validate_texpr(good) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let badinner = TExpr { kind = TVar { name = "s"; is_func = false; func_ns = "" }; type = strt(); line = 0; col = 0 }
    let bad = TExpr { kind = TCast { expr = badinner }; type = i32t(); line = 0; col = 0 }
    match validate_texpr(bad) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- byte↔int cast helpers (byte casts AS u8 — B.36) ---
fn bytet() -> Type { Byte { } }
fn cast_types_to_byte(varname: str, src: Type) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, "byte"), env, empty_table()) { TExpr as te => type_eq(te.type, Byte { }); error => false }
}
fn cast_const_types_to_byte(v: i64) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t("byte") }
    match type_cast(c, empty_env(), empty_table()) { TExpr as te => type_eq(te.type, Byte { }); error => false }
}

#test
fn byte_int_casts_allowed() {
    teko::assert::is_true(cast_types_to("a", bytet(), "u32", PrimKind::U32))
    teko::assert::is_true(cast_types_to("b", bytet(), "u8", PrimKind::U8))
    teko::assert::is_true(cast_types_to("c", bytet(), "i64", PrimKind::I64))
    teko::assert::is_true(cast_types_to_byte("d", u8t()))
    teko::assert::is_true(cast_types_to_byte("e", u32t()))
    teko::assert::is_true(cast_const_types_to_byte(200))
}

#test
fn byte_int_casts_forbidden() {
    teko::assert::is_true(cast_const_errors(300, "byte"))
    teko::assert::is_true(cast_const_errors(-1, "byte"))
    teko::assert::is_true(cast_errors("a", boolt(), "byte"))
    teko::assert::is_true(cast_errors("b", bytet(), "bool"))
    teko::assert::is_true(cast_errors("c", bytet(), "str"))
}

#test
fn revalidate_rederives_byte_casts() {
    let gi = TExpr { kind = TVar { name = "b"; is_func = false; func_ns = "" }; type = bytet(); line = 0; col = 0 }
    let g = TExpr { kind = TCast { expr = gi }; type = u32t(); line = 0; col = 0 }
    match validate_texpr(g) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let gi2 = TExpr { kind = TVar { name = "x"; is_func = false; func_ns = "" }; type = u8t(); line = 0; col = 0 }
    let g2 = TExpr { kind = TCast { expr = gi2 }; type = bytet(); line = 0; col = 0 }
    match validate_texpr(g2) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let bi = TExpr { kind = TVar { name = "b"; is_func = false; func_ns = "" }; type = bytet(); line = 0; col = 0 }
    let bad = TExpr { kind = TCast { expr = bi }; type = boolt(); line = 0; col = 0 }
    match validate_texpr(bad) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- C3 field-access: a TypeTable with one struct `Foo { token: u8 }` ---
fn foo_decl() -> parser::TypeDecl {
    let fld = parser::Field { name = "token"; type_ann = named_t("u8"); vis = parser::Visibility::Pub; is_intern = false }
    let fields = teko::list::push(teko::list::empty(), fld)
    parser::TypeDecl { name = "Foo"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
}
fn foo_table() -> TypeTable {
    teko::list::push(teko::list::empty(), TypeReg { name = "Foo"; namespace = ""; vis = parser::Visibility::Private; decl = foo_decl() })
}
fn foo_env() -> Env { define(empty_env(), "s", Named { name = "Foo" }, false) }

#test
fn field_read_types_to_field_type() {
    let fa = parser::FieldAccess { receiver = e_var("s"); field = "token" }
    match type_field_access(fa, foo_env(), foo_table()) { TExpr as te => teko::assert::is_true(prim_is(te.type, PrimKind::U8)); error => teko::assert::is_true(false) }
}

#test
fn field_not_found_errors() {
    let fa = parser::FieldAccess { receiver = e_var("s"); field = "nope" }
    match type_field_access(fa, foo_env(), foo_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn field_on_non_struct_errors() {
    let env = define(empty_env(), "n", Prim { kind = PrimKind::I32 }, false)
    let fa = parser::FieldAccess { receiver = e_var("n"); field = "token" }
    match type_field_access(fa, env, foo_table()) { TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn revalidate_rederives_field_access() {
    let recv = TExpr { kind = TVar { name = "s"; is_func = false; func_ns = "" }; type = Named { name = "Foo" }; line = 0; col = 0 }
    let good = TExpr { kind = TFieldAccess { receiver = recv; field = "token" }; type = Prim { kind = PrimKind::U8 }; line = 0; col = 0 }
    match validate_texpr(good) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let badrecv = TExpr { kind = TVar { name = "n"; is_func = false; func_ns = "" }; type = Prim { kind = PrimKind::I32 }; line = 0; col = 0 }
    let bad = TExpr { kind = TFieldAccess { receiver = badrecv; field = "token" }; type = Prim { kind = PrimKind::U8 }; line = 0; col = 0 }
    match validate_texpr(bad) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn mut_rule_assign() {
    let menv = define(empty_env(), "m", u32t(), true)
    let ok = parser::Assign { kind = parser::AssignKind::Simple; name = "m"; op = lexer::TokenKind::Assign; value = e_var("m"); deref = false; target = parser::no_expr() }
    match type_assign(ok, menv, empty_table()) { TypedStmt => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let lenv = define(empty_env(), "l", u32t(), false)
    let bad = parser::Assign { kind = parser::AssignKind::Simple; name = "l"; op = lexer::TokenKind::Assign; value = e_var("l"); deref = false; target = parser::no_expr() }
    match type_assign(bad, lenv, empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

fn binding_of(name: str, ann: str, value: parser::Expr) -> parser::Binding {
    parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; has_type = true; type_ann = named_t(ann); value = value }
}

#test
fn annotated_literal() {
    let b = binding_of("x", "u8", e_num(1))
    match type_binding(b, empty_env(), empty_table()) {
        TypedStmt as ts => match ts.node {
            TBinding as tb => {
                teko::assert::is_true(prim_is(tb.bound, PrimKind::U8))
                // #68: a fitting bare-literal initializer ADOPTS the declared narrow type — the
                // leaf itself is retyped to u8 (not left at the literal's natural i64), so
                // codegen/VM see the narrow width (e.g. a later `<<=` masks by 7, not 63).
                teko::assert::is_true(prim_is(tb.value.type, PrimKind::U8))
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
    let b2 = binding_of("y", "u8", e_num(999))
    match type_binding(b2, empty_env(), empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let env = define(empty_env(), "w", i32t(), false)
    let b3 = binding_of("z", "u8", e_var("w"))
    match type_binding(b3, env, empty_table()) { TypedStmt => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

fn arr_elems3(v0: i128, v1: i128, v2: i128) -> parser::ArrayLit {
    mut es: []parser::ArrayElem = teko::list::empty()
    es = teko::list::push(es, parser::ArrayElem { is_spread = false; expr = e_num(v0) })
    es = teko::list::push(es, parser::ArrayElem { is_spread = false; expr = e_num(v1) })
    es = teko::list::push(es, parser::ArrayElem { is_spread = false; expr = e_num(v2) })
    parser::ArrayLit { elements = es }
}

// (#71) `annotated_literal_ok` over an ARRAY LITERAL `[1, 2, 3]` against a PRE-BUILT `[]u8` Type
// (constructed directly — NOT via resolve_type on a hand-built nested parser::SliceType AST node,
// which hits a known VM-only latent bug: single-field wrapper TypeExpr variants like SliceType
// get transparent-field-descended into their FIRST-declared inner arm by the VM's pat_match, so
// `resolve_type(SliceType{element: NamedType{"u8"}}, …)` misresolves under `teko test`/the .tkt
// runner to the element's own resolve (Prim{U8}) instead of wrapping it in Slice — see
// [[teko-vm-wrapper-descent-bug]]; NATIVE resolve_type is unaffected, proven by the real
// examples/regressions/array_literal_narrow_binding differential fixture, which type-checks and
// runs correctly on BOTH engines end-to-end through the real parser). Testing annotated_literal_ok
// directly with a pre-built Type sidesteps that unrelated VM quirk entirely.
// EVERY non-spread element must itself be a fitting literal for u8; NULL = all adopt.
#test
fn annotated_array_literal_ok_recurses_element_wise() {
    let u8_slice: Type = Slice { element = Prim { kind = PrimKind::U8 } }
    match annotated_literal_ok(ek(arr_elems3(1, 2, 3)), u8_slice) { null => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    // (#71) out-of-range element: `[1, 300, 3]` against []u8 must remain a compile ERROR (adoption
    // is gated by the SAME per-element range check as the scalar case — value_fits).
    match annotated_literal_ok(ek(arr_elems3(1, 300, 3)), u8_slice) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    // a non-slice annotation over an array literal is rejected outright.
    match annotated_literal_ok(ek(arr_elems3(1, 2, 3)), Prim { kind = PrimKind::U8 }) { null => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// (#71) `retype_literal` over a checked `[1, 2, 3]` TArrayLit RECURSES element-wise: the array's
// own `.type` becomes the target slice AND every element leaf is individually retyped to the
// element type — not just the array's outer `.type` (the #68 mechanism only retyped the top-level
// leaf; #71 extends it one level into array elements). Built directly on typed nodes (TExpr/
// TArrayLit/TArrayElem), bypassing type_binding/resolve_type entirely (same VM-safety rationale
// as the annotated_literal_ok test above).
#test
fn retype_literal_recurses_into_array_elements() {
    let i64_elem: Type = i64t()
    let e0 = tnum(1)
    let e1 = tnum(2)
    let elems: []TArrayElem = teko::list::push(teko::list::push(teko::list::empty(), TArrayElem { is_spread = false; expr = e0 }), TArrayElem { is_spread = false; expr = e1 })
    let arr = TExpr { kind = TArrayLit { elements = elems }; type = Slice { element = i64_elem }; line = 0; col = 0 }
    let u8_slice: Type = Slice { element = Prim { kind = PrimKind::U8 } }
    let retyped = retype_literal(arr, u8_slice)
    // the array's own .type is now []u8
    match retyped.type { Slice as s => teko::assert::is_true(prim_is(s.element, PrimKind::U8)); _ => teko::assert::is_true(false) }
    // EVERY element leaf is retyped to u8 individually — the actual #71 gap (#68 only retyped the
    // array's own .type, not the elements inside it).
    match retyped.kind {
        TArrayLit as al => {
            teko::assert::is_true(al.elements.len == 2)
            teko::assert::is_true(prim_is(al.elements[0].expr.type, PrimKind::U8))
            teko::assert::is_true(prim_is(al.elements[1].expr.type, PrimKind::U8))
        }
        _ => teko::assert::is_true(false)
    }
}

// (#71) control — a PLAIN (non-array) leaf still retypes wholesale, unchanged from #68's behavior
// (retype_literal's non-TArrayLit branch).
#test
fn retype_literal_plain_leaf_unchanged_from_68() {
    let retyped = retype_literal(tnum(1), Prim { kind = PrimKind::U8 })
    teko::assert::is_true(prim_is(retyped.type, PrimKind::U8))
}

#test
fn return_type_checks() {
    let body1 = one_stmt(e_var("x"))
    match type_function(mk_fn("f", named_t("u32"), body1), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let body2: []parser::Statement = teko::list::push(teko::list::empty(), ret_stmt(e_var("x")))
    match type_function(mk_fn("f", named_t("u32"), body2), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let loopbody: []parser::Statement = teko::list::push(teko::list::empty(), ret_stmt(e_var("x")))
    let body3: []parser::Statement = teko::list::push(teko::list::empty(), loop_stmt(loopbody))
    match type_function(mk_fn("f", named_t("u32"), body3), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let umembers: []parser::TypeExpr = teko::list::push(teko::list::push(teko::list::empty(), named_t("u32")), named_t("error"))
    let body4: []parser::Statement = teko::list::push(teko::list::empty(), ret_stmt(e_var("x")))
    match type_function(mk_fn("f", parser::UnionType { members = umembers }, body4), empty_env(), empty_table()) { TFunction => teko::assert::is_true(true); error => teko::assert::is_true(false) }
}

#test
fn return_type_mismatch_errors() {
    let body1 = one_stmt(e_var("x"))
    match type_function(mk_fn("f", named_t("u8"), body1), empty_env(), empty_table()) { TFunction => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let body2: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = e_var("x") })
    match type_function(mk_fn("f", named_t("u8"), body2), empty_env(), empty_table()) { TFunction => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

// --- C7: pattern checking + exhaustiveness over a variant Color = RED | GREEN | BLUE ---
fn color_subject() -> Type {
    mut members: []Type = teko::list::empty()
    members = teko::list::push(members, Named { name = "RED" })
    members = teko::list::push(members, Named { name = "GREEN" })
    members = teko::list::push(members, Named { name = "BLUE" })
    Variant { members = members }
}
fn color_table() -> TypeTable {
    mut t: TypeTable = teko::list::empty()
    mut i = 0
    let names = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RED"), "GREEN"), "BLUE")
    loop {
        if i >= names.len { break }
        let td = parser::TypeDecl { name = names[i]; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::empty(); methods = teko::list::empty(); implements = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = "" }
        t = teko::list::push(t, TypeReg { name = names[i]; namespace = ""; vis = parser::Visibility::Private; decl = td })
        i++
    }
    t
}
fn case_pat(name: str) -> parser::Pattern { parser::BindPattern { type_name = path1(name); has_binding = false; binding = ""; is_slice = false; slice_type = null; type_args = teko::list::empty() } }
fn arm_of(p: parser::Pattern) -> parser::Arm { parser::Arm { pattern = p; has_when = false; guard = e_num(0); body = one_stmt(e_num(0)) } }
fn guarded_arm_of(p: parser::Pattern) -> parser::Arm { parser::Arm { pattern = p; has_when = true; guard = ek(parser::BoolLit { value = true }); body = one_stmt(e_num(0)) } }

#test
fn field_pattern_binds_fields() {
    let fp = parser::FieldPattern { type_name = path1("Foo"); fields = teko::list::push(teko::list::empty(), "token") }
    let e2 = match check_pattern(fp, Named { name = "Foo" }, foo_env(), foo_table()) { Env as e => e; error => { teko::assert::is_true(false); return } }
    match lookup(e2, "token") { Type as t => teko::assert::is_true(prim_is(t, PrimKind::U8)); error => teko::assert::is_true(false) }
}

#test
fn field_pattern_barriers() {
    let badfield = parser::FieldPattern { type_name = path1("Foo"); fields = teko::list::push(teko::list::empty(), "nope") }
    match check_pattern(badfield, Named { name = "Foo" }, foo_env(), foo_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let prim = parser::FieldPattern { type_name = path1("u8"); fields = teko::list::empty() }
    match check_pattern(prim, Named { name = "Foo" }, foo_env(), foo_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn range_pattern_check() {
    let env = define(empty_env(), "n", i64t(), false)
    let rp = parser::RangePattern { lo = e_num(0); hi = e_num(9) }
    match check_pattern(rp, i64t(), env, empty_table()) { Env => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    let rpb = parser::RangePattern { lo = e_num(0); hi = e_num(1) }
    match check_pattern(rpb, boolt(), env, empty_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    let rps = parser::RangePattern { lo = e_str("a"); hi = e_num(9) }
    match check_pattern(rps, i64t(), env, empty_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn alt_pattern_check() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    let alt = parser::AltPattern { options = opts }
    match check_pattern(alt, color_subject(), empty_env(), color_table()) { Env => teko::assert::is_true(true); error => teko::assert::is_true(false) }
    mut bopts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    bopts = teko::list::push(bopts, parser::BindPattern { type_name = path1("GREEN"); has_binding = true; binding = "g"; is_slice = false; slice_type = null; type_args = teko::list::empty() })
    let balt = parser::AltPattern { options = bopts }
    match check_pattern(balt, color_subject(), empty_env(), color_table()) { Env => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn exhaustive_with_alt() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    mut arms: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(parser::AltPattern { options = opts }))
    arms = teko::list::push(arms, arm_of(case_pat("BLUE")))
    teko::assert::is_true(exhaustive(arms, color_subject(), color_table(), ""))
}

#test
fn exhaustive_barriers() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    let arms1: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(parser::AltPattern { options = opts }))
    teko::assert::is_false(exhaustive(arms1, color_subject(), color_table(), ""))
    mut arms2: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(case_pat("RED")))
    arms2 = teko::list::push(arms2, arm_of(case_pat("GREEN")))
    arms2 = teko::list::push(arms2, guarded_arm_of(case_pat("BLUE")))
    teko::assert::is_false(exhaustive(arms2, color_subject(), color_table(), ""))
    let arms3: []parser::Arm = teko::list::push(teko::list::empty(), guarded_arm_of(parser::WildcardPattern { }))
    teko::assert::is_false(exhaustive(arms3, color_subject(), color_table(), ""))
}

