#test
fn flags_wrong_arg_type_is_error() {
    // has() called with an i64 (not the same flags type) -- must fail.
    let call = perm_method_call("has", e_num(1))
    let items = teko::list::push(teko::list::push(teko::list::empty(), perm_item()), parser::Item { content = perm_bind_p(); namespace = ""; file = "" })
    let items2 = teko::list::push(items, parser::Item { content = call; namespace = ""; file = "" })
    match type_program(parser::Program { items = items2 }) {
        TProgram => teko::assert::is_true(false)   // must fail
        error    => teko::assert::is_true(true)
    }
}
