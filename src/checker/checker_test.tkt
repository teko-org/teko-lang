// src/checker/checker_test.tkt — tests for the typer (C1). #test functions the runner collects.
// The typer is unit-tested on HAND-BUILT AST: each type_* must produce a fully typed node (happy)
// or refuse an ill-typed one (barrier). Rewritten to current Teko (the `Expr` node-wrapper C1-POS,
// all-fields struct literals, `Function`/`Arm`/`TypeDecl`/`Item` shapes) and module-qualified.

use teko::parser

// --- AST constructors (every expression is wrapped in a positioned `parser::Expr`) ---
fn ek(k: parser::ExprKind) -> parser::Expr { parser::Expr { kind = k; line = 0; col = 0 } }
fn e_num(v: i128) -> parser::Expr { ek(parser::Number { is_float = false; value = v; fval = 0.0 }) }
fn e_var(name: str) -> parser::Expr { ek(parser::Var { name = name }) }
// DEFARGS (2026-07-01) — an all-positional arg_names array of length n, for tests unrelated to named-call.
fn pos_names(n: u64) -> []str {
    mut out: []str = teko::list::empty()
    mut i: u64 = 0
    loop { if i >= n { break }; out = teko::list::push(out, ""); i++ }
    out
}
/** st — an expr-statement wrapping `e`, widened to the `Statement` variant. */
fn st(e: parser::Expr) -> parser::Statement { parser::ExprStmt { expr = e } }
fn one_stmt(e: parser::Expr) -> []parser::Statement { teko::list::push(teko::list::empty(), st(e)) }
/** loop_stmt — a `loop { body }` statement widened to the `Statement` variant (see ret_stmt). */
fn loop_stmt(body: []parser::Statement) -> parser::Statement { parser::LoopStmt { label = ""; init = teko::list::empty(); body = body } }
fn path1(name: str) -> parser::Path { parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) } }
fn named_t(name: str) -> parser::TypeExpr { parser::NamedType { path = path1(name); args = teko::list::empty() } }

// --- Type/env constructors ---
fn u32t() -> Type { Prim { kind = PrimKind::U32 } }
fn u8t() -> Type { Prim { kind = PrimKind::U8 } }
fn i64t() -> Type { Prim { kind = PrimKind::I64 } }
fn boolt() -> Type { Prim { kind = PrimKind::Bool } }
fn empty_env() -> Env { Env { base = teko::list::empty(); bindings = teko::list::empty(); cur_ns = ""; owner_type = ""; di = DiRegistry { providers = teko::list::empty() }; injects = teko::list::empty(); fn_unsafe = false } }
fn empty_table() -> TypeTable { teko::list::empty() }
fn prim_is(t: Type, k: PrimKind) -> bool { match t { Prim as p => p.kind == k; _ => false } }

// (2026-07-01) `~` and the FULL string-literal-kind matrix — plain/verbatim/multi-line all
// decode to a plain StrLit by parse time (no flag leaks), so they fold identically; an
// interpolated string with a REAL hole cannot fold (runtime-dependent); an interpolated string
// with ZERO holes ($"…" / $@"…" with nothing to interpolate) is a rare but foldable edge case.

#test
fn types_compare_and_unary() {
    let env = define(empty_env(), "x", u32t(), false)
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("x") })
    let cmp = parser::Compare { first = e_var("x"); rest = crest }
    let tc = match type_compare(cmp, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tc.type, PrimKind::Bool))
    let un = parser::Unary { op = lexer::TokenKind::Bang; operand = ek(cmp) }   // !(x < x) — operand is bool
    let tu = match type_unary(un, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(tu.type, PrimKind::Bool))
}

// build a `fn NAME(x: u32) -> <ret> { body }` for the function/return tests.
fn mk_fn(name: str, ret: parser::TypeExpr, body: []parser::Statement) -> parser::Function {
    let p = parser::Param { name = "x"; has_type = true; type_ann = named_t("u32"); is_params = false; has_default = false; default_expr = e_num(0) }
    let params = teko::list::push(teko::list::empty(), p)
    parser::Function { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
}

/** lam_collect_descends_loop_init — the closure free-variable collector walks a loop's `init` (and
    body): a var read in the init is collected as a free reference (#517). */
#test
fn lam_collect_descends_loop_init() {
    mut refs: []str = teko::list::empty()
    mut bound: []str = teko::list::empty()
    let ib: parser::Statement = parser::Binding { kind = parser::BindKind::Mut; target = parser::SimpleName { name = "_hi" }; has_type = false; type_ann = named_t("void"); value = e_var("n") }
    let init: []parser::Statement = teko::list::push(teko::list::empty(), ib)
    let brk: []parser::Statement = teko::list::push(teko::list::empty(), parser::BreakStmt { label = "" })
    let loopnode: parser::Statement = parser::LoopStmt { label = ""; init = init; body = brk }
    let stmts: []parser::Statement = teko::list::push(teko::list::empty(), loopnode)
    lam_collect_block(stmts, refs, bound)
    mut found = false
    mut i = 0
    loop {
        if i >= refs.len { break }
        if refs[i] == "n" { found = true }
        i++
    }
    teko::assert::is_true(found)
}

/** chain_stats_descends_loop_init — the self-append-chain escape analysis walks a loop's `init` (and
    body) for the named chain (#517). */
#test
fn chain_stats_descends_loop_init() {
    let init: []TStatement = teko::list::push(teko::list::empty(), t_let("_hi", tnum(3)))
    let brk: []TStatement = teko::list::push(teko::list::empty(), TBreakStmt { label = "" })
    let loopnode: TStatement = TLoopStmt { label = ""; init = init; body = brk }
    let stmts: []TStatement = teko::list::push(teko::list::empty(), loopnode)
    let cs = chain_stats_block(stmts, "x")
    teko::assert::is_true(cs.self_appends == 0)
}

// --- C2 cast helpers ---
fn i8t() -> Type { Prim { kind = PrimKind::I8 } }
fn i16t() -> Type { Prim { kind = PrimKind::I16 } }
fn i32t() -> Type { Prim { kind = PrimKind::I32 } }
fn strt() -> Type { Str { } }
fn cast_of(varname: str, target_name: str) -> parser::Cast {
    parser::Cast { expr = e_var(varname); target = named_t(target_name) }
}
fn cast_types_to(varname: str, src: Type, target_name: str, want: PrimKind) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, target_name), env, empty_table()) { TExpr as te => prim_is(te.type, want); error => false }
}
fn cast_const_types_to(v: i64, target_name: str, want: PrimKind) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t(target_name) }
    match type_cast(c, empty_env(), empty_table()) { TExpr as te => prim_is(te.type, want); error => false }
}
#test
fn casts_allowed() {
    teko::assert::is_true(cast_types_to("a", i8t(), "i32", PrimKind::I32))
    teko::assert::is_true(cast_types_to("c", i32t(), "i8", PrimKind::I8))
    teko::assert::is_true(cast_types_to("d", i32t(), "u32", PrimKind::U32))
    teko::assert::is_true(cast_types_to("e", u32t(), "i8", PrimKind::I8))
    teko::assert::is_true(cast_types_to("f", i32t(), "i32", PrimKind::I32))
    teko::assert::is_true(cast_const_types_to(200, "u8", PrimKind::U8))
    teko::assert::is_true(cast_const_types_to(5, "i8", PrimKind::I8))
}

// --- byte↔int cast helpers (byte casts AS u8 — B.36) ---
fn bytet() -> Type { Byte { } }
fn cast_types_to_byte(varname: str, src: Type) -> bool {
    let env = define(empty_env(), varname, src, false)
    match type_cast(cast_of(varname, "byte"), env, empty_table()) { TExpr as te => type_eq(te.type, Byte { }); error => false }
}
fn cast_const_types_to_byte(v: i64) -> bool {
    let c = parser::Cast { expr = e_num(v to i128); target = named_t("byte") }
    match type_cast(c, empty_env(), empty_table()) { TExpr as te => type_eq(te.type, Byte { }); error => false }
}

#test
fn byte_int_casts_allowed() {
    teko::assert::is_true(cast_types_to("a", bytet(), "u32", PrimKind::U32))
    teko::assert::is_true(cast_types_to("b", bytet(), "u8", PrimKind::U8))
    teko::assert::is_true(cast_types_to("c", bytet(), "i64", PrimKind::I64))
    teko::assert::is_true(cast_types_to_byte("d", u8t()))
    teko::assert::is_true(cast_types_to_byte("e", u32t()))
    teko::assert::is_true(cast_const_types_to_byte(200))
}

// --- C3 field-access: a TypeTable with one struct `Foo { token: u8 }` ---
fn foo_decl() -> parser::TypeDecl {
    let fld = parser::Field { name = "token"; type_ann = named_t("u8"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let fields = teko::list::push(teko::list::empty(), fld)
    parser::TypeDecl { name = "Foo"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
}
fn foo_table() -> TypeTable {
    teko::list::push(teko::list::empty(), TypeReg { name = "Foo"; namespace = ""; vis = parser::Visibility::Private; decl = foo_decl() })
}
// --- C7: pattern checking + exhaustiveness over a variant Color = RED | GREEN | BLUE ---
fn color_subject() -> Type {
    mut members: []Type = teko::list::empty()
    members = teko::list::push(members, Named { name = "RED" })
    members = teko::list::push(members, Named { name = "GREEN" })
    members = teko::list::push(members, Named { name = "BLUE" })
    Variant { members = members }
}
fn color_table() -> TypeTable {
    mut t: TypeTable = teko::list::empty()
    mut i = 0
    let names = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RED"), "GREEN"), "BLUE")
    loop {
        if i >= names.len { break }
        let td = parser::TypeDecl { name = names[i]; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::empty(); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
        t = teko::list::push(t, TypeReg { name = names[i]; namespace = ""; vis = parser::Visibility::Private; decl = td })
        i++
    }
    t
}
fn case_pat(name: str) -> parser::Pattern { parser::BindPattern { type_name = path1(name); has_binding = false; binding = ""; is_slice = false; slice_type = null; type_args = teko::list::empty() } }
fn arm_of(p: parser::Pattern) -> parser::Arm { parser::Arm { pattern = p; has_when = false; guard = e_num(0); body = one_stmt(e_num(0)) } }
fn guarded_arm_of(p: parser::Pattern) -> parser::Arm { parser::Arm { pattern = p; has_when = true; guard = ek(parser::BoolLit { value = true }); body = one_stmt(e_num(0)) } }

#test
fn exhaustive_barriers() {
    mut opts: []parser::Pattern = teko::list::push(teko::list::empty(), case_pat("RED"))
    opts = teko::list::push(opts, case_pat("GREEN"))
    let arms1: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(parser::AltPattern { options = opts }))
    teko::assert::is_false(exhaustive(arms1, color_subject(), color_table(), ""))
    mut arms2: []parser::Arm = teko::list::push(teko::list::empty(), arm_of(case_pat("RED")))
    arms2 = teko::list::push(arms2, arm_of(case_pat("GREEN")))
    arms2 = teko::list::push(arms2, guarded_arm_of(case_pat("BLUE")))
    teko::assert::is_false(exhaustive(arms2, color_subject(), color_table(), ""))
    let arms3: []parser::Arm = teko::list::push(teko::list::empty(), guarded_arm_of(parser::WildcardPattern { }))
    teko::assert::is_false(exhaustive(arms3, color_subject(), color_table(), ""))
}

// ---------------------------------------------------------------------------
// Helpers for extended coverage tests
// ---------------------------------------------------------------------------
fn color_enum_decl() -> parser::TypeDecl {
    let members = teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "RED"), "GREEN"), "BLUE")
    parser::TypeDecl { name = "Color"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::EnumBody { members = members }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
}
fn color_enum_table() -> TypeTable {
    teko::list::push(teko::list::empty(), TypeReg { name = "Color"; namespace = ""; vis = parser::Visibility::Private; decl = color_enum_decl() })
}

// ---------------------------------------------------------------------------
// Group A: numeric predicates + type utilities
// ---------------------------------------------------------------------------
#test
fn checker_basic_predicates() {
    i16t()
    // is_float
    teko::assert::is_true(is_float(Prim { kind = PrimKind::F64 }))
    teko::assert::is_true(is_float(Prim { kind = PrimKind::F32 }))
    teko::assert::is_false(is_float(Prim { kind = PrimKind::I64 }))
    // op_is_arith_bitwise  (%, &, |, ^)
    teko::assert::is_true(op_is_arith_bitwise(lexer::TokenKind::Percent))
    teko::assert::is_true(op_is_arith_bitwise(lexer::TokenKind::Amp))
    teko::assert::is_false(op_is_arith_bitwise(lexer::TokenKind::Plus))
    // prim_width
    teko::assert::is_true(prim_width(PrimKind::I32) == 32)
    teko::assert::is_true(prim_width(PrimKind::U64) == 64)
    teko::assert::is_true(prim_width(PrimKind::I8) == 8)
    // types_eq
    let ts1: []Type = teko::list::push(teko::list::empty(), i64t())
    let ts2: []Type = teko::list::push(teko::list::empty(), i64t())
    let ts3: []Type = teko::list::push(teko::list::empty(), u32t())
    teko::assert::is_true(types_eq(teko::list::empty(), teko::list::empty()))
    teko::assert::is_true(types_eq(ts1, ts2))
    teko::assert::is_false(types_eq(ts1, ts3))
    // float_fits
    teko::assert::is_true(float_fits(3.14, PrimKind::F64))
    teko::assert::is_true(float_fits(1.0, PrimKind::F32))
    teko::assert::is_false(float_fits(1.0, PrimKind::I64))
}

// ---------------------------------------------------------------------------
// Group I: render_func, render_members, union_collect
// ---------------------------------------------------------------------------
#test
fn checker_render_and_join() {
    // render_members directly — two-member variant renders with " | "
    let m1: []Type = teko::list::push(teko::list::empty(), i64t())
    let m2: []Type = teko::list::push(m1, Str { })
    let rms = render_members(m2)
    teko::assert::is_true(teko::str::contains(rms, "|"))
    // render_func directly — "(i64) -> str"
    let fparams: []Type = teko::list::push(teko::list::empty(), i64t())
    let rf = render_func(Func { params = fparams; ret = Str { }; variadic = false; param_names = []; n_required = (fparams).len; defaults = [] })
    teko::assert::is_true(teko::str::contains(rf, "->"))
    // union_collect directly — accumulate two types
    let acc1 = union_collect(teko::list::empty(), i64t(), empty_table())
    teko::assert::is_true(acc1.len == 1)
    let acc2 = union_collect(acc1, Str { }, empty_table())
    teko::assert::is_true(acc2.len == 2)
    // dedup: same type twice → still length 1
    let acc3 = union_collect(teko::list::empty(), i64t(), empty_table())
    let acc4 = union_collect(acc3, i64t(), empty_table())
    teko::assert::is_true(acc4.len == 1)
}

// ---------------------------------------------------------------------------
// Group J: lbl_eq, lbl_enclosing, surface_at
// ---------------------------------------------------------------------------
#test
fn checker_label_surface() {
    // lbl_eq
    teko::assert::is_true(lbl_eq("outer", "outer"))
    teko::assert::is_false(lbl_eq("outer", "inner"))
    // lbl_enclosing
    let scope: []str = teko::list::push(teko::list::push(teko::list::empty(), "outer"), "inner")
    teko::assert::is_true(lbl_enclosing(scope, "outer"))
    teko::assert::is_true(lbl_enclosing(scope, "inner"))
    teko::assert::is_false(lbl_enclosing(scope, "missing"))
    // surface_at
    let e = error { message = "test error" }
    let surfaced = surface_at("test.tks", 3, 7, e)
    teko::assert::is_true(teko::str::contains(surfaced.message, "test.tks"))
}

/** loop_label_must_be_upper_snake — check_labels rejects a lowercase loop label with the
    UPPER_SNAKE diagnostic and accepts an UPPER_SNAKE one (#517 checker-enforced format). */
#test
fn loop_label_must_be_upper_snake() {
    let empty_body: []TStatement = teko::list::empty()
    let bad = teko::list::push(teko::list::empty(), TLoopStmt { label = "outer"; init = teko::list::empty(); body = empty_body })
    let rbad = check_labels(bad, teko::list::empty(), false, teko::list::empty())
    teko::assert::is_true(rbad.failed)
    teko::assert::is_true(teko::str::contains(rbad.message, "UPPER_SNAKE"))
    let good = teko::list::push(teko::list::empty(), TLoopStmt { label = "OUTER"; init = teko::list::empty(); body = empty_body })
    let rgood = check_labels(good, teko::list::empty(), false, teko::list::empty())
    teko::assert::is_false(rgood.failed)
}

// (S4) generics inference primitives — subst_type / unify / collect_sig_type_params.
#test
fn subst_unify_inference() {
    let tbl: TypeTable = teko::list::empty()
    let params: []str = teko::list::push(teko::list::empty(), "T")
    let s0 = Subst { params = params; names = teko::list::empty(); types = teko::list::empty() }
    let patT: Type = Named { name = "T" }

    // unify Named{T} ~ i64 binds T=i64; subst_type then yields i64.
    let s1 = match unify(patT, i64t(), s0, tbl) { Subst as x => x; error => s0 }
    teko::assert::is_true(prim_is(subst_type(patT, s1), PrimKind::I64))
    // a non-type-param Named passes through subst unchanged.
    teko::assert::is_true(match subst_type(Named { name = "Other" }, s1) { Named as n => n.name == "Other"; _ => false })

    // unify []T ~ []str binds T=str; subst []T → []str (structural recursion).
    let patSlice: Type = Slice { element = Named { name = "T" } }
    let s2 = match unify(patSlice, Slice { element = Str { } }, s0, tbl) { Subst as x => x; error => s0 }
    teko::assert::is_true(match subst_type(patSlice, s2) { Slice as sl => match sl.element { Str => true; _ => false }; _ => false })

    // a Void-sentinel arg (empty()/null) cannot pin a type-param → unify errors.
    teko::assert::is_true(match unify(patSlice, Slice { element = Void { } }, s0, tbl) { Subst => false; error => true })

    // collect_sig_type_params over Func{(T) -> T} → ["T"] (deduped).
    let sig: Type = Func { params = teko::list::push(teko::list::empty(), Named { name = "T" }); ret = Named { name = "T" }; variadic = false; param_names = []; n_required = (teko::list::push(teko::list::empty(), Named { name = "T" })).len; defaults = [] }
    let tps = collect_sig_type_params(sig, tbl, teko::list::empty())
    teko::assert::is_true(tps.len == 1)
    teko::assert::is_true(tps[0] == "T")
}

// (S4 type-generics) a single-segment NamedType type-expr with no args.
fn ttype_named(name: str) -> parser::TypeExpr {
    parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }; args = teko::list::empty() }
}
// a table with one GENERIC struct decl: `type Box<T> = struct { value: T }`.
fn box_generic_table() -> TypeTable {
    let fld = parser::Field { name = "value"; type_ann = ttype_named("T"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }
    let decl = parser::TypeDecl { name = "Box"; type_params = teko::list::push(teko::list::empty(), "T"); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    teko::list::push(teko::list::empty(), TypeReg { name = "Box"; namespace = ""; vis = parser::Visibility::Private; decl = decl })
}

// (S4 type-generics) resolve_type on `Box<i64>` → Named{Box__g__i64}; arity is validated; the
// mangle helpers produce the shared instance name.
#test
fn resolves_generic_type_instantiation() {
    let tbl = box_generic_table()
    // Box<i64> → Named{"Box__g__i64"}
    let one = teko::list::push(teko::list::empty(), ttype_named("i64"))
    let inst = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = one }
    // (#110) `resolve_type` returns `Type | error`; `Named` is a case of the INNER `Type` variant,
    // not a direct case of the outer `Type | error` subject — double-match (Type as t => match t {…}).
    teko::assert::is_true(match resolve_type(inst, tbl, "") { Type as t => match t { Named as n => n.name == "Box__g__i64"; _ => false }; error => false })

    // wrong arity Box<i64, str> → error
    mut two: []parser::TypeExpr = teko::list::push(teko::list::empty(), ttype_named("i64"))
    two = teko::list::push(two, ttype_named("str"))
    let inst2 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Box" }) }; args = two }
    teko::assert::is_true(match resolve_type(inst2, tbl, "") { error => true; _ => false })

    // a plain `Box` (no args) still resolves nominally — no regression. (#110: double-match, see above.)
    teko::assert::is_true(match resolve_type(ttype_named("Box"), tbl, "") { Type as t => match t { Named as n => n.name == "Box"; _ => false }; error => false })

    // generic_inst_name / type_mangle directly: Box + [i64, str] → "Box__g__i64__str".
    mut at: []Type = teko::list::push(teko::list::empty(), i64t())
    at = teko::list::push(at, Str { })
    teko::assert::is_true(generic_inst_name("Box", at) == "Box__g__i64__str")
}

// (S-mem) `ptr<T>` — typed pointer: resolves to Ptr{inner}, opaque ptr = Ptr{null}, equal-by-inner.
#test
fn resolves_ptr_generic() {
    let ptr_i64 = parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "ptr" }) }; args = teko::list::push(teko::list::empty(), ttype_named("i64")) }
    let pi = match resolve_type(ptr_i64, empty_table(), "") { Type as t => t; error => { teko::assert::is_true(false); return } }
    // STRUCTURE (VM-safe): ptr<i64> → Ptr{inner present = i64}; opaque ptr = Ptr{inner null}; distinct.
    // (exact `ptr_i64`/`ptr<i64>` mangle/render is verified via real codegen, not here — the VM drops
    // a self-recursive match arm's string prefix; see selfhost-vm-perf.)
    teko::assert::is_true(match pi { Ptr as p => match p.inner { null => false; Type as t => match t { Prim => true; _ => false } }; _ => false })
    teko::assert::is_true(type_eq(pi, pi))
    let bare = match resolve_type(ttype_named("ptr"), empty_table(), "") { Type as t => t; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(match bare { Ptr as p => match p.inner { null => true; Type => false }; _ => false })   // opaque ptr = null inner
    teko::assert::is_true(!type_eq(bare, pi))   // opaque ptr ≠ ptr<i64>
}

// ---------------------------------------------------------------------------
// MEM Step 0 — the checker ESCAPE GATE. A `Ref<T>` is memory-safe BY CONSTRUCTION: the ONLY
// permitted flow is PARAMETER PASS-DOWN. These tests drive the checker functions DIRECTLY,
// asserting each forbidden position yields `error` and the allowed forms still succeed.
// Structure/error-only assertions (VM-safe; no message-string match — the VM drops a
// self-recursive match arm's string prefix; mirrors resolves_ref_generic's discipline).
// ---------------------------------------------------------------------------

// a `Ref<INNER>` type-expr where INNER is itself a (hand-built) type-expr.
fn ref_te_of(inner: parser::TypeExpr) -> parser::TypeExpr {
    parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Ref" }) }; args = teko::list::push(teko::list::empty(), inner) }
}
// a `Ref<NAME>` type-expr over a plain named type.
fn ref_te(name: str) -> parser::TypeExpr { ref_te_of(ttype_named(name)) }

// (MEM Step 0, R2) NOT NULLABLE — `Ref<…>?` is an error.
// VM NOTE: a CONSTRUCTED `Ref<value>` cannot be discriminated in the VM (the VM's transparent-
// field-descent collapses a single-field wrapper to its inner — and a constructed Reference VALUE
// matched in a multi-arm match is unreliable), so an isolated `Ref<i64>?` rejection (driven by the
// OptionalType arm's `Reference => error`) is observable only NATIVELY (the C twin's
// `in.tag == TK_TYPE_REF` check + the native self-host enforce it). To assert the OPTIONAL position
// is gated in the VM too, we use a CONSTRUCTION-REJECTED inner (`Ref<Ref<i64>>`): the inner
// `Ref<i64>` resolves, then R1 rejects `Ref<Ref<…>>` at CONSTRUCTION (VM-reliable — matching a
// resolved Reference type-VALUE in resolve_generic_inst), so the error propagates out of the
// OptionalType arm before it ever needs to match a constructed Reference.
#test
fn mem_ref_not_nullable() {
    let ref_opt = parser::OptionalType { inner = ref_te_of(ref_te("i64")) }   // Ref<Ref<i64>>?
    teko::assert::is_true(match resolve_type(ref_opt, empty_table(), "") { error => true; _ => false })
}

#test
/**
 * (MEM Step 0, R4) NOT a STRUCT FIELD — a `struct { r: Ref<…> }` is rejected at collect
 * (validate_type_decls); a struct with a scalar field collects fine.
 *
 * VM NOTE (see R2): the rejected field uses a CONSTRUCTION-REJECTED inner type (`Ref<Ref<i64>>`,
 * built by `ref_te_of(ref_te("i64"))` below) so R1's VM-reliable rejection drives the collect
 * error; the value-inner field (`Ref<i64>`) is instead rejected NATIVELY by the C twin's
 * `tag == TK_TYPE_REF` check in the bare-position field validation.
 *
 * NOTE (bootstrap ordering, issue #285): the doc sits AFTER `#test` here (the pre-existing
 * placement) rather than before it — the RELEASED seed compiler that builds this very source
 * tree does not yet contain this issue's parser fix, so a doc-before-`#test` fixture in the
 * compiler's OWN corpus would fail to bootstrap. The new before-the-attribute placement is
 * exercised in src/parser/parser_test.tkt instead, via a source STRING the compiler parses at
 * runtime (not through its own bootstrap corpus), which needs no such affordance.
 */
fn mem_ref_not_struct_field() {
    let fld = parser::Field { name = "r"; type_ann = ref_te_of(ref_te("i64")); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let decl = parser::TypeDecl { name = "Holder"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let items: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = decl; namespace = ""; file = "" })
    teko::assert::is_true(match collect(parser::Program { items = items }) { error => true; _ => false })
    let okfld = parser::Field { name = "n"; type_ann = named_t("i64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let okdecl = parser::TypeDecl { name = "Holder2"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), okfld); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let okitems: []parser::Item = teko::list::push(teko::list::empty(), parser::Item { content = okdecl; namespace = ""; file = "" })
    teko::assert::is_true(match collect(parser::Program { items = okitems }) { Collected => true; _ => false })
}

// (MEM Step 0, R4) NOT a SLICE ELEMENT / VARIANT MEMBER — `[]Ref<…>` and `Ref<…> | T` reject.
// VM NOTE (see R2): a CONSTRUCTION-REJECTED inner (`Ref<Ref<i64>>`) so R1's VM-reliable rejection
// drives the error out of the SliceType / UnionType arm; the value-inner element/member
// (`[]Ref<i64>` / `Ref<i64> | T`) is rejected NATIVELY by the C twin's `el.tag == TK_TYPE_REF` /
// `m.tag == TK_TYPE_REF` checks.
#test
fn mem_ref_not_collection_or_variant() {
    // []Ref<Ref<i64>> → error.
    teko::assert::is_true(match resolve_type(parser::SliceType { element = ref_te_of(ref_te("i64")) }, empty_table(), "") { error => true; _ => false })
    // Ref<Ref<i64>> | i64 → error (a reference may not be a variant member).
    let members: []parser::TypeExpr = teko::list::push(teko::list::push(teko::list::empty(), ref_te_of(ref_te("i64"))), ttype_named("i64"))
    teko::assert::is_true(match resolve_type(parser::UnionType { members = members }, empty_table(), "") { error => true; _ => false })
}

// (W9.4) a bind pattern carrying explicit type-args `Box<i64> as x` resolves to the stamped instance
// Box__g__i64 (so exhaustiveness / binding use the concrete case type).
#test
fn bind_pattern_explicit_type_args_resolves_instance() {
    let tbl = box_generic_table()
    let args = teko::list::push(teko::list::empty(), ttype_named("i64"))
    let bp = parser::BindPattern { type_name = path1("Box"); has_binding = true; binding = "x"; is_slice = false; slice_type = null; type_args = args }
    // (#110) bind_pattern_type returns `Type | error`; Named is a case of the INNER `Type` variant —
    // double-match the outer Type case first.
    teko::assert::is_true(match bind_pattern_type(bp, tbl, "") { Type as t => match t { Named as n => n.name == "Box__g__i64"; _ => false }; error => false })   // (#109 W1) ref_ns = "" in the test
    // a bare bind (no type-args) keeps the base name (no regression).
    let plain = parser::BindPattern { type_name = path1("Box"); has_binding = true; binding = "x"; is_slice = false; slice_type = null; type_args = teko::list::empty() }
    teko::assert::is_true(match bind_pattern_type(plain, tbl, "") { Type as t => match t { Named as n => n.name == "Box"; _ => false }; error => false })   // (#109 W1) ref_ns = "" in the test
}

// ---------------------------------------------------------------------------
// Group K: monomorphize (S4b crumb 2c) — direct VM coverage of the mono walk.
// Build typed programs by hand (a generic TFunction template + non-generic callers /
// virtual-main statements), call monomorphize, and assert the generic is DROPPED and a
// stamped concrete copy (idg__g__<arg>) appears with the right return type. The generic
// bodies + caller bodies span varied TExprKind / TStatement cases so the total walk and
// both driver phases (seed collection + fixpoint stamping) execute on the VM.
// ---------------------------------------------------------------------------

// a typed VAR expr of a given type.
fn tvar(name: str, t: Type) -> TExpr { TExpr { kind = TVar { name = name; is_func = false; func_ns = "" }; type = t; line = 0; col = 0 } }
// a typed integer literal (i64).
fn tnum(v: i128) -> TExpr { TExpr { kind = TNumber { is_float = false; value = v; fval = 0.0 }; type = i64t(); line = 0; col = 0 } }
// a generic TFunction `fn NAME<T>(x: PARAMSPELL) -> RET { body }`.
fn gfn(name: str, param_ann: parser::TypeExpr, ret: Type, body: []TStatement) -> TFunction {
    let tps: []str = teko::list::push(teko::list::empty(), "T")
    let tcs: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::NoConstraint { })
    let p = parser::Param { name = "x"; has_type = true; type_ann = param_ann; is_params = false; has_default = false; default_expr = e_num(0) }
    let params = teko::list::push(teko::list::empty(), p)
    TFunction { name = name; type_params = tps; type_constraints = tcs; params = params; return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}
// a non-generic TFunction with a hand-built body.
fn plainfn(name: str, ret: Type, body: []TStatement) -> TFunction {
    TFunction { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); return_type = ret; body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; namespace = ""; file = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}
// a typed call `NAME(arg)` with result type `rt`.
fn tcall1(name: str, arg: TExpr, rt: Type) -> TExpr {
    let callee = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }
    let args = teko::list::push(teko::list::empty(), arg)
    TExpr { kind = TCall { callee = callee; args = args; call_ns = ""; is_closure_call = false; callee_type = Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = rt; line = 0; col = 0 }
}
fn texpr_stmt(e: TExpr) -> TStatement { TExprStmt { expr = e } }
fn treturn(e: TExpr) -> TStatement { TReturn { has_value = true; value = e } }
// find a stamped fn (mangled name) in a typed program's items.
fn find_titem_fn(prog: TProgram, name: str) -> bool {
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if teko::runtime::str_eq(f.name, name) { return true } }; _ => { } }
        i++
    }
    false
}
// is there a stamped instance of `bare` (a fn whose name contains "<bare>__g__")? VM-robust:
// it checks the synthetic `__g__` infix, not the full type-arg spelling.
fn has_stamped_instance(prog: TProgram, bare: str) -> bool {
    let needle = teko::str::concat(bare, "__g__")
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if teko::str::contains(f.name, needle) { return true } }; _ => { } }
        i++
    }
    false
}
fn count_generic_fns(prog: TProgram) -> u64 {
    mut n: u64 = 0
    mut i = 0
    loop {
        if i >= prog.items.len { break }
        match prog.items[i] { TFunction as f => { if f.type_params.len > 0 { n++ } }; _ => { } }
        i++
    }
    n
}

#test
fn mono_stamps_two_instances() {
    // fn idg<T>(x: T) -> T { return x } + two callers (i64 + str). After mono: the generic is
    // DROPPED and idg__g__i64 / idg__g__str are stamped; the callers' callees are rewritten.
    let gbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, gbody)
    // a non-generic caller calling idg(7) [i64] and idg("hi") [str] as virtual-main statements.
    let call_i = texpr_stmt(tcall1("idg", tnum(7), i64t()))
    let call_s = texpr_stmt(tcall1("idg", TExpr { kind = TStrLit { text = "hi" }; type = strt(); line = 0; col = 0 }, strt()))
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, call_i)
    items = teko::list::push(items, call_s)
    let prog = TProgram { items = items }
    let mp = match monomorphize(prog, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    // generic dropped; both instances stamped.
    teko::assert::is_true(count_generic_fns(mp) == 0)
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "idg__g__str"))
    // a stamped fn's return type is concrete.
    mut found_i64_ret = false
    mut i = 0
    loop {
        if i >= mp.items.len { break }
        match mp.items[i] { TFunction as f => { if teko::runtime::str_eq(f.name, "idg__g__i64") { found_i64_ret = prim_is(f.return_type, PrimKind::I64) } }; _ => { } }
        i++
    }
    teko::assert::is_true(found_i64_ret)
}

#test
fn mono_slice_and_optional_mangle() {
    // fn firstg<T>(xs: []T) -> T { return xs[0] } called with []i64 → firstg__g__i64 (slice unify
    // in the PARAM pattern: unify([]T, []i64) binds T=i64). The instance name has a plain i64 arg.
    let idx = TExpr { kind = TIndex { receiver = tvar("xs", Slice { element = Named { name = "T" } }); index = tnum(0) }; type = Named { name = "T" }; line = 0; col = 0 }
    let fbody = teko::list::push(teko::list::empty(), treturn(idx))
    let firstg = gfn("firstg", parser::SliceType { element = named_t("T") }, Named { name = "T" }, fbody)
    let arg = tvar("v", Slice { element = i64t() })
    let caller = texpr_stmt(tcall1("firstg", arg, i64t()))
    mut items: []TItem = teko::list::push(teko::list::empty(), firstg)
    items = teko::list::push(items, caller)
    let mp = match monomorphize(TProgram { items = items }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(find_titem_fn(mp, "firstg__g__i64"))

    // a Slice TYPE-ARG (T bound to []i64) drives the slice_<elem> mangle branch in mono_type_mangle:
    // fn idh<T>(x: T) -> T called with arg of type []i64 → T = []i64 → instance idh__g__slice_i64.
    // (The exact slice_ spelling depends on a recursive-match string compose; assert the stamped
    // instance EXISTS via the synthetic `__g__` infix — VM-robust, and still exercises the branch.)
    let hbody = teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" })))
    let idh = gfn("idh", named_t("T"), Named { name = "T" }, hbody)
    let slice_arg = tvar("s", Slice { element = i64t() })
    let hcaller = texpr_stmt(tcall1("idh", slice_arg, Slice { element = i64t() }))
    mut items2: []TItem = teko::list::push(teko::list::empty(), idh)
    items2 = teko::list::push(items2, hcaller)
    let mp2 = match monomorphize(TProgram { items = items2 }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(count_generic_fns(mp2) == 0)
    teko::assert::is_true(has_stamped_instance(mp2, "idh"))
    // directly exercise EVERY mono_type_mangle arm (branch coverage of the mangle + type_to_texpr).
    teko::assert::is_true(teko::str::len(mono_type_mangle(Slice { element = i64t() })) > 0)
    teko::assert::is_true(teko::str::len(mono_type_mangle(Optional { inner = Str { } })) > 0)
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Str { }), "str"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Byte { }), "byte"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Error { }), "error"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Void { }), "void"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Ptr { inner = null }), "ptr"))
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Uptr { }), "uptr"))
    teko::assert::is_true(teko::str::len(mono_type_mangle(Reference { inner = i64t() })) > 0)   // (MEM-1b) recursive mangle — len-only (VM prefix-drop)
    teko::assert::is_true(teko::runtime::str_eq(mono_type_mangle(Named { name = "Foo" }), "Foo"))
}

#test
fn mono_walk_covers_node_kinds() {
    // a generic fn whose body + a non-generic caller body together exercise many TExprKind /
    // TStatement walk cases (binary, compare, if, cast, field-access, struct-init, interp, in,
    // array, coalesce, safe-field, unary, loop, assign, defer, break/continue), all under the
    // total rewrite walk. The generic call inside drives stamping.
    let idg = gfn("idg", named_t("T"), Named { name = "T" }, teko::list::push(teko::list::empty(), treturn(tvar("x", Named { name = "T" }))))

    // non-generic caller body with a grab-bag of typed nodes (well-typedness is not re-checked
    // by mono — it only rewrites types + callees, so hand-built shapes are fine for the walk).
    let n = tvar("n", i64t())
    let bin = TExpr { kind = TBinary { op = lexer::TokenKind::Plus; left = n; right = tnum(1) }; type = i64t(); line = 0; col = 0 }
    let cmpterm = TCmpTerm { op = lexer::TokenKind::Lt; operand = tnum(10) }
    let cmp = TExpr { kind = TCompare { first = n; rest = teko::list::push(teko::list::empty(), cmpterm) }; type = boolt(); line = 0; col = 0 }
    let un = TExpr { kind = TUnary { op = lexer::TokenKind::Minus; operand = n }; type = i64t(); line = 0; col = 0 }
    let cast = TExpr { kind = TCast { expr = n }; type = u8t(); line = 0; col = 0 }
    let cor = TExpr { kind = TCoalesce { left = tvar("o", Optional { inner = i64t() }); right = tnum(0) }; type = i64t(); line = 0; col = 0 }
    let arr = TExpr { kind = TArrayLit { elements = teko::list::push(teko::list::empty(), TArrayElem { is_spread = false; expr = tnum(1) }) }; type = Slice { element = i64t() }; line = 0; col = 0 }
    let interp = TExpr { kind = TInterp { pieces = teko::list::push(teko::list::push(teko::list::empty(), "v"), ""); holes = teko::list::push(teko::list::empty(), n); specs = teko::list::push(teko::list::empty(), TFSpec { kind = TFSpecNone { } }) }; type = strt(); line = 0; col = 0 }
    let inx = TExpr { kind = TInExpr { lhs = n; elems = teko::list::push(teko::list::empty(), tnum(2)) }; type = boolt(); line = 0; col = 0 }
    // an if-expr value with both branches; a match with one wildcard-bodied arm.
    let ife = TExpr { kind = TIfExpr { cond = cmp; then_blk = teko::list::push(teko::list::empty(), texpr_stmt(tnum(1))); has_else = true; else_blk = teko::list::push(teko::list::empty(), texpr_stmt(tnum(2))) }; type = i64t(); line = 0; col = 0 }
    let genstamp = tcall1("idg", tnum(5), i64t())   // drives stamping from within the walk

    // statements: binding, assign, expr, loop (with break/continue), defer, return.
    mut body: []TStatement = teko::list::push(teko::list::empty(), TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "a" }; bound = i64t(); value = bin })
    body = teko::list::push(body, TAssign { kind = parser::AssignKind::Simple; name = "a"; op = lexer::TokenKind::Assign; bound = i64t(); value = un; deref = false; target = no_texpr() })
    body = teko::list::push(body, texpr_stmt(cast))
    body = teko::list::push(body, texpr_stmt(cor))
    body = teko::list::push(body, texpr_stmt(arr))
    body = teko::list::push(body, texpr_stmt(interp))
    body = teko::list::push(body, texpr_stmt(inx))
    body = teko::list::push(body, texpr_stmt(ife))
    body = teko::list::push(body, texpr_stmt(genstamp))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), TBreakStmt { label = "" })
    loopbody = teko::list::push(loopbody, TContinueStmt { label = "" })
    body = teko::list::push(body, TLoopStmt { label = ""; init = teko::list::empty(); body = loopbody })
    body = teko::list::push(body, TDeferStmt { body = teko::list::push(teko::list::empty(), texpr_stmt(tnum(0))) })
    body = teko::list::push(body, treturn(tnum(0)))

    let caller = plainfn("caller", i64t(), body)
    mut items: []TItem = teko::list::push(teko::list::empty(), idg)
    items = teko::list::push(items, caller)
    let mp = match monomorphize(TProgram { items = items }, empty_table()) { TProgram as x => x; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(find_titem_fn(mp, "idg__g__i64"))
    teko::assert::is_true(find_titem_fn(mp, "caller"))
}

// =========================================================================
// MEM Step 1 — THE ESCAPE CHECK (escape.tks). The classifier must (1) call a returned
// allocation ESCAPING (never frame-local — a leak is safe, a UAF is a vulnerability) and
// (2) call a purely-local allocation FRAME-LOCAL (read only through a scalar field copy).
// =========================================================================

// a typed `Node { val = <i64>; }` struct-init value (Node is the recursive value type).
fn t_node_init(val: TExpr) -> TExpr {
    let fnames = teko::list::push(teko::list::empty(), "val")
    let fvals = teko::list::push(teko::list::empty(), val)
    TExpr { kind = TStructInit { field_names = fnames; field_vals = fvals }; type = Named { name = "Node" }; line = 0; col = 0 }
}
// a `let n = <value>` binding (not const, not discard) to a SimpleName — returned as the raw
// TBinding (the codegen's emit_binding receives this same destructured node).
fn t_let(name: str, value: TExpr) -> TBinding {
    TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = name }; bound = value.type; value = value }
}
// `n.val` typed as i64 (a SCALAR field read — a pure copy, so the receiver does not escape).
fn t_field_i64(recv_name: str, field: str) -> TExpr {
    let recv = tvar(recv_name, Named { name = "Node" })
    TExpr { kind = TFieldAccess { receiver = recv; field = field }; type = i64t(); line = 0; col = 0 }
}

#test
fn escape_call_argument_is_escaping() {
    // fn f() { let n = Node { val = 5 }; use(n) }   — `n` is passed to a call ⇒ may be retained
    // ⇒ conservatively ESCAPING (one-depth: a callee could store the argument).
    let binding = t_let("n", t_node_init(tnum(5)))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tcall1("use", tvar("n", Named { name = "Node" }), i64t())))
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))
    teko::assert::is_true(!binding_is_frame_local(esc, binding))
}

// --- MEM Step 1 UAF FIX regression: a TAIL expr-statement is an IMPLICIT RETURN (escaping) ---
// Codegen (emit_block_tail/emit_exprstmt_tail) drops the frame region BEFORE the implicit
// trailing-value return, so a frame-local recursive-struct read in that tail value would be a
// use-after-free. The escape check must AGREE with codegen and mark such a binding ESCAPING.

// `Node { val = <i64>; next = <Node-typed> }` — the recursive back-edge carrying field.
fn t_node_init2(val: TExpr, next: TExpr) -> TExpr {
    mut fnames = teko::list::push(teko::list::empty(), "val")
    fnames = teko::list::push(fnames, "next")
    mut fvals = teko::list::push(teko::list::empty(), val)
    fvals = teko::list::push(fvals, next)
    TExpr { kind = TStructInit { field_names = fnames; field_vals = fvals }; type = Named { name = "Node" }; line = 0; col = 0 }
}
// `n.next` typed as Node (a NON-scalar field read — surfaces an interior pointer).
fn t_field_node(recv_name: str, field: str) -> TExpr {
    let recv = tvar(recv_name, Named { name = "Node" })
    TExpr { kind = TFieldAccess { receiver = recv; field = field }; type = Named { name = "Node" }; line = 0; col = 0 }
}

#test
fn escape_tail_implicit_return_rebox_is_escaping() {
    // fn f() -> Node { let n = Node { val = 5; next = n }; Node { val = n.val; next = n.next } }
    // The trailing struct-init is an IMPLICIT RETURN (no `return` keyword). It re-boxes `n.next`
    // (a NON-scalar interior pointer) into the returned value — so `n` ESCAPES. Before the fix the
    // tail expr-statement was DISCARDED (non-escaping) ⇒ `n` was wrongly frame-local ⇒ the frame
    // region was dropped on the return edge, then the tail dereferenced the freed cell = UAF.
    // The binding does NOT read `n` (no self-reference) — only the TAIL re-box does, so this test
    // genuinely isolates the tail-position escape (not the binding RHS).
    let binding = t_let("n", t_node_init(tnum(5)))
    let tail = t_node_init2(t_field_i64("n", "val"), t_field_node("n", "next"))
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tail))   // implicit-return tail (no `return`)
    let f = plainfn("f", Named { name = "Node" }, body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))   // tail value escapes ⇒ `n` escapes
    teko::assert::is_true(!binding_is_frame_local(esc, binding))   // ⇒ NOT frame-local (routes to root)
}

#test
fn escape_tail_safe_field_coalesce_is_escaping() {
    // fn f() -> Node { let n = Node{…}; (n.next?.next) ?? other }
    // The implicit-return tail reads `n.next` (a NON-scalar interior pointer) via a safe-field
    // access whose receiver is a non-scalar field read, then COALESCES the (non-scalar) result —
    // so `n` ESCAPES. (Reproducer A: `?.` + `??` in the implicit tail.) The safe-field RESULT type
    // is kept NOMINAL (Node, not Optional) to dodge the VM single-field-wrapper-descent landmine
    // [memory: VM conflates Ref/Ptr/Optional/Slice in `match`]; the native engine handles either,
    // and what the escape check needs is only that the result is NON-scalar.
    let binding = t_let("n", t_node_init(tnum(5)))   // binding does NOT read `n` — only the tail does
    let nnext = t_field_node("n", "next")   // n.next : Node (non-scalar interior pointer)
    let sfa = TExpr { kind = TSafeFieldAccess { receiver = nnext; field = "next" }; type = Named { name = "Node" }; line = 0; col = 0 }
    let tail = TExpr { kind = TCoalesce { left = sfa; right = tvar("other", Named { name = "Node" }) }; type = Named { name = "Node" }; line = 0; col = 0 }
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tail))   // implicit-return tail (no `return`)
    let f = plainfn("f", Named { name = "Node" }, body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))   // tail value escapes ⇒ `n` escapes
    teko::assert::is_true(!binding_is_frame_local(esc, binding))
}

// =========================================================================
// S2 — THE PER-BLOCK ESCAPE CHECK (escape.tks::binding_is_block_local). A binding declared in a
// scope-introducing BLOCK may be freed at the block's exit edges ONLY when every read of it in the
// whole function is a SAFE non-tail/non-assign read strictly inside that block. SECURITY-FIRST:
// any read outside B, in B's tail value, or as an assignment RHS ⇒ NOT block-local (route to the
// enclosing region — a leak is safe, a use-after-free is NEVER).
// =========================================================================

#test
fn block_local_read_only_inside_block_is_block_local() {
    // fn f() -> i64 { mut t=0; loop { let n = Node{val=5}; let g = n.val; t = t+g; break }; t }
    // `n` is declared in the LOOP body and read ONLY via a scalar field copy inside it (non-tail,
    // non-assign) ⇒ block-local ⇒ the loop body region may free it per-iteration.
    let binding = t_let("n", t_node_init(tnum(5)))
    mut loopbody: []TStatement = teko::list::push(teko::list::empty(), binding)
    loopbody = teko::list::push(loopbody, t_let("g", t_field_i64("n", "val")))   // let g = n.val (scalar copy)
    loopbody = teko::list::push(loopbody, TBreakStmt { label = "" })
    let loopstmt = TLoopStmt { label = ""; init = teko::list::empty(); body = loopbody }
    mut body: []TStatement = teko::list::push(teko::list::empty(), t_let("t", t_node_init(tnum(0))))
    body = teko::list::push(body, loopstmt)
    body = teko::list::push(body, treturn(t_field_i64("t", "val")))
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    // n is NOT function-escaping (only a scalar copy is read) AND only read inside the loop body.
    teko::assert::is_true(binding_is_block_local(esc, f.body, loopbody, false, binding))
}

// --- MEM Step 1 UAF FIX #2 regression: a SCALAR read through a BOXED HOP (`a.b.y`) escapes ---
// The scalar non-escaping refinement is SOUND ONLY for a scalar field of a BARE local (a stack
// member). `a.b.y` reads a scalar `.y` but THROUGH `a.b` — a boxed (recursive) field that is a
// heap pointer into the frame region. The whole tail value is evaluated AFTER the region drop, so
// dereferencing the freed `a.b` is a use-after-free. The refinement must route `a` to ESCAPING
// because the field-access receiver (`a.b`) is NOT a bare TVar.

#test
fn escape_tail_scalar_through_boxed_hop_is_escaping() {
    // fn f() -> i64 { let n = Node { val = 5 }; n.next.val }
    // `.val` is scalar (i64) but its receiver `n.next` is a NON-scalar (boxed) interior pointer —
    // a frame-region heap hop. The bare-TVar refinement must NOT fire (receiver is a field access,
    // not a TVar) ⇒ `n` ESCAPES ⇒ NOT frame-local (the only sound choice — avoids the UAF).
    let binding = t_let("n", t_node_init(tnum(5)))
    let nnext = t_field_node("n", "next")   // n.next : Node (boxed heap hop)
    let deep = TExpr { kind = TFieldAccess { receiver = nnext; field = "val" }; type = i64t(); line = 0; col = 0 }   // (n.next).val : i64 (scalar through a boxed hop)
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(deep))   // implicit-return tail (no `return`)
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "n"))   // scalar-through-boxed-hop ⇒ `n` escapes
    teko::assert::is_true(!binding_is_frame_local(esc, binding))   // ⇒ NOT frame-local (UAF avoided)
}

#test
fn escape_tail_index_receiver_is_escaping() {
    // fn f() -> i64 { let n = Node { val = 5 }; arr[n.val] }
    // An index read derefs a heap-backed slice. The index sub-expression `n.val` is evaluated
    // post-drop too; `n.val` is a bare-TVar scalar (frame-local), but the receiver `arr` (a TVar)
    // is read in an escaping context. This pins down that the index path propagates escaping to its
    // receiver while still allowing a bare-TVar scalar index (`n.val`) to stay frame-local.
    let binding = t_let("n", t_node_init(tnum(5)))
    let arr = tvar("arr", Slice { element = i64t() })
    let idx = t_field_i64("n", "val")   // n.val : i64 (bare-TVar scalar)
    let tail = TExpr { kind = TIndex { receiver = arr; index = idx }; type = i64t(); line = 0; col = 0 }
    mut body: []TStatement = teko::list::push(teko::list::empty(), binding)
    body = teko::list::push(body, texpr_stmt(tail))   // implicit-return tail (no `return`)
    let f = plainfn("f", i64t(), body)
    let esc = fn_escaping_vars(f)
    teko::assert::is_true(str_set_has(esc, "arr"))   // index receiver (heap slice) escapes
    teko::assert::is_true(!str_set_has(esc, "n"))   // bare-TVar scalar index stays frame-local
    teko::assert::is_true(binding_is_frame_local(esc, binding))
}

// --- OOP A1 (2026-07-01): unified method model -- struct instance + static methods ---------
// `type Pt = struct { x: i64; fn sum(self) -> i64 { self.x }; fn origin() -> i64 { 0 } }` --
// sum(self)=instance (1st param untyped, the receiver), origin()=static (no untyped 1st param).
fn recv_param(name: str) -> parser::Param { parser::Param { name = name; has_type = false; type_ann = named_t("i64"); is_params = false; has_default = false; default_expr = e_num(0) } }
// --- (W10b.IF, 2026-07-01) interface CONFORMANCE checking ------------------------------------
// A bodyless instance-method signature `fn name(self) -> i64` (an interface member).
fn iface_method(name: str) -> parser::Function {
    parser::Function { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::empty(), recv_param("self")); has_return = true; return_type = named_t("i64"); body = teko::list::empty(); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
}
// A concrete instance method `[vis] fn name(self) -> i64 { 0 }`.
fn impl_method(name: str, vis: parser::Visibility) -> parser::Function {
    parser::Function { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::empty(), recv_param("self")); has_return = true; return_type = named_t("i64"); body = one_stmt(e_num(0)); vis = vis; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
}
// A concrete method with an extra typed param `fn name(self, x: i64) -> i64 { 0 }` (signature mismatch).
fn impl_method_arg(name: str, vis: parser::Visibility) -> parser::Function {
    let params = teko::list::push(teko::list::push(teko::list::empty(), recv_param("self")), parser::Param { name = "x"; has_type = true; type_ann = named_t("i64"); is_params = false; has_default = false; default_expr = e_num(0) })
    parser::Function { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = params; has_return = true; return_type = named_t("i64"); body = one_stmt(e_num(0)); vis = vis; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
}
fn iface_item(name: str, methods: []parser::Function, extends: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::InterfaceBody { extends = extends; methods = methods }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn impl_class_item(name: str, methods: []parser::Function, implements: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = implements; fields = teko::list::empty(); methods = methods; consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn list1(x: parser::Function) -> []parser::Function { teko::list::push(teko::list::empty(), x) }
fn slist1(s: str) -> []str { teko::list::push(teko::list::empty(), s) }

// --- flags methods (C8.3, self-host ported 2026-07-01) ---------------------------------------
fn mk_perm_flags() -> parser::TypeDecl {
    let members = teko::list::push(teko::list::push(teko::list::empty(), "Read"), "Write")
    parser::TypeDecl { name = "Perm"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::FlagsBody { members = members; values = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
}
fn perm_item() -> parser::Item { parser::Item { content = mk_perm_flags(); namespace = ""; file = "" } }
fn perm_member(name: str) -> parser::Expr { ek(parser::PathExpr { path = parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "Perm" }), parser::Segment { name = name }) } }) }
// --- (TR0, 2026-07-02) trait derivation — the FOLD + requirement/conflict rules + honest stops ---
// A trait is declared like a struct (fields + methods, bodies optional), derived via the same
// `&`-list as interfaces; fold_traits rewrites derivers BEFORE typing (fields flatten in, bodied
// methods fold in, bodyless methods become requirements). See TEKO_ROADMAP_TRAITS.md TR0.
fn tr_field(name: str) -> parser::Field { parser::Field { name = name; type_ann = named_t("i64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" } }
fn tr_fields1(name: str) -> []parser::Field { teko::list::push(teko::list::empty(), tr_field(name)) }
fn trait_item(name: str, fields: []parser::Field, methods: []parser::Function) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::TraitBody { fields = fields; methods = methods; consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn deriver_struct_item(name: str, fields: []parser::Field, methods: []parser::Function, derives: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = methods; implements = derives; consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn deriver_class_item(name: str, fields: []parser::Field, methods: []parser::Function, derives: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = derives; fields = fields; methods = methods; consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn items2(a: parser::Item, b: parser::Item) -> []parser::Item { teko::list::push(teko::list::push(teko::list::empty(), a), b) }
fn items3(a: parser::Item, b: parser::Item, c: parser::Item) -> []parser::Item { teko::list::push(items2(a, b), c) }
fn tr_program_ok(items: []parser::Item) -> bool {
    match type_program(parser::Program { items = items }) { TProgram => true; error => false }
}

#test
fn trait_fold_class_gains_members() {
    // a CLASS deriving a trait: folded field participates in a factory's class literal, the
    // folded method satisfies nothing but must type-check under the deriver.
    let tr = trait_item("Stamp", tr_fields1("at"), list1(impl_method("stamp", parser::Visibility::Private)))
    let dv = deriver_class_item("C", teko::list::empty(), teko::list::empty(), slist1("Stamp"))
    teko::assert::is_true(tr_program_ok(items2(tr, dv)))
}

#test
fn trait_requirement_sig_mismatch_is_error() {
    // the deriver provides `need(self, x)` where the trait requires `need(self)`.
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let dv = deriver_struct_item("P", tr_fields1("own"), list1(impl_method_arg("need", parser::Visibility::Private)), slist1("Need"))
    teko::assert::is_true(!tr_program_ok(items2(tr, dv)))
}

#test
fn trait_two_bodied_conflict_needs_deriver_override() {
    // two traits both PROVIDE `m` — without a deriver-defined `m` it is a compile error; the
    // deriver defining its own `m` IS the override (no implicit resolution order).
    let t1 = trait_item("T1", teko::list::empty(), list1(impl_method("m", parser::Visibility::Private)))
    let t2 = trait_item("T2", teko::list::empty(), list1(impl_method("m", parser::Visibility::Private)))
    let bad = deriver_struct_item("P", tr_fields1("own"), teko::list::empty(), teko::list::push(slist1("T1"), "T2"))
    teko::assert::is_true(!tr_program_ok(items3(t1, t2, bad)))
    let good = deriver_struct_item("Q", tr_fields1("own"), list1(impl_method("m", parser::Visibility::Private)), teko::list::push(slist1("T1"), "T2"))
    teko::assert::is_true(tr_program_ok(items3(t1, t2, good)))
}

#test
fn trait_field_collision_is_error() {
    // a trait field colliding with the deriver's own field — fields cannot be overridden.
    let tr = trait_item("Stamp", tr_fields1("x"), teko::list::empty())
    let dv = deriver_struct_item("P", tr_fields1("x"), teko::list::empty(), slist1("Stamp"))
    teko::assert::is_true(!tr_program_ok(items2(tr, dv)))
    // ... and across two derived traits.
    let t2 = trait_item("Stamp2", tr_fields1("y"), teko::list::empty())
    let t3 = trait_item("Stamp3", tr_fields1("y"), teko::list::empty())
    let dv2 = deriver_struct_item("Q", tr_fields1("own"), teko::list::empty(), teko::list::push(slist1("Stamp2"), "Stamp3"))
    teko::assert::is_true(!tr_program_ok(items3(t2, t3, dv2)))
}

#test
fn trait_is_not_instantiable() {
    // `Stamp { at = 1 }` — a trait literal is rejected (derive it instead).
    let tr = trait_item("Stamp", tr_fields1("at"), teko::list::empty())
    let lit = ek(parser::StructLit { type_path = path1("Stamp"); type_args = teko::list::empty(); field_names = teko::list::push(teko::list::empty(), "at"); field_vals = teko::list::push(teko::list::empty(), e_num(1)) })
    let bind_v = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "v" }; has_type = false; type_ann = named_t("i64"); value = lit }
    teko::assert::is_true(!tr_program_ok(items2(tr, parser::Item { content = bind_v; namespace = ""; file = "" })))
}

/** (TR1 #176) build a generic `fn <name><T: <trait>>(x: T) -> i64 { <body> }` item — the shape
    the trait-constraint negatives instantiate. `body` is the fn's statement list. */
fn tr_generic_fn(name: str, trait_name: str, body: []parser::Statement) -> parser::Item {
    let p = parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) }
    let cons: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = trait_name })
    let f = parser::Function { name = name; type_params = teko::list::push(teko::list::empty(), "T"); type_constraints = cons; params = teko::list::push(teko::list::empty(), p); has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    parser::Item { content = f; namespace = ""; file = "" }
}

/** (TR1 #176) a loose `let <bind> = <StructName> { <field> = 0 }` binding item (constructs a struct
    deriver value to feed a generic-fn call). */
fn tr_let_struct(bind: str, type_name: str, field: str) -> parser::Item {
    let lit = ek(parser::StructLit { type_path = path1(type_name); type_args = teko::list::empty(); field_names = teko::list::push(teko::list::empty(), field); field_vals = teko::list::push(teko::list::empty(), e_num(0)) })
    let b = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = bind }; has_type = false; type_ann = named_t("i64"); value = lit }
    parser::Item { content = b; namespace = ""; file = "" }
}

#test
fn trait_constraint_nonderiving_arg_is_error() {
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let total = tr_generic_fn("total", "Need", one_stmt(e_num(0)))
    let plain = deriver_struct_item("Plain", tr_fields1("own"), teko::list::empty(), teko::list::empty())
    let mk = tr_let_struct("p", "Plain", "own")
    let call = parser::Item { content = st(ek(parser::Call { callee = path1("total"); args = teko::list::push(teko::list::empty(), e_var("p")); arg_names = teko::list::push(teko::list::empty(), ""); type_args = teko::list::empty() })); namespace = ""; file = "" }
    mut items: []parser::Item = teko::list::push(teko::list::empty(), tr)
    items = teko::list::push(items, total)
    items = teko::list::push(items, plain)
    items = teko::list::push(items, mk)
    items = teko::list::push(items, call)
    teko::assert::is_true(!tr_program_ok(items))
}

#test
fn trait_struct_as_dynamic_value_is_error() {
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let dv = deriver_struct_item("P", tr_fields1("own"), list1(impl_method("need", parser::Visibility::Private)), slist1("Need"))
    let mk = tr_let_struct("p", "P", "own")
    let bind_s = parser::Binding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "s" }; has_type = true; type_ann = named_t("Need"); value = e_var("p") }
    let widen = parser::Item { content = bind_s; namespace = ""; file = "" }
    mut items: []parser::Item = teko::list::push(teko::list::empty(), tr)
    items = teko::list::push(items, dv)
    items = teko::list::push(items, mk)
    items = teko::list::push(items, widen)
    teko::assert::is_true(!tr_program_ok(items))
}

#test
fn trait_constraint_body_calls_unauthorized_method_is_error() {
    let tr = trait_item("Need", teko::list::empty(), list1(iface_method("need")))
    let call_bad = st(ek(parser::MethodCall { receiver = e_var("x"); method = "absent"; args = teko::list::empty() }))
    let total = tr_generic_fn("total", "Need", teko::list::push(teko::list::empty(), call_bad))
    teko::assert::is_true(!tr_program_ok(items2(tr, total)))
}

#test
fn trait_method_with_dispatch_markers_is_error() {
    // `virtual fn` inside a trait body — the class dispatch markers are meaningless in a trait.
    mut m = impl_method("m", parser::Visibility::Private)
    let vm = parser::Function { name = m.name; type_params = m.type_params; type_constraints = m.type_constraints; params = m.params; has_return = m.has_return; return_type = m.return_type; body = m.body; vis = m.vis; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = true; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    let tr = trait_item("Stamp", teko::list::empty(), list1(vm))
    teko::assert::is_true(!tr_program_ok(teko::list::push(teko::list::empty(), tr)))
}

/**
 * (TR3, #177) A struct field of a NAMED type — for the nested-recursion and nested-not-deriving
 * structural-trait tests below.
 *
 * @param name      the field name
 * @param type_name the field's named type
 * @return the `parser::Field`
 */
fn named_field(name: str, type_name: str) -> parser::Field { parser::Field { name = name; type_ann = named_t(type_name); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" } }

/**
 * (TR3) A single-field list holding one `named_field`.
 *
 * @param name      the field name
 * @param type_name the field's named type
 * @return a one-element `[]parser::Field`
 */
fn named_fields1(name: str, type_name: str) -> []parser::Field { teko::list::push(teko::list::empty(), named_field(name, type_name)) }

/**
 * (TR3) A struct deriving all five structural traits over scalar fields type-checks — the
 * synthesized `eq`/`compare`/`hash`/`clone`/`default` all type against the folded field view.
 */
#test
fn structural_derive_over_scalars_synthesizes_and_types() {
    let derives = teko::list::push(teko::list::push(teko::list::push(teko::list::push(slist1("Eq"), "Ord"), "Hash"), "Clone"), "Default")
    let dv = deriver_struct_item("P", tr_fields1("x"), teko::list::empty(), derives)
    teko::assert::is_true(tr_program_ok(teko::list::push(teko::list::empty(), dv)))
}

/**
 * (TR3 crumb 6b) `Eq` over a nested Named field whose type does NOT derive `Eq` is a located error
 * (the recursion has no `.eq` to call); when the nested type DOES derive `Eq`, the recursion
 * resolves and the program type-checks.
 */
#test
fn structural_derive_over_nonderiving_nested_is_error() {
    let q = deriver_struct_item("Q", tr_fields1("own"), teko::list::empty(), teko::list::empty())
    let p = deriver_struct_item("P", named_fields1("q", "Q"), teko::list::empty(), slist1("Eq"))
    teko::assert::is_true(!tr_program_ok(items2(q, p)))
    let q2 = deriver_struct_item("Q2", tr_fields1("own"), teko::list::empty(), slist1("Eq"))
    let p2 = deriver_struct_item("P2", named_fields1("q", "Q2"), teko::list::empty(), slist1("Eq"))
    teko::assert::is_true(tr_program_ok(items2(q2, p2)))
}

/**
 * (TR3 crumb 6c) An enum-typed field under a structural derive is an honest stop: an enum Named is
 * not a supported field shape in v1, so the synthesis raises a located error.
 */
#test
fn structural_derive_on_an_enum_is_error() {
    let members = teko::list::push(teko::list::push(teko::list::empty(), "RED"), "BLUE")
    let ed = parser::TypeDecl { name = "Hue"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::EnumBody { members = members }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let dv = deriver_struct_item("P", named_fields1("hue", "Hue"), teko::list::empty(), slist1("Eq"))
    teko::assert::is_true(!tr_program_ok(items2(parser::Item { content = ed; namespace = ""; file = "" }, dv)))
}

/**
 * (TR3, trait design §2) A deriver that defines `eq` BY HAND keeps its own method — synthesis is
 * SKIPPED for that name (the hand-written method IS the override), and the program type-checks.
 */
#test
fn structural_override_wins_over_synthesis() {
    let own_eq = parser::Function { name = "eq"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::push(teko::list::empty(), parser::Param { name = "self"; has_type = false; type_ann = named_t(""); is_params = false; has_default = false; default_expr = e_num(0) }), parser::Param { name = "other"; has_type = true; type_ann = named_t("P"); is_params = false; has_default = false; default_expr = e_num(0) }); has_return = true; return_type = named_t("bool"); body = one_stmt(ek(parser::BoolLit { value = true })); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    let dv = deriver_struct_item("P", tr_fields1("x"), teko::list::push(teko::list::empty(), own_eq), slist1("Eq"))
    teko::assert::is_true(tr_program_ok(teko::list::push(teko::list::empty(), dv)))
}

/**
 * (TR3, R1) A `<K: Hashable & Eq>` constraint resolves for a deriver of `Hash` + `Eq` — the
 * `Hashable`≡`Hash` synonym lets the Map-key capability constraint bind against a structural-trait
 * deriver, with no parallel interface.
 */
#test
fn structural_constraint_atom_resolves_via_synonym() {
    let derives = teko::list::push(slist1("Hash"), "Eq")
    let dv = deriver_struct_item("K", tr_fields1("x"), teko::list::empty(), derives)
    let hashable_fn = tr_generic_fn("use_key", "Hashable", one_stmt(e_num(0)))
    let mk = tr_let_struct("k", "K", "x")
    let call = parser::Item { content = st(ek(parser::Call { callee = path1("use_key"); args = teko::list::push(teko::list::empty(), e_var("k")); arg_names = teko::list::push(teko::list::empty(), ""); type_args = teko::list::empty() })); namespace = ""; file = "" }
    mut items: []parser::Item = teko::list::push(teko::list::empty(), dv)
    items = teko::list::push(items, hashable_fn)
    items = teko::list::push(items, mk)
    items = teko::list::push(items, call)
    teko::assert::is_true(tr_program_ok(items))
}

/** A full program `fn both<T: Geo & Named2>(x: T) -> i64 { return x.area() }` type-checks: the
    UNION surface authorizes `area` (owned by Geo), and `Sq2` conforms to both interfaces. */
fn s6_and_program(body_method: str) -> parser::Program {
    let ifc_geo = iface_item("Geo", list1(iface_method("area")), teko::list::empty())
    let ifc_named2 = iface_item("Named2", list1(iface_method("label")), teko::list::empty())
    let sq2 = impl_class_item("Sq2", teko::list::push(list1(impl_method("area", parser::Visibility::Pub)), impl_method("label", parser::Visibility::Pub)), teko::list::push(teko::list::push(teko::list::empty(), "Geo"), "Named2"))
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAnd { left = parser::ConstraintAtom { name = "Geo" }; right = parser::ConstraintAtom { name = "Named2" } })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::MethodCall { receiver = e_var("x"); method = body_method; args = teko::list::empty() }) })
    let f = parser::Function { name = "both"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    let fitem = parser::Item { content = f; namespace = ""; file = "" }
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc_geo), ifc_named2)
    items = teko::list::push(items, sq2)
    items = teko::list::push(items, fitem)
    parser::Program { items = items }
}

#test
/** crumb-7 fixture 1: `A&B`, a method of EACH side (`x.area()`) — accepted. */
fn s6_and_constraint_authorizes_either_sides_method() {
    teko::assert::is_true(tr_program_ok(s6_and_program("area").items))
}

#test
/** crumb-7 fixture 4: nominal mono-rejection is UNTOUCHED — a concrete arg conforming to only ONE
    side of `Geo & Named2` (missing `label`/`Named2`) still fails at `check_constraints`, the
    existing per-instance safety net (S6 adds no new instance-time check). */
fn s6_and_constraint_mono_rejects_non_conforming_concrete() {
    let ifc_geo = iface_item("Geo", list1(iface_method("area")), teko::list::empty())
    let ifc_named2 = iface_item("Named2", list1(iface_method("label")), teko::list::empty())
    let sq_geo_only = impl_class_item("SqGeoOnly", list1(impl_method("area", parser::Visibility::Pub)), slist1("Geo"))
    let tp = teko::list::push(teko::list::empty(), "T")
    let tc: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAnd { left = parser::ConstraintAtom { name = "Geo" }; right = parser::ConstraintAtom { name = "Named2" } })
    let params = teko::list::push(teko::list::empty(), parser::Param { name = "x"; has_type = true; type_ann = named_t("T"); is_params = false; has_default = false; default_expr = e_num(0) })
    let body: []parser::Statement = teko::list::push(teko::list::empty(), parser::Return { has_value = true; value = ek(parser::MethodCall { receiver = e_var("x"); method = "area"; args = teko::list::empty() }) })
    let f = parser::Function { name = "both2"; type_params = tp; type_constraints = tc; params = params; has_return = true; return_type = named_t("i64"); body = body; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    let make_lit = ek(parser::StructLit { type_path = path1("SqGeoOnly"); type_args = teko::list::empty(); field_names = teko::list::empty(); field_vals = teko::list::empty() })
    let call = st(ek(parser::Call { callee = path1("both2"); args = teko::list::push(teko::list::empty(), make_lit); arg_names = pos_names(1); type_args = teko::list::empty() }))
    mut items = teko::list::push(teko::list::push(teko::list::empty(), ifc_geo), ifc_named2)
    items = teko::list::push(items, sq_geo_only)
    items = teko::list::push(items, parser::Item { content = f; namespace = ""; file = "" })
    items = teko::list::push(items, parser::Item { content = call; namespace = ""; file = "" })
    teko::assert::is_true(!tr_program_ok(items))
}

/**
 * (TR2, 2026-07-04) the compile-time FIELD VIEW — `deriver_field_view`. The compiler-internal,
 * deriver-agnostic enumeration of a struct/class's fields with each annotation resolved to a real
 * `Type` (name + type, no runtime value). See TEKO_ROADMAP_TRAITS.md TR2. TR3 (a later unit)
 * synthesizes structural-trait bodies (Eq/Ord/Hash/Clone/Default) from it.
 */
fn fv_field(name: str, type_ann: parser::TypeExpr) -> parser::Field { parser::Field { name = name; type_ann = type_ann; vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" } }
fn fv_struct_item_derives(name: str, fields: []parser::Field, derives: []str) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = derives; consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn fv_class_item(name: str, kind: parser::ClassKind, has_base: bool, base_name: str, fields: []parser::Field) -> parser::Item {
    parser::Item { content = parser::TypeDecl { name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::ClassBody { kind = kind; has_base = has_base; base_name = base_name; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = fields; methods = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }; namespace = ""; file = "" }
}
fn fv_table(items: []parser::Item) -> TypeTable {
    match collect(parser::Program { items = items }) { Collected as c => c.types; error => panic("fv_table: collect failed") }
}

#test
/**
 * `fold_traits` runs before the field view is ever consulted — a struct deriving a trait already
 * carries the trait's field in its OWN `fields` by the time `collect()` sees it.
 */
fn field_view_struct_includes_trait_folded_fields() {
    let tr = trait_item("Stamp", tr_fields1("at"), teko::list::empty())
    let dv = fv_struct_item_derives("Post", teko::list::push(teko::list::empty(), fv_field("title", named_t("str"))), slist1("Stamp"))
    let folded = match fold_traits(parser::Program { items = items2(tr, dv) }) { parser::Program as p => p; error => { teko::assert::is_true(false); return } }
    let table = fv_table(folded.items)
    let view = match deriver_field_view("Post", table) { []FieldView as v => v; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(view.len == 2)
    teko::assert::is_true(view[0].name == "title")
    teko::assert::is_true(view[1].name == "at")
    teko::assert::is_true(type_eq(view[1].type, i64t()))
}

#test
/**
 * A class's view walks the FULL base chain (`effective_class_fields`) — base fields first, then
 * the derived class's own, exactly like construction/field-access already sees it.
 */
fn field_view_class_includes_base_chain_fields() {
    let base = fv_class_item("Animal", parser::ClassKind::Virtual, false, "", teko::list::push(teko::list::empty(), fv_field("name", named_t("str"))))
    let derived = fv_class_item("Dog", parser::ClassKind::Sealed, true, "Animal", teko::list::push(teko::list::empty(), fv_field("breed", named_t("str"))))
    let table = fv_table(items2(base, derived))
    let view = match deriver_field_view("Dog", table) { []FieldView as v => v; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(view.len == 2)
    teko::assert::is_true(view[0].name == "name")
    teko::assert::is_true(view[1].name == "breed")
}

/**
 * `subst_method_sig_names` on a method with NO `-> ret` (`has_return = false`) leaves
 * `return_type` untouched (the substitution's `else` arm) and still preserves `is_unsafe`.
 */
#test
fn subst_method_sig_names_skips_return_type_when_has_return_is_false() {
    let g = parser::Function { name = "peek"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); has_return = false; return_type = named_t("i64"); body = teko::list::empty(); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    let stamped = subst_method_sig_names(g, slist1("T"), teko::list::push(teko::list::empty(), named_t("i64")))
    teko::assert::is_false(stamped.has_return)
    teko::assert::is_false(stamped.is_unsafe)
}

/**
 * `is_must_free_name` on a name absent from the table falls through `type_table_find`'s error
 * arm, returning `false` (an unregistered name can never be `#must_free` — the defensive `error
 * => false` arm this exercises).
 */
#test
fn is_must_free_name_unknown_name_is_false() {
    teko::assert::is_false(is_must_free_name("NoSuchType", empty_table()))
}

/**
 * U2 (#333) — unsafe nominal containment + contagion-by-composition. An `unsafe type M =
 * struct { p: i64 }` item — the leaf unsafe type every U2 test builds on (a plain `i64` field
 * is enough; the FIELD shape is irrelevant to containment, only `M`'s OWN `is_unsafe` flag is).
 */
fn unsafe_leaf_item() -> parser::Item {
    let fld = parser::Field { name = "p"; type_ann = named_t("i64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    parser::Item { content = parser::TypeDecl { name = "M"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = true; must_free = false }; namespace = ""; file = "" }
}

/** The `TypeTable` `unsafe_leaf_item`'s standalone program would collect — built directly (no
 *  `collect(parser::Program)` round-trip needed) since `type_binding`/`type_function` take a
 *  `TypeTable` straight, mirroring `foo_table`/`must_free_table`'s shape above. */
fn unsafe_leaf_table() -> TypeTable {
    match unsafe_leaf_item().content { parser::TypeDecl as td => teko::list::push(teko::list::empty(), TypeReg { name = td.name; namespace = ""; vis = td.vis; decl = td }); _ => teko::list::empty() }
}

/**
 * `method_is_effective_unsafe`'s three arms, each exercised directly: (1) the method's OWN
 * `is_unsafe` short-circuits true (never reachable through real parsing — methods always parse
 * `is_unsafe = false`, per design — but the OR-rule itself must hold if ever driven this way);
 * (2) an ABSENT owner (an unregistered `struct_name`) falls to `type_table_find`'s error arm,
 * `false`; (3) a REGISTERED owner's OWN `is_unsafe` is read when the method's own flag is false —
 * the inheritance rule (§2 line 72) that makes every method of an `unsafe type` unsafe.
 */
#test
fn method_is_effective_unsafe_all_three_arms() {
    let safe_method = parser::Function { name = "m"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::empty(); has_return = false; return_type = named_t("i64"); body = teko::list::empty(); vis = parser::Visibility::Private; has_doc = false; doc = ""; line = 0; col = 0; is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""; is_intern = false; is_abstract = false; is_virtual = false; is_override = false; has_inject = false; injects = teko::list::empty(); is_unsafe = false }
    let unsafe_method = parser::Function { name = safe_method.name; type_params = safe_method.type_params; type_constraints = safe_method.type_constraints; params = safe_method.params; has_return = safe_method.has_return; return_type = safe_method.return_type; body = safe_method.body; vis = safe_method.vis; has_doc = safe_method.has_doc; doc = safe_method.doc; line = safe_method.line; col = safe_method.col; is_test = safe_method.is_test; is_extern = safe_method.is_extern; c_symbol = safe_method.c_symbol; from_lib = safe_method.from_lib; os_guard = safe_method.os_guard; is_intern = safe_method.is_intern; is_abstract = safe_method.is_abstract; is_virtual = safe_method.is_virtual; is_override = safe_method.is_override; has_inject = safe_method.has_inject; injects = safe_method.injects; is_unsafe = true }
    teko::assert::is_true(method_is_effective_unsafe(unsafe_method, "NoSuchOwner", "", empty_table()))
    teko::assert::is_false(method_is_effective_unsafe(safe_method, "NoSuchOwner", "", empty_table()))
    teko::assert::is_true(method_is_effective_unsafe(safe_method, "M", "", unsafe_leaf_table()))
    teko::assert::is_false(method_is_effective_unsafe(safe_method, "Foo", "", foo_table()))
}

/** `unsafe_carrying` recurses through `[]M` (Slice), `M?` (Optional), `Ref<M>` (Reference), and
 *  `ptr<M>` (Ptr, present inner) — every compositional carrier the design calls out (criterion
 *  7). Each wraps the SAME unsafe leaf `M`; the safe-scalar sibling of each shape is false. The
 *  final assertion is the OPAQUE `ptr` (`inner = null`) — the `Ptr` case's `null` arm, never
 *  carrying. */
#test
fn unsafe_carrying_recurses_through_every_carrier() {
    let table = unsafe_leaf_table()
    let m = Named { name = "M" }
    teko::assert::is_true(unsafe_carrying(Slice { element = m }, table))
    teko::assert::is_false(unsafe_carrying(Slice { element = i64t() }, table))
    teko::assert::is_true(unsafe_carrying(Optional { inner = m }, table))
    teko::assert::is_false(unsafe_carrying(Optional { inner = i64t() }, table))
    teko::assert::is_true(unsafe_carrying(Reference { inner = m }, table))
    teko::assert::is_false(unsafe_carrying(Reference { inner = i64t() }, table))
    teko::assert::is_true(unsafe_carrying(Ptr { inner = m }, table))
    teko::assert::is_false(unsafe_carrying(Ptr { inner = i64t() }, table))
    teko::assert::is_false(unsafe_carrying(Ptr { inner = null }, table))
}

/** `unsafe_carrying` over a `Variant` recurses each member — true iff ANY member carries unsafe
 *  data (criterion 7's variant case), and every OTHER `Type` shape not explicitly walked
 *  (`Prim`/`Void`/`Error`/…) falls to the catch-all `_ => false` arm. `Func` is NOT a catch-all
 *  case any more (F2, adversarial review of #333) — it is asserted separately below. */
#test
fn unsafe_carrying_variant_and_catch_all() {
    let table = unsafe_leaf_table()
    let m = Named { name = "M" }
    let mixed = Variant { members = teko::list::push(teko::list::push(teko::list::empty(), i64t()), m) }
    teko::assert::is_true(unsafe_carrying(mixed, table))
    let all_safe = Variant { members = teko::list::push(teko::list::push(teko::list::empty(), i64t()), Str { }) }
    teko::assert::is_false(unsafe_carrying(all_safe, table))
    teko::assert::is_false(unsafe_carrying(Void { }, table))
    teko::assert::is_false(unsafe_carrying(Error { }, table))
}

/**
 * Builds a region-handle TypeTable (#358) — a single `#must_free` struct `Arena` with one `uptr`
 * field `region`, the Arena shape `is_region_handle_name` recognizes structurally.
 *
 * @return TypeTable  a TypeTable holding exactly the region-handle `Arena` decl
 */
fn region_handle_table() -> TypeTable {
    let fld = parser::Field { name = "region"; type_ann = named_t("uptr"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let fields = teko::list::push(teko::list::empty(), fld)
    let decl = parser::TypeDecl { name = "Arena"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = true; must_free = true }
    teko::list::push(teko::list::empty(), TypeReg { name = "Arena"; namespace = ""; vis = parser::Visibility::Pub; decl = decl })
}

/**
 * Builds a `#must_free` struct table whose sole field is a NON-`uptr` (`u64`) — the near-miss the
 * region-handle probe must REJECT (right `#must_free` + arity, wrong field type).
 *
 * @return TypeTable  a TypeTable with one `#must_free` single-`u64`-field struct `NotArena`
 */
fn non_uptr_must_free_table() -> TypeTable {
    let fld = parser::Field { name = "n"; type_ann = named_t("u64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let fields = teko::list::push(teko::list::empty(), fld)
    let decl = parser::TypeDecl { name = "NotArena"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = true; must_free = true }
    teko::list::push(teko::list::empty(), TypeReg { name = "NotArena"; namespace = ""; vis = parser::Visibility::Pub; decl = decl })
}

/**
 * Builds a `#must_free` struct table with TWO `uptr` fields — the near-miss the region-handle probe
 * must REJECT on arity (a single-field shape is required); also exercises the field-name accessor's
 * multi-field else-branch.
 *
 * @return TypeTable  a TypeTable with one `#must_free` two-`uptr`-field struct `TwoField`
 */
fn two_field_must_free_table() -> TypeTable {
    mut fields = teko::list::push(teko::list::empty(), parser::Field { name = "a"; type_ann = named_t("uptr"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" })
    fields = teko::list::push(fields, parser::Field { name = "b"; type_ann = named_t("uptr"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" })
    let decl = parser::TypeDecl { name = "TwoField"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = true; must_free = true }
    teko::list::push(teko::list::empty(), TypeReg { name = "TwoField"; namespace = ""; vis = parser::Visibility::Pub; decl = decl })
}

/**
 * Builds a `#must_free` single-field struct whose field names an UNRESOLVABLE type — exercises
 * `is_region_handle_decl`'s `resolve_type` error arm (a field type that cannot resolve is not
 * `uptr`, so the shape is rejected without crashing).
 *
 * @return TypeTable  a TypeTable with one `#must_free` struct `BadField` whose field type is unknown
 */
fn unresolvable_field_must_free_table() -> TypeTable {
    let fld = parser::Field { name = "x"; type_ann = named_t("NoSuchType"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let fields = teko::list::push(teko::list::empty(), fld)
    let decl = parser::TypeDecl { name = "BadField"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = fields; methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = true; must_free = true }
    teko::list::push(teko::list::empty(), TypeReg { name = "BadField"; namespace = ""; vis = parser::Visibility::Pub; decl = decl })
}

/**
 * Builds a `#must_free` NON-struct (interface) table — exercises `is_region_handle_decl`'s
 * non-`StructBody` reject arm (the flag is set, but the body kind disqualifies it).
 *
 * @return TypeTable  a TypeTable with one `#must_free` interface `MustIface`
 */
fn must_free_iface_table() -> TypeTable {
    let decl = parser::TypeDecl { name = "MustIface"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::InterfaceBody { extends = teko::list::empty(); methods = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = true }
    teko::list::push(teko::list::empty(), TypeReg { name = "MustIface"; namespace = ""; vis = parser::Visibility::Pub; decl = decl })
}

#test
fn region_handle_predicate_recognizes_arena() {
    let tbl = region_handle_table()
    teko::assert::is_false(is_region_handle_name("MustIface", must_free_iface_table()))
    teko::assert::is_true(region_handle_field_name("MustIface", must_free_iface_table()) == "")
    teko::assert::is_true(is_region_handle_name("Arena", tbl))
    teko::assert::is_true(region_handle_field_name("Arena", tbl) == "region")
    teko::assert::is_false(is_region_handle_name("Missing", tbl))
    teko::assert::is_true(region_handle_field_name("Missing", tbl) == "")
    teko::assert::is_false(is_region_handle_name("Foo", foo_table()))
    teko::assert::is_true(region_handle_field_name("Foo", foo_table()) == "token")
    teko::assert::is_false(is_region_handle_name("BadField", unresolvable_field_must_free_table()))
    teko::assert::is_false(is_region_handle_name("NotArena", non_uptr_must_free_table()))
    teko::assert::is_false(is_region_handle_name("TwoField", two_field_must_free_table()))
    teko::assert::is_true(region_handle_field_name("TwoField", two_field_must_free_table()) == "")
    teko::assert::is_false(is_region_handle_name("Color", color_enum_table()))
    teko::assert::is_true(region_handle_field_name("Color", color_enum_table()) == "")
}

/** bigint_named — the `bigint` surface type (the runtime `BigInt` struct's canonical name). */
fn bigint_named() -> Type { Named { name = "teko::numeric::bigint::BigInt" } }
/** dec_named — the `dec` surface type (the runtime `Decimal` struct's canonical name). */
fn dec_named() -> Type { Named { name = "teko::numeric::dec::Decimal" } }
/** call_lowers_to — does a lowered operator `TExpr` call `<ns>::<fn>`? */
fn call_lowers_to(te: TExpr, ns: str, fn_name: str) -> bool {
    match te.kind {
        TCall as call => call.call_ns == ns && call.callee.segments[call.callee.segments.len - 1].name == fn_name
        _ => false
    }
}

/** bignum_plus_lowers_to_add — `bigint + bigint` becomes a `teko::numeric::bigint::add` call. */
#test
fn bignum_plus_lowers_to_add() {
    let env = define(define(empty_env(), "a", bigint_named(), false), "b", bigint_named(), false)
    let bin = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("a"); right = e_var("b") }
    let te = match type_binary(bin, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(call_lowers_to(te, "teko::numeric::bigint", "add"))
}

/** bignum_percent_lowers_to_rem — `bigint % bigint` becomes a `teko::numeric::bigint::rem` call. */
#test
fn bignum_percent_lowers_to_rem() {
    let env = define(define(empty_env(), "a", bigint_named(), false), "b", bigint_named(), false)
    let bin = parser::Binary { op = lexer::TokenKind::Percent; left = e_var("a"); right = e_var("b") }
    let te = match type_binary(bin, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(call_lowers_to(te, "teko::numeric::bigint", "rem"))
}

/** bignum_literal_adopts — `bigint + <int literal>` adopts the literal via `bigint::of`. */
#test
fn bignum_literal_adopts() {
    let env = define(empty_env(), "a", bigint_named(), false)
    let bin = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("a"); right = e_num(7) }
    let te = match type_binary(bin, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    let adopted = match te.kind { TCall as call => call.args[1]; _ => { teko::assert::is_true(false); return } }
    teko::assert::is_true(call_lowers_to(adopted, "teko::numeric::bigint", "of"))
}

/** dec_percent_is_rejected — `dec % dec` is a checker error (decimals have no remainder operator). */
#test
fn dec_percent_is_rejected() {
    let env = define(define(empty_env(), "a", dec_named(), false), "b", dec_named(), false)
    let bin = parser::Binary { op = lexer::TokenKind::Percent; left = e_var("a"); right = e_var("b") }
    match type_binary(bin, env, empty_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "not defined on `dec`")
    }
}

/** bignum_no_implicit_promotion — `bigint + <i64 variable>` is refused, asking for an explicit `of`. */
#test
fn bignum_no_implicit_promotion() {
    let env = define(define(empty_env(), "a", bigint_named(), false), "n", i64t(), false)
    let bin = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("a"); right = e_var("n") }
    match type_binary(bin, env, empty_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "no implicit")
    }
}

/** bignum_mixing_is_rejected — mixing `bigint` and `dec` in one operation is refused. */
#test
fn bignum_mixing_is_rejected() {
    let env = define(define(empty_env(), "a", bigint_named(), false), "b", dec_named(), false)
    let bin = parser::Binary { op = lexer::TokenKind::Plus; left = e_var("a"); right = e_var("b") }
    match type_binary(bin, env, empty_table()) {
        TExpr => teko::assert::is_true(false)
        error as e => teko::assert::str_contains(e.message, "mix")
    }
}

/** bignum_compare_lowers_to_cmp — `bigint < bigint` lowers to a `cmp(...) < 0` bool comparison. */
#test
fn bignum_compare_lowers_to_cmp() {
    let env = define(define(empty_env(), "a", bigint_named(), false), "b", bigint_named(), false)
    let crest = teko::list::push(teko::list::empty(), parser::CmpTerm { op = lexer::TokenKind::Lt; operand = e_var("b") })
    let cmp = parser::Compare { first = e_var("a"); rest = crest }
    let te = match type_compare(cmp, env, empty_table()) { TExpr as e => e; error => { teko::assert::is_true(false); return } }
    teko::assert::is_true(prim_is(te.type, PrimKind::Bool))
    let inner = match te.kind { TCompare as tc => tc.first; _ => { teko::assert::is_true(false); return } }
    teko::assert::is_true(call_lowers_to(inner, "teko::numeric::bigint", "cmp"))
}
