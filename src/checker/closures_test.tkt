// src/checker/closures_test.tkt — (W10a) function-VALUE / closure-TYPE coverage. Exercises the
// whole W10a vertical on the VM in BOTH engines (the build/test gate): the `(A, B) -> R` type
// (no `fn` keyword), a named fn used as a VALUE (→ a tk_closure / FuncVal), passing it as an
// argument, binding it to a local of closure type, calling THROUGH a closure value (a param or a
// local), and returning a function value from a function. Proves parse → resolve → check →
// monomorph → VM all handle the function type + closure call correctly.

// a transparent alias for a function type — resolves to the same Func as the inline `(i64,i64)->i64`.
type ClBinOp = (i64, i64) -> i64

// plain named functions, used both directly AND as values.
fn cl_add(a: i64, b: i64) -> i64 { return a + b }
fn cl_mul(a: i64, b: i64) -> i64 { return a * b }

// a HIGHER-ORDER function: the parameter `f` is a function VALUE; `f(a, b)` is a CLOSURE CALL
// (the callee is a local of function type), invoked through its code pointer.
fn cl_apply(f: (i64, i64) -> i64, a: i64, b: i64) -> i64 { return f(a, b) }

// the alias form in parameter position (must resolve identically to the inline type).
fn cl_apply_alias(f: ClBinOp, a: i64, b: i64) -> i64 { return f(a, b) }

// RETURN a function value (a named fn escaping by-copy, env = NULL — always memory-safe).
fn cl_pick(use_add: bool) -> ClBinOp {
    let chosen = if use_add { cl_add } else { cl_mul }
    return chosen
}

#test fn closure_named_fn_passed_and_called() {
    // a named fn passed as a value, then called through the param.
    teko::assert::is_true(cl_apply(cl_add, 2, 3) == 5)
    teko::assert::is_true(cl_apply(cl_mul, 4, 5) == 20)
}

#test fn closure_alias_param_type() {
    // the alias `ClBinOp` in param position behaves identically.
    teko::assert::is_true(cl_apply_alias(cl_add, 10, 7) == 17)
}

#test fn closure_bound_to_local_then_called() {
    // a named fn bound to a LOCAL of closure type, then called THROUGH the local.
    let op: ClBinOp = cl_add
    teko::assert::is_true(op(6, 9) == 15)
    let op2: (i64, i64) -> i64 = cl_mul
    teko::assert::is_true(op2(3, 6) == 18)
}

#test fn closure_returned_from_fn() {
    // a function VALUE returned from a function, then called through a local.
    let g = cl_pick(true)
    teko::assert::is_true(g(8, 8) == 16)
    let h = cl_pick(false)
    teko::assert::is_true(h(8, 8) == 64)
}

// (W10) anonymous lambda LITERALS — non-capturing + by-copy capture, run in BOTH VMs (the gate).
fn cl_use(f: (i64) -> i64, v: i64) -> i64 { return f(v) }

#test fn lambda_noncapturing_inline() {
    teko::assert::is_true(cl_apply((x: i64, y: i64) => x + y, 8, 9) == 17)
    teko::assert::is_true(cl_use((n: i64) => n * 3, 7) == 21)
}

#test fn lambda_bycopy_capture() {
    let base = 100
    let add_base: (i64) -> i64 = (x) => x + base   // captures `base` by copy
    teko::assert::is_true(add_base(23) == 123)
    let k = 5
    teko::assert::is_true(cl_use((x: i64) => x * k, 6) == 30)   // captures `k`
}

#test fn lambda_block_body() {
    let g: (i64) -> i64 = (x) => {
        let t = x + 1;
        t * 2
    }
    teko::assert::is_true(g(4) == 10)
}

// (issue #107) a closure-typed PARAM named like a reserved non-shadowable builtin (`write`,
// `print`, `len`, …) must call THROUGH the param, never get hijacked into the builtin/extern by
// bare-name sniffing. Regression for the codegen/VM call-lowering bug: both engines matched
// `write`/`len`/etc. by BARE last-segment name BEFORE consulting the checker's `is_closure_call`
// verdict, so a param sharing one of those names silently called the wrong thing (or, for an
// extern like `teko::io::write`, failed to even compile natively — void return vs the param's
// declared u64). `src/io/stream.tks` carried a documented naming workaround for exactly this.
type ShadowFn = (str) -> u64

fn cl_shadow_write(write: ShadowFn) -> u64 { write("ignored") }
fn cl_shadow_print(print: ShadowFn) -> u64 { print("ignored") }
fn cl_shadow_len(len: ShadowFn) -> u64 { len("ignored") }

#test fn closure_param_shadows_write_builtin() {
    // if hijacked, this would call teko::io::write (-> void; a native compile error against the
    // u64-returning param type) or run print/write's real side effect and diverge from 42.
    let f: ShadowFn = (s: str) => 42 to u64
    teko::assert::is_true(cl_shadow_write(f) == 42)
}

#test fn closure_param_shadows_print_builtin() {
    let f: ShadowFn = (s: str) => 7 to u64
    teko::assert::is_true(cl_shadow_print(f) == 7)
}

#test fn closure_param_shadows_len_builtin() {
    // if hijacked, this calls tk_str_len("ignored") == 8, not the closure's 999.
    let f: ShadowFn = (s: str) => 999 to u64
    teko::assert::is_true(cl_shadow_len(f) == 999)
}

// (issue #107) a `let`-bound closure (not just a param) shadowing a reserved builtin name — same
// bare-name hijack risk, different binding origin. One fix (checked BEFORE the builtin-name
// sniffing) must cover both.
#test fn let_bound_closure_shadows_builtin_name() {
    let write: ShadowFn = (s: str) => 55 to u64
    teko::assert::is_true(write("ignored") == 55)
    let len: ShadowFn = (s: str) => 66 to u64
    teko::assert::is_true(len("ignored") == 66)
}

// (issue #107) NESTED closure shadowing: an outer closure param named `write` captured by an
// inner lambda that also introduces its own `write` binding — the innermost `write` must win at
// each call site, never the reserved builtin.
fn cl_shadow_nested(write: ShadowFn) -> u64 {
    let inner: ShadowFn = (s: str) => {
        let write: ShadowFn = (s2: str) => 321 to u64   // shadows the outer PARAM `write`
        write(s)                                        // must call the innermost local, not the builtin
    }
    // the outer `write` param is still reachable here (inner's shadow is scoped to its own body).
    let outer_result = write("outer")
    let inner_result = inner("inner")
    outer_result + inner_result
}

#test fn nested_closure_shadows_builtin_name() {
    let f: ShadowFn = (s: str) => 111 to u64
    teko::assert::is_true(cl_shadow_nested(f) == 432)   // 111 (outer) + 321 (inner's own shadow)
}
