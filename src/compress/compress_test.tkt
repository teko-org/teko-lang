// src/compress/compress_test.tkt — tests for teko::compress (CRC-32 + ZIP-STORE round-trip).
// #test collected (no `main`). Exercises crc32_row/crc32_of and the write_zip → read_zip path
// (zip_u16/zip_u32/zip_bytes/zip_str + the local-file-header parser) that `.tkl` packaging
// relies on. Verified in BOTH the VM gate and the native build gate (verify-both mandate).

// CRC-32 standard check vector: CRC-32("123456789") == 0xCBF43926; CRC-32 of empty == 0.
#test
fn crc32_standard_vector() {
    mut data: []byte = teko::list::empty()
    let s = "123456789"
    mut i: u64 = 0
    loop {
        if i >= s.len { break }
        data = teko::list::push(data, s[i])
        i++
    }
    teko::assert::is_true(teko::compress::crc32_of(data) == 0xCBF43926)

    mut empty: []byte = teko::list::empty()
    teko::assert::is_true(teko::compress::crc32_of(empty) == 0x00000000)
}

// write_zip → read_zip must round-trip an entry's name and bytes verbatim (STORE, method 0).
#test
fn zip_store_round_trip() {
    mut d: []byte = teko::list::empty()
    d = teko::list::push(d, 65 to byte)   // 'A'
    d = teko::list::push(d, 66 to byte)   // 'B'
    d = teko::list::push(d, 67 to byte)   // 'C'

    mut entries: []teko::compress::ZipEntry = teko::list::empty()
    entries = teko::list::push(entries, teko::compress::ZipEntry { name = "abc.txt"; data = d })

    let archive = teko::compress::write_zip(entries)
    teko::assert::is_true(archive.len > 0)
    // Local File Header signature "PK\x03\x04".
    teko::assert::is_true(archive[0] == 0x50)
    teko::assert::is_true(archive[1] == 0x4B)
    teko::assert::is_true(archive[2] == 0x03)
    teko::assert::is_true(archive[3] == 0x04)

    match teko::compress::read_zip(archive) {
        []teko::compress::ZipEntry as got => {
            teko::assert::is_true(got.len == 1)
            teko::assert::is_true(teko::runtime::str_eq(got[0].name, "abc.txt"))
            teko::assert::is_true(got[0].data.len == 3)
            teko::assert::is_true(got[0].data[0] == 65)
            teko::assert::is_true(got[0].data[2] == 67)
        }
        error as e => teko::assert::is_true(false)   // read_zip must succeed on its own output
    }
}
