// src/text/text_test.tkt — tests for teko::text. NO `main`: a .tkt has no entry
// point. Tests are PUBLIC functions marked `#test`; the compiler collects and runs
// them (a test runner — an ALPHA feature). In the bootstrap that runner does not
// exist, so the C mirror (text_test.c) uses a `main` harness instead (C may have a
// main). (`assert` and failure semantics are not yet pinned — alpha.)

// helper (not a test): is str_from_utf8(bytes) ok?
fn is_valid(bytes: []byte) -> bool {
    match str_from_utf8(bytes) {
        str => true
        error => false
    }
}

#test
fn accepts_valid_utf8() {
    teko::assert::is_true(is_valid([0x68, 0x65, 0x6C, 0x6C, 0x6F]))   // "hello"
    teko::assert::is_true(is_valid([0x63, 0x61, 0x66, 0xC3, 0xA9]))   // "café" (é = C3 A9)
    teko::assert::is_true(is_valid([0xE2, 0x82, 0xAC]))   // € U+20AC
    teko::assert::is_true(is_valid([0xF0, 0x9F, 0xA6, 0xB4]))   // U+1F9B4
    teko::assert::is_true(is_valid(teko::list::empty()))   // empty
}

#test
fn rejects_malformed_utf8() {
    teko::assert::is_false(is_valid([0x80]))   // stray continuation
    teko::assert::is_false(is_valid([0xC0, 0xAF]))   // overlong slash
    teko::assert::is_false(is_valid([0xED, 0xA0, 0x80]))   // surrogate U+D800
    teko::assert::is_false(is_valid([0xE2, 0x82]))   // truncated 3-byte
    teko::assert::is_false(is_valid([0xC1, 0x80]))   // lead C1 (overlong)
    teko::assert::is_false(is_valid([0xF4, 0x90, 0x80, 0x80]))   // > U+10FFFF
    teko::assert::is_false(is_valid([0xE2, 0x28, 0xAC]))   // 0x28 not a continuation
}
