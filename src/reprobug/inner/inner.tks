// src/reprobug/inner/inner.tks — namespace teko::reprobug::inner. Declares a `probe`
// with a DIFFERENT arity/signature than teko::reprobug::probe (reprobug.tks), on
// purpose — the collision the VM name-resolution bug (find_function) is regression-
// tested against. See src/reprobug/reprobug.tks for the full writeup.

pub fn probe(x: str) -> str {
    teko::str::concat(x, x, "")
}

pub fn call_own_probe(x: str) -> str {
    probe(x)
}
