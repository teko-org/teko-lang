/**
 * src/io/stream_test.tkt — tests for STDLIB_CORE unit IO1 (teko::io byte-stream contract on
 * INTERFACE VALUES). Same namespace as src/io/stream.tks (tests live BESIDE the code — teko::io),
 * so type statics and free functions are called bare. Everything here is pure Teko: class stream
 * implementers up-cast into the `Reader`/`Writer` contracts and dispatch through their vtables, and
 * the combinators drive those dynamic values (docs/design/interface-value-type.md §3).
 */

/**
 * buf_of — unwrap `Buf | error` where the error case is itself a test failure.
 *
 * @param result  the fallible Buf result
 * @return        the Buf, or an empty Buf after failing the test on the error case
 */
fn buf_of(result: Buf | error) -> Buf {
    match result {
        Buf as b => b
        error => { teko::assert::is_true(false); Buf::empty() }
    }
}

/**
 * count_of — unwrap `u64 | error` where the error case is itself a test failure.
 *
 * @param result  the fallible count result
 * @return        the count, or 0 after failing the test on the error case
 */
fn count_of(result: u64 | error) -> u64 {
    match result {
        u64 as n => n
        error => { teko::assert::is_true(false); 0 to u64 }
    }
}

/**
 * text_of — unwrap `str | error` where the error case is itself a test failure.
 *
 * @param result  the fallible str result
 * @return        the string, or "" after failing the test on the error case
 */
fn text_of(result: str | error) -> str {
    match result {
        str as s => s
        error => { teko::assert::is_true(false); "" }
    }
}

/**
 * is_buf_error — is a `Buf | error` the error case?
 *
 * @param result  the fallible Buf result
 * @return        true iff `result` is the error case
 */
fn is_buf_error(result: Buf | error) -> bool {
    match result {
        Buf => false
        error => true
    }
}

/**
 * FailReader — a `Reader` whose every read fails, for error-propagation tests.
 */
type FailReader = class & Reader {
    /**
     * make — construct the always-failing reader.
     *
     * @return  the failing reader
     */
    pub fn make() -> FailReader { FailReader { } }

    /**
     * read — always the error case.
     *
     * @param max  ignored
     * @return     the read error
     */
    pub fn read(self, max: u64) -> Buf | error { error { message = "boom" } }
}

/**
 * StuckWriter — a `Writer` that never takes a byte, for the no-progress guard.
 */
type StuckWriter = class & Writer {
    /**
     * make — construct the stuck writer.
     *
     * @return  the stuck writer
     */
    pub fn make() -> StuckWriter { StuckWriter { } }

    /**
     * write — accept nothing.
     *
     * @param from  ignored
     * @return      0 (no progress)
     */
    pub fn write(self, from: Buf) -> u64 | error { 0 to u64 }
}

/**
 * LiarWriter — a `Writer` that reports MORE bytes than offered, for the over-report guard.
 */
type LiarWriter = class & Writer {
    /**
     * make — construct the over-reporting writer.
     *
     * @return  the liar writer
     */
    pub fn make() -> LiarWriter { LiarWriter { } }

    /**
     * write — claim to have accepted more than offered.
     *
     * @param from  the offered region
     * @return      an impossibly large count
     */
    pub fn write(self, from: Buf) -> u64 | error { from.len() + 100 }
}

/**
 * HalfWriter — a `Writer` accepting at most HALF of each offered region (rounding up so a 1-byte
 * region still makes progress), appending the accepted prefix to an inner `MemWriter`. Drives the
 * rate-mismatched `write_all`/`TeeWriter` path.
 */
type HalfWriter = class & Writer {
    /** The backing accumulator the accepted prefixes land in. */
    pub inner: MemWriter

    /**
     * make — a half-taker over a fresh accumulator.
     *
     * @return  the half writer
     */
    pub fn make() -> HalfWriter { HalfWriter { inner = MemWriter::empty() } }

    /**
     * write — accept the first `ceil(len/2)` bytes and append them.
     *
     * @param from  the offered region
     * @return      the accepted count, or an error
     */
    pub fn write(self, from: Buf) -> u64 | error {
        let total = from.len()
        if total == 0 { return 0 to u64 }
        let take = (total + 1) / 2
        let prefix = match from.slice(0, take) { Buf as b => b; error as e => return e }
        self.inner.write(prefix)
    }
}

/**
 * buf_construction_and_len — the value-region constructors and length/byte accessors.
 */
#test
fn buf_construction_and_len() {
    teko::assert::is_true(Buf::empty().len() == 0)
    teko::assert::is_true(Buf::from_str("hello").len() == 5)
    let b = Buf::from_bytes([b'a', b'b', b'c'])
    teko::assert::is_true(b.len() == 3)
    let raw = b.bytes()
    teko::assert::is_true(raw.len == 3)
    teko::assert::is_true(raw[0] == b'a')
    teko::assert::is_true(raw[2] == b'c')
}

/**
 * buf_is_a_value_growing_returns_new — a Buf is a value: every grow returns a NEW Buf.
 */
#test
fn buf_is_a_value_growing_returns_new() {
    let base = Buf::from_str("ab")
    let grown = base.push(b'c')
    teko::assert::is_true(base.len() == 2)
    teko::assert::is_true(grown.len() == 3)
    let extended = grown.extend([b'd', b'e'])
    teko::assert::is_true(extended.len() == 5)
    let combined = extended.concat(Buf::from_str("f"))
    teko::assert::is_true(text_of(combined.to_str()) == "abcdef")
    teko::assert::is_true(grown.len() == 3)
}

/**
 * null_stream_reads_nothing_and_discards_everything — the discard sink / empty source, dispatched as
 * interface values.
 */
#test
fn null_stream_reads_nothing_and_discards_everything() {
    let sink = NullStream::make()
    teko::assert::is_true(buf_of(read_chunk(sink, 16)).len() == 0)
    teko::assert::is_true(count_of(write_chunk(sink, Buf::from_str("data"))) == 4)
    let closed = match sink.close() {
        error => false
        null => true
    }
    teko::assert::is_true(closed)
}

/**
 * null_stream_seek_contract — the seek math on the always-empty stream.
 */
#test
fn null_stream_seek_contract() {
    let sink = NullStream::make()
    teko::assert::is_true(count_of(sink.seek(5, Whence::Start)) == 5)
    teko::assert::is_true(count_of(sink.seek(0, Whence::Current)) == 0)
    teko::assert::is_true(count_of(sink.seek(0, Whence::End)) == 0)
    let rejected = match sink.seek(-1, Whence::Start) {
        u64 => false
        error => true
    }
    teko::assert::is_true(rejected)
}

/**
 * mem_reader_seek_whence_math — Start/Current/End seek arithmetic, past-end allowed, negative
 * rejected.
 */
#test
fn mem_reader_seek_whence_math() {
    let reader = MemReader::of_str("abcdefgh")
    teko::assert::is_true(count_of(reader.seek(2, Whence::Start)) == 2)
    teko::assert::is_true(text_of(buf_of(reader.read(3)).to_str()) == "cde")
    teko::assert::is_true(count_of(reader.seek(3, Whence::Current)) == 8)
    teko::assert::is_true(count_of(reader.seek(-2, Whence::End)) == 6)
    teko::assert::is_true(text_of(buf_of(reader.read(10)).to_str()) == "gh")
    let past = MemReader::of_str("abcdefgh")
    teko::assert::is_true(count_of(past.seek(3, Whence::End)) == 11)
    teko::assert::is_true(buf_of(past.read(1)).len() == 0)
    let rejected = match reader.seek(-1, Whence::Start) {
        u64 => false
        error => true
    }
    teko::assert::is_true(rejected)
}

/**
 * read_all_drains_the_stream — `read_all` runs a dynamic `Reader` to EOF.
 */
#test
fn read_all_drains_the_stream() {
    let reader = MemReader::of_str("hello, teko")
    let drained = buf_of(read_all(reader))
    teko::assert::is_true(text_of(drained.to_str()) == "hello, teko")
    let after = buf_of(read_all(reader))
    teko::assert::is_true(after.len() == 0)
    let empty_reader = MemReader::over(Buf::empty())
    teko::assert::is_true(buf_of(read_all(empty_reader)).len() == 0)
}

/**
 * read_exact_demands_the_count — exactly `count` bytes, EOF-before-count is an error.
 */
#test
fn read_exact_demands_the_count() {
    let reader = MemReader::of_str("hello, teko")
    let exact = buf_of(read_exact(reader, 5))
    teko::assert::is_true(text_of(exact.to_str()) == "hello")
    teko::assert::is_true(buf_of(read_exact(reader, 0)).len() == 0)
    teko::assert::is_true(is_buf_error(read_exact(reader, 7)))
}

/**
 * write_all_guards_against_no_progress — a stalled or over-reporting writer is an error.
 */
#test
fn write_all_guards_against_no_progress() {
    let stuck = StuckWriter::make()
    let failed = match write_all(stuck, Buf::from_str("x")) {
        u64 => false
        error => true
    }
    teko::assert::is_true(failed)
    let liar = LiarWriter::make()
    let caught = match write_all(liar, Buf::from_str("x")) {
        u64 => false
        error => true
    }
    teko::assert::is_true(caught)
}

/**
 * buf_writer_holds_until_capacity — a `BufWriter` holds writes until capacity, then drains; `flush`
 * pushes the remainder.
 */
#test
fn buf_writer_holds_until_capacity() {
    let writer = MemWriter::empty()
    let buffered = BufWriter::of(writer, 4)
    teko::assert::is_true(count_of(buffered.write(Buf::from_str("ab"))) == 2)
    teko::assert::is_true(writer.content().len() == 0)
    teko::assert::is_true(count_of(buffered.write(Buf::from_str("cd"))) == 2)
    teko::assert::is_true(text_of(writer.content().to_str()) == "abcd")
    teko::assert::is_true(count_of(buffered.write(Buf::from_str("e"))) == 1)
    teko::assert::is_true(text_of(writer.content().to_str()) == "abcd")
    teko::assert::is_true(count_of(buffered.flush()) == 1)
    teko::assert::is_true(text_of(writer.content().to_str()) == "abcde")
    teko::assert::is_true(count_of(buffered.flush()) == 0)
}

/**
 * tee_writer_mirrors_into_both_sinks — a `TeeWriter` fans each write into two sinks, even a
 * rate-mismatched one.
 */
#test
fn tee_writer_mirrors_into_both_sinks() {
    let primary = MemWriter::empty()
    let secondary = HalfWriter::make()
    let tee = TeeWriter::of(primary, secondary)
    teko::assert::is_true(count_of(write_all(tee, Buf::from_str("hello, teko"))) == 11)
    teko::assert::is_true(text_of(primary.content().to_str()) == "hello, teko")
    teko::assert::is_true(text_of(secondary.inner.content().to_str()) == "hello, teko")
}

/**
 * combinators_propagate_stream_errors — a genuine read/write error surfaces through every combinator.
 */
#test
fn combinators_propagate_stream_errors() {
    teko::assert::is_true(is_buf_error(read_all(FailReader::make())))
    teko::assert::is_true(is_buf_error(read_exact(FailReader::make(), 1)))
    let writer = MemWriter::empty()
    let failed_copy = match copy(writer, FailReader::make()) {
        u64 => false
        error => true
    }
    teko::assert::is_true(failed_copy)
    let limited = LimitReader::of(FailReader::make(), 10)
    teko::assert::is_true(is_buf_error(limited.read(1)))
    let buffered = BufReader::of(FailReader::make(), 4)
    teko::assert::is_true(is_buf_error(buffered.read(1)))
}
