// src/emit/tkb_test.tkt — tests for the .tkb codec (S1a/S1b). #test functions (no main).
// Current Teko: typed nodes are module-qualified (`checker::`) and carry all fields (line/col).

use teko::checker
use teko::parser
use teko::lexer

fn u8ty() -> checker::Type { checker::Prim { kind = checker::PrimKind::U8 } }
fn i64ty() -> checker::Type { checker::Prim { kind = checker::PrimKind::I64 } }
fn boolty() -> checker::Type { checker::Prim { kind = checker::PrimKind::Bool } }
// a one-segment NamedType type-annotation (e.g. `i64`).
fn nt(name: str) -> parser::TypeExpr { parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }; args = teko::list::empty() } }
fn tnum(v: i128) -> checker::TExpr { checker::TExpr { kind = checker::TNumber { is_float = false; value = v; fval = 0.0 }; type = i64ty(); line = 0; col = 0 } }
// drop the last byte of a `[]byte` (str's `slice` is text-only) — shared by header_test (same ns).
fn drop_last(b: []byte) -> []byte {
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop { if i + 1 >= b.len { break }; out = teko::list::push(out, b[i]); i = i + 1 }
    out
}

#test
fn tkb_roundtrip_cast() {
    // S1a: TCast { expr = (TNumber : i64) } : u8 — exact round-trip (tag 10 + type + inner).
    let orig = checker::TExpr { kind = checker::TCast { expr = tnum(7) }; type = u8ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.type {
            checker::Prim as p => {
                teko::assert::is_true(p.kind == checker::PrimKind::U8)
                match got.kind {
                    checker::TCast as c => match c.expr.kind {
                        checker::TNumber as n => teko::assert::is_true(n.value == 7)
                        _ => teko::assert::is_true(false)
                    }
                    _ => teko::assert::is_true(false)
                }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_field_access() {
    // S1b: TFieldAccess { receiver = (TVar s : Named Foo); field = "token" } : u8 — round-trips exactly.
    let recv = checker::TExpr { kind = checker::TVar { name = "s"; is_func = false; func_ns = "" }; type = checker::Named { name = "Foo" }; line = 0; col = 0 }
    let orig = checker::TExpr { kind = checker::TFieldAccess { receiver = recv; field = "token" }; type = u8ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TFieldAccess as f => {
                teko::assert::is_true(f.field == "token")
                match f.receiver.kind { checker::TVar as v => teko::assert::is_true(v.name == "s"); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_arraylit() {
    // C6.7: ArrayLit [1, 2] round-trips — elements are TArrayElem (is_spread=false, expr=TExpr).
    let ae1 = checker::TArrayElem { is_spread = false; expr = tnum(1) }
    let ae2 = checker::TArrayElem { is_spread = false; expr = tnum(2) }
    let elems = teko::list::push(teko::list::push(teko::list::empty(), ae1), ae2)
    let orig = checker::TExpr { kind = checker::TArrayLit { elements = elems }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TArrayLit as a => {
                teko::assert::is_true(a.elements.len == 2)
                teko::assert::is_true(!a.elements[0].is_spread)
                teko::assert::is_true(!a.elements[1].is_spread)
                match a.elements[0].expr.kind { checker::TNumber as n => teko::assert::is_true(n.value == 1); _ => teko::assert::is_true(false) }
                match a.elements[1].expr.kind { checker::TNumber as n => teko::assert::is_true(n.value == 2); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_arraylit_spread() {
    // C6.7: ArrayLit with a spread element [..xs, y] — is_spread flag survives round-trip.
    // xs has type []i64 (the spread slice); y is a plain i64 element.
    let xs_expr = checker::TExpr { kind = checker::TVar { name = "xs"; is_func = false; func_ns = "" }; type = checker::Slice { element = i64ty() }; line = 0; col = 0 }
    let y_expr = checker::TExpr { kind = checker::TVar { name = "y"; is_func = false; func_ns = "" }; type = i64ty(); line = 0; col = 0 }
    let ae_spread = checker::TArrayElem { is_spread = true; expr = xs_expr }
    let ae_plain = checker::TArrayElem { is_spread = false; expr = y_expr }
    let elems = teko::list::push(teko::list::push(teko::list::empty(), ae_spread), ae_plain)
    let slice_ty = checker::Slice { element = i64ty() }
    let orig = checker::TExpr { kind = checker::TArrayLit { elements = elems }; type = slice_ty; line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TArrayLit as a => {
                teko::assert::is_true(a.elements.len == 2)
                // first element: spread (..xs)
                teko::assert::is_true(a.elements[0].is_spread)
                match a.elements[0].expr.kind { checker::TVar as v => teko::assert::is_true(v.name == "xs"); _ => teko::assert::is_true(false) }
                // second element: plain (y)
                teko::assert::is_true(!a.elements[1].is_spread)
                match a.elements[1].expr.kind { checker::TVar as v => teko::assert::is_true(v.name == "y"); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_structinit() {
    // C7.16: StructInit P { x = 5 } round-trips (collect now interns field names + recurses values).
    let names = teko::list::push(teko::list::empty(), "x")
    let vals = teko::list::push(teko::list::empty(), tnum(5))
    let orig = checker::TExpr { kind = checker::TStructInit { field_names = names; field_vals = vals }; type = checker::Named { name = "P" }; line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TStructInit as si => {
                teko::assert::is_true(si.field_names.len == 1)
                teko::assert::is_true(si.field_names[0] == "x")
                match si.field_vals[0].kind { checker::TNumber as n => teko::assert::is_true(n.value == 5); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_coalesce() {
    // C7.16: (a ?? 0) round-trips (collect now recurses left + right).
    let left = checker::TExpr { kind = checker::TVar { name = "a"; is_func = false; func_ns = "" }; type = i64ty(); line = 0; col = 0 }
    let orig = checker::TExpr { kind = checker::TCoalesce { left = left; right = tnum(0) }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TCoalesce as co => {
                match co.left.kind { checker::TVar as v => teko::assert::is_true(v.name == "a"); _ => teko::assert::is_true(false) }
                match co.right.kind { checker::TNumber as n => teko::assert::is_true(n.value == 0); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
/** (#165 C1) a plain call `foo()` resolved to namespace "teko::x" round-trips call_ns +
    is_closure_call (both were hardcoded to ""/false before this crumb). */
fn tkb_roundtrip_call_ns() {
    let cpath = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "foo" }) }
    let orig = checker::TExpr { kind = checker::TCall { callee = cpath; args = teko::list::empty(); call_ns = "teko::x"; is_closure_call = false; callee_type = checker::Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TCall as c => {
                teko::assert::is_true(c.call_ns == "teko::x")
                teko::assert::is_true(!c.is_closure_call)
                teko::assert::is_true(!c.is_iface_dispatch)
                teko::assert::is_true(c.callee.segments[0].name == "foo")
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
/** (#165 C1) a closure call (is_closure_call=true, call_ns="") — the flag survives independent
    of call_ns, and the callee_type Func rides via the leading node type (unused here, Void). */
fn tkb_roundtrip_closure_call_ns() {
    let cpath = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "f" }) }
    let orig = checker::TExpr { kind = checker::TCall { callee = cpath; args = teko::list::empty(); call_ns = ""; is_closure_call = true; callee_type = checker::Void { }; is_iface_dispatch = false; iface_slot = 0 }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TCall as c => {
                teko::assert::is_true(c.is_closure_call)
                teko::assert::is_true(c.call_ns == "")
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_pathexpr() {
    // C7.16: Color::Red round-trips (collect now interns enum_name + member; ordinal u64;
    // (#50) the resolved member value rides too — a flags-style power-of-2 exercises both u64 halves).
    let orig = checker::TExpr { kind = checker::TPathExpr { enum_name = "Color"; member = "Red"; ordinal = 2; value = (1 to u128) << 66 }; type = checker::Named { name = "Color" }; line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TPathExpr as pe => {
                teko::assert::is_true(pe.enum_name == "Color")
                teko::assert::is_true(pe.member == "Red")
                teko::assert::is_true(pe.ordinal == 2)
                teko::assert::is_true(pe.value == (1 to u128) << 66)
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_ifexpr() {
    // C7.16: `if true { let x: i64 = 1; x; return x } else { return 0 }` round-trips (statements + IF).
    let cond = checker::TExpr { kind = checker::TBoolLit { value = true }; type = boolty(); line = 0; col = 0 }
    let xref = checker::TExpr { kind = checker::TVar { name = "x"; is_func = false; func_ns = "" }; type = i64ty(); line = 0; col = 0 }
    mut thenb: []checker::TStatement = teko::list::empty()
    thenb = teko::list::push(thenb, checker::TBinding { kind = parser::BindKind::Let; target = parser::SimpleName { name = "x" }; bound = i64ty(); value = tnum(1) })
    thenb = teko::list::push(thenb, checker::TExprStmt { expr = xref })
    thenb = teko::list::push(thenb, checker::TReturn { has_value = true; value = xref })
    mut elseb: []checker::TStatement = teko::list::empty()
    elseb = teko::list::push(elseb, checker::TReturn { has_value = true; value = tnum(0) })
    let iff = checker::TExpr { kind = checker::TIfExpr { cond = cond; then_blk = thenb; has_else = true; else_blk = elseb }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(iff)) {
        checker::TExpr as got => match got.kind {
            checker::TIfExpr as f => {
                teko::assert::is_true(f.has_else)
                teko::assert::is_true(f.then_blk.len == 3)
                teko::assert::is_true(f.else_blk.len == 1)
                match f.then_blk[0] {
                    checker::TBinding as bd => {
                        teko::assert::is_true(bd.kind == parser::BindKind::Let)
                        match bd.target { parser::SimpleName as sn => teko::assert::is_true(sn.name == "x"); _ => teko::assert::is_true(false) }
                        match bd.value.kind { checker::TNumber as n => teko::assert::is_true(n.value == 1); _ => teko::assert::is_true(false) }
                    }
                    _ => teko::assert::is_true(false)
                }
                match f.then_blk[2] { checker::TReturn as r => teko::assert::is_true(r.has_value); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_loop_stmts() {
    let cond = checker::TExpr { kind = checker::TBoolLit { value = true }; type = boolty(); line = 0; col = 0 }
    mut body: []checker::TStatement = teko::list::empty()
    body = teko::list::push(body, checker::TAssign { kind = parser::AssignKind::Simple; name = "a"; op = lexer::TokenKind::Assign; bound = i64ty(); value = tnum(1); deref = false; target = checker::no_texpr() })
    body = teko::list::push(body, checker::TBreakStmt { label = "" })
    body = teko::list::push(body, checker::TContinueStmt { label = "OUTER" })
    mut linit: []checker::TStatement = teko::list::empty()
    linit = teko::list::push(linit, checker::TBinding { kind = parser::BindKind::Mut; target = parser::SimpleName { name = "_hi" }; bound = i64ty(); value = tnum(5) })
    mut thenb: []checker::TStatement = teko::list::empty()
    thenb = teko::list::push(thenb, checker::TLoopStmt { label = "OUTER"; init = linit; body = body })
    let iff = checker::TExpr { kind = checker::TIfExpr { cond = cond; then_blk = thenb; has_else = false; else_blk = teko::list::empty() }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(iff)) {
        checker::TExpr as got => match got.kind {
            checker::TIfExpr as f => {
                teko::assert::is_true(!f.has_else)
                teko::assert::is_true(f.then_blk.len == 1)
                match f.then_blk[0] {
                    checker::TLoopStmt as l => {
                        teko::assert::is_true(l.label == "OUTER")
                        teko::assert::is_true(l.init.len == 1)
                        match l.init[0] { checker::TBinding as bd => match bd.target { parser::SimpleName as sn => teko::assert::is_true(sn.name == "_hi"); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
                        teko::assert::is_true(l.body.len == 3)
                        match l.body[0] { checker::TAssign as a => { teko::assert::is_true(a.name == "a"); teko::assert::is_true(a.op == lexer::TokenKind::Assign) }; _ => teko::assert::is_true(false) }
                        match l.body[1] { checker::TBreakStmt as b => teko::assert::is_true(b.label == ""); _ => teko::assert::is_true(false) }
                        match l.body[2] { checker::TContinueStmt as c => teko::assert::is_true(c.label == "OUTER"); _ => teko::assert::is_true(false) }
                    }
                    _ => teko::assert::is_true(false)
                }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_program() {
    // C7.16: a whole TProgram (use + struct typedecl + function) round-trips via serialize_program.
    // use teko::lexer
    let upath = parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "teko" }), parser::Segment { name = "lexer" }) }
    let use1 = parser::UseDecl { path = upath; has_alias = false; alias = ""; names = teko::list::empty() }
    // type Point = struct { x: i64 }
    let fld = parser::Field { name = "x"; type_ann = nt("i64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let td = parser::TypeDecl { name = "Point"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    // fn id(n: i64) -> i64 { return n }
    let prm = parser::Param { name = "n"; has_type = true; type_ann = nt("i64"); is_params = false; has_default = false; default_expr = parser::no_expr() }
    let nref = checker::TExpr { kind = checker::TVar { name = "n"; is_func = false; func_ns = "" }; type = i64ty(); line = 0; col = 0 }
    mut body: []checker::TStatement = teko::list::empty()
    body = teko::list::push(body, checker::TReturn { has_value = true; value = nref })
    let fn1 = checker::TFunction { name = "id"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); params = teko::list::push(teko::list::empty(), prm); return_type = i64ty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; namespace = "m"; file = "m.tks"; line = 2; col = 1; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
    mut items: []checker::TItem = teko::list::empty()
    items = teko::list::push(items, use1)
    items = teko::list::push(items, td)
    items = teko::list::push(items, fn1)
    let prog = checker::TProgram { items = items }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => {
            teko::assert::is_true(got.items.len == 3)
            match got.items[0] { parser::UseDecl as u => { teko::assert::is_true(u.path.segments.len == 2); teko::assert::is_true(u.path.segments[1].name == "lexer") }; _ => teko::assert::is_true(false) }
            match got.items[1] {
                parser::TypeDecl as d => {
                    teko::assert::is_true(d.name == "Point")
                    teko::assert::is_true(d.vis == parser::Visibility::Pub)
                    match d.body { parser::StructBody as s => { teko::assert::is_true(s.fields.len == 1); teko::assert::is_true(s.fields[0].name == "x") }; _ => teko::assert::is_true(false) }
                }
                _ => teko::assert::is_true(false)
            }
            match got.items[2] {
                checker::TFunction as f => {
                    teko::assert::is_true(f.name == "id")
                    teko::assert::is_true(f.params.len == 1)
                    teko::assert::is_true(f.params[0].name == "n")
                    teko::assert::is_true(f.namespace == "m")
                    teko::assert::is_true(f.body.len == 1)
                    match f.body[0] { checker::TReturn as r => teko::assert::is_true(r.has_value); _ => teko::assert::is_true(false) }
                }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * A module-level `TConstDecl` TItem (#594 crumb 8) round-trips through `serialize_program`: name,
 * declaring namespace, value type, typed initializer, visibility, and position all survive, so a
 * `pub`/`exp` module const's value crosses a `.tkb` for a consuming module to inline identically.
 */
#test
fn tkb_roundtrip_module_const() {
    let cd = checker::TConstDecl { name = "P"; namespace = "m1"; ty = i64ty(); init = tnum(120); vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 4; col = 1 }
    let items: []checker::TItem = teko::list::push(teko::list::empty(), cd)
    let prog = checker::TProgram { items = items }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => {
            teko::assert::is_true(got.items.len == 1)
            match got.items[0] {
                checker::TConstDecl as c => {
                    teko::assert::is_true(c.name == "P")
                    teko::assert::is_true(c.namespace == "m1")
                    teko::assert::is_true(c.vis == parser::Visibility::Pub)
                    match c.ty { checker::Prim as p => teko::assert::is_true(p.kind == checker::PrimKind::I64); _ => teko::assert::is_true(false) }
                    match c.init.kind { checker::TNumber as n => teko::assert::is_true(n.value == 120); _ => teko::assert::is_true(false) }
                }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * A struct `TypeDecl` whose body carries a static member `const` (#594 crumb 8, §4.10) round-trips:
 * the `consts` list survives with each member const's name, declared type, and visibility, so a
 * `pub`/`exp` member const crosses a `.tkb` with its owning type for cross-module `Type::NAME` reach.
 */
#test
fn tkb_roundtrip_member_const_struct() {
    let fld = parser::Field { name = "x"; type_ann = nt("i64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let consts: []parser::ConstDecl = teko::list::push(teko::list::empty(), member_const("ORIGIN", 9, parser::Visibility::Pub))
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = teko::list::empty(); implements = teko::list::empty(); consts = consts }
    let td = parser::TypeDecl { name = "Point"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let items: []checker::TItem = teko::list::push(teko::list::empty(), td)
    match deserialize_program(serialize_program(checker::TProgram { items = items })) {
        checker::TProgram as got => {
            teko::assert::is_true(got.items.len == 1)
            match got.items[0] {
                parser::TypeDecl as d => match d.body {
                    parser::StructBody as s => {
                        teko::assert::is_true(s.fields.len == 1)
                        teko::assert::is_true(s.consts.len == 1)
                        teko::assert::is_true(s.consts[0].name == "ORIGIN")
                        teko::assert::is_true(s.consts[0].vis == parser::Visibility::Pub)
                    }
                    _ => teko::assert::is_true(false)
                }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * A class and a trait `TypeDecl` each carrying static member consts (#594 crumb 8, §4.10) round-trip:
 * the `consts` list survives on both the `ClassBody` and the `TraitBody`, in declaration order.
 */
#test
fn tkb_roundtrip_member_const_class_trait() {
    let cconsts: []parser::ConstDecl = teko::list::push(teko::list::push(teko::list::empty(), member_const("CAP", 30, parser::Visibility::Pub)), member_const("HIDDEN", 1, parser::Visibility::Private))
    let cbody = parser::ClassBody { kind = parser::ClassKind::Sealed; has_base = false; base_name = ""; has_base_binding = false; base_binding_name = ""; implements = teko::list::empty(); fields = teko::list::empty(); methods = teko::list::empty(); consts = cconsts }
    let ctd = parser::TypeDecl { name = "Vault"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = cbody; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let tconsts: []parser::ConstDecl = teko::list::push(teko::list::empty(), member_const("ROLE", 2, parser::Visibility::Exp))
    let tbody = parser::TraitBody { fields = teko::list::empty(); methods = teko::list::empty(); consts = tconsts }
    let ttd = parser::TypeDecl { name = "Roled"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = tbody; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 2; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    mut items: []checker::TItem = teko::list::push(teko::list::empty(), ctd)
    items = teko::list::push(items, ttd)
    match deserialize_program(serialize_program(checker::TProgram { items = items })) {
        checker::TProgram as got => {
            teko::assert::is_true(got.items.len == 2)
            match got.items[0] {
                parser::TypeDecl as d => match d.body {
                    parser::ClassBody as c => {
                        teko::assert::is_true(c.consts.len == 2)
                        teko::assert::is_true(c.consts[0].name == "CAP")
                        teko::assert::is_true(c.consts[1].name == "HIDDEN")
                        teko::assert::is_true(c.consts[1].vis == parser::Visibility::Private)
                    }
                    _ => teko::assert::is_true(false)
                }
                _ => teko::assert::is_true(false)
            }
            match got.items[1] {
                parser::TypeDecl as d => match d.body {
                    parser::TraitBody as tb => {
                        teko::assert::is_true(tb.consts.len == 1)
                        teko::assert::is_true(tb.consts[0].name == "ROLE")
                        teko::assert::is_true(tb.consts[0].vis == parser::Visibility::Exp)
                    }
                    _ => teko::assert::is_true(false)
                }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * An aliased `use a::b as c` (S1, #335) round-trips through the `.tkb` codec: `has_alias`/`alias`
 * survive and the grouped-names list stays empty.
 */
#test
fn tkb_roundtrip_aliased_use() {
    let upath = parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "a" }), parser::Segment { name = "b" }) }
    let use1 = parser::UseDecl { path = upath; has_alias = true; alias = "c"; names = teko::list::empty() }
    let items: []checker::TItem = teko::list::push(teko::list::empty(), use1)
    let prog = checker::TProgram { items = items }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => {
            teko::assert::is_true(got.items.len == 1)
            match got.items[0] {
                parser::UseDecl as u => {
                    teko::assert::is_true(u.has_alias)
                    teko::assert::is_true(u.alias == "c")
                    teko::assert::is_true(u.path.segments.len == 2)
                    teko::assert::is_true(u.names.len == 0)
                }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/**
 * A grouped `use a::b::[ X, Y ]` (S1, #335) round-trips through the `.tkb` codec: the grouped names
 * are preserved, in order.
 */
#test
fn tkb_roundtrip_grouped_use_names() {
    let upath = parser::Path { segments = teko::list::push(teko::list::push(teko::list::empty(), parser::Segment { name = "a" }), parser::Segment { name = "b" }) }
    let names: []str = teko::list::push(teko::list::push(teko::list::empty(), "X"), "Y")
    let use1 = parser::UseDecl { path = upath; has_alias = false; alias = ""; names = names }
    let items: []checker::TItem = teko::list::push(teko::list::empty(), use1)
    let prog = checker::TProgram { items = items }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => {
            teko::assert::is_true(got.items.len == 1)
            match got.items[0] {
                parser::UseDecl as u => {
                    teko::assert::is_false(u.has_alias)
                    teko::assert::is_true(u.alias == "")
                    teko::assert::is_true(u.path.segments.len == 2)
                    teko::assert::is_true(u.names.len == 2)
                    teko::assert::is_true(u.names[0] == "X")
                    teko::assert::is_true(u.names[1] == "Y")
                }
                _ => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

/** (#165 C0) rewrite the version u32 (bytes 4..7, little-endian) of a serialized program frame to
    a chosen value WITHOUT touching the body — the FNV-1a hash covers only data[16:], so patching a
    header byte keeps the hash valid and lets the version guard be exercised in isolation. */
fn with_program_version(bytes: []byte, ver: byte) -> []byte {
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= bytes.len { break }
        if i == 4 { out = teko::list::push(out, ver) } else { out = teko::list::push(out, bytes[i]) }
        i++
    }
    out
}

/** a trivial one-item TProgram (a single `use`) — enough to serialize a valid v3 frame the version
    tests can re-stamp. */
fn trivial_program() -> checker::TProgram {
    let upath = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "teko" }) }
    let use1 = parser::UseDecl { path = upath; has_alias = false; alias = ""; names = teko::list::empty() }
    checker::TProgram { items = teko::list::push(teko::list::empty(), use1) }
}

#test
/** (#165 C0) a v2 program frame — the pre-#165 layout — must be REJECTED by the v3 reader
    (the added fields changed the body layout; reading v2 as v3 would mis-parse silently). */
fn tkb_rejects_v2_program() {
    let v3 = serialize_program(trivial_program())
    let v2 = with_program_version(v3, 2)
    match deserialize_program(v2) { checker::TProgram => teko::assert::is_true(false); error => teko::assert::is_true(true) }
    match deserialize_program(v3) { checker::TProgram as p => teko::assert::is_true(p.items.len == 1); error => teko::assert::is_true(false) }
}

/** (#165 C2) round-trip a ConstraintExpr in isolation through the same-namespace codec helpers
    (write_constraint/read_constraint) with a fresh string table + Reader — no program frame needed. */
fn roundtrip_constraint(c: parser::ConstraintExpr) -> parser::ConstraintExpr | error {
    let table = collect_constraint(st_empty(), c)
    let bytes = write_constraint(write_strtable(teko::list::empty(), table), table, c)
    let r0 = Reader { data = bytes; pos = 0 }
    let tbl = match read_strtable(r0) { RTable as x => x; error as e => return e }
    match read_constraint(tbl.r, tbl.value) { RConstraint as rc => rc.value; error as e => e }
}

#test
/** (#165 C2) `(Ord & Eq) | Clone` + NoConstraint round-trip with exact structure preserved. */
fn tkb_roundtrip_constraint() {
    let ord = parser::ConstraintAtom { name = "Ord" }
    let eq = parser::ConstraintAtom { name = "Eq" }
    let clone = parser::ConstraintAtom { name = "Clone" }
    let andc = parser::ConstraintAnd { left = ord; right = eq }
    let orc: parser::ConstraintExpr = parser::ConstraintOr { left = andc; right = clone }
    match roundtrip_constraint(orc) {
        parser::ConstraintExpr as v => match v {
            parser::ConstraintOr as o => {
                match o.left {
                    parser::ConstraintAnd as an => {
                        match an.left { parser::ConstraintAtom as a => teko::assert::is_true(a.name == "Ord"); _ => teko::assert::is_true(false) }
                        match an.right { parser::ConstraintAtom as a => teko::assert::is_true(a.name == "Eq"); _ => teko::assert::is_true(false) }
                    }
                    _ => teko::assert::is_true(false)
                }
                match o.right { parser::ConstraintAtom as a => teko::assert::is_true(a.name == "Clone"); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
    match roundtrip_constraint(parser::NoConstraint { }) {
        parser::ConstraintExpr as v => match v {
            parser::NoConstraint => teko::assert::is_true(true)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/** (#165 C3) a Named{T} typed leaf (a generic param used as an operand type). */
fn named_ty(name: str) -> checker::Type { checker::Named { name = name } }

#test
/** (#165 C3) `fn id<T: Ord>(x: T) -> T { return x }` — a generic fn crossing the codec:
    type_params == ["T"] and type_constraints == [Ord] (PARALLEL) must survive a program frame. */
fn tkb_roundtrip_generic_fn() {
    let tref = checker::TExpr { kind = checker::TVar { name = "x"; is_func = false; func_ns = "" }; type = named_ty("T"); line = 0; col = 0 }
    let prm = parser::Param { name = "x"; has_type = true; type_ann = nt("T"); is_params = false; has_default = false; default_expr = parser::no_expr() }
    mut body: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = tref })
    let tparams = teko::list::push(teko::list::empty(), "T")
    let tcons: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = "Ord" })
    let fn1 = checker::TFunction { name = "id"; type_params = tparams; type_constraints = tcons; params = teko::list::push(teko::list::empty(), prm); return_type = named_ty("T"); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; namespace = "m"; file = "m.tks"; line = 1; col = 1; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), fn1) }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => match got.items[0] {
            checker::TFunction as f => {
                teko::assert::is_true(f.type_params.len == 1)
                teko::assert::is_true(f.type_params[0] == "T")
                teko::assert::is_true(f.type_constraints.len == 1)
                match f.type_constraints[0] { parser::ConstraintAtom as a => teko::assert::is_true(a.name == "Ord"); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
/** (#165 C3) `type Box<T> = struct { v: T }` — a generic TypeDecl: type_params ride, and an
    absent constraint is the NoConstraint sentinel (parallel to type_params, same length). */
fn tkb_roundtrip_generic_type() {
    let fld = parser::Field { name = "v"; type_ann = nt("T"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    let tparams = teko::list::push(teko::list::empty(), "T")
    let tcons: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::NoConstraint { })
    let td = parser::TypeDecl { name = "Box"; type_params = tparams; type_constraints = tcons; body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), td) }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => match got.items[0] {
            parser::TypeDecl as d => {
                teko::assert::is_true(d.name == "Box")
                teko::assert::is_true(d.type_params.len == 1)
                teko::assert::is_true(d.type_params[0] == "T")
                teko::assert::is_true(d.type_constraints.len == 1)
                match d.type_constraints[0] { parser::NoConstraint => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/** (#165 C4) round-trip a lone parser::Function through the same-namespace codec helpers. */
fn roundtrip_function(f: parser::Function) -> parser::Function | error {
    let table = collect_function(st_empty(), f)
    let bytes = write_function(write_strtable(teko::list::empty(), table), table, f)
    let r0 = Reader { data = bytes; pos = 0 }
    let tbl = match read_strtable(r0) { RTable as x => x; error as e => return e }
    match read_function(tbl.r, tbl.value) { RFunction as rf => rf.value; error as e => e }
}

#test
/** (#165 C4) `virtual fn area(self) -> i64` under a `#os("linux")` guard — an instance method
    whose receiver is the untyped 1st param (has_type=false); every signature field + flag rides,
    the body is the honest signature-only stub (empty on read). */
fn tkb_roundtrip_method_sig() {
    let recv = parser::Param { name = "self"; has_type = false; type_ann = parser::no_type(); is_params = false; has_default = false; default_expr = parser::no_expr() }
    let m = parser::Function {
        name = "area"; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        params = teko::list::push(teko::list::empty(), recv)
        has_return = true; return_type = nt("i64"); body = teko::list::empty()
        vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 3; col = 5
        is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = "linux"
        is_intern = true; is_abstract = false; is_virtual = true; is_override = false
        has_inject = false; injects = teko::list::empty(); is_unsafe = false
    }
    match roundtrip_function(m) {
        parser::Function as f => {
            teko::assert::is_true(f.name == "area")
            teko::assert::is_true(f.params.len == 1)
            teko::assert::is_true(!f.params[0].has_type)
            teko::assert::is_true(f.params[0].name == "self")
            teko::assert::is_true(f.has_return)
            match f.return_type { parser::NamedType as n => teko::assert::is_true(n.path.segments[0].name == "i64"); _ => teko::assert::is_true(false) }
            teko::assert::is_true(f.body.len == 0)
            teko::assert::is_true(f.os_guard == "linux")
            teko::assert::is_true(f.is_intern)
            teko::assert::is_true(f.is_virtual)
            teko::assert::is_true(!f.is_abstract)
            teko::assert::is_true(!f.is_override)
            teko::assert::is_true(f.line == 3)
            teko::assert::is_true(f.col == 5)
        }
        error => teko::assert::is_true(false)
    }
}

#test
/** (U1, #332) is_unsafe = true round-trips through the .tkb codec's Function payload — the
    companion of tkb_roundtrip_method_sig (which only ever exercised is_unsafe = false). */
fn tkb_roundtrip_function_is_unsafe_true() {
    let m = parser::Function {
        name = "peek"; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        params = teko::list::empty()
        has_return = true; return_type = nt("i64"); body = teko::list::empty()
        vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1
        is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""
        is_intern = false; is_abstract = false; is_virtual = false; is_override = false
        has_inject = false; injects = teko::list::empty(); is_unsafe = true
    }
    match roundtrip_function(m) {
        parser::Function as f => teko::assert::is_true(f.is_unsafe)
        error => teko::assert::is_true(false)
    }
}

#test
/** (U1, #332) is_unsafe = true round-trips through the .tkb codec's TypeDecl payload — every
    existing tkb_test.tkt TypeDecl fixture only ever exercised is_unsafe = false. */
fn tkb_roundtrip_typedecl_is_unsafe_true() {
    let body = parser::StructBody { fields = teko::list::empty(); methods = teko::list::empty(); implements = teko::list::empty(); consts = teko::list::empty() }
    let td = parser::TypeDecl { name = "RawBuf"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = true; must_free = false }
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), td) }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => match got.items[0] {
            parser::TypeDecl as d => teko::assert::is_true(d.is_unsafe)
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/** (#165 C5) a bodyless instance-method signature `fn <name>(self)` — the receiver is the untyped
    1st param; helper for the struct/interface method-order fixtures. */
fn method_sig(name: str) -> parser::Function {
    let recv = parser::Param { name = "self"; has_type = false; type_ann = parser::no_type(); is_params = false; has_default = false; default_expr = parser::no_expr() }
    parser::Function {
        name = name; type_params = teko::list::empty(); type_constraints = teko::list::empty()
        params = teko::list::push(teko::list::empty(), recv)
        has_return = false; return_type = parser::no_type(); body = teko::list::empty()
        vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 0; col = 0
        is_test = false; is_extern = false; c_symbol = ""; from_lib = ""; os_guard = ""
        is_intern = false; is_abstract = false; is_virtual = false; is_override = false
        has_inject = false; injects = teko::list::empty(); is_unsafe = false
    }
}

#test
/** (#165 C5) a struct with two methods [greet, name] — before this crumb methods dropped to
    empty (invisible to a consuming project via seed_from_dep); the ORDER is the vtable contract. */
fn tkb_roundtrip_struct_with_methods() {
    let fld = parser::Field { name = "x"; type_ann = nt("i64"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    mut methods: []parser::Function = teko::list::push(teko::list::empty(), method_sig("greet"))
    methods = teko::list::push(methods, method_sig("name"))
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = methods; implements = teko::list::push(teko::list::empty(), "Named"); consts = teko::list::empty() }
    let td = parser::TypeDecl { name = "Point"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), td) }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => match got.items[0] {
            parser::TypeDecl as d => match d.body {
                parser::StructBody as s => {
                    teko::assert::is_true(s.fields.len == 1)
                    teko::assert::is_true(s.methods.len == 2)
                    teko::assert::is_true(s.methods[0].name == "greet")
                    teko::assert::is_true(s.methods[1].name == "name")
                    teko::assert::is_true(s.implements.len == 1)
                    teko::assert::is_true(s.implements[0] == "Named")
                }
                _ => teko::assert::is_true(false)
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
/** (#165 C5) an interface `Shape` extending `Drawable` with two methods [area, perimeter] —
    the method ORDER is the vtable-slot contract the cross-package D3 dispatch relies on. */
fn tkb_roundtrip_interface_methods() {
    mut methods: []parser::Function = teko::list::push(teko::list::empty(), method_sig("area"))
    methods = teko::list::push(methods, method_sig("perimeter"))
    let body = parser::InterfaceBody { extends = teko::list::push(teko::list::empty(), "Drawable"); methods = methods }
    let td = parser::TypeDecl { name = "Shape"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), td) }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => match got.items[0] {
            parser::TypeDecl as d => match d.body {
                parser::InterfaceBody as ib => {
                    teko::assert::is_true(ib.extends.len == 1)
                    teko::assert::is_true(ib.extends[0] == "Drawable")
                    teko::assert::is_true(ib.methods.len == 2)
                    teko::assert::is_true(ib.methods[0].name == "area")
                    teko::assert::is_true(ib.methods[1].name == "perimeter")
                }
                _ => teko::assert::is_true(false)
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
/** (#165 C5) a class `Circle` extending base `Shape` (binding `parent`) implementing `Drawable`
    with one method — kind + base + binding + implements + methods all ride (were all dropped). */
fn tkb_roundtrip_class_with_base_and_methods() {
    let fld = parser::Field { name = "r"; type_ann = nt("i64"); vis = parser::Visibility::Private; is_intern = true; has_doc = false; doc = "" }
    let body = parser::ClassBody {
        kind = parser::ClassKind::Virtual; has_base = true; base_name = "Shape"
        has_base_binding = true; base_binding_name = "parent"
        implements = teko::list::push(teko::list::empty(), "Drawable")
        fields = teko::list::push(teko::list::empty(), fld)
        methods = teko::list::push(teko::list::empty(), method_sig("area"))
        consts = teko::list::empty()
    }
    let td = parser::TypeDecl { name = "Circle"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
    let prog = checker::TProgram { items = teko::list::push(teko::list::empty(), td) }
    match deserialize_program(serialize_program(prog)) {
        checker::TProgram as got => match got.items[0] {
            parser::TypeDecl as d => match d.body {
                parser::ClassBody as c => {
                    teko::assert::is_true(c.kind == parser::ClassKind::Virtual)
                    teko::assert::is_true(c.has_base)
                    teko::assert::is_true(c.base_name == "Shape")
                    teko::assert::is_true(c.has_base_binding)
                    teko::assert::is_true(c.base_binding_name == "parent")
                    teko::assert::is_true(c.implements.len == 1)
                    teko::assert::is_true(c.implements[0] == "Drawable")
                    teko::assert::is_true(c.fields.len == 1)
                    teko::assert::is_true(c.fields[0].vis == parser::Visibility::Private)
                    teko::assert::is_true(c.fields[0].is_intern)
                    teko::assert::is_true(c.methods.len == 1)
                    teko::assert::is_true(c.methods[0].name == "area")
                }
                _ => teko::assert::is_true(false)
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_roundtrip_matchexpr() {
    // C7.16: `match x { 0 => return 1; Foo as y => return 2; _ => return 3 }` round-trips (match + 3 pattern kinds).
    let voidx = checker::TExpr { kind = checker::TNullLit { }; type = checker::Void { }; line = 0; col = 0 }   // placeholder guard (has_when=false)
    let subj = checker::TExpr { kind = checker::TVar { name = "x"; is_func = false; func_ns = "" }; type = i64ty(); line = 0; col = 0 }
    let lit0 = parser::Expr { kind = parser::Number { is_float = false; value = 0; fval = 0.0 }; line = 0; col = 0 }
    mut body0: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = tnum(1) })
    let arm0 = checker::TArm { pattern = parser::LiteralPattern { value = lit0 }; has_when = false; guard = voidx; body = body0 }
    let foopath = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "Foo" }) }
    mut body1: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = tnum(2) })
    let arm1 = checker::TArm { pattern = parser::BindPattern { type_name = foopath; has_binding = true; binding = "y"; is_slice = false; slice_type = null; type_args = teko::list::empty() }; has_when = false; guard = voidx; body = body1 }
    mut body2: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = tnum(3) })
    let arm2 = checker::TArm { pattern = parser::WildcardPattern { }; has_when = false; guard = voidx; body = body2 }
    mut arms: []checker::TArm = teko::list::empty()
    arms = teko::list::push(arms, arm0)
    arms = teko::list::push(arms, arm1)
    arms = teko::list::push(arms, arm2)
    let m = checker::TExpr { kind = checker::TMatchExpr { subject = subj; arms = arms }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(m)) {
        checker::TExpr as got => match got.kind {
            checker::TMatchExpr as mm => {
                teko::assert::is_true(mm.arms.len == 3)
                match mm.subject.kind { checker::TVar as v => teko::assert::is_true(v.name == "x"); _ => teko::assert::is_true(false) }
                match mm.arms[0].pattern { parser::LiteralPattern as l => match l.value.kind { parser::Number as n => teko::assert::is_true(n.value == 0); _ => teko::assert::is_true(false) }; _ => teko::assert::is_true(false) }
                match mm.arms[1].pattern {
                    parser::BindPattern as bp => {
                        teko::assert::is_true(bp.has_binding)
                        teko::assert::is_true(bp.binding == "y")
                        teko::assert::is_true(bp.type_name.segments[0].name == "Foo")
                    }
                    _ => teko::assert::is_true(false)
                }
                match mm.arms[2].pattern { parser::WildcardPattern => teko::assert::is_true(true); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn tkb_tamper_caught() {
    // barrier (M.1): a corrupted body (last byte dropped) fails the FNV-1a hash check → error.
    let orig = checker::TExpr { kind = checker::TCast { expr = tnum(7) }; type = u8ty(); line = 0; col = 0 }
    let bytes = serialize(orig)
    let short = drop_last(bytes)
    match deserialize(short) { checker::TExpr => teko::assert::is_true(false); error => teko::assert::is_true(true) }
}

#test
fn tkb_roundtrip_iface_dispatch_tag24() {
    // (W10b.D3) tag 24 — a DYNAMIC contract-method call must round-trip the fields the plain
    // call encoding (tag 7) does not carry: is_iface_dispatch, the resolved method Func (the
    // vtable cast signature), and the vtable slot. callee = [Shape, area]; receiver = args[0].
    let recv = checker::TExpr { kind = checker::TVar { name = "c"; is_func = false; func_ns = "" }; type = checker::Named { name = "Circle" }; line = 0; col = 0 }
    mut segs: []parser::Segment = teko::list::push(teko::list::empty(), parser::Segment { name = "Shape" })
    segs = teko::list::push(segs, parser::Segment { name = "area" })
    let params: []checker::Type = teko::list::push(teko::list::empty(), checker::Named { name = "Shape" })
    let pnames: []str = teko::list::push(teko::list::empty(), "self")
    let mft = checker::Func { params = params; ret = i64ty(); variadic = false; param_names = pnames; n_required = 1; defaults = teko::list::empty() }
    let args: []checker::TExpr = teko::list::push(teko::list::empty(), recv)
    let orig = checker::TExpr { kind = checker::TCall { callee = parser::Path { segments = segs }; args = args; call_ns = ""; is_closure_call = false; callee_type = mft; is_iface_dispatch = true; iface_slot = 1 }; type = i64ty(); line = 0; col = 0 }
    match deserialize(serialize(orig)) {
        checker::TExpr as got => match got.kind {
            checker::TCall as c => {
                teko::assert::is_true(c.is_iface_dispatch)
                teko::assert::is_true(c.iface_slot == 1)
                teko::assert::is_true(c.callee.segments.len == 2)
                teko::assert::is_true(c.callee.segments[0].name == "Shape")
                teko::assert::is_true(c.callee.segments[1].name == "area")
                // the method Func survives (params + ret — the codec's Func payload)
                match c.callee_type {
                    checker::Func as f => {
                        teko::assert::is_true(f.params.len == 1)
                        match f.params[0] { checker::Named as n => teko::assert::is_true(n.name == "Shape"); _ => teko::assert::is_true(false) }
                        match f.ret { checker::Prim as p => teko::assert::is_true(p.kind == checker::PrimKind::I64); _ => teko::assert::is_true(false) }
                    }
                    _ => teko::assert::is_true(false)
                }
                // the receiver rides as args[0], narrow class type intact
                teko::assert::is_true(c.args.len == 1)
                match c.args[0].kind { checker::TVar as v => teko::assert::is_true(v.name == "c"); _ => teko::assert::is_true(false) }
                match c.args[0].type { checker::Named as n => teko::assert::is_true(n.name == "Circle"); _ => teko::assert::is_true(false) }
            }
            _ => teko::assert::is_true(false)
        }
        error => teko::assert::is_true(false)
    }
}

/** ty_prim — an `i64` Prim, the leaf the descent tests wrap and re-read. */
fn ty_prim() -> checker::Type { checker::Prim { kind = checker::PrimKind::I64 } }
/** match_prim_arm — "prim" when `ty` is DIRECTLY a Prim, else "other". A bare outer-case arm over a
    `checker::Type` value: matches on the value's OWN case tag, no transparent wrapper-descent. Both
    engines agree on this nominal-direct outcome (native tag-match == the VM's own-case pat_match);
    the old form asserted the VM's runtime single-field-wrapper descent, which native — matching on
    the static union tag — cannot replicate, so the native gate (#265) surfaced it as a divergence. */
fn match_prim_arm(ty: checker::Type) -> str {
    match ty { checker::Prim => "prim"; _ => "other" }
}

#test
fn descent_multifield_sibling_no_descend() {
    let f: checker::Type = checker::Func { params = teko::list::empty(); ret = ty_prim(); variadic = false; param_names = teko::list::empty(); n_required = 0; defaults = teko::list::empty() }
    teko::assert::is_true(match_prim_arm(f) == "other")
}

#test
fn optional_wrapper_inner_is_prim() {
    let o: checker::Type = checker::Optional { inner = ty_prim() }
    let inner = match o { checker::Optional as opt => match_prim_arm(opt.inner); _ => "other" }
    teko::assert::is_true(inner == "prim")
}

#test
fn slice_wrapper_element_is_prim() {
    let s: checker::Type = checker::Slice { element = ty_prim() }
    let elem = match s { checker::Slice as sl => match_prim_arm(sl.element); _ => "other" }
    teko::assert::is_true(elem == "prim")
}

/** (#165 C7) whether two byte buffers are element-for-element equal (lengths + every byte). */
fn bytes_equal(a: []byte, b: []byte) -> bool {
    if a.len != b.len { return false }
    mut i: u64 = 0
    loop {
        if i >= a.len { break }
        if a[i] != b[i] { return false }
        i++
    }
    true
}

/**
 * A static type-member `const` declaration for the codec fixtures (#594 crumb 8): a `[vis] const
 * NAME: u8 = <val>` peer to a struct/class body's fields and methods. Its `init` is a bare literal —
 * the body codec does not serialize a member const's initializer (the value rides the hoisted
 * module-level TConstDecl), so a read-back member const carries `no_expr()`.
 *
 * @param name  the member const's name
 * @param val   the initializer literal's value
 * @param vis   the member const's visibility
 * @return      the parsed member const declaration
 */
fn member_const(name: str, val: i128, vis: parser::Visibility) -> parser::ConstDecl {
    let lit = parser::Expr { kind = parser::Number { is_float = false; value = val; fval = 0.0 }; line = 0; col = 0 }
    parser::ConstDecl { name = name; ty = nt("u8"); init = lit; vis = vis; has_doc = false; doc = ""; line = 3; col = 5 }
}

/** (#165 C7) a generic struct `type Box<T: Ord> = struct { v: T; exp const TAG: u8 = 7 }` carrying two
    methods [get, set], one implements ("Named"), and one static member const — exercises type_params +
    constraints + method order + the §4.10 `consts` list (#594 crumb 8). */
fn rich_generic_struct() -> parser::TypeDecl {
    let fld = parser::Field { name = "v"; type_ann = nt("T"); vis = parser::Visibility::Pub; is_intern = false; has_doc = false; doc = "" }
    mut methods: []parser::Function = teko::list::push(teko::list::empty(), method_sig("get"))
    methods = teko::list::push(methods, method_sig("set"))
    let consts: []parser::ConstDecl = teko::list::push(teko::list::empty(), member_const("TAG", 7, parser::Visibility::Exp))
    let body = parser::StructBody { fields = teko::list::push(teko::list::empty(), fld); methods = methods; implements = teko::list::push(teko::list::empty(), "Named"); consts = consts }
    let tcons: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = "Ord" })
    parser::TypeDecl { name = "Box"; type_params = teko::list::push(teko::list::empty(), "T"); type_constraints = tcons; body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 1; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
}

/** (#165 C7) an interface `Named` extending `Any` with two methods [name, rename] — the vtable
    contract whose method ORDER must survive the codec. */
fn rich_interface() -> parser::TypeDecl {
    mut methods: []parser::Function = teko::list::push(teko::list::empty(), method_sig("name"))
    methods = teko::list::push(methods, method_sig("rename"))
    let body = parser::InterfaceBody { extends = teko::list::push(teko::list::empty(), "Any"); methods = methods }
    parser::TypeDecl { name = "Named"; type_params = teko::list::empty(); type_constraints = teko::list::empty(); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; line = 5; col = 1; di_kind = parser::DiKind::None; has_di_key = false; di_key = ""; is_unsafe = false; must_free = false }
}

/** (#165 C7) a generic fn `fn pick<T: Ord>(x: T) -> T` whose body is a match over `x` with a
    `defer` — a generic top-level fn (TYPED body) crossing every statement kind the codec carries. */
fn rich_generic_fn() -> checker::TFunction {
    let voidx = checker::TExpr { kind = checker::TNullLit { }; type = checker::Void { }; line = 0; col = 0 }
    let subj = checker::TExpr { kind = checker::TVar { name = "x"; is_func = false; func_ns = "" }; type = named_ty("T"); line = 0; col = 0 }
    let lit0 = parser::Expr { kind = parser::Number { is_float = false; value = 0; fval = 0.0 }; line = 0; col = 0 }
    mut armbody: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = subj })
    let arm0 = checker::TArm { pattern = parser::LiteralPattern { value = lit0 }; has_when = false; guard = voidx; body = armbody }
    mut wildbody: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TReturn { has_value = true; value = subj })
    let arm1 = checker::TArm { pattern = parser::WildcardPattern { }; has_when = false; guard = voidx; body = wildbody }
    mut arms: []checker::TArm = teko::list::push(teko::list::empty(), arm0)
    arms = teko::list::push(arms, arm1)
    let mexpr = checker::TExpr { kind = checker::TMatchExpr { subject = subj; arms = arms }; type = named_ty("T"); line = 0; col = 0 }
    mut deferbody: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TExprStmt { expr = subj })
    mut body: []checker::TStatement = teko::list::push(teko::list::empty(), checker::TDeferStmt { body = deferbody })
    body = teko::list::push(body, checker::TExprStmt { expr = mexpr })
    let prm = parser::Param { name = "x"; has_type = true; type_ann = nt("T"); is_params = false; has_default = false; default_expr = parser::no_expr() }
    let tcons: []parser::ConstraintExpr = teko::list::push(teko::list::empty(), parser::ConstraintAtom { name = "Ord" })
    checker::TFunction { name = "pick"; type_params = teko::list::push(teko::list::empty(), "T"); type_constraints = tcons; params = teko::list::push(teko::list::empty(), prm); return_type = named_ty("T"); body = body; vis = parser::Visibility::Pub; has_doc = false; doc = ""; namespace = "m"; file = "m.tks"; line = 1; col = 1; is_test = false; is_extern = false; c_symbol = ""; from_lib = "" }
}

/** (#594 crumb 8) a module-level `exp const LIMIT: i64 = 255` TItem — a struct-of-existing-codecs
    (name, namespace, value type, typed initializer, vis, doc, line/col) whose typed initializer rides
    the `.tkb` in full so a consuming module inlines it identically. */
fn rich_module_const() -> checker::TConstDecl {
    checker::TConstDecl { name = "LIMIT"; namespace = "m"; ty = i64ty(); init = tnum(255); vis = parser::Visibility::Exp; has_doc = false; doc = ""; line = 9; col = 1 }
}

/** (#165 C7) a RICH TProgram: a `use`, a generic struct with methods + implements + a static member
    const, an interface (vtable order), a generic fn whose typed body carries a match + defer, and a
    module-level const TItem (#594 crumb 8). */
fn rich_program() -> checker::TProgram {
    let upath = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = "teko" }) }
    mut items: []checker::TItem = teko::list::push(teko::list::empty(), parser::UseDecl { path = upath; has_alias = false; alias = ""; names = teko::list::empty() })
    items = teko::list::push(items, rich_generic_struct())
    items = teko::list::push(items, rich_interface())
    items = teko::list::push(items, rich_generic_fn())
    items = teko::list::push(items, rich_module_const())
    checker::TProgram { items = items }
}

#test
/** (#165 C7 — ACCEPT) full-fidelity round-trip: serialize a rich program, deserialize, then
    RE-serialize; the two byte-arrays must be identical. Any dropped field (call_ns, type_params,
    constraints, methods, flags) mutates the second pass, so byte-identity is the total-fidelity gate. */
fn tkb_roundtrip_program_byte_identical() {
    let first = serialize_program(rich_program())
    match deserialize_program(first) {
        checker::TProgram as prog => {
            let second = serialize_program(prog)
            teko::assert::is_true(bytes_equal(first, second))
        }
        error => teko::assert::is_true(false)
    }
}
