// src/runtime/teko_rt_test.tkt — tests for teko::runtime. #test collected (no `main`).
//
// The runtime is the metal bottom: its true surface (print/println, the panics) bottoms
// out at the DEFERRED host write/abort (the FFI edge — C1), so it CANNOT be unit-tested in
// the seed directly. What IS testable today is the OBSERVABLE behavior the checked guards
// and the str view must preserve — exercised through `teko::assert::*` (the same builtin the
// VM routes to the runtime, so a passing test round-trips the runtime's assert/print path).
//
// NOTE (M.3 — honest). The barrier (panic) cases — ÷0, impossible cast, the panics
// themselves — are verified END-TO-END through the real front-end + VM/native in the crumb's
// VERIFY step (a panic-capture harness does not exist in the runner yet); here they are
// asserted via their NEGATION (the NON-panicking side) where expressible.

// Checked division/modulo with a non-zero divisor: no panic, ordinary result (div/mod).
#test
fn checked_div_mod_no_panic() {
    teko::assert::is_true(84 / 2 == 42)       // div: non-zero divisor → result, no panic_div0
    teko::assert::is_true(85 % 43 == 42)      // mod: non-zero divisor → result, no panic_div0
}

// Checked narrowing cast that FITS the target: no panic (the panic_cast side is the barrier).
#test
fn checked_cast_in_range_no_panic() {
    teko::assert::is_true((255 to u8) == 255) // 255 fits u8 → no panic_cast
    teko::assert::is_true((0 to u8) == 0)     // lower edge fits
}

// str is a byte VIEW; str_contains is the substring scan the runtime/assert seed share.
#test
fn str_view_contains() {
    teko::assert::str_contains("hello", "ell") // present
    teko::assert::str_contains("hello", "")    // empty needle ⊆ any hay
    teko::assert::is_false(teko::str::contains("hello", "xyz")) // absent → would be the panic side
}

// teko::string::concat / concat3 — the LEGISLATED public string-building API
// (TEKO_LEGISLATION.md "`+` never concatenates": string building is `string::concat` /
// interpolation `$"..."`, never `+`). Resolved by LAST PATH SEGMENT (same mechanism as
// str_concat / teko::str::concat above) — `teko::string::concat` is simply another spelling
// of the same builtin dispatch, proven here under its legislated namespace/name.
#test
fn string_concat_two() {
    let s = teko::string::concat("hello", " world")
    teko::assert::is_true(teko::str::contains(s, "hello world"))
    teko::assert::is_true(s.len == 11)
}

#test
fn string_concat_empty_operands() {
    teko::assert::is_true(teko::string::concat("", "").len == 0)
    teko::assert::is_true(teko::string::concat("abc", "").len == 3)
    teko::assert::is_true(teko::string::concat("", "abc").len == 3)
}

// concat3 — the multi-arg (3-piece) answer. Teko has no variadic parameters (a fixed
// `<T>`-generic or fixed-arity param list is the only function-declaration shape — see
// TEKO_LEGISLATION.md's function grammar), so a fixed 3-ary overload is the ergonomic
// form for a small, known number of pieces (see concat_all below for an ARBITRARY count).
#test
fn string_concat3_three() {
    let s = teko::string::concat3("foo", "-", "bar")
    teko::assert::is_true(teko::str::contains(s, "foo-bar"))
    teko::assert::is_true(s.len == 7)
}

// concat_all([]str) -> str — the loop-friendly many-piece answer: folds teko::string::concat
// over a slice. NOT a new builtin (no checker/codegen/VM changes) — expressible entirely in
// terms of the concat primitive, so it lives as an ordinary user-space fold, matching the
// "no variadic params" constraint honestly (M.3) instead of inventing new call-syntax.
fn concat_all(pieces: []str) -> str {
    mut acc = ""
    mut i: u64 = 0
    loop {
        if i >= pieces.len { break }
        acc = teko::string::concat(acc, pieces[i])
        i++
    }
    acc
}

#test
fn string_concat_all_many_pieces() {
    let parts: []str = teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::push(teko::list::empty(), "a"), "b"), "c"), "d"), "e")
    let s = concat_all(parts)
    teko::assert::is_true(s.len == 5)
    teko::assert::is_true(teko::str::contains(s, "abcde"))
}

#test
fn string_concat_all_empty_slice() {
    let none: []str = teko::list::empty()
    teko::assert::is_true(concat_all(none).len == 0)
}

// Direct calls to teko::runtime functions that are coverable through find_function.
// These are NOT intercepted as builtins (unlike print/str_concat/etc.) so they
// ARE reachable and countable for coverage.

#test
fn runtime_div_mod_direct() {
    // teko::runtime::div and mod (the checked helpers)
    let d = teko::runtime::div(84, 2)
    teko::assert::is_true(d == 42)
    let m = teko::runtime::mod(85, 43)
    teko::assert::is_true(m == 42)
}

#test
fn runtime_to_u8_direct() {
    // teko::runtime::to_u8 — in-range value returns the byte
    let b = teko::runtime::to_u8(65)
    teko::assert::is_true(b == 65)
    let b0 = teko::runtime::to_u8(0)
    teko::assert::is_true(b0 == 0)
    let b255 = teko::runtime::to_u8(255)
    teko::assert::is_true(b255 == 255)
}

#test
fn runtime_str_functions_direct() {
    // teko::runtime::str_eq
    teko::assert::is_true(teko::runtime::str_eq("hello", "hello"))
    teko::assert::is_false(teko::runtime::str_eq("hello", "world"))

    // teko::runtime::str_len
    let n = teko::runtime::str_len("hello")
    teko::assert::is_true(n == 5)
    let n0 = teko::runtime::str_len("")
    teko::assert::is_true(n0 == 0)

    // teko::runtime::str_slice
    let sl = teko::runtime::str_slice("hello", 1, 3)
    teko::assert::is_true(sl == "el")

    // teko::runtime::str_slice_to
    let sto = teko::runtime::str_slice_to("hello", 3)
    teko::assert::is_true(sto == "hel")

    // teko::runtime::str_slice_from
    let sfr = teko::runtime::str_slice_from("hello", 2)
    teko::assert::is_true(sfr == "llo")

    // teko::runtime::str_ends_with
    teko::assert::is_true(teko::runtime::str_ends_with("hello", "llo"))
    teko::assert::is_false(teko::runtime::str_ends_with("hello", "ell"))

    // teko::runtime::str_contains (the runtime function, not the builtin path)
    teko::assert::is_true(teko::runtime::str_contains("hello", "ell"))
    teko::assert::is_false(teko::runtime::str_contains("hello", "xyz"))
}

#test
fn runtime_float_parse_direct() {
    // teko::runtime::float_parse — parses a decimal float string
    let f = teko::runtime::float_parse("3.14")
    teko::assert::is_true(f > 3.0)
    teko::assert::is_true(f < 4.0)
    let fz = teko::runtime::float_parse("0.0")
    teko::assert::is_true(fz == 0.0)
}

// (S1) Arena primitive proof. Teko has NO raw-pointer surface, so region_alloc is exercised
// INDIRECTLY through the observable allocation-heavy paths it now backs. Any bump-offset
// off-by-one, lost chunk, mis-aligned write, or truncated cross-chunk copy surfaces here as a
// failed spot-check. (1) List copy-grow drives the native tk_slice_push -> tk_alloc path; (2)
// the str_concat/u64_to_str fold drives teko::runtime str builders -> tk_alloc, accumulating
// past the 64 KiB default chunk so the new-chunk + big-alloc paths are crossed under the VM gate.
#test
fn region_backed_alloc_stress() {
    mut xs: []u64 = teko::list::empty()
    mut i: u64 = 0
    loop {
        if i >= 500 { break }
        xs = teko::list::push(xs, i)
        i++
    }
    teko::assert::is_true(xs.len == 500)
    teko::assert::is_true(xs[0] == 0)
    teko::assert::is_true(xs[250] == 250)
    teko::assert::is_true(xs[499] == 499)

    mut acc = ""
    mut j: u64 = 0
    loop {
        if j >= 300 { break }
        acc = teko::runtime::str_concat(acc, teko::runtime::u64_to_str(j))
        j++
    }
    teko::assert::is_true(teko::runtime::str_contains(acc, "100"))
    teko::assert::is_true(teko::runtime::str_len(acc) > 300)
}
