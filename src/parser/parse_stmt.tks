// src/parser/parse_stmt.tks   (namespace 'teko::parser')

use teko::lexer

// dispatch a statement. P4a: `return [expr]` and a bare-expression statement. P4b–P4d add
// bindings, assignment, loop/break/continue.
fn parse_statement(tokens: []lexer::Token, pos: u64) -> Parsed<Statement> | error {
    if !has_token(tokens, pos) { return err_at(tokens, pos, "expected a statement") }
    if is_kind_at(tokens, pos, lexer::TokenKind::Return) {
        // `return` with an optional value: bare `return` ends at a separator or `}`.
        let after = pos + 1
        if !has_token(tokens, after) || is_sep(tokens, after) || is_kind_at(tokens, after, lexer::TokenKind::RBrace) {
            return Parsed<Statement> { node = Return { has_value = false; value = Expr { kind = Number { is_float = false; value = 0; fval = 0.0 }; line = 0; col = 0 } }; next = after }   // (C1-POS) placeholder value — gated by has_value, position unknown (0)
        }
        let v = match parse_expr(tokens, after) { Parsed<Expr> as x => x; error as e => return e }
        return Parsed<Statement> { node = Return { has_value = true; value = v.node }; next = v.next }
    }
    if is_kind_at(tokens, pos, lexer::TokenKind::Loop) {
        // optional label: `loop NAME { … }` (an IDENT right after `loop`, before the brace)
        mut label = ""
        mut lbrace = pos + 1
        if is_kind_at(tokens, pos + 1, lexer::TokenKind::Ident) { label = tokens[pos + 1].text; lbrace = pos + 2 }
        if !is_kind_at(tokens, lbrace, lexer::TokenKind::LBrace) {
            return err_at(tokens, lbrace, "expected '{' after `loop`")
        }
        let blk = match parse_block(tokens, lbrace) { ParsedList<Statement> as x => x; error as e => return e }
        return Parsed<Statement> { node = LoopStmt { label = label; body = blk.items }; next = blk.next }
    }
    if is_kind_at(tokens, pos, lexer::TokenKind::Break) {
        // optional label on the SAME line: `break NAME` (a separator would tokenize between)
        mut label = ""
        mut next = pos + 1
        if is_kind_at(tokens, pos + 1, lexer::TokenKind::Ident) { label = tokens[pos + 1].text; next = pos + 2 }
        return Parsed<Statement> { node = BreakStmt { label = label }; next = next }
    }
    if is_kind_at(tokens, pos, lexer::TokenKind::Continue) {
        mut label = ""
        mut next = pos + 1
        if is_kind_at(tokens, pos + 1, lexer::TokenKind::Ident) { label = tokens[pos + 1].text; next = pos + 2 }
        return Parsed<Statement> { node = ContinueStmt { label = label }; next = next }
    }
    if is_kind_at(tokens, pos, lexer::TokenKind::Defer) {
        // `defer { stmts }` — a mandatory block must follow immediately (C7.18).
        let lbrace = pos + 1
        if !is_kind_at(tokens, lbrace, lexer::TokenKind::LBrace) {
            return err_at(tokens, lbrace, "expected '{' after `defer`")
        }
        let blk = match parse_block(tokens, lbrace) { ParsedList<Statement> as x => x; error as e => return e }
        return Parsed<Statement> { node = DeferStmt { body = blk.items }; next = blk.next }
    }
    if is_kind_at(tokens, pos, lexer::TokenKind::Let) || is_kind_at(tokens, pos, lexer::TokenKind::Mut) || is_kind_at(tokens, pos, lexer::TokenKind::Const) {
        return parse_binding(tokens, pos)
    }
    if is_kind_at(tokens, pos, lexer::TokenKind::Ident) && is_assign_op(tokens, pos + 1) {
        return parse_assign(tokens, pos)
    }
    // `i++` / `i--` — postfix increment/decrement STATEMENT sugar: desugar to the compound
    // assignment `i += 1` / `i -= 1` (reuses assign typing/codegen/VM; mut-guard included).
    if is_kind_at(tokens, pos, lexer::TokenKind::Ident) &&
    (is_kind_at(tokens, pos + 1, lexer::TokenKind::PlusPlus) || is_kind_at(tokens, pos + 1, lexer::TokenKind::MinusMinus)) {
        let op = if is_kind_at(tokens, pos + 1, lexer::TokenKind::PlusPlus) { lexer::TokenKind::PlusEq } else { lexer::TokenKind::MinusEq }
        return Parsed<Statement> { node = Assign { kind = AssignKind::Simple; name = tokens[pos].text; op = op; value = Expr { kind = Number { is_float = false; value = 1; fval = 0.0 }; line = 0; col = 0 }; deref = false; target = no_expr() }; next = pos + 2 }   // (C1-POS) synthesized `1` for the `i++`/`i--` desugar — not stamped in the C twin (position unknown, 0)
    }
    // (#88) a general FIELD/deref-assign target: parse a full postfix EXPRESSION, then — if it is a
    // field-access path (`recv.field`, possibly nested / indexed) AND an assign-op follows — treat it as
    // an assignment target. Subsumes the old hardcoded `name.value op= …` (MEM-1b-ii) shape: the TYPER
    // decides Ref-deref (`r.value` on a `Ref<T>`) vs a struct/class field write from the receiver TYPE.
    // A field-access with NO assign-op, and any non-field expr (e.g. `obj.m()`), fall through to the
    // expr-statement below UNCHANGED — method-call statements are never swallowed.
    let e = match parse_expr(tokens, pos) { Parsed<Expr> as x => x; error as e => return e }
    let is_field = match e.node.kind { FieldAccess as _fa => true; _ => false }
    if is_field && is_assign_op(tokens, e.next) {
        let op = kind_at(tokens, e.next)
        let v = match parse_expr(tokens, e.next + 1) { Parsed<Expr> as x => x; error as er => return er }
        return Parsed<Statement> { node = Assign { kind = AssignKind::Field; name = ""; op = op; value = v.node; deref = false; target = e.node }; next = v.next }
    }
    Parsed<Statement> { node = ExprStmt { expr = e.node }; next = e.next }
}

// a `{ … }` block: a sequence of statements, `;`/newline separated; empty `{ }` allowed;
// trailing separator allowed. `pos` is at `{`. (Same separator shape as field lists — B.17.)
fn parse_block(tokens: []lexer::Token, pos: u64) -> ParsedList<Statement> | error {
    mut p = skip_seps(tokens, pos + 1)   // consume `{`, skip leading separators
    mut stmts: []Statement = teko::list::empty()
    loop {
        if is_kind_at(tokens, p, lexer::TokenKind::RBrace) { break }
        let s = match parse_statement(tokens, p) { Parsed<Statement> as x => x; error as e => return e }
        stmts = teko::list::push(stmts, s.node)
        p = s.next
        if is_kind_at(tokens, p, lexer::TokenKind::RBrace) { break }
        if !is_sep(tokens, p) {
            return err_at(tokens, p, "expected ';', a newline, or '}' after a statement")
        }
        p = skip_seps(tokens, p)
    }
    ParsedList<Statement> { items = stmts; next = p + 1 }   // consume `}`
}

// a placeholder TypeExpr for an absent annotation (never read — gated by has_type).
fn no_type() -> TypeExpr {
    NamedType { path = Path { segments = teko::list::empty() }; args = teko::list::empty() }
}

// (2026-07-01 DEFARGS) a placeholder Expr for Param.default_expr when has_default=false —
// never evaluated, mirrors no_type()'s sentinel convention.
pub fn no_expr() -> Expr {
    Expr { kind = NullLit { }; line = 0; col = 0 }
}

// an optional `: T` annotation. Absent → has_type=false (type_ann a placeholder). `pos`
// is where the `:` would be.
fn parse_annotation(tokens: []lexer::Token, pos: u64) -> Annotation | error {
    if !is_kind_at(tokens, pos, lexer::TokenKind::Colon) {
        return Annotation { has_type = false; type_ann = no_type(); next = pos }
    }
    let ty = match parse_type(tokens, pos + 1) { ParsedType as x => x; error as e => return e }
    Annotation { has_type = true; type_ann = ty.node; next = ty.next }
}

// `let|mut|const TARGET [: T] = value` (B.13, B.21). TARGET is a name or a destructure
// `{ x; y }` (parse_bind_target).
fn parse_binding(tokens: []lexer::Token, pos: u64) -> Parsed<Statement> | error {
    let kw = kind_at(tokens, pos)
    mut kind = BindKind::Let
    if kw == lexer::TokenKind::Mut { kind = BindKind::Mut }
    if kw == lexer::TokenKind::Const { kind = BindKind::Const }
    let tgt = match parse_bind_target(tokens, pos + 1) { Parsed<BindTarget> as x => x; error as e => return e }
    let ann = match parse_annotation(tokens, tgt.next) { Annotation as x => x; error as e => return e }
    if !is_kind_at(tokens, ann.next, lexer::TokenKind::Assign) {
        return err_at(tokens, ann.next, "expected '=' in a binding")
    }
    let v = match parse_expr(tokens, ann.next + 1) { Parsed<Expr> as x => x; error as e => return e }
    Parsed<Statement> { node = Binding { kind = kind; target = tgt.node; has_type = ann.has_type; type_ann = ann.type_ann; value = v.node }; next = v.next }
}

// a binding target: a simple name or a destructure `{ x; y }` (B.13). `pos` after the kw.
// Reuses parse_field_names for the `{ … }` name list.
fn parse_bind_target(tokens: []lexer::Token, pos: u64) -> Parsed<BindTarget> | error {
    if is_kind_at(tokens, pos, lexer::TokenKind::LBrace) {
        let names = match parse_field_names(tokens, pos) { ParsedList<str> as x => x; error as e => return e }
        return Parsed<BindTarget> { node = DestructurePattern { names = names.items }; next = names.next }
    }
    // `let _ = expr` — DISCARD binding: evaluate the value for effect, bind nothing. A SIMPLE
    // target named "_" (the wildcard); codegen lowers it to `(void)(expr);` (no C variable, so
    // repeated `let _` never collides), and it is never read. (B.21 — explicit ignore.)
    if !is_name_at(tokens, pos) && !is_kind_at(tokens, pos, lexer::TokenKind::Underscore) {
        return err_at(tokens, pos, "expected a name, `_`, or `{ … }` after `let`/`mut`/`const`")
    }
    Parsed<BindTarget> { node = SimpleName { name = tokens[pos].text }; next = pos + 1 }
}

// `name op= value` (B.4 — assignment is statement-only). Simple-name target; the op
// (= += -= …) is captured. (is_assign_op already checked at dispatch.)
fn parse_assign(tokens: []lexer::Token, pos: u64) -> Parsed<Statement> | error {
    let name = tokens[pos].text
    let op = kind_at(tokens, pos + 1)
    let v = match parse_expr(tokens, pos + 2) { Parsed<Expr> as x => x; error as e => return e }
    Parsed<Statement> { node = Assign { kind = AssignKind::Simple; name = name; op = op; value = v.node; deref = false; target = no_expr() }; next = v.next }
}

// (added to parse_statement, P4d; labels — M.5)
//   loop [NAME] { body } → LoopStmt { label = NAME?, body = <block> }   (reuses parse_block)
//   break [NAME]         → BreakStmt { label = NAME? }
//   continue [NAME]      → ContinueStmt { label = NAME? }
// (label empty "" = unlabeled / innermost loop)
