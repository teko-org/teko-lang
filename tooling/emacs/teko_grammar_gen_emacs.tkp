# tooling/emacs/teko_grammar_gen_emacs.tkp — the A4 Emacs major-mode generator
# (TEKO_ROADMAP_TOOLING.md, Eixo A). Reads A1's tooling/shared/grammar-spec.json and writes
# tooling/emacs/teko-mode.el.
#
# Build + run (native only — extern fns for file I/O are VM-unsupported):
#   teko build tooling/emacs -o tooling/emacs/bin
#   tooling/emacs/bin/teko_grammar_gen_emacs [repo-root]   # default repo-root: "."
name = "teko_grammar_gen_emacs"
source = "src"

[artifact]
kind = "binary"
