{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Teko",
  "scopeName": "source.tks",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#literals" },
    { "include": "#keywords" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.block.documentation.teko", "match": "\\/\\*\\*[\\s\\S]*?\\*/" },
        { "name": "comment.block.teko", "match": "\\/\\*[\\s\\S]*?\\*/" },
        { "name": "comment.line.double-slash.teko", "match": "\\/\\/.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.teko", "match": "\"(\\\\.|[^\\\\\"])*\"" }
      ]
    },
    "literals": {
      "patterns": [
        { "name": "constant.character.teko", "match": "\\b(b|c)'(\\\\.|[^\\\\'])*'" },
        { "name": "constant.numeric.teko", "match": "\\b0[bB][01_]+\\b" },
        { "name": "constant.numeric.teko", "match": "\\b0[xX][0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.teko", "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9][0-9_]*)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.teko", "match": "\\b(interface|abstract|continue|override|variant|virtual|extern|intern|return|struct|break|class|const|defer|false|flags|match|else|enum|loop|null|true|type|when|exp|let|mut|pub|use|as|fn|if|in|to)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.teko", "match": "<<=|>>=|\\.\\.=|==|=>|!=|<=|>=|<<|>>|->|::|&&|\\|\\||\\+\\+|--|\\+=|-=|\\*=|\\/=|%=|&=|\\|=|\\^=|\\?\\?|\\?\\.|\\.\\.|\\+|-|\\*|\\/|%|&|\\||\\^|~|!|<|>|=|:|;|,|\\.|\\(|\\)|\\{|\\}|\\[|\\]|\\?|#" }
      ]
    }
  }
}
